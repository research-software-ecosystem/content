galaxytool:nanocompore a schema1:SoftwareApplication ;
    schema1:applicationSubCategory "edam:topic_0659",
        "edam:topic_0749",
        "edam:topic_3170",
        "edam:topic_3308",
        "edam:topic_3512" ;
    schema1:description "Nanocompore compares 2 ONT nanopore direct RNA sequencing datasets from different experimental conditions expected to have a significant impact on RNA modifications. It is recommended to have at least 2 replicates per condition. For example one can use a control condition with a significantly reduced number of modifications such as a cell line for which a modification writing enzyme was knocked-down or knocked-out. Alternatively, on a smaller scale transcripts of interests could be synthesized in-vitro." ;
    schema1:featureList edam:operation_0428,
        edam:operation_3196,
