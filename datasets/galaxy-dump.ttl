        "galaxywf:workflow?id=ce5c16ac23c4fbb1",
        "galaxywf:workflow?id=f33b5135ee99e0dc",
        "galaxywf:workflow?id=fc0b9efa7d2e61e6",
        "workflowhub:100?version=1",
        "workflowhub:102?version=1",
        "workflowhub:1480?version=1",
        "workflowhub:1631?version=1" ;
    schema1:keywords "SAM" ;
    schema1:name "ngsutils" ;
    schema1:url "https://github.com/ngsutils/ngsutils" .

