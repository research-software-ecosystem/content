galaxytool:cutesv a schema1:SoftwareApplication ;
    schema1:applicationSubCategory "edam:topic_3168",
        "edam:topic_3316" ;
    schema1:description "Long-read sequencing enables the comprehensive discovery of structural variations (SVs). However, it is still non-trivial to achieve high sensitivity and performance simultaneously due to the complex SV characteristics implied by noisy long reads. Therefore, we propose cuteSV, a sensitive, fast and scalable long-read-based SV detection approach. cuteSV uses tailored methods to collect the signatures of various types of SVs and employs a clustering-and-refinement method to analyze the signatures to implement sensitive SV detection. Benchmarks on real Pacific Biosciences (PacBio) and Oxford Nanopore Technology (ONT) datasets demonstrate that cuteSV has better yields and scalability than state-of-the-art tools." ;
    schema1:featureList edam:operation_3196,
        edam:operation_3199,
        edam:operation_3228 ;
    schema1:identifier "bioconda:cutesv",
        "biotools:cuteSV" ;
    schema1:keywords "Variant Analysis" ;
    schema1:name "cutesv" ;
    schema1:softwareVersion "2.1.3" ;
    schema1:url "https://github.com/tjiangHIT/cuteSV" .

