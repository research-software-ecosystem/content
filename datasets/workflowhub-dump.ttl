        <https://workflowhub.eu/workflows/356#generic_consensus_construction_from_vcf_calls-outputs-chrom_pos_ref_failed_variants>,
        <https://workflowhub.eu/workflows/356#generic_consensus_construction_from_vcf_calls-outputs-chrom_pos_ref_failed_variants_with_0_based_start>,
        <https://workflowhub.eu/workflows/356#generic_consensus_construction_from_vcf_calls-outputs-chrom_pos_ref_failed_variants_with_0_based_start_end>,
