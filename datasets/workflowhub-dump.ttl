        <https://workflowhub.eu/workflows/247#protein_ligand_complex_parameterization_main-inputs-%23main/Water%20model>,
        <https://workflowhub.eu/workflows/247#protein_ligand_complex_parameterization_main-inputs-%23main/pH> ;
    ns1:isBasedOn <https://workflowhub.eu/workflows/247?version=1> ;
    ns1:keywords "" ;
    ns1:license <https://spdx.org/licenses/MIT> ;
    ns1:name "protein-ligand-complex-parameterization/main" ;
