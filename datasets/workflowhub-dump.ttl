<https://workflowhub.eu/workflows/510?version=2> a ns1:ComputationalWorkflow,
        ns1:SoftwareSourceCode ;
    dcterms:conformsTo <https://bioschemas.org/profiles/ComputationalWorkflow/1.0-RELEASE/> ;
    ns1:creator <https://orcid.org/0000-0001-6966-0814>,
        <https://orcid.org/0000-0001-9359-7149>,
        <https://orcid.org/0000-0002-4321-0257>,
