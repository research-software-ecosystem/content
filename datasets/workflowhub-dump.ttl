        <https://workflowhub.eu/workflows/354#generic_variation_analysis_reporting-outputs-combined_variant_report>,
        <https://workflowhub.eu/workflows/354#generic_variation_analysis_reporting-outputs-filtered_extracted_variants>,
        <https://workflowhub.eu/workflows/354#generic_variation_analysis_reporting-outputs-filtered_variants>,
        <https://workflowhub.eu/workflows/354#generic_variation_analysis_reporting-outputs-highest_impact_effects>,
        <https://workflowhub.eu/workflows/354#generic_variation_analysis_reporting-outputs-prefiltered_variants>,
        <https://workflowhub.eu/workflows/354#generic_variation_analysis_reporting-outputs-processed_variants_collection>,
        <https://workflowhub.eu/workflows/354#generic_variation_analysis_reporting-outputs-variants_for_plotting> ;
