    ns1:keywords "OME-Zarr, Python, imaging, image processing, Machine Learning, S3" ;
    ns1:license <https://spdx.org/licenses/BSD-2-Clause> ;
    ns1:name "Load ome.zarr Image with labels from public S3 repositories, analyze in parallel using Cellpose and compare results" ;
    ns1:producer <https://workflowhub.eu/projects/69> ;
    ns1:sdPublisher <https://about.workflowhub.eu/> ;
