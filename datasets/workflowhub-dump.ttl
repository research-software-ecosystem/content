    ns1:name "RATECE-PLANICA ski station (Slovenia) under CMIP-6 SSP585 condition" ;
    ns1:producer <https://workflowhub.eu/projects/18> ;
    ns1:programmingLanguage <https://workflowhub.eu/workflows/47#jupyter> ;
    ns1:sdPublisher <https://about.workflowhub.eu/> ;
