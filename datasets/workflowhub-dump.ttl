<https://workflowhub.eu/workflows/259?version=3> a ns1:ComputationalWorkflow,
        ns1:SoftwareSourceCode ;
    dcterms:conformsTo <https://bioschemas.org/profiles/ComputationalWorkflow/1.0-RELEASE/> ;
