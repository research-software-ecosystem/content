<https://workflowhub.eu/workflows/193#workflow_of_biotranslator_comparative_analysis-inputs-Input%20sets%20of%20genes> a ns1:FormalParameter ;
    dcterms:conformsTo <https://bioschemas.org/profiles/FormalParameter/1.0-RELEASE/> ;
    ns1:name "Input sets of genes" .

