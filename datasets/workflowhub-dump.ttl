    ns1:name "Cell Lineage in the adult mouse corpus callosum" ;
    ns1:producer <https://workflowhub.eu/projects/69> ;
    ns1:programmingLanguage <https://workflowhub.eu/workflows/267#jupyter> ;
    ns1:sdPublisher <https://about.workflowhub.eu/> ;
    ns1:url <https://workflowhub.eu/workflows/267?version=1> ;
    ns1:version 1 .

