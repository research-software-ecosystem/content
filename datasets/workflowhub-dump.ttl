<https://workflowhub.eu/workflows/3?version=1> a ns1:ComputationalWorkflow,
        ns1:SoftwareSourceCode ;
    dcterms:conformsTo <https://bioschemas.org/profiles/ComputationalWorkflow/1.0-RELEASE/> ;
    ns1:dateCreated "2020-04-10T10:45:00Z"^^ns1:Date ;
    ns1:dateModified "2023-01-16T13:39:45Z"^^ns1:Date ;
    ns1:description """Virus genome assembly with Unicycler and Spades,
The 2 assemblers works in parallel. The graph  visualization is made with Bandage.
