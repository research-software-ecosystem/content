        <https://workflowhub.eu/workflows/400#rnaseq_sr_main-outputs-Transcripts%20Expression%20from%20Cufflinks>,
        <https://workflowhub.eu/workflows/400#rnaseq_sr_main-outputs-Unstranded%20Coverage> ;
