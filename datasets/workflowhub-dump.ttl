    ns1:keywords "Bioinformatics, Luigi &amp; Rufus workflow, Pathway co-occurrence, Gene ontology term sets similarity, Domain-Domain interaction" ;
    ns1:license <https://spdx.org/licenses/MIT> ;
    ns1:name "PredPrIn - Scientific workflow to predict protein-protein interactions based in a combined analysis of multiple protein characteristics." ;
