    ns1:identifier <https://www.nextflow.io/> ;
    ns1:name "Nextflow" ;
    ns1:url <https://www.nextflow.io/> .

<https://workflowhub.eu/workflows/340?version=1> a ns1:ComputationalWorkflow,
        ns1:SoftwareSourceCode ;
