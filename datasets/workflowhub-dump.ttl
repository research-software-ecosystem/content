    ns1:description "Analysis of S-protein polymorphism. This workflow includes: obtaining coding sequences of S proteins from a diverse group of coronaviruses and generating amino acid alignments to assess conservation of the polymorphic location. More info can be found at https://covid19.galaxyproject.org/genomics/" ;
    ns1:image <https://workflowhub.eu/workflows/8/diagram?version=1> ;
    ns1:input <https://workflowhub.eu/workflows/9#genomics___analysis_of_s_protein_polymorphism-inputs-0_Input%20Dataset> ;
    ns1:keywords "covid-19" ;
    ns1:license <https://spdx.org/licenses/MIT> ;
    ns1:name "Genomics - Analysis of S-protein polymorphism" ;
    ns1:producer <https://workflowhub.eu/projects/3> ;
    ns1:programmingLanguage <https://workflowhub.eu/workflows/9#galaxy> ;
    ns1:sdPublisher <https://about.workflowhub.eu/> ;
    ns1:url <https://workflowhub.eu/workflows/9?version=1> ;
    ns1:version 1 .

