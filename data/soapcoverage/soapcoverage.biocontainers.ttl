@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:soapcoverage a schema1:SoftwareApplication ;
    schema1:description "SOAPcoverarge can calculate sequencing coverage or physical coverage as well as duplication rate and details of specific block for each segments and whole genome by using SOAP, BLAT, BLAST, BlastZ, mum- mer and MAQ aligement results with multi-thread." ;
    schema1:license "GPL" ;
    schema1:name "soapcoverage" ;
    schema1:url "http://soap.genomics.org.cn/soapaligner.html" .

