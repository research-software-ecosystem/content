@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-derfinder a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/biostatistics/kxt053" ;
    schema1:description "Annotation-agnostic differential expression analysis of rna-seq data at base-pair resolution via the der finder approach" ;
    schema1:identifier biotools:derfinder ;
    schema1:keywords "Gene Expression Profiling",
        "Genomics",
        "Humans",
        "RNA-Seq",
        "RNA-seq",
        "Sequence Analysis, RNA" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-derfinder" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/derfinder.html" .

