@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-derfinder a schema1:SoftwareApplication ;
    schema1:description "Annotation-agnostic differential expression analysis of RNA-seq data at base-pair resolution via the DER Finder approach" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/derfinder_1.40.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/derfinder/derfinder_1.40.0.tar.gz', 'https://bioarchive.galaxyproject.org/derfinder_1.40.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-derfinder/bioconductor-derfinder_1.40.0_src_all.tar.gz']" ;
    schema1:identifier biotools:derfinder ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-derfinder" ;
    schema1:softwareVersion "1.40.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/derfinder.html" ;
    spdx:builtFrom biotools:derfinder .

