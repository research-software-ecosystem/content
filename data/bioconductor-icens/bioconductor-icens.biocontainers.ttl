@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-icens a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Many functions for computing the npmle for censored and truncated data." ;
    schema1:identifier biotools:icens ;
    schema1:keywords "Computational Biology",
        "Gene Expression Profiling",
        "Genomics",
        "High-Throughput Screening Assays",
        "Machine learning",
        "Programming Languages",
        "Statistics and probability",
        "User-Computer Interface" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-icens" ;
    schema1:url "http://bioconductor.org/packages/release/bioc/html/Icens.html" .

