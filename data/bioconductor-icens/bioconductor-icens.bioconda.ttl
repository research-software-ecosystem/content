@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-icens a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "NPMLE for Censored and Truncated Data" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/Icens_1.78.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/Icens/Icens_1.78.0.tar.gz', 'https://bioarchive.galaxyproject.org/Icens_1.78.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-icens/bioconductor-icens_1.78.0_src_all.tar.gz']" ;
    schema1:identifier biotools:icens ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-icens" ;
    schema1:softwareVersion "1.78.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/Icens.html" ;
    spdx:builtFrom biotools:icens .

