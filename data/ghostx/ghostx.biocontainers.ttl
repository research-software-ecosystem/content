@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:ghostx a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1371/journal.pone.0103833" ;
    schema1:description "GHOSTX is a homology search tool which can detect remote homologues like BLAST and is about 100 times more efficient than BLAST by using suffix arrays. GHOSTX outputs search results in the format similar to BLAST-tabular format." ;
    schema1:keywords "Clustering",
        "Databases, Genetic",
        "Metagenome",
        "Protein Sequences",
        "Sequence Alignment",
        "Sequence Homology" ;
    schema1:license "BSD-2-Clause" ;
    schema1:name "ghostx" ;
    schema1:url "http://www.bi.cs.titech.ac.jp/ghostx/" .

