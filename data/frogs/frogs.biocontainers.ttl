@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:frogs a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btx791" ;
    schema1:description "Frogs is a workflow designed to produce an otus count matrix from high depth sequencing amplicon data. this is the official release 3.1.0 of frogs." ;
    schema1:identifier biotools:frogs ;
    schema1:keywords "Bacteria",
        "Cluster Analysis",
        "Clustering",
        "Evolutionary biology",
        "Metagenomics",
        "Microbial ecology",
        "Sequencing",
        "Taxonomy" ;
    schema1:license "GNU General Public License v3.0" ;
    schema1:name "frogs" ;
    schema1:url "https://github.com/geraldinepascal/FROGS" .

