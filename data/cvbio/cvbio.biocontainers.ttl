@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:cvbio a schema1:SoftwareApplication ;
    schema1:description "Tools for working with genomic and sequencing data, including multi-species read disambiguation" ;
    schema1:keywords "Genomics" ;
    schema1:license "MIT" ;
    schema1:name "cvbio" ;
    schema1:url "https://github.com/clintval/cvbio" .

