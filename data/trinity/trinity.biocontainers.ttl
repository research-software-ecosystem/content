@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:trinity a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nbt.1883" ;
    schema1:description "Trinity assembles transcript sequences from Illumina RNA-Seq data." ;
    schema1:identifier biotools:trinity ;
    schema1:keywords "Base Sequence",
        "Gene Expression Profiling",
        "Gene expression",
        "Gene transcripts",
        "Molecular Sequence Data",
        "RNA",
        "RNA-Seq",
        "Reference Values",
        "Sequence Analysis, RNA",
        "Transcriptome",
        "Transcriptomics" ;
    schema1:license "BSD-3-Clause" ;
    schema1:name "trinity" ;
    schema1:url "https://github.com/trinityrnaseq/trinityrnaseq/" .

