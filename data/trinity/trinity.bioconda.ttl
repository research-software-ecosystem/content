@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:trinity a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nbt.1883",
        "doi:10.1038/nprot.2013.084" ;
    schema1:description "Trinity assembles transcript sequences from Illumina RNA-Seq data." ;
    schema1:downloadUrl "https://github.com/trinityrnaseq/trinityrnaseq/releases/download/Trinity-v2.15.2/trinityrnaseq-v2.15.2.FULL.tar.gz" ;
    schema1:identifier biotools:trinity ;
    schema1:license "BSD-3-Clause" ;
    schema1:name "trinity" ;
    schema1:softwareHelp "https://github.com/trinityrnaseq/trinityrnaseq/wiki" ;
    schema1:softwareVersion "2.15.2" ;
    schema1:url "https://github.com/trinityrnaseq/trinityrnaseq" ;
    spdx:builtFrom biotools:trinity .

