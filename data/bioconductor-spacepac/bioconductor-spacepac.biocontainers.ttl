@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-spacepac a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/1471-2105-15-231" ;
    schema1:description "Identification of Mutational Clusters in 3D Protein Space via Simulation." ;
    schema1:identifier biotools:spacepac ;
    schema1:keywords "Cluster Analysis",
        "Clustering",
        "Computational Biology",
        "Databases, Protein",
        "Genes, Neoplasm",
        "Genetic variation",
        "Humans",
        "Mutation",
        "Neoplasms",
        "Protein Structure, Tertiary",
        "Proteins",
        "Proteomics" ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-spacepac" ;
    schema1:url "http://bioconductor.org/packages/3.6/bioc/html/SpacePAC.html" .

