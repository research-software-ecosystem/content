@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-spacepac a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/1471-2105-15-231" ;
    schema1:description "Identification of Mutational Clusters in 3D Protein Space via Simulation." ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.18/bioc/src/contrib/SpacePAC_1.40.0.tar.gz', 'https://bioconductor.org/packages/3.18/bioc/src/contrib/Archive/SpacePAC/SpacePAC_1.40.0.tar.gz', 'https://bioarchive.galaxyproject.org/SpacePAC_1.40.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-spacepac/bioconductor-spacepac_1.40.0_src_all.tar.gz']" ;
    schema1:identifier biotools:spacepac ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-spacepac" ;
    schema1:softwareVersion "1.40.0" ;
    schema1:url "https://bioconductor.org/packages/3.18/bioc/html/SpacePAC.html" ;
    spdx:builtFrom biotools:spacepac .

