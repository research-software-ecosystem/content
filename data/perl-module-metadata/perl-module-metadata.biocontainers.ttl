@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:perl-module-metadata a schema1:SoftwareApplication ;
    schema1:description "Gather package and pod information from perl module files" ;
    schema1:license "Not available" ;
    schema1:name "perl-module-metadata" ;
    schema1:url "https://github.com/Perl-Toolchain-Gang/Module-Metadata" .

