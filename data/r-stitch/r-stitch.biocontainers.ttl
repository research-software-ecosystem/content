@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-stitch a schema1:SoftwareApplication ;
    schema1:description "STITCH - Sequencing To Imputation Through Constructing Haplotypes" ;
    schema1:keywords "Animals",
        "Animals, Outbred Strains",
        "Asian Continental Ancestry Group",
        "Computational Biology",
        "Genetics, Population",
        "Genotype",
        "Haplotypes",
        "High-Throughput Nucleotide Sequencing",
        "Humans",
        "Mice",
        "Polymorphism, Single Nucleotide",
        "Sequence Analysis, DNA" ;
    schema1:license "GPL-3.0" ;
    schema1:name "r-stitch" ;
    schema1:url "https://github.com/rwdavies/stitch" .

