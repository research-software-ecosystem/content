@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:run-dbcan a schema1:SoftwareApplication ;
    schema1:description "Standalone version of dbcan annotation tool for automated cazyme annotation" ;
    schema1:keywords "Metagenome",
        "Protein Sequences" ;
    schema1:license "Not available" ;
    schema1:name "run-dbcan" ;
    schema1:url "https://github.com/linnabrown/run_dbcan" .

