@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:cnvnator a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1101/gr.114876.110" ;
    schema1:description "Tool for calling copy number variations." ;
    schema1:identifier biotools:cnvnator ;
    schema1:keywords "Base Composition",
        "DNA Copy Number Variations",
        "Ethnic Groups",
        "Genetics",
        "Genome, Human",
        "Genomics",
        "Genotype",
        "Genotype and phenotype",
        "Human biology",
        "Humans",
        "Metagenomics",
        "Sensitivity and Specificity",
        "Sequence Analysis, DNA" ;
    schema1:license "MIT" ;
    schema1:name "cnvnator" ;
    schema1:url "https://github.com/abyzovlab/CNVnator" .

