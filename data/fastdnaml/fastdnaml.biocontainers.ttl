@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:fastdnaml a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/10.1.41" ;
    schema1:description "Tool for construction of phylogenetic trees of dna sequences" ;
    schema1:keywords "Bacteria",
        "DNA",
        "DNA, Bacterial",
        "Databases, Factual",
        "Evaluation Studies as Topic",
        "Likelihood Functions",
        "Phylogeny",
        "RNA, Ribosomal, 16S",
        "Sequence Alignment" ;
    schema1:license "GPL-2+" ;
    schema1:name "fastdnaml" ;
    schema1:url "ftp://ftp.bio.indiana.edu/molbio/evolve/fastdnaml/fastDNAml.html" .

