@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:dammet a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/gigascience/giz025" ;
    schema1:description "Software to reconstruct methylomes from HTS data underlying and ancient specimen" ;
    schema1:keywords "Autopsy",
        "Computational Biology",
        "CpG Islands",
        "DNA Damage",
        "DNA Methylation",
        "Epigenomics",
        "Gene Expression Profiling",
        "High-Throughput Nucleotide Sequencing",
        "Humans" ;
    schema1:license "MIT" ;
    schema1:name "dammet" ;
    schema1:url "https://gitlab.com/KHanghoj/DamMet" .

