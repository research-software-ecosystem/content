@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-fastseg a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/gks003" ;
    schema1:description "fastseg - a fast segmentation algorithm" ;
    schema1:identifier biotools:fastseg ;
    schema1:keywords "Chromosomes, Human, X",
        "DNA Copy Number Variations",
        "HapMap Project",
        "High-Throughput Nucleotide Sequencing",
        "Humans",
        "Male",
        "Microarray experiment",
        "Poisson Distribution",
        "Sequence Analysis, DNA",
        "Sequence analysis",
        "Sequencing" ;
    schema1:license "LGPL (>= 2.0)" ;
    schema1:name "bioconductor-fastseg" ;
    schema1:url "https://bioconductor.org/packages/release/bioc/html/fastseg.html" .

