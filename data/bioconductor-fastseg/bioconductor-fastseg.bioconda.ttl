@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-fastseg a schema1:SoftwareApplication ;
    schema1:description "fastseg - a fast segmentation algorithm" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/fastseg_1.56.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/fastseg/fastseg_1.56.0.tar.gz', 'https://bioarchive.galaxyproject.org/fastseg_1.56.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-fastseg/bioconductor-fastseg_1.56.0_src_all.tar.gz']" ;
    schema1:identifier biotools:fastseg ;
    schema1:license "LGPL (>= 2.0)" ;
    schema1:name "bioconductor-fastseg" ;
    schema1:softwareVersion "1.56.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/fastseg.html" ;
    spdx:builtFrom biotools:fastseg .

