@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bamutil a schema1:SoftwareApplication ;
    schema1:description "Programs that perform operations on SAM/BAM files, all built into a single executable, bam." ;
    schema1:downloadUrl "https://github.com/statgen/bamUtil/archive/v1.0.15.tar.gz",
        "https://github.com/statgen/libStatGen/archive/v1.0.15.tar.gz" ;
    schema1:identifier biotools:Bamutil ;
    schema1:license "GPL-3.0-or-later" ;
    schema1:name "bamutil" ;
    schema1:softwareHelp "https://genome.sph.umich.edu/wiki/BamUtil" ;
    schema1:softwareVersion "1.0.15" ;
    schema1:url "https://genome.sph.umich.edu/wiki/BamUtil" ;
    spdx:builtFrom biotools:Bamutil .

