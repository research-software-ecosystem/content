@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:kronos a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/gigascience/gix042" ;
    schema1:description "Kronos is a highly flexible Python-based software tool that mainly enables bioinformatics developers, i.e. bioinformaticians who develop workflows for analyzing genomic data, to quickly make a workflow." ;
    schema1:identifier biotools:kronos ;
    schema1:keywords "Genomics",
        "High-Throughput Nucleotide Sequencing",
        "Sequence analysis",
        "Software engineering",
        "Whole Genome Sequencing" ;
    schema1:license "MIT" ;
    schema1:name "kronos" ;
    schema1:url "https://github.com/jtaghiyar/kronos" .

