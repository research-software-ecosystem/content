@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:hmftools-purple a schema1:SoftwareApplication ;
    schema1:description "Purity/ploidy estimator. leverages the read depth and tumor baf to estimate the purity of a sample and generate a copy number profile" ;
    schema1:keywords "Genomics",
        "Whole genome sequencing" ;
    schema1:license "MIT" ;
    schema1:name "hmftools-purple" ;
    schema1:url "https://github.com/hartwigmedical/hmftools/tree/master/purity-ploidy-estimator" .

