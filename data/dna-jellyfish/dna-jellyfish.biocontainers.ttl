@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:dna-jellyfish a schema1:SoftwareApplication ;
    schema1:description "Count k-mers in dna sequences (python bindings of jellyfish)" ;
    schema1:license "Not available" ;
    schema1:name "dna-jellyfish" ;
    schema1:url "http://www.cbcb.umd.edu/software/jellyfish/" .

