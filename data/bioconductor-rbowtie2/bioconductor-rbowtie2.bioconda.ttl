@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-rbowtie2 a schema1:SoftwareApplication ;
    schema1:description "An R Wrapper for Bowtie2 and AdapterRemoval" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/Rbowtie2_2.16.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/Rbowtie2/Rbowtie2_2.16.0.tar.gz', 'https://bioarchive.galaxyproject.org/Rbowtie2_2.16.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-rbowtie2/bioconductor-rbowtie2_2.16.0_src_all.tar.gz']" ;
    schema1:identifier biotools:rbowtie2 ;
    schema1:license "GPL (>= 3)" ;
    schema1:name "bioconductor-rbowtie2" ;
    schema1:softwareVersion "2.16.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/Rbowtie2.html" ;
    spdx:builtFrom biotools:rbowtie2 .

