@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-macorrplot a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Visualize artificial correlation in microarray data" ;
    schema1:identifier biotools:macorrplot ;
    schema1:keywords "Computational Biology",
        "Gene Expression Profiling",
        "Gene regulation",
        "Genetics",
        "Genomics",
        "High-Throughput Screening Assays",
        "Microarray experiment",
        "Programming Languages",
        "User-Computer Interface" ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-macorrplot" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/maCorrPlot.html" .

