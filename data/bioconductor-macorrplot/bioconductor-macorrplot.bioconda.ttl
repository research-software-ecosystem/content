@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-macorrplot a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Visualize artificial correlation in microarray data" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/maCorrPlot_1.80.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/maCorrPlot/maCorrPlot_1.80.0.tar.gz', 'https://bioarchive.galaxyproject.org/maCorrPlot_1.80.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-macorrplot/bioconductor-macorrplot_1.80.0_src_all.tar.gz']" ;
    schema1:identifier biotools:macorrplot ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-macorrplot" ;
    schema1:softwareVersion "1.80.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/maCorrPlot.html" ;
    spdx:builtFrom biotools:macorrplot .

