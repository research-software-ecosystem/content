@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:fmh-funprofiler a schema1:SoftwareApplication ;
    schema1:author "dkoslicki",
        "miraep8" ;
    schema1:citation "doi:10.1093/bioinformatics/btae397" ;
    schema1:description "fmh-funprofiler is a pipeline that leverages FracMinHash (implemented in sourmash) to functionally profile metagenomic samples, offering a faster and more memory-efficient alternative to alignment-based methods." ;
    schema1:downloadUrl "https://github.com/KoslickiLab/fmh-funprofiler/archive/refs/tags/v1.1.1.tar.gz" ;
    schema1:identifier biotools:fmh-funprofiler ;
    schema1:license "MIT" ;
    schema1:maintainer "dkoslicki",
        "miraep8" ;
    schema1:name "fmh-funprofiler" ;
    schema1:softwareVersion "1.1.1" ;
    schema1:url "https://github.com/KoslickiLab/fmh-funprofiler" ;
    spdx:builtFrom biotools:fmh-funprofiler .

