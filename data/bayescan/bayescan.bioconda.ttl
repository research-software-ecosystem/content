@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bayescan a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1534/genetics.108.092221" ;
    schema1:description "Phylogenetics - Randomized Axelerated Maximum Likelihood." ;
    schema1:downloadUrl "https://cmpg.unibe.ch/software/BayeScan/files/BayeScan2.1.zip" ;
    schema1:identifier biotools:bayescan ;
    schema1:license "GPL-3.0-or-later" ;
    schema1:name "bayescan" ;
    schema1:softwareHelp "https://cmpg.unibe.ch/software/BayeScan/files/BayeScan2.1_manual.pdf" ;
    schema1:softwareVersion "2.1" ;
    schema1:url "https://cmpg.unibe.ch/software/BayeScan" ;
    spdx:builtFrom biotools:bayescan .

