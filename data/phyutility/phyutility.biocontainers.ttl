@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:phyutility a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btm619" ;
    schema1:description "Simple analyses or modifications on both phylogenetic trees and data matrices" ;
    schema1:keywords "Computational Biology",
        "Phylogeny",
        "Sequence Alignment",
        "User-Computer Interface" ;
    schema1:license "GPL-3.0+" ;
    schema1:name "phyutility" ;
    schema1:url "http://github.com/blackrim/phyutility" .

