@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:genomad a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/s41587-023-01953-y" ;
    schema1:description "Identification of mobile genetic elements." ;
    schema1:downloadUrl "https://pypi.io/packages/source/g/genomad/genomad-1.12.0.tar.gz" ;
    schema1:identifier biotools:genomad ;
    schema1:license "BSD-4-Clause" ;
    schema1:name "genomad" ;
    schema1:softwareHelp "https://portal.nersc.gov/genomad" ;
    schema1:softwareVersion "1.12.0" ;
    schema1:url "https://portal.nersc.gov/genomad" ;
    spdx:builtFrom biotools:genomad .

