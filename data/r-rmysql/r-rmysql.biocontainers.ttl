@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-rmysql a schema1:SoftwareApplication ;
    schema1:description "Legacy DBI interface to MySQL / MariaDB based on old code ported from S-PLUS. A modern MySQL client based on Rcpp is available from the RMariaDB package." ;
    schema1:license "GPL-2.0" ;
    schema1:name "r-rmysql" ;
    schema1:url "https://downloads.mariadb.org/connector-c/" .

