@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-netbiov a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btu384" ;
    schema1:description "A package for visualizing complex biological network" ;
    schema1:identifier biotools:netbiov ;
    schema1:keywords "Arabidopsis",
        "Biology",
        "Computational Biology",
        "Computer Graphics",
        "Data visualisation",
        "Gene Regulatory Networks",
        "Humans",
        "Lymphoma, B-Cell",
        "Medicine",
        "Molecular interactions, pathways and networks",
        "Oncology",
        "Programming Languages",
        "Reproducibility of Results" ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-netbiov" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/netbiov.html" .

