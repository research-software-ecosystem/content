@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:spoa a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1101/gr.214270.116" ;
    schema1:description "SIMD partial order alignment tool/library." ;
    schema1:downloadUrl "https://github.com/rvaser/spoa/archive/refs/tags/4.1.5.tar.gz" ;
    schema1:identifier biotools:spoa ;
    schema1:license "MIT" ;
    schema1:name "spoa" ;
    schema1:softwareHelp "https://github.com/rvaser/spoa/blob/4.1.5/README.md" ;
    schema1:softwareVersion "4.1.5" ;
    schema1:url "https://github.com/rvaser/spoa" ;
    spdx:builtFrom biotools:spoa .

