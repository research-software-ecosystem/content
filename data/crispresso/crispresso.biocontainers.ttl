@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:crispresso a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nbt.3583" ;
    schema1:description "A software pipeline for the analysis of targeted CRISPR-Cas9 sequencing data" ;
    schema1:keywords "Animals",
        "CRISPR-Cas Systems",
        "Clustered Regularly Interspaced Short Palindromic Repeats",
        "Computer Simulation",
        "Gene Editing",
        "High-Throughput Nucleotide Sequencing",
        "Humans",
        "Models, Genetic",
        "Sequence Analysis, DNA",
        "Whole genome sequencing" ;
    schema1:license "GPL-3.0" ;
    schema1:name "crispresso" ;
    schema1:url "https://github.com/lucapinello/CRISPResso" .

