@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-marray a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1007/0-387-21679-0_3" ;
    schema1:description "Exploratory analysis for two-color spotted microarray data" ;
    schema1:identifier biotools:marray ;
    schema1:keywords "Gene expression",
        "Genetics",
        "Microarray experiment" ;
    schema1:license "LGPL" ;
    schema1:name "bioconductor-marray" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/marray.html" .

