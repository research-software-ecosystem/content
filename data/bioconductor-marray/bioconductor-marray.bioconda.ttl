@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-marray a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1007/0-387-21679-0_3" ;
    schema1:description "Exploratory analysis for two-color spotted microarray data" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/marray_1.88.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/marray/marray_1.88.0.tar.gz', 'https://bioarchive.galaxyproject.org/marray_1.88.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-marray/bioconductor-marray_1.88.0_src_all.tar.gz']" ;
    schema1:identifier biotools:marray ;
    schema1:license "LGPL" ;
    schema1:name "bioconductor-marray" ;
    schema1:softwareVersion "1.88.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/marray.html" ;
    spdx:builtFrom biotools:marray .

