@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:qsignature a schema1:SoftwareApplication ;
    schema1:description "Qsignature is a simple and highly effective method for detecting potential sample mix-ups using distance measurements between snp" ;
