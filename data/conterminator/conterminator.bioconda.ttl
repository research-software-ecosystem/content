@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:conterminator a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s13059-020-02023-1" ;
    schema1:description "Conterminator: software to detect contamination in large sequence sets" ;
    schema1:downloadUrl "https://github.com/martin-steinegger/conterminator/archive/1-c74b5.tar.gz" ;
    schema1:identifier biotools:conterminator ;
    schema1:license "GPL3" ;
    schema1:name "conterminator" ;
    schema1:softwareVersion "1.c74b5" ;
    schema1:url "https://github.com/martin-steinegger/conterminator" ;
    spdx:builtFrom biotools:conterminator .

