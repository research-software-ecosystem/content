@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:mgkit a schema1:SoftwareApplication ;
    schema1:citation "doi:10.6084/m9.figshare.1588384" ;
    schema1:description "Metagenomics Framework" ;
    schema1:downloadUrl "https://github.com/frubino/mgkit/archive/refs/tags/0.5.8.tar.gz" ;
    schema1:identifier biotools:mgkit ;
    schema1:license "GPL-2.0-or-later" ;
    schema1:name "mgkit" ;
    schema1:softwareVersion "0.5.8" ;
    schema1:url "https://github.com/frubino/mgkit" ;
    spdx:builtFrom biotools:mgkit .

