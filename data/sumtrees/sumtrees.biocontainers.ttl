@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:sumtrees a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btq228" ;
    schema1:description "Phylogenetic tree summarization and annotation" ;
    schema1:keywords "Computational Biology",
        "Databases, Factual",
        "Genetics",
        "Phylogenetics",
        "Phylogeny",
        "Programming Languages" ;
    schema1:license "BSD-3-clause" ;
    schema1:name "sumtrees" ;
    schema1:url "https://github.com/jeetsukumaran/DendroPy" .

