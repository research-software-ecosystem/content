@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-gewist a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1002/gepi.20624" ;
    schema1:description "Gene Environment Wide Interaction Search Threshold" ;
    schema1:identifier biotools:gewist ;
    schema1:keywords "DNA polymorphism",
        "Epistasis, Genetic",
        "Gene-Environment Interaction",
        "Genetics",
        "Genome-Wide Association Study",
        "Humans",
        "Polymorphism, Single Nucleotide" ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-gewist" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/GEWIST.html" .

