@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-gewist a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1002/gepi.20624" ;
    schema1:description "Gene Environment Wide Interaction Search Threshold" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/GEWIST_1.50.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/GEWIST/GEWIST_1.50.0.tar.gz', 'https://bioarchive.galaxyproject.org/GEWIST_1.50.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-gewist/bioconductor-gewist_1.50.0_src_all.tar.gz']" ;
    schema1:identifier biotools:gewist ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-gewist" ;
    schema1:softwareVersion "1.50.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/GEWIST.html" ;
    spdx:builtFrom biotools:gewist .

