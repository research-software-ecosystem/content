biocontainers:glyxtoolms a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1021/acs.analchem.8b02087" ;
    schema1:description "glyXtoolMS provides a) scripts for glycopeptide analysis within the OpenMS proteomics framework (using the TOPPAS pipeline engine) and a visulization / evaluation tool for further manual analysis of the results." ;
