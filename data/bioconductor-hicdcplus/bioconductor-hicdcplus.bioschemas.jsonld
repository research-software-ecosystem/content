  "@graph": [
    {
      "@id": "https://doi.org/10.1038/s41467-021-23749-x",
      "@type": "sc:CreativeWork"
    },
    {
      "@id": "https://bio.tools/bioconductor-hicdcplus",
      "@type": "sc:SoftwareApplication",
      "dcterms:conformsTo": "https://bioschemas.org/profiles/ComputationalTool/0.6-DRAFT",
      "sc:additionalType": [
        "Command-line tool",
        "Library"
      ],
      "sc:author": "Merve Sahin",
      "sc:citation": {
        "@id": "https://doi.org/10.1038/s41467-021-23749-x"
      },
      "sc:description": "Systematic 3D interaction calls and differential analysis for Hi-C and HiChIP. The HiC-DC+ (Hi-C/HiChIP direct caller plus) package enables principled statistical analysis of Hi-C and HiChIP data sets – including calling significant interactions within a single experiment and performing differential analysis between conditions given replicate experiments – to facilitate global integrative studies. HiC-DC+ estimates significant interactions in a Hi-C or HiChIP experiment directly from the raw contact matrix for each chromosome up to a specified genomic distance, binned by uniform genomic intervals or restriction enzyme fragments, by training a background model to account for random polymer ligation and systematic sources of read count variation.",
      "sc:license": "GPL-3.0-only",
      "sc:name": "HiCDCPlus",
      "sc:operatingSystem": [
        "Windows",
        "Linux",
        "Mac"
      ],
      "sc:softwareHelp": {
        "@id": "https://bioconductor.org/packages/HiCDCPlus"
      },
      "sc:softwareVersion": "1.18.0",
      "sc:url": "https://bioconductor.org/packages/HiCDCPlus"
    }
  ]
