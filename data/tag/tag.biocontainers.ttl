@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:tag a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btv510" ;
    schema1:description "Genome annotation data analysis and management implemented in pure python." ;
    schema1:identifier biotools:tag ;
    schema1:keywords "Genomics",
        "Mapping",
        "Metagenome",
        "Metagenomics",
        "Transcriptomics" ;
    schema1:license "BSD 3-Clause \"New\" or \"Revised\" License" ;
    schema1:name "tag" ;
    schema1:url "https://github.com/standage/tag/" .

