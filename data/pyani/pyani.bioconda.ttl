@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:pyani a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1039/C5AY02550H" ;
    schema1:description "pyani provides a package and script for calculation of genome-scale average nucleotide identity." ;
    schema1:downloadUrl "https://github.com/widdowquinn/pyani/archive/v0.2.13.1.tar.gz" ;
    schema1:identifier biotools:pyani ;
    schema1:license "MIT" ;
    schema1:name "pyani" ;
    schema1:softwareHelp "https://widdowquinn.github.io/pyani" ;
    schema1:softwareVersion "0.2.13.1" ;
    schema1:url "https://github.com/widdowquinn/pyani" ;
    spdx:builtFrom biotools:pyani .

