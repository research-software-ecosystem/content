@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:pyani a schema1:SoftwareApplication ;
    schema1:description "Pyani provides a package and script for calculation of genome-scale average nucleotide identity." ;
    schema1:keywords "Clustering",
        "Sequence Alignment" ;
    schema1:license "MIT" ;
    schema1:name "pyani" ;
    schema1:url "https://github.com/widdowquinn/pyani" .

