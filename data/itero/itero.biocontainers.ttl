@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:itero a schema1:SoftwareApplication ;
    schema1:description "A pipeline for iterative, guided contig assembly that integrates spades, bwa, and samtools to produce assembled contigs." ;
    schema1:license "BSD 3-Clause \"New\" or \"Revised\" License" ;
    schema1:name "itero" ;
    schema1:url "https://github.com/faircloth-lab/itero" .

