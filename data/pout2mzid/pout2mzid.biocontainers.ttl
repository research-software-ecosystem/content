@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:pout2mzid a schema1:SoftwareApplication ;
    schema1:description "Adds percolator statistics to mzIdentML files that were used as input to percolator" ;
