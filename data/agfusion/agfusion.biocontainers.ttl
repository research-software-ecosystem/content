@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:agfusion a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1101/080903" ;
    schema1:description "Python package to annotate and visualize gene fusions." ;
    schema1:keywords "Genomics",
        "Protein Sequences",
        "RNA-Seq" ;
    schema1:license "MIT" ;
    schema1:name "agfusion" ;
    schema1:url "https://github.com/murphycj/AGFusion" .

