@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:mccortex a schema1:SoftwareApplication ;
    schema1:description "De novo genome assembly and multisample variant calling." ;
    schema1:downloadUrl "https://github.com/mcveanlab/mccortex/releases/download/mccortex-1.0/mccortex1_0.tar.gz" ;
    schema1:identifier biotools:mccortex ;
    schema1:license "MIT" ;
    schema1:name "mccortex" ;
    schema1:softwareHelp "https://github.com/mcveanlab/mccortex/wiki" ;
    schema1:softwareVersion "1.0" ;
    schema1:url "https://github.com/mcveanlab/mccortex" ;
    spdx:builtFrom biotools:mccortex .

