@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:mccortex a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/bty157" ;
    schema1:description "De novo genome assembly and multisample variant calling " ;
    schema1:identifier biotools:mccortex ;
    schema1:keywords "Data Visualization",
        "Data visualisation",
        "Genetic variation",
        "Genetics",
        "Genomics",
        "High-Throughput Nucleotide Sequencing",
        "Humans",
        "Klebsiella pneumoniae",
        "Sequence Analysis, DNA",
        "Sequencing" ;
    schema1:license "MIT" ;
    schema1:name "mccortex" ;
    schema1:url "https://github.com/mcveanlab/mccortex" .

