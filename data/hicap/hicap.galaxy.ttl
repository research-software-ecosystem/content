@prefix galaxytool: <https://github.com/galaxyproject/tools-iuc/tree/master/tools/> .
@prefix schema1: <http://schema.org/> .

galaxytool:hicap a schema1:SoftwareApplication ;
    schema1:description "Identify cap locus serotype and structure in Haemophilus influenzae assemblies" ;
    schema1:identifier "bioconda:hicap",
        "biotools:hicap" ;
    schema1:keywords "Sequence Analysis" ;
    schema1:name "hicap" ;
    schema1:softwareVersion "1.0.4" ;
    schema1:url "https://github.com/scwatts/hicap" .

