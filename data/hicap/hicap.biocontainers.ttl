        "Genomics",
        "Genotype",
        "Haemophilus influenzae",
        "Humans",
        "Phylogeny",
        "Sequence Analysis, DNA",
        "Serogroup",
        "Serotyping" ;
    schema1:license "GPL-3.0" ;
    schema1:name "hicap" ;
    schema1:url "https://github.com/scwatts/hicap" .

