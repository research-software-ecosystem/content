@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:isa-extractor a schema1:SoftwareApplication ;
    schema1:description "Extract collections of raw data files (mzML, mzXML, netCDF, mzData or nmrML) from an ISA study." ;
    schema1:keywords "Metabolomics",
        "Proteomics" ;
    schema1:license "Custom License" ;
    schema1:name "isa-extractor" ;
    schema1:url "https://github.com/workflow4metabolomics/isa-extractor" .

