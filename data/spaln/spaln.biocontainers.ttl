@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:spaln a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/gks708" ;
    schema1:description "Map and align a set of cDNA/EST or protein sequences onto a genome" ;
    schema1:keywords "Arabidopsis",
        "Benchmarking",
        "Humans",
        "Neurospora crassa",
        "Ortholog",
        "Protein Sequences",
        "RNA Splicing",
        "Sequence Alignment",
        "Species Specificity" ;
    schema1:license "GPL-2.0" ;
    schema1:name "spaln" ;
    schema1:url "http://www.genome.ist.i.kyoto-u.ac.jp/~aln_user/spaln/" .

