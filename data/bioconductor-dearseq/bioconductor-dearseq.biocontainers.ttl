@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-dearseq a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18129/b9.bioc.dearseq" ;
    schema1:description "Differential expression analysis for rna-seq data through a robust variance component test" ;
    schema1:keywords "Genetics",
        "RNA-Seq",
        "Transcriptomics" ;
    schema1:license "GPL-2 | file LICENSE" ;
    schema1:name "bioconductor-dearseq" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/dearseq.html" .

