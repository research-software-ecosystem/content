@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-gsreg a schema1:SoftwareApplication ;
    schema1:citation "doi:10.4137/CIN.S14066" ;
    schema1:description "Gene Set Regulation (GS-Reg)" ;
    schema1:identifier biotools:gsreg ;
    schema1:keywords "Gene expression",
        "Molecular genetics" ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-gsreg" ;
    schema1:url "http://bioconductor.org/packages/3.6/bioc/html/GSReg.html" .

