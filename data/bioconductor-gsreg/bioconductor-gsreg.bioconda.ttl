@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-gsreg a schema1:SoftwareApplication ;
    schema1:citation "doi:10.4137/CIN.S14066" ;
    schema1:description "Gene Set Regulation (GS-Reg)" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/GSReg_1.40.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/GSReg/GSReg_1.40.0.tar.gz', 'https://bioarchive.galaxyproject.org/GSReg_1.40.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-gsreg/bioconductor-gsreg_1.40.0_src_all.tar.gz']" ;
    schema1:identifier biotools:gsreg ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-gsreg" ;
    schema1:softwareVersion "1.40.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/GSReg.html" ;
    spdx:builtFrom biotools:gsreg .

