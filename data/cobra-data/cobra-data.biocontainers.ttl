@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:cobra-data a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/1752-0509-7-74" ;
    schema1:description "Constraint-based modeling of biological networks (data)" ;
    schema1:keywords "Genomics",
        "Metabolic Networks and Pathways",
        "Models, Biological",
        "Programming Languages" ;
    schema1:license "GPL-2+ or LGPL-2.0+" ;
    schema1:name "cobra-data" ;
    schema1:url "http://opencobra.github.io/cobrapy/" .

