@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:sonlib a schema1:SoftwareApplication ;
    schema1:description "Small general purpose library for c and python with focus on bioinformatics." ;
    schema1:license "MIT" ;
    schema1:name "sonlib" ;
    schema1:url "https://github.com/benedictpaten/sonLib" .

