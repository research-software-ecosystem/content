@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-epivizrstandalone a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "This package imports the epiviz visualization javascript app for genomic data interactive visualization. the 'epivizrserver' package is used to provide a web server running completely within r. this standalone version allows to browse arbitrary genomes through genome annotations provided by bioconductor packages." ;
    schema1:identifier biotools:epivizrstandalone ;
    schema1:keywords "Computational Biology",
        "Data visualisation",
        "Gene Expression Profiling",
        "Genomics",
        "High-Throughput Screening Assays",
        "Programming Languages",
        "User-Computer Interface" ;
    schema1:license "MIT" ;
    schema1:name "bioconductor-epivizrstandalone" ;
    schema1:url "http://bioconductor.org/packages/release/bioc/html/epivizrStandalone.html" .

