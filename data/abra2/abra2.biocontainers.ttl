@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:abra2 a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btz033" ;
    schema1:description "ABRA is a realigner for next generation sequencing data. It uses localized assembly and global realignment to align reads more accurately, thus improving downstream analysis (detection of indels and complex variants in particular)." ;
    schema1:keywords "DNA",
        "High-Throughput Nucleotide Sequencing",
        "Humans",
        "INDEL Mutation",
        "RNA",
        "Sequence Analysis, DNA" ;
    schema1:license "MIT" ;
    schema1:name "abra2" ;
    schema1:url "https://github.com/mozack/abra2" .

