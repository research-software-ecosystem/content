@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:piranha a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btp257",
        "doi:10.1093/nar/gkq474" ;
    schema1:description "Piranha is a peak-caller for clip- and rip-seq data." ;
    schema1:identifier biotools:piranha ;
    schema1:keywords "Binding Sites",
        "Computational Biology",
        "Databases, Protein",
        "Machine learning",
        "Protein binding sites",
        "Protein sites, features and motifs",
        "Proteins",
        "RNA",
        "RNA-Binding Proteins",
        "RNA-Seq" ;
    schema1:license "GPL-3.0" ;
    schema1:name "piranha" ;
    schema1:url "https://github.com/smithlabcode/piranha" .

