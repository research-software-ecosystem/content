@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:newick_utils a schema1:SoftwareApplication ;
    schema1:description "The Newick Utilities are a suite of Unix shell tools for processing phylogenetic trees. We distribute the package under the BSD License. Functions include re-rooting, extracting subtrees, trimming, pruning, condensing, drawing (ASCII graphics or SVG)." ;
    schema1:license "BSD License" ;
    schema1:name "newick_utils" ;
    schema1:url "https://github.com/tjunier/newick_utils" .

