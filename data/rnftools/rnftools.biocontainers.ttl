@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:rnftools a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btv524" ;
    schema1:description "Rnf framework for ngs: simulation of reads, evaluation of mappers, conversion of rnf-compliant data." ;
    schema1:keywords "Computer Simulation",
        "Genome",
        "High-Throughput Nucleotide Sequencing",
        "Humans",
        "Whole genome sequencing" ;
    schema1:license "MIT" ;
    schema1:name "rnftools" ;
    schema1:url "https://github.com/karel-brinda/rnftools" .

