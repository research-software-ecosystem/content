@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:mathstats a schema1:SoftwareApplication ;
    schema1:description "Statistical functions, goodness-of-fit tests and special and special distributions not implemented in scipy/numpy ." ;
    schema1:license "GPL-3" ;
    schema1:name "mathstats" ;
    schema1:url "https://github.com/ksahlin/mathstats" .

