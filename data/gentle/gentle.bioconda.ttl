@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:gentle a schema1:SoftwareApplication ;
    schema1:author "smoe" ;
    schema1:description "Software suite for DNA cloning." ;
    schema1:downloadUrl "https://github.com/GENtle-persons/gentle-m/archive/refs/tags/1.9.5.alpha1.tar.gz" ;
    schema1:identifier biotools:gentle ;
    schema1:license "GPL-2.0-or-later" ;
    schema1:maintainer "smoe" ;
    schema1:name "gentle" ;
    schema1:softwareVersion "1.9.5.alpha1" ;
    schema1:url "https://github.com/GENtle-persons/gentle-m" ;
    spdx:builtFrom biotools:gentle .

