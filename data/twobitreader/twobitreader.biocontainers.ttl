@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:twobitreader a schema1:SoftwareApplication ;
    schema1:description "A fast python package for reading .2bit files (used by the ucsc genome browser)" ;
    schema1:license "Artistic License" ;
    schema1:name "twobitreader" ;
    schema1:url "https://github.com/benjschiller/twobitreader" .

