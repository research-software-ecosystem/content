@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:phylip a schema1:SoftwareApplication ;
    schema1:description "Package of programs for inferring phylogenies." ;
    schema1:downloadUrl "https://phylipweb.github.io/phylip/download/phylip-3.697.tar.gz" ;
    schema1:identifier biotools:PHYLIP ;
    schema1:license "BSD" ;
    schema1:name "phylip" ;
    schema1:softwareHelp "https://phylipweb.github.io/phylip" ;
    schema1:softwareVersion "3.697" ;
    schema1:url "https://phylipweb.github.io/phylip" ;
    spdx:builtFrom biotools:PHYLIP .

