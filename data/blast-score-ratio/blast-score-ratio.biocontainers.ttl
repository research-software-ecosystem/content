@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:blast-score-ratio a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/1471-2105-6-2" ;
    schema1:description "Obtain BLAST score ratios (BSRs), for use in comparative genomics and identifying horizontally transferred genetic material, from fastA files containing the protein sequences for different organisms." ;
    schema1:keywords "Chromosome Inversion",
        "Computational Biology",
        "Computer Graphics",
        "Databases, Genetic",
        "Gene Deletion",
        "Genome",
        "Genome, Bacterial",
        "Genomics",
        "Internet",
        "Peptides",
        "Programming Languages",
        "Protein Sequences",
        "Proteomics",
        "Sequence Alignment",
        "User-Computer Interface" ;
    schema1:license "Not available" ;
    schema1:name "blast-score-ratio" ;
    schema1:url "https://pypi.org/project/blast-score-ratio/" .

