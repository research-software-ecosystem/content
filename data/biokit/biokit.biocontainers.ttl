@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:biokit a schema1:SoftwareApplication ;
    schema1:description "Set of visualisation and analysis tools for biological data sets" ;
    schema1:license "BSD" ;
    schema1:name "biokit" ;
    schema1:url "http://pypi.python.org/pypi/biokit" .

