@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-inversion a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/1471-2105-13-28" ;
    schema1:description "Inversions in genotype data" ;
    schema1:identifier biotools:inversion ;
    schema1:keywords "Chromosome Inversion",
        "Chromosomes, Human, Pair 17",
        "Genetics, Population",
        "Genome-Wide Association Study",
        "Genotype and phenotype",
        "HapMap Project",
        "Humans",
        "Linkage Disequilibrium",
        "Models, Genetic",
        "Oligonucleotide Array Sequence Analysis",
        "Polymorphism, Single Nucleotide",
        "Sequence analysis",
        "Sequencing" ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-inversion" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/inveRsion.html" .

