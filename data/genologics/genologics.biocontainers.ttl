@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:genologics a schema1:SoftwareApplication ;
    schema1:description "Python interface to the genologics lims (laboratory information management system) server via its rest api." ;
    schema1:license "MIT" ;
    schema1:name "genologics" ;
    schema1:url "https://github.com/scilifelab/genologics" .

