@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-epivizrserver a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "This package provides objects to manage websocket connections to epiviz apps. other epivizr package use this infrastructure." ;
    schema1:identifier biotools:epivizrserver ;
    schema1:keywords "Computational Biology",
        "Data management",
        "Gene Expression Profiling",
        "Genomics",
        "High-Throughput Screening Assays",
        "Programming Languages",
        "User-Computer Interface" ;
    schema1:license "MIT" ;
    schema1:name "bioconductor-epivizrserver" ;
    schema1:url "http://bioconductor.org/packages/release/bioc/html/epivizrServer.html" .

