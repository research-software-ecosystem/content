@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-epivizrserver a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "WebSocket server infrastructure for epivizr apps and packages" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/epivizrServer_1.34.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/epivizrServer/epivizrServer_1.34.0.tar.gz', 'https://bioarchive.galaxyproject.org/epivizrServer_1.34.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-epivizrserver/bioconductor-epivizrserver_1.34.0_src_all.tar.gz']" ;
    schema1:identifier biotools:epivizrserver ;
    schema1:license "MIT + file LICENSE" ;
    schema1:name "bioconductor-epivizrserver" ;
    schema1:softwareVersion "1.34.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/epivizrServer.html" ;
    spdx:builtFrom biotools:epivizrserver .

