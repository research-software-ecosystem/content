@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:sibeliaz a schema1:SoftwareApplication ;
    schema1:description "A fast whole-genome aligner based on de Bruijn graphs." ;
    schema1:identifier biotools:sibeliaz ;
    schema1:license "Custom OSS" ;
    schema1:name "sibeliaz" ;
    schema1:softwareHelp "https://github.com/medvedevgroup/SibeliaZ/blob/v1.2.7/README.md" ;
    schema1:softwareVersion "1.2.7" ;
    schema1:url "https://github.com/medvedevgroup/SibeliaZ" ;
    spdx:builtFrom biotools:sibeliaz .

