@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-spktools a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/gkn430" ;
    schema1:description "Methods for Spike-in Arrays" ;
    schema1:identifier biotools:spktools ;
    schema1:keywords "Analysis of Variance",
        "Gene Expression Profiling",
        "Humans",
        "Microarray experiment",
        "Oligonucleotide Array Sequence Analysis",
        "RNA, Messenger",
        "Reproducibility of Results" ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-spktools" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/spkTools.html" .

