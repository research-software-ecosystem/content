@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-spktools a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/gkn430" ;
    schema1:description "Methods for Spike-in Arrays" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/spkTools_1.66.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/spkTools/spkTools_1.66.0.tar.gz', 'https://bioarchive.galaxyproject.org/spkTools_1.66.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-spktools/bioconductor-spktools_1.66.0_src_all.tar.gz']" ;
    schema1:identifier biotools:spktools ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-spktools" ;
    schema1:softwareVersion "1.66.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/spkTools.html" ;
    spdx:builtFrom biotools:spktools .

