@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:rust-bio-tools a schema1:SoftwareApplication ;
    schema1:description "A set of command line utilities based on Rust-Bio." ;
    schema1:keywords "Genomics" ;
    schema1:license "MIT" ;
    schema1:name "rust-bio-tools" ;
    schema1:url "https://github.com/rust-bio/rust-bio-tools" .

