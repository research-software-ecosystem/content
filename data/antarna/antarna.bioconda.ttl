@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:antarna a schema1:SoftwareApplication ;
    schema1:description "antaRNA is a python based implementation of ant-colony optimization of the RNA inverse folding problem." ;
    schema1:downloadUrl "https://github.com/RobertKleinkauf/antarna/archive/v2.0.6.tar.gz" ;
    schema1:identifier biotools:antarna ;
    schema1:license "MIT" ;
    schema1:name "antarna" ;
    schema1:softwareVersion "2.0.6" ;
    schema1:url "https://github.com/RobertKleinkauf/antarna" ;
    spdx:builtFrom biotools:antarna .

