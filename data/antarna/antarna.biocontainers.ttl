@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:antarna a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btv319" ;
    schema1:description "antaRNA is a python based implementation of ant-colony optimization of the RNA inverse folding problem." ;
    schema1:identifier biotools:antarna ;
    schema1:keywords "Animals",
        "Ants",
        "Base Composition",
        "Base Sequence",
        "Databases, Genetic",
        "Sequence Analysis, RNA",
        "Sequence analysis" ;
    schema1:license "MIT" ;
    schema1:name "antarna" ;
    schema1:url "https://github.com/RobertKleinkauf/antarna" .

