@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-trigger a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Transcriptional Regulatory Inference from Genetics of Gene ExpRession" ;
    schema1:identifier biotools:trigger ;
    schema1:keywords "Computational Biology",
        "Gene Expression",
        "Gene Expression Profiling",
        "Genetics",
        "Genomics",
        "Genotype and phenotype",
        "High-Throughput Screening Assays",
        "Molecular interactions, pathways and networks",
        "Programming Languages",
        "User-Computer Interface" ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-trigger" ;
    schema1:url "http://bioconductor.org/packages/3.6/bioc/html/trigger.html" .

