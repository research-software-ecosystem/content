@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:sofa-apps a schema1:SoftwareApplication ;
    schema1:description "Gui for the simulation open framework architecture (sofa)" ;
    schema1:license "custom, see /usr/share/doc/sofa-apps/copyright" ;
    schema1:name "sofa-apps" ;
    schema1:url "https://github.com/sofa-framework/sofa/" .

