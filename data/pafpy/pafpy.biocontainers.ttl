@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:pafpy a schema1:SoftwareApplication ;
    schema1:description "A lightweight library for working with PAF (Pairwise mApping Format) files" ;
    schema1:license "Unlicense" ;
    schema1:name "pafpy" ;
    schema1:url "https://github.com/mbhall88/pafpy" .

