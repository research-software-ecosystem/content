@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-squadd a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Add-on of the SQUAD Software" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.18/bioc/src/contrib/SQUADD_1.52.0.tar.gz', 'https://bioconductor.org/packages/3.18/bioc/src/contrib/Archive/SQUADD/SQUADD_1.52.0.tar.gz', 'https://bioarchive.galaxyproject.org/SQUADD_1.52.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-squadd/bioconductor-squadd_1.52.0_src_all.tar.gz']" ;
    schema1:identifier biotools:squadd ;
    schema1:license "GPL (>=2)" ;
    schema1:name "bioconductor-squadd" ;
    schema1:softwareVersion "1.52.0" ;
    schema1:url "https://bioconductor.org/packages/3.18/bioc/html/SQUADD.html" ;
    spdx:builtFrom biotools:squadd .

