@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-squadd a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Add-on of the SQUAD Software" ;
    schema1:identifier biotools:squadd ;
    schema1:keywords "Computational Biology",
        "Gene Expression Profiling",
        "Genomics",
        "High-Throughput Screening Assays",
        "Molecular interactions, pathways and networks",
        "Programming Languages",
        "User-Computer Interface" ;
    schema1:license "GPL (>=2)" ;
    schema1:name "bioconductor-squadd" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/SQUADD.html" .

