@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:pybedgraph a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btaa061" ;
    schema1:description "A package for fast operations on 1-dimensional genomic signal tracks" ;
    schema1:keywords "Chromatin",
        "Genome",
        "Genomics",
        "High-Throughput Nucleotide Sequencing" ;
    schema1:license "MIT" ;
    schema1:name "pybedgraph" ;
    schema1:url "https://github.com/TheJacksonLaboratory/pyBedGraph" .

