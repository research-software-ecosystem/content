      "sc:author": [
        "Gabriel Odom",
        "Lissette Gomez",
        "Lily Wang",
        "Tiago Silva"
      ],
      "sc:citation": {
        "@id": "https://doi.org/10.18129/B9.bioc.coMethDMR"
      },
      "sc:contributor": [
        "Boissel Mathilde",
        "Ning Lijiao"
      ],
      "sc:description": "coMethDMR identifies genomic regions associated with continuous phenotypes by optimally leverages covariations among CpGs within predefined genomic regions. Instead of testing all CpGs within a genomic region, coMethDMR carries out an additional step that selects co-methylated sub-regions first without using any outcome information. Next, coMethDMR tests association between methylation within the sub-region and continuous phenotype using a random coefficient mixed effects model, which models both variations between CpG sites within the region and differential methylation simultaneously.",
      "sc:license": "GPL-3.0-only",
      "sc:name": "coMethDMR",
      "sc:operatingSystem": [
        "Windows",
        "Mac",
        "Linux"
      ],
      "sc:softwareHelp": {
        "@id": "https://bioconductor.org/packages/coMethDMR"
      },
      "sc:softwareVersion": "1.14.0",
      "sc:url": "https://bioconductor.org/packages/coMethDMR"
    }
  ]
