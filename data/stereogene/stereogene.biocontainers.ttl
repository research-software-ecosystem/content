@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:stereogene a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btx379",
        "doi:10.1101/059584" ;
    schema1:description "StereoGene: Rapid Estimation of Genomewide Correlation of Continuous or Interval Feature Data" ;
    schema1:identifier biotools:stereogene ;
    schema1:keywords "Chromatin Immunoprecipitation",
        "Epigenomics",
        "Gene Expression Regulation",
        "Genome, Human",
        "Genomics",
        "Humans",
        "Mapping",
        "Sequence Analysis, DNA",
        "Sequencing" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "stereogene" ;
    schema1:url "https://github.com/favorov/stereogene" .

