@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-mgfm a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s12864-015-1785-9" ;
    schema1:description "Marker Gene Finder in Microarray gene expression data" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/MGFM_1.44.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/MGFM/MGFM_1.44.0.tar.gz', 'https://bioarchive.galaxyproject.org/MGFM_1.44.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-mgfm/bioconductor-mgfm_1.44.0_src_all.tar.gz']" ;
    schema1:identifier biotools:mgfm ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-mgfm" ;
    schema1:softwareVersion "1.44.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/MGFM.html" ;
    spdx:builtFrom biotools:mgfm .

