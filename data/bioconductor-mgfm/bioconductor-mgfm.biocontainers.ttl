@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-mgfm a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s12864-015-1785-9" ;
    schema1:description "Marker Gene Finder in Microarray gene expression data" ;
    schema1:identifier biotools:mgfm ;
    schema1:keywords "Computational Biology",
        "Gene Expression",
        "Gene Expression Profiling",
        "Gene Ontology",
        "Gene expression",
        "Genetic Association Studies",
        "Genetic Markers",
        "Genetics",
        "Microarray experiment",
        "Organ Specificity",
        "Reproducibility of Results",
        "Web Browser" ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-mgfm" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/MGFM.html" .

