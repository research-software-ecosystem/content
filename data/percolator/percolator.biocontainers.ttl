@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:percolator a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1007/s13361-016-1460-7",
        "doi:10.1038/nmeth1113" ;
    schema1:description "Semi-supervised learning for peptide identification from ms/ms data." ;
    schema1:identifier biotools:Percolator ;
    schema1:keywords "Databases, Protein",
        "Humans",
        "Machine learning",
        "Mass Spectrometry",
        "Peptides",
        "Proteomics",
        "Proteomics experiment",
        "Statistics and probability" ;
    schema1:license "Apache-2.0" ;
    schema1:name "percolator" ;
    schema1:url "https://github.com/percolator/percolator" .

