@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:percolator a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1007/s13361-016-1460-7" ;
    schema1:description "Semi-supervised learning for peptide identification from shotgun proteomics datasets." ;
    schema1:downloadUrl "https://github.com/percolator/percolator/archive/refs/tags/rel-3-07-01.tar.gz" ;
    schema1:identifier biotools:Percolator ;
    schema1:license "Apache-2.0" ;
    schema1:name "percolator" ;
    schema1:softwareHelp "http://percolator.ms" ;
    schema1:softwareVersion "3.7.1" ;
    schema1:url "https://github.com/percolator/percolator" ;
    spdx:builtFrom biotools:Percolator .

