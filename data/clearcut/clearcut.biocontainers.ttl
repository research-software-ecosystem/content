@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:clearcut a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btl478" ;
    schema1:description "Extremely efficient phylogenetic tree reconstruction" ;
    schema1:keywords "Computational Biology",
        "Computer Simulation",
        "Evolution, Molecular",
        "Models, Genetic",
        "Models, Statistical",
        "Phylogeny",
        "Programming Languages" ;
    schema1:license "BSD" ;
    schema1:name "clearcut" ;
    schema1:url "http://bioinformatics.hungry.com/clearcut/" .

