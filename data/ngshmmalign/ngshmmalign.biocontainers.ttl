@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:ngshmmalign a schema1:SoftwareApplication ;
    schema1:description "ngshmmalign is a profile HMM aligner for NGS reads designed particularly for small genomes" ;
    schema1:keywords "Sequence Alignment" ;
    schema1:license "GPL-2.0+" ;
    schema1:name "ngshmmalign" ;
    schema1:url "https://github.com/cbg-ethz/ngshmmalign" .

