@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:hs-blastn a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/gkv784" ;
    schema1:description "hs-blastn, a fast and accurate nucleotide-nucleotide sequences aligner." ;
    schema1:identifier biotools:hs-blastn ;
    schema1:keywords "Base Sequence",
        "DNA",
        "Databases, Nucleic Acid",
        "Genome, Human",
        "Humans",
        "Sequence Alignment",
        "Sequence analysis",
        "Sequence assembly" ;
    schema1:license "GPL-3.0" ;
    schema1:name "hs-blastn" ;
    schema1:url "https://github.com/chenying2016/queries" .

