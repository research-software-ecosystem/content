@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:apoc a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btt024" ;
    schema1:description "Large-scale structural comparison of protein pockets" ;
    schema1:keywords "Bacteria",
        "Bacterial Proteins",
        "Binding Sites",
        "GTP Phosphohydrolases",
        "Ligands",
        "Models, Molecular",
        "Models, Statistical",
        "Protein Conformation",
        "Proteins" ;
    schema1:license "This software is freely available to ALL users." ;
    schema1:name "apoc" ;
    schema1:url "http://cssb.biology.gatech.edu/APoc" .

