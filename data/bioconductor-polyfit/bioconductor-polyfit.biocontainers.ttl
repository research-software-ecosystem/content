@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-polyfit a schema1:SoftwareApplication ;
    schema1:citation "doi:10.7717/peerj.576" ;
    schema1:description "Add-on to DESeq to improve p-values and q-values" ;
    schema1:identifier biotools:polyfit ;
    schema1:keywords "Laboratory information management",
        "Statistics and probability" ;
    schema1:license "GPL-3.0" ;
    schema1:name "bioconductor-polyfit" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/Polyfit.html" .

