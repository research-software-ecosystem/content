@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-gseabase a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "This package provides classes and methods to support gene set enrichment analysis (gsea)." ;
    schema1:identifier biotools:gseabase ;
    schema1:keywords "Computational Biology",
        "Gene Expression Profiling",
        "Gene expression",
        "Genomics",
        "High-Throughput Screening Assays",
        "Programming Languages",
        "User-Computer Interface" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-gseabase" ;
    schema1:url "http://bioconductor.org/packages/release/bioc/html/GSEABase.html" .

