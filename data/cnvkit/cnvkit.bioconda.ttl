@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:cnvkit a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1371/journal.pcbi.1004873" ;
    schema1:description "Copy number variant detection from high-throughput sequencing." ;
    schema1:downloadUrl "https://github.com/etal/cnvkit/archive/v0.9.13.tar.gz" ;
    schema1:identifier biotools:cnvkit ;
    schema1:license "Apache-2.0" ;
    schema1:name "cnvkit" ;
    schema1:softwareHelp "https://cnvkit.readthedocs.io/en/stable" ;
    schema1:softwareVersion "0.9.13" ;
    schema1:url "https://github.com/etal/cnvkit" ;
    spdx:builtFrom biotools:cnvkit .

