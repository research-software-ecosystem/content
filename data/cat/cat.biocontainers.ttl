        "Benzene",
        "Binding Sites",
        "Cluster Analysis",
        "Genomics",
        "Humans",
        "Imidazoles",
        "Ligands",
        "Macromolecular Substances",
        "Metagenome",
        "Metagenomics",
        "Molecular Dynamics Simulation",
        "Protein Domains",
        "Proteins",
        "Proteome",
        "Receptors, Androgen",
        "Solvents" ;
    schema1:license "NIT" ;
    schema1:name "cat" ;
    schema1:url "https://github.com/dutilh/CAT" .

