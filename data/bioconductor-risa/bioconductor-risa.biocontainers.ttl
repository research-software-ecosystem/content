@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-risa a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/1471-2105-15-S7-S11" ;
    schema1:description "Converting experimental metadata from ISA-tab into Bioconductor data structures" ;
    schema1:identifier biotools:risa ;
    schema1:keywords "Amino Acid Sequence",
        "Humans",
        "Huntingtin Protein",
        "Huntington Disease",
        "Laboratory techniques",
        "Mass spectrometry",
        "Metabolomics",
        "Models, Molecular",
        "Molecular Sequence Data",
        "Nerve Tissue Proteins",
        "Peptides",
        "Protein Conformation",
        "Proteomics" ;
    schema1:license "LGPL" ;
    schema1:name "bioconductor-risa" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/Risa.html" .

