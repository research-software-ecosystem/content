@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-risa a schema1:SoftwareApplication ;
    schema1:description "Converting experimental metadata from ISA-tab into Bioconductor data structures" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.18/bioc/src/contrib/Risa_1.44.0.tar.gz', 'https://bioconductor.org/packages/3.18/bioc/src/contrib/Archive/Risa/Risa_1.44.0.tar.gz', 'https://bioarchive.galaxyproject.org/Risa_1.44.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-risa/bioconductor-risa_1.44.0_src_all.tar.gz']" ;
    schema1:identifier biotools:risa ;
    schema1:license "LGPL" ;
    schema1:name "bioconductor-risa" ;
    schema1:softwareVersion "1.44.0" ;
    schema1:url "https://bioconductor.org/packages/3.18/bioc/html/Risa.html" ;
    spdx:builtFrom biotools:risa .

