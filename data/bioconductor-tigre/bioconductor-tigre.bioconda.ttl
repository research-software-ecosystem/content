@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-tigre a schema1:SoftwareApplication ;
    schema1:description "Transcription factor Inference through Gaussian process Reconstruction of Expression" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/tigre_1.60.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/tigre/tigre_1.60.0.tar.gz', 'https://bioarchive.galaxyproject.org/tigre_1.60.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-tigre/bioconductor-tigre_1.60.0_src_all.tar.gz']" ;
    schema1:identifier biotools:tigre ;
    schema1:license "AGPL-3" ;
    schema1:name "bioconductor-tigre" ;
    schema1:softwareVersion "1.60.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/tigre.html" ;
    spdx:builtFrom biotools:tigre .

