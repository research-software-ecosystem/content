@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:theseus a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btl332" ;
    schema1:description "Superimpose macromolecules using maximum likelihood" ;
    schema1:keywords "Protein Sequences",
        "Sequence Alignment" ;
    schema1:license "GPL-3.0+" ;
    schema1:name "theseus" ;
    schema1:url "http://www.theseus3d.org" .

