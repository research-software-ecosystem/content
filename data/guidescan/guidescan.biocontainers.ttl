@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:guidescan a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nbt.3804" ;
    schema1:description "Tools to create and interface genome-wide CRISPR guideRNA databases" ;
    schema1:identifier biotools:guidescan ;
    schema1:keywords "Biotechnology",
        "CRISPR-Cas Systems",
        "Chromosome Mapping",
        "Clustered Regularly Interspaced Short Palindromic Repeats",
        "Functional genomics",
        "Gene Silencing",
        "Machine Learning",
        "RNA",
        "RNA, Small Interfering",
        "Sequence Analysis, RNA",
        "Synthetic chemistry" ;
    schema1:license "Custom License" ;
    schema1:name "guidescan" ;
    schema1:url "https://bitbucket.org/arp2012/guidescan_public" .

