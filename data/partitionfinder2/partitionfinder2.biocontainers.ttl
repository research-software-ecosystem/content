@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:partitionfinder2 a schema1:SoftwareApplication ;
    schema1:description "Partitionfinder 2: program for simultaneously choosing partitioning schemes and models of molecular evolution for phylogenetic analyses of dna, protein, and morphological data" ;
    schema1:license "GPL-2.0-only" ;
    schema1:name "partitionfinder2" ;
    schema1:url "https://github.com/brettc/partitionfinder" .

