    {
      "@id": "https://bio.tools/bioconductor-msimpute",
      "@type": "sc:SoftwareApplication",
      "dcterms:conformsTo": "https://bioschemas.org/profiles/ComputationalTool/0.6-DRAFT",
      "sc:additionalType": [
        "Library",
        "Command-line tool"
      ],
      "sc:author": "Soroor Hediyeh-zadeh",
      "sc:citation": {
        "@id": "https://doi.org/10.18129/B9.bioc.msImpute"
      },
      "sc:description": "MsImpute is a package for imputation of peptide intensity in proteomics experiments. It additionally contains tools for MAR/MNAR diagnosis and assessment of distortions to the probability distribution of the data post imputation.  The missing values are imputed by low-rank approximation of the underlying data matrix if they are MAR (method = \"v2\"), by Barycenter approach if missingness is MNAR (\"v2-mnar\"), or by Peptide Identity Propagation (PIP).",
      "sc:license": "GPL-2.0-only",
      "sc:name": "msImpute",
      "sc:operatingSystem": [
        "Mac",
        "Linux",
        "Windows"
      ],
      "sc:softwareHelp": {
        "@id": "https://bioconductor.org/packages/msImpute"
      },
      "sc:softwareVersion": "1.20.0",
      "sc:url": "https://bioconductor.org/packages/msImpute"
    }
  ]
