@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-tenxplore a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18129/b9.bioc.tenxplore" ;
    schema1:description "Ontological exploration of scrna-seq of 1.3 million mouse neurons from 10x genomics" ;
    schema1:keywords "Genomics",
        "RNA-Seq",
        "Transcriptomics" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-tenxplore" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/tenXplore.html" .

