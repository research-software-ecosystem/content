@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-affyexpress a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Affymetrix Quality Assessment and Analysis Tool" ;
    schema1:identifier biotools:affyexpress ;
    schema1:keywords "Computational Biology",
        "Data mining",
        "Gene Expression",
        "Gene Expression Profiling",
        "Gene expression",
        "Genomics",
        "High-Throughput Screening Assays",
        "Programming Languages",
        "User-Computer Interface" ;
    schema1:license "LGPL" ;
    schema1:name "bioconductor-affyexpress" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/AffyExpress.html" .

