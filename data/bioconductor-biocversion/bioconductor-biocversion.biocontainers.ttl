@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-biocversion a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18129/b9.bioc.biocversion" ;
    schema1:description "Set the appropriate version of bioconductor packages" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-biocversion" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/BiocVersion.html" .

