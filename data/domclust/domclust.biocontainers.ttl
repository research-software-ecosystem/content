@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:domclust a schema1:SoftwareApplication ;
    schema1:description "Effective tool for orthologous grouping in multiple genomes" ;
    schema1:keywords "Clustering",
        "Genomics",
        "Ortholog" ;
    schema1:license "GPL-3.0" ;
    schema1:name "domclust" ;
    schema1:url "http://mbgd.genome.ad.jp/domclust/" .

