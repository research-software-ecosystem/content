bioconda:bioconductor-bicare a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Biclustering Analysis and Results Exploration" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/BicARE_1.64.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/BicARE/BicARE_1.64.0.tar.gz', 'https://bioarchive.galaxyproject.org/BicARE_1.64.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-bicare/bioconductor-bicare_1.64.0_src_all.tar.gz']" ;
    schema1:identifier biotools:bicare ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-bicare" ;
    schema1:softwareVersion "1.64.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/BicARE.html" ;
    spdx:builtFrom biotools:bicare .

