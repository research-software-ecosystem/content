@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-bicare a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Biclustering Analysis and Results Exploration" ;
    schema1:identifier biotools:bicare ;
    schema1:keywords "Clustering",
        "Computational Biology",
        "Data management",
        "Gene Expression Profiling",
        "Genomics",
        "High-Throughput Screening Assays",
        "Informatics",
        "Programming Languages",
        "User-Computer Interface" ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-bicare" ;
    schema1:url "https://www.bioconductor.org/packages/release/bioc/html/BicARE.html" .

