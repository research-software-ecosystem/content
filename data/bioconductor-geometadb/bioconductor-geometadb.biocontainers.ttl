@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-geometadb a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btn520" ;
    schema1:description "A thin wrapper around the sqlite database along with associated documentation. access to the metadata associated with samples, platforms, and datasets much more feasible." ;
    schema1:identifier biotools:geometadb ;
    schema1:keywords "Data acquisition",
        "Databases, Genetic",
        "Gene Expression",
        "Gene Expression Profiling",
        "Information Storage and Retrieval",
        "Microarray experiment",
        "Oligonucleotide Array Sequence Analysis",
        "User-Computer Interface" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-geometadb" ;
    schema1:url "http://bioconductor.org/packages/release/bioc/html/GEOmetadb.html" .

