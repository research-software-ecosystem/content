@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-geometadb a schema1:SoftwareApplication ;
    schema1:description "A compilation of metadata from NCBI GEO" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/GEOmetadb_1.68.1.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/GEOmetadb/GEOmetadb_1.68.1.tar.gz', 'https://bioarchive.galaxyproject.org/GEOmetadb_1.68.1.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-geometadb/bioconductor-geometadb_1.68.1_src_all.tar.gz']" ;
    schema1:identifier biotools:geometadb ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-geometadb" ;
    schema1:softwareVersion "1.68.1" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/GEOmetadb.html" ;
    spdx:builtFrom biotools:geometadb .

