@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-ggrepel a schema1:SoftwareApplication ;
    schema1:description "Provides text and label geoms for 'ggplot2' that help to avoid overlapping text labels. Labels repel away from each other and away from the data points." ;
    schema1:license "GPL-2" ;
    schema1:name "r-ggrepel" ;
    schema1:url "None" .

