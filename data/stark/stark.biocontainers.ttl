@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:stark a schema1:SoftwareApplication ;
    schema1:description "A tool for bluntifying a bidirected de bruijn graph by removing overlaps." ;
