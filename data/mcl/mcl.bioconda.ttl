@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:mcl a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/30.7.1575",
        "doi:10.1137/040608635" ;
    schema1:description "MCL - a cluster algorithm for graphs." ;
    schema1:downloadUrl "https://micans.org/mcl/src/cimfomfa-22-273.tar.gz",
        "https://micans.org/mcl/src/mcl-22-282.tar.gz" ;
    schema1:identifier biotools:mcl ;
    schema1:license "GPL-3.0-only" ;
    schema1:name "mcl" ;
    schema1:softwareHelp "https://micans.org/mcl/man/mcl.html" ;
    schema1:softwareVersion "22.282" ;
    schema1:url "https://micans.org/mcl" ;
    spdx:builtFrom biotools:mcl .

