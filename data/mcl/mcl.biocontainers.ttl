@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:mcl a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1007/978-1-61779-361-5_15" ;
    schema1:description "Mcl is a clustering algorithm widely used in bioinformatics and gaining traction in other fields." ;
    schema1:identifier biotools:mcl ;
    schema1:keywords "Cluster Analysis",
        "Computational Biology",
        "Computer science",
        "Gene Expression Profiling",
        "Mathematical Concepts",
        "Molecular interactions, pathways and networks",
        "Sequence Homology, Amino Acid" ;
    schema1:license "GPL-2.0" ;
    schema1:name "mcl" ;
    schema1:url "http://micans.org/mcl/" .

