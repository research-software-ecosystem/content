@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:erne a schema1:SoftwareApplication ;
    schema1:description "ERNE - Extended Randomized Numerical alignEr" ;
    schema1:downloadUrl "https://downloads.sourceforge.net/project/erne/2.1.1/erne-2.1.1-source.tar.gz" ;
    schema1:identifier biotools:erne ;
    schema1:license "GPLv3" ;
    schema1:name "erne" ;
    schema1:softwareVersion "2.1.1" ;
    schema1:url "http://erne.sourceforge.net" ;
    spdx:builtFrom biotools:erne .

