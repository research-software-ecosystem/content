@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:opencontactcli a schema1:SoftwareApplication ;
    schema1:description "Static contact mapping algorithm to identify potential peptide biomimetics from protein interaction partner structure files." ;
    schema1:keywords "Proteomics" ;
    schema1:license "https://github.com/galaxyproteomics/OpenContact/blob/master/LICENSE_AGREEMENT/OpenContact_License.txt" ;
    schema1:name "opencontactcli" ;
    schema1:url "https://github.com/galaxyproteomics/OpenContact/tree/master" .

