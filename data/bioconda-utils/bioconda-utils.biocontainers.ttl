@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconda-utils a schema1:SoftwareApplication ;
    schema1:description "Utilities for building and managing bioconda recipes." ;
    schema1:license "MIT" ;
    schema1:name "bioconda-utils" ;
    schema1:url "http://bioconda.github.io/build-system.html" .

