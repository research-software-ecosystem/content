@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bustools a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/BIOINFORMATICS/BTZ279" ;
    schema1:description "bustools is a program for manipulating BUS files for single cell RNA-Seq datasets. It can be used to error correct barcodes, collapse UMIs, produce gene count or transcript compatibility count matrices, and is useful for many other tasks." ;
    schema1:keywords "RNA-Seq",
        "Sequence Analysis, RNA",
        "Single-Cell Analysis",
        "Whole Exome Sequencing" ;
    schema1:license "BSD-2-Clause" ;
    schema1:name "bustools" ;
    schema1:url "https://github.com/BUStools/bustools" .

