@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:flash a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btr507" ;
    schema1:description "Merge mates from fragments that are shorter than twice the read length" ;
    schema1:identifier biotools:flash ;
    schema1:keywords "Chromosomes, Human, Pair 14",
        "Genetics",
        "Genome",
        "Genomics",
        "Humans",
        "RNA-Seq",
        "Sequence Analysis, DNA",
        "Sequence assembly",
        "Sequencing",
        "Staphylococcus aureus",
        "Transcriptome" ;
    schema1:license "GPL-3.0" ;
    schema1:name "flash" ;
    schema1:url "https://ccb.jhu.edu/software/FLASH/" .

