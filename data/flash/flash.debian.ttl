@prefix debianmed: <https://salsa.debian.org/med-team/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

debianmed:flash a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btr507" ;
    schema1:description "Fast Length Adjustment of SHort reads" ;
    schema1:identifier "bio.tools:flash",
        "conda:bioconda:flash" ;
    schema1:license "unknown" ;
    schema1:name "flash" ;
    schema1:softwareVersion "1.2.11" ;
    schema1:url "https://ccb.jhu.edu/software/FLASH/" ;
    spdx:builtFrom "flash" .

