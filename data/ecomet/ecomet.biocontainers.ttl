@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:ecomet a schema1:SoftwareApplication ;
    schema1:description "Eco-Metabolomics container containing R and packages used in Ecology and Metabolomics" ;
    schema1:keywords "Metabolomics" ;
    schema1:license "Apache-2" ;
    schema1:name "ecomet" ;
    schema1:url "https://github.com/phnmnl/container-ecomet" .

