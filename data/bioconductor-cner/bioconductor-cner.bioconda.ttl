@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-cner a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "CNE Detection and Visualization" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/CNEr_1.46.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/CNEr/CNEr_1.46.0.tar.gz', 'https://bioarchive.galaxyproject.org/CNEr_1.46.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-cner/bioconductor-cner_1.46.0_src_all.tar.gz']" ;
    schema1:identifier biotools:cner ;
    schema1:license "GPL-2 | file LICENSE" ;
    schema1:name "bioconductor-cner" ;
    schema1:softwareVersion "1.46.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/CNEr.html" ;
    spdx:builtFrom biotools:cner .

