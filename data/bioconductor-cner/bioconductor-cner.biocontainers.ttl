@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-cner a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "CNE Detection and Visualization" ;
    schema1:identifier biotools:cner ;
    schema1:keywords "Computational Biology",
        "Functional, regulatory and non-coding RNA",
        "Gene Expression Profiling",
        "Genomics",
        "High-Throughput Screening Assays",
        "Programming Languages",
        "User-Computer Interface" ;
    schema1:license "GPL-2 | file LICENSE" ;
    schema1:name "bioconductor-cner" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/CNEr.html" .

