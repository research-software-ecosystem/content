@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-geneplast a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Evolutionary and plasticity analysis of orthologous groups" ;
    schema1:identifier biotools:geneplast ;
    schema1:keywords "Computational Biology",
        "Evolutionary biology",
        "Gene Expression Profiling",
        "Genetics",
        "Genomics",
        "High-Throughput Screening Assays",
        "Ortholog",
        "Programming Languages",
        "User-Computer Interface" ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-geneplast" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/geneplast.html" .

