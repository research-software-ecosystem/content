@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:jemboss a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btg251" ;
    schema1:description "Graphical user interface to emboss" ;
    schema1:keywords "Computer Graphics",
        "Database Management Systems",
        "Databases, Factual",
        "Europe",
        "Hypermedia",
        "Information Storage and Retrieval",
        "Internet",
        "Local Area Networks",
        "Molecular Biology",
        "Programming Languages",
        "Software Design",
        "User-Computer Interface" ;
    schema1:license "emboss" ;
    schema1:name "jemboss" ;
    schema1:url "http://emboss.sourceforge.net" .

