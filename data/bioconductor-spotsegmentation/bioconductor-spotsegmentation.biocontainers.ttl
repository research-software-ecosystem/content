@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-spotsegmentation a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/bti447" ;
    schema1:description "Microarray Spot Segmentation and Gridding for Blocks of Microarray Spots" ;
    schema1:identifier biotools:spotsegmentation ;
    schema1:keywords "Artifacts",
        "Clustering",
        "Data quality management",
        "Gene Expression Profiling",
        "Image Enhancement",
        "Image Interpretation, Computer-Assisted",
        "In Situ Hybridization, Fluorescence",
        "Microarray experiment",
        "Microscopy, Fluorescence",
        "Models, Genetic",
        "Oligonucleotide Array Sequence Analysis",
        "Pattern Recognition, Automated" ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-spotsegmentation" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/spotSegmentation.html" .

