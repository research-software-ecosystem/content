@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-graphite a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/1471-2105-13-20" ;
    schema1:description "GRAPH Interaction from pathway Topological Environment" ;
    schema1:identifier biotools:graphite ;
    schema1:keywords "Functional genomics",
        "Gene Regulatory Networks",
        "Humans",
        "Insulin",
        "Metabolomics",
        "Oligonucleotide Array Sequence Analysis",
        "Receptor, Notch1",
        "Signal Transduction" ;
    schema1:license "AGPL-3" ;
    schema1:name "bioconductor-graphite" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/graphite.html" .

