@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-graphite a schema1:SoftwareApplication ;
    schema1:description "GRAPH Interaction from pathway Topological Environment" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/graphite_1.52.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/graphite/graphite_1.52.0.tar.gz', 'https://bioarchive.galaxyproject.org/graphite_1.52.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-graphite/bioconductor-graphite_1.52.0_src_all.tar.gz']" ;
    schema1:identifier biotools:graphite ;
    schema1:license "AGPL-3" ;
    schema1:name "bioconductor-graphite" ;
    schema1:softwareVersion "1.52.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/graphite.html" ;
    spdx:builtFrom biotools:graphite .

