@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:genomicassertions a schema1:SoftwareApplication ;
    schema1:description "A package to test common files in genomics (.vcf.gz, .bam)" ;
    schema1:license "MIT" ;
    schema1:name "genomicassertions" ;
    schema1:url "https://github.com/dakl/genomicassertions" .

