@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:ucsc-pslscore a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btq351",
        "doi:10.1101/gr.229102" ;
    schema1:description "Calculate web blat score from psl files." ;
    schema1:identifier biotools:UCSC_Genome_Browser_Utilities ;
    schema1:keywords "California",
        "Database Management Systems",
        "Databases, Genetic",
        "Gene Expression",
        "Genes",
        "Genome, Human",
        "Humans",
        "RNA, Messenger",
        "Sequence Homology, Nucleic Acid",
        "Universities" ;
    schema1:license "Custom License" ;
    schema1:name "ucsc-pslscore" ;
    schema1:url "http://hgdownload.cse.ucsc.edu/admin/exe/" .

