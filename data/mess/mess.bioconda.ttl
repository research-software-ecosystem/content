@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:mess a schema1:SoftwareApplication ;
    schema1:author "farchaab",
        "tpillone" ;
    schema1:description "Snakemake pipeline for simulating shotgun metagenomic samples" ;
    schema1:downloadUrl "https://github.com/metagenlab/MeSS/archive/refs/tags/v0.12.0.tar.gz" ;
    schema1:identifier biotools:mess ;
    schema1:license "MIT" ;
    schema1:maintainer "farchaab",
        "tpillone" ;
    schema1:name "mess" ;
    schema1:softwareHelp "https://metagenlab.github.io/MeSS" ;
    schema1:softwareVersion "0.12.0" ;
    schema1:url "https://github.com/metagenlab/MeSS" ;
    spdx:builtFrom biotools:mess .

