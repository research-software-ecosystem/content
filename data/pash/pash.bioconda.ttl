@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:pash a schema1:SoftwareApplication ;
    schema1:description "A versatile software package for read mapping and integrative analysis of genomic and epigenomic variation using massively parallel DNA sequencing" ;
    schema1:downloadUrl "https://genboree.org/pash-supp/pash-3.0.6.2.tar.gz" ;
    schema1:identifier biotools:pash ;
    schema1:license "Unknown" ;
    schema1:name "pash" ;
    schema1:softwareVersion "3.0.6.2" ;
    schema1:url "http://www.bioinformatics.bbsrc.ac.uk/projects/bismark/" ;
    spdx:builtFrom biotools:pash .

