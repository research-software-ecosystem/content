@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:pash a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/1471-2105-11-572" ;
    schema1:description "A versatile software package for read mapping and integrative analysis" ;
    schema1:identifier biotools:pash ;
    schema1:keywords "Base Sequence",
        "DNA",
        "Databases, Genetic",
        "Epigenetics",
        "Epigenomics",
        "Genetic Variation",
        "Genome",
        "Polymorphism, Single Nucleotide",
        "Sequence Analysis, DNA" ;
    schema1:license "Not available" ;
    schema1:name "pash" ;
    schema1:url "http://www.bioinformatics.bbsrc.ac.uk/projects/bismark/" .

