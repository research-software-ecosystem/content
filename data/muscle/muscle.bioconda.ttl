@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:muscle a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/s41467-022-34630-w" ;
    schema1:description "Multiple sequence and structure alignment with top benchmark scores scalable to thousands of sequences." ;
    schema1:downloadUrl "https://github.com/rcedgar/muscle/archive/refs/tags/v5.3.tar.gz" ;
    schema1:identifier biotools:muscle ;
    schema1:license "GPL-3.0-only" ;
    schema1:name "muscle" ;
    schema1:softwareHelp "https://drive5.com/muscle5" ;
    schema1:softwareVersion "5.3" ;
    schema1:url "https://github.com/rcedgar/muscle" ;
    spdx:builtFrom biotools:muscle .

