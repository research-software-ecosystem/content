@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-plw a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/1471-2105-9-156" ;
    schema1:description "Probe level Locally moderated Weighted t-tests." ;
    schema1:identifier biotools:plw ;
    schema1:keywords "Artificial Intelligence",
        "Bayes Theorem",
        "Computer Simulation",
        "DNA Probes",
        "Gene Expression Profiling",
        "Models, Genetic",
        "Models, Statistical",
        "Oligonucleotide Array Sequence Analysis",
        "Pattern Recognition, Automated",
        "Probes and primers",
        "Statistics and probability" ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-plw" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/plw.html" .

