@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:kaiju a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/ncomms11257" ;
    schema1:description "Fast and sensitive taxonomic classification for metagenomics." ;
    schema1:downloadUrl "https://github.com/bioinformatics-centre/kaiju/archive/v1.10.1.tar.gz" ;
    schema1:identifier biotools:kaiju ;
    schema1:license "GPL-3.0-or-later" ;
    schema1:name "kaiju" ;
    schema1:softwareHelp "https://github.com/bioinformatics-centre/kaiju/blob/v1.10.1/README.md" ;
    schema1:softwareVersion "1.10.1" ;
    schema1:url "https://github.com/bioinformatics-centre/kaiju" ;
    spdx:builtFrom biotools:kaiju .

