@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:kaiju a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/ncomms11257" ;
    schema1:description "Fast and sensitive taxonomic classification for metagenomics" ;
    schema1:identifier biotools:kaiju ;
    schema1:keywords "Amino Acid Sequence",
        "Animals",
        "Classification",
        "Genomics",
        "Humans",
        "Metagenome",
        "Metagenomics",
        "Protein Sequences",
        "Proteins" ;
    schema1:license "GPL-3.0" ;
    schema1:name "kaiju" ;
    schema1:url "https://github.com/bioinformatics-centre/kaiju" .

