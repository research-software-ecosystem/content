@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:footprint a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/gku810" ;
    schema1:description "This is a pipeline to find transcription factor footprints in atac-seq or dnase-seq data." ;
    schema1:keywords "Genomics",
        "Ortholog",
        "RNA-Seq" ;
    schema1:license "Not available" ;
    schema1:name "footprint" ;
    schema1:url "https://ohlerlab.mdc-berlin.de/software/Reproducible_footprinting_139/" .

