@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-timecoursedata a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18129/b9.bioc.timecoursedata" ;
    schema1:description "A data package for timecourse rna-seq and microarray gene expression data sets" ;
    schema1:keywords "Gene Expression",
        "RNA-Seq" ;
    schema1:license "Not available" ;
    schema1:name "bioconductor-timecoursedata" ;
    schema1:url "https://bioconductor.org/packages/3.12/data/experiment/html/timecoursedata.html" .

