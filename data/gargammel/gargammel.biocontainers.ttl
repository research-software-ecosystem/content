@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:gargammel a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btw670" ;
    schema1:description "Tool for simulating ancient DNA datasets" ;
    schema1:keywords "Genomics",
        "Metagenomics" ;
    schema1:license "GPL-3.0-only" ;
    schema1:name "gargammel" ;
    schema1:url "https://github.com/grenaud/gargammel" .

