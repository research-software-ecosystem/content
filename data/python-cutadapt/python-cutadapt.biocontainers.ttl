@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:python-cutadapt a schema1:SoftwareApplication ;
    schema1:citation "doi:10.14806/ej.17.1.200" ;
    schema1:description "Cutadapt finds and removes adapter sequences, primers, poly-A tails and other types of unwanted sequence from your high-throughput sequencing reads." ;
    schema1:license "MIT" ;
    schema1:name "python-cutadapt" ;
    schema1:url "https://pypi.org/project/cutadapt/" .

