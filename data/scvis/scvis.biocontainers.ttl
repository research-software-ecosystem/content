@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:scvis a schema1:SoftwareApplication ;
    schema1:description "scvis is a python package for dimension reduction of high-dimensional biological data, especially single-cell RNA-sequencing (scRNA-seq) data." ;
    schema1:license "CC-BY-4.0" ;
    schema1:name "scvis" ;
    schema1:url "https://bitbucket.org/jerry00/scvis-dev/commits/all" .

