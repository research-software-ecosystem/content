@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:fastspar a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/bty734",
        "doi:10.1371/journal.pcbi.1002687" ;
    schema1:description "Rapid and scalable correlation estimation for compositional data" ;
    schema1:keywords "Chromosome Mapping",
        "Clustering",
        "Computer Simulation",
        "Genetics, Population",
        "Genome, Bacterial",
        "Humans",
        "Microbial Consortia",
        "Models, Genetic",
        "Recombination, Genetic",
        "Statistics as Topic" ;
    schema1:license "GPL-3.0" ;
    schema1:name "fastspar" ;
    schema1:url "https://github.com/scwatts/fastspar" .

