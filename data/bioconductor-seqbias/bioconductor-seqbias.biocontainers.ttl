biocontainers:bioconductor-seqbias a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18129/b9.bioc.seqbias" ;
    schema1:description "Estimation of per-position bias in high-throughput sequencing data" ;
    schema1:license "LGPL-3" ;
    schema1:name "bioconductor-seqbias" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/seqbias.html" .

