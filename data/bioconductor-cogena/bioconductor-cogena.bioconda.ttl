@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-cogena a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s12864-016-2737-8" ;
    schema1:description "co-expressed gene-set enrichment analysis" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/cogena_1.40.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/cogena/cogena_1.40.0.tar.gz', 'https://bioarchive.galaxyproject.org/cogena_1.40.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-cogena/bioconductor-cogena_1.40.0_src_all.tar.gz']" ;
    schema1:identifier biotools:cogena ;
    schema1:license "LGPL-3" ;
    schema1:name "bioconductor-cogena" ;
    schema1:softwareVersion "1.40.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/cogena.html" ;
    spdx:builtFrom biotools:cogena .

