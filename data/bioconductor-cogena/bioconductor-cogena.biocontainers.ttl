@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-cogena a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s12864-016-2737-8" ;
    schema1:description "co-expressed gene-set enrichment analysis" ;
    schema1:identifier biotools:cogena ;
    schema1:keywords "Cluster Analysis",
        "Clustering",
        "Drug Discovery",
        "Drug Repositioning",
        "Gene Expression",
        "Gene Expression Profiling",
        "Gene Regulatory Networks",
        "Genetics",
        "Sequence analysis",
        "Web Browser",
        "Workflow" ;
    schema1:license "LGPL-3.0" ;
    schema1:name "bioconductor-cogena" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/cogena.html" .

