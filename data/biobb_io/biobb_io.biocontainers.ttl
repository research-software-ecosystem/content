@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:biobb_io a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/s41597-019-0177-4" ;
    schema1:description "Biobb_io is the Biobb module collection to fetch data to be consumed by the rest of the Biobb building blocks." ;
