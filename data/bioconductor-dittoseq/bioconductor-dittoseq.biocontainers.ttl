@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-dittoseq a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18129/b9.bioc.dittoseq" ;
    schema1:description "User friendly single-cell and bulk rna sequencing visualization" ;
    schema1:keywords "RNA-Seq",
        "Transcriptomics" ;
    schema1:license "MIT" ;
    schema1:name "bioconductor-dittoseq" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/dittoSeq.html" .

