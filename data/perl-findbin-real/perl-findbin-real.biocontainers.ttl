@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:perl-findbin-real a schema1:SoftwareApplication ;
    schema1:description "Locates the full path to the script bin directory to allow the use of paths relative to the bin directory." ;
