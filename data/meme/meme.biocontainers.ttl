@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:meme a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btv750" ;
    schema1:description "Motif based sequence analysis tools" ;
    schema1:identifier biotools:meme ;
    schema1:keywords "Binding Sites",
        "DNA",
        "Genome",
        "Humans",
        "Nucleic acid sites, features and motifs",
        "Protein sites, features and motifs",
        "Regulatory Elements, Transcriptional",
        "Sequence Analysis, DNA",
        "Transcription Factors" ;
    schema1:license "Custom License" ;
    schema1:name "meme" ;
    schema1:url "http://meme-suite.org" .

