@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:meme a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/gkv416" ;
    schema1:description "Motif-based sequence analysis tools." ;
    schema1:downloadUrl "https://meme-suite.org/meme/meme-software/5.5.9/meme-5.5.9.tar.gz" ;
    schema1:identifier biotools:meme_suite ;
    schema1:license "Custom" ;
    schema1:name "meme" ;
    schema1:softwareHelp "https://meme-suite.org/meme/doc/overview.html" ;
    schema1:softwareVersion "5.5.9" ;
    schema1:url "https://meme-suite.org" ;
    spdx:builtFrom biotools:meme_suite .

