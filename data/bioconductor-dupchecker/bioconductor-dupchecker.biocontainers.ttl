@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-dupchecker a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/1471-2105-15-323" ;
    schema1:description "a package for checking high-throughput genomic data redundancy in meta-analysis" ;
    schema1:identifier biotools:dupchecker ;
    schema1:keywords "Cluster Analysis",
        "Data Interpretation, Statistical",
        "Databases, Genetic",
        "Gene Expression",
        "Gene Expression Profiling",
        "Genomics",
        "High-Throughput Nucleotide Sequencing",
        "Meta-Analysis as Topic",
        "Sequencing" ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-dupchecker" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/DupChecker.html" .

