@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:keggcharter a schema1:SoftwareApplication ;
    schema1:description "A tool for representing genomic potential and transcriptomic expression into kegg pathways" ;
    schema1:keywords "Gene Expression",
        "Genomics",
        "Ortholog",
        "Transcriptomics" ;
    schema1:license "Not available" ;
    schema1:name "keggcharter" ;
    schema1:url "https://github.com/iquasere/KEGGCharter" .

