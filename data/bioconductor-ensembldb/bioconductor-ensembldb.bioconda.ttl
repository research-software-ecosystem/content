@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-ensembldb a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Utilities to create and use Ensembl-based annotation databases" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/ensembldb_2.34.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/ensembldb/ensembldb_2.34.0.tar.gz', 'https://bioarchive.galaxyproject.org/ensembldb_2.34.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-ensembldb/bioconductor-ensembldb_2.34.0_src_all.tar.gz']" ;
    schema1:identifier biotools:ensembldb ;
    schema1:license "LGPL" ;
    schema1:name "bioconductor-ensembldb" ;
    schema1:softwareVersion "2.34.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/ensembldb.html" ;
    spdx:builtFrom biotools:ensembldb .

