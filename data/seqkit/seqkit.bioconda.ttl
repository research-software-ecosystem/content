@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:seqkit a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1371/journal.pone.0163962" ;
    schema1:description "A cross-platform and ultrafast toolkit for FASTA/Q file manipulation." ;
    schema1:downloadUrl "https://github.com/shenwei356/seqkit/archive/refs/tags/v2.13.0.tar.gz" ;
    schema1:identifier biotools:seqkit ;
    schema1:license "MIT" ;
    schema1:name "seqkit" ;
    schema1:softwareHelp "https://bioinf.shenwei.me/seqkit" ;
    schema1:softwareVersion "2.13.0" ;
    schema1:url "https://github.com/shenwei356/seqkit" ;
    spdx:builtFrom biotools:seqkit .

