@prefix debianmed: <https://salsa.debian.org/med-team/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

debianmed:seqkit a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1371/journal.pone.0163962" ;
    schema1:description "cross-platform and ultrafast toolkit for FASTA/Q file manipulation" ;
    schema1:identifier "bio.tools:seqkit",
        "conda:bioconda:seqkit" ;
    schema1:license "unknown" ;
    schema1:name "seqkit" ;
    schema1:softwareVersion "2.10.1+ds" ;
    schema1:url "https://github.com/shenwei356/seqkit" ;
    spdx:builtFrom "seqkit" .

