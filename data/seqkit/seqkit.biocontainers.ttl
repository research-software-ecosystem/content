@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:seqkit a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1371/journal.pone.0163962" ;
    schema1:description "Cross-platform and ultrafast toolkit for fastaq file manipulation" ;
    schema1:keywords "Amino Acid Sequence",
        "Base Sequence",
        "Data Mining",
        "Protein Sequences",
        "Sequence Alignment",
        "Web Browser" ;
    schema1:license "MIT" ;
    schema1:name "seqkit" ;
    schema1:url "https://github.com/shenwei356/seqkit/" .

