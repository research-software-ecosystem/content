@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:genie a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/gkr246" ;
    schema1:description "A toolkit for working with next-generation sequencing data" ;
    schema1:identifier biotools:genie ;
    schema1:keywords "Animals",
        "Data mining",
        "Gene Expression Profiling",
        "Genes",
        "Genomics",
        "Heart",
        "Humans",
        "Internet",
        "MEDLINE",
        "Mice",
        "Models, Animal",
        "Zebrafish" ;
    schema1:license "MIT" ;
    schema1:name "genie" ;
    schema1:url "https://github.com/sakkayaphab/genie" .

