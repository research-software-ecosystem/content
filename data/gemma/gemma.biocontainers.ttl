@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:gemma a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btp259" ;
    schema1:description "Gemma is an open source database, analysis software system and web site for expression data re-use and meta-analysis. it currently contains analyzed data from over 3300 expression profiling studies, yielding billions of data points that can be searched and explored. gemma offers web-based access to differential expression results and coexpression data in a meta-analysis framework." ;
    schema1:identifier biotools:gemma ;
    schema1:keywords "Computational Biology",
        "Databases, Genetic",
        "Functional genomics",
        "Gene Expression",
        "Gene expression",
        "Genetics",
        "Genomics",
        "Oligonucleotide Array Sequence Analysis",
        "Semantics",
        "Transcriptome",
        "Unified Medical Language System" ;
    schema1:license "GPL-3.0+" ;
    schema1:name "gemma" ;
    schema1:url "http://chibi.ubc.ca/Gemma" .

