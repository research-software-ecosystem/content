@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:gemma a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/ng.2310" ;
    schema1:description "Linear mixed models (LMMs) for genome-wide association (GWA)." ;
    schema1:downloadUrl "https://github.com/genetics-statistics/GEMMA/archive/refs/tags/v0.98.5.tar.gz" ;
    schema1:identifier biotools:gemma_algorithm ;
    schema1:license "GPL-3.0-or-later" ;
    schema1:name "gemma" ;
    schema1:softwareHelp "https://github.com/genetics-statistics/GEMMA/blob/v0.98.5/README.md" ;
    schema1:softwareVersion "0.98.5" ;
    schema1:url "https://github.com/genetics-statistics/GEMMA" ;
    spdx:builtFrom biotools:gemma_algorithm .

