@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-geosubmission a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Prepares microarray data for submission to GEO" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/GEOsubmission_1.62.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/GEOsubmission/GEOsubmission_1.62.0.tar.gz', 'https://bioarchive.galaxyproject.org/GEOsubmission_1.62.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-geosubmission/bioconductor-geosubmission_1.62.0_src_all.tar.gz']" ;
    schema1:identifier biotools:geosubmission ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-geosubmission" ;
    schema1:softwareVersion "1.62.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/GEOsubmission.html" ;
    spdx:builtFrom biotools:geosubmission .

