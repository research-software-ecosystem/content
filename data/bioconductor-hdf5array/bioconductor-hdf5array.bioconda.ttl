@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-hdf5array a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "HDF5 datasets as array-like objects in R" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/HDF5Array_1.38.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/HDF5Array/HDF5Array_1.38.0.tar.gz', 'https://bioarchive.galaxyproject.org/HDF5Array_1.38.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-hdf5array/bioconductor-hdf5array_1.38.0_src_all.tar.gz']" ;
    schema1:identifier biotools:hdf5array ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-hdf5array" ;
    schema1:softwareVersion "1.38.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/HDF5Array.html" ;
    spdx:builtFrom biotools:hdf5array .

