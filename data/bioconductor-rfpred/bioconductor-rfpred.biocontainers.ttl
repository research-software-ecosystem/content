@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-rfpred a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1101/037127" ;
    schema1:description "Assign rfPred functional prediction scores to a missense variants list" ;
    schema1:identifier biotools:rfpred ;
    schema1:keywords "Exome sequencing" ;
    schema1:license "GPL (>=2 )" ;
    schema1:name "bioconductor-rfpred" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/rfPred.html" .

