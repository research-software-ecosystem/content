@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-quasr a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/gkq211" ;
    schema1:description "Quantify and Annotate Short Reads in R" ;
    schema1:identifier biotools:quasr ;
    schema1:keywords "Alternative Splicing",
        "ChIP-seq",
        "Computational Biology",
        "Genetics",
        "Humans",
        "Microarray experiment",
        "Polymerase Chain Reaction",
        "RNA Splice Sites",
        "RNA-seq",
        "Sequence Analysis, RNA",
        "Sequencing",
        "Workflows" ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-quasr" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/QuasR.html" .

