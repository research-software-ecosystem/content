@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-quasr a schema1:SoftwareApplication ;
    schema1:description "Quantify and Annotate Short Reads in R" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/QuasR_1.46.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/QuasR/QuasR_1.46.0.tar.gz', 'https://bioarchive.galaxyproject.org/QuasR_1.46.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-quasr/bioconductor-quasr_1.46.0_src_all.tar.gz']" ;
    schema1:identifier biotools:quasr ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-quasr" ;
    schema1:softwareVersion "1.46.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/QuasR.html" ;
    spdx:builtFrom biotools:quasr .

