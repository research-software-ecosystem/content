@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-causalr a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Causal network analysis methods" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/CausalR_1.42.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/CausalR/CausalR_1.42.0.tar.gz', 'https://bioarchive.galaxyproject.org/CausalR_1.42.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-causalr/bioconductor-causalr_1.42.0_src_all.tar.gz']" ;
    schema1:identifier biotools:causalr ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-causalr" ;
    schema1:softwareVersion "1.42.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/CausalR.html" ;
    spdx:builtFrom biotools:causalr .

