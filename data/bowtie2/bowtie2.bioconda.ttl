@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bowtie2 a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.1923" ;
    schema1:description "A fast and sensitive gapped read aligner." ;
    schema1:downloadUrl "https://github.com/BenLangmead/bowtie2/archive/v2.5.5.tar.gz" ;
    schema1:identifier biotools:bowtie2 ;
    schema1:license "GPL-3.0-or-later" ;
    schema1:name "bowtie2" ;
    schema1:softwareHelp "https://github.com/BenLangmead/bowtie2/blob/v2.5.5/README.md" ;
    schema1:softwareVersion "2.5.5" ;
    schema1:url "https://bowtie-bio.sourceforge.net/bowtie2/index.shtml" ;
    spdx:builtFrom biotools:bowtie2 .

