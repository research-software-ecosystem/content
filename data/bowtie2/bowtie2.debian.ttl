@prefix debianmed: <https://salsa.debian.org/med-team/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

debianmed:bowtie2 a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.1923" ;
    schema1:description "ultrafast memory-efficient short read aligner" ;
    schema1:identifier "bio.tools:bowtie2",
        "conda:bioconda:bowtie2",
        "guix:bowtie",
        "omictools:OMICS_31633",
        "scicrunch:SCR_005476" ;
    schema1:license "unknown" ;
    schema1:name "bowtie2" ;
    schema1:softwareVersion "2.5.5" ;
    schema1:url "https://bowtie-bio.sourceforge.net/bowtie2" ;
    spdx:builtFrom "bowtie2" .

