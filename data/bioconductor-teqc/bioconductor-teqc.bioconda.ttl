@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-teqc a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btr122" ;
    schema1:description "Quality control for target capture experiments" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/TEQC_4.28.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/TEQC/TEQC_4.28.0.tar.gz', 'https://bioarchive.galaxyproject.org/TEQC_4.28.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-teqc/bioconductor-teqc_4.28.0_src_all.tar.gz']" ;
    schema1:identifier biotools:teqc ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-teqc" ;
    schema1:softwareVersion "4.28.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/TEQC.html" ;
    spdx:builtFrom biotools:teqc .

