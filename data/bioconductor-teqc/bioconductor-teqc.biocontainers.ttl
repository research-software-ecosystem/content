@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-teqc a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btr122" ;
    schema1:description "Quality control for target capture experiments" ;
    schema1:identifier biotools:teqc ;
    schema1:keywords "Computational Biology",
        "DNA Probes",
        "Genetics",
        "Microarray experiment",
        "Nucleic Acid Hybridization",
        "Polymerase Chain Reaction",
        "Quality Control",
        "Reproducibility of Results",
        "Sensitivity and Specificity",
        "Sequence Analysis, DNA" ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-teqc" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/TEQC.html" .

