@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:pullseq a schema1:SoftwareApplication ;
    schema1:description "Utility program for extracting sequences from a fasta/fastq file." ;
    schema1:license "MIT" ;
    schema1:name "pullseq" ;
    schema1:url "https://github.com/bcthomas/pullseq" .

