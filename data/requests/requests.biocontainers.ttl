@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:requests a schema1:SoftwareApplication ;
    schema1:description "Requests is an elegant and simple HTTP library for Python" ;
    schema1:license "Apache-2.0" ;
    schema1:name "requests" ;
    schema1:url "https://github.com/psf/requests" .

