@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-ctrap a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18129/b9.bioc.ctrap" ;
    schema1:description "Identification of candidate causal perturbations from differential gene expression data" ;
    schema1:keywords "Gene Expression",
        "Transcriptomics" ;
    schema1:license "MIT" ;
    schema1:name "bioconductor-ctrap" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/cTRAP.html" .

