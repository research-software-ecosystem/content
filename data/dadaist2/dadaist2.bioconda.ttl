@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:dadaist2 a schema1:SoftwareApplication ;
    schema1:author "telatin" ;
    schema1:citation "doi:10.3390/ijms22105309" ;
    schema1:description "Command line wrapper to run DADA2 on a set of paired-end reads" ;
    schema1:downloadUrl "https://github.com/quadram-institute-bioscience/dadaist2/archive/v1.3.1.tar.gz" ;
    schema1:identifier biotools:dadaist2 ;
    schema1:license "MIT" ;
    schema1:maintainer "telatin" ;
    schema1:name "dadaist2" ;
    schema1:softwareVersion "1.3.1" ;
    schema1:url "https://quadram-institute-bioscience.github.io/dadaist2" ;
    spdx:builtFrom biotools:dadaist2 .

