@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:dadaist2 a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3869" ;
    schema1:description "Command line wrapper to run dada2 on a set of paired-end reads" ;
    schema1:identifier biotools:dadaist2 ;
