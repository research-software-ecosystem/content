        "Cohort Studies",
        "Computational Biology",
        "DNA, Bacterial",
        "False Positive Reactions",
        "Feces",
        "Female",
        "High-Throughput Nucleotide Sequencing",
        "Humans",
        "Lactobacillus",
        "Mice",
        "Microbiota",
        "Pregnancy",
        "RNA, Ribosomal, 16S",
        "Reproducibility of Results",
        "Sequence Analysis, DNA",
        "Vagina" ;
    schema1:license "MIT" ;
    schema1:name "dadaist2" ;
    schema1:url "https://github.com/quadram-institute-bioscience/dadaist2" .

