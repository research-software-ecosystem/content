@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:macs2 a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/gb-2008-9-9-r137" ;
    schema1:description "Model Based Analysis for ChIP-Seq data." ;
    schema1:downloadUrl "https://pypi.io/packages/source/M/MACS2/MACS2-2.2.9.1.tar.gz" ;
    schema1:identifier biotools:macs ;
    schema1:license "BSD-3-Clause" ;
    schema1:name "macs2" ;
    schema1:softwareHelp "https://macs3-project.github.io/MACS" ;
    schema1:softwareVersion "2.2.9.1" ;
    schema1:url "https://github.com/macs3-project/MACS" ;
    spdx:builtFrom biotools:macs .

