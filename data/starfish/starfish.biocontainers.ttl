@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:starfish a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/1471-2105-13-241" ;
    schema1:description "Standardized analysis pipeline for image-based transcriptomics" ;
    schema1:identifier biotools:starfish ;
    schema1:keywords "Chromatin",
        "Chromosomes",
        "DNA",
        "Genetics",
        "Humans",
        "Models, Molecular",
        "Nucleic Acid Conformation",
        "Statistics and probability",
        "Transcriptomics" ;
    schema1:license "MIT" ;
    schema1:name "starfish" ;
    schema1:url "https://github.com/spacetx/starfish" .

