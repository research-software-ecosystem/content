@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-lpeadj a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "A correction of the local pooled error (LPE) method to replace the asymptotic variance adjustment with an unbiased adjustment based on sample size." ;
    schema1:identifier biotools:lpeadj ;
    schema1:keywords "Applied mathematics",
        "Computational Biology",
        "Gene Expression Profiling",
        "Genomics",
        "High-Throughput Screening Assays",
        "Programming Languages",
        "Proteomics",
        "Statistics and probability",
        "User-Computer Interface" ;
    schema1:license "LGPL" ;
    schema1:name "bioconductor-lpeadj" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/LPEadj.html" .

