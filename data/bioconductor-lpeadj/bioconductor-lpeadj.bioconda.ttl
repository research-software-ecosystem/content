@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-lpeadj a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "A correction of the local pooled error (LPE) method to replace the asymptotic variance adjustment with an unbiased adjustment based on sample size." ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.18/bioc/src/contrib/LPEadj_1.62.0.tar.gz', 'https://bioconductor.org/packages/3.18/bioc/src/contrib/Archive/LPEadj/LPEadj_1.62.0.tar.gz', 'https://bioarchive.galaxyproject.org/LPEadj_1.62.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-lpeadj/bioconductor-lpeadj_1.62.0_src_all.tar.gz']" ;
    schema1:identifier biotools:lpeadj ;
    schema1:license "LGPL" ;
    schema1:name "bioconductor-lpeadj" ;
    schema1:softwareVersion "1.62.0" ;
    schema1:url "https://bioconductor.org/packages/3.18/bioc/html/LPEadj.html" ;
    spdx:builtFrom biotools:lpeadj .

