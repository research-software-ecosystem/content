@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:smithwaterman a schema1:SoftwareApplication ;
    schema1:description "Determine similar regions between two strings or genomic sequences" ;
    schema1:license "custom, see /usr/share/doc/smithwaterman/copyright" ;
    schema1:name "smithwaterman" ;
    schema1:url "https://github.com/ekg/smithwaterman" .

