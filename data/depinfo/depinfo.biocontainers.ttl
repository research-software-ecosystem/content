@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:depinfo a schema1:SoftwareApplication ;
    schema1:description "Retrieve and print python 3 package dependencies" ;
    schema1:license "Apache-2.0" ;
    schema1:name "depinfo" ;
    schema1:url "https://github.com/Midnighter/dependency-info" .

