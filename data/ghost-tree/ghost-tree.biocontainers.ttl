@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:ghost-tree a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s40168-016-0153-6",
        "doi:10.7287/peerj.preprints.1106v1" ;
    schema1:description "Ghost-tree is a bioinformatics tool that combines sequence data from two genetic marker databases into one phylogenetic tree that can be used for diversity analyses." ;
    schema1:keywords "Genetics",
        "Phylogenetics" ;
    schema1:license "BSD 3-Clause \"New\" or \"Revised\" License" ;
    schema1:name "ghost-tree" ;
    schema1:url "https://github.com/JTFouquier/ghost-tree" .

