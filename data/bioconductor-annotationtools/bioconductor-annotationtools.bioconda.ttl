@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-annotationtools a schema1:SoftwareApplication ;
    schema1:description "Annotate microarrays and perform cross-species gene expression analyses using flat file databases" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/annotationTools_1.80.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/annotationTools/annotationTools_1.80.0.tar.gz', 'https://bioarchive.galaxyproject.org/annotationTools_1.80.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-annotationtools/bioconductor-annotationtools_1.80.0_src_all.tar.gz']" ;
    schema1:identifier biotools:annotationtools ;
    schema1:license "GPL" ;
    schema1:name "bioconductor-annotationtools" ;
    schema1:softwareVersion "1.80.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/annotationTools.html" ;
    spdx:builtFrom biotools:annotationtools .

