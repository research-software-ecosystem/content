@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-annotationtools a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/1471-2105-9-26" ;
    schema1:description "Annotate microarrays and perform cross-species gene expression analyses using flat file databases" ;
    schema1:identifier biotools:annotationtools ;
    schema1:keywords "Data integration and warehousing",
        "Database Management Systems",
        "Databases, Genetic",
        "Documentation",
        "Gene Expression",
        "Gene Expression Profiling",
        "Gene expression",
        "Oligonucleotide Array Sequence Analysis",
        "Ortholog",
        "Programming Languages",
        "Sequence analysis",
        "Species Specificity" ;
    schema1:license "GPL" ;
    schema1:name "bioconductor-annotationtools" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/annotationTools.html" .

