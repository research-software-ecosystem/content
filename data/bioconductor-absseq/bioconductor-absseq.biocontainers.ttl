@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-absseq a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s12864-016-2848-2" ;
    schema1:description "ABSSeq: a new RNA-Seq analysis method based on modelling absolute expression differences" ;
    schema1:identifier biotools:absseq ;
    schema1:keywords "Computational Biology",
        "Computer Simulation",
        "Gene Expression Profiling",
        "Gene Expression Regulation",
        "Gene expression",
        "RNA-Seq",
        "RNA-seq",
        "ROC Curve",
        "Sequence Analysis, RNA",
        "Statistics and probability",
        "Transcriptome" ;
    schema1:license "GPL-3.0" ;
    schema1:name "bioconductor-absseq" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/ABSSeq.html" .

