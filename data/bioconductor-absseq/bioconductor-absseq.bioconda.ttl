@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-absseq a schema1:SoftwareApplication ;
    schema1:description "ABSSeq: a new RNA-Seq analysis method based on modelling absolute expression differences" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/ABSSeq_1.60.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/ABSSeq/ABSSeq_1.60.0.tar.gz', 'https://bioarchive.galaxyproject.org/ABSSeq_1.60.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-absseq/bioconductor-absseq_1.60.0_src_all.tar.gz']" ;
    schema1:identifier biotools:absseq ;
    schema1:license "GPL (>= 3)" ;
    schema1:name "bioconductor-absseq" ;
    schema1:softwareVersion "1.60.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/ABSSeq.html" ;
    spdx:builtFrom biotools:absseq .

