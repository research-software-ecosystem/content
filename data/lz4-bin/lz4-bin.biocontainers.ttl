@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:lz4-bin a schema1:SoftwareApplication ;
    schema1:description "Extremely Fast Compression Application" ;
    schema1:license "BSD" ;
    schema1:name "lz4-bin" ;
    schema1:url "https://github.com/lz4/lz4" .

