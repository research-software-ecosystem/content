    schema1:description "An object-oriented perl toolkit for analyzing and manipulating phyloinformatic data." ;
    schema1:keywords "Computational Biology",
        "Computing Methodologies",
        "Evolution, Molecular",
        "Genetics",
        "Genome",
        "Phylogenetics",
        "Phylogeny" ;
    schema1:license "Not available" ;
    schema1:name "perl-bio-phylo" ;
    schema1:url "http://biophylo.blogspot.com/" .

