@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:gemini a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1371/journal.pcbi.1003153" ;
    schema1:description "A lightweight db framework for disease and population genetics" ;
    schema1:identifier biotools:GEMINI ;
    schema1:keywords "Data Mining",
        "Databases, Genetic",
        "Genetic Variation",
        "Genetic variation",
        "Genetics",
        "Genome, Human",
        "Genomics",
        "Genotype",
        "Humans",
        "Sequence analysis" ;
    schema1:license "MIT" ;
    schema1:name "gemini" ;
    schema1:url "https://github.com/arq5x/gemini" .

