@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:gemini a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1371/journal.pcbi.1003153" ;
    schema1:description "a lightweight db framework for disease and population genetics." ;
    schema1:downloadUrl "https://github.com/arq5x/gemini/archive/v0.30.2.tar.gz" ;
    schema1:identifier biotools:GEMINI ;
    schema1:license "MIT License" ;
    schema1:name "gemini" ;
    schema1:softwareVersion "0.30.2" ;
    schema1:url "https://github.com/arq5x/gemini" ;
    spdx:builtFrom biotools:GEMINI .

