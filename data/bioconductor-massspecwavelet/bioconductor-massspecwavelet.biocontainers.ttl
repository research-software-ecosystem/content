@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-massspecwavelet a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btl355" ;
    schema1:description "Mass spectrum processing by wavelet-based algorithms" ;
    schema1:identifier biotools:massspecwavelet ;
    schema1:keywords "Artificial Intelligence",
        "Mass spectrometry",
        "Pattern Recognition, Automated",
        "Peptide Mapping",
        "Proteome",
        "Proteomics",
        "Proteomics experiment",
        "Quality Control",
        "Reproducibility of Results",
        "Sensitivity and Specificity",
        "Signal Processing, Computer-Assisted",
        "Small molecules",
        "Spectrometry, Mass, Matrix-Assisted Laser Desorption-Ionization" ;
    schema1:license "LGPL (>= 2)" ;
    schema1:name "bioconductor-massspecwavelet" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/MassSpecWavelet.html" .

