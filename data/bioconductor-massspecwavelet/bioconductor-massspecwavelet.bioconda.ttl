@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-massspecwavelet a schema1:SoftwareApplication ;
    schema1:description "Peak Detection for Mass Spectrometry data using wavelet-based algorithms" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/MassSpecWavelet_1.72.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/MassSpecWavelet/MassSpecWavelet_1.72.0.tar.gz', 'https://bioarchive.galaxyproject.org/MassSpecWavelet_1.72.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-massspecwavelet/bioconductor-massspecwavelet_1.72.0_src_all.tar.gz']" ;
    schema1:identifier biotools:massspecwavelet ;
    schema1:license "LGPL (>= 2)" ;
    schema1:name "bioconductor-massspecwavelet" ;
    schema1:softwareVersion "1.72.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/MassSpecWavelet.html" ;
    spdx:builtFrom biotools:massspecwavelet .

