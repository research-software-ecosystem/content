@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-seqplots a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18129/b9.bioc.seqplots" ;
    schema1:description "An interactive tool for visualizing NGS signals and sequence motif densities along genomic features using average plots and heatmaps" ;
    schema1:keywords "Clustering",
        "RNA-Seq" ;
    schema1:license "GPL-3.0" ;
    schema1:name "bioconductor-seqplots" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/seqplots.html" .

