@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:shapeit5 a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1101/2022.10.19.512867" ;
    schema1:description "Fast and accurate method for estimation of haplotypes (phasing)." ;
    schema1:identifier biotools:shapeit5 ;
    schema1:license "MIT" ;
    schema1:name "shapeit5" ;
    schema1:softwareHelp "https://odelaneau.github.io/shapeit5" ;
    schema1:softwareVersion "5.1.1" ;
    schema1:url "https://odelaneau.github.io/shapeit5" ;
    spdx:builtFrom biotools:shapeit5 .

