@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-netpathminer a schema1:SoftwareApplication ;
    schema1:description "NetPathMiner for Biological Network Construction, Path Mining and Visualization" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/NetPathMiner_1.46.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/NetPathMiner/NetPathMiner_1.46.0.tar.gz', 'https://bioarchive.galaxyproject.org/NetPathMiner_1.46.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-netpathminer/bioconductor-netpathminer_1.46.0_src_all.tar.gz']" ;
    schema1:identifier biotools:netpathminer ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-netpathminer" ;
    schema1:softwareVersion "1.46.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/NetPathMiner.html" ;
    spdx:builtFrom biotools:netpathminer .

