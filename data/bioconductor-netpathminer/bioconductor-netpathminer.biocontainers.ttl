@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-netpathminer a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btu501" ;
    schema1:description "NetPathMiner for Biological Network Construction, Path Mining and Visualization" ;
    schema1:identifier biotools:netpathminer ;
    schema1:keywords "Carbohydrate Metabolism",
        "Cluster Analysis",
        "Clustering",
        "Computer Graphics",
        "Data Mining",
        "Endocrinology and metabolism",
        "Gene expression",
        "Genomics",
        "Machine learning",
        "Metabolic Networks and Pathways",
        "Molecular interactions, pathways and networks",
        "Signal Transduction",
        "Transcriptome" ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-netpathminer" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/NetPathMiner.html" .

