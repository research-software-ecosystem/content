@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:ptrimmer a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/S12859-019-2854-X" ;
    schema1:description "Used to trim off the primer sequence from mutiplex amplicon sequencing" ;
    schema1:keywords "High-Throughput Nucleotide Sequencing",
        "Humans",
        "Sequence Analysis, DNA" ;
    schema1:license "GNU General Public License v3 (GPL-3.0)" ;
    schema1:name "ptrimmer" ;
    schema1:url "https://github.com/DMU-lilab/pTrimmer" .

