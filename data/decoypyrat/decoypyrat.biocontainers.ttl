@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:decoypyrat a schema1:SoftwareApplication ;
    schema1:citation "doi:10.4172/jpb.1000404" ;
    schema1:description "Fast Hybrid Decoy Sequence Database Creation for Proteomic Mass Spectrometery Analyses" ;
    schema1:keywords "Mass spectra",
