@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:regtools a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1101/436634" ;
    schema1:description "Tools that integrate DNA-seq and RNA-seq data to help interpret mutations in a regulatory and splicing context." ;
    schema1:keywords "Gene Expression",
        "RNA-Seq",
        "Transcriptome" ;
    schema1:license "MIT" ;
    schema1:name "regtools" ;
    schema1:url "https://github.com/griffithlab/regtools/" .

