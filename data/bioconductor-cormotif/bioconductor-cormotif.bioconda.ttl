@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-cormotif a schema1:SoftwareApplication ;
    schema1:description "Correlation Motif Fit" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/Cormotif_1.52.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/Cormotif/Cormotif_1.52.0.tar.gz', 'https://bioarchive.galaxyproject.org/Cormotif_1.52.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-cormotif/bioconductor-cormotif_1.52.0_src_all.tar.gz']" ;
    schema1:identifier biotools:cormotif ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-cormotif" ;
    schema1:softwareVersion "1.52.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/Cormotif.html" ;
    spdx:builtFrom biotools:cormotif .

