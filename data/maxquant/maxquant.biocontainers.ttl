@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:maxquant a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1002/pmic.201400449",
        "doi:10.1007/978-1-4939-1142-4_24",
        "doi:10.1038/nbt.1511",
        "doi:10.1038/s41592-018-0018-y" ;
    schema1:description "Maxquant is a quantitative proteomics software package designed for analyzing large mass-spectrometric data sets. license restricted." ;
    schema1:identifier biotools:MaxQuant ;
    schema1:keywords "Computational Biology",
        "Databases, Protein",
        "Mass spectrometry",
        "Proteomics",
        "Proteomics experiment",
        "Statistics and probability" ;
    schema1:license "Custom License" ;
    schema1:name "maxquant" ;
    schema1:url "http://www.coxdocs.org/doku.php?id=maxquant:start" .

