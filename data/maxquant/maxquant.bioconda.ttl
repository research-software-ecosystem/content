@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:maxquant a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/s41592-018-0018-y" ;
    schema1:description "MaxQuant is a quantitative proteomics software package designed for analyzing large mass-spectrometric data sets. License restricted." ;
    schema1:downloadUrl "http://computproteomics.bmb.sdu.dk/share/MaxQuant_2.0.3.0.zip" ;
    schema1:identifier biotools:MaxQuant ;
    schema1:license "http://www.coxdocs.org/lib/exe/fetch.php?media=license_agreement.pdf" ;
    schema1:name "maxquant" ;
    schema1:softwareVersion "2.0.3.0" ;
    schema1:url "http://www.coxdocs.org/doku.php?id=maxquant:start" ;
    spdx:builtFrom biotools:MaxQuant .

