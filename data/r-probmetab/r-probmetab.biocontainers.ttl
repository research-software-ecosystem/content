@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-probmetab a schema1:SoftwareApplication ;
    schema1:description "Provides probability ranking to candidate compounds assigned to masses, with the prior assumption of connected sample and additional previous and spectral information modeled by the user." ;
    schema1:keywords "Metabolomics" ;
    schema1:license "GPL-3.0" ;
    schema1:name "r-probmetab" ;
    schema1:url "https://github.com/rsilvabioinfo/ProbMetab" .

