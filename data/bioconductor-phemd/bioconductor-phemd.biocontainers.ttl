@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-phemd a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18129/b9.bioc.phemd" ;
    schema1:description "Phenotypic EMD for comparison of single-cell samples" ;
    schema1:keywords "Clustering",
        "Genomics",
        "Proteomics",
        "Transcriptomics" ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-phemd" ;
    schema1:url "https://bioconductor.org/packages/3.9/bioc/html/phemd.html" .

