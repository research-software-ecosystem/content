@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-sleuth a schema1:SoftwareApplication ;
    schema1:description "Sleuth is an R library for analysis of RNA-Seq experiments for which transcript abundances have been quantified with kallisto." ;
    schema1:license "GPL-3.0" ;
    schema1:name "r-sleuth" ;
    schema1:url "http://pachterlab.github.io/sleuth" .

