@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:pyfastx a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bib/bbaa368" ;
    schema1:description "A robust python module for fast random access to sequences from plain and gzipped FASTA/Q file" ;
    schema1:license "MIT" ;
    schema1:name "pyfastx" ;
    schema1:url "https://github.com/lmdu/pyfastx" .

