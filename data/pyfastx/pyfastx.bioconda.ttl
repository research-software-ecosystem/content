@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:pyfastx a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bib/bbaa368" ;
    schema1:description "pyfastx is a python module for fast random access to sequences from plain and gzipped FASTA/Q file." ;
    schema1:downloadUrl "https://github.com/lmdu/pyfastx/archive/2.3.0.tar.gz" ;
    schema1:identifier biotools:pyfastx ;
    schema1:license "MIT" ;
    schema1:name "pyfastx" ;
    schema1:softwareHelp "https://pyfastx.readthedocs.io/en/latest" ;
    schema1:softwareVersion "2.3.0" ;
    schema1:url "https://github.com/lmdu/pyfastx" ;
    spdx:builtFrom biotools:pyfastx .

