@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:diamond_add_taxonomy a schema1:SoftwareApplication ;
    schema1:description "Utility to work with ncbi taxonomy database including tool to annotate diamond results with taxonomy lineage" ;
    schema1:license "MIT" ;
    schema1:name "diamond_add_taxonomy" ;
    schema1:url "https://github.com/pvanheus/diamond_add_taxonomy" .

