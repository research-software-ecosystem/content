@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:secapr a schema1:SoftwareApplication ;
    schema1:citation "doi:10.7287/PEERJ.PREPRINTS.26477V2",
        "doi:10.7287/PEERJ.PREPRINTS.26477V3" ;
    schema1:description "Process sequence-capture fastq files into alignments for phylogenetic analyses. integrates allele phasing, producing haplotype alignments." ;
    schema1:keywords "Genetics",
        "Phylogenetics" ;
    schema1:license "Not available" ;
    schema1:name "secapr" ;
    schema1:url "https://github.com/AntonelliLab/seqcap_processor" .

