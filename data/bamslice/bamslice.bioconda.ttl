@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bamslice a schema1:SoftwareApplication ;
    schema1:author "bwlang" ;
    schema1:description "Extract byte ranges from BAM files and convert to interleaved FASTQ format for parallel processing" ;
    schema1:downloadUrl "https://github.com/nebiolabs/bamslice/archive/v0.1.7.tar.gz" ;
    schema1:identifier biotools:bamslice ;
    schema1:license "AGPL-3.0-only" ;
    schema1:maintainer "bwlang" ;
    schema1:name "bamslice" ;
    schema1:softwareHelp "https://docs.rs/bamslice" ;
    schema1:softwareVersion "0.1.7" ;
    schema1:url "https://github.com/nebiolabs/bamslice" ;
    spdx:builtFrom biotools:bamslice .

