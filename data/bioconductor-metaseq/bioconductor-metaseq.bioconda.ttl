@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-metaseq a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Meta-analysis of RNA-Seq count data in multiple studies" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/metaSeq_1.50.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/metaSeq/metaSeq_1.50.0.tar.gz', 'https://bioarchive.galaxyproject.org/metaSeq_1.50.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-metaseq/bioconductor-metaseq_1.50.0_src_all.tar.gz']" ;
    schema1:identifier biotools:metaseq ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-metaseq" ;
    schema1:softwareVersion "1.50.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/metaSeq.html" ;
    spdx:builtFrom biotools:metaseq .

