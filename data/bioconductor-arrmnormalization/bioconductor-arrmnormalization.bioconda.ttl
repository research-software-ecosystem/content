@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-arrmnormalization a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s13059-014-0503-2" ;
    schema1:description "Adaptive Robust Regression normalization for Illumina methylation data" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/ARRmNormalization_1.46.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/ARRmNormalization/ARRmNormalization_1.46.0.tar.gz', 'https://bioarchive.galaxyproject.org/ARRmNormalization_1.46.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-arrmnormalization/bioconductor-arrmnormalization_1.46.0_src_all.tar.gz']" ;
    schema1:identifier biotools:arrmnormalization ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-arrmnormalization" ;
    schema1:softwareVersion "1.46.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/ARRmNormalization.html" ;
    spdx:builtFrom biotools:arrmnormalization .

