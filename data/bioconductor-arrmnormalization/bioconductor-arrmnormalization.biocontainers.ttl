@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-arrmnormalization a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s13059-014-0503-2" ;
    schema1:description "Perform the adaptive robust regression method (arrm) for the normalization of methylation data from the illumina infinium humanmethylation 450k assay." ;
    schema1:identifier biotools:arrmnormalization ;
    schema1:keywords "Computational Biology",
        "DNA Methylation",
        "DNA Probes",
        "Epigenesis, Genetic",
        "Epigenetics",
        "Humans",
        "Neoplasms",
        "Oligonucleotide Array Sequence Analysis",
        "Sequence sites, features and motifs",
        "Sequencing" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-arrmnormalization" ;
    schema1:url "http://bioconductor.org/packages/release/bioc/html/ARRmNormalization.html" .

