@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-chromplot a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btw137" ;
    schema1:description "Global visualization tool of genomic data" ;
    schema1:identifier biotools:chromplot ;
    schema1:keywords "Animals",
        "Chromosomes",
        "Computer Graphics",
        "Data visualisation",
        "Genetic Variation",
        "Genetics",
        "Genome",
        "Genomics",
        "Humans",
        "Mice" ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-chromplot" ;
    schema1:url "https://bioconductor.org/packages/release/bioc/html/chromPlot.html" .

