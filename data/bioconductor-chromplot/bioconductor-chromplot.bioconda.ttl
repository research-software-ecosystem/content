@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-chromplot a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btw137" ;
    schema1:description "Global visualization tool of genomic data" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/chromPlot_1.38.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/chromPlot/chromPlot_1.38.0.tar.gz', 'https://bioarchive.galaxyproject.org/chromPlot_1.38.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-chromplot/bioconductor-chromplot_1.38.0_src_all.tar.gz']" ;
    schema1:identifier biotools:chromplot ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-chromplot" ;
    schema1:softwareVersion "1.38.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/chromPlot.html" ;
    spdx:builtFrom biotools:chromplot .

