@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:plast a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/1471-2105-10-329" ;
    schema1:description "Parallel local alignment search tool for database comparison." ;
    schema1:identifier biotools:plast ;
    schema1:keywords "Computational Biology",
        "Databases, Factual",
        "Information Storage and Retrieval",
        "Microcomputers",
        "Sequence analysis" ;
    schema1:license "CECILL-2.0" ;
    schema1:name "plast" ;
    schema1:url "https://github.com/PLAST-software" .

