@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:refgenieserver a schema1:SoftwareApplication ;
    schema1:description "This server provides both a web interface and a restful api. users may explore and download archived indexes from the web interface or develop tools that programmatically query the api." ;
    schema1:license "BSD 2-Clause \"Simplified\" License" ;
    schema1:name "refgenieserver" ;
    schema1:url "https://github.com/databio/refgenie/" .

