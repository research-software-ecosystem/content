@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:strainseeker a schema1:SoftwareApplication ;
    schema1:citation "doi:10.7717/peerj.3353" ;
    schema1:description "A bacterial identification program for fast identification of bacterial strains from raw sequencing reads" ;
    schema1:license "BSD" ;
    schema1:name "strainseeker" ;
    schema1:url "http://bioinfo.ut.ee/strainseeker" .

