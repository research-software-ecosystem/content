@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-qlcmatrix a schema1:SoftwareApplication ;
    schema1:description "Extension of the functionality of the Matrix package for using sparse matrices. Some of the functions are very general, while other are highly specific for special data format as used for quantitative language comparison (QLC)." ;
    schema1:license "GPL-3." ;
    schema1:name "r-qlcmatrix" ;
    schema1:url "https://CRAN.R-project.org/package=qlcMatrix" .

