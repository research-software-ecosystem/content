@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-chippeakanno a schema1:SoftwareApplication ;
    schema1:description "Batch annotation of the peaks identified from either ChIP-seq, ChIP-chip experiments, or any experiments that result in large number of genomic interval data" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/ChIPpeakAnno_3.40.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/ChIPpeakAnno/ChIPpeakAnno_3.40.0.tar.gz', 'https://bioarchive.galaxyproject.org/ChIPpeakAnno_3.40.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-chippeakanno/bioconductor-chippeakanno_3.40.0_src_all.tar.gz']" ;
    schema1:identifier biotools:chippeakanno ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-chippeakanno" ;
    schema1:softwareVersion "3.40.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/ChIPpeakAnno.html" ;
    spdx:builtFrom biotools:chippeakanno .

