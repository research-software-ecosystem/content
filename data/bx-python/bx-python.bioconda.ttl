@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bx-python a schema1:SoftwareApplication ;
    schema1:author "nsoranzo" ;
    schema1:description "Tools for manipulating biological data, particularly multiple sequence alignments." ;
    schema1:downloadUrl "https://pypi.org/packages/source/b/bx-python/bx_python-0.14.0.tar.gz" ;
    schema1:identifier biotools:bx-python ;
    schema1:license "MIT" ;
    schema1:maintainer "nsoranzo" ;
    schema1:name "bx-python" ;
    schema1:softwareHelp "https://bx-python.readthedocs.io/en/latest" ;
    schema1:softwareVersion "0.14.0" ;
    schema1:url "https://github.com/bxlab/bx-python" ;
    spdx:builtFrom biotools:bx-python .

