@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bx-python a schema1:SoftwareApplication ;
    schema1:description "Toolkit to enable rapid implementation of genome scale analyses" ;
    schema1:identifier biotools:bx-python ;
    schema1:keywords "Sequence Alignment",
        "Sequence analysis" ;
    schema1:license "MIT" ;
    schema1:name "bx-python" ;
    schema1:url "https://github.com/bxlab/bx-python" .

