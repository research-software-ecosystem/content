@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-metaarray a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/1471-2105-8-364" ;
    schema1:description "Integration of Microarray Data for Meta-analysis" ;
    schema1:identifier biotools:metaarray ;
    schema1:keywords "Biomarkers, Tumor",
        "Carcinoma",
        "Data Interpretation, Statistical",
        "Data management",
        "Gene Expression",
        "Gene Expression Profiling",
        "Gene expression",
        "Humans",
        "Markov Chains",
        "Microarray experiment",
        "Neoplasm Proteins",
        "Oligonucleotide Array Sequence Analysis" ;
    schema1:license "LGPL-2" ;
    schema1:name "bioconductor-metaarray" ;
    schema1:url "http://bioconductor.org/packages/3.5/bioc/html/metaArray.html" .

