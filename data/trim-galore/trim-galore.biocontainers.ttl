@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:trim-galore a schema1:SoftwareApplication ;
    schema1:description "Trim galore is a wrapper script to automate quality and adapter trimming as well as quality control" ;
    schema1:license "GPL-3.0" ;
    schema1:name "trim-galore" ;
    schema1:url "https://github.com/FelixKrueger/TrimGalore" .

