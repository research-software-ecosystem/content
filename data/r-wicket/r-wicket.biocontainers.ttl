@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-wicket a schema1:SoftwareApplication ;
    schema1:description "Utilities to generate bounding boxes from 'WKT' (Well-Known Text) objects and R data types, validate 'WKT' objects and convert object types from the 'sp' package into 'WKT' representations." ;
    schema1:license "MIT" ;
    schema1:name "r-wicket" ;
    schema1:url "https://github.com/ropensci/wicket" .

