@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-ebcoexpress a schema1:SoftwareApplication ;
    schema1:description "EBcoexpress for Differential Co-Expression Analysis" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/EBcoexpress_1.50.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/EBcoexpress/EBcoexpress_1.50.0.tar.gz', 'https://bioarchive.galaxyproject.org/EBcoexpress_1.50.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-ebcoexpress/bioconductor-ebcoexpress_1.50.0_src_all.tar.gz']" ;
    schema1:identifier biotools:ebcoexpress ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-ebcoexpress" ;
    schema1:softwareVersion "1.50.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/EBcoexpress.html" ;
    spdx:builtFrom biotools:ebcoexpress .

