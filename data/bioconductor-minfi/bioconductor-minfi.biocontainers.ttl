@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-minfi a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btw691" ;
    schema1:description "Tools to analyze & visualize illumina infinium methylation arrays." ;
    schema1:identifier biotools:minfi ;
    schema1:keywords "DNA",
        "DNA Methylation",
        "Epigenetics",
        "Epigenomics",
        "Genetics",
        "Humans",
        "Microarray experiment",
        "Oligonucleotide Array Sequence Analysis",
        "Sequence Analysis, DNA" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-minfi" ;
    schema1:url "http://bioconductor.org/packages/release/bioc/html/minfi.html" .

