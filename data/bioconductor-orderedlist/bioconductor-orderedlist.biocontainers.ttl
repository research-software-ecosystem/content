@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-orderedlist a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btl385" ;
    schema1:description "Similarities of Ordered Gene Lists" ;
    schema1:identifier biotools:orderedlist ;
    schema1:keywords "Artificial Intelligence",
        "Computer Simulation",
        "Gene Expression",
        "Gene Expression Profiling",
        "Gene expression",
        "Genetics",
        "Microarray experiment",
        "Models, Biological",
        "Multigene Family",
        "Oligonucleotide Array Sequence Analysis",
        "Pattern Recognition, Automated" ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-orderedlist" ;
    schema1:url "http://bioconductor.org/packages/3.6/bioc/html/OrderedList.html" .

