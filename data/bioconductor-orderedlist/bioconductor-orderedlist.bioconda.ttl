@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-orderedlist a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btl385" ;
    schema1:description "Similarities of Ordered Gene Lists" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/OrderedList_1.82.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/OrderedList/OrderedList_1.82.0.tar.gz', 'https://bioarchive.galaxyproject.org/OrderedList_1.82.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-orderedlist/bioconductor-orderedlist_1.82.0_src_all.tar.gz']" ;
    schema1:identifier biotools:orderedlist ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-orderedlist" ;
    schema1:softwareVersion "1.82.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/OrderedList.html" ;
    spdx:builtFrom biotools:orderedlist .

