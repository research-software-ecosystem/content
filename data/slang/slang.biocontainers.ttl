@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:slang a schema1:SoftwareApplication ;
    schema1:description "S-Lang allows developers to create robust multi-platform software" ;
    schema1:license "GPL" ;
    schema1:name "slang" ;
    schema1:url "http://www.jedsoft.org/slang/" .

