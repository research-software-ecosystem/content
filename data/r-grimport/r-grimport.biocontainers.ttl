@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-grimport a schema1:SoftwareApplication ;
    schema1:description "Functions for converting, importing, and drawing PostScript pictures in R plots." ;
    schema1:license "GPL-2." ;
    schema1:name "r-grimport" ;
    schema1:url "https://CRAN.R-project.org/package=grImport" .

