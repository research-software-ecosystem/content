@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:coils a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1126/science.252.5009.1162" ;
    schema1:description "A generalized profile syntax for biomolecular sequence motifs and its function in automatic sequence interpretation." ;
    schema1:identifier biotools:coils ;
    schema1:keywords "Amino Acid Sequence",
        "Amino Acids",
        "Animals",
        "Clustering",
        "Databases, Factual",
        "Humans",
        "Probability",
        "Protein Conformation",
        "Protein Sequences",
        "Protein structure analysis",
        "Proteins",
        "Statistics and probability" ;
    schema1:license "GPL" ;
    schema1:name "coils" ;
    schema1:url "https://github.com/Rostlab" .

