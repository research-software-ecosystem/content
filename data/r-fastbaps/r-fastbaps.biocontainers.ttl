@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-fastbaps a schema1:SoftwareApplication ;
    schema1:citation "doi:10.5281/zenodo.1472299" ;
    schema1:description "A fast approximation to a Dirichlet Process Mixture model (DPM) for clustering genetic data" ;
    schema1:keywords "Clustering",
        "Genetics",
        "Phylogenetics",
        "Sequence Alignment" ;
    schema1:license "MIT" ;
    schema1:name "r-fastbaps" ;
    schema1:url "https://github.com/gtonkinhill/fastbaps" .

