@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-chromheatmap a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "This package can be used to plot genome-wide data (e.g. expression, cgh, snp) along each strand of a given chromosome as a heat map, that can be used to interactively identify probes and genes of interest." ;
    schema1:identifier biotools:chromheatmap ;
    schema1:keywords "Computational Biology",
        "Data visualisation",
        "Gene Expression Profiling",
        "Genomics",
        "High-Throughput Screening Assays",
        "Programming Languages",
        "User-Computer Interface" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-chromheatmap" ;
    schema1:url "http://bioconductor.org/packages/release/bioc/html/ChromHeatMap.html" .

