@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-chromheatmap a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Heat map plotting by genome coordinate" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/ChromHeatMap_1.64.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/ChromHeatMap/ChromHeatMap_1.64.0.tar.gz', 'https://bioarchive.galaxyproject.org/ChromHeatMap_1.64.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-chromheatmap/bioconductor-chromheatmap_1.64.0_src_all.tar.gz']" ;
    schema1:identifier biotools:chromheatmap ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-chromheatmap" ;
    schema1:softwareVersion "1.64.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/ChromHeatMap.html" ;
    spdx:builtFrom biotools:chromheatmap .

