@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:slamdunk a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s12859-019-2849-7" ;
    schema1:description "Slamdunk is a software tool for slamseq data analysis." ;
    schema1:keywords "High-Throughput Nucleotide Sequencing",
        "Nucleotides",
        "Polymorphism, Single Nucleotide",
        "RNA-Seq",
        "Sequence Analysis, RNA" ;
    schema1:license "AGPL-3.0" ;
    schema1:name "slamdunk" ;
    schema1:url "https://github.com/t-neumann/slamdunk" .

