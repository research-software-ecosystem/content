@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:irep a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nbt.3704" ;
    schema1:description "Calculate irep replication rates from metagenome sequencing" ;
    schema1:keywords "Bacteria",
        "Bacterial Load",
        "Cell Proliferation",
        "Chromosome Mapping",
        "Genome, Bacterial",
        "Genomics",
        "Metagenome",
        "Metagenomics",
        "Microbial Consortia",
        "Reproducibility of Results",
        "Sensitivity and Specificity" ;
    schema1:license "MIT" ;
    schema1:name "irep" ;
    schema1:url "https://github.com/christophertbrown/iRep" .

