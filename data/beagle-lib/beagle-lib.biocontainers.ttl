@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:beagle-lib a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btp244",
        "doi:10.1093/sysbio/syr100" ;
    schema1:description "General purpose library for evaluating the likelihood of sequence evolution on trees" ;
    schema1:keywords "Genetics",
        "Phylogenetics" ;
    schema1:license "GPL-3.0+" ;
    schema1:name "beagle-lib" ;
    schema1:url "https://github.com/beagle-dev/beagle-lib" .

