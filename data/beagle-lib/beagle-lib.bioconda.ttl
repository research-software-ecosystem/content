@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:beagle-lib a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/sysbio/syr100" ;
    schema1:description "A general purpose library for evaluating the likelihood of sequence evolution on phylogenetic trees." ;
    schema1:downloadUrl "https://github.com/beagle-dev/beagle-lib/archive/v4.0.1.tar.gz" ;
    schema1:identifier biotools:beagle-lib ;
    schema1:license "GPL-3.0-or-later" ;
    schema1:name "beagle-lib" ;
    schema1:softwareHelp "https://github.com/beagle-dev/beagle-lib/blob/v4.0.1/README.md" ;
    schema1:softwareVersion "4.0.1" ;
    schema1:url "https://github.com/beagle-dev/beagle-lib" ;
    spdx:builtFrom biotools:beagle-lib .

