@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-bamsignals a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Extract read count signals from bam files" ;
    schema1:identifier biotools:bamsignals ;
    schema1:keywords "Computational Biology",
        "Data visualisation",
        "Gene Expression Profiling",
        "Genomics",
        "High-Throughput Screening Assays",
        "Programming Languages",
        "Sequence analysis",
        "User-Computer Interface" ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-bamsignals" ;
    schema1:url "http://bioconductor.org/packages/3.6/bioc/html/bamsignals.html" .

