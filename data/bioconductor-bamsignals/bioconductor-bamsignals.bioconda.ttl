@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-bamsignals a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Extract read count signals from bam files" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/bamsignals_1.42.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/bamsignals/bamsignals_1.42.0.tar.gz', 'https://bioarchive.galaxyproject.org/bamsignals_1.42.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-bamsignals/bioconductor-bamsignals_1.42.0_src_all.tar.gz']" ;
    schema1:identifier biotools:bamsignals ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-bamsignals" ;
    schema1:softwareVersion "1.42.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/bamsignals.html" ;
    spdx:builtFrom biotools:bamsignals .

