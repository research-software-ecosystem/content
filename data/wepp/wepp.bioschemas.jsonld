      "sc:citation": {
        "@id": "https://doi.org/10.1101/2025.06.09.25329287"
      },
      "sc:description": "WEPP is a pathogen-agnostic pipeline for wastewater-based epidemiology that enhances resolution by incorporating comprehensive phylogenetic placement of sequencing reads into mutation-annotated trees. It reports haplotype abundance, lineages, and unaccounted alleles, providing insights into emerging variants.",
