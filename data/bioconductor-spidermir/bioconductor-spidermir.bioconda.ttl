@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-spidermir a schema1:SoftwareApplication ;
    schema1:citation "doi:10.3390/ijms18020274" ;
    schema1:description "SpidermiR: An R/Bioconductor package for integrative network analysis with miRNA data" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.18/bioc/src/contrib/SpidermiR_1.32.0.tar.gz', 'https://bioconductor.org/packages/3.18/bioc/src/contrib/Archive/SpidermiR/SpidermiR_1.32.0.tar.gz', 'https://bioarchive.galaxyproject.org/SpidermiR_1.32.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-spidermir/bioconductor-spidermir_1.32.0_src_all.tar.gz']" ;
    schema1:identifier biotools:spidermir ;
    schema1:license "GPL (>= 3)" ;
    schema1:name "bioconductor-spidermir" ;
    schema1:softwareVersion "1.32.0" ;
    schema1:url "https://bioconductor.org/packages/3.18/bioc/html/SpidermiR.html" ;
    spdx:builtFrom biotools:spidermir .

