@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:vcflib a schema1:SoftwareApplication ;
    schema1:author "jpuritz",
        "mencian" ;
    schema1:citation "doi:10.1371/journal.pcbi.1009123" ;
    schema1:description "Command-line tools for manipulating VCF files." ;
    schema1:downloadUrl "https://github.com/vcflib/vcflib/releases/download/v1.0.15/vcflib-1.0.15-src.tar.gz",
        "https://ziglang.org/download/0.15.1/zig-aarch64-linux-0.15.1.tar.xz",
        "https://ziglang.org/download/0.15.1/zig-aarch64-macos-0.15.1.tar.xz",
        "https://ziglang.org/download/0.15.1/zig-x86_64-linux-0.15.1.tar.xz",
        "https://ziglang.org/download/0.15.1/zig-x86_64-macos-0.15.1.tar.xz" ;
    schema1:identifier biotools:vcflib ;
    schema1:license "MIT" ;
    schema1:maintainer "jpuritz",
        "mencian" ;
    schema1:name "vcflib" ;
    schema1:softwareHelp "https://github.com/vcflib/vcflib/blob/v1.0.15/README.md" ;
    schema1:softwareVersion "1.0.15" ;
    schema1:url "https://github.com/vcflib/vcflib" ;
    spdx:builtFrom biotools:vcflib .

