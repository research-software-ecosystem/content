@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-annotationhubdata a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Transform public data resources into Bioconductor Data Structures" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/AnnotationHubData_1.40.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/AnnotationHubData/AnnotationHubData_1.40.0.tar.gz', 'https://bioarchive.galaxyproject.org/AnnotationHubData_1.40.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-annotationhubdata/bioconductor-annotationhubdata_1.40.0_src_all.tar.gz']" ;
    schema1:identifier biotools:annotationhubdata ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-annotationhubdata" ;
    schema1:softwareVersion "1.40.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/AnnotationHubData.html" ;
    spdx:builtFrom biotools:annotationhubdata .

