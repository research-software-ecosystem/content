@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-annotationhubdata a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "These recipes convert a wide variety and a growing number of public bioinformatic data sets into easily-used standard bioconductor data structures." ;
    schema1:identifier biotools:annotationhubdata ;
    schema1:keywords "Computational Biology",
        "Data architecture, analysis and design",
        "Data management",
        "Gene Expression Profiling",
        "Genomics",
        "High-Throughput Screening Assays",
        "Programming Languages",
        "Proteomics",
        "User-Computer Interface" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-annotationhubdata" ;
    schema1:url "http://bioconductor.org/packages/release/bioc/html/AnnotationHubData.html" .

