@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-clipper a schema1:SoftwareApplication ;
    schema1:description "Gene Set Analysis Exploiting Pathway Topology" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/clipper_1.50.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/clipper/clipper_1.50.0.tar.gz', 'https://bioarchive.galaxyproject.org/clipper_1.50.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-clipper/bioconductor-clipper_1.50.0_src_all.tar.gz']" ;
    schema1:identifier biotools:clipper ;
    schema1:license "AGPL-3" ;
    schema1:name "bioconductor-clipper" ;
    schema1:softwareVersion "1.50.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/clipper.html" ;
    spdx:builtFrom biotools:clipper .

