@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bambamc a schema1:SoftwareApplication ;
    schema1:description "lightweight C implementation of name collating BAM file input and BAM file output" ;
    schema1:license "GPL-3.0" ;
    schema1:name "bambamc" ;
    schema1:url "https://github.com/gt1/bambamc" .

