@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:neurodocker a schema1:SoftwareApplication ;
    schema1:description "Neurodocker is a command-line program that generates custom Dockerfiles and Singularity recipes for neuroimaging and minifies existing containers." ;
    schema1:license "Apache-2.0" ;
    schema1:name "neurodocker" ;
    schema1:url "https://github.com/kaczmarj/neurodocker" .

