@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:seqmagick a schema1:SoftwareApplication ;
    schema1:description "Tools for converting and modifying sequence files from the command-line" ;
    schema1:license "GPL-3.0" ;
    schema1:name "seqmagick" ;
    schema1:url "http://github.com/fhcrc/seqmagick" .

