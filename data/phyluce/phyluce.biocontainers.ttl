@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:phyluce a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btv646" ;
    schema1:description "Software for uce (and general) phylogenomics." ;
    schema1:identifier biotools:phyluce ;
    schema1:keywords "DNA",
        "Genetic Loci",
        "Genomics",
        "Phylogenomics",
        "Programming Languages" ;
    schema1:license "Custom License" ;
    schema1:name "phyluce" ;
    schema1:url "https://github.com/faircloth-lab/phyluce" .

