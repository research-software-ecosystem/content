@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:libgenome a schema1:SoftwareApplication ;
    schema1:description "A C++ development library designed to make common operations on DNA and protein sequences easy. libGenome provides functionality to read, write, and manipulate sequence and annotation data in several file formats." ;
    schema1:keywords "Genomics" ;
    schema1:license "GPL-2.0" ;
    schema1:name "libgenome" ;
    schema1:url "http://darlinglab.org/mauve/" .

