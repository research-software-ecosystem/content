@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bedtk a schema1:SoftwareApplication ;
    schema1:author "mjsteinbaugh" ;
    schema1:description "Bedtk is a set of simple tools to process BED files." ;
    schema1:downloadUrl "https://github.com/lh3/bedtk/archive/refs/tags/v1.2.tar.gz" ;
    schema1:identifier biotools:bedtk ;
    schema1:license "MIT" ;
    schema1:maintainer "mjsteinbaugh" ;
    schema1:name "bedtk" ;
    schema1:softwareHelp "https://github.com/lh3/bedtk" ;
    schema1:softwareVersion "1.2" ;
    schema1:url "https://github.com/lh3/bedtk" ;
    spdx:builtFrom biotools:bedtk .

