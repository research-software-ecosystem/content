@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:ecmwfapi a schema1:SoftwareApplication ;
    schema1:description "Ecmwf api is a set of services developed by ecmwf http://www.ecmwf.int to allow users from the outside to access some internal features and data of the centre." ;
    schema1:license "Apache-2.0" ;
    schema1:name "ecmwfapi" ;
    schema1:url "https://software.ecmwf.int/wiki/display/WEBAPI/Access+ECMWF+Public+Datasets#AccessECMWFPublicDatasets-clientlibraries" .

