@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bayestyper a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/s41588-018-0145-5" ;
    schema1:description "A method for variant graph genotyping based on exact alignment of k-mers" ;
    schema1:identifier biotools:bayestyper ;
    schema1:keywords "DNA polymorphism",
        "Genetic Variation",
        "Genetics",
        "Genome, Human",
        "Genotype",
        "High-Throughput Nucleotide Sequencing",
        "Humans",
        "Sequence Analysis, DNA",
        "Sequence assembly",
        "Whole genome sequencing" ;
    schema1:license "MIT" ;
    schema1:name "bayestyper" ;
    schema1:url "https://github.com/bioinformatics-centre/BayesTyper" .

