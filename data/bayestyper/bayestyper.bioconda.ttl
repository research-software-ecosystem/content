@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bayestyper a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/s41588-018-0145-5" ;
    schema1:description "A method for variant graph genotyping based on exact alignment of k-mers." ;
    schema1:downloadUrl "https://github.com/bioinformatics-centre/BayesTyper/archive/v1.5.tar.gz" ;
    schema1:identifier biotools:bayestyper ;
    schema1:license "MIT" ;
    schema1:name "bayestyper" ;
    schema1:softwareHelp "https://github.com/bioinformatics-centre/BayesTyper/blob/v1.5/README.md" ;
    schema1:softwareVersion "1.5" ;
    schema1:url "https://github.com/bioinformatics-centre/BayesTyper" ;
    spdx:builtFrom biotools:bayestyper .

