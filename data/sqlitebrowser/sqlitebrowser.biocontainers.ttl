@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:sqlitebrowser a schema1:SoftwareApplication ;
    schema1:description "Sqlitebrowser\\n\\n> Db browser for sqlite is a high quality, visual, open source tool to create, design, and edit database files compatible with sqlite." ;
    schema1:license "GPL-3.0" ;
    schema1:name "sqlitebrowser" ;
    schema1:url "https://github.com/sqlitebrowser/sqlitebrowser" .

