@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:funcannot a schema1:SoftwareApplication ;
    schema1:description "Annotates cDNA, protein, mutation type, and other funcational changes to variants in a VCF file with pre-existing gene annotations" ;
    schema1:license "GPL-3.0" ;
    schema1:name "funcannot" ;
    schema1:url "https://github.com/BioTools-Tek/funcannot" .

