@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:pathoscope a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/2049-2618-2-33" ;
    schema1:description "Species identification and strain attribution with unassembled sequencing data" ;
    schema1:identifier biotools:pathoscope ;
    schema1:keywords "DNA",
        "Genomics",
        "Sequence assembly",
        "Sequencing",
        "Statistics and probability" ;
    schema1:license "GPL-3.0" ;
    schema1:name "pathoscope" ;
    schema1:url "https://github.com/PathoScope/PathoScope" .

