@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:libarbdb a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/gkh293" ;
    schema1:description "ARB 6 Sequence Analysis Suite" ;
    schema1:identifier biotools:arb ;
    schema1:keywords "Data Display",
        "Databases, Genetic",
        "Internet",
        "Phylogeny",
        "Sequence Alignment",
        "Sequence Analysis, DNA",
        "Sequence Analysis, Protein",
        "Sequence Analysis, RNA",
        "Time Factors" ;
    schema1:license "ARB" ;
    schema1:name "libarbdb" ;
    schema1:url "http://www.arb-home.de" .

