      "@type": "sc:SoftwareApplication",
      "dcterms:conformsTo": "https://bioschemas.org/profiles/ComputationalTool/0.6-DRAFT",
      "sc:additionalType": [
        "Command-line tool",
        "Library"
      ],
      "sc:author": "Andy An",
      "sc:citation": {
        "@id": "https://doi.org/10.18129/B9.bioc.pathlinkR"
      },
      "sc:description": "pathlinkR is an R package designed to facilitate analysis of RNA-Seq results. Specifically, our aim with pathlinkR was to provide a number of tools which take a list of DE genes and perform different analyses on them, aiding with the interpretation of results. Functions are included to perform pathway enrichment, with muliplte databases supported, and tools for visualizing these results. Genes can also be used to create and plot protein-protein interaction networks, all from inside of R.",
      "sc:license": "GPL-3.0-only",
      "sc:name": "pathlinkR",
      "sc:operatingSystem": [
        "Windows",
        "Mac",
        "Linux"
      ],
      "sc:softwareHelp": {
        "@id": "https://bioconductor.org/packages/pathlinkR"
      },
      "sc:softwareVersion": "1.6.0",
      "sc:url": "https://bioconductor.org/packages/pathlinkR"
    }
  ]
