@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-clomial a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1371/journal.pcbi.1003703" ;
    schema1:description "Infers clonal composition of a tumor" ;
    schema1:identifier biotools:clomial ;
    schema1:keywords "Biomarkers",
        "Breast Neoplasms",
        "Clustering",
        "Computational Biology",
        "Computer Simulation",
        "Female",
        "Genetics",
        "Genotype",
        "Humans",
        "Oncology",
        "Phylogeny",
        "Sequencing",
        "Statistics and probability" ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-clomial" ;
    schema1:url "https://www.bioconductor.org/packages/release/bioc/html/Clomial.html" .

