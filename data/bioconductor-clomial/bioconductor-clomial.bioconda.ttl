@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-clomial a schema1:SoftwareApplication ;
    schema1:description "Infers clonal composition of a tumor" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/Clomial_1.42.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/Clomial/Clomial_1.42.0.tar.gz', 'https://bioarchive.galaxyproject.org/Clomial_1.42.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-clomial/bioconductor-clomial_1.42.0_src_all.tar.gz']" ;
    schema1:identifier biotools:clomial ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-clomial" ;
    schema1:softwareVersion "1.42.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/Clomial.html" ;
    spdx:builtFrom biotools:clomial .

