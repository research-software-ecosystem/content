@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:treeview a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/12.4.357" ;
    schema1:description "Simple program for displaying phylogenies on apple macintosh and windows pcs. it provides a simple way to view the contents of a nexus, phylip, hennig86, clustal, or other format tree file. while paup and macclade have excellent tree printing facilities, there may be times you just want to view the trees without having to load the data set they were generated from." ;
    schema1:identifier biotools:treeview ;
    schema1:keywords "Computer Graphics",
        "Data visualisation",
        "Evolutionary biology",
        "Microcomputers",
        "Phylogenetics",
        "Phylogeny" ;
    schema1:license "GPL-2" ;
    schema1:name "treeview" ;
    schema1:url "http://taxonomy.zoology.gla.ac.uk/rod/treeview.html" .

