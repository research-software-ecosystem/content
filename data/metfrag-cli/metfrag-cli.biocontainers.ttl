@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:metfrag-cli a schema1:SoftwareApplication ;
    schema1:description "Command Line Interface for MetFrag." ;
