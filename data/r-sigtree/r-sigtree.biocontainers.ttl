@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-sigtree a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1016/j.csbj.2017.06.002" ;
    schema1:description "Provides tools to identify and visualize branches in a phylogenetic tree that are significantly responsive to some intervention, taking as primary inputs a phylogenetic tree (of class phylo) and a data frame (or matrix) of corresponding tip (OTU) labels and p-values." ;
    schema1:keywords "Genetics",
        "Phylogenetics" ;
    schema1:license "GPL-3.0" ;
    schema1:name "r-sigtree" ;
    schema1:url "https://CRAN.R-project.org/package=SigTree" .

