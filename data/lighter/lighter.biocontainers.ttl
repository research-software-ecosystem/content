@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:lighter a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s13059-014-0509-9" ;
    schema1:description "Lighter is a kmer-based error correction method for whole genome sequencing data" ;
    schema1:identifier biotools:Lighter ;
    schema1:keywords "Computational Biology",
        "DNA",
        "Genomics",
        "High-Throughput Nucleotide Sequencing",
        "Humans",
        "Quality Control",
        "Sequence Analysis, DNA",
        "Sequencing",
        "Whole genome sequencing" ;
    schema1:license "GPL-3.0" ;
    schema1:name "lighter" ;
    schema1:url "https://github.com/mourisl/Lighter" .

