@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:lighter a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s13059-014-0509-9" ;
    schema1:description "Lighter is a kmer-based error correction method for whole genome sequencing data." ;
    schema1:downloadUrl "https://github.com/mourisl/Lighter/archive/v1.1.3.tar.gz" ;
    schema1:identifier biotools:Lighter ;
    schema1:license "GPL-3.0-or-later" ;
    schema1:name "lighter" ;
    schema1:softwareHelp "https://github.com/mourisl/Lighter/blob/v1.1.3/README.md" ;
    schema1:softwareVersion "1.1.3" ;
    schema1:url "https://github.com/mourisl/Lighter" ;
    spdx:builtFrom biotools:Lighter .

