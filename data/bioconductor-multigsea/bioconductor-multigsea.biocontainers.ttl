@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-multigsea a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s12859-020-03910-x" ;
    schema1:description "Extracted features from pathways derived from 8 different databases (KEGG, Reactome, Biocarta, etc.) can be used on transcriptomic, proteomic, and/or metabolomic level to calculate a combined GSEA-based enrichment score." ;
    schema1:keywords "Animals",
        "Computational Biology",
        "Databases, Factual",
        "Humans",
        "Metabolome",
        "Proteome",
        "Transcriptome" ;
    schema1:license "GPL-3.0" ;
    schema1:name "bioconductor-multigsea" ;
    schema1:url "https://bioconductor.org/packages/3.12/bioc/html/multiGSEA.html" .

