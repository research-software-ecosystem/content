@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-bumphunter a schema1:SoftwareApplication ;
    schema1:description "Bump Hunter" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/bumphunter_1.48.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/bumphunter/bumphunter_1.48.0.tar.gz', 'https://bioarchive.galaxyproject.org/bumphunter_1.48.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-bumphunter/bioconductor-bumphunter_1.48.0_src_all.tar.gz']" ;
    schema1:identifier biotools:bumphunter ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-bumphunter" ;
    schema1:softwareVersion "1.48.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/bumphunter.html" ;
    spdx:builtFrom biotools:bumphunter .

