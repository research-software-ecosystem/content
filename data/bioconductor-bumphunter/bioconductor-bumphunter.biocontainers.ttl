@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-bumphunter a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btu049" ;
    schema1:description "Tools for finding bumps in genomic data." ;
    schema1:identifier biotools:bumphunter ;
    schema1:keywords "Aged",
        "Colonic Neoplasms",
        "DNA Methylation",
        "Genetics",
        "Genome",
        "Genomics",
        "High-Throughput Nucleotide Sequencing",
        "Humans",
        "Oligonucleotide Array Sequence Analysis",
        "Polymorphism, Single Nucleotide",
        "Sequence analysis" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-bumphunter" ;
    schema1:url "http://bioconductor.org/packages/release/bioc/html/bumphunter.html" .

