@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:seqbuster a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/gkp1127" ;
    schema1:description "Seqbuster, a web-based bioinformatic tool offering a custom analysis of deep sequencing data at different levels, with special emphasis on the analysis of mirna variants or isomirs and the discovering of new small rnas." ;
    schema1:identifier biotools:seqbuster ;
    schema1:keywords "Cell Differentiation",
        "Computational Biology",
        "Embryonic Stem Cells",
        "Functional, regulatory and non-coding RNA",
        "Genetic Variation",
        "Humans",
        "MicroRNAs",
        "Sequence Analysis, RNA",
        "Transcriptomics" ;
    schema1:license "MIT" ;
    schema1:name "seqbuster" ;
    schema1:url "https://github.com/lpantano/seqbuster" .

