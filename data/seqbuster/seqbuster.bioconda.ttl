@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:seqbuster a schema1:SoftwareApplication ;
    schema1:description "miRNA and isomiR annotation" ;
    schema1:downloadUrl "https://github.com/lpantano/seqbuster/archive/miraligner-3.5.tar.gz" ;
    schema1:identifier biotools:seqbuster ;
    schema1:license "MIT" ;
    schema1:name "seqbuster" ;
    schema1:softwareVersion "3.5" ;
    schema1:url "https://github.com/lpantano/seqbuster" ;
    spdx:builtFrom biotools:seqbuster .

