@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:deblur a schema1:SoftwareApplication ;
    schema1:description "Deblur is a greedy deconvolution algorithm based on known read error profiles." ;
    schema1:license "BSD" ;
    schema1:name "deblur" ;
    schema1:url "https://github.com/biocore/deblur" .

