@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-cogps a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "cancer outlier Gene Profile Sets" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/coGPS_1.54.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/coGPS/coGPS_1.54.0.tar.gz', 'https://bioarchive.galaxyproject.org/coGPS_1.54.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-cogps/bioconductor-cogps_1.54.0_src_all.tar.gz']" ;
    schema1:identifier biotools:cogps ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-cogps" ;
    schema1:softwareVersion "1.54.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/coGPS.html" ;
    spdx:builtFrom biotools:cogps .

