@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-cancermutationanalysis a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1007/978-1-62703-721-1_7" ;
    schema1:description "Cancer mutation analysis" ;
    schema1:identifier biotools:cancermutationanalysis ;
    schema1:keywords "Computational Biology",
        "Data Interpretation, Statistical",
        "Genes, Neoplasm",
        "Genetic Association Studies",
        "Genetic variation",
        "Genetics",
        "Humans",
        "Markov Chains",
        "Models, Genetic",
        "Molecular Sequence Annotation",
        "Monte Carlo Method",
        "Neoplasms",
        "Oncology",
        "Point Mutation",
        "Whole genome sequencing" ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-cancermutationanalysis" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/CancerMutationAnalysis.html" .

