@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-xde a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1198/jasa.2009.ap07611" ;
    schema1:description "XDE: a Bayesian hierarchical model for cross-study analysis of differential gene expression" ;
    schema1:identifier biotools:xde ;
    schema1:keywords "Data quality management",
        "Gene Expression",
        "Gene expression",
        "Statistics and probability" ;
    schema1:license "LGPL-2" ;
    schema1:name "bioconductor-xde" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/XDE.html" .

