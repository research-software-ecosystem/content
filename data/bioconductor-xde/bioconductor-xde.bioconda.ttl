@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-xde a schema1:SoftwareApplication ;
    schema1:description "XDE: a Bayesian hierarchical model for cross-study analysis of differential gene expression" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/XDE_2.56.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/XDE/XDE_2.56.0.tar.gz', 'https://bioarchive.galaxyproject.org/XDE_2.56.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-xde/bioconductor-xde_2.56.0_src_all.tar.gz']" ;
    schema1:identifier biotools:xde ;
    schema1:license "LGPL-2" ;
    schema1:name "bioconductor-xde" ;
    schema1:softwareVersion "2.56.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/XDE.html" ;
    spdx:builtFrom biotools:xde .

