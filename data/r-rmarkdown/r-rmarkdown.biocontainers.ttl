@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-rmarkdown a schema1:SoftwareApplication ;
    schema1:description "Convert r markdown documents into a variety of formats" ;
    schema1:keywords "Clustering",
        "Genetics",
        "Genomics",
        "Metabolomics",
        "Metagenome",
        "Metagenomics",
        "Proteomics" ;
    schema1:license "GPL-3.0" ;
    schema1:name "r-rmarkdown" ;
    schema1:url "https://CRAN.R-project.org/package=rmarkdown" .

