@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-seqgsea a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btu090" ;
    schema1:description "Gene Set Enrichment Analysis (GSEA) of RNA-Seq Data: integrating differential expression and splicing" ;
    schema1:identifier biotools:seqgsea ;
    schema1:keywords "Gene Expression Profiling",
        "Gene expression",
        "Humans",
        "RNA Splicing",
        "RNA-Seq",
        "RNA-seq",
        "Sequence Analysis, RNA" ;
    schema1:license "GPL-3.0" ;
    schema1:name "bioconductor-seqgsea" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/SeqGSEA.html" .

