    {
      "@id": "https://bio.tools/bioconductor-deltacapturec",
      "@type": "sc:SoftwareApplication",
      "dcterms:conformsTo": "https://bioschemas.org/profiles/ComputationalTool/0.6-DRAFT",
      "sc:additionalType": [
        "Command-line tool",
        "Library"
      ],
      "sc:author": "Michael Shapiro",
      "sc:citation": {
        "@id": "https://doi.org/10.1101/2021.05.18.442939"
      },
      "sc:description": "This package discovers meso-scale chromatin remodelling from 3C data.  3C data is local in nature.  It givens interaction counts between restriction enzyme digestion fragments and a preferred 'viewpoint' region.  By binning this data and using permutation testing, this package can test whether there are statistically significant changes in the interaction counts between the data from two cell types or two treatments.",
      "sc:license": "MIT",
      "sc:name": "deltaCaptureC",
      "sc:operatingSystem": [
        "Mac",
        "Linux",
        "Windows"
      ],
      "sc:softwareHelp": {
        "@id": "https://bioconductor.org/packages/deltaCaptureC"
      },
      "sc:softwareVersion": "1.24.0",
      "sc:url": "https://bioconductor.org/packages/deltaCaptureC"
    }
  ]
