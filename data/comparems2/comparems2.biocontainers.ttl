@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:comparems2 a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1002/rcm.6162",
        "doi:10.1002/rcm.7494" ;
    schema1:description "A simple tool developed to compare, globally, all MS/MS spectra between two datasets (in Mascot Generic Format or MGF)." ;
    schema1:identifier biotools:comparems2 ;
    schema1:keywords "Animals",
        "Biomarkers",
        "Chromatography, Liquid",
        "Genetics",
        "Humans",
        "Mass Spectrometry",
        "Mass spectra",
        "Metabolomics",
        "Molecular Biology",
        "Phylogenetics",
        "Phylogeny",
        "Proteomics",
        "Proteomics experiment" ;
    schema1:license "GPL-3.0" ;
    schema1:name "comparems2" ;
    schema1:url "http://www.ms-utils.org/compareMS2.html" .

