@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:comparems2 a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1002/rcm.6162" ;
    schema1:description "A simple tool developed to compare, globally, all MS/MS spectra between two datasets (in Mascot Generic Format or MGF)." ;
    schema1:downloadUrl "http://www.ms-utils.org/compareMS2.c" ;
    schema1:identifier biotools:comparems2 ;
    schema1:license "GPL3" ;
    schema1:name "comparems2" ;
    schema1:softwareVersion "1" ;
    schema1:url "http://www.ms-utils.org/compareMS2.html" ;
    spdx:builtFrom biotools:comparems2 .

