@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-ipac a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/1471-2105-14-190" ;
    schema1:description "Identification of Protein Amino acid Clustering" ;
    schema1:identifier biotools:ipac ;
    schema1:keywords "Cluster Analysis",
        "Clustering",
        "Humans",
        "Mutation",
        "Neoplasm Proteins",
        "Protein Structure",
        "Protein Structure, Tertiary",
        "Protein sites, features and motifs",
        "Protein structure analysis",
        "Proteins",
        "Proteomics" ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-ipac" ;
    schema1:url "http://bioconductor.org/packages/3.6/bioc/html/iPAC.html" .

