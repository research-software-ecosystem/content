bioconda:bioconductor-kcsmart a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/1756-0500-3-298" ;
    schema1:description "Multi sample aCGH analysis package using kernel convolution" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/KCsmart_2.64.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/KCsmart/KCsmart_2.64.0.tar.gz', 'https://bioarchive.galaxyproject.org/KCsmart_2.64.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-kcsmart/bioconductor-kcsmart_2.64.0_src_all.tar.gz']" ;
    schema1:identifier biotools:kcsmart ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-kcsmart" ;
    schema1:softwareVersion "2.64.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/KCsmart.html" ;
    spdx:builtFrom biotools:kcsmart .

