@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-ruvseq a schema1:SoftwareApplication ;
    schema1:description "Remove Unwanted Variation from RNA-Seq Data" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/RUVSeq_1.40.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/RUVSeq/RUVSeq_1.40.0.tar.gz', 'https://bioarchive.galaxyproject.org/RUVSeq_1.40.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-ruvseq/bioconductor-ruvseq_1.40.0_src_all.tar.gz']" ;
    schema1:identifier biotools:ruvseq ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-ruvseq" ;
    schema1:softwareVersion "1.40.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/RUVSeq.html" ;
    spdx:builtFrom biotools:ruvseq .

