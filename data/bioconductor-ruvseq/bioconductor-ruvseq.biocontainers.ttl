@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-ruvseq a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1007/978-1-4939-6934-0_17" ;
    schema1:description "Remove Unwanted Variation from RNA-Seq Data" ;
    schema1:identifier biotools:ruvseq ;
    schema1:keywords "Dried Blood Spot Testing",
        "Gene expression",
        "Humans",
        "Infant, Newborn",
        "Isoenzymes",
        "Lysosomal Storage Diseases",
        "Neonatal Screening",
        "RNA-Seq",
        "RNA-seq",
        "alpha-Galactosidase",
        "alpha-Glucosidases" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-ruvseq" ;
    schema1:url "http://bioconductor.org/packages/release/bioc/html/RUVSeq.html" .

