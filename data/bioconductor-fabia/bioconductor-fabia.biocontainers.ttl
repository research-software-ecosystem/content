@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-fabia a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btq227" ;
    schema1:description "FABIA: Factor Analysis for Bicluster Acquisition" ;
    schema1:identifier biotools:fabia ;
    schema1:keywords "Clustering",
        "Factor Analysis, Statistical",
        "Gene Expression",
        "Gene Expression Profiling",
        "Oligonucleotide Array Sequence Analysis",
        "Pattern Recognition, Automated",
        "Statistics and probability" ;
    schema1:license "LGPL (>= 2.1)" ;
    schema1:name "bioconductor-fabia" ;
    schema1:url "http://bioconductor.org/packages/3.6/bioc/html/fabia.html" .

