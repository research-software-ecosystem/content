@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-fabia a schema1:SoftwareApplication ;
    schema1:description "FABIA: Factor Analysis for Bicluster Acquisition" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/fabia_2.56.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/fabia/fabia_2.56.0.tar.gz', 'https://bioarchive.galaxyproject.org/fabia_2.56.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-fabia/bioconductor-fabia_2.56.0_src_all.tar.gz']" ;
    schema1:identifier biotools:fabia ;
    schema1:license "LGPL (>= 2.1)" ;
    schema1:name "bioconductor-fabia" ;
    schema1:softwareVersion "2.56.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/fabia.html" ;
    spdx:builtFrom biotools:fabia .

