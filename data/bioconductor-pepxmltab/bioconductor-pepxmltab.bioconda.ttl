@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-pepxmltab a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Parsing pepXML files and filter based on peptide FDR." ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/pepXMLTab_1.40.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/pepXMLTab/pepXMLTab_1.40.0.tar.gz', 'https://bioarchive.galaxyproject.org/pepXMLTab_1.40.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-pepxmltab/bioconductor-pepxmltab_1.40.0_src_all.tar.gz']" ;
    schema1:identifier biotools:pepxmltab ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-pepxmltab" ;
    schema1:softwareVersion "1.40.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/pepXMLTab.html" ;
    spdx:builtFrom biotools:pepxmltab .

