@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-pepxmltab a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Parsing pepxml files based one xml package. the package tries to handle pepxml files generated from different softwares. the output will be a peptide-spectrum-matching tabular file. the package also provide function to filter the psms based on fdr." ;
    schema1:identifier biotools:pepxmltab ;
    schema1:keywords "Computational Biology",
        "Gene Expression Profiling",
        "Genomics",
        "High-Throughput Screening Assays",
        "Programming Languages",
        "Proteomics",
        "Small molecules",
        "User-Computer Interface" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-pepxmltab" ;
    schema1:url "http://bioconductor.org/packages/release/bioc/html/pepXMLTab.html" .

