@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:jpredapi a schema1:SoftwareApplication ;
    schema1:description "Python library for submitting jobs to JPRED - A Protein Secondary Structure Prediction Server" ;
    schema1:license "MIT" ;
    schema1:name "jpredapi" ;
    schema1:url "https://github.com/MoseleyBioinformaticsLab/jpredapi" .

