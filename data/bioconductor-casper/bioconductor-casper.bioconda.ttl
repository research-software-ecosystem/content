@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-casper a schema1:SoftwareApplication ;
    schema1:description "Characterization of Alternative Splicing based on Paired-End Reads" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/casper_2.44.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/casper/casper_2.44.0.tar.gz', 'https://bioarchive.galaxyproject.org/casper_2.44.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-casper/bioconductor-casper_2.44.0_src_all.tar.gz']" ;
    schema1:identifier biotools:casper ;
    schema1:license "GPL (>=2)" ;
    schema1:name "bioconductor-casper" ;
    schema1:softwareVersion "2.44.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/casper.html" ;
    spdx:builtFrom biotools:casper .

