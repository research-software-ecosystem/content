@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:metacluster a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/bts397",
        "doi:10.1186/1471-2164-15-S1-S12" ;
    schema1:description "MetaCluster5.1 is a new software for binning short pair-end reads" ;
    schema1:identifier biotools:metacluster ;
    schema1:keywords "Clustering",
        "Genomics",
        "Metagenomics",
        "Microbiology",
        "Phylogenetics",
        "Sensitivity and Specificity",
        "Sequence Analysis, DNA",
        "Sequence composition, complexity and repeats" ;
    schema1:license "GPL-2.0" ;
    schema1:name "metacluster" ;
    schema1:url "http://i.cs.hku.hk/~alse/MetaCluster/" .

