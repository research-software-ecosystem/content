@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:squirrel a schema1:SoftwareApplication ;
    schema1:description "Some QUIck Reconstruction to Resolve Evolutionary Links." ;
    schema1:downloadUrl "https://github.com/aineniamh/squirrel/archive/refs/tags/1.3.2.tar.gz" ;
    schema1:identifier biotools:squirrel ;
    schema1:license "GPL-3.0-only" ;
    schema1:name "squirrel" ;
    schema1:softwareHelp "https://github.com/aineniamh/squirrel/blob/1.3.2/README.md" ;
    schema1:softwareVersion "1.3.2" ;
    schema1:url "https://github.com/aineniamh/squirrel" ;
    spdx:builtFrom biotools:squirrel .

