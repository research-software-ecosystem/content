@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:singlem a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btu170" ;
    schema1:description "Singlem is a tool to find the abundances of discrete operational taxonomic units (otus) directly from shotgun metagenome data, without heavy reliance on reference sequence databases. it is able to differentiate closely related species even if those species are from lineages new to science." ;
    schema1:keywords "Clustering",
        "Genomics",
        "Metagenome" ;
    schema1:license "GNU General Public License v3.0" ;
    schema1:name "singlem" ;
    schema1:url "https://github.com/wwood/singlem" .

