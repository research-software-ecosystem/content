@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-motifdb a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "More than 2000 annotated position frequency matrices from nine public sources, for multiple organisms." ;
    schema1:identifier biotools:motifdb ;
    schema1:keywords "Computational Biology",
        "Data architecture, analysis and design",
        "Gene Expression Profiling",
        "Genomics",
        "High-Throughput Screening Assays",
        "Nucleic acid sites, features and motifs",
        "Programming Languages",
        "Sequence analysis",
        "User-Computer Interface" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-motifdb" ;
    schema1:url "http://bioconductor.org/packages/release/bioc/html/MotifDb.html" .

