@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-motifdb a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "An Annotated Collection of Protein-DNA Binding Sequence Motifs" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/MotifDb_1.48.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/MotifDb/MotifDb_1.48.0.tar.gz', 'https://bioarchive.galaxyproject.org/MotifDb_1.48.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-motifdb/bioconductor-motifdb_1.48.0_src_all.tar.gz']" ;
    schema1:identifier biotools:motifdb ;
    schema1:license "Artistic-2.0 | file LICENSE" ;
    schema1:name "bioconductor-motifdb" ;
    schema1:softwareVersion "1.48.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/MotifDb.html" ;
    spdx:builtFrom biotools:motifdb .

