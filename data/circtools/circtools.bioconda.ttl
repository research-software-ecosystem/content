@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:circtools a schema1:SoftwareApplication ;
    schema1:author "BarryDigby" ;
    schema1:citation "doi:10.1093/bioinformatics/bty948" ;
    schema1:description "circtools - a circular RNA toolbox." ;
    schema1:downloadUrl "https://pypi.io/packages/source/c/circtools/circtools-2.0.4.tar.gz" ;
    schema1:identifier biotools:circtools ;
    schema1:license "GPL-3.0-or-later" ;
    schema1:maintainer "BarryDigby" ;
    schema1:name "circtools" ;
    schema1:softwareHelp "https://docs.circ.tools/en/latest" ;
    schema1:softwareVersion "2.0.4" ;
    schema1:url "https://github.com/jakobilab/circtools" ;
    spdx:builtFrom biotools:circtools .

