@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:amap a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btl311" ;
    schema1:description "AMAP is a multiple sequence alignment program based on sequence annealing." ;
    schema1:keywords "Amino Acid Sequence",
        "Molecular Sequence Data",
        "Proteins",
        "RNA-Seq",
        "Sequence Alignment",
        "Sequence Analysis, Protein",
        "Transcriptomics" ;
    schema1:license "GPL-2.0" ;
    schema1:name "amap" ;
    schema1:url "https://github.com/pachterlab" .

