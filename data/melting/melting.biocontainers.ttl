@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:melting a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/1471-2105-13-101" ;
    schema1:description "Computes, for a nucleic acid duplex, the enthalpy, the entropy and the melting temperature of the helix-coil transitions. three types of hybridisation are possible: dna/dna, dna/rna, and rna/rna." ;
    schema1:identifier biotools:melting ;
    schema1:keywords "DNA",
        "Nucleic Acid Denaturation",
        "Nucleic Acid Hybridization",
        "Nucleic Acids",
        "Nucleic acid structure analysis",
        "Nucleic acids",
        "RNA",
        "Temperature",
        "Thermodynamics",
        "User-Computer Interface" ;
    schema1:license "GPL-2+" ;
    schema1:name "melting" ;
    schema1:url "http://www.ebi.ac.uk/compneur-srv/melting/" .

