@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:python-cobra-data a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/1752-0509-7-74" ;
    schema1:description "COnstraint-Based Reconstruction and Analysis (COBRA) methods are widely used for genome-scale modeling of metabolic networks in both prokaryotes and eukaryotes. COBRApy is a constraint-based modeling package that is designed to accommodate the biological complexity of the next generation of COBRA models and provides access to commonly used COBRA methods, such as flux balance analysis, flux variability analysis, and gene deletion analyses." ;
    schema1:keywords "Genomics",
        "Metabolic Networks and Pathways",
        "Models, Biological",
        "Programming Languages" ;
    schema1:license "GPL-2.0" ;
    schema1:name "python-cobra-data" ;
    schema1:url "https://github.com/opencobra/cobrapy" .

