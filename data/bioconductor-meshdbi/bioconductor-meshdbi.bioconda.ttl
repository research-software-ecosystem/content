@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-meshdbi a schema1:SoftwareApplication ;
    schema1:description "DBI to construct MeSH-related package from sqlite file" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/MeSHDbi_1.42.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/MeSHDbi/MeSHDbi_1.42.0.tar.gz', 'https://bioarchive.galaxyproject.org/MeSHDbi_1.42.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-meshdbi/bioconductor-meshdbi_1.42.0_src_all.tar.gz']" ;
    schema1:identifier biotools:meshdbi ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-meshdbi" ;
    schema1:softwareVersion "1.42.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/MeSHDbi.html" ;
    spdx:builtFrom biotools:meshdbi .

