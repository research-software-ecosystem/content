@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-meshdbi a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s12859-015-0453-z" ;
    schema1:description "The package is a unified implementation of mesh.db, mesh.aor.db, and mesh.pcr.db and also is interfaced to construct gene-mesh package (mesh.xxx.eg.db). loadmeshdbipkg import sqlite file and generate mesh.xxx.eg.db." ;
    schema1:identifier biotools:meshdbi ;
    schema1:keywords "Animals",
        "Caloric Restriction",
        "Computational Biology",
        "Data management",
        "Gene Expression Profiling",
        "Genome-Wide Association Study",
        "Humans",
        "Information Storage and Retrieval",
        "Medical Subject Headings",
        "Medical informatics",
        "Molecular Sequence Annotation",
        "Oligonucleotide Array Sequence Analysis",
        "Pseudomonas aeruginosa",
        "PubMed",
        "Rats",
        "Vocabulary, Controlled" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-meshdbi" ;
    schema1:url "http://bioconductor.org/packages/release/bioc/html/MeSHDbi.html" .

