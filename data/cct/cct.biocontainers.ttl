@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:cct a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/gki432" ;
    schema1:description "Cct (current comparative table) is a software package that you can install and set-up on your own system to help you to maintain and search databases." ;
    schema1:identifier biotools:cct ;
    schema1:keywords "Computational Biology",
        "Computational biology",
        "Database management",
        "Databases, Nucleic Acid",
        "Databases, Protein",
        "Genomics",
        "Internet",
        "Proteins",
        "User-Computer Interface" ;
    schema1:license "custom, see /usr/share/doc/cct/copyright" ;
    schema1:name "cct" ;
    schema1:url "http://sourceforge.net/projects/orb-cct" .

