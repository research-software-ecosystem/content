@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:connor a schema1:SoftwareApplication ;
    schema1:description "A command-line tool to deduplicate bam files based on custom, inline barcoding." ;
    schema1:license "Apache-2.0" ;
    schema1:name "connor" ;
    schema1:url "https://github.com/umich-brcf-bioinf/Connor" .

