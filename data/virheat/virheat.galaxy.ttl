@prefix galaxytool: <https://github.com/galaxyproject/tools-iuc/tree/master/tools/> .
@prefix schema1: <http://schema.org/> .

galaxytool:virheat a schema1:SoftwareApplication ;
    schema1:description "generates a heatmap of allele frequencies from vcf files" ;
    schema1:identifier "bioconda:virheat",
        "biotools:virheat" ;
    schema1:keywords "Variant Analysis",
        "Visualization" ;
    schema1:name "virheat" ;
    schema1:softwareVersion "0.7.1" ;
    schema1:url "https://github.com/jonas-fuchs/virHEAT" .

