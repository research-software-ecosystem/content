@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:splitcode a schema1:SoftwareApplication ;
    schema1:author "Yenaled" ;
    schema1:citation "doi:10.1101/2023.03.20.533521" ;
    schema1:description "Flexible parsing, interpretation, and editing of technical sequences." ;
    schema1:downloadUrl "https://github.com/pachterlab/splitcode/archive/refs/tags/v0.31.6.tar.gz" ;
    schema1:identifier biotools:splitcode ;
    schema1:license "BSD-2-Clause" ;
    schema1:maintainer "Yenaled" ;
    schema1:name "splitcode" ;
    schema1:softwareHelp "https://splitcode.readthedocs.io" ;
    schema1:softwareVersion "0.31.6" ;
    schema1:url "https://github.com/pachterlab/splitcode" ;
    spdx:builtFrom biotools:splitcode .

