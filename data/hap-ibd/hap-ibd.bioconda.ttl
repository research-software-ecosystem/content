@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:hap-ibd a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1016/j.ajhg.2020.02.010" ;
    schema1:description "Hap-ibd Detects identity-by-descent (IBD) segments and homozygosity-by-descent (HBD) segments in phased genotype data." ;
    schema1:downloadUrl "https://faculty.washington.edu/browning/hap-ibd.jar" ;
    schema1:identifier biotools:hap-ibd ;
    schema1:license "Apache-2.0" ;
    schema1:name "hap-ibd" ;
    schema1:softwareHelp "https://github.com/browning-lab/hap-ibd/blob/master/README.md" ;
    schema1:softwareVersion "1.0.rev20May22.818" ;
    schema1:url "https://github.com/browning-lab/hap-ibd" ;
    spdx:builtFrom biotools:hap-ibd .

