@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:probamconvert a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1021/acs.jproteome.7b00132" ;
    schema1:description "Probamconvert is a conversion tool to convert common peptide identification files (mzidentml, pepxml, mztab) to the probam or probed format" ;
    schema1:keywords "Proteomics" ;
    schema1:license "Apache License, Version 2.0" ;
    schema1:name "probamconvert" ;
    schema1:url "https://github.com/Biobix/proBAMconvert" .

