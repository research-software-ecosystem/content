@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-annotationhub a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Client to access AnnotationHub resources" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/AnnotationHub_3.14.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/AnnotationHub/AnnotationHub_3.14.0.tar.gz', 'https://bioarchive.galaxyproject.org/AnnotationHub_3.14.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-annotationhub/bioconductor-annotationhub_3.14.0_src_all.tar.gz']" ;
    schema1:identifier biotools:annotationhub ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-annotationhub" ;
    schema1:softwareVersion "3.14.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/AnnotationHub.html" ;
    spdx:builtFrom biotools:annotationhub .

