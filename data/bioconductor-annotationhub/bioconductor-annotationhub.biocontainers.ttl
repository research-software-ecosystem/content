@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-annotationhub a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "This package provides a client for the bioconductor corresponding web resource, which provides a central location where genomic files (e.g., vcf, bed, wig) and other resources from standard locations (e.g., ucsc, ensembl) can be discovered. the resource includes metadata about each resource, e.g., a textual description, tags, and date of modification. the client creates and manages a local cache of files retrieved by the user, helping with quick and reproducible access." ;
    schema1:identifier biotools:annotationhub ;
    schema1:keywords "Computational Biology",
        "Database management",
        "Gene Expression Profiling",
        "Genomics",
        "High-Throughput Screening Assays",
        "Informatics",
        "Programming Languages",
        "Proteomics",
        "User-Computer Interface" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-annotationhub" ;
    schema1:url "http://bioconductor.org/packages/release/bioc/html/AnnotationHub.html" .

