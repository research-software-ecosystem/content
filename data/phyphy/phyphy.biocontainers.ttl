@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:phyphy a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1101/206011",
        "doi:10.21105/joss.00514" ;
    schema1:description "Facilitating the execution and parsing of standard HyPhy (>=2.3.7) analyses" ;
    schema1:license "BSD-3-Clause" ;
    schema1:name "phyphy" ;
    schema1:url "https://github.com/sjspielman/phyphy" .

