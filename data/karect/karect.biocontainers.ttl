@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:karect a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btv415" ;
    schema1:description "KAUST Assembly Read Error Correction Tool" ;
    schema1:keywords "Chromosome Mapping",
        "Computational Biology",
        "Genome, Human",
        "High-Throughput Nucleotide Sequencing",
        "Humans",
        "INDEL Mutation",
        "Mutagenesis, Insertional",
        "Sequence Analysis, DNA",
        "Sequence Deletion" ;
    schema1:license "GPL-2.0" ;
    schema1:name "karect" ;
    schema1:url "https://github.com/aminallam/karect" .

