@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:mir-prefer a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btu380" ;
    schema1:description "microRNA PREdiction From small RNA-seq data" ;
    schema1:identifier biotools:mir-prefer ;
    schema1:keywords "Base Sequence",
        "Benchmarking",
        "Computational Biology",
        "False Positive Reactions",
        "Functional, regulatory and non-coding RNA",
        "Genome",
        "MicroRNAs",
        "Plants",
        "RNA",
        "RNA-Seq",
        "Reproducibility of Results",
        "Sequence Analysis, RNA" ;
    schema1:license "GPL" ;
    schema1:name "mir-prefer" ;
    schema1:url "https://github.com/hangelwen/miR-PREFeR" .

