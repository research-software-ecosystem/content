@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:circlator a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s13059-015-0849-0" ;
    schema1:description "Circlator: a tool to circularise genome assemblies" ;
    schema1:keywords "Contig Mapping",
        "DNA, Circular",
        "Genome, Bacterial",
        "Genome, Mitochondrial",
        "Genome, Protozoan",
        "Genomics",
        "Humans",
        "Plasmodium falciparum",
        "Sequence Alignment" ;
    schema1:license "GPL-3.0" ;
    schema1:name "circlator" ;
    schema1:url "https://github.com/sanger-pathogens/circlator" .

