@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-genbankr a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Parsing GenBank files into semantically useful objects" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.17/bioc/src/contrib/genbankr_1.27.0.tar.gz', 'https://bioconductor.org/packages/3.17/bioc/src/contrib/Archive/genbankr/genbankr_1.27.0.tar.gz', 'https://bioarchive.galaxyproject.org/genbankr_1.27.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-genbankr/bioconductor-genbankr_1.27.0_src_all.tar.gz']" ;
    schema1:identifier biotools:genbankr ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-genbankr" ;
    schema1:softwareVersion "1.27.0" ;
    schema1:url "https://bioconductor.org/packages/3.17/bioc/html/genbankr.html" ;
    spdx:builtFrom biotools:genbankr .

