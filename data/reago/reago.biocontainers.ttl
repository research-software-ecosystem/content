@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:reago a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btv231" ;
    schema1:description "An assembly tool for 16S ribosomal RNA recovery from metagenomic data" ;
    schema1:identifier biotools:reago ;
    schema1:keywords "Computational Biology",
        "Databases, Nucleic Acid",
        "Genes, rRNA",
        "Metagenomics",
        "Microbiology",
        "Microbiota",
        "Phylogeny",
        "RNA",
        "RNA, Bacterial",
        "RNA, Ribosomal, 16S",
        "Sequence Analysis, RNA",
        "Sequence assembly" ;
    schema1:license "Apache-2.0" ;
    schema1:name "reago" ;
    schema1:url "https://github.com/chengyuan/reago-1.1" .

