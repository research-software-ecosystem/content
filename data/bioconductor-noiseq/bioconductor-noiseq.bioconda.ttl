@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-noiseq a schema1:SoftwareApplication ;
    schema1:description "Exploratory analysis and differential expression for RNA-seq data" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/NOISeq_2.50.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/NOISeq/NOISeq_2.50.0.tar.gz', 'https://bioarchive.galaxyproject.org/NOISeq_2.50.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-noiseq/bioconductor-noiseq_2.50.0_src_all.tar.gz']" ;
    schema1:identifier biotools:noiseq ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-noiseq" ;
    schema1:softwareVersion "2.50.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/NOISeq.html" ;
    spdx:builtFrom biotools:noiseq .

