@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-phyloseq a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1371/journal.pone.0061217" ;
    schema1:description "Gnu r handling and analysis of high-throughput microbiome census data" ;
    schema1:identifier biotools:phyloseq ;
    schema1:keywords "Clustering",
        "Data Interpretation, Statistical",
        "Genomics",
        "Humans",
        "Metagenome",
        "Metagenomics",
        "Microbiology",
        "Multivariate Analysis",
        "Phylogeny",
        "Principal Component Analysis",
        "Sequence Analysis, DNA",
        "Sequence analysis" ;
    schema1:license "AGPL-3" ;
    schema1:name "bioconductor-phyloseq" ;
    schema1:url "https://bioconductor.org/packages/phyloseq/" .

