@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-phyloseq a schema1:SoftwareApplication ;
    schema1:description "Handling and analysis of high-throughput microbiome census data" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/phyloseq_1.50.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/phyloseq/phyloseq_1.50.0.tar.gz', 'https://bioarchive.galaxyproject.org/phyloseq_1.50.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-phyloseq/bioconductor-phyloseq_1.50.0_src_all.tar.gz']" ;
    schema1:identifier biotools:phyloseq ;
    schema1:license "AGPL-3" ;
    schema1:name "bioconductor-phyloseq" ;
    schema1:softwareVersion "1.50.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/phyloseq.html" ;
    spdx:builtFrom biotools:phyloseq .

