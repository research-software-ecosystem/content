@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:mzquality a schema1:SoftwareApplication ;
    schema1:description "A tool to assess the quality of targeted mass spectrometry measurements." ;
    schema1:keywords "Mass spectrometry",
        "Metabolomics" ;
    schema1:license "Apache-2.0" ;
    schema1:name "mzquality" ;
    schema1:url "https://github.com/phnmnl/container-mzquality" .

