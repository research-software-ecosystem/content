@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:ngseqbasic a schema1:SoftwareApplication ;
    schema1:description "Basic ChIP/DNaseI/ATAC analysis - from FASTQ to visualisation of tracks, in one command." ;
    schema1:license "GPL-3.0" ;
    schema1:name "ngseqbasic" ;
    schema1:url "http://userweb.molbiol.ox.ac.uk/public/telenius/NGseqBasicManual/external/instructionsBioconda.html" .

