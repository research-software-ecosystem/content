@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:clinvar-tsv a schema1:SoftwareApplication ;
    schema1:description "A Snakemake-based program to download ClinVar and convert to easy-to-use TSV files." ;
    schema1:license "MIT" ;
    schema1:name "clinvar-tsv" ;
    schema1:url "https://github.com/bihealth/clinvar-tsv" .

