@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:mlst a schema1:SoftwareApplication ;
    schema1:description "Scan contig files against PubMLST typing schemes" ;
    schema1:downloadUrl "https://github.com/tseemann/mlst/archive/v2.33.1.tar.gz" ;
    schema1:identifier biotools:mlst ;
    schema1:license "GPL-2.0" ;
    schema1:name "mlst" ;
    schema1:softwareVersion "2.33.1" ;
    schema1:url "https://github.com/tseemann/mlst" ;
    spdx:builtFrom biotools:mlst .

