@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:mlst a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1128/JCM.06094-11" ;
    schema1:description "Multi locus sequence typing from an assembled genome or from a set of reads." ;
    schema1:identifier biotools:mlst ;
    schema1:keywords "Bacteria",
        "Bacterial Typing Techniques",
        "Contig Mapping",
        "Databases, Genetic",
        "Genes, Bacterial",
        "Genome, Bacterial",
        "High-Throughput Nucleotide Sequencing",
        "Immunoproteins, genes and antigens",
        "Multilocus Sequence Typing" ;
    schema1:license "Apache-2.0" ;
    schema1:name "mlst" ;
    schema1:url "http://cge.cbs.dtu.dk/services/MLST/" .

