@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:minnow a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/BIOINFORMATICS/BTZ351" ;
    schema1:description "A principled framework for rapid simulation of dscRNA-seq data at the read level" ;
    schema1:identifier biotools:minnow ;
    schema1:keywords "Gene Expression Profiling",
        "Gene transcripts",
        "Genomics",
        "High-Throughput Nucleotide Sequencing",
        "PCR experiment",
        "RNA-Seq",
        "Sequence Analysis, RNA",
        "Single-Cell Analysis",
        "Transcriptome" ;
    schema1:license "GPL-3.0" ;
    schema1:name "minnow" ;
    schema1:url "https://github.com/COMBINE-lab/minnow" .

