@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-ggtree a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1111/2041-210X.12628" ;
    schema1:description "an R package for visualization of tree and annotation data" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/ggtree_4.0.4.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/ggtree/ggtree_4.0.4.tar.gz', 'https://bioarchive.galaxyproject.org/ggtree_4.0.4.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-ggtree/bioconductor-ggtree_4.0.4_src_all.tar.gz']" ;
    schema1:identifier biotools:ggtree ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-ggtree" ;
    schema1:softwareVersion "4.0.4" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/ggtree.html" ;
    spdx:builtFrom biotools:ggtree .

