@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-ggtree a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1111/2041-210X.12628" ;
    schema1:description "Extend the 'ggplot2' plotting system which implemented the grammar of graphics. it is designed for visualization and annotation of phylogenetic trees with their covariates and other associated data." ;
    schema1:identifier biotools:ggtree ;
    schema1:keywords "Clustering",
        "Data visualisation",
        "Genetics",
        "Metagenome",
        "Phylogenetics",
        "Phylogeny" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-ggtree" ;
    schema1:url "http://bioconductor.org/packages/release/bioc/html/ggtree.html" .

