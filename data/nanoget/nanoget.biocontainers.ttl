@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:nanoget a schema1:SoftwareApplication ;
    schema1:description "Functions to extract information from Oxford Nanopore sequencing data and alignments." ;
    schema1:license "MIT" ;
    schema1:name "nanoget" ;
    schema1:url "https://github.com/wdecoster/nanoget" .

