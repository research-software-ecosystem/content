@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-basics a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18129/b9.bioc.basics" ;
    schema1:description "Bayesian Analysis of Single-Cell Sequencing data" ;
    schema1:keywords "Gene Expression",
        "RNA-Seq",
        "Transcriptomics" ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-basics" ;
    schema1:url "https://bioconductor.org/packages/3.8/bioc/html/BASiCS.html" .

