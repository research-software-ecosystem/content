@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-caomicsv a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18129/b9.bioc.caomicsv" ;
    schema1:description "Visualization of multi-dimentional cancer genomics data" ;
    schema1:keywords "Gene Expression",
        "Genomics" ;
    schema1:license "GPL (>=2.0)" ;
    schema1:name "bioconductor-caomicsv" ;
    schema1:url "https://bioconductor.org/packages/3.8/bioc/html/caOmicsV.html" .

