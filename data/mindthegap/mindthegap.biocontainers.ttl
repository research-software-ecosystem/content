@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:mindthegap a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btu545" ;
    schema1:description "Mindthegap performs detection and assembly of dna insertion variants in ngs read datasets with respect to a reference genome." ;
    schema1:identifier biotools:mindthegap ;
    schema1:keywords "Animals",
        "Caenorhabditis elegans",
        "Genetic variation",
        "Genome",
        "Genomics",
        "Humans",
        "Metagenomics",
        "Mutagenesis, Insertional",
        "Sequence Analysis, DNA" ;
    schema1:license "AGPL-3.0-only" ;
    schema1:name "mindthegap" ;
    schema1:url "https://github.com/GATB/MindTheGap" .

