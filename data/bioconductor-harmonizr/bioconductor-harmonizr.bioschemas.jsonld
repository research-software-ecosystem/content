  "@graph": [
    {
      "@id": "https://bio.tools/bioconductor-harmonizr",
      "@type": "sc:SoftwareApplication",
      "dcterms:conformsTo": "https://bioschemas.org/profiles/ComputationalTool/0.6-DRAFT",
      "sc:additionalType": [
        "Command-line tool",
        "Library"
      ],
      "sc:author": [
        "Simon Schlumbohm",
        "Philipp Neumann",
        "Julia Neumann"
      ],
      "sc:citation": {
        "@id": "https://doi.org/10.18129/B9.bioc.HarmonizR"
      },
      "sc:description": "An implementation, which takes input data and makes it available for proper batch effect removal by ComBat or Limma. The implementation appropriately handles missing values by dissecting the input matrix into smaller matrices with sufficient data to feed the ComBat or limma algorithm. The adjusted data is returned to the user as a rebuild matrix. The implementation is meant to make as much data available as possible with minimal data loss.",
      "sc:license": "GPL-3.0-only",
      "sc:name": "HarmonizR",
      "sc:operatingSystem": [
        "Windows",
        "Linux",
        "Mac"
      ],
