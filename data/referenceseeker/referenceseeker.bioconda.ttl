@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:referenceseeker a schema1:SoftwareApplication ;
    schema1:author "oschwengers" ;
    schema1:description "Rapid determination of appropriate reference genomes." ;
    schema1:downloadUrl "https://github.com/oschwengers/referenceseeker/archive/v1.8.0.tar.gz" ;
    schema1:identifier biotools:referenceseeker ;
    schema1:license "GPLv3" ;
    schema1:maintainer "oschwengers" ;
    schema1:name "referenceseeker" ;
    schema1:softwareVersion "1.8.0" ;
    schema1:url "https://github.com/oschwengers/referenceseeker" ;
    spdx:builtFrom biotools:referenceseeker .

