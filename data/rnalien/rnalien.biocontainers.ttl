@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:rnalien a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/gkw558" ;
    schema1:description "A tool for unsupervised construction of rna family models" ;
    schema1:identifier biotools:RNAlien ;
    schema1:keywords "Base Pairing",
        "Humans",
        "Models, Molecular",
        "Nucleic Acid Conformation",
        "RNA",
        "Sequence Homology, Nucleic Acid",
        "Time Factors" ;
    schema1:license "GPL-3" ;
    schema1:name "rnalien" ;
    schema1:url "http://rna.tbi.univie.ac.at/rnalien/tool" .

