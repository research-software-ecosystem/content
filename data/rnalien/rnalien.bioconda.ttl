@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:rnalien a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/gkw558" ;
    schema1:description "A tool for unsupervised construction of RNA family models" ;
    schema1:downloadUrl "https://github.com/eggzilla/RNAlien/releases/download/1.8.0/RNAlien.tar.gz" ;
    schema1:identifier biotools:RNAlien ;
    schema1:license "GPL-3" ;
    schema1:name "rnalien" ;
    schema1:softwareVersion "1.8.0" ;
    schema1:url "http://rna.tbi.univie.ac.at/rnalien/tool" ;
    spdx:builtFrom biotools:RNAlien .

