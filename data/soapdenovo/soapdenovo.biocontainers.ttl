@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:soapdenovo a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1101/gr.097261.109" ;
    schema1:description "Soapdenovo, a short read de novo assembly tool, is a package for assembling short oligonucleotide into contigs and scaffolds." ;
    schema1:identifier biotools:soapdenovo ;
    schema1:keywords "African Continental Ancestry Group",
        "Asian Continental Ancestry Group",
        "Genome, Human",
        "Human Genome Project",
        "Humans",
        "Oligonucleotide Array Sequence Analysis",
        "Sequence Alignment",
        "Sequence Analysis, DNA",
        "Sequence assembly" ;
    schema1:license "GPL-3.0" ;
    schema1:name "soapdenovo" ;
    schema1:url "http://soap.genomics.org.cn/soapdenovo.html" .

