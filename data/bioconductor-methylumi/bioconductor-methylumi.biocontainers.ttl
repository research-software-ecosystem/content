@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-methylumi a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/1471-2164-14-293" ;
    schema1:description "Handle Illumina methylation data" ;
    schema1:identifier biotools:methylumi ;
    schema1:keywords "Chromosomes, Human, X",
        "Computational Biology",
        "DNA",
        "DNA Methylation",
        "Epigenetics",
        "Genomic Imprinting",
        "Humans",
        "Oligonucleotide Array Sequence Analysis",
        "Polymorphism, Single Nucleotide",
        "Sequencing",
        "Statistics as Topic" ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-methylumi" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/methylumi.html" .

