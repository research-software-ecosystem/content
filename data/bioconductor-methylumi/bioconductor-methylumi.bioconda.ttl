@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-methylumi a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/1471-2164-14-293" ;
    schema1:description "Handle Illumina methylation data" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/methylumi_2.52.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/methylumi/methylumi_2.52.0.tar.gz', 'https://bioarchive.galaxyproject.org/methylumi_2.52.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-methylumi/bioconductor-methylumi_2.52.0_src_all.tar.gz']" ;
    schema1:identifier biotools:methylumi ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-methylumi" ;
    schema1:softwareVersion "2.52.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/methylumi.html" ;
    spdx:builtFrom biotools:methylumi .

