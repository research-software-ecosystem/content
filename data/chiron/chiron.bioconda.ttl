@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:chiron a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/gigascience/giy037" ;
    schema1:description "A deep neural network basecaller for nanopore sequencing." ;
    schema1:downloadUrl "https://pypi.io/packages/source/c/chiron/chiron-0.6.1.1.tar.gz" ;
    schema1:identifier biotools:Chiron ;
    schema1:license "Mozilla Public License 2.0 (MPL 2.0)" ;
    schema1:name "chiron" ;
    schema1:softwareVersion "0.6.1.1" ;
    schema1:url "https://github.com/haotianteng/chiron" ;
    spdx:builtFrom biotools:Chiron .

