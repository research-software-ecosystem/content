@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:npinv a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s12859-018-2252-9" ;
    schema1:description "an accurate tool for detecting and genotyping inversion using multiple alignment long reads" ;
    schema1:keywords "Chromosome Inversion",
        "Genotype",
        "Humans" ;
    schema1:license "MIT" ;
    schema1:name "npinv" ;
    schema1:url "https://github.com/haojingshao/npInv" .

