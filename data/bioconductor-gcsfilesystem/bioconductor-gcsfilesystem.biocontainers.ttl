@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-gcsfilesystem a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18129/b9.bioc.gcsfilesystem" ;
    schema1:description "Mounting a Google Cloud bucket to a local directory. The files in the bucket can be viewed and read as if they are locally stored. For using the package, you need to install GCSDokan on Windows or gcsfuse on Linux and MacOs." ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-gcsfilesystem" ;
    schema1:url "https://bioconductor.org/packages/3.12/bioc/html/GCSFilesystem.html" .

