@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-translatome a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btt634" ;
    schema1:description "Comparison between multiple levels of gene expression" ;
    schema1:identifier biotools:translatome ;
    schema1:keywords "Cell Differentiation",
        "Computational Biology",
        "Data mining",
        "Databases, Factual",
        "Gene Expression",
        "Gene expression",
        "Genomics",
        "Hepatocytes",
        "Humans",
        "Protein Biosynthesis",
        "Proteome",
        "RNA, Messenger",
        "Regulatory Sequences, Nucleic Acid",
        "Transcriptome" ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-translatome" ;
    schema1:url "http://bioconductor.org/packages/3.6/bioc/html/tRanslatome.html" .

