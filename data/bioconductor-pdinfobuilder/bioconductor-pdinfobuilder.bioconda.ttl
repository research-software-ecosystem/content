@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-pdinfobuilder a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btq431" ;
    schema1:description "Platform Design Information Package Builder" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/pdInfoBuilder_1.74.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/pdInfoBuilder/pdInfoBuilder_1.74.0.tar.gz', 'https://bioarchive.galaxyproject.org/pdInfoBuilder_1.74.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-pdinfobuilder/bioconductor-pdinfobuilder_1.74.0_src_all.tar.gz']" ;
    schema1:identifier biotools:pdinfobuilder ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-pdinfobuilder" ;
    schema1:softwareVersion "1.74.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/pdInfoBuilder.html" ;
    spdx:builtFrom biotools:pdinfobuilder .

