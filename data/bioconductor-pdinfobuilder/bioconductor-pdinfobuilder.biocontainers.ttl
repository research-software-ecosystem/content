@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-pdinfobuilder a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btq431" ;
    schema1:description "Platform Design Information Package Builder" ;
    schema1:identifier biotools:pdinfobuilder ;
    schema1:keywords "DNA polymorphism",
        "Database management",
        "Databases, Factual",
        "Gene Expression Profiling",
        "Microarray experiment",
        "Oligonucleotide Array Sequence Analysis",
        "Oligonucleotides",
        "User-Computer Interface" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-pdinfobuilder" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/pdInfoBuilder.html" .

