@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:vcflatten a schema1:SoftwareApplication ;
    schema1:description "A command line tool for flattening vcf files down to simpler tsv files." ;
    schema1:license "Not available" ;
    schema1:name "vcflatten" ;
    schema1:url "http://innovativemedicine.ca/tools/vcflatten" .

