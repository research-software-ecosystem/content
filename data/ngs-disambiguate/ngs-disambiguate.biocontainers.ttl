@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:ngs-disambiguate a schema1:SoftwareApplication ;
    schema1:citation "doi:10.12688/f1000research.10082.1",
        "doi:10.5281/zenodo.166017" ;
    schema1:description "Disambiguation algorithm for reads aligned to human and mouse genomes using Tophat or BWA mem" ;
    schema1:license "MIT" ;
    schema1:name "ngs-disambiguate" ;
    schema1:url "https://github.com/AstraZeneca-NGS/disambiguate" .

