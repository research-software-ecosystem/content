@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-phyext2 a schema1:SoftwareApplication ;
    schema1:description "Based on (but not identical to) the no-longer-maintained package 'phyext', provides enhancements to 'phylobase' classes, specifically for use by package 'sigtree'; provides classes and methods which help users manipulate branch-annotated trees (as in 'sigtree'); also provides support for a few other extra features." ;
    schema1:keywords "Genetics",
        "Phylogenetics" ;
    schema1:license "GPL-3" ;
    schema1:name "r-phyext2" ;
    schema1:url "https://CRAN.R-project.org/package=phyext2" .

