@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:phyx a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btx063" ;
    schema1:description "Performs phylogenetics analyses on trees and sequences.." ;
    schema1:identifier biotools:phyx ;
    schema1:keywords "Genetics",
        "Genomics",
        "Phylogenetics",
        "Phylogeny",
        "Sequence Alignment",
        "Simulation experiment" ;
    schema1:license "GPL-3.0" ;
    schema1:name "phyx" ;
    schema1:url "https://github.com/FePhyFoFum/phyx" .

