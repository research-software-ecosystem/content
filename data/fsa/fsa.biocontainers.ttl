@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:fsa a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1371/journal.pcbi.1000392" ;
    schema1:description "Fast statistical alignment of protein, rna or dna sequences" ;
    schema1:keywords "Amino Acid Sequence",
        "Animals",
        "Artificial Intelligence",
        "Base Sequence",
        "Data Interpretation, Statistical",
        "Databases, Genetic",
        "Humans",
        "Markov Chains",
        "Models, Genetic",
        "Molecular Sequence Data",
        "Ortholog",
        "Sensitivity and Specificity",
        "Sequence Alignment",
        "Sequence Analysis" ;
    schema1:license "GPL-3" ;
    schema1:name "fsa" ;
    schema1:url "http://fsa.sourceforge.net/" .

