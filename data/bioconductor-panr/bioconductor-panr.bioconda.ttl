    schema1:identifier biotools:panr ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-panr" ;
    schema1:softwareVersion "1.56.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/PANR.html" ;
    spdx:builtFrom biotools:panr .

