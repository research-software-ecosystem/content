@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-arrayqualitymetrics a schema1:SoftwareApplication ;
    schema1:description "Quality metrics report for microarray data sets" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/arrayQualityMetrics_3.62.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/arrayQualityMetrics/arrayQualityMetrics_3.62.0.tar.gz', 'https://bioarchive.galaxyproject.org/arrayQualityMetrics_3.62.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-arrayqualitymetrics/bioconductor-arrayqualitymetrics_3.62.0_src_all.tar.gz']" ;
    schema1:identifier biotools:arrayqualitymetrics ;
    schema1:license "LGPL (>= 2)" ;
    schema1:name "bioconductor-arrayqualitymetrics" ;
    schema1:softwareVersion "3.62.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/arrayQualityMetrics.html" ;
    spdx:builtFrom biotools:arrayqualitymetrics .

