@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-arrayqualitymetrics a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1016/j.ygeno.2010.01.003" ;
    schema1:description "Quality metrics report for microarray data sets" ;
    schema1:identifier biotools:arrayqualitymetrics ;
    schema1:keywords "Animals",
        "Computational Biology",
        "Data Interpretation, Statistical",
        "Data quality management",
        "Gene Expression Profiling",
        "Humans",
        "Mice",
        "Microarray experiment",
        "Oligonucleotide Array Sequence Analysis",
        "Quality Control" ;
    schema1:license "LGPL (>= 2)" ;
    schema1:name "bioconductor-arrayqualitymetrics" ;
    schema1:url "http://bioconductor.org/packages/3.6/bioc/html/arrayQualityMetrics.html" .

