@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-seqarray a schema1:SoftwareApplication ;
    schema1:description "Data Management of Large-Scale Whole-Genome Sequence Variant Calls" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/SeqArray_1.46.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/SeqArray/SeqArray_1.46.0.tar.gz', 'https://bioarchive.galaxyproject.org/SeqArray_1.46.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-seqarray/bioconductor-seqarray_1.46.0_src_all.tar.gz']" ;
    schema1:identifier biotools:seqarray ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-seqarray" ;
    schema1:softwareVersion "1.46.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/SeqArray.html" ;
    spdx:builtFrom biotools:seqarray .

