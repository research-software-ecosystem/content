@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-clonotyper a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btt004" ;
    schema1:description "The purpose of this package is to process and quantitatively analyse millions of v-cdr3-j combination, called clonotypes, from multiple sequence libraries." ;
    schema1:identifier biotools:clonotyper ;
    schema1:keywords "High-Throughput Nucleotide Sequencing",
        "Humans",
        "Immunology",
        "Receptors, Antigen, T-Cell, alpha-beta",
        "Sequence Analysis, DNA",
        "Sequence analysis" ;
    schema1:license "file LICENSE" ;
    schema1:name "bioconductor-clonotyper" ;
    schema1:url "http://bioconductor.org/packages/release/bioc/html/clonotypeR.html" .

