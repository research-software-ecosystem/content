@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:peakranger a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/1471-2105-12-139" ;
    schema1:description "Peakranger is a multi-purporse software suite for analyzing next-generation sequencing (ngs) data." ;
    schema1:identifier biotools:peakranger ;
    schema1:keywords "Base Sequence",
        "ChIP-seq",
        "Chromatin",
        "Chromatin Assembly and Disassembly",
        "Chromatin Immunoprecipitation",
        "Histone Code",
        "Protein Binding",
        "Sensitivity and Specificity",
        "Sequence Analysis, DNA" ;
    schema1:license "Artistic License 2.0" ;
    schema1:name "peakranger" ;
    schema1:url "http://ranger.sourceforge.net" .

