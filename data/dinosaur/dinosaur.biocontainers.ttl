@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:dinosaur a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1021/acs.jproteome.6b00016" ;
    schema1:description "Feature finding algorithm for detection of isotope patterns in hplc mass spectrometry data." ;
    schema1:identifier biotools:dinosaur ;
    schema1:keywords "Clustering",
        "Databases, Protein",
        "Mass Spectrometry",
        "Mass spectrometry",
        "Peptides",
        "Proteomics",
        "Workflow" ;
    schema1:license "Apache-2.0" ;
    schema1:name "dinosaur" ;
    schema1:url "https://github.com/fickludd/dinosaur" .

