@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:ivar a schema1:SoftwareApplication ;
    schema1:author "gkarthik" ;
    schema1:citation "doi:10.1186/s13059-018-1618-7" ;
    schema1:description "iVar is a computational package that contains functions broadly useful for viral amplicon-based sequencing." ;
    schema1:downloadUrl "https://github.com/andersen-lab/ivar/archive/v1.4.4.tar.gz" ;
    schema1:identifier biotools:ivar ;
    schema1:license "GPL-3.0-or-later" ;
    schema1:maintainer "gkarthik" ;
    schema1:name "ivar" ;
    schema1:softwareHelp "https://andersen-lab.github.io/ivar/html" ;
    schema1:softwareVersion "1.4.4" ;
    schema1:url "https://github.com/andersen-lab/ivar" ;
    spdx:builtFrom biotools:ivar .

