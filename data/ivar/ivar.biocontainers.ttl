@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:ivar a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s13059-018-1618-7" ;
    schema1:description "iVar is a computational package that contains functions broadly useful for viral amplicon-based sequencing." ;
    schema1:identifier biotools:ivar ;
    schema1:keywords "Genetic Variation",
        "Genomics",
        "Sequence Analysis, RNA",
        "West Nile virus",
        "Zika Virus" ;
    schema1:license "GPL-3.0" ;
    schema1:name "ivar" ;
    schema1:url "https://andersen-lab.github.io/ivar/html/" .

