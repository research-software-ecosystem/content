  "@graph": [
    {
      "@id": "https://bio.tools/bioconductor-fenr",
      "@type": "sc:SoftwareApplication",
      "dcterms:conformsTo": "https://bioschemas.org/profiles/ComputationalTool/0.6-DRAFT",
      "sc:additionalType": [
        "Command-line tool",
        "Library"
      ],
      "sc:author": "Marek Gierlinski",
      "sc:citation": {
        "@id": "https://doi.org/10.18129/B9.bioc.fenr"
      },
      "sc:description": "Perform fast functional enrichment on feature lists (like genes or proteins) using the hypergeometric distribution. Tailored for speed, this package is ideal for interactive platforms such as Shiny. It supports the retrieval of functional data from sources like GO, KEGG, Reactome, Bioplanet and WikiPathways. By downloading and preparing data first, it allows for rapid successive tests on various feature selections without the need for repetitive, time-consuming preparatory steps typical of other packages.",
      "sc:license": "MIT",
      "sc:name": "fenr",
      "sc:operatingSystem": [
        "Windows",
        "Mac",
        "Linux"
      ],
      "sc:softwareHelp": {
        "@id": "https://bioconductor.org/packages/fenr"
      },
      "sc:softwareVersion": "1.8.1",
      "sc:url": "https://bioconductor.org/packages/fenr"
    },
