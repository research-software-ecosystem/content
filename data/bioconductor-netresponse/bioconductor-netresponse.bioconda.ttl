@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-netresponse a schema1:SoftwareApplication ;
    schema1:description "Functional Network Analysis" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/netresponse_1.70.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/netresponse/netresponse_1.70.0.tar.gz', 'https://bioarchive.galaxyproject.org/netresponse_1.70.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-netresponse/bioconductor-netresponse_1.70.0_src_all.tar.gz']" ;
    schema1:identifier biotools:netresponse ;
    schema1:license "GPL (>=2)" ;
    schema1:name "bioconductor-netresponse" ;
    schema1:softwareVersion "1.70.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/netresponse.html" ;
    spdx:builtFrom biotools:netresponse .

