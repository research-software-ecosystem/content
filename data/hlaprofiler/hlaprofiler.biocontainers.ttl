@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:hlaprofiler a schema1:SoftwareApplication ;
    schema1:description "HLAProfiler uses k-mer profiles to predict HLA types from paired-end RNA-seq data." ;
    schema1:keywords "RNA-Seq" ;
    schema1:license "Custom non-commercial license" ;
    schema1:name "hlaprofiler" ;
    schema1:url "https://github.com/ExpressionAnalysis/HLAProfiler" .

