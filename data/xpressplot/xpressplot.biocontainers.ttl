@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:xpressplot a schema1:SoftwareApplication ;
    schema1:description "A toolkit for navigating and analyzing gene expression datasets." ;
    schema1:keywords "Gene Expression",
        "Genomics",
        "RNA-Seq" ;
    schema1:license "GNU General Public License v3.0" ;
    schema1:name "xpressplot" ;
    schema1:url "https://github.com/XPRESSyourself/XPRESSplot" .

