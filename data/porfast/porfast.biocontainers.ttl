@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:porfast a schema1:SoftwareApplication ;
    schema1:description "Extract ORFs from paired end Illumina reads (FASTQ)." ;
    schema1:license "MIT" ;
    schema1:name "porfast" ;
    schema1:url "https://github.com/telatin/porfast" .

