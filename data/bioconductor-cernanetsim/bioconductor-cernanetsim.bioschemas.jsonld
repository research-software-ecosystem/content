  "@graph": [
    {
      "@id": "https://bio.tools/bioconductor-cernanetsim",
      "@type": "sc:SoftwareApplication",
      "dcterms:conformsTo": "https://bioschemas.org/profiles/ComputationalTool/0.6-DRAFT",
      "sc:additionalType": [
        "Command-line tool",
        "Library"
      ],
      "sc:author": [
        "Alper Yilmaz",
        "Selcen Ari Yuka"
      ],
      "sc:citation": {
        "@id": "https://doi.org/10.7717/peerj.11121"
      },
      "sc:description": "This package simulates regulations of ceRNA (Competing Endogenous) expression levels after a expression level change in one or more miRNA/mRNAs. The methodolgy adopted by the package has potential to incorparate any ceRNA (circRNA, lincRNA, etc.) into miRNA:target interaction network.  The package basically distributes miRNA expression over available ceRNAs where each ceRNA attracks miRNAs proportional to its amount. But, the package can utilize multiple parameters that modify miRNA effect on its target (seed type, binding energy, binding location, etc.).  The functions handle the given dataset as graph object and the processes progress via edge and node variables.",
      "sc:license": "GPL-3.0-or-later",
      "sc:name": "ceRNAnetsim",
      "sc:operatingSystem": [
        "Windows",
        "Mac",
        "Linux"
      ],
      "sc:softwareHelp": {
        "@id": "https://bioconductor.org/packages/ceRNAnetsim"
      },
      "sc:softwareVersion": "1.22.0",
      "sc:url": "https://bioconductor.org/packages/ceRNAnetsim"
    },
    {
      "@id": "https://doi.org/10.7717/peerj.11121",
      "@type": "sc:CreativeWork"
    }
  ]
