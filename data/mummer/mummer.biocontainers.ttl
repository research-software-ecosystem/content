        "Polymorphism, Single Nucleotide",
        "Programming Languages",
        "Protein Sequences",
        "Sequence Alignment",
        "Sequence Analysis, DNA",
        "Sequence Analysis, Protein",
        "Sequencing" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "mummer" ;
    schema1:url "http://mummer.sourceforge.net/" .

