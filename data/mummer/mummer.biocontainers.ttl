@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:mummer a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/27.11.2369",
        "doi:10.1371/journal.pcbi.1005944" ;
    schema1:description "Mummer is a modular system for the rapid whole genome alignment of finished or draft sequence. basically it is a ultra-fast alignment of large-scale dna and protein sequences" ;
