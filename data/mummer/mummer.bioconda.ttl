@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:mummer a schema1:SoftwareApplication ;
    schema1:description "MUMmer is a system for rapidly aligning entire genomes" ;
    schema1:downloadUrl "https://downloads.sourceforge.net/project/mummer/mummer/3.23/MUMmer3.23.tar.gz" ;
    schema1:identifier biotools:mummer ;
    schema1:license "The Artistic License" ;
    schema1:name "mummer" ;
    schema1:softwareVersion "3.23" ;
    schema1:url "http://mummer.sourceforge.net/" ;
    spdx:builtFrom biotools:mummer .

