@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:scipy a schema1:SoftwareApplication ;
    schema1:description "Scientific Library for Python" ;
    schema1:license "BSD-3-Clause" ;
    schema1:name "scipy" ;
    schema1:url "https://github.com/scipy/scipy" .

