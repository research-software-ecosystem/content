@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:perl-cpan-shell a schema1:SoftwareApplication ;
    schema1:description "CPAN - query, download and build perl modules from CPAN sites" ;
    schema1:license "perl_5" ;
    schema1:name "perl-cpan-shell" ;
    schema1:url "https://perldoc.perl.org/5.8.2/CPAN" .

