@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:discovar a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/ng.3121" ;
    schema1:description "Suitable for variant calling with reference and de novo assembly of small genomes." ;
    schema1:downloadUrl "ftp://ftp.broadinstitute.org/pub/crd/Discovar/latest_source_code/discovar-52488.tar.gz" ;
    schema1:identifier biotools:discovar ;
    schema1:license "MIT" ;
    schema1:name "discovar" ;
    schema1:softwareVersion "52488" ;
    schema1:url "https://www.broadinstitute.org/software/discovar" ;
    spdx:builtFrom biotools:discovar .

