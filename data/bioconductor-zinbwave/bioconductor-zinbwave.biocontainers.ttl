@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-zinbwave a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/s41467-017-02554-5" ;
    schema1:description "Implements a general and flexible zero-inflated negative binomial model that can be used to provide a low-dimensional representations of single-cell rna-seq data. the model accounts for zero inflation (dropouts), over-dispersion, and the count nature of the data. the model also accounts for the difference in library sizes and optionally for batch effects and/or other covariates, avoiding the need for pre-normalize the data." ;
    schema1:identifier biotools:zinbwave ;
    schema1:keywords "Animals",
        "Cell Line",
        "Computational Biology",
        "Gene Expression Profiling",
        "Gene Expression Regulation",
        "Gene expression",
        "High-Throughput Nucleotide Sequencing",
        "Humans",
        "Male",
        "Mice",
        "Neurons",
        "Principal Component Analysis",
        "RNA",
        "RNA-Seq",
        "RNA-seq",
        "Sequencing",
        "Single-Cell Analysis",
        "Transcriptomics",
        "Visual Cortex" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-zinbwave" ;
    schema1:url "http://bioconductor.org/packages/release/bioc/html/zinbwave.html" .

