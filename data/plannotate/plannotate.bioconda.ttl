@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:plannotate a schema1:SoftwareApplication ;
    schema1:author "mmcguffi",
        "rpetit3" ;
    schema1:description "Webserver and command line tool for annotating engineered plasmids." ;
    schema1:downloadUrl "https://github.com/mmcguffi/plannotate/archive/refs/tags/v1.2.4.tar.gz",
        "https://github.com/mmcguffi/plannotate/releases/download/v1.2.0/BLAST_dbs.tar.gz" ;
    schema1:identifier biotools:plannotate ;
    schema1:license "GPL-3.0-or-later" ;
    schema1:maintainer "mmcguffi",
        "rpetit3" ;
    schema1:name "plannotate" ;
    schema1:softwareHelp "https://github.com/mmcguffi/pLannotate/blob/v1.2.4/README.md" ;
    schema1:softwareVersion "1.2.4" ;
    schema1:url "https://github.com/mmcguffi/pLannotate" ;
    spdx:builtFrom biotools:plannotate .

