@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bottle a schema1:SoftwareApplication ;
    schema1:description "Fast and simple wsgi-framework for small web-applications." ;
    schema1:license "MIT" ;
    schema1:name "bottle" ;
    schema1:url "https://github.com/bottlepy/bottle" .

