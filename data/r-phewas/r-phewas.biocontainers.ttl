@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-phewas a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btu197" ;
    schema1:description "Phenome Wide Association Studies (PheWAS) - Functions to perform Phenome Wide Association Studies (PheWAS). These functions include the conversion of ICD9 codes to PheWAS codes (v1.2), statistical analysis, and plotting." ;
    schema1:keywords "Data Interpretation, Statistical",
        "Genetic Association Studies",
        "Genetic Variation",
        "Humans",
        "Multiple Sclerosis",
        "Phenotype" ;
    schema1:license "GPL-3.0" ;
    schema1:name "r-phewas" ;
    schema1:url "https://github.com/PheWAS/PheWAS" .

