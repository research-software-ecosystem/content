  "@graph": [
    {
      "@id": "https://bio.tools/bioconductor-alpsnmr",
      "@type": "sc:SoftwareApplication",
      "dcterms:conformsTo": "https://bioschemas.org/profiles/ComputationalTool/0.6-DRAFT",
      "sc:additionalType": [
        "Command-line tool",
        "Library"
      ],
      "sc:author": [
        "Santiago Marco Colás",
        "Francisco Madrid Gambin",
        "Sergio Oller Moreno",
        "Luis Fernandez",
        "Ivan Montoliu Roura",
        "Héctor Gracia Cabrera"
      ],
      "sc:citation": {
        "@id": "https://doi.org/10.1093/bioinformatics/btaa022"
      },
      "sc:contributor": [
        "Laura López Sánchez",
        "Miller Jack"
      ],
      "sc:description": "Reads Bruker NMR data directories both zipped and unzipped. It provides automated and efficient signal processing for untargeted NMR metabolomics. It is able to interpolate the samples, detect outliers, exclude regions, normalize, detect peaks, align the spectra, integrate peaks, manage metadata and visualize the spectra. After spectra proccessing, it can apply multivariate analysis on extracted data. Efficient plotting with 1-D data is also available. Basic reading of 1D ACD/Labs exported JDX samples is also available.",
      "sc:license": "MIT",
      "sc:name": "AlpsNMR",
      "sc:operatingSystem": [
        "Linux",
        "Windows",
        "Mac"
      ],
      "sc:softwareHelp": {
        "@id": "https://bioconductor.org/packages/AlpsNMR"
      },
      "sc:softwareVersion": "4.12.0",
      "sc:url": "https://bioconductor.org/packages/AlpsNMR"
    },
    {
      "@id": "https://doi.org/10.1093/bioinformatics/btaa022",
      "@type": "sc:CreativeWork"
    }
