@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:pisces a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/gki402" ;
    schema1:description "Somatic and germline variant caller for amplicon data. recommended caller for tumor-only workflows." ;
    schema1:identifier biotools:pisces ;
    schema1:keywords "Databases, Protein",
        "Gene and protein families",
        "Internet",
        "Protein Conformation",
        "Protein folds and structural domains",
        "Proteins",
        "Sequence Alignment",
        "Sequence Analysis, Protein",
        "Sequence analysis",
        "Sequencing" ;
    schema1:license "GNU GENERAL PUBLIC LICENSE Version 3" ;
    schema1:name "pisces" ;
    schema1:url "https://github.com/Illumina/Pisces" .

