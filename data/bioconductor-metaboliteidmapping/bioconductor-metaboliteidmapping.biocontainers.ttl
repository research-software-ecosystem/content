@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-metaboliteidmapping a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18129/b9.bioc.metaboliteidmapping" ;
    schema1:description "The package provides a comprehensive mapping table of nine different Metabolite ID formats and their common name. The data has been collected and merged from four publicly available source, including HMDB, Comptox Dashboard, ChEBI, and the graphite Bioconductor R package." ;
    schema1:license "GPL-3.0" ;
    schema1:name "bioconductor-metaboliteidmapping" ;
    schema1:url "https://bioconductor.org/packages/3.12/data/annotation/html/metaboliteIDmapping.html" .

