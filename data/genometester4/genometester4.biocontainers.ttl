@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:genometester4 a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/1471-2105-7-172",
        "doi:10.1186/s13742-015-0097-y" ;
    schema1:description "A toolkit for performing set operations - union, intersection and complement - on k-mer lists." ;
    schema1:identifier biotools:genometester ;
    schema1:keywords "Base Sequence",
        "Binding Sites",
        "DNA Primers",
        "Genome, Human",
        "Humans",
        "Molecular Sequence Data",
        "Polymerase Chain Reaction",
        "Sequence analysis" ;
    schema1:license "GPL-3.0" ;
    schema1:name "genometester4" ;
    schema1:url "https://github.com/bioinfo-ut/GenomeTester4" .

