@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:hdf5 a schema1:SoftwareApplication ;
    schema1:description "HDF5 is a data model, library, and file format for storing and managing data" ;
    schema1:license "BSD-3" ;
    schema1:name "hdf5" ;
    schema1:url "https://github.com/h5py/h5py" .

