  "@graph": [
    {
      "@id": "https://bio.tools/bioconductor-mai",
      "@type": "sc:SoftwareApplication",
      "dcterms:conformsTo": "https://bioschemas.org/profiles/ComputationalTool/0.6-DRAFT",
      "sc:additionalType": [
        "Command-line tool",
        "Library"
      ],
      "sc:author": [
        "Debmalya Nandy",
        "Jonathan Dekermanjian",
        "Elin Shaddox",
        "Katerina Kechris",
        "Debashis Ghosh"
      ],
      "sc:citation": {
        "@id": "https://doi.org/10.18129/B9.bioc.MAI"
      },
      "sc:description": "A two-step approach to imputing missing data in metabolomics. Step 1 uses a random forest classifier to classify missing values as either Missing Completely at Random/Missing At Random (MCAR/MAR) or Missing Not At Random (MNAR). MCAR/MAR are combined because it is often difficult to distinguish these two missing types in metabolomics data. Step 2 imputes the missing values based on the classified missing mechanisms, using the appropriate imputation algorithms. Imputation algorithms tested and available for MCAR/MAR include Bayesian Principal Component Analysis (BPCA), Multiple Imputation No-Skip K-Nearest Neighbors (Multi_nsKNN), and Random Forest. Imputation algorithms tested and available for MNAR include nsKNN and a single imputation approach for imputation of metabolites where left-censoring is present.",
      "sc:license": "GPL-3.0-only",
      "sc:name": "MAI",
      "sc:operatingSystem": [
        "Windows",
        "Mac",
        "Linux"
      ],
      "sc:softwareHelp": {
        "@id": "https://bioconductor.org/packages/MAI"
      },
      "sc:softwareVersion": "1.16.0",
      "sc:url": "https://bioconductor.org/packages/MAI"
    },
    {
      "@id": "https://doi.org/10.18129/B9.bioc.MAI",
      "@type": "sc:CreativeWork"
    }
  ]
