@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:canvas a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btw163" ;
    schema1:description "Copy number variant (cnv) calling from dna sequencing data" ;
    schema1:keywords "DNA Copy Number Variations",
        "Exome",
        "Humans",
        "Neoplasms",
        "Whole genome sequencing" ;
    schema1:license "Not available" ;
    schema1:name "canvas" ;
    schema1:url "https://github.com/Illumina/canvas" .

