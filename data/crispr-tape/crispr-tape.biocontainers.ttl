@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:CRISPR-TAPE a schema1:SoftwareApplication ;
    schema1:citation "doi:10.15252/msb.20209475" ;
    schema1:description "Existing CRIPSR gRNA design tools target protein-coding regions within genomic loci and non-specifically target the entire input region of DNA. Current tools fail to consider proteomic-based applications, so CRISPR-TAPE has been developed to reduce the substantial time burden associated with manual curation of gRNA libraries and empower the proteomics community." ;
    schema1:keywords "Proteomics" ;
    schema1:license "Not available" ;
    schema1:name "CRISPR-TAPE" ;
    schema1:url "https://github.com/LaboratoryChild/CRISPR-TAPE" .

