@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:estscan a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/29.1.148",
        "doi:10.1093/nar/gkh479",
        "doi:10.1093/nar/gkm352",
        "doi:10.1186/1751-0473-2-2" ;
    schema1:description "Estscan can detect coding regions (cds) in dna sequences, even if they are of low quality.  it  also detects/corrects sequencing errors that lead to frameshifts.  estscan is not a gene prediction program , nor is it an open reading frame detector.  in fact, its strength lies in the fact that it does not require an open reading frame to detect a coding region.  the program may miss a few translated amino acids at termini, but detects coding regions with high selectivity and sensitivity." ;
    schema1:identifier biotools:estscan ;
    schema1:keywords "Genomics",
        "Protein Sequences",
        "Transcriptomics" ;
    schema1:license "ESTScan" ;
    schema1:name "estscan" ;
    schema1:url "http://myhits.isb-sib.ch/cgi-bin/estscan" .

