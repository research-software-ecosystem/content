@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:riboplot a schema1:SoftwareApplication ;
    schema1:description "Plot read counts of riboseq data from bam format alignment files" ;
    schema1:keywords "RNA-Seq",
        "Transcriptome" ;
    schema1:license "BSD 3-Clause \"New\" or \"Revised\" License" ;
    schema1:name "riboplot" ;
    schema1:url "https://github.com/vimalkvn/riboplot" .

