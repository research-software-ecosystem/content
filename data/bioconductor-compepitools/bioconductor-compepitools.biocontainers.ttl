@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-compepitools a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s12859-015-0742-6" ;
    schema1:description "Tools for computational epigenomics" ;
    schema1:identifier biotools:compepitools ;
    schema1:keywords "CpG Islands",
        "DNA",
        "DNA Methylation",
        "Epigenomics",
        "Genomics",
        "High-Throughput Nucleotide Sequencing",
        "Histone Code",
        "Internet",
        "RNA",
        "Sequence Analysis, DNA",
        "Transcription Factors",
        "User-Computer Interface" ;
    schema1:license "GPL" ;
    schema1:name "bioconductor-compepitools" ;
    schema1:url "http://bioconductor.org/packages/3.5/bioc/html/compEpiTools.html" .

