@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-compepitools a schema1:SoftwareApplication ;
    schema1:description "Tools for computational epigenomics" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/compEpiTools_1.44.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/compEpiTools/compEpiTools_1.44.0.tar.gz', 'https://bioarchive.galaxyproject.org/compEpiTools_1.44.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-compepitools/bioconductor-compepitools_1.44.0_src_all.tar.gz']" ;
    schema1:identifier biotools:compepitools ;
    schema1:license "GPL" ;
    schema1:name "bioconductor-compepitools" ;
    schema1:softwareVersion "1.44.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/compEpiTools.html" ;
    spdx:builtFrom biotools:compepitools .

