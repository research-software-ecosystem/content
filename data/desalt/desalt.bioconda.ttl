@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:desalt a schema1:SoftwareApplication ;
    schema1:description "De Bruijn graph-based Spliced Aligner for Long Transcriptome reads." ;
    schema1:downloadUrl "https://github.com/ydLiu-HIT/deSALT/archive/v1.5.6.tar.gz" ;
    schema1:identifier biotools:deSALT ;
    schema1:license "MIT" ;
    schema1:name "desalt" ;
    schema1:softwareHelp "https://github.com/ydLiu-HIT/deSALT/blob/v1.5.6/README.md" ;
    schema1:softwareVersion "1.5.6" ;
    schema1:url "https://github.com/ydLiu-HIT/deSALT" ;
    spdx:builtFrom biotools:deSALT .

