@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:plascope a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1099/mgen.0.000211" ;
    schema1:description "PlaScope is a targeted approach to assess the plasmidome of bacteria." ;
    schema1:keywords "Chromosomes, Bacterial",
        "Drug Resistance, Bacterial",
        "Escherichia coli",
        "Genome, Bacterial",
        "Genomics",
        "Klebsiella pneumoniae",
        "Operon",
        "Plasmids",
        "Virulence Factors",
        "Whole Genome Sequencing",
        "Workflow" ;
    schema1:license "GPL (>=3)" ;
    schema1:name "plascope" ;
    schema1:url "https://github.com/labgem/PlaScope" .

