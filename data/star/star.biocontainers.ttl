@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:star a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.4106",
        "doi:10.1093/bioinformatics/bts635",
        "doi:10.1093/bioinformatics/btu146" ;
    schema1:description "Ultrafast universal rna-seq aligner" ;
    schema1:identifier biotools:star ;
    schema1:keywords "High-Throughput Nucleotide Sequencing",
        "RNA",
        "RNA-Seq",
        "RNA-seq",
        "Sequence Analysis, RNA",
        "Transcriptomics" ;
    schema1:license "GPL-3.0" ;
    schema1:name "star" ;
    schema1:url "https://github.com/alexdobin/STAR" .

