@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:star a schema1:SoftwareApplication ;
    schema1:author "mjsteinbaugh" ;
    schema1:description "An RNA-seq read aligner." ;
    schema1:downloadUrl "https://github.com/alexdobin/STAR/archive/2.7.11b.tar.gz" ;
    schema1:identifier biotools:star ;
    schema1:license "GPL-3.0-or-later" ;
    schema1:maintainer "mjsteinbaugh" ;
    schema1:name "star" ;
    schema1:softwareHelp "https://github.com/alexdobin/STAR/blob/2.7.11b/doc/STARmanual.pdf" ;
    schema1:softwareVersion "2.7.11b" ;
    schema1:url "https://github.com/alexdobin/STAR" ;
    spdx:builtFrom biotools:star .

