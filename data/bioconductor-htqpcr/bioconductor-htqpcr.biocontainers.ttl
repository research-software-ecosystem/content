@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-htqpcr a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btp578" ;
    schema1:description "Analysis of ct values from high throughput quantitative real-time pcr (qpcr) assays across multiple conditions or replicates. the input data can be from spatially-defined formats such abi taqman low density arrays or openarray; lightcycler from roche applied science, etc. it handles data loading, quality assessment, normalization, visualization and parametric or non-parametric testing for statistical significance in ct values between features." ;
    schema1:identifier biotools:htqpcr ;
    schema1:keywords "Computational Biology",
        "Databases, Genetic",
        "Gene Expression Profiling",
        "PCR experiment",
        "Polymerase Chain Reaction",
        "Sequence analysis" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-htqpcr" ;
    schema1:url "http://bioconductor.org/packages/release/bioc/html/HTqPCR.html" .

