@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-htqpcr a schema1:SoftwareApplication ;
    schema1:description "Automated analysis of high-throughput qPCR data" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.18/bioc/src/contrib/HTqPCR_1.56.0.tar.gz', 'https://bioconductor.org/packages/3.18/bioc/src/contrib/Archive/HTqPCR/HTqPCR_1.56.0.tar.gz', 'https://bioarchive.galaxyproject.org/HTqPCR_1.56.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-htqpcr/bioconductor-htqpcr_1.56.0_src_all.tar.gz']" ;
    schema1:identifier biotools:htqpcr ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-htqpcr" ;
    schema1:softwareVersion "1.56.0" ;
    schema1:url "https://bioconductor.org/packages/3.18/bioc/html/HTqPCR.html" ;
    spdx:builtFrom biotools:htqpcr .

