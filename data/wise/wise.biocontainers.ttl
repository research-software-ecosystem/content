@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:wise a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1101/gr.10.4.547",
        "doi:10.1101/gr.1865504" ;
    schema1:description "Comparison of biopolymers, like dna and protein sequences" ;
    schema1:identifier biotools:wise ;
    schema1:keywords "3' Flanking Region",
        "5' Flanking Region",
        "Computational Biology",
        "DNA",
        "DNA, Complementary",
        "HMMs",
        "Models, Theoretical",
        "Predictive Value of Tests",
        "Research Design" ;
    schema1:license "GRL" ;
    schema1:name "wise" ;
    schema1:url "http://www.ebi.ac.uk/~birney/wise2/" .

