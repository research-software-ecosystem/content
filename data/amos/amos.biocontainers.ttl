@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:amos a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bib/5.3.237" ;
    schema1:description "A modular, open-source whole genome assembler." ;
    schema1:identifier biotools:amos ;
    schema1:keywords "Chromosome Mapping",
        "Consensus Sequence",
        "DNA Mutational Analysis",
        "Genetic Variation",
        "Genome, Bacterial",
        "Genomics",
        "Metagenome",
        "Sequence Alignment",
        "Sequence Analysis, DNA",
        "Sequence Homology, Nucleic Acid",
        "Sequence assembly",
        "Streptococcus agalactiae" ;
    schema1:license "Artistic License" ;
    schema1:name "amos" ;
    schema1:url "http://amos.sourceforge.net/wiki/index.php/AMOS" .

