@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:amos a schema1:SoftwareApplication ;
    schema1:description "A Modular, Open-Source whole genome assembler" ;
    schema1:downloadUrl "https://sourceforge.net/projects/amos/files/amos/3.1.0/amos-3.1.0.tar.gz" ;
    schema1:identifier biotools:amos ;
    schema1:license "Artistic License" ;
    schema1:name "amos" ;
    schema1:softwareVersion "3.1.0" ;
    schema1:url "http://amos.sourceforge.net/wiki/index.php/AMOS" ;
    spdx:builtFrom biotools:amos .

