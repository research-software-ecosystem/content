@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:kggseq a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1002/humu.22766" ;
    schema1:description "KGGSeq is a software platform constituted of Bioinformatics and statistical genetics functions making use of valuable biologic resources and knowledge for sequencing-based genetic mapping of variants/genes responsible for human diseases/traits." ;
    schema1:identifier biotools:kggseq ;
    schema1:keywords "Computational Biology",
        "Databases, Genetic",
        "Exome",
        "Genetic Association Studies",
        "Genetic Diseases, Inborn",
        "Genetic variation",
        "Genetics",
        "Genomics",
        "High-Throughput Nucleotide Sequencing",
        "Humans",
        "Internet",
        "Molecular Sequence Annotation",
        "Pathology",
        "Web Browser" ;
    schema1:license "Apache-2.0" ;
    schema1:name "kggseq" ;
    schema1:url "http://grass.cgs.hku.hk/limx/kggseq/" .

