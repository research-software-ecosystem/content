@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-a4reporting a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Automated Affymetrix Array Analysis Reporting Package" ;
    schema1:identifier biotools:a4reporting ;
    schema1:keywords "Computational Biology",
        "Function analysis",
        "Gene Expression Profiling",
        "Genomics",
        "High-Throughput Screening Assays",
        "Microarray experiment",
        "Programming Languages",
        "User-Computer Interface" ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-a4reporting" ;
    schema1:url "http://bioconductor.org/packages/3.6/bioc/html/a4Reporting.html" .

