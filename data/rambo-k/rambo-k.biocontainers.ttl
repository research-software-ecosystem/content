@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:rambo-k a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1371/journal.pone.0137896" ;
    schema1:description "Reference-based tool for rapid and sensitive extraction of one organisms reads from a mixed dataset." ;
    schema1:identifier biotools:rambo-k ;
    schema1:keywords "DNA",
        "Datasets as Topic",
        "Genome",
        "Genomics",
        "High-Throughput Nucleotide Sequencing",
        "Model organisms",
        "Programming Languages",
        "Sequence Analysis, DNA",
        "Sequencing" ;
    schema1:license "GPL-3.0" ;
    schema1:name "rambo-k" ;
    schema1:url "https://gitlab.com/SimonHTausch/RAMBO-K" .

