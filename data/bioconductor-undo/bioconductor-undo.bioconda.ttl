@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-undo a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btu607" ;
    schema1:description "Unsupervised Deconvolution of Tumor-Stromal Mixed Expressions" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/UNDO_1.48.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/UNDO/UNDO_1.48.0.tar.gz', 'https://bioarchive.galaxyproject.org/UNDO_1.48.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-undo/bioconductor-undo_1.48.0_src_all.tar.gz']" ;
    schema1:identifier biotools:undo ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-undo" ;
    schema1:softwareVersion "1.48.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/UNDO.html" ;
    spdx:builtFrom biotools:undo .

