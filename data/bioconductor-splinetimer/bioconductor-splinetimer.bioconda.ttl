@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-splinetimer a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1371/journal.pone.0160791" ;
    schema1:description "Time-course differential gene expression data analysis using spline regression models followed by gene association network reconstruction" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/splineTimeR_1.34.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/splineTimeR/splineTimeR_1.34.0.tar.gz', 'https://bioarchive.galaxyproject.org/splineTimeR_1.34.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-splinetimer/bioconductor-splinetimer_1.34.0_src_all.tar.gz']" ;
    schema1:identifier biotools:splinetimer ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-splinetimer" ;
    schema1:softwareVersion "1.34.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/splineTimeR.html" ;
    spdx:builtFrom biotools:splinetimer .

