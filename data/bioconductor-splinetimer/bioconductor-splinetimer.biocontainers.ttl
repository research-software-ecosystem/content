@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-splinetimer a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1371/journal.pone.0160791" ;
    schema1:description "Time-course differential gene expression data analysis using spline regression models followed by gene association network reconstruction" ;
    schema1:identifier biotools:splinetimer ;
    schema1:keywords "Gene Expression",
        "Gene Expression Profiling",
        "Gene Regulatory Networks",
        "Gene expression",
        "Kinetics",
        "Models, Genetic",
        "Molecular interactions, pathways and networks",
        "Radiation Tolerance",
        "Regression Analysis" ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-splinetimer" ;
    schema1:url "http://bioconductor.org/packages/3.6/bioc/html/splineTimeR.html" .

