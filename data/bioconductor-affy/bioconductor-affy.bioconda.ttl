@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-affy a schema1:SoftwareApplication ;
    schema1:description "Methods for Affymetrix Oligonucleotide Arrays" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/affy_1.88.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/affy/affy_1.88.0.tar.gz', 'https://bioarchive.galaxyproject.org/affy_1.88.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-affy/bioconductor-affy_1.88.0_src_all.tar.gz']" ;
    schema1:identifier biotools:affy ;
    schema1:license "LGPL (>= 2.0)" ;
    schema1:name "bioconductor-affy" ;
    schema1:softwareVersion "1.88.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/affy.html" ;
    spdx:builtFrom biotools:affy .

