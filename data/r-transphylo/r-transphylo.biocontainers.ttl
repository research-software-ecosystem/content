@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-transphylo a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/molbev/msu121",
        "doi:10.1093/molbev/msw275" ;
    schema1:description "Reconstruction of transmission trees using genomic data" ;
    schema1:identifier biotools:TransPhylo ;
    schema1:keywords "Communicable Diseases",
        "Computational Biology",
        "Computer Simulation",
        "Disease Outbreaks",
        "Disease Transmission, Infectious",
        "Genomics",
        "Humans",
        "Infectious disease",
        "Markov Chains",
        "Models, Genetic",
        "Monte Carlo Method",
        "Pathology",
        "Phylogenetics",
        "Phylogeny",
        "Probability" ;
    schema1:license "GPL-2.0" ;
    schema1:name "r-transphylo" ;
    schema1:url "https://github.com/xavierdidelot/TransPhyloMatlab" .

