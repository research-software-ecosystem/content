@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-cexor a schema1:SoftwareApplication ;
    schema1:citation "doi:10.14806/ej.21.0.837" ;
    schema1:description "An R package to uncover high-resolution protein-DNA interactions in ChIP-exo replicates" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/CexoR_1.44.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/CexoR/CexoR_1.44.0.tar.gz', 'https://bioarchive.galaxyproject.org/CexoR_1.44.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-cexor/bioconductor-cexor_1.44.0_src_all.tar.gz']" ;
    schema1:identifier biotools:cexor ;
    schema1:license "Artistic-2.0 | GPL-2 + file LICENSE" ;
    schema1:name "bioconductor-cexor" ;
    schema1:softwareVersion "1.44.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/CexoR.html" ;
    spdx:builtFrom biotools:cexor .

