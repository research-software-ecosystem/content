@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-vbmp a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btm535" ;
    schema1:description "Variational Bayesian Multinomial Probit Regression" ;
    schema1:identifier biotools:vbmp ;
    schema1:keywords "Artificial Intelligence",
        "Bayes Theorem",
        "Biomarkers, Tumor",
        "Breast Neoplasms",
        "Data mining",
        "Gene Expression Profiling",
        "Humans",
        "Neoplasm Proteins",
        "Oligonucleotide Array Sequence Analysis",
        "Pattern Recognition, Automated",
        "Programming Languages",
        "Regression Analysis",
        "Statistics and probability" ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-vbmp" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/vbmp.html" .

