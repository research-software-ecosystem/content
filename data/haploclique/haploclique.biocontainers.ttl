@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:haploclique a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1371/journal.pcbi.1003515" ;
    schema1:description "Viral quasispecies assembly via maximal clique finding. A method to reconstruct viral haplotypes and detect large insertions and deletions from NGS data." ;
    schema1:identifier biotools:haploclique ;
    schema1:keywords "CD8-Positive T-Lymphocytes",
        "Computational Biology",
        "Gene Deletion",
        "Genetic Variation",
        "Genetics",
        "Genome, Viral",
        "Haplotypes",
        "Hepacivirus",
        "High-Throughput Nucleotide Sequencing",
        "Humans",
        "Models, Statistical",
        "Mutation",
        "Probability",
        "Sequence Alignment",
        "Sequence Analysis, DNA",
        "Sequencing",
        "Virology",
        "Viruses" ;
    schema1:license "GPL-3.0+" ;
    schema1:name "haploclique" ;
    schema1:url "https://github.com/cbg-ethz/haploclique" .

