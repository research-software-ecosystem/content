@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-cghbase a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1016/j.ejmg.2005.10.046" ;
    schema1:description "CGHbase: Base functions and classes for arrayCGH data analysis." ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/CGHbase_1.66.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/CGHbase/CGHbase_1.66.0.tar.gz', 'https://bioarchive.galaxyproject.org/CGHbase_1.66.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-cghbase/bioconductor-cghbase_1.66.0_src_all.tar.gz']" ;
    schema1:identifier biotools:cghbase ;
    schema1:license "GPL" ;
    schema1:name "bioconductor-cghbase" ;
    schema1:softwareVersion "1.66.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/CGHbase.html" ;
    spdx:builtFrom biotools:cghbase .

