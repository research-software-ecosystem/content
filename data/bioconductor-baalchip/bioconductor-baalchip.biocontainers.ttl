@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-baalchip a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s13059-017-1165-7" ;
    schema1:description "This package offers functions to process multiple chip-seq bam files and detect allele-specific events. computes allele counts at individual variants (snps/snvs), implements extensive qc steps to remove problematic variants, and utilizes a bayesian framework to identify statistically significant allele-specific events. it is able to account for copy number differences between the two alleles, a known phenotypical feature of cancer samples." ;
    schema1:identifier biotools:baalchip ;
    schema1:keywords "Alleles",
        "Allelic Imbalance",
        "Bayes Theorem",
        "Binding Sites",
        "Cell Line, Tumor",
        "ChIP-seq",
        "Chromatin Immunoprecipitation",
        "Computational Biology",
        "DNA Copy Number Variations",
        "Data quality management",
        "Gene Amplification",
        "Genotype",
        "High-Throughput Nucleotide Sequencing",
        "Humans",
        "Neoplasms",
        "Quality Control",
        "Reproducibility of Results",
        "Sequencing",
        "Transcription Factors",
        "Workflow" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-baalchip" ;
    schema1:url "http://bioconductor.org/packages/release/bioc/html/BaalChIP.html" .

