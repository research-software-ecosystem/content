@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-baalchip a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s13059-017-1165-7" ;
    schema1:description "BaalChIP: Bayesian analysis of allele-specific transcription factor binding in cancer genomes" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/BaalChIP_1.32.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/BaalChIP/BaalChIP_1.32.0.tar.gz', 'https://bioarchive.galaxyproject.org/BaalChIP_1.32.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-baalchip/bioconductor-baalchip_1.32.0_src_all.tar.gz']" ;
    schema1:identifier biotools:baalchip ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-baalchip" ;
    schema1:softwareVersion "1.32.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/BaalChIP.html" ;
    spdx:builtFrom biotools:baalchip .

