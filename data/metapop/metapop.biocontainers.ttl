@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:metapop a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1007/s10592-008-9718-7",
        "doi:10.1101/2020.11.01.363960" ;
    schema1:description "A pipeline for the macro- and micro-diversity analyses and visualization of metagenomic-derived populations" ;
    schema1:license "Not available" ;
    schema1:name "metapop" ;
    schema1:url "https://https://github.com/metaGmetapop/metapop" .

