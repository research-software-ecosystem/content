@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-rgraphviz a schema1:SoftwareApplication ;
    schema1:description "Provides plotting capabilities for R graph objects" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/Rgraphviz_2.50.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/Rgraphviz/Rgraphviz_2.50.0.tar.gz', 'https://bioarchive.galaxyproject.org/Rgraphviz_2.50.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-rgraphviz/bioconductor-rgraphviz_2.50.0_src_all.tar.gz']" ;
    schema1:identifier biotools:rgraphviz ;
    schema1:license "EPL" ;
    schema1:name "bioconductor-rgraphviz" ;
    schema1:softwareVersion "2.50.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/Rgraphviz.html" ;
    spdx:builtFrom biotools:rgraphviz .

