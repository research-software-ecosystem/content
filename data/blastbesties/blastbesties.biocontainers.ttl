@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:blastbesties a schema1:SoftwareApplication ;
    schema1:description "Rapid discovery of reciprocal best blast pairs from blast output files." ;
    schema1:license "MIT" ;
    schema1:name "blastbesties" ;
    schema1:url "https://github.com/Adamtaranto/blast-besties" .

