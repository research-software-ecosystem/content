@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:pdfkit a schema1:SoftwareApplication ;
    schema1:description "Wkhtmltopdf python wrapper to convert html to pdf using the webkit rendering engine and qt" ;
    schema1:license "MIT" ;
    schema1:name "pdfkit" ;
    schema1:url "https://pypi.python.org/pypi/pdfkit" .

