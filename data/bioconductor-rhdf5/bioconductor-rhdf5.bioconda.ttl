@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-rhdf5 a schema1:SoftwareApplication ;
    schema1:description "R Interface to HDF5" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/rhdf5_2.54.1.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/rhdf5/rhdf5_2.54.1.tar.gz', 'https://bioarchive.galaxyproject.org/rhdf5_2.54.1.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-rhdf5/bioconductor-rhdf5_2.54.1_src_all.tar.gz']" ;
    schema1:identifier biotools:rhdf5 ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-rhdf5" ;
    schema1:softwareVersion "2.54.1" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/rhdf5.html" ;
    spdx:builtFrom biotools:rhdf5 .

