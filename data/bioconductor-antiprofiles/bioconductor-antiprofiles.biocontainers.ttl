@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-antiprofiles a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/1471-2105-13-272" ;
    schema1:description "Implementation of gene expression anti-profiles" ;
    schema1:identifier biotools:antiprofiles ;
    schema1:keywords "Area Under Curve",
        "Biomarkers, Tumor",
        "Colonic Neoplasms",
        "Gene Expression",
        "Gene Expression Profiling",
        "Gene expression",
        "Genetic Variation",
        "Genetics",
        "Genomics",
        "Humans",
        "Oligonucleotide Array Sequence Analysis",
        "Prognosis",
        "Transcriptome" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-antiprofiles" ;
    schema1:url "http://bioconductor.org/packages/release/bioc/html/antiProfiles.html" .

