@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-antiprofiles a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/1471-2105-13-272" ;
    schema1:description "Implementation of gene expression anti-profiles" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/antiProfiles_1.50.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/antiProfiles/antiProfiles_1.50.0.tar.gz', 'https://bioarchive.galaxyproject.org/antiProfiles_1.50.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-antiprofiles/bioconductor-antiprofiles_1.50.0_src_all.tar.gz']" ;
    schema1:identifier biotools:antiprofiles ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-antiprofiles" ;
    schema1:softwareVersion "1.50.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/antiProfiles.html" ;
    spdx:builtFrom biotools:antiprofiles .

