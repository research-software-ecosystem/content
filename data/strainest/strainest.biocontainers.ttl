@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:strainest a schema1:SoftwareApplication ;
    schema1:description "Abundance estimation of strains" ;
    schema1:keywords "Clustering",
        "Genomics",
        "Metagenome",
        "Metagenomics" ;
    schema1:license "GPL-3.0" ;
    schema1:name "strainest" ;
    schema1:url "https://github.com/compmetagen/strainest" .

