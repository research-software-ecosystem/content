@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:perl-fastx-abi a schema1:SoftwareApplication ;
    schema1:description "FASTX::Abi - Read Sanger trace file (.ab1 chromatograms) in FASTQ format. For traces called with hetero option, the ambiguities will be split into two sequences to allow usage from NGS tools that usually do not understand IUPAC ambiguities. " ;
    schema1:license "MIT" ;
    schema1:name "perl-fastx-abi" ;
    schema1:url "https://github.com/telatin/FASTX-Abi" .

