        "Models, Genetic",
        "ROC Curve",
        "Sensitivity and Specificity" ;
    schema1:license "GPL-3.0" ;
    schema1:name "bioconductor-rtopper" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/RTopper.html" .

