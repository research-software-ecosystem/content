@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-rtopper a schema1:SoftwareApplication ;
    schema1:description "This package is designed to perform Gene Set Analysis across multiple genomic platforms" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/RTopper_1.56.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/RTopper/RTopper_1.56.0.tar.gz', 'https://bioarchive.galaxyproject.org/RTopper_1.56.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-rtopper/bioconductor-rtopper_1.56.0_src_all.tar.gz']" ;
    schema1:identifier biotools:rtopper ;
    schema1:license "GPL (>= 3) + file LICENSE" ;
    schema1:name "bioconductor-rtopper" ;
    schema1:softwareVersion "1.56.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/RTopper.html" ;
    spdx:builtFrom biotools:rtopper .

