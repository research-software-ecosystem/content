@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-multiclust a schema1:SoftwareApplication ;
    schema1:citation "doi:10.4137/cin.s38000" ;
    schema1:description "multiClust: An R-package for Identifying Biologically Relevant Clusters in Cancer Transcriptome Profiles" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/multiClust_1.40.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/multiClust/multiClust_1.40.0.tar.gz', 'https://bioarchive.galaxyproject.org/multiClust_1.40.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-multiclust/bioconductor-multiclust_1.40.0_src_all.tar.gz']" ;
    schema1:identifier biotools:multiclust ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-multiclust" ;
    schema1:softwareVersion "1.40.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/multiClust.html" ;
    spdx:builtFrom biotools:multiclust .

