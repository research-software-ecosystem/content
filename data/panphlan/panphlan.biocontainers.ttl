@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:panphlan a schema1:SoftwareApplication ;
    schema1:description "Panphlan is a strain-level metagenomic profiling tool for identifying the gene composition and in-vivo transcriptional activity of individual strains in metagenomic samples. panphlan's ability for strain-tracking and functional analysis of unknown pathogens makes it an efficient tool for nculture-free infectious outbreak epidemiology and microbial population nstudies." ;
    schema1:license "MIT" ;
    schema1:name "panphlan" ;
    schema1:url "https://bitbucket.org/CibioCM/panphlan" .

