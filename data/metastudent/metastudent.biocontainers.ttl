@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:metastudent a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/1471-2105-14-S3-S7" ;
    schema1:description "Metastudent predicts gene ontology (go) terms from the molecular function ontology (mfo) and biological process ontology (bpo) for input protein sequences by homology-based inference from already annotated proteins." ;
    schema1:identifier biotools:metastudent ;
    schema1:keywords "Computational biology",
        "Protein Sequences",
        "Proteins",
        "Sequence Homology, Amino Acid" ;
    schema1:license "GPL-2+" ;
    schema1:name "metastudent" ;
    schema1:url "https://github.com/Rostlab/MetaStudent" .

