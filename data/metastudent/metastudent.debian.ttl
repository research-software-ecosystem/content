@prefix debianmed: <https://salsa.debian.org/med-team/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

debianmed:metastudent a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/1471-2105-14-S3-S7" ;
    schema1:description "predictor of Gene Ontology terms from protein sequence" ;
    schema1:identifier "bio.tools:metastudent",
        "omictools:OMICS_20187" ;
    schema1:license "unknown" ;
    schema1:name "metastudent" ;
    schema1:softwareVersion "2.0.1" ;
    schema1:url "https://rostlab.org/owiki/index.php/Metastudent" ;
    spdx:builtFrom "metastudent" .

