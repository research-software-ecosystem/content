@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-sushi a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btu379" ;
    schema1:description "Tools for visualizing genomics data" ;
    schema1:identifier biotools:sushi ;
    schema1:keywords "Computational Biology",
        "Data visualisation",
        "Genetics",
        "Genome-Wide Association Study",
        "Genomics",
        "Internet",
        "Programming Languages" ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-sushi" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/Sushi.html" .

