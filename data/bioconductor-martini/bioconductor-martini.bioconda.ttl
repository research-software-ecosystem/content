@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-martini a schema1:SoftwareApplication ;
    schema1:description "GWAS Incorporating Networks" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/martini_1.26.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/martini/martini_1.26.0.tar.gz', 'https://bioarchive.galaxyproject.org/martini_1.26.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-martini/bioconductor-martini_1.26.0_src_all.tar.gz']" ;
    schema1:identifier biotools:martini ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-martini" ;
    schema1:softwareVersion "1.26.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/martini.html" ;
    spdx:builtFrom biotools:martini .

