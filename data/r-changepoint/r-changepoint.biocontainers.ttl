@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-changepoint a schema1:SoftwareApplication ;
    schema1:description "Implements various mainstream and specialised changepoint methods for finding single and multiple changepoints within data.  Many popular non-parametric and frequentist methods are included.  The cpt.mean(), cpt.var(), cpt.meanvar() functions should be your first point of call." ;
    schema1:license "GPL" ;
    schema1:name "r-changepoint" ;
    schema1:url "None" .

