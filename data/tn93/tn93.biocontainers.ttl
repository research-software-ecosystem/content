@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:tn93 a schema1:SoftwareApplication ;
    schema1:description "This is a simple program meant to compute pairwise distances between aligned nucleotide sequences in sequential FASTA format using the Tamura Nei 93 distance." ;
    schema1:license "MIT" ;
    schema1:name "tn93" ;
    schema1:url "https://github.com/veg/tn93" .

