@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:tn93 a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/molbev/msy016" ;
    schema1:description "This is a simple program meant to compute pairwise distances between aligned nucleotide sequences in sequential FASTA format using the Tamura Nei 93 distance." ;
    schema1:downloadUrl "https://github.com/veg/tn93/archive/v1.0.15.tar.gz" ;
    schema1:identifier biotools:tn93 ;
    schema1:license "MIT" ;
    schema1:name "tn93" ;
    schema1:softwareHelp "https://github.com/veg/tn93/blob/v1.0.15/README.md" ;
    schema1:softwareVersion "1.0.15" ;
    schema1:url "https://github.com/veg/tn93" ;
    spdx:builtFrom biotools:tn93 .

