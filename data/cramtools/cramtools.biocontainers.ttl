@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:cramtools a schema1:SoftwareApplication ;
    schema1:description "A set of java tools and apis for efficient compression of sequence read data" ;
    schema1:identifier biotools:CRAMTools ;
    schema1:keywords "Data architecture, analysis and design" ;
    schema1:license "Apache-2.0" ;
    schema1:name "cramtools" ;
    schema1:url "http://www.ebi.ac.uk/ena/software/cram-toolkit" .

