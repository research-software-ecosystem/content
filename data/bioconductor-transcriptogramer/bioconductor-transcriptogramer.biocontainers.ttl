@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-transcriptogramer a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18129/b9.bioc.transcriptogramer" ;
    schema1:description "Transcriptional analysis based on transcriptograms" ;
    schema1:keywords "Clustering",
        "Gene Expression",
        "Transcriptome" ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-transcriptogramer" ;
    schema1:url "https://bioconductor.org/packages/3.8/bioc/html/transcriptogramer.html" .

