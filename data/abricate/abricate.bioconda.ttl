@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:abricate a schema1:SoftwareApplication ;
    schema1:description "Mass screening of contigs for antibiotic resistance genes" ;
    schema1:downloadUrl "https://github.com/tseemann/abricate/archive/v1.4.0.tar.gz" ;
    schema1:identifier biotools:ABRicate ;
    schema1:license "GPL-2.0-only" ;
    schema1:name "abricate" ;
    schema1:softwareVersion "1.4.0" ;
    schema1:url "https://github.com/tseemann/abricate" ;
    spdx:builtFrom biotools:ABRicate .

