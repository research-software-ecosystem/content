@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-lpe a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btg264" ;
    schema1:description "Methods for analyzing microarray data using Local Pooled Error (LPE) method" ;
    schema1:identifier biotools:lpe ;
    schema1:keywords "Animals",
        "Data Interpretation, Statistical",
        "Gene Expression Profiling",
        "Gene Expression Regulation",
        "Gene expression",
        "Genetic Variation",
        "Humans",
        "Mice",
        "Microarray experiment",
        "Models, Genetic",
        "Models, Statistical",
        "Oligonucleotide Array Sequence Analysis",
        "Sample Size",
        "Statistics and probability",
        "T-Lymphocytes" ;
    schema1:license "LGPL" ;
    schema1:name "bioconductor-lpe" ;
    schema1:url "http://bioconductor.org/packages/3.6/bioc/html/LPE.html" .

