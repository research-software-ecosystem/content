@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-lpe a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btg264" ;
    schema1:description "Methods for analyzing microarray data using Local Pooled Error (LPE) method" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/LPE_1.84.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/LPE/LPE_1.84.0.tar.gz', 'https://bioarchive.galaxyproject.org/LPE_1.84.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-lpe/bioconductor-lpe_1.84.0_src_all.tar.gz']" ;
    schema1:identifier biotools:lpe ;
    schema1:license "LGPL" ;
    schema1:name "bioconductor-lpe" ;
    schema1:softwareVersion "1.84.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/LPE.html" ;
    spdx:builtFrom biotools:lpe .

