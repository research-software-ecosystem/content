@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-methylkit a schema1:SoftwareApplication ;
    schema1:description "DNA methylation analysis from high-throughput bisulfite sequencing results" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/methylKit_1.32.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/methylKit/methylKit_1.32.0.tar.gz', 'https://bioarchive.galaxyproject.org/methylKit_1.32.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-methylkit/bioconductor-methylkit_1.32.0_src_all.tar.gz']" ;
    schema1:identifier biotools:methylkit ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-methylkit" ;
    schema1:softwareVersion "1.32.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/methylKit.html" ;
    spdx:builtFrom biotools:methylkit .

