@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:abyss a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1101/gr.089532.108",
        "doi:10.1101/gr.214346.116" ;
    schema1:description "De novo genome sequence assembler." ;
    schema1:identifier biotools:abyss ;
    schema1:keywords "Contig Mapping",
        "Genome Size",
        "Genomics",
        "Humans",
        "RNA-Seq",
        "Sequence Alignment",
        "Sequence Analysis, DNA",
        "Sequence assembly",
        "Transcriptome" ;
    schema1:license "GPL-3.0+" ;
    schema1:name "abyss" ;
    schema1:url "https://github.com/bcgsc/abyss/" .

