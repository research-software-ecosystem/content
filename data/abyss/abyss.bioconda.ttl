@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:abyss a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1101/gr.089532.108",
        "doi:10.1101/gr.214346.116" ;
    schema1:description "Assembly By Short Sequences - a de novo, parallel, paired-end short read sequence assembler." ;
    schema1:downloadUrl "https://github.com/BirolLab/abyss/releases/download/2.3.10/abyss-2.3.10.tar.gz" ;
    schema1:identifier biotools:abyss ;
    schema1:license "GPL-3.0-only" ;
    schema1:name "abyss" ;
    schema1:softwareHelp "https://github.com/BirolLab/abyss/blob/v2.3.10/README.md" ;
    schema1:softwareVersion "2.3.10" ;
    schema1:url "https://github.com/BirolLab/abyss" ;
    spdx:builtFrom biotools:abyss .

