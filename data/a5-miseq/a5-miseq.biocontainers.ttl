@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:a5-miseq a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btu661" ;
    schema1:description "A5-miseq is a pipeline for assembling dna sequence data generated on the illumina sequencing platform. this readme will take you through the steps necessary for running" ;
    schema1:identifier biotools:a5-miseq ;
    schema1:keywords "Genome, Bacterial",
        "Genomics",
        "Programming Languages",
        "Sequence Analysis, DNA",
        "Sequence assembly" ;
    schema1:license "GPL-3.0" ;
    schema1:name "a5-miseq" ;
    schema1:url "https://sourceforge.net/projects/ngopt/" .

