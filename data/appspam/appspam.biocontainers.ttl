@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:appspam a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btaa657",
        "doi:10.1093/bioinformatics/btw776",
        "doi:10.1101/2020.10.19.344986",
        "doi:10.1371/journal.pone.0031009" ;
    schema1:description "Alignment-free Phylogenetic Placement algorithm based on Spaced-word Matches" ;
    schema1:license "GPL-3" ;
    schema1:name "appspam" ;
    schema1:url "https://github.com/matthiasblanke/App-SpaM/" .

