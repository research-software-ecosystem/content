@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:tqdist a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btu157" ;
    schema1:description "computes the triplet distance between rooted trees in O(n log n) time and the quartet distance between unrooted trees in O(dn log n) time, where d degree of the tree with the smallest degree." ;
    schema1:identifier biotools:tqdist ;
    schema1:keywords "Classification",
        "Phylogeny" ;
    schema1:license "GPL" ;
    schema1:name "tqdist" ;
    schema1:url "http://users-cs.au.dk/cstorm/software/tqdist/" .

