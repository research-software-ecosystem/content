@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-genefu a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btv693" ;
    schema1:description "Computation of Gene Expression-Based Signatures in Breast Cancer" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/genefu_2.42.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/genefu/genefu_2.42.0.tar.gz', 'https://bioarchive.galaxyproject.org/genefu_2.42.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-genefu/bioconductor-genefu_2.42.0_src_all.tar.gz']" ;
    schema1:identifier biotools:genefu ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-genefu" ;
    schema1:softwareVersion "2.42.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/genefu.html" ;
    spdx:builtFrom biotools:genefu .

