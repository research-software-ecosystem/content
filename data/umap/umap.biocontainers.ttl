@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:umap a schema1:SoftwareApplication ;
    schema1:description "Umap and bismap: tools for genome and methylome mappability" ;
    schema1:license "BSD-2" ;
    schema1:name "umap" ;
    schema1:url "https://bitbucket.org/hoffmanlab/umap/" .

