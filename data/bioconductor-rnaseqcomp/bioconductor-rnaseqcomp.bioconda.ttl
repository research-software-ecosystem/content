@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-rnaseqcomp a schema1:SoftwareApplication ;
    schema1:description "Benchmarks for RNA-seq Quantification Pipelines" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/rnaseqcomp_1.40.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/rnaseqcomp/rnaseqcomp_1.40.0.tar.gz', 'https://bioarchive.galaxyproject.org/rnaseqcomp_1.40.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-rnaseqcomp/bioconductor-rnaseqcomp_1.40.0_src_all.tar.gz']" ;
    schema1:identifier biotools:rnaseqcomp ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-rnaseqcomp" ;
    schema1:softwareVersion "1.40.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/rnaseqcomp.html" ;
    spdx:builtFrom biotools:rnaseqcomp .

