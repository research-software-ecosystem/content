@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:corepywrap a schema1:SoftwareApplication ;
    schema1:description "Library that exports c++ mmcif accessors to python" ;
    schema1:license "custom, see /usr/share/doc/corepywrap/copyright" ;
    schema1:name "corepywrap" ;
    schema1:url "http://sw-tools.rcsb.org/apps/CORE-WRAPPER/index.html" .

