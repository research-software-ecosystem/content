@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:htsbox a schema1:SoftwareApplication ;
    schema1:description "HTSbox is a fork of early HTSlib. It is a collection of small experimental tools manipulating HTS-related files." ;
    schema1:keywords "Genomics" ;
    schema1:license "Apache-2.0" ;
    schema1:name "htsbox" ;
    schema1:url "https://github.com/lh3/htsbox" .

