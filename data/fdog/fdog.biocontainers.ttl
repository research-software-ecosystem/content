@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:fdog a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/1471-2148-9-157" ;
    schema1:description "Feature-aware Directed OrtholoG search" ;
    schema1:keywords "Animals",
        "Cluster Analysis",
        "Expressed Sequence Tags",
        "Fungi",
        "Genome, Fungal",
        "Genomics",
        "Humans",
        "Markov Chains",
        "Models, Genetic",
        "Ortholog",
        "Phylogeny",
        "Sequence Analysis, DNA" ;
    schema1:license "GPL-3" ;
    schema1:name "fdog" ;
    schema1:url "https://github.com/BIONF/fDOG" .

