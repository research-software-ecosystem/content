@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:ngsplotdb-ngsplotdb-hg19 a schema1:SoftwareApplication ;
    schema1:description "HG19 genome database for NGSplot" ;
    schema1:keywords "Clustering",
        "Gene Expression",
        "Genomics",
        "RNA-Seq" ;
    schema1:license "GPL-2.0" ;
    schema1:name "ngsplotdb-ngsplotdb-hg19" ;
    schema1:url "https://github.com/shenlab-sinai/ngsplot" .

