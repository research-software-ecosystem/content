@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:ldblockshow a schema1:SoftwareApplication ;
    schema1:description "A tool for showing linkage disequilibrium heatmaps from variant call format (VCF) files." ;
    schema1:downloadUrl "https://github.com/BGI-shenzhen/LDBlockShow/archive/v1.41.tar.gz" ;
    schema1:identifier biotools:ldblockshow ;
    schema1:license "MIT" ;
    schema1:name "ldblockshow" ;
    schema1:softwareVersion "1.41" ;
    schema1:url "https://github.com/BGI-shenzhen/LDBlockShow" ;
    spdx:builtFrom biotools:ldblockshow .

