@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:obitools a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1111/1755-0998.12428" ;
    schema1:description "Set of python programs developed to simplify the manipulation of sequence files. they were mainly designed to help us for analyzing next generation sequencer outputs (454 or illumina) in the context of dna metabarcoding." ;
    schema1:identifier biotools:obitools ;
    schema1:keywords "Clustering",
        "DNA",
        "DNA Barcoding, Taxonomic",
        "High-Throughput Nucleotide Sequencing",
        "Internet",
        "Sequence analysis",
        "Sequencing" ;
    schema1:license "CeCILL-2.1" ;
    schema1:name "obitools" ;
    schema1:url "https://git.metabarcoding.org/obitools/obitools/wikis/home" .

