@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-spem a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1089/cmb.2011.0269" ;
    schema1:description "S-system parameter estimation method" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/SPEM_1.46.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/SPEM/SPEM_1.46.0.tar.gz', 'https://bioarchive.galaxyproject.org/SPEM_1.46.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-spem/bioconductor-spem_1.46.0_src_all.tar.gz']" ;
    schema1:identifier biotools:spem ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-spem" ;
    schema1:softwareVersion "1.46.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/SPEM.html" ;
    spdx:builtFrom biotools:spem .

