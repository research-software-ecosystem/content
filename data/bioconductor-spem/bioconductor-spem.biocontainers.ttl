@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-spem a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1089/cmb.2011.0269" ;
    schema1:description "S-system parameter estimation method" ;
    schema1:identifier biotools:spem ;
    schema1:keywords "Area Under Curve",
        "Computer Simulation",
        "DNA Repair",
        "Escherichia coli",
        "Gene Expression Profiling",
        "Gene Expression Regulation, Bacterial",
        "Gene Regulatory Networks",
        "Genes, Bacterial",
        "Models, Genetic",
        "Molecular interactions, pathways and networks",
        "SOS Response, Genetics" ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-spem" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/SPEM.html" .

