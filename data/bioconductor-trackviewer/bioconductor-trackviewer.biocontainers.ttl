@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-trackviewer a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "A R/Bioconductor package with web interface for drawing elegant interactive tracks or lollipop plot to facilitate integrated analysis of multi-omics data" ;
    schema1:identifier biotools:trackviewer ;
    schema1:keywords "Computational Biology",
        "Data visualisation",
        "Gene Expression Profiling",
        "Genomics",
        "High-Throughput Screening Assays",
        "Programming Languages",
        "RNA-Seq",
        "Sequence analysis",
        "User-Computer Interface" ;
    schema1:license "GPL-2.0" ;
    schema1:name "bioconductor-trackviewer" ;
    schema1:url "https://www.bioconductor.org/packages/release/bioc/html/trackViewer.html" .

