@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-trackviewer a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "A R/Bioconductor package with web interface for drawing elegant interactive tracks or lollipop plot to facilitate integrated analysis of multi-omics data" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/trackViewer_1.42.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/trackViewer/trackViewer_1.42.0.tar.gz', 'https://bioarchive.galaxyproject.org/trackViewer_1.42.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-trackviewer/bioconductor-trackviewer_1.42.0_src_all.tar.gz']" ;
    schema1:identifier biotools:trackviewer ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-trackviewer" ;
    schema1:softwareVersion "1.42.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/trackViewer.html" ;
    spdx:builtFrom biotools:trackviewer .

