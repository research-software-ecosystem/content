@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:perl-bioperl-core a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1007/978-1-59745-535-0_26" ;
    schema1:description "core packages for the bioperl toolkit; you really should install perl-bioperl." ;
