    schema1:keywords "Computational Biology",
        "Databases, Genetic",
        "Programming Languages",
        "User-Computer Interface" ;
    schema1:license "perl_5" ;
    schema1:name "perl-bioperl-core" ;
    schema1:url "http://metacpan.org/pod/BioPerl" .

