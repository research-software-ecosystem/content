@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:blat a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1101/gr.229202" ;
    schema1:description "Blat is a bioinformatics software tool which performs rapid mrna/dna and cross-species protein alignments" ;
    schema1:identifier biotools:blat ;
    schema1:keywords "Animals",
        "Computational Biology",
        "DNA",
        "Humans",
        "Mice",
        "Protein Biosynthesis",
        "Proteins",
        "RNA, Messenger",
        "Sequence Alignment",
        "Sequence analysis" ;
    schema1:license "Apache-2.0" ;
    schema1:name "blat" ;
    schema1:url "https://users.soe.ucsc.edu/~kent/src/" .

