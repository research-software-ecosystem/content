@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-seqtools a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Analysis of nucleotide, sequence and quality content on fastq files" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/seqTools_1.40.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/seqTools/seqTools_1.40.0.tar.gz', 'https://bioarchive.galaxyproject.org/seqTools_1.40.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-seqtools/bioconductor-seqtools_1.40.0_src_all.tar.gz']" ;
    schema1:identifier biotools:seqtools ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-seqtools" ;
    schema1:softwareVersion "1.40.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/seqTools.html" ;
    spdx:builtFrom biotools:seqtools .

