@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:epiweeks a schema1:SoftwareApplication ;
    schema1:description "Calculate epidemiological weeks using the cdc (mmwr) and iso week numbering systems." ;
    schema1:license "Not available" ;
    schema1:name "epiweeks" ;
    schema1:url "https://github.com/dralshehri/epiweeks" .

