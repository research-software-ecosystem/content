@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:sra-toolkit a schema1:SoftwareApplication ;
    schema1:description "Utilities for the ncbi sequence read archive" ;
    schema1:license "custom, see /usr/share/doc/sra-toolkit/copyright" ;
    schema1:name "sra-toolkit" ;
    schema1:url "https://github.com/ncbi/sra-tools/" .

