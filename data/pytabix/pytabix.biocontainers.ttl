@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:pytabix a schema1:SoftwareApplication ;
    schema1:description "Fast random access to sorted files compressed with bgzip and indexed by tabix." ;
    schema1:license "MIT" ;
    schema1:name "pytabix" ;
    schema1:url "https://github.com/slowkow/pytabix" .

