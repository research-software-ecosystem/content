@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:transindel a schema1:SoftwareApplication ;
    schema1:description "Transindel is used to detect indels (insertions and deletions) from dna-seq or rna-seq data by parsing chimeric alignments from bwa-mem.." ;
    schema1:keywords "RNA-Seq" ;
    schema1:license "GPL-3.0" ;
    schema1:name "transindel" ;
    schema1:url "https://github.com/cauyrd/transIndel" .

