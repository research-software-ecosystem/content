@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:rsat-core a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/gky317" ;
    schema1:description "Regulatory Sequence Analysis Tools (RSAT)" ;
    schema1:downloadUrl "https://github.com/rsa-tools/rsat-code/archive/refs/tags/2025.04.04.tar.gz" ;
    schema1:identifier biotools:rsat ;
    schema1:license "GNU Affero General Public License v3" ;
    schema1:name "rsat-core" ;
    schema1:softwareVersion "2025.04.04" ;
    schema1:url "http://rsat.eu" ;
    spdx:builtFrom biotools:rsat .

