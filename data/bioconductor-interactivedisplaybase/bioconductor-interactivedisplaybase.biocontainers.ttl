@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-interactivedisplaybase a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "This package contains the basic methods needed to generate interactive shiny-based display methods for bioconductor objects." ;
    schema1:identifier biotools:interactivedisplaybase ;
    schema1:keywords "Bioinformatics",
        "Computational Biology",
        "Gene Expression Profiling",
        "Genetics",
        "Genomics",
        "High-Throughput Screening Assays",
        "Programming Languages",
        "Software engineering",
        "User-Computer Interface" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-interactivedisplaybase" ;
    schema1:url "http://bioconductor.org/packages/release/bioc/html/interactiveDisplayBase.html" .

