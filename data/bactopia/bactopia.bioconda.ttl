@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bactopia a schema1:SoftwareApplication ;
    schema1:author "rpetit3" ;
    schema1:citation "doi:10.1128/mSystems.00190-20" ;
    schema1:description "Bactopia is a flexible pipeline for complete analysis of bacterial genomes." ;
    schema1:downloadUrl "https://github.com/bactopia/bactopia/archive/v4.0.0.tar.gz" ;
    schema1:identifier biotools:bactopia ;
    schema1:license "MIT" ;
    schema1:maintainer "rpetit3" ;
    schema1:name "bactopia" ;
    schema1:softwareVersion "4.0.0" ;
    schema1:url "https://bactopia.io/" ;
    spdx:builtFrom biotools:bactopia .

