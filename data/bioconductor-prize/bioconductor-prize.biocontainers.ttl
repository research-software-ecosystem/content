@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-prize a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "This tool offers a novel approach to narrow down long lists of candidates by prioritizing them based on how well they meet the research goal. it organizes and analyzes complex decisions where multiple criteria are involved. the technique structures problems into a hierarchy of elements, and helps to specify numerical weights representing the relative importance of each element." ;
    schema1:identifier biotools:prize ;
    schema1:keywords "Cell biology",
        "Computational Biology",
        "Gene Expression Profiling",
        "Gene expression",
        "Genomics",
        "High-Throughput Screening Assays",
        "Programming Languages",
        "RNA-Seq",
        "User-Computer Interface" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-prize" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/Prize.html" .

