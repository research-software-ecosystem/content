@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bamhash a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btv539" ;
    schema1:description "Hash BAM and FASTQ files to verify data integrity" ;
    schema1:identifier biotools:bamhash ;
    schema1:keywords "DNA",
        "Data management",
        "Data quality management",
        "Genetics",
        "Humans",
        "Reproducibility of Results",
        "Sequence Analysis",
        "Statistics as Topic" ;
    schema1:license "BSD" ;
    schema1:name "bamhash" ;
    schema1:url "https://github.com/DecodeGenetics/BamHash" .

