@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:peptimapper a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s12864-019-5431-9" ;
    schema1:description "Also called ectoline, peptimapper is composed of a subset of pepline (2.0.1), ad redistribution of pepnovo+ (3.1 beta) and glue scripts to run a pepline/ectoline analysis." ;
    schema1:keywords "Amino Acid Sequence",
        "Codon",
        "Eukaryota",
        "Genome",
        "Mass Spectrometry",
        "Molecular Sequence Annotation",
        "Peptides",
        "Proteogenomics",
        "Reproducibility of Results",
        "Workflow" ;
    schema1:license "GPL-3.0-only" ;
    schema1:name "peptimapper" ;
    schema1:url "https://github.com/laeticlo/Ectoline" .

