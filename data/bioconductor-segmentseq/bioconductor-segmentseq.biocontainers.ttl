@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-segmentseq a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btr687" ;
    schema1:description "Methods for identifying small RNA loci from high-throughput sequencing data" ;
    schema1:identifier biotools:segmentseq ;
    schema1:keywords "Arabidopsis",
        "ChIP-seq",
        "Computer Simulation",
        "Genome, Plant",
        "High-Throughput Nucleotide Sequencing",
        "Mapping",
        "RNA, Plant",
        "RNA, Small Interfering",
        "RNA-Seq",
        "Sequence Analysis, RNA",
        "Transcriptome" ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-segmentseq" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/segmentSeq.html" .

