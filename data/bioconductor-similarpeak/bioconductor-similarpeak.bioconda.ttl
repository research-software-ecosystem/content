@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-similarpeak a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1371/journal.pcbi.1004751" ;
    schema1:description "Metrics to estimate a level of similarity between two ChIP-Seq profiles" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/similaRpeak_1.38.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/similaRpeak/similaRpeak_1.38.0.tar.gz', 'https://bioarchive.galaxyproject.org/similaRpeak_1.38.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-similarpeak/bioconductor-similarpeak_1.38.0_src_all.tar.gz']" ;
    schema1:identifier biotools:similarpeak ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-similarpeak" ;
    schema1:softwareVersion "1.38.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/similaRpeak.html" ;
    spdx:builtFrom biotools:similarpeak .

