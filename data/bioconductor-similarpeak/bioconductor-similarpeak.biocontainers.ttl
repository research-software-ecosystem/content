@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-similarpeak a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1371/journal.pcbi.1004751" ;
    schema1:description "This package calculates metrics which assign a level of similarity between chip-seq profiles." ;
    schema1:identifier biotools:similarpeak ;
    schema1:keywords "B-Lymphocytes",
        "Cell Line",
        "ChIP-seq",
        "Chromatin Immunoprecipitation",
        "Gene Expression Profiling",
        "Genetics",
        "High-Throughput Nucleotide Sequencing",
        "Humans",
        "Metagenomics",
        "Protein binding sites",
        "Regulatory Sequences, Nucleic Acid",
        "Transcription, Genetic" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-similarpeak" ;
    schema1:url "http://bioconductor.org/packages/release/bioc/html/similaRpeak.html" .

