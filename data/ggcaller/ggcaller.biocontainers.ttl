@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:ggcaller a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1016/j.jbiotec.2017.07.017",
        "doi:10.1101/695338" ;
    schema1:description "A gene caller for Bifrost graphs" ;
    schema1:keywords "Databases, Genetic",
        "Genome, Human",
        "Genomics",
        "High-Throughput Nucleotide Sequencing",
        "Humans",
        "Sequence Alignment",
        "Sequence Analysis, DNA" ;
    schema1:license "MIT" ;
    schema1:name "ggcaller" ;
    schema1:url "https://github.com/samhorsfield96/ggCaller" .

