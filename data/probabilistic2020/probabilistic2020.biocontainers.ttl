@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:probabilistic2020 a schema1:SoftwareApplication ;
    schema1:description "Simulates somatic mutations, and calls statistically significant oncogenes and tumor suppressor genes based on a randomization-based test" ;
    schema1:keywords "Clustering",
        "Protein Structure" ;
    schema1:license "Apache-2-0" ;
    schema1:name "probabilistic2020" ;
    schema1:url "https://github.com/KarchinLab/probabilistic2020" .

