@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:phabox a schema1:SoftwareApplication ;
    schema1:author "PENG Cheng",
        "SHANG Jiayu" ;
    schema1:citation "doi:10.1093/bioadv/vbad101" ;
    schema1:description "Virus identification and analysis tool set" ;
    schema1:downloadUrl "https://github.com/KennthShang/PhaBOX/archive/refs/tags/v2.1.13.tar.gz" ;
    schema1:identifier biotools:phabox ;
    schema1:license "GPL-3.0" ;
    schema1:maintainer "PENG Cheng",
        "SHANG Jiayu" ;
    schema1:name "phabox" ;
    schema1:softwareHelp "https://github.com/KennthShang/PhaBOX/wiki" ;
    schema1:softwareVersion "2.1.13" ;
    schema1:url "https://github.com/KennthShang/PhaBOX" ;
    spdx:builtFrom biotools:phabox .

