@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:mqc a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1016/j.cmpb.2018.10.018" ;
    schema1:description "Qualtiy control tool to assess the mapping quality of a ribosome profiling experiment" ;
    schema1:keywords "Cell Line, Tumor",
        "Colonic Neoplasms",
        "Computational Biology",
        "Cycloheximide",
        "Gene Expression Profiling",
        "Genome-Wide Association Study",
        "HCT116 Cells",
        "HEK293 Cells",
        "High-Throughput Nucleotide Sequencing",
        "Humans",
        "Open Reading Frames",
        "Quality Control",
        "RNA, Messenger",
        "Reproducibility of Results",
        "Ribosomes",
        "Sequence Analysis, DNA",
        "Sequence Analysis, RNA" ;
    schema1:license "GNU General Public License v3.0" ;
    schema1:name "mqc" ;
    schema1:url "https://github.com/Biobix/mQC" .

