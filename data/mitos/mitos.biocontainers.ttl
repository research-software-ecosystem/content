@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:mitos a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1016/j.ympev.2012.08.023" ;
    schema1:description "MITOS is a tool for the annotation of metazoan mitochondrial genomes." ;
    schema1:identifier biotools:mitos ;
    schema1:keywords "Animals",
        "Computational Biology",
        "Evolution, Molecular",
        "Genome, Mitochondrial",
        "Internet",
        "Molecular Sequence Annotation",
        "Phylogeny",
        "Sequence Analysis, DNA",
        "Whole genome sequencing",
        "Zoology" ;
    schema1:license "MIT" ;
    schema1:name "mitos" ;
    schema1:url "http://mitos.bioinf.uni-leipzig.de" .

