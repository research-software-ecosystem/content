@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:raiss a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btz466" ;
    schema1:description "SNP summary statistics imputation package" ;
    schema1:identifier biotools:raiss ;
    schema1:keywords "GWAS study",
        "Genetics",
        "Genome-Wide Association Study",
        "Genotype",
        "Phenotype",
        "Polymorphism, Single Nucleotide",
        "Statistics and probability" ;
    schema1:license "MIT" ;
    schema1:name "raiss" ;
    schema1:url "http://statistical-genetics.pages.pasteur.fr/raiss/" .

