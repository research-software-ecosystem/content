@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:seqan a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1016/j.jbiotec.2017.07.017",
        "doi:10.1186/1471-2105-9-11" ;
    schema1:description "SeqAn is an open source C++ library of efficient algorithms and data structures for the analysis of sequences with the focus on biological data." ;
    schema1:identifier biotools:seqan ;
    schema1:keywords "Bioinformatics",
        "Comparative genomics",
        "Databases, Genetic",
        "Genome, Human",
        "Genomics",
        "High-Throughput Nucleotide Sequencing",
        "Humans",
        "Metagenomics",
        "Sequence Alignment",
        "Sequence Analysis, DNA",
        "Software engineering",
        "Transcriptomics" ;
    schema1:license "BSD-3-Clause" ;
    schema1:name "seqan" ;
    schema1:url "http://www.seqan.de/" .

