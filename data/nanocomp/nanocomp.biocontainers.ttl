@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:nanocomp a schema1:SoftwareApplication ;
    schema1:description "Comparing runs of oxford nanopore sequencing data and alignments" ;
    schema1:license "GPL-3.0" ;
    schema1:name "nanocomp" ;
    schema1:url "https://github.com/wdecoster/NanoComp" .

