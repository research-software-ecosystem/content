@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:hmmratac a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/gkz533" ;
    schema1:description "Peak caller for ATAC-seq data" ;
    schema1:keywords "DNA",
        "Datasets as Topic",
        "Genome, Human",
        "High-Throughput Nucleotide Sequencing",
        "Histones",
        "Humans",
        "Markov Chains",
        "Nucleosomes",
        "Sequence Analysis, DNA",
        "Supervised Machine Learning",
        "Transposases" ;
    schema1:license "GPL-3.0" ;
    schema1:name "hmmratac" ;
    schema1:url "https://github.com/LiuLabUB/HMMRATAC" .

