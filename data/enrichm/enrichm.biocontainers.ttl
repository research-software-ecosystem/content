@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:enrichm a schema1:SoftwareApplication ;
    schema1:description "EnrichM is a toolbox for comparing the functional composition of population genomes" ;
    schema1:keywords "Genomics",
        "Metagenome",
        "Transcriptome" ;
    schema1:license "GPL-3.0" ;
    schema1:name "enrichm" ;
    schema1:url "https://github.com/geronimp/enrichM" .

