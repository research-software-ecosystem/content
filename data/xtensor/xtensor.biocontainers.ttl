@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:xtensor a schema1:SoftwareApplication ;
    schema1:description "xtensor is a C++ library meant for numerical analysis with multi-dimensional array expressions." ;
    schema1:license "BSD-3.0" ;
    schema1:name "xtensor" ;
    schema1:url "https://github.com/xtensor-stack/xtensor" .

