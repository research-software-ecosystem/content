@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:umis a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.4220" ;
    schema1:description "Tools for processing UMI RNA-tag data" ;
    schema1:identifier biotools:umis ;
    schema1:keywords "Animals",
        "Embryonic Stem Cells",
        "Freezing",
        "Gene expression",
        "Mice",
        "Poly A",
        "RNA, Messenger",
        "RNA-Seq",
        "RNA-seq",
        "Sensitivity and Specificity",
        "Sequence Analysis, RNA",
        "Single-Cell Analysis",
        "Workflow" ;
    schema1:license "MIT" ;
    schema1:name "umis" ;
    schema1:url "https://github.com/vals/umis" .

