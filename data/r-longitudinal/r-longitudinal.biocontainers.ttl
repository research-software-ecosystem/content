@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-longitudinal a schema1:SoftwareApplication ;
    schema1:description "Contains general data structures and functions for longitudinal data with multiple variables, repeated measurements, and irregularly spaced time points. Also implements a shrinkage estimator of dynamical correlation and dynamical covariance." ;
    schema1:license "GPL (>= 3)" ;
    schema1:name "r-longitudinal" ;
    schema1:url "None" .

