@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:moabs a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/gb-2014-15-2-r38" ;
    schema1:description "A comprehensive, accurate and efficient solution for analysis of large scale base-resolution DNA methylation data" ;
    schema1:keywords "CpG Islands",
        "DNA Methylation",
        "High-Throughput Nucleotide Sequencing",
        "Humans",
        "Models, Statistical",
        "Sequence Analysis, DNA" ;
    schema1:license "GPL-3.0" ;
    schema1:name "moabs" ;
    schema1:url "https://code.google.com/archive/p/moabs/" .

