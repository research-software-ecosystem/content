@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:sina a schema1:SoftwareApplication ;
    schema1:author "epruesse" ;
    schema1:citation "doi:10.1093/bioinformatics/bts252" ;
    schema1:description "Reference based multiple sequence alignment" ;
    schema1:downloadUrl "https://github.com/epruesse/SINA/releases/download/v1.7.2/sina-1.7.2.tar.gz" ;
    schema1:identifier biotools:SINA ;
    schema1:license "GPLv3" ;
    schema1:maintainer "epruesse" ;
    schema1:name "sina" ;
    schema1:softwareHelp "https://sina.readthedocs.io" ;
    schema1:softwareVersion "1.7.2" ;
    schema1:url "https://github.com/epruesse/SINA" ;
    spdx:builtFrom biotools:SINA .

