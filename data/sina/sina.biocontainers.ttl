@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:sina a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/bts252" ;
    schema1:description "Reference based multiple sequence alignment" ;
    schema1:identifier biotools:SINA ;
    schema1:keywords "Base Sequence",
        "Computational Biology",
        "Databases, Nucleic Acid",
        "Genes, rRNA",
        "Nucleic acid structure analysis",
        "RNA",
        "RNA, Ribosomal",
        "Sequence Alignment",
        "Sequence analysis",
        "Sequencing",
        "Taxonomy" ;
    schema1:license "GPL-3.0" ;
    schema1:name "sina" ;
    schema1:url "https://github.com/epruesse/SINA" .

