        "Epigenetics",
        "Genome, Human",
        "High-Throughput Nucleotide Sequencing",
        "Humans",
        "Methylated DNA immunoprecipitation",
        "Organ Specificity",
        "Sequence Analysis, DNA",
        "Sequencing" ;
    schema1:license "GPL-3.0" ;
    schema1:name "bioconductor-methylmnm" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/methylMnM.html" .

