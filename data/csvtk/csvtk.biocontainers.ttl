@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:csvtk a schema1:SoftwareApplication ;
    schema1:description "A cross-platform, efficient, practical CSV/TSV toolkit" ;
    schema1:license "MIT" ;
    schema1:name "csvtk" ;
    schema1:url "https://github.com/shenwei356/csvtk" .

