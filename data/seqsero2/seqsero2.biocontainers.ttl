@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:seqsero2 a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1128/AEM.01746-19" ;
    schema1:description "Salmonella serotype prediction from genome sequencing data" ;
    schema1:keywords "Genome, Bacterial",
        "Salmonella",
        "Serogroup",
        "Serotyping",
        "Whole Genome Sequencing",
        "Whole genome sequencing" ;
    schema1:license "GPL-2.0" ;
    schema1:name "seqsero2" ;
    schema1:url "https://github.com/denglab/SeqSero2" .

