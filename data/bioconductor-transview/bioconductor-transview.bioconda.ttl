@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-transview a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Read density map construction and accession. Visualization of ChIPSeq and RNASeq data sets" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.18/bioc/src/contrib/TransView_1.46.0.tar.gz', 'https://bioconductor.org/packages/3.18/bioc/src/contrib/Archive/TransView/TransView_1.46.0.tar.gz', 'https://bioarchive.galaxyproject.org/TransView_1.46.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-transview/bioconductor-transview_1.46.0_src_all.tar.gz']" ;
    schema1:identifier biotools:transview ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-transview" ;
    schema1:softwareVersion "1.46.0" ;
    schema1:url "https://bioconductor.org/packages/3.18/bioc/html/TransView.html" ;
    spdx:builtFrom biotools:transview .

