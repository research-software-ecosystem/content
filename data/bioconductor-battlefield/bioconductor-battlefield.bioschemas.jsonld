  "@graph": [
    {
      "@id": "https://bio.tools/bioconductor-battlefield",
      "@type": "sc:SoftwareApplication",
      "dcterms:conformsTo": "https://bioschemas.org/profiles/ComputationalTool/0.6-DRAFT",
      "sc:additionalType": [
        "Command-line tool",
        "Library"
      ],
      "sc:author": "Jean-Philippe Villemin",
      "sc:citation": {
        "@id": "https://doi.org/10.18129/B9.bioc.Battlefield"
      },
      "sc:contributor": "European Research Council",
      "sc:description": "Battlefield is a Swiss-army toolkit originally developed to define and extract spatial spots from specific tissue regions—such as front regions, niche borders, invasive margins, and cluster interfaces—using spatial transcriptomics data or clustered tissue maps. It has since been extended to support trajectory selection and layer inspection, and now provides a collection of low-level utilities for spatial transcriptomics analysis. These utilities are primarily intended to be reused within higher-level analytical packages. It is designed to work with sequencing-based platforms such as Visium at several resolutions and Visium HD(binned).",
      "sc:funder": "European Research Council",
      "sc:name": "Battlefield",
      "sc:operatingSystem": [
        "Linux",
        "Mac",
        "Windows"
      ],
      "sc:softwareHelp": {
        "@id": "https://bioconductor.org/packages/Battlefield"
      },
