@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-gofunction a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bib/bbr041" ;
    schema1:description "GO-function: deriving biologcially relevant functions from statistically significant functions" ;
    schema1:identifier biotools:gofunction ;
    schema1:keywords "Colorectal Neoplasms",
        "Computational Biology",
        "Databases, Genetic",
        "Gene Expression Profiling",
        "Genomics" ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-gofunction" ;
    schema1:url "http://bioconductor.org/packages/3.6/bioc/html/GOFunction.html" .

