@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:guidemaker a schema1:SoftwareApplication ;
    schema1:author "arivers",
        "ravinpoudel" ;
    schema1:citation "doi:10.5281/zenodo.4849258" ;
    schema1:description "GuideMaker: Software to design gRNAs pools in non-model genomes and CRISPR-Cas systems" ;
    schema1:downloadUrl "https://github.com/USDA-ARS-GBRU/GuideMaker/archive/v0.4.2.tar.gz" ;
    schema1:identifier biotools:GuideMaker ;
    schema1:license "CC0-1.0" ;
    schema1:maintainer "arivers",
        "ravinpoudel" ;
    schema1:name "guidemaker" ;
    schema1:softwareHelp "https://guidemaker.org/" ;
    schema1:softwareVersion "0.4.2" ;
    schema1:url "https://guidemaker.app.scinet.usda.gov/" ;
    spdx:builtFrom biotools:GuideMaker .

