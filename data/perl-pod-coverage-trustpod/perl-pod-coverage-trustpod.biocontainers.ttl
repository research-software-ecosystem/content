@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:perl-pod-coverage-trustpod a schema1:SoftwareApplication ;
    schema1:description "Allow a module's pod to contain pod::coverage hints" ;
    schema1:license "Not available" ;
    schema1:name "perl-pod-coverage-trustpod" ;
    schema1:url "https://github.com/rjbs/Pod-Coverage-TrustPod" .

