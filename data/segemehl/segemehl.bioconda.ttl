@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:segemehl a schema1:SoftwareApplication ;
    schema1:description "Short read mapping with gaps." ;
    schema1:downloadUrl "http://www.bioinf.uni-leipzig.de/Software/segemehl/downloads/segemehl-0.3.4.tar.gz" ;
    schema1:identifier biotools:segemehl ;
    schema1:license "GPL-3.0-or-later" ;
    schema1:name "segemehl" ;
    schema1:softwareHelp "http://www.bioinf.uni-leipzig.de/Software/segemehl" ;
    schema1:softwareVersion "0.3.4" ;
    schema1:url "http://www.bioinf.uni-leipzig.de/Software/segemehl" ;
    spdx:builtFrom biotools:segemehl .

