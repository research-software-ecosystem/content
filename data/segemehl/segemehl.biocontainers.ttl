@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:segemehl a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btu146" ;
    schema1:description "A software to map short sequencer reads to reference genomes. unlike other methods, segemehl is able to detect not only mismatches but also insertions and deletions. furthermore, this tool is not limited to a specific read length and is able to map primer- or polyadenylation contaminated reads correctly." ;
    schema1:identifier biotools:segemehl ;
    schema1:keywords "DNA",
        "High-Throughput Nucleotide Sequencing",
        "Mapping",
        "RNA",
        "Sequence Analysis, RNA",
        "Sequencing" ;
    schema1:license "GPL-3.0+" ;
    schema1:name "segemehl" ;
    schema1:url "http://hoffmann.bioinf.uni-leipzig.de/LIFE/segemehl.html" .

