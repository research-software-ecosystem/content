@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:spacepharer a schema1:SoftwareApplication ;
    schema1:author "milot-mirdita" ;
    schema1:citation "doi:10.1093/bioinformatics/btab222" ;
    schema1:description "SpacePHARER: Sensitive identification of phages from CRISPR spacers in prokaryotic hosts" ;
    schema1:downloadUrl "https://github.com/soedinglab/spacepharer/archive/5-c2e680a.tar.gz" ;
    schema1:identifier biotools:spacepharer ;
    schema1:license "GPL-3" ;
    schema1:maintainer "milot-mirdita" ;
    schema1:name "spacepharer" ;
    schema1:softwareVersion "5.c2e680a" ;
    schema1:url "https://github.com/soedinglab/spacepharer" ;
    spdx:builtFrom biotools:spacepharer .

