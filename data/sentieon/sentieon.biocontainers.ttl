@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:sentieon a schema1:SoftwareApplication ;
    schema1:description "Accelerated performance bioinformatics tools for mapping and variant calling." ;
    schema1:keywords "Genomics",
        "Proteomics" ;
    schema1:license "Commercial (requires license for use; redistribution allowed)" ;
    schema1:name "sentieon" ;
    schema1:url "http://sentieon.com" .

