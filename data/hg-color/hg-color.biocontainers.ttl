@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:hg-color a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/bty521" ;
    schema1:description "HG-CoLoR (Hybrid Graph for the error Correction of Long Reads) is a hybrid method for the error correction of long reads that follows the main idea from NaS to produce corrected long reads from assemblies of related accurate short reads." ;
    schema1:keywords "Computational Biology",
        "High-Throughput Nucleotide Sequencing",
        "Nanopores",
        "Sequence Analysis, DNA" ;
    schema1:license "GPL" ;
    schema1:name "hg-color" ;
    schema1:url "https://github.com/pierre-morisse/HG-CoLoR" .

