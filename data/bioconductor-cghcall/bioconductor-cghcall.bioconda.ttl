@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-cghcall a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btm030" ;
    schema1:description "Calling aberrations for array CGH tumor profiles." ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/CGHcall_2.68.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/CGHcall/CGHcall_2.68.0.tar.gz', 'https://bioarchive.galaxyproject.org/CGHcall_2.68.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-cghcall/bioconductor-cghcall_2.68.0_src_all.tar.gz']" ;
    schema1:identifier biotools:cghcall ;
    schema1:license "GPL (http://www.gnu.org/copyleft/gpl.html)" ;
    schema1:name "bioconductor-cghcall" ;
    schema1:softwareVersion "2.68.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/CGHcall.html" ;
    spdx:builtFrom biotools:cghcall .

