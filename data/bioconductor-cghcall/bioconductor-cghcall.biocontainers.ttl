@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-cghcall a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btm030" ;
    schema1:description "Calling aberrations for array CGH tumor profiles." ;
    schema1:identifier biotools:cghcall ;
    schema1:keywords "Chromosome Aberrations",
        "Chromosome Mapping",
        "DNA, Neoplasm",
        "Gene Dosage",
        "Humans",
        "Neoplasms",
        "Oligonucleotide Array Sequence Analysis",
        "Oncology",
        "Sequence Alignment",
        "Sequence Analysis, DNA" ;
    schema1:license "GPL" ;
    schema1:name "bioconductor-cghcall" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/CGHcall.html" .

