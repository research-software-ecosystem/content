@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:mobyle a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btp493" ;
    schema1:description "Web portal that provides web forms for command-line software" ;
    schema1:keywords "Computational Biology",
        "Databases, Factual",
        "Internet",
        "User-Computer Interface" ;
    schema1:license "GPL-2+" ;
    schema1:name "mobyle" ;
    schema1:url "https://projets.pasteur.fr/projects/mobyle" .

