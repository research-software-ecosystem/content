@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-ruvnormalize a schema1:SoftwareApplication ;
    schema1:description "RUV for normalization of expression array data" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/RUVnormalize_1.40.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/RUVnormalize/RUVnormalize_1.40.0.tar.gz', 'https://bioarchive.galaxyproject.org/RUVnormalize_1.40.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-ruvnormalize/bioconductor-ruvnormalize_1.40.0_src_all.tar.gz']" ;
    schema1:identifier biotools:ruvnormalize ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-ruvnormalize" ;
    schema1:softwareVersion "1.40.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/RUVnormalize.html" ;
    spdx:builtFrom biotools:ruvnormalize .

