@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-ruvnormalize a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/biostatistics/kxv026" ;
    schema1:description "RUV for normalization of expression array data" ;
    schema1:identifier biotools:ruvnormalize ;
    schema1:keywords "Data Interpretation, Statistical",
        "Gene Expression",
        "Gene expression",
        "Genetic Variation",
        "Humans",
        "Microarray Analysis" ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-ruvnormalize" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/RUVnormalize.html" .

