@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:vamb a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1101/2024.10.25.620172" ;
    schema1:description "Variational autoencoder for metagenomic binning." ;
    schema1:downloadUrl "https://pypi.org/packages/source/v/vamb/vamb-5.0.4.tar.gz" ;
    schema1:identifier biotools:vamb ;
    schema1:license "MIT" ;
    schema1:name "vamb" ;
    schema1:softwareHelp "https://vamb.readthedocs.io/en/latest" ;
    schema1:softwareVersion "5.0.4" ;
    schema1:url "https://github.com/RasmussenLab/vamb" ;
    spdx:builtFrom biotools:vamb .

