@prefix debianmed: <https://salsa.debian.org/med-team/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

debianmed:rna-star a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/bts635" ;
    schema1:description "ultrafast universal RNA-seq aligner" ;
    schema1:identifier "bio.tools:star",
        "conda:bioconda:star",
        "guix:star",
        "omictools:OMICS_01254",
        "scicrunch:SCR_015899" ;
    schema1:license "unknown" ;
    schema1:name "rna-star" ;
    schema1:softwareVersion "2.7.11b" ;
    schema1:url "https://github.com/alexdobin/STAR/" ;
    spdx:builtFrom "star" .

