@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:pyx a schema1:SoftwareApplication ;
    schema1:description "Python package for the generation of postscript, pdf, and svg files" ;
    schema1:license "GNU General Public License v2.0" ;
    schema1:name "pyx" ;
    schema1:url "https://github.com/pyx-project/pyx" .

