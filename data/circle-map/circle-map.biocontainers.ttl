@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:circle-map a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/S12859-019-3160-3" ;
    schema1:description "Circular dna analysis tools" ;
    schema1:keywords "DNA, Circular",
        "Databases, Genetic",
        "Humans",
        "Nucleotides",
        "Sequence Alignment" ;
    schema1:license "MIT" ;
    schema1:name "circle-map" ;
    schema1:url "https://github.com/iprada/Circle-Map" .

