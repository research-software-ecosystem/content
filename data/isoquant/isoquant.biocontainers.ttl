@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:isoquant a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1021/ac300510t" ;
    schema1:description "Isoquant is a tool for reference-based analysis of long rna reads." ;
    schema1:keywords "Amino Acids",
        "Animals",
        "Cells, Cultured",
        "Chromatography, High Pressure Liquid",
        "Databases, Protein",
        "Hippocampus",
        "Isotope Labeling",
        "Proteins",
        "Proteomics",
        "Rats",
        "Tandem Mass Spectrometry" ;
    schema1:license "Not available" ;
    schema1:name "isoquant" ;
    schema1:url "https://github.com/ablab/IsoQuant" .

