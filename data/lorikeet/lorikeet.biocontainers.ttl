@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:lorikeet a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1371/journal.pmed.1001880" ;
    schema1:description "Tool for digital spoligotyping of mtb strains from illumina read data" ;
    schema1:keywords "Adult",
        "Antitubercular Agents",
        "Disease Outbreaks",
        "Extensively Drug-Resistant Tuberculosis",
        "Female",
        "Genome, Bacterial",
        "Humans",
        "Male",
        "Microbial Sensitivity Tests",
        "Mutation",
        "Mycobacterium tuberculosis",
        "Sequence Analysis, DNA",
        "South Africa",
        "Whole genome sequencing" ;
    schema1:license "GPL-3.0" ;
    schema1:name "lorikeet" ;
    schema1:url "https://github.com/AbeelLab/lorikeet" .

