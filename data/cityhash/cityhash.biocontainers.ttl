@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:cityhash a schema1:SoftwareApplication ;
    schema1:description "Python-bindings for CityHash, a fast non-cryptographic hash algorithm." ;
    schema1:license "MIT" ;
    schema1:name "cityhash" ;
    schema1:url "https://github.com/escherba/python-cityhash" .

