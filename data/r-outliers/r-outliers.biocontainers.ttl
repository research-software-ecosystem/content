@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-outliers a schema1:SoftwareApplication ;
    schema1:description "A collection of some tests commonly used for identifying outliers." ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "r-outliers" ;
    schema1:url "https://cran.r-project.org/package=outliers" .

