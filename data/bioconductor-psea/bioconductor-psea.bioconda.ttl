@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-psea a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/scibx.2011.1159" ;
    schema1:description "Population-Specific Expression Analysis." ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.18/bioc/src/contrib/PSEA_1.36.0.tar.gz', 'https://bioconductor.org/packages/3.18/bioc/src/contrib/Archive/PSEA/PSEA_1.36.0.tar.gz', 'https://bioarchive.galaxyproject.org/PSEA_1.36.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-psea/bioconductor-psea_1.36.0_src_all.tar.gz']" ;
    schema1:identifier biotools:psea ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-psea" ;
    schema1:softwareVersion "1.36.0" ;
    schema1:url "https://bioconductor.org/packages/3.18/bioc/html/PSEA.html" ;
    spdx:builtFrom biotools:psea .

