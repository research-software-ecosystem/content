@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-psea a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/scibx.2011.1159" ;
    schema1:description "Population-Specific Expression Analysis." ;
    schema1:identifier biotools:psea ;
    schema1:keywords "Data quality management",
        "Gene Expression",
        "Gene expression",
        "Personalised medicine" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-psea" ;
    schema1:url "http://bioconductor.org/packages/release/bioc/html/PSEA.html" .

