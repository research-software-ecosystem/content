@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:python3-ruffus a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btq524" ;
    schema1:description "CGAT-ruffus is a lightweight python module for running computational pipelines" ;
    schema1:keywords "Computational Biology",
        "Databases, Factual",
        "Internet" ;
    schema1:license "MIT" ;
    schema1:name "python3-ruffus" ;
    schema1:url "https://github.com/cgat-developers/ruffus" .

