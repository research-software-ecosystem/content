@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:genomicconsensus a schema1:SoftwareApplication ;
    schema1:description "PacBio genomic consensus and variant caller for RSII and Sequel" ;
    schema1:license "BSD-3-Clause-Clear" ;
    schema1:name "genomicconsensus" ;
    schema1:url "https://github.com/PacificBiosciences/pbbioconda" .

