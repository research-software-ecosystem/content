@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-compgo a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18129/b9.bioc.compgo" ;
    schema1:description "An R pipeline for .bed file annotation, comparing GO term enrichment between gene sets and data visualisation" ;
    schema1:keywords "Data visualisation" ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-compgo" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/CompGO.html" .

