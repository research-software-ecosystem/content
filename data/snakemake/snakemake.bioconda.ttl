@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:snakemake a schema1:SoftwareApplication ;
    schema1:author "corneliusroemer",
        "johanneskoester" ;
    schema1:citation "doi:10.1093/bioinformatics/bts480" ;
    schema1:description "A popular workflow management system aiming at full in-silico reproducibility." ;
    schema1:downloadUrl "https://pypi.io/packages/source/s/snakemake/snakemake-9.21.1.tar.gz" ;
    schema1:identifier biotools:snakemake ;
    schema1:license "MIT" ;
    schema1:maintainer "corneliusroemer",
        "johanneskoester" ;
    schema1:name "snakemake" ;
    schema1:softwareHelp "https://snakemake.readthedocs.io/en/stable" ;
    schema1:softwareVersion "9.21.1" ;
    schema1:url "https://snakemake.github.io" ;
    spdx:builtFrom biotools:snakemake .

