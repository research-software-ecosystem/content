@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-splinter a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Splice Interpreter of Transcripts" ;
    schema1:identifier biotools:splinter ;
    schema1:keywords "Computational Biology",
        "Data visualisation",
        "Gene Expression Profiling",
        "Gene expression",
        "Genomics",
        "High-Throughput Screening Assays",
        "Programming Languages",
        "RNA splicing",
        "RNA-Seq",
        "User-Computer Interface" ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-splinter" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/SPLINTER.html" .

