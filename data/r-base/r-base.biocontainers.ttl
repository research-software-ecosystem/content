@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-base a schema1:SoftwareApplication ;
    schema1:description "R is a free software environment for statistical computing and graphics." ;
    schema1:license "GPL-3.0" ;
    schema1:name "r-base" ;
    schema1:url "http://www.r-project.org/" .

