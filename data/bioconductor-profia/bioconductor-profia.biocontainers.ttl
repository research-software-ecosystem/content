@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-profia a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Preprocessing of FIA-HRMS data" ;
    schema1:identifier biotools:profia ;
    schema1:keywords "Computational Biology",
        "Gene Expression Profiling",
        "Genomics",
        "High-Throughput Screening Assays",
        "Mass spectrometry",
        "Metabolomics",
        "Programming Languages",
        "Proteomics",
        "User-Computer Interface" ;
    schema1:license "CeCILL" ;
    schema1:name "bioconductor-profia" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/proFIA.html" .

