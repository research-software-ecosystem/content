@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:metamaps a schema1:SoftwareApplication ;
    schema1:description "MetaMaps is a tool for long-read metagenomic analysis" ;
    schema1:license "Public Domain" ;
    schema1:name "metamaps" ;
    schema1:url "https://github.com/DiltheyLab/MetaMaps" .

