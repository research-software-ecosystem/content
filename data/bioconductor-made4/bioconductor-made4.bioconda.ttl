@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-made4 a schema1:SoftwareApplication ;
    schema1:description "Multivariate analysis of microarray data using ADE4" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/made4_1.80.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/made4/made4_1.80.0.tar.gz', 'https://bioarchive.galaxyproject.org/made4_1.80.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-made4/bioconductor-made4_1.80.0_src_all.tar.gz']" ;
    schema1:identifier biotools:made4 ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-made4" ;
    schema1:softwareVersion "1.80.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/made4.html" ;
    spdx:builtFrom biotools:made4 .

