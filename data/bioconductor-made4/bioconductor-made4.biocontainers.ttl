@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-made4 a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/bti394" ;
    schema1:description "Multivariate data analysis and graphical display of microarray data. functions include between group analysis and coinertia analysis. it contains functions that require ade4." ;
    schema1:identifier biotools:made4 ;
    schema1:keywords "Clustering",
        "Computer Graphics",
        "Documentation",
        "Gene Expression Profiling",
        "Gene Expression Regulation",
        "Gene expression",
        "Genetics",
        "Microarray experiment",
        "Models, Biological",
        "Multivariate Analysis",
        "Oligonucleotide Array Sequence Analysis",
        "Phylogeny",
        "Signal Transduction",
        "Transcriptomics",
        "User-Computer Interface" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-made4" ;
    schema1:url "http://bioconductor.org/packages/release/bioc/html/made4.html" .

