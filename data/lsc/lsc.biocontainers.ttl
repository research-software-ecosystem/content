@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:lsc a schema1:SoftwareApplication ;
    schema1:description "LSC is a long read error correction tool that offers fast correction with high sensitivity and good accuracy." ;
    schema1:license "Apache-2.0" ;
    schema1:name "lsc" ;
    schema1:url "https://www.healthcare.uiowa.edu/labs/au/LSC/" .

