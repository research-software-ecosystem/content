@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:raven-assembler a schema1:SoftwareApplication ;
    schema1:author "thanhleviet" ;
    schema1:description "Raven is an assembler for raw reads generated by the third generation sequencing." ;
    schema1:downloadUrl "https://github.com/lbcb-sci/raven/archive/1.8.3.tar.gz" ;
    schema1:identifier biotools:raven ;
    schema1:license "MIT" ;
    schema1:maintainer "thanhleviet" ;
    schema1:name "raven-assembler" ;
    schema1:softwareHelp "https://github.com/lbcb-sci/raven/blob/1.8.3/README.md" ;
    schema1:softwareVersion "1.8.3" ;
    schema1:url "https://github.com/lbcb-sci/raven" ;
    spdx:builtFrom biotools:raven .

