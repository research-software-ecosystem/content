@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:mirtop a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btz675",
        "doi:10.7490/f1000research.1115724.1" ;
    schema1:description "Small rna-seq annotation" ;
    schema1:identifier biotools:mirtop ;
    schema1:keywords "Functional, regulatory and non-coding RNA",
        "Gene Expression Regulation",
        "High-Throughput Nucleotide Sequencing",
        "MicroRNAs",
        "RNA-Seq",
        "Sequence Analysis, RNA",
        "Transcription factors and regulatory sites",
        "Transcriptome" ;
    schema1:license "MIT" ;
    schema1:name "mirtop" ;
    schema1:url "http://github.com/mirtop/mirtop" .

