@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:mirtop a schema1:SoftwareApplication ;
    schema1:description "Small RNA-seq annotation." ;
    schema1:downloadUrl "https://github.com/miRTop/mirtop/archive/v0.4.30.tar.gz" ;
    schema1:identifier biotools:mirtop ;
    schema1:license "MIT" ;
    schema1:name "mirtop" ;
    schema1:softwareHelp "https://mirtop.readthedocs.io/en/latest" ;
    schema1:softwareVersion "0.4.30" ;
    schema1:url "https://github.com/mirtop/mirtop" ;
    spdx:builtFrom biotools:mirtop .

