@prefix debianmed: <https://salsa.debian.org/med-team/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

debianmed:mirtop a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btz675",
        "doi:10.7490/f1000research.1115724.1" ;
    schema1:description "annotate miRNAs with a standard mirna/isomir naming" ;
    schema1:identifier "bio.tools:mirtop",
        "conda:bioconda:mirtop",
        "omictools:OMICS_31718" ;
    schema1:license "unknown" ;
    schema1:name "mirtop" ;
    schema1:softwareVersion "0.4.30" ;
    schema1:url "https://github.com/miRTop/mirtop" ;
    spdx:builtFrom "mirtop" .

