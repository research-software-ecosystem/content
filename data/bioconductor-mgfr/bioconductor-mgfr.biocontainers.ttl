@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-mgfr a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s12864-015-1785-9" ;
    schema1:description "Marker Gene Finder in RNA-seq data" ;
    schema1:identifier biotools:mgfr ;
    schema1:keywords "Computational Biology",
        "Gene Expression Profiling",
        "Gene Ontology",
        "Genetic Association Studies",
        "Genetic Markers",
        "Genetics",
        "Organ Specificity",
        "RNA",
        "RNA-Seq",
        "Reproducibility of Results",
        "Sequencing",
        "Web Browser" ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-mgfr" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/MGFR.html" .

