@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:igphyml a schema1:SoftwareApplication ;
    schema1:description "IgPhyML is a program designed to build phylogenetic trees and test evolutionary hypotheses regarding B cell affinity maturation." ;
    schema1:license "GPL-2.0" ;
    schema1:name "igphyml" ;
    schema1:url "https://igphyml.readthedocs.io/en/latest/index.html" .

