@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:augustus a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1002/cpbi.57",
        "doi:10.1007/978-1-4939-9173-0_5",
        "doi:10.1007/978-1-4939-9173-0_8",
        "doi:10.1093/bioinformatics/btg1080",
        "doi:10.1093/bioinformatics/btn013",
        "doi:10.1093/bioinformatics/btr010",
        "doi:10.1093/bioinformatics/btw494",
        "doi:10.1186/1471-2105-7-62",
        "doi:10.1186/gb-2006-7-s1-s11" ;
    schema1:description "Augustus is a eukaryotic gene prediction tool. It can integrate evidence, e.g. from rna-seq, ests, proteomics, but can also predict genes ab initio. The ppx extension to augustus can take a protein sequence multiple sequence alignment as input to find new members of the family in a genome. it can be run through a web interface, or downloaded and run locally." ;
    schema1:identifier biotools:augustus ;
    schema1:keywords "Animals",
        "Computational Biology",
        "Databases, Genetic",
        "Evolution, Molecular",
        "Gene and protein families",
        "Gene transcripts",
        "Genome",
        "Molecular Sequence Annotation",
        "Sequence Analysis, RNA",
        "User-Computer Interface",
        "Vertebrates" ;
    schema1:license "Artistic-1.0" ;
    schema1:name "augustus" ;
    schema1:url "https://github.com/Gaius-Augustus/Augustus" .

