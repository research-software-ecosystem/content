@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:trnascan-se a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/gkw413" ;
    schema1:description "tRNA detection in large-scale genome sequence" ;
    schema1:identifier biotools:trnascan-se ;
    schema1:keywords "Base Sequence",
        "Databases, Genetic",
        "Genes, Fungal",
        "Genomics",
        "Humans",
        "Internet",
        "Nucleic Acid Conformation",
        "RNA",
        "RNA, Transfer",
        "Saccharomyces cerevisiae",
        "Sequence analysis",
        "User-Computer Interface" ;
    schema1:license "GPL-3.0" ;
    schema1:name "trnascan-se" ;
    schema1:url "http://lowelab.ucsc.edu/tRNAscan-SE/" .

