@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:trnascan-se a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/gkab688" ;
    schema1:description "tRNA detection in large-scale genomic sequences" ;
    schema1:downloadUrl "https://github.com/UCSC-LoweLab/tRNAscan-SE/archive/refs/tags/v2.0.12.tar.gz" ;
    schema1:identifier biotools:trnascan-se ;
    schema1:license "GPL-3.0-or-later" ;
    schema1:name "trnascan-se" ;
    schema1:softwareHelp "https://lowelab.ucsc.edu/tRNAscan-SE/help.html" ;
    schema1:softwareVersion "2.0.12" ;
    schema1:url "https://lowelab.ucsc.edu/tRNAscan-SE/" ;
    spdx:builtFrom biotools:trnascan-se .

