        "conda:bioconda:flexbar",
        "omictools:OMICS_01087",
        "scicrunch:SCR_013001" ;
    schema1:license "unknown" ;
    schema1:name "flexbar" ;
    schema1:softwareVersion "3.5.0" ;
    schema1:url "https://github.com/seqan/flexbar" ;
    spdx:builtFrom "flexbar" .

