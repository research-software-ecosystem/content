@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:flexbar a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btx330",
        "doi:10.3390/biology1030895" ;
    schema1:description "Flexible barcode and adapter removal." ;
    schema1:downloadUrl "https://github.com/seqan/flexbar/archive/v3.5.0.tar.gz" ;
    schema1:identifier biotools:flexbar ;
    schema1:license "BSD-3-Clause" ;
    schema1:name "flexbar" ;
    schema1:softwareHelp "https://github.com/seqan/flexbar/wiki" ;
    schema1:softwareVersion "3.5.0" ;
    schema1:url "https://github.com/seqan/flexbar" ;
    spdx:builtFrom biotools:flexbar .

