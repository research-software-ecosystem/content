@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:biosigner a schema1:SoftwareApplication ;
    schema1:citation "doi:10.3389/fmolb.2016.00026" ;
    schema1:description "Discovery of significant signatures from omics data." ;
    schema1:identifier biotools:biosigner ;
    schema1:keywords "Gene and protein families",
        "Genomics" ;
    schema1:license "Not available" ;
    schema1:name "biosigner" ;
    schema1:url "https://github.com/inambioinfo/biosigner" .

