@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-rtca a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1016/j.compbiolchem.2013.12.004" ;
    schema1:description "Open-source toolkit to analyse data from xCELLigence System (RTCA)" ;
    schema1:identifier biotools:rtca ;
    schema1:keywords "Antineoplastic Agents",
        "Cell Proliferation",
        "Cluster Analysis",
        "Data visualisation",
        "Hep G2 Cells",
        "Humans",
        "Principal Component Analysis",
        "Time Factors" ;
    schema1:license "LGPL-3" ;
    schema1:name "bioconductor-rtca" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/RTCA.html" .

