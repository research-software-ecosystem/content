@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-rtca a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1016/j.compbiolchem.2013.12.004" ;
    schema1:description "Open-source toolkit to analyse data from xCELLigence System (RTCA)" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/RTCA_1.62.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/RTCA/RTCA_1.62.0.tar.gz', 'https://bioarchive.galaxyproject.org/RTCA_1.62.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-rtca/bioconductor-rtca_1.62.0_src_all.tar.gz']" ;
    schema1:identifier biotools:rtca ;
    schema1:license "LGPL-3" ;
    schema1:name "bioconductor-rtca" ;
    schema1:softwareVersion "1.62.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/RTCA.html" ;
    spdx:builtFrom biotools:rtca .

