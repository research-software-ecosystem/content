@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-proxy a schema1:SoftwareApplication ;
    schema1:description "Provides an extensible framework for the efficient calculation of auto- and cross-proximities, along with implementations of the most popular ones." ;
    schema1:keywords "Genomics",
        "Metagenomics" ;
    schema1:license "GPL-2.0" ;
    schema1:name "r-proxy" ;
    schema1:url "https://CRAN.R-project.org/package=proxy" .

