@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-limma a schema1:SoftwareApplication ;
    schema1:description "Linear Models for Microarray and Omics Data" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/limma_3.62.1.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/limma/limma_3.62.1.tar.gz', 'https://bioarchive.galaxyproject.org/limma_3.62.1.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-limma/bioconductor-limma_3.62.1_src_all.tar.gz']" ;
    schema1:identifier biotools:limma ;
    schema1:license "GPL (>=2)" ;
    schema1:name "bioconductor-limma" ;
    schema1:softwareVersion "3.62.1" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/limma.html" ;
    spdx:builtFrom biotools:limma .

