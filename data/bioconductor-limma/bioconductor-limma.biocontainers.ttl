@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-limma a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/gkv007" ;
    schema1:description "Linear models for microarray data" ;
    schema1:identifier biotools:limma ;
    schema1:keywords "Clustering",
        "Gene Expression Regulation",
        "Genetics",
        "Genomics",
        "Metabolomics",
        "Metagenome",
        "Molecular biology",
        "Oligonucleotide Array Sequence Analysis",
        "Proteomics",
        "Sequence Analysis, RNA",
        "Transcriptomics" ;
    schema1:license "LGPL-2+" ;
    schema1:name "bioconductor-limma" ;
    schema1:url "https://bioconductor.org/packages/limma/" .

