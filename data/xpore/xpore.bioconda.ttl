@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:xpore a schema1:SoftwareApplication ;
    schema1:author "artbio" ;
    schema1:citation "doi:10.1101/2020.06.18.160010" ;
    schema1:description "xpore is a python package for Nanopore data analysis of differential RNA modifications." ;
    schema1:downloadUrl "https://pypi.io/packages/source/x/xpore/xpore-2.1.tar.gz" ;
    schema1:identifier biotools:xpore ;
    schema1:license "MIT" ;
    schema1:maintainer "artbio" ;
    schema1:name "xpore" ;
    schema1:softwareHelp "https://xpore.readthedocs.io/en/latest/" ;
    schema1:softwareVersion "2.1" ;
    schema1:url "https://github.com/GoekeLab/xpore" ;
    spdx:builtFrom biotools:xpore .

