@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-histonehmm a schema1:SoftwareApplication ;
    schema1:description "histoneHMM is a software to analyse ChIP-seq data of histone modifications with broad genomic footprints like H3K27me3. It allows for calling modified regions in single samples as well as for calling differentially modified regions in a comparison of two samples" ;
    schema1:license "GPL" ;
    schema1:name "r-histonehmm" ;
    schema1:url "http://histonehmm.molgen.mpg.de/" .

