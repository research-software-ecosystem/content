@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:somalier a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s13073-020-00761-2" ;
    schema1:description "Fast sample-swap and relatedness checks on BAMs/CRAMs/VCFs/GVCFs." ;
    schema1:downloadUrl "https://github.com/brentp/somalier/archive/refs/tags/v0.3.2.tar.gz" ;
    schema1:identifier biotools:somalier ;
    schema1:license "MIT" ;
    schema1:name "somalier" ;
    schema1:softwareHelp "https://github.com/brentp/somalier/blob/v0.3.2/README.md" ;
    schema1:softwareVersion "0.3.2" ;
    schema1:url "https://github.com/brentp/somalier" ;
    spdx:builtFrom biotools:somalier .

