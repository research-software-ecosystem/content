@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:estmapper a schema1:SoftwareApplication ;
    schema1:description "Software package for the high-throughput alignment of large cDNA (EST, mRNA) sequence sets to a large eukaryotic genome of the same species." ;
    schema1:license "GPL-2.0" ;
    schema1:name "estmapper" ;
    schema1:url "http://kmer.sourceforge.net/wiki/index.php/Getting_Started_with_ESTmapper" .

