@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:tidehunter a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/BIOINFORMATICS/BTZ376" ;
    schema1:description "Efficient and sensitive tandem repeat detection from noisy long reads using seed-and-chain" ;
    schema1:keywords "High-Throughput Nucleotide Sequencing",
        "Nanopores",
        "Sequence Analysis, DNA",
        "Tandem Repeat Sequences" ;
    schema1:license "MIT" ;
    schema1:name "tidehunter" ;
    schema1:url "https://github.com/yangao07/TideHunter" .

