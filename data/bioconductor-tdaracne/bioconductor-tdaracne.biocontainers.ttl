@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-tdaracne a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/1471-2105-11-154" ;
    schema1:description "Network reverse engineering from time course data." ;
    schema1:identifier biotools:tdaracne ;
    schema1:keywords "Computational Biology",
        "Escherichia coli",
        "Gene Expression Profiling",
        "Gene Regulatory Networks",
        "Genome, Bacterial",
        "Genome, Fungal",
        "Molecular interactions, pathways and networks",
        "Oligonucleotide Array Sequence Analysis",
        "Saccharomyces cerevisiae" ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-tdaracne" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/TDARACNE.html" .

