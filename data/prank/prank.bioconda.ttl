@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:prank a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1007/978-1-62703-646-7_10" ;
    schema1:description "PRANK is a probabilistic multiple alignment program for DNA, codon and amino-acid sequences." ;
    schema1:downloadUrl "https://github.com/ariloytynoja/prank-msa/archive/refs/tags/v.251117.tar.gz" ;
    schema1:identifier biotools:prank ;
    schema1:license "GPL-3.0-or-later" ;
    schema1:name "prank" ;
    schema1:softwareHelp "https://ariloytynoja.github.io/prank-msa" ;
    schema1:softwareVersion "251117" ;
    schema1:url "http://wasabiapp.org/software/prank" ;
    spdx:builtFrom biotools:prank .

