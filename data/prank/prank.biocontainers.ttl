@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:prank a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1007/978-1-62703-646-7_10" ;
    schema1:description "Probabilistic multiple alignment program for dna, codon and amino-acid sequences." ;
    schema1:identifier biotools:prank ;
    schema1:keywords "Base Sequence",
        "Computational Biology",
        "Data visualisation",
        "Evolution, Molecular",
        "Phylogeny",
        "Reproducibility of Results",
        "Sequence Alignment",
        "Sequence analysis" ;
    schema1:license "GPL-2+" ;
    schema1:name "prank" ;
    schema1:url "https://github.com/veidenberg/wasabi" .

