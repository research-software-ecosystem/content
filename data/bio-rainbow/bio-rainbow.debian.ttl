@prefix debianmed: <https://salsa.debian.org/med-team/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

debianmed:bio-rainbow a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/bts482" ;
    schema1:description "clustering and assembling short reads for bioinformatics" ;
    schema1:identifier "bio.tools:rainbow",
        "conda:bioconda:rainbow",
        "omictools:OMICS_03722",
        "scicrunch:SCR_002724" ;
    schema1:license "unknown" ;
    schema1:name "bio-rainbow" ;
    schema1:softwareVersion "2.0.4" ;
    schema1:url "http://sourceforge.net/projects/bio-rainbow/" ;
    spdx:builtFrom "rainbow" .

