@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bio-rainbow a schema1:SoftwareApplication ;
    schema1:description "Clustering and assembling short reads for bioinformatics" ;
    schema1:keywords "Clustering",
        "Sequence Alignment" ;
    schema1:license "GPL-3.0+" ;
    schema1:name "bio-rainbow" ;
    schema1:url "http://sourceforge.net/projects/bio-rainbow/" .

