@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:reparation_blast a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/gkx758" ;
    schema1:description "A pipeline that detects novel open reading frames with ribseq data for bacteria." ;
    schema1:keywords "Genomics",
        "Protein Sequences" ;
    schema1:license "GNU General Public License v3.0" ;
    schema1:name "reparation_blast" ;
    schema1:url "https://github.com/RickGelhausen/REPARATION_blast" .

