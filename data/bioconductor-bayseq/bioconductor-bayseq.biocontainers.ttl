@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-bayseq a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/1471-2105-11-422" ;
    schema1:description "Empirical Bayesian analysis of patterns of differential expression in count data" ;
    schema1:identifier biotools:bayseq ;
    schema1:keywords "Arabidopsis",
        "Base Sequence",
        "Bayes Theorem",
        "Gene Expression Profiling",
        "Gene expression",
        "RNA, Plant",
        "Research Design",
        "Sequencing" ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-bayseq" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/baySeq.html" .

