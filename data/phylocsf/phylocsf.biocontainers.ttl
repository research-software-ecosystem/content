@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:phylocsf a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1101/GR.246462.118" ;
    schema1:description "Phylocsf is a method to determine whether a multi-species nucleotide sequence alignment is likely to represent a protein-coding region." ;
    schema1:identifier biotools:phyloCSF ;
    schema1:keywords "Animals",
        "Exons",
        "GWAS study",
        "Gene transcripts",
        "Genome, Human",
        "Genome-Wide Association Study",
        "Genomics",
        "High-Throughput Nucleotide Sequencing",
        "Humans",
        "Open Reading Frames",
        "Ortholog",
        "Phylogenetics",
        "Protein Sequences",
        "Pseudogenes",
        "Sequence Alignment",
        "Sequence Analysis, DNA",
        "Transcriptome" ;
    schema1:license "AGPL-3.0" ;
    schema1:name "phylocsf" ;
    schema1:url "https://github.com/mlin/PhyloCSF/wiki" .

