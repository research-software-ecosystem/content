@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:phylocsf a schema1:SoftwareApplication ;
    schema1:description "Phylogenetic analysis of multi-species genome sequence alignments to identify conserved protein-coding regions" ;
    schema1:downloadUrl "https://github.com/RomainFeron/PhyloCSF/archive/1.0.1-conda.tar.gz" ;
    schema1:identifier biotools:phyloCSF ;
    schema1:license "AGPL-3.0" ;
    schema1:name "phylocsf" ;
    schema1:softwareVersion "1.0.1" ;
    schema1:url "https://github.com/mlin/PhyloCSF/wiki" ;
    spdx:builtFrom biotools:phyloCSF .

