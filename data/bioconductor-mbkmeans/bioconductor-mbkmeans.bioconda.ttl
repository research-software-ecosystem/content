@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-mbkmeans a schema1:SoftwareApplication ;
    schema1:description "Mini-batch K-means Clustering for Single-Cell RNA-seq" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/mbkmeans_1.22.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/mbkmeans/mbkmeans_1.22.0.tar.gz', 'https://bioarchive.galaxyproject.org/mbkmeans_1.22.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-mbkmeans/bioconductor-mbkmeans_1.22.0_src_all.tar.gz']" ;
    schema1:identifier biotools:mbkmeans ;
    schema1:license "MIT + file LICENSE" ;
    schema1:name "bioconductor-mbkmeans" ;
    schema1:softwareVersion "1.22.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/mbkmeans.html" ;
    spdx:builtFrom biotools:mbkmeans .

