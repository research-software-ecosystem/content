@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:alignlib-lite a schema1:SoftwareApplication ;
    schema1:description "Simple wrapper around alignlib C++ library for sequence alignment" ;
    schema1:keywords "Protein Sequences",
        "Sequence Alignment" ;
    schema1:license "GPL-2.0-or-later" ;
    schema1:name "alignlib-lite" ;
    schema1:url "https://github.com/AndreasHeger/alignlib" .

