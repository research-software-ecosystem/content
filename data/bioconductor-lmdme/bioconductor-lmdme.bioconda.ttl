@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-lmdme a schema1:SoftwareApplication ;
    schema1:description "Linear Model decomposition for Designed Multivariate Experiments" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/lmdme_1.52.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/lmdme/lmdme_1.52.0.tar.gz', 'https://bioarchive.galaxyproject.org/lmdme_1.52.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-lmdme/bioconductor-lmdme_1.52.0_src_all.tar.gz']" ;
    schema1:identifier biotools:lmdme ;
    schema1:license "GPL (>=2)" ;
    schema1:name "bioconductor-lmdme" ;
    schema1:softwareVersion "1.52.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/lmdme.html" ;
    spdx:builtFrom biotools:lmdme .

