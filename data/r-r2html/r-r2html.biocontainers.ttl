@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-r2html a schema1:SoftwareApplication ;
    schema1:description "Includes HTML function and methods to write in an HTML file. Thus, making HTML reports is easy. Includes a function that allows redirection on the fly, which appears to be very useful for teaching purpose, as the student can keep a copy of the produced output to keep all that he did during the course. Package comes with a vignette describing how to write HTML reports for statistical analysis. Finally, a driver for 'Sweave' allows to parse HTML flat files containing R code and to automatically write the corresponding outputs (tables and graphs)." ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "r-r2html" ;
    schema1:url "https://cran.r-project.org/web/packages/R2HTML/index.html" .

