@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-sads a schema1:SoftwareApplication ;
    schema1:description "Maximum likelihood tools to fit and compare models of species abundance distributions and of species rank-abundance distributions." ;
    schema1:license "GPL-2" ;
    schema1:name "r-sads" ;
    schema1:url "https://github.com/piklprado/sads" .

