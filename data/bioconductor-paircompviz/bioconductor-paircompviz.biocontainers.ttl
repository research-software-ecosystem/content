@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-paircompviz a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Multiple comparison test visualization" ;
    schema1:identifier biotools:paircompviz ;
    schema1:keywords "Computational Biology",
        "Data visualisation",
        "Experimental design and studies",
        "Gene Expression Profiling",
        "Genomics",
        "High-Throughput Screening Assays",
        "Programming Languages",
        "User-Computer Interface" ;
    schema1:license "GPL (>=3.0)" ;
    schema1:name "bioconductor-paircompviz" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/paircompviz.html" .

