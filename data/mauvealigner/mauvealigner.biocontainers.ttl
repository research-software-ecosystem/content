@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:mauvealigner a schema1:SoftwareApplication ;
    schema1:description "The mauveAligner and progressiveMauve command-line tools for generating multiple genome alignments in the presence of large-scale evolutionary events" ;
    schema1:license "GPL-2.0" ;
    schema1:name "mauvealigner" ;
    schema1:url "https://github.com/koadman/mauveAligner" .

