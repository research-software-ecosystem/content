@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-tcc a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/biostatistics/kxm030" ;
    schema1:description "TCC: Differential expression analysis for tag count data with robust normalization strategies" ;
    schema1:identifier biotools:tcc ;
    schema1:keywords "Bias",
        "Binomial Distribution",
        "Biometry",
        "Expressed Sequence Tags",
        "Gene Expression Profiling",
        "Gene Library",
        "Gene expression",
        "Humans",
        "Information Storage and Retrieval",
        "Likelihood Functions",
        "RNA, Messenger",
        "RNA-Seq",
        "RNA-seq",
        "Regression Analysis",
        "Research Design",
        "Sample Size",
        "Stochastic Processes",
        "Weights and Measures" ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-tcc" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/TCC.html" .

