      "sc:author": [
        "Pedro Russo",
        "Helder Nakaya",
        "Melissa Lever"
      ],
      "sc:citation": {
        "@id": "https://doi.org/10.18129/B9.bioc.mdp"
      },
      "sc:description": "The Molecular Degree of Perturbation webtool quantifies the heterogeneity of samples. It takes a data.frame of omic data that contains at least two classes (control and test) and assigns a score to all samples based on how perturbed they are compared to the controls. It is based on the Molecular Distance to Health (Pankla et al. 2009), and expands on this algorithm by adding the options to calculate the z-score using the modified z-score (using median absolute deviation), change the z-score zeroing threshold, and look at genes that are most perturbed in the test versus control classes.",
      "sc:featureList": {
        "@id": "edam:operation_2428"
      },
      "sc:isAccessibleForFree": true,
      "sc:license": "GPL-3.0-only",
      "sc:name": "mdp",
      "sc:operatingSystem": [
        "Windows",
        "Mac",
        "Linux"
      ],
