@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-aod a schema1:SoftwareApplication ;
    schema1:description "This package provides a set of functions to analyse overdispersed counts or proportions. Most of the methods are already available elsewhere but are scattered in different packages. The proposed functions should be considered as complements to more sophisticated methods such as generalized estimating equations (GEE) or generalized linear mixed effect models (GLMM)." ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "r-aod" ;
    schema1:url "http://cran.r-project.org/package=aod" .

