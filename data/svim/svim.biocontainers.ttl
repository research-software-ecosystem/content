@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:svim a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btz041" ;
    schema1:description "SVIM is a structural variant caller for long reads." ;
    schema1:keywords "Clustering",
        "Genome",
        "Genomics",
        "High-Throughput Nucleotide Sequencing",
        "Humans",
        "Sequence Analysis, DNA" ;
    schema1:license "GPL-3.0" ;
    schema1:name "svim" ;
    schema1:url "https://github.com/eldariont/svim" .

