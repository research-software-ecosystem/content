@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:oncogemini a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1101/2020.03.10.979591" ;
    schema1:description "Oncogemini is an adaptation of gemini intended for the improved identification of biologically and clinically relevant tumor variants from multi-sample and longitudinal tumor sequencing data" ;
    schema1:license "MIT" ;
    schema1:name "oncogemini" ;
    schema1:url "https://github.com/fakedrtom/oncogemini" .

