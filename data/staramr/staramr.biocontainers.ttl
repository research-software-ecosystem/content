@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:staramr a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/jac/dks261" ;
    schema1:description "Scan genome contigs against the resfinder and pointfinder databases" ;
    schema1:keywords "Bacteria",
        "Bacterial Infections",
        "Computational Biology",
        "Drug Resistance, Bacterial",
        "Genomics",
        "Humans",
        "Internet" ;
    schema1:license "Apache-2.0" ;
    schema1:name "staramr" ;
    schema1:url "https://github.com/phac-nml/staramr" .

