@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:lexmapr a schema1:SoftwareApplication ;
    schema1:description "A lexicon and rule-based tool for translating short biomedical specimen descriptions into semantic web ontology terms" ;
    schema1:license "GNU General Public License v3.0" ;
    schema1:name "lexmapr" ;
    schema1:url "https://github.com/LexMapr/lexmapr" .

