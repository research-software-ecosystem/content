@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:multiz a schema1:SoftwareApplication ;
    schema1:description "DNA multiple sequence aligner from Penn State's Miller lab." ;
    schema1:downloadUrl "https://github.com/multiz/multiz/archive/refs/tags/20190527.tar.gz" ;
    schema1:identifier biotools:multiz ;
    schema1:license "MIT" ;
    schema1:name "multiz" ;
    schema1:softwareVersion "11.2" ;
    schema1:url "http://www.bx.psu.edu/miller_lab/" ;
    spdx:builtFrom biotools:multiz .

