@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:pretextmap a schema1:SoftwareApplication ;
    schema1:description "Paired REad TEXTure Mapper. Converts SAM formatted read pairs into genome contact maps." ;
    schema1:license "MIT" ;
    schema1:name "pretextmap" ;
    schema1:url "https://github.com/wtsi-hpag/PretextMap" .

