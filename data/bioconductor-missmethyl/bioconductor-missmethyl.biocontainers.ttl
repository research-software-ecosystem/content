        "Genome, Human",
        "Humans",
        "Methylated DNA immunoprecipitation",
        "Oligonucleotide Array Sequence Analysis",
        "Sequencing" ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-missmethyl" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/missMethyl.html" .

