@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-missmethyl a schema1:SoftwareApplication ;
    schema1:description "Analysing Illumina HumanMethylation BeadChip Data" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/missMethyl_1.40.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/missMethyl/missMethyl_1.40.0.tar.gz', 'https://bioarchive.galaxyproject.org/missMethyl_1.40.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-missmethyl/bioconductor-missmethyl_1.40.0_src_all.tar.gz']" ;
    schema1:identifier biotools:missmethyl ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-missmethyl" ;
    schema1:softwareVersion "1.40.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/missMethyl.html" ;
    spdx:builtFrom biotools:missmethyl .

