@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:aliscore a schema1:SoftwareApplication ;
    schema1:description "Aliscore is designed to filter alignment ambiguous or randomly similar sites in multiple sequence alignments (msa)." ;
    schema1:keywords "Genetics",
        "Genomics",
        "Phylogenetics",
        "Sequence Alignment" ;
    schema1:license "GPL-2.0-only" ;
    schema1:name "aliscore" ;
    schema1:url "https://www.zfmk.de/en/research/research-centres-and-groups/aliscore" .

