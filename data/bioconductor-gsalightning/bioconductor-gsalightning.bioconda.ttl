@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-gsalightning a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btw349" ;
    schema1:description "Fast Permutation-based Gene Set Analysis" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/GSALightning_1.38.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/GSALightning/GSALightning_1.38.0.tar.gz', 'https://bioarchive.galaxyproject.org/GSALightning_1.38.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-gsalightning/bioconductor-gsalightning_1.38.0_src_all.tar.gz']" ;
    schema1:identifier biotools:gsalightning ;
    schema1:license "GPL (>=2)" ;
    schema1:name "bioconductor-gsalightning" ;
    schema1:softwareVersion "1.38.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/GSALightning.html" ;
    spdx:builtFrom biotools:gsalightning .

