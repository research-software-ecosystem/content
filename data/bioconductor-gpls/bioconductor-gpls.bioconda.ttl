@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-gpls a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1198/106186005X47697" ;
    schema1:description "Classification using generalized partial least squares" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/gpls_1.82.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/gpls/gpls_1.82.0.tar.gz', 'https://bioarchive.galaxyproject.org/gpls_1.82.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-gpls/bioconductor-gpls_1.82.0_src_all.tar.gz']" ;
    schema1:identifier biotools:gpls ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-gpls" ;
    schema1:softwareVersion "1.82.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/gpls.html" ;
    spdx:builtFrom biotools:gpls .

