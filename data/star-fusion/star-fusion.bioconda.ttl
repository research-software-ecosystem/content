@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:star-fusion a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s13059-019-1842-9" ;
    schema1:description "STAR-Fusion fusion variant caller. All dependencies required to run FusionInspector and FusionAnnotator are included." ;
    schema1:downloadUrl "https://github.com/STAR-Fusion/STAR-Fusion/releases/download/STAR-Fusion-v1.15.1/STAR-Fusion-v1.15.1.FULL.tar.gz" ;
    schema1:identifier biotools:star-fusion ;
    schema1:license "BSD-3-Clause" ;
    schema1:name "star-fusion" ;
    schema1:softwareHelp "https://github.com/STAR-Fusion/STAR-Fusion/wiki" ;
    schema1:softwareVersion "1.15.1" ;
    schema1:url "https://github.com/STAR-Fusion/STAR-Fusion" ;
    spdx:builtFrom biotools:star-fusion .

