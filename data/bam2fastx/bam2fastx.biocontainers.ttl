@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bam2fastx a schema1:SoftwareApplication ;
    schema1:description "Converting and demultiplexing of PacBio BAM files into gzipped fasta and fastq files" ;
    schema1:license "BSD-3-Clause-Clear" ;
    schema1:name "bam2fastx" ;
    schema1:url "https://github.com/PacificBiosciences/bam2fastx" .

