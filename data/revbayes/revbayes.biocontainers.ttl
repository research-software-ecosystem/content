@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:revbayes a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/sysbio/syw021" ;
    schema1:description "Bayesian phylogenetic inference using probabilistic graphical models and an interactive language." ;
    schema1:identifier biotools:revbayes ;
    schema1:keywords "Applied mathematics",
        "Bayes Theorem",
        "Classification",
        "Models, Biological",
        "Phylogenetics",
        "Phylogeny",
        "Statistics and probability" ;
    schema1:license "GPL-3.0" ;
    schema1:name "revbayes" ;
    schema1:url "https://github.com/revbayes" .

