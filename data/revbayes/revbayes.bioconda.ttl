@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:revbayes a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/sysbio/syu039",
        "doi:10.1093/sysbio/syw021" ;
    schema1:description "Bayesian Phylogenetic Inference Using Graphical Models and an Interactive Model-Specification Language." ;
    schema1:downloadUrl "https://github.com/revbayes/revbayes/archive/refs/tags/v1.3.2.tar.gz" ;
    schema1:identifier biotools:revbayes ;
    schema1:license "GPL-3.0-or-later" ;
    schema1:name "revbayes" ;
    schema1:softwareHelp "https://revbayes.github.io/tutorials" ;
    schema1:softwareVersion "1.3.2" ;
    schema1:url "https://revbayes.github.io" ;
    spdx:builtFrom biotools:revbayes .

