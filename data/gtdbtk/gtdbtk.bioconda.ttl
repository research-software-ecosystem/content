@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:gtdbtk a schema1:SoftwareApplication ;
    schema1:author "aaronmussig",
        "pchaumeil" ;
    schema1:citation "doi:10.1093/bioinformatics/btz848" ;
    schema1:description "A toolkit for assigning objective taxonomic classifications to bacterial and archaeal genomes." ;
    schema1:downloadUrl "https://pypi.org/packages/source/g/gtdbtk/gtdbtk-2.7.1.tar.gz" ;
    schema1:identifier biotools:GTDB-Tk ;
    schema1:license "GPL-3.0-or-later" ;
    schema1:maintainer "aaronmussig",
        "pchaumeil" ;
    schema1:name "gtdbtk" ;
    schema1:softwareHelp "https://ecogenomics.github.io/GTDBTk" ;
    schema1:softwareVersion "2.7.1" ;
    schema1:url "https://github.com/Ecogenomics/GTDBTk" ;
    spdx:builtFrom biotools:GTDB-Tk .

