@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:gtdbtk a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btz848" ;
    schema1:description "A toolkit for assigning objective taxonomic classifications to bacterial and archaeal genomes." ;
    schema1:keywords "Genetics",
        "Genomics",
        "Metagenome",
        "Phylogenetics" ;
    schema1:license "GPL-3.0" ;
    schema1:name "gtdbtk" ;
    schema1:url "https://github.com/Ecogenomics/GTDBTk" .

