@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-interpretmsspectrum a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1021/acs.analchem.6b02743" ;
    schema1:description "Annotate and interpret deconvoluted mass spectra (mass*intensity pairs) from high resolution mass spectrometry devices." ;
    schema1:keywords "Gas Chromatography-Mass Spectrometry",
        "Mass spectra",
        "Mass spectrometry",
        "Metabolomics",
        "Molecular Weight" ;
    schema1:license "GPL-3" ;
    schema1:name "r-interpretmsspectrum" ;
    schema1:url "https://cran.r-project.org/package=InterpretMSSpectrum" .

