@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:canu a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1101/gr.215087.116" ;
    schema1:description "De-novo assembly tool for long read chemistry like nanopore data and pacbio data." ;
    schema1:identifier biotools:canu ;
    schema1:keywords "Animals",
        "Contig Mapping",
        "Drosophila melanogaster",
        "Genome, Bacterial",
        "Genomics",
        "Humans",
        "Repetitive Sequences, Nucleic Acid",
        "Sequence Analysis, DNA" ;
    schema1:license "GPL-2.0+" ;
    schema1:name "canu" ;
    schema1:url "https://github.com/marbl/canu" .

