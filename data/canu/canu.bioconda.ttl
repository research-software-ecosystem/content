@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:canu a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nbt.4277",
        "doi:10.1101/gr.215087.116",
        "doi:10.1101/gr.263566.120" ;
    schema1:description "Canu is a fork of the Celera Assembler designed for high-noise single-molecule sequencing." ;
    schema1:identifier biotools:canu ;
    schema1:license "GPL-2.0-or-later and others" ;
    schema1:name "canu" ;
    schema1:softwareHelp "https://canu.readthedocs.org" ;
    schema1:softwareVersion "2.3" ;
    schema1:url "https://github.com/marbl/canu" ;
    spdx:builtFrom biotools:canu .

