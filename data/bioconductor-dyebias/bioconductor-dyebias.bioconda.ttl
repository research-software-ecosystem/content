@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-dyebias a schema1:SoftwareApplication ;
    schema1:description "The GASSCO method for correcting for slide-dependent gene-specific dye bias" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/dyebias_1.70.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/dyebias/dyebias_1.70.0.tar.gz', 'https://bioarchive.galaxyproject.org/dyebias_1.70.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-dyebias/bioconductor-dyebias_1.70.0_src_all.tar.gz']" ;
    schema1:identifier biotools:dyebias ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-dyebias" ;
    schema1:softwareVersion "1.70.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/dyebias.html" ;
    spdx:builtFrom biotools:dyebias .

