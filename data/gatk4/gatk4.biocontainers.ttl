@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:gatk4 a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1101/gr.107524.110" ;
    schema1:description "Genome analysis toolkit (gatk4)" ;
    schema1:identifier biotools:gatk ;
    schema1:keywords "Base Sequence",
        "Genetic variation",
        "Genome",
        "Genomics",
        "Sequence Analysis, DNA",
        "Sequence analysis",
        "Sequencing",
        "Workflows" ;
    schema1:license "BSD 3-Clause" ;
    schema1:name "gatk4" ;
    schema1:url "https://www.broadinstitute.org/gatk/" .

