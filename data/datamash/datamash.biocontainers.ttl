@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:datamash a schema1:SoftwareApplication ;
    schema1:description "Gnu datamash is a command-line program which performs basic numeric,textual and statistical operations on input textual data files." ;
    schema1:license "GPL-3.0" ;
    schema1:name "datamash" ;
    schema1:url "http://ftpmirror.gnu.org/datamash/" .

