@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-mvcclass a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Model-View-Controller (MVC) Classes" ;
    schema1:identifier biotools:mvcclass ;
    schema1:keywords "Computational Biology",
        "Data management",
        "Gene Expression Profiling",
        "Genomics",
        "High-Throughput Screening Assays",
        "Programming Languages",
        "User-Computer Interface" ;
    schema1:license "LGPL" ;
    schema1:name "bioconductor-mvcclass" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/MVCClass.html" .

