@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:extract_fasta_seq a schema1:SoftwareApplication ;
    schema1:author "linzhi2013" ;
    schema1:description "To extract specific fasta sequences from a fasta file." ;
    schema1:downloadUrl "https://pypi.io/packages/source/e/extract_fasta_seq/extract_fasta_seq-0.0.1.tar.gz" ;
    schema1:identifier biotools:extract_fasta_seq ;
    schema1:license "GNU General Public v3 or later (GPLv3+)" ;
    schema1:maintainer "linzhi2013" ;
    schema1:name "extract_fasta_seq" ;
    schema1:softwareVersion "0.0.1" ;
    schema1:url "https://github.com/linzhi2013/extract_fasta_seq" ;
    spdx:builtFrom biotools:extract_fasta_seq .

