@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:chap a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1016/j.jmb.2019.06.003" ;
    schema1:description "CHAP is a tool for the functional annotation of ion channel structures" ;
    schema1:keywords "Biomimetics",
        "Cell Membrane",
        "Computer Simulation",
        "Hydrophobic and Hydrophilic Interactions",
        "Ion Channel Gating",
        "Ion Channels",
        "Molecular Dynamics",
        "Molecular Dynamics Simulation",
        "Protein Conformation",
        "Water" ;
    schema1:license "MIT" ;
    schema1:name "chap" ;
    schema1:url "https://github.com/channotation/chap" .

