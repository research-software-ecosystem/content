      "sc:citation": {
        "@id": "https://doi.org/10.18129/B9.bioc.SpatialArtifacts"
      },
      "sc:contributor": "Stephanie C. Hicks",
      "sc:description": "SpatialArtifacts provides a data-driven two-step workflow to identify, classify, and handle spatial artifacts in spatial transcriptomics data. The package combines median absolute deviation (MAD)-based outlier detection with morphological image processing (fill, outline, and star patterns) to detect edge and interior artifacts. It supports multiple platforms including 10x Genomics Visium (standard and HD), allowing for consistent quality control across different spatial resolutions.",
      "sc:license": "Artistic-2.0",
      "sc:name": "SpatialArtifacts",
