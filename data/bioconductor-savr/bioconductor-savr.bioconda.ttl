@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-savr a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Parse and analyze Illumina SAV files" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.17/bioc/src/contrib/savR_1.37.0.tar.gz', 'https://bioconductor.org/packages/3.17/bioc/src/contrib/Archive/savR/savR_1.37.0.tar.gz', 'https://bioarchive.galaxyproject.org/savR_1.37.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-savr/bioconductor-savr_1.37.0_src_all.tar.gz']" ;
    schema1:identifier biotools:savr ;
    schema1:license "AGPL-3" ;
    schema1:name "bioconductor-savr" ;
    schema1:softwareVersion "1.37.0" ;
    schema1:url "https://bioconductor.org/packages/3.17/bioc/html/savR.html" ;
    spdx:builtFrom biotools:savr .

