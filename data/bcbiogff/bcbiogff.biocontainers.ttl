@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bcbiogff a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btp163" ;
    schema1:description "Read and write generic feature format (gff) with biopython integration." ;
    schema1:identifier biotools:biopython ;
    schema1:keywords "Bioinformatics",
        "Computational Biology",
        "Computational biology",
        "Data management",
        "Databases, Factual",
        "Internet",
        "Programming Languages",
        "Software engineering" ;
    schema1:license "Biopython License Agreement" ;
    schema1:name "bcbiogff" ;
    schema1:url "https://github.com/chapmanb/bcbb/blob/master/gff" .

