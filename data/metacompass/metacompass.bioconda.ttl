@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:metacompass a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1101/212506" ;
    schema1:description "MetaCompass: Reference-guided Assembly of Metagenomes." ;
    schema1:downloadUrl "['https://ftp.nandesyn.single-cell.cn/MetaCompass-1.12.tar.gz', 'https://github.com/marbl/MetaCompass/archive/refs/tags/v1.12.tar.gz']" ;
    schema1:identifier biotools:MetaCompass ;
    schema1:license "Artistic-License-2.0" ;
    schema1:name "metacompass" ;
    schema1:softwareHelp "https://github.com/marbl/MetaCompass/wiki" ;
    schema1:softwareVersion "1.12" ;
    schema1:url "https://github.com/marbl/MetaCompass" ;
    spdx:builtFrom biotools:MetaCompass .

