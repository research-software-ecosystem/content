@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-bigmemory a schema1:SoftwareApplication ;
    schema1:description "Create, store, access, and manipulate massive matrices. Matrices are allocated to shared memory and may use memory-mapped files.  Packages 'biganalytics', 'bigtabulate', 'synchronicity', and 'bigalgebra' provide advanced functionality." ;
    schema1:license "LGPL-3 | Apache-2.0" ;
    schema1:name "r-bigmemory" ;
    schema1:url "None" .

