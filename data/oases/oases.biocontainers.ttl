@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:oases a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/bts094" ;
    schema1:description "De novo transcriptome assembler for short reads" ;
    schema1:identifier biotools:oases ;
    schema1:keywords "Alternative Splicing",
        "Animals",
        "Gene Expression Profiling",
        "High-Throughput Nucleotide Sequencing",
        "Humans",
        "Mice",
        "RNA, Messenger",
        "RNA-Seq",
        "RNA-seq",
        "Sequence Analysis, RNA",
        "Sequence assembly",
        "Transcriptome",
        "Transcriptomics",
        "Whole genome sequencing" ;
    schema1:license "GPL" ;
    schema1:name "oases" ;
    schema1:url "https://github.com/dzerbino/oases" .

