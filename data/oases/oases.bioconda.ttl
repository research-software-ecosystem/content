@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:oases a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/bts094" ;
    schema1:description "De novo transcriptome assembler for short reads." ;
    schema1:identifier biotools:oases ;
    schema1:license "GPL-3.0-or-later" ;
    schema1:name "oases" ;
    schema1:softwareHelp "https://github.com/dzerbino/oases/blob/0.2.09/README.md" ;
    schema1:softwareVersion "0.2.09" ;
    schema1:url "https://github.com/dzerbino/oases" ;
    spdx:builtFrom biotools:oases .

