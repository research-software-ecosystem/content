@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:merfin a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/s41592-022-01445-y",
        "doi:10.1101/2022.12.01.518724" ;
    schema1:description "Improved variant filtering and polishing via k-mer validation." ;
    schema1:identifier biotools:merfin ;
    schema1:license "Apache-2.0" ;
    schema1:name "merfin" ;
    schema1:softwareHelp "https://github.com/arangrhie/merfin/blob/v1.1/README.md" ;
    schema1:softwareVersion "1.1" ;
    schema1:url "https://github.com/arangrhie/merfin" ;
    spdx:builtFrom biotools:merfin .

