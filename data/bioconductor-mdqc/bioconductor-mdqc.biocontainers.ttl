@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-mdqc a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btm487" ;
    schema1:description "Mahalanobis Distance Quality Control for microarrays" ;
    schema1:identifier biotools:mdqc ;
    schema1:keywords "Data Interpretation, Statistical",
        "Data quality management",
        "Databases, Genetic",
        "Gene Expression Profiling",
        "Gene expression",
        "Information Storage and Retrieval",
        "Microarray experiment",
        "Multivariate Analysis",
        "Oligonucleotide Array Sequence Analysis",
        "Quality Control",
        "Reproducibility of Results",
        "Sensitivity and Specificity" ;
    schema1:license "LGPL (>= 2)" ;
    schema1:name "bioconductor-mdqc" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/mdqc.html" .

