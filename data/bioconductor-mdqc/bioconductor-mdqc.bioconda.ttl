@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-mdqc a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btm487" ;
    schema1:description "Mahalanobis Distance Quality Control for microarrays" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/mdqc_1.68.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/mdqc/mdqc_1.68.0.tar.gz', 'https://bioarchive.galaxyproject.org/mdqc_1.68.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-mdqc/bioconductor-mdqc_1.68.0_src_all.tar.gz']" ;
    schema1:identifier biotools:mdqc ;
    schema1:license "LGPL (>= 2)" ;
    schema1:name "bioconductor-mdqc" ;
    schema1:softwareVersion "1.68.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/mdqc.html" ;
    spdx:builtFrom biotools:mdqc .

