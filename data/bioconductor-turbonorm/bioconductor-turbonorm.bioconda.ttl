@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-turbonorm a schema1:SoftwareApplication ;
    schema1:description "A fast scatterplot smoother suitable for microarray normalization" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/TurboNorm_1.54.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/TurboNorm/TurboNorm_1.54.0.tar.gz', 'https://bioarchive.galaxyproject.org/TurboNorm_1.54.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-turbonorm/bioconductor-turbonorm_1.54.0_src_all.tar.gz']" ;
    schema1:identifier biotools:turbonorm ;
    schema1:license "LGPL" ;
    schema1:name "bioconductor-turbonorm" ;
    schema1:softwareVersion "1.54.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/TurboNorm.html" ;
    spdx:builtFrom biotools:turbonorm .

