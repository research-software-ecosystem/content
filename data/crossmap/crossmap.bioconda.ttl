@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:crossmap a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btt730" ;
    schema1:description "CrossMap is a program for convenient conversion of genome coordinates and genomeannotation files between assemblies." ;
    schema1:downloadUrl "https://github.com/liguowang/CrossMap/archive/v0.7.3.tar.gz" ;
    schema1:identifier biotools:crossmap ;
    schema1:license "GPL-3.0-or-later" ;
    schema1:name "crossmap" ;
    schema1:softwareHelp "https://crossmap.readthedocs.io/en/latest" ;
    schema1:softwareVersion "0.7.3" ;
    schema1:url "https://crossmap.sourceforge.net" ;
    spdx:builtFrom biotools:crossmap .

