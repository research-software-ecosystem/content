@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:crossmap a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btt730" ;
    schema1:description "Crossmap is a program for convenient conversion of genome coordinates and genomeannotation files between assemblies." ;
    schema1:keywords "Animals",
        "Base Sequence",
        "Genome",
        "Genomics",
        "High-Throughput Nucleotide Sequencing",
        "Humans",
        "Mice",
        "Sequence Alignment" ;
    schema1:license "GPL-2.0" ;
    schema1:name "crossmap" ;
    schema1:url "http://crossmap.sourceforge.net" .

