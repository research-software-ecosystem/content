@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-cellarepertorium a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18129/b9.bioc.cellarepertorium" ;
    schema1:description "Methods to cluster and analyze high-throughput single cell immune cell repertoires, especially from the 10X Genomics VDJ solution. Contains an R interface to CD-HIT (Li and Godzik 2006). Methods to visualize and analyze paired heavy-light chain data. Tests for specific expansion, as well as omnibus oligoclonality under hypergeometric models." ;
    schema1:keywords "Clustering",
        "Genomics",
        "Transcriptomics" ;
    schema1:license "GPL-3.0" ;
    schema1:name "bioconductor-cellarepertorium" ;
    schema1:url "https://bioconductor.org/packages/3.12/bioc/html/CellaRepertorium.html" .

