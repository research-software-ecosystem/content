@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:fasten a schema1:SoftwareApplication ;
    schema1:description "Perform random operations on fastq files, using unix streaming. Secure your analysis with Fasten!" ;
    schema1:license "MIT" ;
    schema1:name "fasten" ;
    schema1:url "https://github.com/lskatz/fasten" .

