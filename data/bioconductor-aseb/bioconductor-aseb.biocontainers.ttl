@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-aseb a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/gks437" ;
    schema1:description "Predict Acetylated Lysine Sites" ;
    schema1:identifier biotools:aseb ;
    schema1:keywords "Acetylation",
        "Acetyltransferases",
        "Humans",
        "Internet",
        "Lysine",
        "Protein Interaction Mapping",
        "Protein Processing, Post-Translational",
        "Protein sites, features and motifs",
        "Proteins",
        "Proteomics",
        "Tumor Suppressor Protein p53",
        "User-Computer Interface" ;
    schema1:license "GPL-3.0" ;
    schema1:name "bioconductor-aseb" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/ASEB.html" .

