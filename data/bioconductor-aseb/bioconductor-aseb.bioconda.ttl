@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-aseb a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/gks437" ;
    schema1:description "Predict Acetylated Lysine Sites" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/ASEB_1.54.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/ASEB/ASEB_1.54.0.tar.gz', 'https://bioarchive.galaxyproject.org/ASEB_1.54.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-aseb/bioconductor-aseb_1.54.0_src_all.tar.gz']" ;
    schema1:identifier biotools:aseb ;
    schema1:license "GPL (>= 3)" ;
    schema1:name "bioconductor-aseb" ;
    schema1:softwareVersion "1.54.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/ASEB.html" ;
    spdx:builtFrom biotools:aseb .

