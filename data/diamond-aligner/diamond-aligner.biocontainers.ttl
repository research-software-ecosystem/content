@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:diamond-aligner a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3176" ;
    schema1:description "Accelerated blast compatible local sequence aligner" ;
    schema1:keywords "Base Sequence",
        "Humans",
        "Metagenomics",
        "Microbiota",
        "Sensitivity and Specificity",
        "Sequence Alignment",
        "Sequence Analysis, DNA" ;
    schema1:license "BSD-3-clause" ;
    schema1:name "diamond-aligner" ;
    schema1:url "https://github.com/bbuchfink/diamond" .

