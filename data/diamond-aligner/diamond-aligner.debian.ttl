@prefix debianmed: <https://salsa.debian.org/med-team/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

debianmed:diamond-aligner a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3176" ;
    schema1:description "accelerated BLAST compatible local sequence aligner" ;
    schema1:identifier "bio.tools:Diamond",
        "conda:bioconda:diamond",
        "omictools:OMICS_08011",
        "scicrunch:SCR_016071" ;
    schema1:license "unknown" ;
    schema1:name "diamond-aligner" ;
    schema1:softwareVersion "2.1.14" ;
    schema1:url "https://github.com/bbuchfink/diamond" ;
    spdx:builtFrom "Diamond" .

