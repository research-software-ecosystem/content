@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:vcftools a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btr330" ;
    schema1:description "Provide easily accessible methods for working with complex genetic variation data in the form of vcf files." ;
    schema1:identifier biotools:vcftools ;
    schema1:keywords "Alleles",
        "Genetic Variation",
        "Genetic variation",
        "Genome, Human",
        "Genomics",
        "Genotype",
        "Humans",
        "Information Storage and Retrieval" ;
    schema1:license "GPL-3.0" ;
    schema1:name "vcftools" ;
    schema1:url "https://github.com/vcftools/vcftools" .

