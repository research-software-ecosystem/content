@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:vcftools a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btr330" ;
    schema1:description "A set of tools written in Perl and C++ for working with VCF files." ;
    schema1:downloadUrl "https://github.com/vcftools/vcftools/archive/v0.1.17.tar.gz" ;
    schema1:identifier biotools:vcftools ;
    schema1:license "LGPL-3.0-only" ;
    schema1:name "vcftools" ;
    schema1:softwareHelp "https://vcftools.github.io" ;
    schema1:softwareVersion "0.1.17" ;
    schema1:url "https://github.com/vcftools/vcftools" ;
    spdx:builtFrom biotools:vcftools .

