@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-browserviz a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1007/978-1-4302-4426-4_17" ;
    schema1:description "BrowserViz: interactive R/browser graphics using websockets and JSON" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/BrowserViz_2.32.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/BrowserViz/BrowserViz_2.32.0.tar.gz', 'https://bioarchive.galaxyproject.org/BrowserViz_2.32.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-browserviz/bioconductor-browserviz_2.32.0_src_all.tar.gz']" ;
    schema1:identifier biotools:browserviz ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-browserviz" ;
    schema1:softwareVersion "2.32.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/BrowserViz.html" ;
    spdx:builtFrom biotools:browserviz .

