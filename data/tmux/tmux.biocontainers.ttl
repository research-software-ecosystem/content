@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:tmux a schema1:SoftwareApplication ;
    schema1:description "Tmux is a terminal multiplexer" ;
    schema1:license "BSD" ;
    schema1:name "tmux" ;
    schema1:url "https://github.com/tmux/tmux/" .

