@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:pytest-xdist a schema1:SoftwareApplication ;
    schema1:description "Py.test xdist plugin for distributed testing and loop-on-failing modes" ;
    schema1:license "MIT" ;
    schema1:name "pytest-xdist" ;
    schema1:url "https://github.com/pytest-dev/pytest-xdist" .

