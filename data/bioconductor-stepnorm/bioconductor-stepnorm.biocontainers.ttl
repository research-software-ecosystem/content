@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-stepnorm a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1109/IEMBS.2004.1403830" ;
    schema1:description "Stepwise normalization functions for cDNA microarrays" ;
    schema1:identifier biotools:stepnorm ;
    schema1:keywords "Gene transcripts",
        "Microarray experiment" ;
    schema1:license "LGPL" ;
    schema1:name "bioconductor-stepnorm" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/stepNorm.html" .

