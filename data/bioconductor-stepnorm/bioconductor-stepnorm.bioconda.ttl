@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-stepnorm a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1109/IEMBS.2004.1403830" ;
    schema1:description "Stepwise normalization functions for cDNA microarrays" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/stepNorm_1.78.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/stepNorm/stepNorm_1.78.0.tar.gz', 'https://bioarchive.galaxyproject.org/stepNorm_1.78.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-stepnorm/bioconductor-stepnorm_1.78.0_src_all.tar.gz']" ;
    schema1:identifier biotools:stepnorm ;
    schema1:license "LGPL" ;
    schema1:name "bioconductor-stepnorm" ;
    schema1:softwareVersion "1.78.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/stepNorm.html" ;
    spdx:builtFrom biotools:stepnorm .

