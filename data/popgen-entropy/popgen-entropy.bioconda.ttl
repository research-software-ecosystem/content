@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:popgen-entropy a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1101/2020.07.31.231514" ;
    schema1:description "This program is for inferring population structure from autopolyploid and mixed-ploidy individuals." ;
    schema1:downloadUrl "https://bitbucket.org/buerklelab/mixedploidy-entropy/get/550355eac120.zip" ;
    schema1:identifier biotools:popgen-entropy ;
    schema1:license "GPLv3" ;
    schema1:name "popgen-entropy" ;
    schema1:softwareVersion "2.0" ;
    schema1:url "https://bitbucket.org/buerklelab/mixedploidy-entropy/src/master/" ;
    spdx:builtFrom biotools:popgen-entropy .

