@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:popgen-entropy a schema1:SoftwareApplication ;
    schema1:description "This program is for inferring population structure from autopolyploid and mixed-ploidy individuals, similar to structure, but using genotype-likelihood data for low- to medium-coverage sequencing depth." ;
    schema1:identifier biotools:popgen-entropy ;
    schema1:license "BSD" ;
    schema1:name "popgen-entropy" ;
    schema1:url "https://bitbucket.org/buerklelab/mixedploidy-entropy/src/master/" .

