@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:opencfu a schema1:SoftwareApplication ;
    schema1:description "Count cell colonies (cfus) on agar plates by processing digital pictures" ;
    schema1:license "GPL-3.0" ;
    schema1:name "opencfu" ;
    schema1:url "https://github.com/qgeissmann/OpenCFU" .

