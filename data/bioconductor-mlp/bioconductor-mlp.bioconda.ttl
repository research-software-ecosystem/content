@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-mlp a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1007/978-3-642-24007-2_12" ;
    schema1:description "Mean Log P Analysis" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/MLP_1.54.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/MLP/MLP_1.54.0.tar.gz', 'https://bioarchive.galaxyproject.org/MLP_1.54.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-mlp/bioconductor-mlp_1.54.0_src_all.tar.gz']" ;
    schema1:identifier biotools:mlp ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-mlp" ;
    schema1:softwareVersion "1.54.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/MLP.html" ;
    spdx:builtFrom biotools:mlp .

