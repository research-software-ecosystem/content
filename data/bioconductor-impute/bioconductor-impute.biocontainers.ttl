@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-impute a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1007/978-3-642-57489-4_7" ;
    schema1:description "impute: Imputation for microarray data" ;
    schema1:identifier biotools:impute ;
    schema1:keywords "Gene expression",
        "Microarray experiment" ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-impute" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/impute.html" .

