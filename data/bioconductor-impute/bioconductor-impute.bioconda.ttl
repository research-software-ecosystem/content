@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-impute a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1007/978-3-642-57489-4_7" ;
    schema1:description "impute: Imputation for microarray data" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/impute_1.84.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/impute/impute_1.84.0.tar.gz', 'https://bioarchive.galaxyproject.org/impute_1.84.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-impute/bioconductor-impute_1.84.0_src_all.tar.gz']" ;
    schema1:identifier biotools:impute ;
    schema1:license "GPL-2.0-or-later" ;
    schema1:name "bioconductor-impute" ;
    schema1:softwareVersion "1.84.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/impute.html" ;
    spdx:builtFrom biotools:impute .

