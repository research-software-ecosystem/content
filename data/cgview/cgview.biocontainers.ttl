@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:cgview a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/gkn179" ;
    schema1:description "The cgview server generates graphical maps of circular genomes that can be used to visualize sequence conservation in the context of sequence features, imported analysis results, open reading frames and base composition plots. the server uses blast to compare the primary sequence of up to three genomes or sequence sets, aiding in the identification of conserved genome segments, instances of horizontal transfer or visualization of genome segments from newly obtained sequence reads." ;
    schema1:identifier biotools:cgview ;
    schema1:keywords "Chromosome Mapping",
        "Computer Graphics",
        "DNA, Circular",
        "Genome, Bacterial",
        "Genome, Chloroplast",
        "Genome, Mitochondrial",
        "Genomics",
        "Internet",
        "Mapping",
        "Plasmids",
        "Sequence Alignment",
        "Sequence analysis",
        "Sequence sites, features and motifs",
        "Sequencing" ;
    schema1:license "MIT" ;
    schema1:name "cgview" ;
    schema1:url "http://stothard.afns.ualberta.ca/cgview_server/" .

