@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:glpk a schema1:SoftwareApplication ;
    schema1:description "The GLPK (GNU Linear Programming Kit) package is intended for solving large-scale linear programming (LP), mixed integer programming (MIP), and other related problems. It is a set of routines written in ANSI C and organized in the form of a callable library." ;
    schema1:license "GNU General Public License 3.0" ;
    schema1:name "glpk" ;
    schema1:url "None" .

