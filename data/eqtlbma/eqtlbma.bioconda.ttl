@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:eqtlbma a schema1:SoftwareApplication ;
    schema1:description "Package to detect eQTLs jointly in multiple subgroups (e.g. tissues) via Bayesian Model Averaging." ;
    schema1:downloadUrl "https://github.com/timflutre/eqtlbma/archive/v1.3.3.tar.gz" ;
    schema1:identifier biotools:eQtlBma ;
    schema1:license "GPLv3" ;
    schema1:name "eqtlbma" ;
    schema1:softwareVersion "1.3.3" ;
    schema1:url "https://github.com/timflutre/eqtlbma" ;
    spdx:builtFrom biotools:eQtlBma .

