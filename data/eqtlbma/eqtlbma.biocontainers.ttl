@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:eqtlbma a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1371/journal.pgen.1003486" ;
    schema1:description "Package to detect eQTLs jointly in multiple subgroups (e.g. tissues) via Bayesian Model Averaging." ;
    schema1:identifier biotools:eQtlBma ;
    schema1:keywords "Chromosome Mapping",
        "Gene Expression",
        "Genetics",
        "Genome-Wide Association Study",
        "Mapping",
        "Models, Theoretical",
        "Organ Specificity",
        "Quantitative Trait Loci" ;
    schema1:license "GPL-3.0" ;
    schema1:name "eqtlbma" ;
    schema1:url "https://github.com/timflutre/eqtlbma" .

