@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:expat a schema1:SoftwareApplication ;
    schema1:description "Expat is an xml parser library written in c. it is a stream-oriented parser in which an application registers handlers for things the parser might find in the xml document (like start tags)." ;
    schema1:license "MIT" ;
    schema1:name "expat" ;
    schema1:url "https://downloads.sourceforge.net/project/expat/expat/2.1.0/expat-2.1.0.tar.gz" .

