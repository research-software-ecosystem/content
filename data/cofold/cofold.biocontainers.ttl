@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:cofold a schema1:SoftwareApplication ;
    schema1:description "An rna secondary structure prediction method that takes co-transcriptional folding into account." ;
    schema1:license "MIT-like" ;
    schema1:name "cofold" ;
    schema1:url "http://www.e-rna.org/cofold/" .

