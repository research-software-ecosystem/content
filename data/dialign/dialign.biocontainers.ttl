@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:dialign a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/gkt283" ;
    schema1:description "Multiple alignment program which assembles a global sequence alignment from gap-free local pairwise alignments. this method could be especially useful when comparing large sequences that have only local similarities." ;
    schema1:identifier biotools:dialign ;
    schema1:keywords "Genetics",
        "Internet",
        "Sequence Alignment",
        "Sequence Analysis, DNA",
        "Sequence Analysis, Protein",
        "Sequence analysis",
        "Sequence assembly" ;
    schema1:license "LGPL-2.1+" ;
    schema1:name "dialign" ;
    schema1:url "http://dialign.gobics.de" .

