@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:musicc a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s13059-015-0610-8" ;
    schema1:description "Musicc: a marker genes based framework for metagenomic normalization and accurate profiling of gene abundances in the microbiome." ;
    schema1:keywords "Cell Proliferation",
        "High-Throughput Nucleotide Sequencing",
        "Humans",
        "Machine Learning",
        "Metagenomics",
        "Microbiota",
        "Sequence Analysis, DNA" ;
    schema1:license "BSD 3-Clause \"New\" or \"Revised\" License" ;
    schema1:name "musicc" ;
    schema1:url "https://github.com/borenstein-lab/MUSiCC" .

