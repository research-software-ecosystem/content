@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-quantsmooth a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Quantile smoothing and genomic visualization of array data" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/quantsmooth_1.76.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/quantsmooth/quantsmooth_1.76.0.tar.gz', 'https://bioarchive.galaxyproject.org/quantsmooth_1.76.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-quantsmooth/bioconductor-quantsmooth_1.76.0_src_all.tar.gz']" ;
    schema1:identifier biotools:quantsmooth ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-quantsmooth" ;
    schema1:softwareVersion "1.76.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/quantsmooth.html" ;
    spdx:builtFrom biotools:quantsmooth .

