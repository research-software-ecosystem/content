@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:saint a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.1541" ;
    schema1:description "Filter high confidence interactions from spectral count data in affinity purification–mass spectrometry." ;
    schema1:identifier biotools:saint ;
    schema1:keywords "Chromatography, Affinity",
        "Computational Biology",
        "Computer Simulation",
        "Interactions",
        "Mass Spectrometry",
        "Mass spectrometry",
        "Peptides",
        "Probability",
        "Protein Binding",
        "Protein Interaction Mapping",
        "Proteins",
        "Proteomics" ;
    schema1:license "GPL-3.0+" ;
    schema1:name "saint" ;
    schema1:url "http://saint-apms.sourceforge.net/Main.html" .

