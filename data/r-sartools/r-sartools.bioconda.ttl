@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:r-sartools a schema1:SoftwareApplication ;
    schema1:author "ArneKr",
        "FrodePedersen",
        "MathiasHaudgaard",
        "bgruening",
        "daler",
        "hvaret",
        "jdblischak",
        "johanneskoester" ;
    schema1:description "Statistical Analysis of RNA-Seq data." ;
    schema1:downloadUrl "https://github.com/PF2-pasteur-fr/SARTools/archive/v1.8.2.tar.gz" ;
    schema1:identifier biotools:sartools ;
    schema1:license "GPL-2.0-or-later" ;
    schema1:maintainer "ArneKr",
        "FrodePedersen",
        "MathiasHaudgaard",
        "bgruening",
        "daler",
        "hvaret",
        "jdblischak",
        "johanneskoester" ;
    schema1:name "r-sartools" ;
    schema1:softwareVersion "1.8.2" ;
    schema1:url "https://github.com/PF2-pasteur-fr/SARTools" ;
    spdx:builtFrom biotools:sartools .

