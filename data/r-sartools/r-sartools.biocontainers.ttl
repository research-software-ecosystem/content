@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-sartools a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1371/journal.pone.0157022" ;
    schema1:description "R package dedicated to the differential analysis of rna-seq data. it provides tools to generate descriptive and diagnostic graphs, to run the differential analysis with one of the well known deseq2 or edger packages and to export the results into easily readable tab-delimited files. it also facilitates the generation of a html report which displays all the figures produced, explains the statistical methods and gives the results of the differential analysis." ;
    schema1:identifier biotools:sartools ;
    schema1:keywords "Computational Biology",
        "Gene Expression Profiling",
        "High-Throughput Nucleotide Sequencing",
        "Humans",
        "RNA",
        "RNA-Seq",
        "Sequence Analysis, RNA",
        "Statistics and probability",
        "Transcriptomics" ;
    schema1:license "GPL-2.0" ;
    schema1:name "r-sartools" ;
    schema1:url "https://github.com/PF2-pasteur-fr/SARTools" .

