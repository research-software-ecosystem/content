@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bs-seeker2 a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/1471-2164-14-774" ;
    schema1:description "BS Seeker 2 is a seamless and versatile pipeline for accurately and fast mapping the bisulfite-treated short reads." ;
    schema1:identifier biotools:bs-seeker2 ;
    schema1:keywords "CpG Islands",
        "DNA Methylation",
        "Genome, Human",
        "Genomics",
        "High-Throughput Nucleotide Sequencing",
        "Humans",
        "Mapping",
        "Methylated DNA immunoprecipitation",
        "Nucleic acid structure analysis",
        "Sequence Alignment",
        "Sequence Analysis, DNA",
        "Sequencing",
        "Sulfites" ;
    schema1:license "MIT" ;
    schema1:name "bs-seeker2" ;
    schema1:url "http://pellegrini.mcdb.ucla.edu/BS_Seeker2/" .

