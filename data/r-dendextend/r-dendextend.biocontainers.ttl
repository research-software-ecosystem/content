@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-dendextend a schema1:SoftwareApplication ;
    schema1:description "Offers a set of functions for extending dendrogram objects in R, letting you visualize and compare trees of hierarchical clusterings. You can (1) Adjust a tree's graphical parameters - the color, size, type, etc of its branches, nodes and labels. (2) Visually and statistically compare different dendrograms to one another." ;
    schema1:license "GPL-2 | GPL-3" ;
    schema1:name "r-dendextend" ;
    schema1:url "None" .

