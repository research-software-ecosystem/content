@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:connectome-workbench a schema1:SoftwareApplication ;
    schema1:description "Connectome Workbench is an open source, freely available visualization and discovery tool used to map neuroimaging data, especially data generated by the Human Connectome Project" ;
    schema1:license "GPL-2.0" ;
    schema1:name "connectome-workbench" ;
    schema1:url "https://github.com/Washington-University/workbench" .

