@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-relations a schema1:SoftwareApplication ;
    schema1:description "Data structures and algorithms for k-ary relations with arbitrary domains, featuring relational algebra, predicate functions, and fitters for consensus relations." ;
    schema1:license "GPL-2.0" ;
    schema1:name "r-relations" ;
    schema1:url "https://CRAN.R-project.org/package=relations" .

