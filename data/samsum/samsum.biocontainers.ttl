@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:samsum a schema1:SoftwareApplication ;
    schema1:description "A light-weight python package for summarizing sequence coverage from SAM and BAM files" ;
    schema1:license "GGPL-3.0" ;
    schema1:name "samsum" ;
    schema1:url "https://github.com/hallamlab/samsum" .

