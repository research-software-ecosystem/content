@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-synergyfinder a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1007/978-1-4939-7493-1_17",
        "doi:10.1093/bioinformatics/btx162" ;
    schema1:description "Calculate and Visualize Synergy Scores for Drug Combinations" ;
    schema1:identifier biotools:synergyfinder ;
    schema1:keywords "Antineoplastic Agents",
        "Antineoplastic Combined Chemotherapy Protocols",
        "Cell Line, Tumor",
        "Computational biology",
        "Drug Screening Assays, Antitumor",
        "Drug Synergism",
        "High-Throughput Screening Assays",
        "Humans",
        "Neoplasms" ;
    schema1:license "Mozilla Public License 2.0" ;
    schema1:name "bioconductor-synergyfinder" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/synergyfinder.html" .

