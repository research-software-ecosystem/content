@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-synergyfinder a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btx162" ;
    schema1:description "Calculate and Visualize Synergy Scores for Drug Combinations" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/synergyfinder_3.14.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/synergyfinder/synergyfinder_3.14.0.tar.gz', 'https://bioarchive.galaxyproject.org/synergyfinder_3.14.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-synergyfinder/bioconductor-synergyfinder_3.14.0_src_all.tar.gz']" ;
    schema1:identifier biotools:synergyfinder ;
    schema1:license "Mozilla Public License 2.0" ;
    schema1:name "bioconductor-synergyfinder" ;
    schema1:softwareVersion "3.14.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/synergyfinder.html" ;
    spdx:builtFrom biotools:synergyfinder .

