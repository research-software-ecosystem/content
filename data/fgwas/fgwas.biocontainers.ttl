@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:fgwas a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1016/j.ajhg.2014.03.004" ;
    schema1:description "fgwas is a command line tool for integrating functional genomic information into a genome-wide association study (GWAS)." ;
    schema1:keywords "Functional genomics",
        "Genomics" ;
    schema1:license "GPL-2.0" ;
    schema1:name "fgwas" ;
    schema1:url "https://github.com/joepickrell/fgwas" .

