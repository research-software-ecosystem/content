@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:dadi a schema1:SoftwareApplication ;
    schema1:description "Fit population genetic models using diffusion approximations to the allele frequency spectrum" ;
