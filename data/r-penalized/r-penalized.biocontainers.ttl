@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-penalized a schema1:SoftwareApplication ;
    schema1:description "Fitting possibly high dimensional penalized regression models. The penalty structure can be any combination of an L1 penalty (lasso and fused lasso), an L2 penalty (ridge) and a positivity constraint on the regression coefficients. The supported regression models are linear, logistic and Poisson regression and the Cox Proportional Hazards model. Cross-validation routines allow optimization of the tuning parameters." ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "r-penalized" ;
    schema1:url "https://CRAN.R-project.org/package=penalized" .

