@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-googlegenomics a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18129/b9.bioc.googlegenomics" ;
    schema1:description "Provides an R package to interact with the Google Genomics API." ;
    schema1:keywords "Genetics",
        "Genomics" ;
    schema1:license "Apache License (== 2.0) | file LICENSE" ;
    schema1:name "bioconductor-googlegenomics" ;
    schema1:url "https://bioconductor.org/packages/3.8/bioc/html/GoogleGenomics.html" .

