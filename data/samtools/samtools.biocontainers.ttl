@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:samtools a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btp352" ;
    schema1:description "A software package with various utilities for processing alignments in the sam format, including variant calling and alignment viewing." ;
    schema1:identifier biotools:samtools ;
    schema1:keywords "Base Sequence",
        "Computational Biology",
        "Genome",
        "Genomics",
        "Mapping",
        "Molecular Sequence Data",
        "Rare diseases",
        "Sequence Alignment",
        "Sequence Analysis, DNA",
        "Sequence analysis",
        "Sequencing" ;
    schema1:license "MIT" ;
    schema1:name "samtools" ;
    schema1:url "https://github.com/samtools/samtools" .

