@prefix debianmed: <https://salsa.debian.org/med-team/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

debianmed:samtools a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btp352" ;
    schema1:description "processing sequence alignments in SAM, BAM and CRAM formats" ;
    schema1:identifier "bio.tools:samtools",
        "conda:bioconda:samtools",
        "guix:samtools",
        "omictools:OMICS_00090",
        "scicrunch:SCR_002105" ;
    schema1:keywords "field::biology",
        "implemented-in::c",
        "interface::commandline",
        "network::client",
        "protocol::ftp",
        "protocol::http",
        "role::program",
        "scope::utility",
        "uitoolkit::ncurses",
        "use::analysing",
        "use::calculating",
        "use::filtering",
        "works-with::biological-sequence" ;
    schema1:license "unknown" ;
    schema1:name "samtools" ;
    schema1:softwareVersion "1.22.1" ;
    schema1:url "https://www.htslib.org/" ;
    spdx:builtFrom "samtools" .

