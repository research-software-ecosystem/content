@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:samtools a schema1:SoftwareApplication ;
    schema1:description "Tools for dealing with SAM, BAM and CRAM files" ;
    schema1:downloadUrl "https://github.com/samtools/samtools/releases/download/1.23.1/samtools-1.23.1.tar.bz2" ;
    schema1:identifier biotools:samtools ;
    schema1:license "MIT" ;
    schema1:name "samtools" ;
    schema1:softwareVersion "1.23.1" ;
    schema1:url "https://github.com/samtools/samtools" ;
    spdx:builtFrom biotools:samtools .

