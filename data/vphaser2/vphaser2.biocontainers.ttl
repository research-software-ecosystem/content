@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:vphaser2 a schema1:SoftwareApplication ;
    schema1:description "V-phaser 2 is a tool to call variants in genetically heterogeneous populations from ultra-deep sequence data" ;
    schema1:keywords "Genetics",
        "Genomics",
        "Metabolomics",
        "Proteomics" ;
    schema1:license "single user license for academic non-commercial research purposes only" ;
    schema1:name "vphaser2" ;
    schema1:url "https://www.broadinstitute.org/scientific-community/science/projects/viral-genomics/v-phaser-2" .

