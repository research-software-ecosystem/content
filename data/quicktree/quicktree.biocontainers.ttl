@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:quicktree a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/18.11.1546" ;
    schema1:description "Fast implementation of the neighbour-joining phylogenetic inference method" ;
    schema1:keywords "Database Management Systems",
        "Databases, Protein",
        "Evolution, Molecular",
        "HIV Envelope Protein gp120",
        "Humans",
        "Phylogeny",
        "Quality Control",
        "Sensitivity and Specificity",
        "Sequence Alignment",
        "Sequence Analysis, Protein" ;
    schema1:license "Apache-2.0" ;
    schema1:name "quicktree" ;
    schema1:url "https://github.com/khowe/quicktree" .

