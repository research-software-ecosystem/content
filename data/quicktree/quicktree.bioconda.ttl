@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:quicktree a schema1:SoftwareApplication ;
    schema1:description "Fast implementation of the neighbour-joining phylogenetic inference method." ;
    schema1:downloadUrl "https://github.com/khowe/quicktree/archive/v2.5.tar.gz" ;
    schema1:identifier biotools:quicktree ;
    schema1:license "Apache-2.0" ;
    schema1:name "quicktree" ;
    schema1:softwareVersion "2.5" ;
    schema1:url "https://github.com/khowe/quicktree" ;
    spdx:builtFrom biotools:quicktree .

