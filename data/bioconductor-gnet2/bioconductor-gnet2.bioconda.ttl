@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-gnet2 a schema1:SoftwareApplication ;
    schema1:description "Constructing gene regulatory networks from expression data through functional module inference" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/GNET2_1.26.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/GNET2/GNET2_1.26.0.tar.gz', 'https://bioarchive.galaxyproject.org/GNET2_1.26.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-gnet2/bioconductor-gnet2_1.26.0_src_all.tar.gz']" ;
    schema1:identifier biotools:gnet2 ;
    schema1:license "Apache License 2.0" ;
    schema1:name "bioconductor-gnet2" ;
    schema1:softwareVersion "1.26.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/GNET2.html" ;
    spdx:builtFrom biotools:gnet2 .

