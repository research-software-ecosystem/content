@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:go a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/gkp1018",
        "doi:10.1093/nar/gkr1028" ;
    schema1:description "Go is an open source programming language that makes it easy to build simple, reliable, and efficient software." ;
    schema1:identifier biotools:go ;
    schema1:keywords "Databases, Genetic",
        "Gene expression",
        "Gene structure",
        "Molecular Sequence Annotation",
        "Ontology and terminology",
        "Quality Control",
        "Small molecules",
        "Vocabulary, Controlled",
        "Zoology" ;
    schema1:license "Custom License" ;
    schema1:name "go" ;
    schema1:url "https://github.com/golang/go" .

