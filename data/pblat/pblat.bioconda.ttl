@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:pblat a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s12859-019-2597-8" ;
    schema1:description "blat with multi-threads support" ;
    schema1:downloadUrl "https://github.com/icebert/pblat/archive/2.5.1.tar.gz" ;
    schema1:identifier biotools:pblat ;
    schema1:license "OTHER" ;
    schema1:name "pblat" ;
    schema1:softwareVersion "2.5.1" ;
    schema1:url "https://icebert.github.io/pblat" ;
    spdx:builtFrom biotools:pblat .

