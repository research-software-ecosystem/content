@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:pblat a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s12859-019-2597-8" ;
    schema1:description "blat with multi-threads support" ;
    schema1:identifier biotools:pblat ;
    schema1:keywords "Computational Biology",
        "Gene transcripts",
        "Genome, Human",
        "High-Throughput Nucleotide Sequencing",
        "Humans",
        "Mapping",
        "RNA-seq",
        "Sequence Alignment",
        "Sequence Analysis, DNA" ;
    schema1:license "https://icebert.github.io/pblat" ;
    schema1:name "pblat" ;
    schema1:url "https://github.com/icebert/pblat" .

