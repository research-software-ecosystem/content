@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:edlib-aligner a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btw753" ;
    schema1:description "Edlib sequence alignment tool using edit distance" ;
    schema1:keywords "Sequence Alignment",
        "Sequence Analysis, DNA" ;
    schema1:license "custom, see /usr/share/doc/edlib-aligner/copyright" ;
    schema1:name "edlib-aligner" ;
    schema1:url "https://github.com/Martinsos/edlib" .

