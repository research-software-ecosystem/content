@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:clinker a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/gigascience/giy079" ;
    schema1:description "Clinker is a bioinformatics pipeline that generates a supertranscriptome from popular fusion finder outputs (jaffa, tophatfusion, soap, defuse, pizzly, etc), that can be then be either viewed in genome viewers such as igv or through the included plotting feature developed with gviz." ;
    schema1:keywords "Alternative Splicing",
        "Computational Biology",
        "Frameshift Mutation",
        "Gene Expression Profiling",
        "Genomics",
        "Humans",
        "Leukemia, B-Cell",
        "Oncogene Proteins, Fusion",
        "Precursor Cell Lymphoblastic Leukemia-Lymphoma",
        "Programming Languages",
        "Protein Domains",
        "Protein Isoforms",
        "RNA",
        "Receptors, Cytokine",
        "Receptors, Purinergic P2Y",
        "Sequence Analysis, RNA" ;
    schema1:license "MIT" ;
    schema1:name "clinker" ;
    schema1:url "https://github.com/Oshlack/Clinker" .

