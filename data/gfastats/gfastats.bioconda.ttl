@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:gfastats a schema1:SoftwareApplication ;
    schema1:description "The swiss army knife for genome assembly" ;
    schema1:downloadUrl "https://github.com/vgl-hub/gfastats/releases/download/v1.3.11/gfastats.v1.3.11-with_submodules.zip" ;
    schema1:identifier biotools:gfastats ;
    schema1:license "MIT" ;
    schema1:name "gfastats" ;
    schema1:softwareVersion "1.3.11" ;
    schema1:url "https://github.com/vgl-hub/gfastats" ;
    spdx:builtFrom biotools:gfastats .

