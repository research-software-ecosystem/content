@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:reframed a schema1:SoftwareApplication ;
    schema1:author "acaprez",
        "cdanielmachado",
        "lhtxa" ;
    schema1:citation "doi:10.5281/zenodo.7955995" ;
    schema1:description "Metabolic modeling package." ;
    schema1:downloadUrl "https://pypi.io/packages/source/r/reframed/reframed-1.6.0.tar.gz" ;
    schema1:identifier biotools:reframed ;
    schema1:license "Apache-2.0" ;
    schema1:maintainer "acaprez",
        "cdanielmachado",
        "lhtxa" ;
    schema1:name "reframed" ;
    schema1:softwareVersion "1.6.0" ;
    schema1:url "https://github.com/cdanielmachado/reframed" ;
    spdx:builtFrom biotools:reframed .

