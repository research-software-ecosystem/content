@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:quip a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/gks754" ;
    schema1:description "Aggressive compression of FASTQ and SAM/BAM files." ;
    schema1:downloadUrl "https://github.com/dcjones/quip/archive/refs/tags/v1.1.8.tar.gz" ;
    schema1:identifier biotools:quip ;
    schema1:license "Custom" ;
    schema1:name "quip" ;
    schema1:softwareVersion "1.1.8" ;
    schema1:url "http://homes.cs.washington.edu/%7Edcjones/quip" ;
    spdx:builtFrom biotools:quip .

