@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:quip a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/gks754" ;
    schema1:description "Aggressive compression of FASTQ and SAM/BAM files." ;
    schema1:identifier biotools:quip ;
    schema1:keywords "Data Compression",
        "Data management",
        "High-Throughput Nucleotide Sequencing",
        "Probability" ;
    schema1:license "Custom License" ;
    schema1:name "quip" ;
    schema1:url "https://homes.cs.washington.edu/~dcjones/quip/" .

