@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:fasttree a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/molbev/msp077" ;
    schema1:description "FastTree infers approximately-maximum-likelihood phylogenetic trees from alignments of nucleotide or protein sequences." ;
    schema1:downloadUrl "https://github.com/morgannprice/fasttree/archive/refs/tags/v2.2.0.tar.gz" ;
    schema1:identifier biotools:fasttree ;
    schema1:license "GPL-2.0-or-later" ;
    schema1:name "fasttree" ;
    schema1:softwareHelp "https://morgannprice.github.io/fasttree" ;
    schema1:softwareVersion "2.2.0" ;
    schema1:url "https://morgannprice.github.io/fasttree" ;
    spdx:builtFrom biotools:fasttree .

