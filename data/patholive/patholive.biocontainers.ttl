@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:patholive a schema1:SoftwareApplication ;
    schema1:description "A real-time pathogen diagnostics tool for metagenomic Illumina sequencing data." ;
    schema1:license "BSD-3-Clause" ;
    schema1:name "patholive" ;
    schema1:url "https://gitlab.com/SimonHTausch/PathoLive" .

