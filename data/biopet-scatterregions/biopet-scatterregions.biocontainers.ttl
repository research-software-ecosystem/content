@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:biopet-scatterregions a schema1:SoftwareApplication ;
    schema1:description "This tool breaks a reference or bed file into smaller scatter regions of equal size." ;
    schema1:license "MIT" ;
    schema1:name "biopet-scatterregions" ;
    schema1:url "https://github.com/biopet/scatterregions" .

