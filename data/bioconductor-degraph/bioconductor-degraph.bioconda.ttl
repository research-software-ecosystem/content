@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-degraph a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1214/11-AOAS528" ;
    schema1:description "Two-sample tests on a graph" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/DEGraph_1.58.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/DEGraph/DEGraph_1.58.0.tar.gz', 'https://bioarchive.galaxyproject.org/DEGraph_1.58.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-degraph/bioconductor-degraph_1.58.0_src_all.tar.gz']" ;
    schema1:identifier biotools:degraph ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-degraph" ;
    schema1:softwareVersion "1.58.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/DEGraph.html" ;
    spdx:builtFrom biotools:degraph .

