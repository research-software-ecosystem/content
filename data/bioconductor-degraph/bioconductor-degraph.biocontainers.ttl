@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-degraph a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1214/11-AOAS528" ;
    schema1:description "Two-sample tests on a graph" ;
    schema1:identifier biotools:degraph ;
    schema1:keywords "Gene Expression",
        "Statistics and probability" ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-degraph" ;
    schema1:url "http://bioconductor.org/packages/3.6/bioc/html/DEGraph.html" .

