@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:nanosim-h a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/gigascience/gix010",
        "doi:10.5281/zenodo.1341249" ;
    schema1:description "Nanosim-h is a simulator of oxford nanopore reads that captures the technology-specific features of ont data, and allows for adjustments upon improvement of nanopore sequencing technology." ;
    schema1:keywords "Computational Biology",
        "Genomics",
        "High-Throughput Nucleotide Sequencing",
        "Sequence Analysis, DNA" ;
    schema1:license "Not available" ;
    schema1:name "nanosim-h" ;
    schema1:url "https://github.com/karel-brinda/NanoSim-H" .

