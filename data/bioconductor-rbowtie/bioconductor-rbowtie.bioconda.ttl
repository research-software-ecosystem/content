@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-rbowtie a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "R bowtie wrapper" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/Rbowtie_1.46.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/Rbowtie/Rbowtie_1.46.0.tar.gz', 'https://bioarchive.galaxyproject.org/Rbowtie_1.46.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-rbowtie/bioconductor-rbowtie_1.46.0_src_all.tar.gz']" ;
    schema1:identifier biotools:rbowtie ;
    schema1:license "Artistic-2.0 | file LICENSE" ;
    schema1:name "bioconductor-rbowtie" ;
    schema1:softwareVersion "1.46.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/Rbowtie.html" ;
    spdx:builtFrom biotools:rbowtie .

