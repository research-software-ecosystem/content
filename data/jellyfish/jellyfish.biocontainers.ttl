@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:jellyfish a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btr011" ;
    schema1:description "A command-line algorithm for counting k-mers in dna sequence." ;
    schema1:identifier biotools:jellyfish ;
    schema1:keywords "Animals",
        "Base Sequence",
        "Computational Biology",
        "Genome",
        "Genomics",
        "Humans",
        "Sequence Alignment",
        "Sequence Analysis, DNA",
        "Sequence analysis" ;
    schema1:license "GPL-3.0" ;
    schema1:name "jellyfish" ;
    schema1:url "https://github.com/gmarcais/Jellyfish" .

