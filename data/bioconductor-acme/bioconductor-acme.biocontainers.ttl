        "Humans",
        "Immunoprecipitation experiment",
        "Microarray experiment",
        "Oligonucleotide Array Sequence Analysis",
        "Sequence sites, features and motifs" ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-acme" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/ACME.html" .

