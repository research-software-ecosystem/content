biocontainers:bioconductor-acme a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1016/S0076-6879(06)11014-9" ;
    schema1:description "Algorithms for Calculating Microarray Enrichment (ACME)" ;
    schema1:identifier biotools:acme ;
