@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-acme a schema1:SoftwareApplication ;
    schema1:description "Algorithms for Calculating Microarray Enrichment (ACME)" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/ACME_2.62.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/ACME/ACME_2.62.0.tar.gz', 'https://bioarchive.galaxyproject.org/ACME_2.62.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-acme/bioconductor-acme_2.62.0_src_all.tar.gz']" ;
    schema1:identifier biotools:acme ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-acme" ;
    schema1:softwareVersion "2.62.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/ACME.html" ;
    spdx:builtFrom biotools:acme .

