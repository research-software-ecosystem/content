@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:strudel a schema1:SoftwareApplication ;
    schema1:description "Strudel is a graphical tool for visualizing genetic and physical maps of genomes for comparative purposes." ;
    schema1:keywords "Genetics",
        "RNA-Seq" ;
    schema1:license "Not available" ;
    schema1:name "strudel" ;
    schema1:url "https://ics.hutton.ac.uk/strudel" .

