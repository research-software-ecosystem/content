@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-ideoviz a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Plots data (continuous/discrete) along chromosomal ideogram" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/IdeoViz_1.46.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/IdeoViz/IdeoViz_1.46.0.tar.gz', 'https://bioarchive.galaxyproject.org/IdeoViz_1.46.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-ideoviz/bioconductor-ideoviz_1.46.0_src_all.tar.gz']" ;
    schema1:identifier biotools:ideoviz ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-ideoviz" ;
    schema1:softwareVersion "1.46.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/IdeoViz.html" ;
    spdx:builtFrom biotools:ideoviz .

