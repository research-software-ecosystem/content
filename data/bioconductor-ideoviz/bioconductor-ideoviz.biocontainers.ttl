@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-ideoviz a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Plots data (continuous/discrete) along chromosomal ideogram" ;
    schema1:identifier biotools:ideoviz ;
    schema1:keywords "Computational Biology",
        "Gene Expression Profiling",
        "Genomics",
        "High-Throughput Screening Assays",
        "Nucleic acid structure analysis",
        "Programming Languages",
        "User-Computer Interface" ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-ideoviz" ;
    schema1:url "https://bioconductor.org/packages/release/bioc/html/IdeoViz.html" .

