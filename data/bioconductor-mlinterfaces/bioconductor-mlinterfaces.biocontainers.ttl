@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-mlinterfaces a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Uniform interfaces to R machine learning procedures for data in Bioconductor containers" ;
    schema1:identifier biotools:mlinterfaces ;
    schema1:keywords "Clustering",
        "Computational Biology",
        "Gene Expression Profiling",
        "Genomics",
        "High-Throughput Screening Assays",
        "Machine learning",
        "Ortholog",
        "Programming Languages",
        "User-Computer Interface" ;
    schema1:license "LGPL" ;
    schema1:name "bioconductor-mlinterfaces" ;
    schema1:url "http://bioconductor.org/packages/3.6/bioc/html/MLInterfaces.html" .

