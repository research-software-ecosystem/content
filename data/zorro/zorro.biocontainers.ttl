@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:zorro a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s13059-017-1213-3" ;
    schema1:description "Zorro is an hybrid sequencing technology assembler. it takes to sets of pre-assembled contigs and merge them into a more contiguous and consistent assembly. the main caracteristic of zorro is the treatment before and after assembly to avoid errors." ;
    schema1:identifier biotools:zorro ;
    schema1:keywords "Chromosome Mapping",
        "Contig Mapping",
        "Eukaryota",
        "Genome",
        "Genomics",
        "High-Throughput Nucleotide Sequencing",
        "Prokaryotic Cells",
        "Sequence Alignment",
        "Sequence Analysis, DNA" ;
    schema1:license "GPL-3.0" ;
    schema1:name "zorro" ;
    schema1:url "https://sourceforge.net/projects/probmask/" .

