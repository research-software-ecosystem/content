@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:busco a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btv351" ;
    schema1:description "Provides measures for quantitative assessment of genome assembly, gene set, and transcriptome completeness based on evolutionarily informed expectations of gene content from near-universal single-copy orthologs." ;
    schema1:identifier biotools:busco ;
    schema1:keywords "Animals",
        "Computational Biology",
        "Gene Dosage",
        "Genome",
        "Genomics",
        "Humans",
        "Molecular Sequence Annotation",
        "Sequence analysis",
        "Sequence assembly",
        "Transcriptomics" ;
    schema1:license "GPL" ;
    schema1:name "busco" ;
    schema1:url "https://gitlab.com/ezlab/busco/" .

