    schema1:license "MIT" ;
    schema1:maintainer "berkelem" ;
    schema1:name "busco" ;
    schema1:softwareHelp "https://busco.ezlab.org/busco_userguide.html" ;
    schema1:softwareVersion "6.0.0" ;
    schema1:url "https://busco.ezlab.org" ;
    spdx:builtFrom biotools:busco .

