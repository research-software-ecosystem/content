        "conda:bioconda:busco" ;
    schema1:license "unknown" ;
    schema1:name "busco" ;
    schema1:softwareVersion "5.5.0" ;
    schema1:url "https://gitlab.com/ezlab/busco" ;
    spdx:builtFrom "busco" .

