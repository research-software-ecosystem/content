@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:primer3-py a schema1:SoftwareApplication ;
    schema1:description "Primer3-py is a Python-abstracted API for the popular Primer3 library." ;
    schema1:license "GPL-2.0" ;
    schema1:name "primer3-py" ;
    schema1:url "https://libnano.github.io/primer3-py/" .

