@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:zga a schema1:SoftwareApplication ;
    schema1:description "Prokaryotic genome assembly and annotation pipeline" ;
    schema1:identifier biotools:zga ;
    schema1:keywords "Genomics",
        "Metagenome" ;
    schema1:license "Not available" ;
    schema1:name "zga" ;
    schema1:url "https://github.com/laxeye/zga" .

