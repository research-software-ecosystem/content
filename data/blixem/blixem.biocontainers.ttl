@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:blixem a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/10.3.301" ;
    schema1:description "Interactive browser of sequence alignments" ;
    schema1:identifier biotools:blixem ;
    schema1:keywords "Amino Acid Sequence",
        "Base Sequence",
        "DNA",
        "Exons",
        "Molecular Sequence Data",
        "Phylogenetics",
        "Sequence Alignment",
        "Sequence Homology, Nucleic Acid",
        "Sequence analysis",
        "Software Design" ;
    schema1:license "GPL-3.0+" ;
    schema1:name "blixem" ;
    schema1:url "http://www.sanger.ac.uk/science/tools/seqtools" .

