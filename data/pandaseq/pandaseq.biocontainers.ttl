@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:pandaseq a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/1471-2105-13-31" ;
    schema1:description "PANDASEQ is a program to align Illumina reads, optionally with PCR primers embedded in the sequence, and reconstruct an overlapping sequence." ;
    schema1:keywords "Bacteria",
        "Metagenomics",
        "RNA, Bacterial",
        "RNA, Ribosomal, 16S" ;
    schema1:license "GPL-3.0" ;
    schema1:name "pandaseq" ;
    schema1:url "https://github.com/neufeld/pandaseq" .

