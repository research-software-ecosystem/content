@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:slncky a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s13059-016-0880-9" ;
    schema1:description "Slncky is a tool for lncrna discovery from rna-seq data. slncky filters a high-quality set of noncoding transcripts, discovers lncrna orthologs, and characterizes conserved lncrna evolution. slncky was developed as a collaboration between the garber lab at umass medical and the regev lab at the broad institute." ;
    schema1:identifier biotools:slncky ;
    schema1:keywords "Animals",
        "Evolution, Molecular",
        "Evolutionary biology",
        "Functional, regulatory and non-coding RNA",
        "Mammals",
        "Molecular Sequence Annotation",
        "Ortholog",
        "RNA, Long Noncoding",
        "RNA-Seq",
        "Sequence Alignment",
        "Sequence Analysis, RNA",
        "Transcriptome",
        "Zoology" ;
    schema1:license "MIT" ;
    schema1:name "slncky" ;
    schema1:url "https://github.com/slncky/slncky" .

