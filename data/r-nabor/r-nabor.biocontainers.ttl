@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-nabor a schema1:SoftwareApplication ;
    schema1:description "An r wrapper for 'libnabo', an exact or approximate k nearest neighbour library which is optimised for low dimensional spaces (e.g. 3d)" ;
    schema1:license "BSD_3_clause" ;
    schema1:name "r-nabor" ;
    schema1:url "https://CRAN.R-project.org/package=nabor" .

