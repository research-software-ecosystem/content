@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-phylobase a schema1:SoftwareApplication ;
    schema1:description "Provides a base S4 class for comparative methods, incorporating one or more trees and trait data." ;
    schema1:keywords "Genetics",
        "Phylogenetics" ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "r-phylobase" ;
    schema1:url "https://github.com/fmichonneau/phylobase" .

