@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-biomart a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nprot.2009.97" ;
    schema1:description "Interface to BioMart databases (i.e. Ensembl)" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/biomaRt_2.62.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/biomaRt/biomaRt_2.62.0.tar.gz', 'https://bioarchive.galaxyproject.org/biomaRt_2.62.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-biomart/bioconductor-biomart_2.62.0_src_all.tar.gz']" ;
    schema1:identifier biotools:biomaRt ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-biomart" ;
    schema1:softwareVersion "2.62.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/biomaRt.html" ;
    spdx:builtFrom biotools:biomaRt .

