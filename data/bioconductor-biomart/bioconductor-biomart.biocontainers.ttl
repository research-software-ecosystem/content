@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-biomart a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nprot.2009.97",
        "doi:10.1093/bioinformatics/bti525" ;
    schema1:description "Interface to biomart databases (i.e. ensembl)" ;
    schema1:identifier biotools:biomaRt ;
    schema1:keywords "Data acquisition",
        "Database Management Systems",
        "Database management",
        "Databases, Protein",
        "Gene Expression Profiling",
        "Information Storage and Retrieval",
        "Model organisms",
        "Molecular interactions, pathways and networks",
        "Oligonucleotide Array Sequence Analysis",
        "Proteomics",
        "Systems Integration",
        "Zoology" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-biomart" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/biomaRt.html" .

