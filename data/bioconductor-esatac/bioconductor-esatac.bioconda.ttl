@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-esatac a schema1:SoftwareApplication ;
    schema1:description "An Easy-to-use Systematic pipeline for ATACseq data analysis" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/esATAC_1.28.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/esATAC/esATAC_1.28.0.tar.gz', 'https://bioarchive.galaxyproject.org/esATAC_1.28.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-esatac/bioconductor-esatac_1.28.0_src_all.tar.gz']" ;
    schema1:identifier biotools:esATAC ;
    schema1:license "GPL-3 | file LICENSE" ;
    schema1:name "bioconductor-esatac" ;
    schema1:softwareVersion "1.28.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/esATAC.html" ;
    spdx:builtFrom biotools:esATAC .

