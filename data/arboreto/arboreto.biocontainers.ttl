@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:arboreto a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/BIOINFORMATICS/BTY916" ;
    schema1:description "Scalable gene regulatory network inference using tree-based ensemble regressors" ;
    schema1:identifier biotools:arboreto ;
    schema1:keywords "Clustering",
        "Gene Expression",
        "Gene expression",
        "Molecular interactions, pathways and networks",
        "RNA-Seq",
        "Transcription Factors" ;
    schema1:license "BSD 3-Clause \"New\" or \"Revised\" License" ;
    schema1:name "arboreto" ;
    schema1:url "https://github.com/tmoerman/arboreto" .

