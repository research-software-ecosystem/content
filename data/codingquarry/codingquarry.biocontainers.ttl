@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:codingquarry a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s12864-015-1344-4" ;
    schema1:description "CodingQuarry: highly accurate hidden Markov model gene prediction in fungal genomes using RNA-seq transcripts." ;
    schema1:keywords "Gene Expression Profiling",
        "Genes, Fungal",
        "Genome, Fungal",
        "Markov Chains",
        "Models, Genetic",
        "Molecular Sequence Annotation",
        "Saccharomyces cerevisiae",
        "Schizosaccharomyces",
        "Sequence Analysis, RNA" ;
    schema1:license "GPL-3" ;
    schema1:name "codingquarry" ;
    schema1:url "https://sourceforge.net/p/codingquarry/" .

