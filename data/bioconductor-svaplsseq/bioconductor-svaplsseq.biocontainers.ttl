@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-svaplsseq a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1101/062125" ;
    schema1:description "SVAPLSseq-An R package to estimate the hidden factors of unwanted variability and adjust for them to enable a more powerful and accurate differential expression analysis based on RNAseq data" ;
    schema1:identifier biotools:svaplsseq ;
    schema1:keywords "Gene expression",
        "RNA-Seq" ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-svaplsseq" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/SVAPLSseq.html" .

