@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:sparseassembler a schema1:SoftwareApplication ;
    schema1:description "A sparse k-mer graph based, memory-efficient genome assembler" ;
    schema1:license "GPL-3.0" ;
    schema1:name "sparseassembler" ;
    schema1:url "https://github.com/yechengxi/SparseAssembler" .

