@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-biseq a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bib/bbv095" ;
    schema1:description "Processing and analyzing bisulfite sequencing data" ;
    schema1:identifier biotools:biseq ;
    schema1:keywords "DNA Methylation",
        "Genetics",
        "Genome, Human",
        "Genomics",
        "Humans",
        "Methylated DNA immunoprecipitation",
        "Sequence Analysis, DNA",
        "Sequencing",
        "Sulfites" ;
    schema1:license "LGPL-3" ;
    schema1:name "bioconductor-biseq" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/BiSeq.html" .

