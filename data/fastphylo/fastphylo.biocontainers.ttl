@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:fastphylo a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/1471-2105-14-334" ;
    schema1:description "Fastphylo is software project containing the implementations of the algorithms \"Fast Computation of Distance Estimators and (Fast Neighbor Joinin)." ;
    schema1:keywords "Amino Acid Sequence",
        "Biological Evolution",
        "Computational Biology",
        "Genetics",
        "Language",
        "Memory",
        "Multigene Family",
        "Phylogenetics",
        "Phylogeny" ;
    schema1:license "MIT" ;
    schema1:name "fastphylo" ;
    schema1:url "https://github.com/arvestad/FastPhylo" .

