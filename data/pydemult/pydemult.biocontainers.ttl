@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:pydemult a schema1:SoftwareApplication ;
    schema1:description "Streamed and parallel demultiplexing of fastq files in python" ;
    schema1:license "MIT" ;
    schema1:name "pydemult" ;
    schema1:url "https://github.com/jenzopr/pydemult" .

