@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bowtie a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/1471-2105-14-184",
        "doi:10.1186/gb-2009-10-3-r25",
        "doi:10.7490/f1000research.1114334.1" ;
    schema1:description "An ultrafast memory-efficient short read aligner" ;
    schema1:identifier biotools:bowtie ;
    schema1:keywords "Benchmarking",
        "Genome",
        "Genomics",
        "High-Throughput Nucleotide Sequencing",
        "Mapping",
        "Sequence Alignment",
        "Sequence Analysis, DNA",
        "Sequence assembly",
        "Sequencing" ;
    schema1:license "GPL-3.0" ;
    schema1:name "bowtie" ;
    schema1:url "http://bowtie-bio.sourceforge.net/index.shtml" .

