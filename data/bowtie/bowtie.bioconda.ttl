@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bowtie a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/gb-2009-10-3-r25" ;
    schema1:description "An ultrafast memory-efficient short read aligner" ;
    schema1:downloadUrl "https://github.com/BenLangmead/bowtie/archive/v1.3.1.tar.gz" ;
    schema1:identifier biotools:bowtie ;
    schema1:license "Artistic-2.0-only" ;
    schema1:name "bowtie" ;
    schema1:softwareVersion "1.3.1" ;
    schema1:url "https://github.com/BenLangmead/bowtie" ;
    spdx:builtFrom biotools:bowtie .

