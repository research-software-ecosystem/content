@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-genomicinteractions a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s12864-015-2140-x" ;
    schema1:description "Utilities for handling genomic interaction data" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/GenomicInteractions_1.40.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/GenomicInteractions/GenomicInteractions_1.40.0.tar.gz', 'https://bioarchive.galaxyproject.org/GenomicInteractions_1.40.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-genomicinteractions/bioconductor-genomicinteractions_1.40.0_src_all.tar.gz']" ;
    schema1:identifier biotools:genomicinteractions ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-genomicinteractions" ;
    schema1:softwareVersion "1.40.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/GenomicInteractions.html" ;
    spdx:builtFrom biotools:genomicinteractions .

