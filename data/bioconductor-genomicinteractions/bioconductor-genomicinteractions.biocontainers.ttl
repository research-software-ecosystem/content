@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-genomicinteractions a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s12864-015-2140-x" ;
    schema1:description "Utilities for handling genomic interaction data" ;
    schema1:identifier biotools:genomicinteractions ;
    schema1:keywords "Animals",
        "Chromatin",
        "Computer Graphics",
        "Databases, Genetic",
        "Genomics",
        "Humans",
        "K562 Cells",
        "Mice",
        "Molecular Sequence Annotation",
        "Protein interactions",
        "Sequencing",
        "Thymocytes" ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-genomicinteractions" ;
    schema1:url "https://bioconductor.org/packages/release/bioc/html/GenomicInteractions.html" .

