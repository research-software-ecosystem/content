@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:wget a schema1:SoftwareApplication ;
    schema1:description "utility for non-interactive download of files from the Web" ;
    schema1:license "GPL-3.0" ;
    schema1:name "wget" ;
    schema1:url "https://www.gnu.org/software/wget/" .

