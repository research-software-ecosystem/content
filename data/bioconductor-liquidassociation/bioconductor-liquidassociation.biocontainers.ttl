@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-liquidassociation a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "LiquidAssociation" ;
    schema1:identifier biotools:liquidassociation ;
    schema1:keywords "Biochemistry",
        "Computational Biology",
        "Gene Expression Profiling",
        "Genetics",
        "Genomics",
        "High-Throughput Screening Assays",
        "Nucleic acid sites, features and motifs",
        "Nucleic acid structure analysis",
        "Programming Languages",
        "User-Computer Interface" ;
    schema1:license "GPL (>=3)" ;
    schema1:name "bioconductor-liquidassociation" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/LiquidAssociation.html" .

