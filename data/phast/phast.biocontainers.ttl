@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:phast a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/gkr485" ;
    schema1:description "Phast (phage search tool) is a web server designed to rapidly and accurately identify, annotate and graphically display prophage sequences within bacterial genomes or plasmids. phast also generates downloadable, high quality, interactive graphics that display all identified prophage components in both circular and linear genomic views." ;
    schema1:identifier biotools:phast ;
    schema1:keywords "Databases, Genetic",
        "Genome, Bacterial",
        "Genomics",
        "Internet",
        "Molecular Sequence Annotation",
        "Molecular interactions, pathways and networks",
        "Prophages",
        "Protein interaction experiment",
        "Sequence Analysis, DNA",
        "Sequencing" ;
    schema1:license "BSD-3-clause" ;
    schema1:name "phast" ;
    schema1:url "http://phast.wishartlab.com/" .

