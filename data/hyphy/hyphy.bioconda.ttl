@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:hyphy a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1007/978-1-4939-8736-8_6",
        "doi:10.1093/bioinformatics/bti079",
        "doi:10.1093/molbev/msz197" ;
    schema1:description "An open-source software package for comparative sequence analysis using stochastic evolutionary models." ;
    schema1:downloadUrl "https://github.com/veg/hyphy/archive/2.5.99.tar.gz" ;
    schema1:identifier biotools:HyPhy ;
    schema1:license "MIT" ;
    schema1:name "hyphy" ;
    schema1:softwareHelp "https://hyphy.org" ;
    schema1:softwareVersion "2.5.99" ;
    schema1:url "https://hyphy.org" ;
    spdx:builtFrom biotools:HyPhy .

