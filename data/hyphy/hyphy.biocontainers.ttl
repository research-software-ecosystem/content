@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:hyphy a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1007/978-1-4939-8736-8_6" ;
    schema1:description "HyPhy is an open-source software package for the analysis of genetic sequences using techniques in phylogenetics, molecular evolution, and machine learning." ;
    schema1:keywords "Amino Acids",
        "Bayes Theorem",
        "Evolution, Molecular",
        "Genetics",
        "Hepacivirus",
        "Phylogenetics",
        "Phylogeny",
        "Proteins" ;
    schema1:license "Custom License" ;
    schema1:name "hyphy" ;
    schema1:url "https://github.com/veg/hyphy" .

