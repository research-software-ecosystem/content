@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:ymp a schema1:SoftwareApplication ;
    schema1:description "Create entire ngs pipelines with one command" ;
    schema1:keywords "Genomics",
        "Metagenome",
        "Metagenomics",
        "RNA-Seq" ;
    schema1:license "GPL-3.0" ;
    schema1:name "ymp" ;
    schema1:url "https://github.com/epruesse/ymp" .

