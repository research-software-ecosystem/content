@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:apscale a schema1:SoftwareApplication ;
    schema1:author "DominikBuchner" ;
    schema1:description "Advanced Pipeline for Simple yet Comprehensive AnaLysEs of DNA metabarcoding data." ;
    schema1:downloadUrl "https://pypi.org/packages/source/a/apscale/apscale-4.3.0.tar.gz" ;
    schema1:identifier biotools:apscale ;
    schema1:license "MIT" ;
    schema1:maintainer "DominikBuchner" ;
    schema1:name "apscale" ;
    schema1:softwareHelp "https://github.com/DominikBuchner/apscale/blob/main/README.md" ;
    schema1:softwareVersion "4.3.0" ;
    schema1:url "https://github.com/DominikBuchner/apscale" ;
    spdx:builtFrom biotools:apscale .

