@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-hybridmtest a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Hybrid Multiple Testing" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/HybridMTest_1.50.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/HybridMTest/HybridMTest_1.50.0.tar.gz', 'https://bioarchive.galaxyproject.org/HybridMTest_1.50.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-hybridmtest/bioconductor-hybridmtest_1.50.0_src_all.tar.gz']" ;
    schema1:identifier biotools:hybridmtest ;
    schema1:license "GPL Version 2 or later" ;
    schema1:name "bioconductor-hybridmtest" ;
    schema1:softwareVersion "1.50.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/HybridMTest.html" ;
    spdx:builtFrom biotools:hybridmtest .

