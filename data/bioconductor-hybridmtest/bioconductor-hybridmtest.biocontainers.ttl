@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-hybridmtest a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Hybrid Multiple Testing" ;
    schema1:identifier biotools:hybridmtest ;
    schema1:keywords "Computational Biology",
        "Experimental design and studies",
        "Gene Expression Profiling",
        "Genetics",
        "Genomics",
        "High-Throughput Screening Assays",
        "Programming Languages",
        "Statistics and probability",
        "User-Computer Interface" ;
    schema1:license "GPL Version 2 or later" ;
    schema1:name "bioconductor-hybridmtest" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/HybridMTest.html" .

