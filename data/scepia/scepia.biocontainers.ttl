@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:scepia a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1016/j.cell.2018.06.052",
        "doi:10.1126/science.aba7612" ;
    schema1:description "Single cell epigenome-based inference of activity" ;
    schema1:identifier biotools:scepia ;
    schema1:keywords "Clustering",
        "RNA-Seq",
        "Transcription Factors" ;
    schema1:license "MIT" ;
    schema1:name "scepia" ;
    schema1:url "https://github.com/vanheeringen-lab/scepia" .

