@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:scepia a schema1:SoftwareApplication ;
    schema1:author "maarten-vd-sande",
        "rebecza",
        "simonvh" ;
    schema1:description "Single Cell Epigenome-based Inference of Activity" ;
    schema1:downloadUrl "https://github.com/vanheeringen-lab/scepia/releases/download/0.5.1/scepia-0.5.1.tar.gz" ;
    schema1:identifier biotools:scepia ;
    schema1:license "MIT" ;
    schema1:maintainer "maarten-vd-sande",
        "rebecza",
        "simonvh" ;
    schema1:name "scepia" ;
    schema1:softwareVersion "0.5.1" ;
    schema1:url "https://github.com/vanheeringen-lab/scepia" ;
    spdx:builtFrom biotools:scepia .

