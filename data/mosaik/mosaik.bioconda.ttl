@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:mosaik a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1371/journal.pone.0090581" ;
    schema1:description "MOSAIK is a stable, sensitive and open-source program for mapping second and third-generation sequencing reads to a reference genome." ;
    schema1:downloadUrl "https://github.com/wanpinglee/MOSAIK/archive/e04c806bb1410cf1dbd1534991c46d696aec6723.zip" ;
    schema1:identifier biotools:mosaik ;
    schema1:license "GPL 2.0+" ;
    schema1:name "mosaik" ;
    schema1:softwareVersion "2.2.26" ;
    schema1:url "https://github.com/wanpinglee/MOSAIK" ;
    spdx:builtFrom biotools:mosaik .

