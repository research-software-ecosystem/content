@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:mosaik a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/1471-2164-15-264",
        "doi:10.1371/journal.pone.0090581" ;
    schema1:description "Mosaik is a stable, sensitive and open-source program for mapping second and third-generation sequencing reads to a reference genome." ;
    schema1:identifier biotools:mosaik ;
    schema1:keywords "Chromosome Mapping",
        "Computational Biology",
        "Databases, Nucleic Acid",
        "Genomics",
        "High-Throughput Nucleotide Sequencing",
        "Internet",
        "Reproducibility of Results",
        "Sensitivity and Specificity",
        "Sequence analysis",
        "Sequence assembly" ;
    schema1:license "GPL 2.0+" ;
    schema1:name "mosaik" ;
    schema1:url "https://github.com/wanpinglee/MOSAIK" .

