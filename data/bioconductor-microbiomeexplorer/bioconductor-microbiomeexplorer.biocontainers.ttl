@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-microbiomeexplorer a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btaa838" ;
    schema1:description "The MicrobiomeExplorer R package is designed to facilitate the analysis and visualization of marker-gene survey feature data. It allows a user to perform and visualize typical microbiome analytical workflows either through the command line or an interactive Shiny application included with the package. In addition to applying common analytical workflows the application enables automated analysis report generation." ;
    schema1:keywords "Clustering",
        "Genomics",
        "Metagenome",
        "Metagenomics" ;
    schema1:license "MIT" ;
    schema1:name "bioconductor-microbiomeexplorer" ;
    schema1:url "https://bioconductor.org/packages/3.12/bioc/html/microbiomeExplorer.html" .

