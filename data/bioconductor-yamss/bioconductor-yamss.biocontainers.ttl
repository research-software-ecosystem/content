biocontainers:bioconductor-yamss a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1021/acs.analchem.6b04719" ;
    schema1:description "Tools to analyze and visualize high-throughput metabolomics data aquired using chromatography-mass spectrometry. these tools preprocess data in a way that enables reliable and powerful differential analysis." ;
