@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-yamss a schema1:SoftwareApplication ;
    schema1:description "Tools for high-throughput metabolomics" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/yamss_1.36.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/yamss/yamss_1.36.0.tar.gz', 'https://bioarchive.galaxyproject.org/yamss_1.36.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-yamss/bioconductor-yamss_1.36.0_src_all.tar.gz']" ;
    schema1:identifier biotools:yamss ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-yamss" ;
    schema1:softwareVersion "1.36.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/yamss.html" ;
    spdx:builtFrom biotools:yamss .

