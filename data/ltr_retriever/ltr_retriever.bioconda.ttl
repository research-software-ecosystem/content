@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:ltr_retriever a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1104/pp.17.01310" ;
    schema1:description "Sensitive and accurate identification of LTR retrotransposons" ;
    schema1:downloadUrl "https://github.com/oushujun/LTR_retriever/archive/v3.0.5.tar.gz" ;
    schema1:identifier biotools:ltr_retriever ;
    schema1:license "GPL-3.0-or-later" ;
    schema1:name "ltr_retriever" ;
    schema1:softwareVersion "3.0.5" ;
    schema1:url "https://github.com/oushujun/LTR_retriever" ;
    spdx:builtFrom biotools:ltr_retriever .

