@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:weblogo a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1101/gr.849004" ;
    schema1:description "Web-based application designed to make generate sequence logos." ;
    schema1:identifier biotools:weblogo ;
    schema1:keywords "Amino Acid Sequence",
        "Base Sequence",
        "Computer Graphics",
        "Cyclic AMP Receptor Protein",
        "DNA, Bacterial",
        "Escherichia coli Proteins",
        "Genomics",
        "Internet",
        "Nucleic Acid Conformation",
        "Nucleic acid sites, features and motifs",
        "Protein Structure, Quaternary",
        "Sequence Alignment",
        "Sequence analysis" ;
    schema1:license "MIT" ;
    schema1:name "weblogo" ;
    schema1:url "http://weblogo.berkeley.edu/" .

