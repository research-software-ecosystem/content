@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:fastqmetrics a schema1:SoftwareApplication ;
    schema1:description "Extract metrics from a fastq file, streaming" ;
    schema1:license "MIT" ;
    schema1:name "fastqmetrics" ;
    schema1:url "https://github.com/wdecoster/fastqmetrics" .

