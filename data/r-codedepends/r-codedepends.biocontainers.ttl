@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-codedepends a schema1:SoftwareApplication ;
    schema1:description "Tools for analyzing R expressions or blocks of code and determining the dependencies between them. It focuses on R scripts, but can be used on the bodies of functions. There are many facilities including the ability to summarize or get a high-level view of code, determining dependencies between variables, code improvement suggestions." ;
    schema1:license "GPL-3" ;
    schema1:name "r-codedepends" ;
    schema1:url "https://github.com/duncantl/CodeDepends" .

