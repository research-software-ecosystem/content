biocontainers:r-idr a schema1:SoftwareApplication ;
    schema1:description "This is a package for estimating the copula mixture model and plotting correspondence curves in \"Measuring reproducibility of high-throughput experiments\" (2011), Annals of Applied Statistics, Vol. 5, No. 3, 1752-1779, by Li, Brown, Huang, and Bickel " ;
    schema1:license "GPL (>= 2.0)" ;
    schema1:name "r-idr" ;
    schema1:url "None" .

