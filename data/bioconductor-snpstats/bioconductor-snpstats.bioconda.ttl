@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-snpstats a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "SnpMatrix and XSnpMatrix classes and methods" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/snpStats_1.56.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/snpStats/snpStats_1.56.0.tar.gz', 'https://bioarchive.galaxyproject.org/snpStats_1.56.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-snpstats/bioconductor-snpstats_1.56.0_src_all.tar.gz']" ;
    schema1:identifier biotools:snpstats ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-snpstats" ;
    schema1:softwareVersion "1.56.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/snpStats.html" ;
    spdx:builtFrom biotools:snpstats .

