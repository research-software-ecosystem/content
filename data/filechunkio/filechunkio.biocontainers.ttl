@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:filechunkio a schema1:SoftwareApplication ;
    schema1:description "FileChunkIO represents a chunk of an OS-level file containing bytes data" ;
    schema1:license "MIT" ;
    schema1:name "filechunkio" ;
    schema1:url "https://github.com/fabiant7t/filechunkio" .

