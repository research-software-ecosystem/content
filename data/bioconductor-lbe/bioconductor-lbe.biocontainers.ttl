@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-lbe a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/bti063" ;
    schema1:description "Estimation of the false discovery rate." ;
    schema1:identifier biotools:lbe ;
    schema1:keywords "Biomarkers, Tumor",
        "Breast Neoplasms",
        "Computer Simulation",
        "Data Interpretation, Statistical",
        "Diagnosis, Computer-Assisted",
        "False Positive Reactions",
        "Gene Expression Profiling",
        "Humans",
        "Leukemia",
        "Models, Genetic",
        "Models, Statistical",
        "Neoplasm Proteins",
        "Oligonucleotide Array Sequence Analysis",
        "Statistics and probability" ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-lbe" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/LBE.html" .

