@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-lbe a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/bti063" ;
    schema1:description "Estimation of the false discovery rate" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/LBE_1.74.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/LBE/LBE_1.74.0.tar.gz', 'https://bioarchive.galaxyproject.org/LBE_1.74.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-lbe/bioconductor-lbe_1.74.0_src_all.tar.gz']" ;
    schema1:identifier biotools:lbe ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-lbe" ;
    schema1:softwareVersion "1.74.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/LBE.html" ;
    spdx:builtFrom biotools:lbe .

