@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-qcmetrics a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "A Framework for Quality Control" ;
    schema1:identifier biotools:qcmetrics ;
    schema1:keywords "Bioinformatics",
        "Computational Biology",
        "Data quality management",
        "Data visualisation",
        "Gene Expression Profiling",
        "Genetics",
        "Genomics",
        "High-Throughput Screening Assays",
        "Programming Languages",
        "Proteomics",
        "Proteomics experiment",
        "Quality affairs",
        "User-Computer Interface" ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-qcmetrics" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/qcmetrics.html" .

