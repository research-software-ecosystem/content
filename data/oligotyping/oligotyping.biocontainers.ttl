@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:oligotyping a schema1:SoftwareApplication ;
    schema1:description "The oligotyping and minimum entropy decomposition (med) pipeline for the analysis of marker gene amplicons" ;
    schema1:license "GPL (> 3)" ;
    schema1:name "oligotyping" ;
    schema1:url "http://oligotyping.org" .

