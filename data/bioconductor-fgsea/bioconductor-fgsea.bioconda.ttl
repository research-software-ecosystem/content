@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-fgsea a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1101/060012" ;
    schema1:description "Fast Gene Set Enrichment Analysis" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/fgsea_1.32.2.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/fgsea/fgsea_1.32.2.tar.gz', 'https://bioarchive.galaxyproject.org/fgsea_1.32.2.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-fgsea/bioconductor-fgsea_1.32.2_src_all.tar.gz']" ;
    schema1:identifier biotools:fgsea ;
    schema1:license "MIT + file LICENCE" ;
    schema1:name "bioconductor-fgsea" ;
    schema1:softwareVersion "1.32.2" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/fgsea.html" ;
    spdx:builtFrom biotools:fgsea .

