@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:pybel a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btx660" ;
    schema1:description "Pybel is a python package for parsing and handling biological networks encoded in the biological expression language (bel)." ;
    schema1:identifier biotools:pybel ;
    schema1:keywords "Alzheimer Disease",
        "Computational Biology",
        "Data integration and warehousing",
        "Gene expression",
        "Humans",
        "Metabolic Networks and Pathways",
        "Models, Biological",
        "Molecular interactions, pathways and networks",
        "Programming Languages",
        "Signal Transduction" ;
    schema1:license "MIT" ;
    schema1:name "pybel" ;
    schema1:url "https://github.com/pybel/pybel" .

