@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:haystack_bio a schema1:SoftwareApplication ;
    schema1:description "Epigenetic variability and transcription factor motifs analysis pipeline" ;
    schema1:keywords "Gene Expression",
        "Genetics",
        "Genomics",
        "RNA-Seq",
        "Transcription Factors" ;
    schema1:license "GNU Affero General Public License v3.0" ;
    schema1:name "haystack_bio" ;
    schema1:url "https://github.com/pinellolab/haystack_bio" .

