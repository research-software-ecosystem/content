      "sc:author": "Jared Brown",
      "sc:citation": {
        "@id": "https://doi.org/10.1093/bioinformatics/btab450"
      },
      "sc:contributor": "Christina Kendziorski",
      "sc:description": "Dino normalizes single-cell, mRNA sequencing data to correct for technical variation, particularly sequencing depth, prior to downstream analysis. The approach produces a matrix of corrected expression for which the dependency between sequencing depth and the full distribution of normalized expression; many existing methods aim to remove only the dependency between sequencing depth and the mean of the normalized expression. This is particuarly useful in the context of highly sparse datasets such as those produced by 10X genomics and other uninque molecular identifier (UMI) based microfluidics protocols for which the depth-dependent proportion of zeros in the raw expression data can otherwise present a challenge.",
      "sc:featureList": [
        {
          "@id": "edam:operation_3435"
        },
        {
          "@id": "edam:operation_3223"
        },
        {
          "@id": "edam:operation_3200"
        }
      ],
      "sc:isAccessibleForFree": true,
      "sc:license": "GPL-3.0-only",
      "sc:name": "Dino",
      "sc:softwareHelp": {
        "@id": "https://bioconductor.org/packages/Dino"
      },
