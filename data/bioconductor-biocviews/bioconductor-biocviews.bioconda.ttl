@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-biocviews a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Categorized views of R package repositories" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/biocViews_1.74.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/biocViews/biocViews_1.74.0.tar.gz', 'https://bioarchive.galaxyproject.org/biocViews_1.74.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-biocviews/bioconductor-biocviews_1.74.0_src_all.tar.gz']" ;
    schema1:identifier biotools:biocviews ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-biocviews" ;
    schema1:softwareVersion "1.74.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/biocViews.html" ;
    spdx:builtFrom biotools:biocviews .

