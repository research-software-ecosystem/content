@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bttcmp a schema1:SoftwareApplication ;
    schema1:author "liaochenlanruo" ;
    schema1:description "A toxin minging tool for Bacillus thuringiensis" ;
    schema1:downloadUrl "https://github.com/liaochenlanruo/BTTCMP/archive/v1.0.3.tar.gz" ;
    schema1:identifier biotools:bttcmp ;
    schema1:license "GPLv3" ;
    schema1:maintainer "liaochenlanruo" ;
    schema1:name "bttcmp" ;
    schema1:softwareVersion "1.0.3" ;
    schema1:url "https://github.com/liaochenlanruo/BTTCMP/blob/master/README.md" ;
    spdx:builtFrom biotools:bttcmp .

