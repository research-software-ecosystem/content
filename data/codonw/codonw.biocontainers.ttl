@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:codonw a schema1:SoftwareApplication ;
    schema1:description "Correspondence analysis of codon usage" ;
    schema1:identifier biotools:codonw ;
    schema1:keywords "Genetics" ;
    schema1:license "GPL-2" ;
    schema1:name "codonw" ;
    schema1:url "http://codonw.sourceforge.net" .

