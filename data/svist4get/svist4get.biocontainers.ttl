@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:svist4get a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s12859-019-2706-8" ;
    schema1:description "A simple visualization tool for genomic tracks from sequencing experiments" ;
    schema1:identifier biotools:svist4get ;
    schema1:keywords "ChIP-seq",
        "Genome",
        "Genomics",
        "High-Throughput Nucleotide Sequencing",
        "Imaging",
        "RNA, Messenger",
        "RNA-seq",
        "Ribosomes" ;
    schema1:license "WTFPL" ;
    schema1:name "svist4get" ;
    schema1:url "https://bitbucket.org/artegorov/svist4get/" .

