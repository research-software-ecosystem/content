@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-swathxtend a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1074/mcp.M115.055558" ;
    schema1:description "SWATH extended library generation and statistical data analysis" ;
    schema1:identifier biotools:swathxtend ;
    schema1:keywords "Chromatography, Liquid",
        "Humans",
        "K562 Cells",
        "Mass Spectrometry",
        "Peptide Library",
        "Proteomics",
        "Proteomics experiment" ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-swathxtend" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/SwathXtend.html" .

