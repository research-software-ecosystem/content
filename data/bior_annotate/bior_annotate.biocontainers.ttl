@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bior_annotate a schema1:SoftwareApplication ;
    schema1:description "Biological repository is a toolkit and set of catalogs to retrieve genomic annotation for variants, genes, diseases, conditions, genetic tests, and drugs." ;
    schema1:license "Custom License" ;
    schema1:name "bior_annotate" ;
    schema1:url "https://github.com/BioinformaticsToolsAtMayo" .

