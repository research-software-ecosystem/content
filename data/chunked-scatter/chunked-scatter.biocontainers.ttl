@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:chunked-scatter a schema1:SoftwareApplication ;
    schema1:description "Chunk and scatter the regions in a bed or sequence dict file" ;
    schema1:license "MIT" ;
    schema1:name "chunked-scatter" ;
    schema1:url "https://github.com/biowdl/chunked-scatter" .

