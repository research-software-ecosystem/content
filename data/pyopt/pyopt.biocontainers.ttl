@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:pyopt a schema1:SoftwareApplication ;
    schema1:description "A python-based package for formulating and solving nonlinear constrained optimization problems in an efficient, reusable and portable manner." ;
    schema1:license "Creative Commons License" ;
    schema1:name "pyopt" ;
    schema1:url "http://www.pyopt.org/index.html" .

