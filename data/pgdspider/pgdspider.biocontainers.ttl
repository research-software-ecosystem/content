@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:pgdspider a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btr642" ;
    schema1:description "An automated data conversion tool for connecting population genetics and genomics programs" ;
    schema1:keywords "Genetics",
        "Genetics, Population",
        "Genomics",
        "Information Storage and Retrieval",
        "User-Computer Interface" ;
    schema1:license "Not available" ;
    schema1:name "pgdspider" ;
    schema1:url "http://www.cmpg.unibe.ch/software/PGDSpider/" .

