@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:runcircos-gui a schema1:SoftwareApplication ;
    schema1:description "Gui tool to run circos" ;
    schema1:license "custom, see /usr/share/doc/runcircos-gui/copyright" ;
    schema1:name "runcircos-gui" ;
    schema1:url "https://github.com/narunlifescience/runcircos-gui" .

