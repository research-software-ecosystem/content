@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:seq2hla a schema1:SoftwareApplication ;
    schema1:description "Precision HLA typing and expression from next-generation RNA sequencing data" ;
    schema1:identifier biotools:seq2hla ;
    schema1:license "MIT" ;
    schema1:name "seq2hla" ;
    schema1:softwareVersion "2.3" ;
    schema1:url "https://github.com/TRON-Bioinformatics/seq2HLA" ;
    spdx:builtFrom biotools:seq2hla .

