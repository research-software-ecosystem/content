@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-r3cseq a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/gkt373" ;
    schema1:description "Analysis of Chromosome Conformation Capture and Next-generation Sequencing (3C-seq)" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/r3Cseq_1.56.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/r3Cseq/r3Cseq_1.56.0.tar.gz', 'https://bioarchive.galaxyproject.org/r3Cseq_1.56.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-r3cseq/bioconductor-r3cseq_1.56.0_src_all.tar.gz']" ;
    schema1:identifier biotools:r3cseq ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-r3cseq" ;
    schema1:softwareVersion "1.56.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/r3Cseq.html" ;
    spdx:builtFrom biotools:r3cseq .

