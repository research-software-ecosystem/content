@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-r3cseq a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/gkt373" ;
    schema1:description "Analysis of Chromosome Conformation Capture and Next-generation Sequencing (3C-seq)" ;
    schema1:identifier biotools:r3cseq ;
    schema1:keywords "Animals",
        "Chromatin Immunoprecipitation",
        "Chromosomes",
        "Genes, myb",
        "Genomics",
        "High-Throughput Nucleotide Sequencing",
        "Mice",
        "Sequence Analysis, DNA",
        "Sequencing",
        "beta-Globins" ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-r3cseq" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/r3Cseq.html" .

