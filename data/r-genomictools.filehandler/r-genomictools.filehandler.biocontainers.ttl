@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-genomictools.filehandler a schema1:SoftwareApplication ;
    schema1:description "A collection of I/O tools for handling the most commonly used genomic datafiles, like fasta/-q, bed, gff, gtf, ped/map and vcf." ;
    schema1:license "GPL-2" ;
    schema1:name "r-genomictools.filehandler" ;
    schema1:url "https://CRAN.R-project.org/package=GenomicTools.fileHandler" .

