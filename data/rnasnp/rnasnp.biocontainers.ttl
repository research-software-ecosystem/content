@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:rnasnp a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1002/humu.22273" ;
    schema1:description "Efficient detection of local RNA secondary structure changes induced by SNPs." ;
    schema1:identifier biotools:rnasnp ;
    schema1:keywords "DNA polymorphism",
        "Genetic Association Studies",
        "Humans",
        "Nucleic Acid Conformation",
        "Nucleic acid structure analysis",
        "Polymorphism, Single Nucleotide",
        "RNA",
        "RNA Folding" ;
    schema1:license "RTH" ;
    schema1:name "rnasnp" ;
    schema1:url "http://rth.dk/resources/rnasnp/software" .

