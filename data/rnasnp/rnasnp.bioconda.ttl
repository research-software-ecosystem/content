@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:rnasnp a schema1:SoftwareApplication ;
    schema1:description "Efficient detection of local RNA secondary structure changes induced by SNPs." ;
    schema1:downloadUrl "http://rth.dk/resources/rnasnp/software_src/RNAsnp-1.2.tar.gz" ;
    schema1:identifier biotools:rnasnp ;
    schema1:license "RTH" ;
    schema1:name "rnasnp" ;
    schema1:softwareVersion "1.2" ;
    schema1:url "http://rth.dk/resources/rnasnp/software" ;
    spdx:builtFrom biotools:rnasnp .

