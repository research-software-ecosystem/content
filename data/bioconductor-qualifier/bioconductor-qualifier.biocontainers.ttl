@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-qualifier a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/1471-2105-13-252" ;
    schema1:description "Provides quality control and quality assessment tools for gated flow cytometry data." ;
    schema1:identifier biotools:qualifier ;
    schema1:keywords "Cell biology",
        "Data Interpretation, Statistical",
        "Data quality management",
        "Data visualisation",
        "Flow Cytometry",
        "Humans",
        "Oncology" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-qualifier" ;
    schema1:url "http://bioconductor.org/packages/release/bioc/html/QUALIFIER.html" .

