@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-drugvsdisease a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Comparison of disease and drug profiles using Gene set Enrichment Analysis" ;
    schema1:identifier biotools:drugvsdisease ;
    schema1:keywords "Clustering",
        "Computational Biology",
        "Gene Expression",
        "Gene Expression Profiling",
        "Genomics",
        "High-Throughput Screening Assays",
        "Pathology",
        "Pharmacology",
        "Programming Languages",
        "User-Computer Interface" ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-drugvsdisease" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/DrugVsDisease.html" .

