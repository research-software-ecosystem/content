@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-flowmatch a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Matching and meta-clustering in flow cytometry" ;
    schema1:identifier biotools:flowmatch ;
    schema1:keywords "Cell biology",
        "Clustering",
        "Computational Biology",
        "Gene Expression Profiling",
        "Genomics",
        "High-Throughput Screening Assays",
        "Programming Languages",
        "User-Computer Interface" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-flowmatch" ;
    schema1:url "http://bioconductor.org/packages/3.6/bioc/html/flowMatch.html" .

