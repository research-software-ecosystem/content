@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-flowmatch a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Matching and meta-clustering in flow cytometry" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/flowMatch_1.42.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/flowMatch/flowMatch_1.42.0.tar.gz', 'https://bioarchive.galaxyproject.org/flowMatch_1.42.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-flowmatch/bioconductor-flowmatch_1.42.0_src_all.tar.gz']" ;
    schema1:identifier biotools:flowmatch ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-flowmatch" ;
    schema1:softwareVersion "1.42.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/flowMatch.html" ;
    spdx:builtFrom biotools:flowmatch .

