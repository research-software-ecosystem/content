@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-agdex a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btr362" ;
    schema1:description "Agreement of Differential Expression Analysis" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/AGDEX_1.54.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/AGDEX/AGDEX_1.54.0.tar.gz', 'https://bioarchive.galaxyproject.org/AGDEX_1.54.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-agdex/bioconductor-agdex_1.54.0_src_all.tar.gz']" ;
    schema1:identifier biotools:agdex ;
    schema1:license "GPL Version 2 or later" ;
    schema1:name "bioconductor-agdex" ;
    schema1:softwareVersion "1.54.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/AGDEX.html" ;
    spdx:builtFrom biotools:agdex .

