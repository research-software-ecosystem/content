@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-agdex a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btr362" ;
    schema1:description "Agreement of Differential Expression Analysis" ;
    schema1:identifier biotools:agdex ;
    schema1:keywords "Animals",
        "Computational Biology",
        "Disease Models, Animal",
        "Ependymoma",
        "Gene Expression Profiling",
        "Gene expression",
        "Genetics",
        "Genomics",
        "Humans",
        "Meta-Analysis as Topic",
        "Mice",
        "Models, Statistical" ;
    schema1:license "GPL Version 2 or later" ;
    schema1:name "bioconductor-agdex" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/AGDEX.html" .

