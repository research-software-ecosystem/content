@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:pispino a schema1:SoftwareApplication ;
    schema1:description "Pispino (pipits spin-off tools): bioinformatics toolkits for processing ngs data" ;
    schema1:license "GPL-3" ;
    schema1:name "pispino" ;
    schema1:url "https://github.com/hsgweon/pispino" .

