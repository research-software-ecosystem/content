@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:biocontainers a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btx192" ;
    schema1:description "Base image for biodocker" ;
    schema1:identifier biotools:biocontainers ;
    schema1:keywords "Bioinformatics",
        "Cheminformatics",
        "Computational Biology",
        "Data management",
        "Genomics",
        "Laboratory information management",
        "Metabolomics",
        "Proteomics" ;
    schema1:license "Apache-2.0" ;
    schema1:name "biocontainers" ;
    schema1:url "https://github.com/Biocontainers" .

