@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:pyteomics a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1007/s13361-012-0516-6" ;
    schema1:description "Framework for proteomics data analysis, supporting mzml, mgf, pepxml and more." ;
    schema1:identifier biotools:pyteomics ;
    schema1:keywords "Chromatography, Liquid",
        "Data Mining",
        "Databases, Protein",
        "Internet",
        "Mass Spectrometry",
        "Proteomics",
        "Proteomics experiment",
        "Reproducibility of Results" ;
    schema1:license "Apache-2.0" ;
    schema1:name "pyteomics" ;
    schema1:url "http://packages.python.org/pyteomics/" .

