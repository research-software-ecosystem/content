@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-otubase a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btr196" ;
    schema1:description "Provides structure and functions for the analysis of OTU data" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/OTUbase_1.60.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/OTUbase/OTUbase_1.60.0.tar.gz', 'https://bioarchive.galaxyproject.org/OTUbase_1.60.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-otubase/bioconductor-otubase_1.60.0_src_all.tar.gz']" ;
    schema1:identifier biotools:otubase ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-otubase" ;
    schema1:softwareVersion "1.60.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/OTUbase.html" ;
    spdx:builtFrom biotools:otubase .

