@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-otubase a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btr196" ;
    schema1:description "Provides a platform for operational taxonomic unit based analysis." ;
    schema1:identifier biotools:otubase ;
    schema1:keywords "Classification",
        "Cluster Analysis",
        "Data architecture, analysis and design",
        "Sequence Analysis, DNA",
        "Taxonomy" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-otubase" ;
    schema1:url "http://bioconductor.org/packages/release/bioc/html/OTUbase.html" .

