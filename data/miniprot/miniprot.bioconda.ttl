@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:miniprot a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btad014" ;
    schema1:description "Miniprot aligns a protein sequence against a genome with affine gap penalty, splicing and frameshift. It is primarily intended for annotating protein-coding genes in a new species using known genes from other species." ;
    schema1:downloadUrl "https://github.com/lh3/miniprot/archive/refs/tags/v0.18.tar.gz" ;
    schema1:identifier biotools:miniprot ;
    schema1:license "MIT" ;
    schema1:name "miniprot" ;
    schema1:softwareHelp "https://lh3.github.io/miniprot/miniprot.html" ;
    schema1:softwareVersion "0.18" ;
    schema1:url "https://github.com/lh3/miniprot" ;
    spdx:builtFrom biotools:miniprot .

