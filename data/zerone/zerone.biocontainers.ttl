@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:zerone a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btw336" ;
    schema1:description "Zerone discretizes several ChIP-seq replicates simultaneously and resolves conflicts between them." ;
    schema1:keywords "Animals",
        "Chromatin Immunoprecipitation",
        "DNA Replication",
        "Genome",
        "Quality Control",
        "Reproducibility of Results",
        "Sequence Analysis, DNA" ;
    schema1:license "GPL-3.0" ;
    schema1:name "zerone" ;
    schema1:url "https://github.com/nanakiksc/zerone" .

