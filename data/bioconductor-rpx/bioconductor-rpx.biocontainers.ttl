@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-rpx a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nbt.2839" ;
    schema1:description "R Interface to the ProteomeXchange Repository" ;
    schema1:identifier biotools:rpx ;
    schema1:keywords "Animals",
        "Database Management Systems",
        "Databases, Protein",
        "Humans",
        "International Cooperation",
        "Internet",
        "Mass Spectrometry",
        "Mice",
        "Proteomics" ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-rpx" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/rpx.html" .

