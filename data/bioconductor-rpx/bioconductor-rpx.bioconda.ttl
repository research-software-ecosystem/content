@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-rpx a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nbt.2839" ;
    schema1:description "R Interface to the ProteomeXchange Repository" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/rpx_2.18.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/rpx/rpx_2.18.0.tar.gz', 'https://bioarchive.galaxyproject.org/rpx_2.18.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-rpx/bioconductor-rpx_2.18.0_src_all.tar.gz']" ;
    schema1:identifier biotools:rpx ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-rpx" ;
    schema1:softwareVersion "2.18.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/rpx.html" ;
    spdx:builtFrom biotools:rpx .

