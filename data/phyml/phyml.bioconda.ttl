@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:phyml a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/sysbio/syq010" ;
    schema1:description "Phylogenetic estimation using (Maximum) Likelihood" ;
    schema1:downloadUrl "https://github.com/stephaneguindon/phyml/archive/v3.3.20220408.tar.gz" ;
    schema1:identifier biotools:phyml ;
    schema1:license "GPL-3.0-only" ;
    schema1:name "phyml" ;
    schema1:softwareHelp "https://github.com/stephaneguindon/phyml/blob/master/doc/phyml-manual.pdf" ;
    schema1:softwareVersion "3.3.20220408" ;
    schema1:url "http://www.atgc-montpellier.fr/phyml/" ;
    spdx:builtFrom biotools:phyml .

