@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:phyml a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1080/10635150390235520",
        "doi:10.1080/10635150600755453",
        "doi:10.1093/bioinformatics/bti713",
        "doi:10.1093/nar/gki352",
        "doi:10.1093/sysbio/syq010" ;
    schema1:description "Phylogenetic estimation software using maximum likelihood" ;
    schema1:identifier biotools:phyml ;
    schema1:keywords "Bioinformatics",
        "Genetics",
        "Internet",
        "Likelihood Functions",
        "Phylogenetics",
        "Phylogeny",
        "Sequence Analysis, DNA",
        "Sequence Analysis, Protein",
        "Time Factors",
        "User-Computer Interface" ;
    schema1:license "GPL-2.0" ;
    schema1:name "phyml" ;
    schema1:url "https://github.com/stephaneguindon/phyml" .

