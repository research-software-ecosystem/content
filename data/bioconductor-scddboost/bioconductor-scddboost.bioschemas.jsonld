  "@id": "https://bio.tools/bioconductor-scddboost",
  "@type": "sc:SoftwareApplication",
  "dcterms:conformsTo": "https://bioschemas.org/profiles/ComputationalTool/0.6-DRAFT",
  "sc:additionalType": [
    "Command-line tool",
    "Library"
  ],
  "sc:author": "Xiuyu Ma",
  "sc:contributor": "Michael A. Newton",
  "sc:description": "scDDboost is an R package to analyze changes in the distribution of single-cell expression data between two experimental conditions. Compared to other methods that assess differential expression, scDDboost benefits uniquely from information conveyed by the clustering of cells into cellular subtypes. Through a novel empirical Bayesian formulation it calculates gene-specific posterior probabilities that the marginal expression distribution is the same (or different) between the two conditions. The implementation in scDDboost treats gene-level expression data within each condition as a mixture of negative binomial distributions.",
  "sc:license": "GPL-2.0-or-later",
  "sc:name": "scDDboost",
  "sc:operatingSystem": [
    "Mac",
    "Windows",
    "Linux"
  ],
  "sc:softwareHelp": {
    "@id": "https://bioconductor.org/packages/scDDboost"
  },
  "sc:softwareVersion": "1.12.0",
  "sc:url": "https://bioconductor.org/packages/scDDboost"
}