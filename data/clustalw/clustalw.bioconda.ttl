@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:clustalw a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btm404",
        "doi:10.1093/nar/22.22.4673" ;
    schema1:description "ClustalW2 is a general purpose multiple sequence alignment program for DNA or proteins." ;
    schema1:downloadUrl "http://www.clustal.org/download/current/clustalw-2.1.tar.gz" ;
    schema1:identifier biotools:clustalw_biolib ;
    schema1:license "LGPL-3.0-or-later" ;
    schema1:name "clustalw" ;
    schema1:softwareHelp "http://www.clustal.org/download/clustalw_help.txt" ;
    schema1:softwareVersion "2.1" ;
    schema1:url "http://www.clustal.org/clustal2" ;
    spdx:builtFrom biotools:clustalw_biolib .

