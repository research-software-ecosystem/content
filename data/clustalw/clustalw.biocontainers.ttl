@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:clustalw a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1016/0378-1119(88)90330-7",
        "doi:10.1093/bioinformatics/8.2.189",
        "doi:10.1093/nar/22.22.4673",
        "doi:10.1093/nar/25.24.4876",
        "doi:10.1093/nar/gkg500" ;
    schema1:description "Multiple sequence alignment software. old deprecated versions. even older versions were clustal and clustal v (clustalv)." ;
    schema1:identifier biotools:clustalw ;
    schema1:keywords "Amino Acid Sequence",
        "Animals",
        "Base Sequence",
        "Globins",
        "Humans",
        "Microcomputers",
        "Molecular Sequence Data",
        "Phylogeny",
        "RNA, Ribosomal, 5S",
        "Sequence analysis" ;
    schema1:license "LGPL-3.0+" ;
    schema1:name "clustalw" ;
    schema1:url "http://www.clustal.org/download/1.X/ftp-igbmc.u-strasbg.fr/pub/" .

