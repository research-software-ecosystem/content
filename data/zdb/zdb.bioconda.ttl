@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:zdb a schema1:SoftwareApplication ;
    schema1:author "bkm",
        "njohner" ;
    schema1:description "zDB is both a bacterial comparative genomics pipeline and a tool to visualize the results" ;
    schema1:downloadUrl "https://github.com/metagenlab/zDB/archive/refs/tags/v1.3.12.tar.gz" ;
    schema1:identifier biotools:zDB ;
    schema1:license "MIT" ;
    schema1:maintainer "bkm",
        "njohner" ;
    schema1:name "zdb" ;
    schema1:softwareHelp "https://zdb.readthedocs.io/en/latest/" ;
    schema1:softwareVersion "1.3.12" ;
    schema1:url "https://github.com/metagenlab/zDB/" ;
    spdx:builtFrom biotools:zDB .

