@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-organismdbi a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Software to enable the smooth interfacing of different database packages" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/OrganismDbi_1.48.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/OrganismDbi/OrganismDbi_1.48.0.tar.gz', 'https://bioarchive.galaxyproject.org/OrganismDbi_1.48.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-organismdbi/bioconductor-organismdbi_1.48.0_src_all.tar.gz']" ;
    schema1:identifier biotools:organismdbi ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-organismdbi" ;
    schema1:softwareVersion "1.48.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/OrganismDbi.html" ;
    spdx:builtFrom biotools:organismdbi .

