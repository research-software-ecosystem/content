bioconda:bioconductor-probamr a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1074/mcp.M115.052860" ;
    schema1:description "Generating SAM file for PSMs in shotgun proteomics data" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/proBAMr_1.40.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/proBAMr/proBAMr_1.40.0.tar.gz', 'https://bioarchive.galaxyproject.org/proBAMr_1.40.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-probamr/bioconductor-probamr_1.40.0_src_all.tar.gz']" ;
    schema1:identifier biotools:probamr ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-probamr" ;
    schema1:softwareVersion "1.40.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/proBAMr.html" ;
    spdx:builtFrom biotools:probamr .

