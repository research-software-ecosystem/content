@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:picopore a schema1:SoftwareApplication ;
    schema1:citation "doi:10.12688/f1000research.11022.1" ;
    schema1:description "A tool for reducing the size of Oxford Nanopore Technologies datasets without losing information." ;
    schema1:identifier biotools:picopore ;
    schema1:keywords "Genomics",
        "Sequencing" ;
    schema1:license "GPL" ;
    schema1:name "picopore" ;
    schema1:url "https://github.com/scottgigante/picopore" .

