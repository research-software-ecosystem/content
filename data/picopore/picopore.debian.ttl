@prefix debianmed: <https://salsa.debian.org/med-team/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

debianmed:picopore a schema1:SoftwareApplication ;
    schema1:citation "doi:10.12688/f1000research.11022.3" ;
    schema1:description "lossless compression of Nanopore files" ;
    schema1:identifier "bio.tools:picopore",
        "conda:bioconda:picopore" ;
    schema1:license "unknown" ;
    schema1:name "picopore" ;
    schema1:softwareVersion "1.2.0" ;
    schema1:url "https://github.com/scottgigante/picopore" ;
    spdx:builtFrom "picopore" .

