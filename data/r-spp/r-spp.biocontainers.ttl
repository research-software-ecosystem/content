@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-spp a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nbt.1508" ;
    schema1:description "Analysis of ChIP-seq and other functional sequencing data [Kharchenko PV (2008) <DOI:10.1038/nbt.1508>]." ;
    schema1:identifier biotools:spp ;
    schema1:keywords "Binding Sites",
        "ChIP-seq",
        "Chromatin Immunoprecipitation",
        "Computational Biology",
        "DNA-Binding Proteins",
        "Genomics",
        "Protein Binding",
        "Research Design",
        "Sequence Analysis, DNA",
        "Transcription Factors" ;
    schema1:license "GPL-2" ;
    schema1:name "r-spp" ;
    schema1:url "https://CRAN.R-project.org/package=spp" .

