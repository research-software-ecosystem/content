@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:r-spp a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nbt.1508" ;
    schema1:description "Analysis of ChIP-seq and other functional sequencing data [Kharchenko PV (2008) <DOI:10.1038/nbt.1508>]." ;
    schema1:downloadUrl "['/src/contrib/spp_1.16.0.tar.gz', '/src/contrib/Archive/spp/spp_1.16.0.tar.gz']" ;
    schema1:identifier biotools:spp ;
    schema1:license "GPL-2.0-only" ;
    schema1:name "r-spp" ;
    schema1:softwareHelp "https://CRAN.R-project.org/package=spp" ;
    schema1:softwareVersion "1.16.0" ;
    schema1:url "https://CRAN.R-project.org/package=spp" ;
    spdx:builtFrom biotools:spp .

