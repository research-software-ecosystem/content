@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:humann a schema1:SoftwareApplication ;
    schema1:citation "doi:10.7554/eLife.65088" ;
    schema1:description "HUMAnN: The HMP Unified Metabolic Analysis Network, version 3" ;
    schema1:downloadUrl "https://pypi.io/packages/source/h/humann/humann-3.9.tar.gz" ;
    schema1:identifier biotools:humann ;
    schema1:license "MIT" ;
    schema1:name "humann" ;
    schema1:softwareHelp "http://huttenhower.sph.harvard.edu/humann" ;
    schema1:softwareVersion "3.9" ;
    schema1:url "https://huttenhower.sph.harvard.edu/humann" ;
    spdx:builtFrom biotools:humann .

