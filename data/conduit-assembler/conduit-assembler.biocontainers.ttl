@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:conduit-assembler a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1101/2020.02.08.939942" ;
    schema1:description "Long- and short-read hybrid de novo transcriptome assembly" ;
    schema1:keywords "Clustering",
        "RNA-Seq",
        "Transcriptome",
        "Transcriptomics" ;
    schema1:license "GPL-2" ;
    schema1:name "conduit-assembler" ;
    schema1:url "https://github.com/NatPRoach/conduit" .

