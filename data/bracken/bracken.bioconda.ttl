@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bracken a schema1:SoftwareApplication ;
    schema1:citation "doi:10.7717/peerj-cs.104" ;
    schema1:description "Bracken (Bayesian Reestimation of Abundance with KrakEN) is a highly accurate statistical method that computes the abundance of species in DNA sequences from a metagenomics sample." ;
    schema1:downloadUrl "https://github.com/jenniferlu717/Bracken/archive/v3.1.tar.gz" ;
    schema1:identifier biotools:Bracken ;
    schema1:license "GPL-3.0-or-later" ;
    schema1:name "bracken" ;
    schema1:softwareHelp "https://github.com/jenniferlu717/Bracken/blob/v3.1/README.md" ;
    schema1:softwareVersion "3.1" ;
    schema1:url "https://github.com/jenniferlu717/Bracken" ;
    spdx:builtFrom biotools:Bracken .

