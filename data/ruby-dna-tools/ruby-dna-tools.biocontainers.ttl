@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:ruby-dna-tools a schema1:SoftwareApplication ;
    schema1:description "Various libraries containing useful functions for working with dna sequences, written in ruby. some tools are not specific to dna." ;
    schema1:license "GNU General Public License v2.0" ;
    schema1:name "ruby-dna-tools" ;
    schema1:url "https://github.com/Carldeboer/Ruby-DNA-Tools" .

