@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-stringdb a schema1:SoftwareApplication ;
    schema1:description "STRINGdb - Protein-Protein Interaction Networks and Functional Enrichment Analysis" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/STRINGdb_2.22.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/STRINGdb/STRINGdb_2.22.0.tar.gz', 'https://bioarchive.galaxyproject.org/STRINGdb_2.22.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-stringdb/bioconductor-stringdb_2.22.0_src_all.tar.gz']" ;
    schema1:identifier biotools:stringdb ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-stringdb" ;
    schema1:softwareVersion "2.22.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/STRINGdb.html" ;
    spdx:builtFrom biotools:stringdb .

