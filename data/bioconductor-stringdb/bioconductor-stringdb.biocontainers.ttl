@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-stringdb a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/gks1094" ;
    schema1:description "STRINGdb (Search Tool for the Retrieval of Interacting proteins database)" ;
    schema1:identifier biotools:stringdb ;
    schema1:keywords "Data Interpretation, Statistical",
        "Data Mining",
        "Databases, Protein",
        "Internet",
        "Protein Interaction Mapping",
        "Protein interactions",
        "Proteins",
        "Systems Integration",
        "User-Computer Interface" ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-stringdb" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/STRINGdb.html" .

