@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-funchip a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btx201" ;
    schema1:description "Clustering and Alignment of ChIP-Seq peaks based on their shapes" ;
    schema1:identifier biotools:funchip ;
    schema1:keywords "Animals",
        "ChIP-seq",
        "Chromatin Immunoprecipitation",
        "Cluster Analysis",
        "Clustering",
        "Fibroblasts",
        "Genomics",
        "Mice" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-funchip" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/FunChIP.html" .

