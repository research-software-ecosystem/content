@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-funchip a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btx201" ;
    schema1:description "Clustering and Alignment of ChIP-Seq peaks based on their shapes" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.18/bioc/src/contrib/FunChIP_1.28.0.tar.gz', 'https://bioconductor.org/packages/3.18/bioc/src/contrib/Archive/FunChIP/FunChIP_1.28.0.tar.gz', 'https://bioarchive.galaxyproject.org/FunChIP_1.28.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-funchip/bioconductor-funchip_1.28.0_src_all.tar.gz']" ;
    schema1:identifier biotools:funchip ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-funchip" ;
    schema1:softwareVersion "1.28.0" ;
    schema1:url "https://bioconductor.org/packages/3.18/bioc/html/FunChIP.html" ;
    spdx:builtFrom biotools:funchip .

