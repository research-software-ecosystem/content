@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:galaxy-util a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/gkw343",
        "doi:10.1093/nar/gky379" ;
    schema1:description "Galaxy generic utilities" ;
    schema1:identifier biotools:galaxy ;
    schema1:keywords "Comparative genomics",
        "Datasets as Topic",
        "Functional genomics",
        "Genomics",
        "Humans",
        "Information Dissemination",
        "International Cooperation",
        "Internet",
        "Metabolomics",
        "Molecular Imaging",
        "Proteomics",
        "Reproducibility of Results",
        "Sequence assembly",
        "User-Computer Interface",
        "Whole genome sequencing" ;
    schema1:license "AFL-3.0" ;
    schema1:name "galaxy-util" ;
    schema1:url "https://github.com/galaxyproject/galaxy-hub" .

