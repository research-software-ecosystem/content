@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:seqiolib a schema1:SoftwareApplication ;
    schema1:description "Library to read, write sequence, variants, regions to use them for training of machine learning algorithms." ;
    schema1:license "Not available" ;
    schema1:name "seqiolib" ;
    schema1:url "https://github.com/visze/seqiolib" .

