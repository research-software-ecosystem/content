@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioawk a schema1:SoftwareApplication ;
    schema1:description "Bwk awk modified for biological data." ;
    schema1:license "Free software license (https://github.com/lh3/bioawk/blob/master/README.awk#L1)" ;
    schema1:name "bioawk" ;
    schema1:url "https://github.com/lh3/bioawk" .

