@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-annotationfuncs a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Annotation translation functions" ;
    schema1:identifier biotools:annotationfuncs ;
    schema1:keywords "Computational Biology",
        "Data integration and warehousing",
        "Gene Expression Profiling",
        "Genomics",
        "High-Throughput Screening Assays",
        "Programming Languages",
        "User-Computer Interface" ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-annotationfuncs" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/AnnotationFuncs.html" .

