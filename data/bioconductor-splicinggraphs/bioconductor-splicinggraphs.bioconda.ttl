@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-splicinggraphs a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/18.suppl_1.s181" ;
    schema1:description "Create, manipulate, visualize splicing graphs, and assign RNA-seq reads to them" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/SplicingGraphs_1.50.1.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/SplicingGraphs/SplicingGraphs_1.50.1.tar.gz', 'https://bioarchive.galaxyproject.org/SplicingGraphs_1.50.1.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-splicinggraphs/bioconductor-splicinggraphs_1.50.1_src_all.tar.gz']" ;
    schema1:identifier biotools:splicinggraphs ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-splicinggraphs" ;
    schema1:softwareVersion "1.50.1" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/SplicingGraphs.html" ;
    spdx:builtFrom biotools:splicinggraphs .

