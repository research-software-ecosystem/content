@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-splicinggraphs a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/18.suppl_1.s181" ;
    schema1:description "This package allows the user to create, manipulate, and visualize splicing graphs and their bubbles based on a gene model for a given organism. additionally it allows the user to assign rna-seq reads to the edges of a set of splicing graphs, and to summarize them in different ways." ;
    schema1:identifier biotools:splicinggraphs ;
    schema1:keywords "Adenylosuccinate Lyase",
        "Alternative Splicing",
        "Consensus Sequence",
        "DNA, Recombinant",
        "Expressed Sequence Tags",
        "Gene Expression Profiling",
        "Genetic Variation",
        "Genetics",
        "Humans",
        "RNA splicing",
        "RNA-Seq",
        "Sequence Alignment",
        "Sequence Analysis, DNA",
        "Transcriptomics",
        "User-Computer Interface" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-splicinggraphs" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/SplicingGraphs.html" .

