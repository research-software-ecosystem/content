@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:deeptools a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/gkw257" ;
    schema1:description "A set of user-friendly tools for normalization and visualzation of deep-sequencing data" ;
    schema1:downloadUrl "https://github.com/deeptools/deepTools/archive/refs/tags/3.5.6.tar.gz" ;
    schema1:identifier biotools:deeptools ;
    schema1:license "MIT" ;
    schema1:name "deeptools" ;
    schema1:softwareHelp "https://deeptools.readthedocs.io/en/latest/" ;
    schema1:softwareVersion "3.5.6" ;
    schema1:url "https://github.com/deeptools/deepTools" ;
    spdx:builtFrom biotools:deeptools .

