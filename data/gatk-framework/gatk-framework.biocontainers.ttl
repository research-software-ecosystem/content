@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:gatk-framework a schema1:SoftwareApplication ;
    schema1:description "The core mit-licensed genome analysis toolkit (gatk) framework, free for all uses" ;
    schema1:license "MIT" ;
    schema1:name "gatk-framework" ;
    schema1:url "https://github.com/chapmanb/gatk" .

