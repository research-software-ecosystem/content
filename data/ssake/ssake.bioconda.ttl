@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:ssake a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btl629" ;
    schema1:description "SSAKE is a genomics application for de novo assembly of millions of very short DNA sequences." ;
    schema1:downloadUrl "https://github.com/warrenlr/SSAKE/archive/v4.0.tar.gz" ;
    schema1:identifier biotools:ssake ;
    schema1:license "GPL-2.0" ;
    schema1:name "ssake" ;
    schema1:softwareVersion "4.0" ;
    schema1:url "https://github.com/warrenlr/SSAKE" ;
    spdx:builtFrom biotools:ssake .

