@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:ssake a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btl629" ;
    schema1:description "A program for assemblying short dna sequences. the program cycles through sequence data stored in a hash table and progressively searches through a prefix tree for the longest possible k-mer between any two sequencis." ;
    schema1:identifier biotools:ssake ;
    schema1:keywords "Base Sequence",
        "Chromosome Mapping",
        "Contig Mapping",
        "Genomics",
        "Metagenome",
        "Molecular Sequence Data",
        "Proteomics",
        "RNA-Seq",
        "Sequence Analysis, DNA",
        "Sequence assembly",
        "Sequencing",
        "Transcriptome" ;
    schema1:license "GPL-2.0" ;
    schema1:name "ssake" ;
    schema1:url "http://www.bcgsc.ca/platform/bioinfo/software/ssake" .

