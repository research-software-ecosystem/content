@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:beast a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/molbev/mss075" ;
    schema1:description "BEAST is a cross-platform program for Bayesian analysis of molecular sequences using MCMC" ;
    schema1:identifier biotools:beast ;
    schema1:keywords "Animals",
        "Base Sequence",
        "Bayes Theorem",
        "Computational Biology",
        "DNA, Mitochondrial",
        "Finches",
        "Genetics",
        "Molecular Sequence Data",
        "Phenotype",
        "Phylogenetics",
        "Phylogeny",
        "Sequence analysis",
        "User-Computer Interface" ;
    schema1:license "LGPL-2.1" ;
    schema1:name "beast" ;
    schema1:url "https://github.com/beast-dev/beast-mcmc" .

