@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:beast a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/s41592-025-02751-x" ;
    schema1:description "BEAST is a cross-platform program for Bayesian analysis of molecular sequences using MCMC." ;
    schema1:downloadUrl "https://github.com/beast-dev/beast-mcmc/releases/download/v10.5.0/BEAST_X_v10.5.0.tgz" ;
    schema1:identifier biotools:beast ;
    schema1:license "LGPL-2.1-or-later" ;
    schema1:name "beast" ;
    schema1:softwareHelp "https://beast.community" ;
    schema1:softwareVersion "10.5.0" ;
    schema1:url "https://beast.community" ;
    spdx:builtFrom biotools:beast .

