@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bedtools a schema1:SoftwareApplication ;
    schema1:description "A powerful toolset for genome arithmetic" ;
    schema1:downloadUrl "https://github.com/arq5x/bedtools2/releases/download/v2.31.1/bedtools-2.31.1.tar.gz" ;
    schema1:identifier biotools:bedtools ;
    schema1:license "MIT" ;
    schema1:name "bedtools" ;
    schema1:softwareVersion "2.31.1" ;
    schema1:url "http://bedtools.readthedocs.org/" ;
    spdx:builtFrom biotools:bedtools .

