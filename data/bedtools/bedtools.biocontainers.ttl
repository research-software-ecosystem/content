@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bedtools a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btq033",
        "doi:10.1093/bioinformatics/btr539" ;
    schema1:description "Bedtools is an extensive suite of utilities for comparing genomic features in bed format." ;
    schema1:identifier biotools:bedtools ;
    schema1:keywords "Animals",
        "Computational Biology",
        "Genomics",
        "Molecular Sequence Annotation" ;
    schema1:license "GPL-2.0" ;
    schema1:name "bedtools" ;
    schema1:url "https://github.com/arq5x/bedtools2" .

