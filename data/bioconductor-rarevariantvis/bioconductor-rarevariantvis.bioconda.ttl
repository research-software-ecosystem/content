@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-rarevariantvis a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btw359" ;
    schema1:description "A suite for analysis of rare genomic variants in whole genome sequencing data" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/RareVariantVis_2.38.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/RareVariantVis/RareVariantVis_2.38.0.tar.gz', 'https://bioarchive.galaxyproject.org/RareVariantVis_2.38.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-rarevariantvis/bioconductor-rarevariantvis_2.38.0_src_all.tar.gz']" ;
    schema1:identifier biotools:rarevariantvis ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-rarevariantvis" ;
    schema1:softwareVersion "2.38.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/RareVariantVis.html" ;
    spdx:builtFrom biotools:rarevariantvis .

