@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-rarevariantvis a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btw359" ;
    schema1:description "A suite for analysis of rare genomic variants in whole genome sequencing data. it annotates, filters and presents genomic variants in a global, per chromosome way." ;
    schema1:identifier biotools:rarevariantvis ;
    schema1:keywords "Exome",
        "Genetic Variation",
        "Genetic variation",
        "Genome, Human",
        "Genomics",
        "Humans",
        "Rare Diseases",
        "Rare diseases",
        "Sequence Analysis, DNA",
        "Sequencing",
        "Whole genome sequencing" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-rarevariantvis" ;
    schema1:url "http://bioconductor.org/packages/release/bioc/html/RareVariantVis.html" .

