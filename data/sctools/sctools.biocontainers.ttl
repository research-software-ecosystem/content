@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:sctools a schema1:SoftwareApplication ;
    schema1:description "SCTools is a suite of tools performing utility operations over single-cell samples" ;
    schema1:license "AGPL-3.0" ;
    schema1:name "sctools" ;
    schema1:url "https://github.com/bioinformatics-polito/SCTools" .

