@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-virfinder a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s40168-017-0283-5" ;
    schema1:description "VirFinder: a novel k-mer based tool for identifying viral sequences from assembled metagenomic data." ;
    schema1:keywords "Computational Biology",
        "DNA, Viral",
        "Gastrointestinal Microbiome",
        "Genome, Viral",
        "Humans",
        "Liver Cirrhosis",
        "Machine Learning",
        "Metagenome",
        "Metagenomics",
        "Phylogeny",
        "Sequence Analysis, DNA" ;
    schema1:license "USC-RL v1.0" ;
    schema1:name "r-virfinder" ;
    schema1:url "https://github.com/jessieren/VirFinder" .

