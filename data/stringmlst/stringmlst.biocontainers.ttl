@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:stringmlst a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btw586" ;
    schema1:description "Fast k-mer based tool for multi locus sequence typing (mlst) directly from genome sequencing reads" ;
    schema1:identifier biotools:stringmlst ;
    schema1:keywords "Assembly",
        "Bacteria",
        "Bacterial Typing Techniques",
        "Campylobacter jejuni",
        "Chlamydia trachomatis",
        "DNA",
        "High-Throughput Nucleotide Sequencing",
        "Multilocus Sequence Typing",
        "Neisseria meningitidis",
        "Sequence Analysis, DNA",
        "Sequencing",
        "Streptococcus pneumoniae" ;
    schema1:license "Attribution-NonCommercial-ShareAlike 4.0 International Public License" ;
    schema1:name "stringmlst" ;
    schema1:url "https://github.com/jordanlab/stringMLST" .

