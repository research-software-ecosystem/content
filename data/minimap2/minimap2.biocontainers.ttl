@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:minimap2 a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/bty191" ;
    schema1:description "Pairwise aligner for genomic and spliced nucleotide sequences" ;
    schema1:identifier biotools:minimap2 ;
    schema1:keywords "Base Sequence",
        "Genomics",
        "High-Throughput Nucleotide Sequencing",
        "Mapping",
        "RNA-Seq",
        "Sequence Alignment",
        "Sequence Analysis, DNA" ;
    schema1:license "MIT" ;
    schema1:name "minimap2" ;
    schema1:url "https://github.com/lh3/minimap2" .

