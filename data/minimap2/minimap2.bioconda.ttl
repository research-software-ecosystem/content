@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:minimap2 a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/bty191" ;
    schema1:description "A versatile pairwise aligner for genomic and spliced nucleotide sequences." ;
    schema1:downloadUrl "https://github.com/lh3/minimap2/archive/v2.30.tar.gz" ;
    schema1:identifier biotools:minimap2 ;
    schema1:license "MIT" ;
    schema1:name "minimap2" ;
    schema1:softwareHelp "https://lh3.github.io/minimap2/minimap2.html" ;
    schema1:softwareVersion "2.3" ;
    schema1:url "https://github.com/lh3/minimap2" ;
    spdx:builtFrom biotools:minimap2 .

