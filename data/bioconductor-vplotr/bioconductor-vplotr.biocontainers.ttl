@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-vplotr a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18129/b9.bioc.vplotr" ;
    schema1:description "The pattern of digestion and protection from DNA nucleases such as DNAse I, micrococcal nuclease, and Tn5 transposase can be used to infer the location of associated proteins. This package contains useful functions to analyze patterns of paired-end sequencing fragment density. VplotR facilitates the generation of V-plots and footprint profiles over single or aggregated genomic loci of interest." ;
    schema1:license "GPL-3.0" ;
    schema1:name "bioconductor-vplotr" ;
    schema1:url "https://bioconductor.org/packages/3.12/bioc/html/VplotR.html" .

