@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bam-readcount a schema1:SoftwareApplication ;
    schema1:citation "doi:10.21105/joss.03722" ;
    schema1:description "bam-readcount generates metrics at single nucleotide positions." ;
    schema1:identifier biotools:bam-readcount ;
    schema1:license "MIT" ;
    schema1:name "bam-readcount" ;
    schema1:softwareHelp "https://github.com/genome/bam-readcount/blob/v1.0.1/README.md" ;
    schema1:softwareVersion "1.0.1" ;
    schema1:url "https://github.com/genome/bam-readcount" ;
    spdx:builtFrom biotools:bam-readcount .

