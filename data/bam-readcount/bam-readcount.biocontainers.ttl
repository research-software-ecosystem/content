@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bam-readcount a schema1:SoftwareApplication ;
    schema1:description "bam-readcount generates metrics at single nucleotide positions." ;
    schema1:license "MIT" ;
    schema1:name "bam-readcount" ;
    schema1:url "https://github.com/genome/bam-readcount" .

