@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:mzmine a schema1:SoftwareApplication ;
    schema1:description "Integrative analysis of multimodal mass spectrometry data." ;
    schema1:downloadUrl "https://github.com/mzmine/mzmine/archive/refs/tags/v4.7.29.tar.gz" ;
    schema1:identifier biotools:mzmine ;
    schema1:license "MIT" ;
    schema1:name "mzmine" ;
    schema1:softwareHelp "https://mzmine.github.io/mzmine_documentation" ;
    schema1:softwareVersion "4.7.29" ;
    schema1:url "https://github.com/mzmine/mzmine" ;
    spdx:builtFrom biotools:mzmine .

