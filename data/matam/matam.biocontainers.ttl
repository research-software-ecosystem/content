@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:matam a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btx644" ;
    schema1:description "MATAM is a software dedicated to the fast and accurate targeted assembly of short reads." ;
    schema1:identifier biotools:matam ;
    schema1:keywords "Clustering",
        "Gastrointestinal Microbiome",
        "Genomics",
        "High-Throughput Nucleotide Sequencing",
        "Humans",
        "Metagenome",
        "Metagenomics",
        "Metatranscriptomics",
        "Phylogeny",
        "RNA, Ribosomal, 16S",
        "Sequence Analysis, DNA",
        "Sequence assembly" ;
    schema1:license "AGPL-3.0" ;
    schema1:name "matam" ;
    schema1:url "https://github.com/bonsai-team/matam" .

