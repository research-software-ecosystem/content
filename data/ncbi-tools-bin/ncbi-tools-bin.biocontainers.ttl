@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:ncbi-tools-bin a schema1:SoftwareApplication ;
    schema1:description "Ncbi libraries for biology applications (text-based utilities)" ;
    schema1:license "public_domain" ;
    schema1:name "ncbi-tools-bin" ;
    schema1:url "http://www.ncbi.nlm.nih.gov/IEB/ToolBox/" .

