@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:genonets a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/gkw313" ;
    schema1:description "A genotype network is a graph in which vertices represent genotypes that have the same phenotype. this tool provides the following features: (i) the construction of genotype networks for categorical and univariate phenotypes; (ii) analyses of genotype network topology and how it relates to robustness and evolvability, as well as analyses of genotype network topography and how it relates to the navigability of a genotype network; (iii) multiple interactive visualizations." ;
    schema1:identifier biotools:genonets ;
    schema1:keywords "Amino Acid Sequence",
        "Computer Graphics",
        "DNA",
        "Evolution, Molecular",
        "Evolutionary biology",
        "Gene Expression Regulation",
        "Gene Regulatory Networks",
        "Genotype",
        "Humans",
        "Internet",
        "Mutation",
        "Phenotype",
        "RNA",
        "Selection, Genetic",
        "Systems biology",
        "Transcription Factors",
        "User-Computer Interface",
        "Viruses" ;
    schema1:license "MIT" ;
    schema1:name "genonets" ;
    schema1:url "http://ieu-genonets.uzh.ch" .

