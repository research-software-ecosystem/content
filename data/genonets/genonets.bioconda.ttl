@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:genonets a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/gkw313" ;
    schema1:description "Framework for creating and analyzing genotype networks from data." ;
    schema1:downloadUrl "https://files.pythonhosted.org/packages/fb/ea/acf63ad7b54fc16ddacd0a9d1f4da4c455b5efe6fe7ec30b7eb2b0bd69e4/genonets-2.0.tar.gz" ;
    schema1:identifier biotools:genonets ;
    schema1:license "MIT License" ;
    schema1:name "genonets" ;
    schema1:softwareVersion "2.0" ;
    schema1:url "https://github.com/fkhalid/genonets" ;
    spdx:builtFrom biotools:genonets .

