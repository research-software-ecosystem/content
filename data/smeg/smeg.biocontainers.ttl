@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:smeg a schema1:SoftwareApplication ;
    schema1:description "Strain-level metagenomic estimation of growth rate (smeg) measures growth rates of microbial strains from complex metagenomic dataset" ;
    schema1:keywords "Clustering",
        "Metagenome" ;
    schema1:license "Not available" ;
    schema1:name "smeg" ;
    schema1:url "https://github.com/ohlab/SMEG" .

