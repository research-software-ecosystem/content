@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:univariate a schema1:SoftwareApplication ;
    schema1:description "The module performs two sample tests (t-test and Wilcoxon rank test), analysis of variance and Kruskal-Wallis rank test, and correlation tests (by using either the pearson or the spearman correlation), with correction for multiple testing." ;
    schema1:keywords "Metabolomics" ;
    schema1:license "Custom License" ;
    schema1:name "univariate" ;
    schema1:url "https://github.com/phnmnl/container-univariate" .

