      "sc:author": [
        "Brett McGregor",
        "Kai Guo"
      ],
      "sc:citation": {
        "@id": "https://doi.org/10.18129/B9.bioc.VennDetail"
      },
      "sc:description": "A comprehensive package for visualizing multi-set intersections and extracting detailed subset information. VennDetail generates high-resolution visualizations including traditional Venn diagrams, Venn-pie plots, and UpSet-style plots. It provides functions to extract and combine subset details with user datasets in various formats. The package is particularly useful for bioinformatics applications but can be used for any multi-set analysis.",
      "sc:license": "GPL-2.0-only",
      "sc:name": "VennDetail",
      "sc:operatingSystem": [
        "Linux",
        "Windows",
        "Mac"
      ],
