@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:btrim a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1016/j.ygeno.2011.05.009",
        "doi:abs/1711.03336" ;
    schema1:description "This tool is made to remove tips (short dead ends) from a compacted de Bruijn graph and more generally to remove sequencing errors. Used in Bcool a short read corrector" ;
    schema1:identifier biotools:btrim ;
    schema1:keywords "High-Throughput Nucleotide Sequencing",
        "Sequence Analysis, DNA",
        "Sequence analysis" ;
    schema1:license "AGPL-3.0" ;
    schema1:name "btrim" ;
    schema1:url "https://github.com/Malfoy/BTRIM" .

