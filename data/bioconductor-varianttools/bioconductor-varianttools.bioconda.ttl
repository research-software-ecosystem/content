@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-varianttools a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1101/027227" ;
    schema1:description "Tools for Exploratory Analysis of Variant Calls" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/VariantTools_1.48.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/VariantTools/VariantTools_1.48.0.tar.gz', 'https://bioarchive.galaxyproject.org/VariantTools_1.48.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-varianttools/bioconductor-varianttools_1.48.0_src_all.tar.gz']" ;
    schema1:identifier biotools:varianttools ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-varianttools" ;
    schema1:softwareVersion "1.48.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/VariantTools.html" ;
    spdx:builtFrom biotools:varianttools .

