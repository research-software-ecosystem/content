@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-varianttools a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1101/027227" ;
    schema1:description "Tools for Exploratory Analysis of Variant Calls" ;
    schema1:identifier biotools:varianttools ;
    schema1:keywords "Genetic variation",
        "Genetics",
        "Genomics" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-varianttools" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/VariantTools.html" .

