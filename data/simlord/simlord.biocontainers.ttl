@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:simlord a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btw286" ;
    schema1:description "Simlord is a read simulator for long reads from third generation sequencing. currently, it supports the pacific biosciences smrt error model." ;
    schema1:keywords "Computer Simulation",
        "Genomics",
        "High-Throughput Nucleotide Sequencing",
        "Sequence Analysis, DNA" ;
    schema1:license "MIT" ;
    schema1:name "simlord" ;
    schema1:url "https://bitbucket.org/genomeinformatics/simlord/" .

