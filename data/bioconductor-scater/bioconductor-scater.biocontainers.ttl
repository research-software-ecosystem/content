@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-scater a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btw777" ;
    schema1:description "Single-Cell Analysis Toolkit for Gene Expression Data in R" ;
    schema1:identifier biotools:scater ;
    schema1:keywords "Cell Line",
        "Clustering",
        "Gene Expression",
        "Humans",
        "Molecular genetics",
        "Principal Component Analysis",
        "Programming Languages",
        "Quality Control",
        "Quality affairs",
        "RNA",
        "RNA-Seq",
        "RNA-seq",
        "Sequence Analysis, RNA",
        "Single-Cell Analysis",
        "Statistics as Topic",
        "Transcriptomics" ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-scater" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/scater.html" .

