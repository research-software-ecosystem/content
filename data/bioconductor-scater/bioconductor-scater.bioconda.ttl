@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-scater a schema1:SoftwareApplication ;
    schema1:description "Single-Cell Analysis Toolkit for Gene Expression Data in R" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/scater_1.34.1.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/scater/scater_1.34.1.tar.gz', 'https://bioarchive.galaxyproject.org/scater_1.34.1.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-scater/bioconductor-scater_1.34.1_src_all.tar.gz']" ;
    schema1:identifier biotools:scater ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-scater" ;
    schema1:softwareVersion "1.34.1" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/scater.html" ;
    spdx:builtFrom biotools:scater .

