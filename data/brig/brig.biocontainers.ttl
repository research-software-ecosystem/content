@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:brig a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/1471-2164-12-402" ;
    schema1:description "Brig is a cross-platform (windows/mac/unix) application that can display circular comparisons between a large number of genomes, with a focus on handling genome assembly data." ;
    schema1:identifier biotools:brig ;
    schema1:keywords "Comparative genomics",
        "Computer Graphics",
        "Genome, Archaeal",
        "Genome, Bacterial",
        "Genomics",
        "User-Computer Interface" ;
    schema1:license "GPL-3.0+" ;
    schema1:name "brig" ;
    schema1:url "http://brig.sourceforge.net/" .

