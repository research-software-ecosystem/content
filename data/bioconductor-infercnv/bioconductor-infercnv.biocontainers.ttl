@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-infercnv a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18129/b9.bioc.infercnv" ;
    schema1:description "Infer copy number variation from single-cell rna-seq data" ;
    schema1:keywords "Genetics",
        "RNA-Seq",
        "Transcriptomics" ;
    schema1:license "BSD_3_clause" ;
    schema1:name "bioconductor-infercnv" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/infercnv.html" .

