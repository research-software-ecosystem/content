@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-taxa a schema1:SoftwareApplication ;
    schema1:description "taxa defines taxonomic classes and functions to manipulate them. The goal is to use these classes as low level fundamental taxonomic classes that other R packages can build on and supply robust manipulation functions (e.g. subsetting) that are broadly useful." ;
    schema1:license "Custom License" ;
    schema1:name "r-taxa" ;
    schema1:url "https://github.com/ropensci/taxa" .

