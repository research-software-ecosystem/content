@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:mrsfast a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth0810-576",
        "doi:10.1186/1471-2105-14-184" ;
    schema1:description "mrsFAST - micro-read substitution-only Fast Alignment Search Tool." ;
    schema1:identifier biotools:mrsfast ;
    schema1:keywords "Benchmarking",
        "Genome",
        "Genomics",
        "High-Throughput Nucleotide Sequencing",
        "Sequence Alignment",
        "Sequence Analysis, DNA" ;
    schema1:license "BSD" ;
    schema1:name "mrsfast" ;
    schema1:url "https://github.com/sfu-compbio/mrsfast" .

