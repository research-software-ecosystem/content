@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-pics a schema1:SoftwareApplication ;
    schema1:description "Probabilistic inference of ChIP-seq" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/PICS_2.50.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/PICS/PICS_2.50.0.tar.gz', 'https://bioarchive.galaxyproject.org/PICS_2.50.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-pics/bioconductor-pics_2.50.0_src_all.tar.gz']" ;
    schema1:identifier biotools:pics ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-pics" ;
    schema1:softwareVersion "2.50.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/PICS.html" ;
    spdx:builtFrom biotools:pics .

