@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-pics a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1111/j.1541-0420.2010.01441.x" ;
    schema1:description "Probabilistic inference of ChIP-seq" ;
    schema1:identifier biotools:pics ;
    schema1:keywords "Base Sequence",
        "ChIP-seq",
        "Chromatin Immunoprecipitation",
        "Clustering",
        "Computer Simulation",
        "DNA",
        "DNA binding sites",
        "Models, Genetic",
        "Models, Statistical",
        "Molecular Sequence Data",
        "Sequence Alignment",
        "Sequence Analysis, DNA",
        "Sequence sites, features and motifs",
        "Sequencing" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-pics" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/PICS.html" .

