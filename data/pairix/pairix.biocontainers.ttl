@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:pairix a schema1:SoftwareApplication ;
    schema1:description "2D indexing on bgzipped text files of paired genomic coordinates" ;
    schema1:license "MIT" ;
    schema1:name "pairix" ;
    schema1:url "https://github.com/4dn-dcic/pairix" .

