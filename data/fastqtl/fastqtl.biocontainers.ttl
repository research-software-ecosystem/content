@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:fastqtl a schema1:SoftwareApplication ;
    schema1:description "Quantitative trait loci (qtl) mapper in cis for molecular phenotypes" ;
    schema1:license "custom, see /usr/share/doc/fastqtl/copyright" ;
    schema1:name "fastqtl" ;
    schema1:url "http://fastqtl.sourceforge.net/" .

