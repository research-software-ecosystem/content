@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:jamm a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btu568" ;
    schema1:description "Jamm is a peak finder for ngs datasets (chip-seq, atac-seq, dnase-seq..etc.) that can integrate replicates and assign peak boundaries accurately." ;
    schema1:identifier biotools:jamm ;
    schema1:keywords "ChIP-seq",
        "Genetic Variation",
        "High-Throughput Nucleotide Sequencing",
        "Humans",
        "Models, Statistical",
        "Nucleic acids",
        "Reproducibility of Results",
        "Sequence Analysis, DNA",
        "Sequencing" ;
    schema1:license "GNU General Public License v3.0" ;
    schema1:name "jamm" ;
    schema1:url "https://github.com/mahmoudibrahim/JAMM" .

