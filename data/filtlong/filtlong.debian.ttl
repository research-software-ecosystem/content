@prefix debianmed: <https://salsa.debian.org/med-team/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

debianmed:filtlong a schema1:SoftwareApplication ;
    schema1:description "quality filtering tool for long reads of genome sequences" ;
    schema1:identifier "bio.tools:Filtlong",
        "conda:bioconda:filtlong" ;
    schema1:license "unknown" ;
    schema1:name "filtlong" ;
    schema1:softwareVersion "0.3.1" ;
    schema1:url "https://github.com/rrwick/Filtlong" ;
    spdx:builtFrom "Filtlong" .

