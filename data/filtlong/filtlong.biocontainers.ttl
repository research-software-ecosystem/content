@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:filtlong a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1099/MGEN.0.000312" ;
    schema1:description "Filtlong is a tool for filtering long reads. It can take a set of long reads and produce a smaller, better subset. It uses both read length (longer is better) and read identity (higher is better) when choosing which reads pass the filter." ;
    schema1:keywords "Bacteroides fragilis",
        "Drug Resistance, Multiple, Bacterial",
        "Genome, Bacterial",
        "Genomics",
        "High-Throughput Nucleotide Sequencing",
        "Humans",
        "Sequence Analysis, DNA",
        "Whole Genome Sequencing" ;
    schema1:license "GPL-3.0" ;
    schema1:name "filtlong" ;
    schema1:url "https://github.com/rrwick/Filtlong" .

