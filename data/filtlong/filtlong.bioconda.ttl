@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:filtlong a schema1:SoftwareApplication ;
    schema1:description "Filtlong is a tool for filtering long reads. It can take a set of long reads and produce a smaller, better subset. It uses both read length (longer is better) and read identity (higher is better) when choosing which reads pass the filter." ;
    schema1:downloadUrl "https://github.com/rrwick/Filtlong/archive/v0.3.1.tar.gz" ;
    schema1:identifier biotools:filtlong ;
    schema1:license "GPL-3.0-or-later" ;
    schema1:name "filtlong" ;
    schema1:softwareHelp "https://github.com/rrwick/Filtlong/blob/v0.3.1/README.md" ;
    schema1:softwareVersion "0.3.1" ;
    schema1:url "https://github.com/rrwick/Filtlong" ;
    spdx:builtFrom biotools:filtlong .

