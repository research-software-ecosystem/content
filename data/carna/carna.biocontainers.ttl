@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:carna a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1007/978-3-642-15396-9_16",
        "doi:10.1093/nar/gks491" ;
    schema1:description "Constraint-based alignment of rna ensembles" ;
    schema1:identifier biotools:carna ;
    schema1:keywords "Internet",
        "Nucleic Acid Conformation",
        "Nucleic acid structure analysis",
        "RNA",
        "Sequence Alignment",
        "Sequence Analysis, RNA",
        "Sequence analysis" ;
    schema1:license "GPL" ;
    schema1:name "carna" ;
    schema1:url "https://www.bioinf.uni-leipzig.de/~will/Software/CARNA/" .

