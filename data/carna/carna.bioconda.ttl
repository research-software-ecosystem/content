@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:carna a schema1:SoftwareApplication ;
    schema1:description "Constraint-based Alignment of RNA Ensembles" ;
    schema1:downloadUrl "http://www.bioinf.uni-leipzig.de/~will/Software/CARNA/Releases/carna-1.3.3.tar.gz" ;
    schema1:identifier biotools:carna ;
    schema1:license "GPL" ;
    schema1:name "carna" ;
    schema1:softwareVersion "1.3.3" ;
    schema1:url "https://www.bioinf.uni-leipzig.de/~will/Software/CARNA/" ;
    spdx:builtFrom biotools:carna .

