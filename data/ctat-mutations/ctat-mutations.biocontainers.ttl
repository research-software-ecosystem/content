@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:ctat-mutations a schema1:SoftwareApplication ;
    schema1:description " mutation detection in rna-seq using gatk-v4.0 in rna-seq variant calling, several sources of variant annotation, and filtering based on cravat." ;
    schema1:license "Not available" ;
    schema1:name "ctat-mutations" ;
    schema1:url "https://github.com/NCIP/ctat-mutations" .

