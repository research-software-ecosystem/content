@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:polystest a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1074/mcp.RA119.001777" ;
    schema1:description "Interactive tool for statistical testing, data browsing and interactive visualization of quantitative omics data" ;
    schema1:downloadUrl "https://bitbucket.org/veitveit/polystest/get/release-1.3.4.tar.gz" ;
    schema1:identifier biotools:polystest ;
    schema1:license "GPL (>=2)" ;
    schema1:name "polystest" ;
    schema1:softwareVersion "1.3.4" ;
    schema1:url "https://bitbucket.org/veitveit/polystest/src/master/" ;
    spdx:builtFrom biotools:polystest .

