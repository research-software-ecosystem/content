@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:ursgal a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1021/acs.jproteome.5b00860" ;
    schema1:description "Universal Python module combining common bottom-up proteomics tools for large-scale analysis" ;
    schema1:identifier biotools:ursgal ;
    schema1:keywords "Clustering",
        "Databases, Protein",
        "High-Throughput Screening Assays",
        "Mass spectra",
        "Mass spectrometry",
        "Peptides",
        "Proteomics",
        "Proteomics experiment",
        "Search Engine" ;
    schema1:license "LGPL" ;
    schema1:name "ursgal" ;
    schema1:url "https://github.com/ursgal/ursgal" .

