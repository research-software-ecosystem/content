@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:kmer-jellyfish a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btr011" ;
    schema1:description "Jellyfish is a tool for fast, memory-efficient counting of k-mers in DNA. A k-mer is a substring of length k, and counting the occurrences of all such substrings is a central step in many analyses of DNA sequence." ;
    schema1:downloadUrl "https://github.com/gmarcais/Jellyfish/releases/download/v2.3.1/jellyfish-2.3.1.tar.gz" ;
    schema1:identifier biotools:jellyfish ;
    schema1:license "GPL-3.0-or-later" ;
    schema1:name "kmer-jellyfish" ;
    schema1:softwareHelp "https://genome.umd.edu/docs/JellyfishUserGuide.pdf" ;
    schema1:softwareVersion "2.3.1" ;
    schema1:url "https://genome.umd.edu/jellyfish.html" ;
    spdx:builtFrom biotools:jellyfish .

