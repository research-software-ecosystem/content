@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-clusterexperiment a schema1:SoftwareApplication ;
    schema1:description "Compare Clusterings for Single-Cell Sequencing" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/clusterExperiment_2.30.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/clusterExperiment/clusterExperiment_2.30.0.tar.gz', 'https://bioarchive.galaxyproject.org/clusterExperiment_2.30.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-clusterexperiment/bioconductor-clusterexperiment_2.30.0_src_all.tar.gz']" ;
    schema1:identifier biotools:clusterexperiment ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-clusterexperiment" ;
    schema1:softwareVersion "2.30.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/clusterExperiment.html" ;
    spdx:builtFrom biotools:clusterexperiment .

