@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:nullarbor a schema1:SoftwareApplication ;
    schema1:description "Reads to report pipeline for bacterial isolate ngs data" ;
    schema1:identifier biotools:nullarbor ;
    schema1:keywords "Genomics",
        "Model organisms" ;
    schema1:license "GPL-2.0" ;
    schema1:name "nullarbor" ;
    schema1:url "https://github.com/tseemann/nullarbor" .

