@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:quorum a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1371/journal.pone.0130821" ;
    schema1:description "Quality optimized reads of genomic sequences" ;
    schema1:keywords "Animals",
        "Computational Biology",
        "Genome",
        "Genomics",
        "High-Throughput Nucleotide Sequencing",
        "Humans",
        "Sequence Analysis, DNA" ;
    schema1:license "GPL-3.0+" ;
    schema1:name "quorum" ;
    schema1:url "https://github.com/gmarcais/Quorum" .

