@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:pyfasta a schema1:SoftwareApplication ;
    schema1:description "Pythonic (and command-line) access to fasta sequence files." ;
    schema1:identifier biotools:pyfasta ;
    schema1:keywords "Sequence analysis" ;
    schema1:license "MIT" ;
    schema1:name "pyfasta" ;
    schema1:url "https://github.com/brentp/pyfasta/" .

