@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:pyfasta a schema1:SoftwareApplication ;
    schema1:description "fast, memory-efficient, pythonic (and command-line) access to fasta sequence files" ;
    schema1:downloadUrl "https://pypi.python.org/packages/source/p/pyfasta/pyfasta-0.5.2.tar.gz" ;
    schema1:identifier biotools:pyfasta ;
    schema1:license "MIT" ;
    schema1:name "pyfasta" ;
    schema1:softwareVersion "0.5.2" ;
    schema1:url "http://github.com/brentp/pyfasta/" ;
    spdx:builtFrom biotools:pyfasta .

