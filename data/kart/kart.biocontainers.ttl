@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:kart a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btx189" ;
    schema1:description "Kart: a divide-and-conquer algorithm for NGS read alignment" ;
    schema1:keywords "Genetic Variation",
        "Genome, Human",
        "High-Throughput Nucleotide Sequencing",
        "Humans",
        "Sequence Alignment",
        "Sequence Analysis, DNA" ;
    schema1:license "MIT" ;
    schema1:name "kart" ;
    schema1:url "https://github.com/hsinnan75/Kart" .

