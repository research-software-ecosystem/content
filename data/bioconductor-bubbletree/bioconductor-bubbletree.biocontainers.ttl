@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-bubbletree a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/gkv1102" ;
    schema1:description "BubbleTree: an intuitive visualization to elucidate tumoral aneuploidy and clonality in somatic mosaicism using next generation sequencing data" ;
    schema1:identifier biotools:bubbletree ;
    schema1:keywords "Aneuploidy",
        "DNA Copy Number Variations",
        "High-Throughput Nucleotide Sequencing",
        "Humans",
        "Neoplasms",
        "Oncology",
        "Sequence Analysis, DNA",
        "Whole genome sequencing" ;
    schema1:license "LGPL (>= 3)" ;
    schema1:name "bioconductor-bubbletree" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/BubbleTree.html" .

