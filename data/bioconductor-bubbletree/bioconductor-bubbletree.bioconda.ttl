@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-bubbletree a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/gkv1102" ;
    schema1:description "BubbleTree: an intuitive visualization to elucidate tumoral aneuploidy and clonality in somatic mosaicism using next generation sequencing data" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/BubbleTree_2.36.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/BubbleTree/BubbleTree_2.36.0.tar.gz', 'https://bioarchive.galaxyproject.org/BubbleTree_2.36.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-bubbletree/bioconductor-bubbletree_2.36.0_src_all.tar.gz']" ;
    schema1:identifier biotools:bubbletree ;
    schema1:license "LGPL (>= 3)" ;
    schema1:name "bioconductor-bubbletree" ;
    schema1:softwareVersion "2.36.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/BubbleTree.html" ;
    spdx:builtFrom biotools:bubbletree .

