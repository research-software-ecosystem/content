@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioperl a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1007/978-1-59745-535-0_26" ;
    schema1:description "A collection of perl modules that facilitate the development of perl scripts for bioinformatics applications.  it provides software modules for many of the typical tasks of bioinformatics programming." ;
    schema1:identifier biotools:bioperl ;
    schema1:keywords "Computational Biology",
        "Data management",
        "Databases, Genetic",
        "Genomics",
        "Programming Languages",
        "Software engineering",
        "User-Computer Interface" ;
    schema1:license "Perl" ;
    schema1:name "bioperl" ;
    schema1:url "http://bioperl.org/" .

