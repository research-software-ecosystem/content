@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:xatlas a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1101/295071" ;
    schema1:description "xAtlas is a fast and retrainable small variant caller that has been developed at the Baylor College of Medicine Human Genome Sequencing Center." ;
    schema1:license "BSD-3-Clause" ;
    schema1:name "xatlas" ;
    schema1:url "https://github.com/jfarek/xatlas" .

