@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-geneattribution a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btw698" ;
    schema1:description "Identification of candidate genes associated with genetic variation" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/geneAttribution_1.32.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/geneAttribution/geneAttribution_1.32.0.tar.gz', 'https://bioarchive.galaxyproject.org/geneAttribution_1.32.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-geneattribution/bioconductor-geneattribution_1.32.0_src_all.tar.gz']" ;
    schema1:identifier biotools:geneattribution ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-geneattribution" ;
    schema1:softwareVersion "1.32.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/geneAttribution.html" ;
    spdx:builtFrom biotools:geneattribution .

