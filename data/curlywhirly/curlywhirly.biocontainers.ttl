biocontainers:curlywhirly a schema1:SoftwareApplication ;
    schema1:description "Curlywhirly is an application for viewing multi-dimensional data, with a particular focus on the outputs of principle coordinate analysis and principal components analysis" ;
    schema1:keywords "RNA-Seq" ;
    schema1:license "Not available" ;
    schema1:name "curlywhirly" ;
    schema1:url "https://ics.hutton.ac.uk/curlywhirly" .

