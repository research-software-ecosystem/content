@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-precrec a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btw570",
        "doi:10.1371/journal.pone.0118432" ;
    schema1:description "Accurate calculations and visualization of precision-recall and ROC (Receiver Operator Characteristics) curves." ;
    schema1:keywords "Classification",
        "Datasets as Topic",
        "ROC Curve" ;
    schema1:license "GPL-3" ;
    schema1:name "r-precrec" ;
    schema1:url "https://github.com/takayasaito/precrec" .

