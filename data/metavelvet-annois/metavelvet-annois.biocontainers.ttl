@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:metavelvet-annois a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/gks678" ;
    schema1:description "Metavelvet annois - an extra package for metavelvet for versions < 1.2.01" ;
    schema1:identifier biotools:metavelvet ;
    schema1:keywords "Assembly",
        "Bacteria",
        "Gastrointestinal Tract",
        "Genome, Bacterial",
        "Genomics",
        "Humans",
        "Metagenome",
        "Metagenomics",
        "Sequence Analysis, DNA" ;
    schema1:license "Not available" ;
    schema1:name "metavelvet-annois" ;
    schema1:url "http://metavelvet.dna.bio.keio.ac.jp" .

