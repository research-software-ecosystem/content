@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r2r a schema1:SoftwareApplication ;
    schema1:description "software to speed depiction of aesthetic consensus RNA secondary structures" ;
    schema1:identifier biotools:r2r ;
    schema1:keywords "Data visualisation",
        "Sequencing" ;
    schema1:license "GPL-2" ;
    schema1:name "r2r" ;
    schema1:url "http://breaker.research.yale.edu/R2R/" .

