@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:py2bit a schema1:SoftwareApplication ;
    schema1:description "A package for accessing 2bit files using lib2bit" ;
    schema1:license "MIT" ;
    schema1:name "py2bit" ;
    schema1:url "https://github.com/deeptools/py2bit" .

