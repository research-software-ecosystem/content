@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-subseq a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btu552" ;
    schema1:description "Subsampling of high throughput sequencing count data for use in experiment design and analysis." ;
    schema1:identifier biotools:subseq ;
    schema1:keywords "Animals",
        "Gene expression",
        "High-Throughput Nucleotide Sequencing",
        "RNA-Seq",
        "Rats",
        "Sequence Analysis, RNA" ;
    schema1:license "MIT" ;
    schema1:name "bioconductor-subseq" ;
    schema1:url "http://bioconductor.org/packages/release/bioc/html/subSeq.html" .

