@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-subseq a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btu552" ;
    schema1:description "Subsampling of high-throughput sequencing count data" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/subSeq_1.36.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/subSeq/subSeq_1.36.0.tar.gz', 'https://bioarchive.galaxyproject.org/subSeq_1.36.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-subseq/bioconductor-subseq_1.36.0_src_all.tar.gz']" ;
    schema1:identifier biotools:subseq ;
    schema1:license "MIT + file LICENSE" ;
    schema1:name "bioconductor-subseq" ;
    schema1:softwareVersion "1.36.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/subSeq.html" ;
    spdx:builtFrom biotools:subseq .

