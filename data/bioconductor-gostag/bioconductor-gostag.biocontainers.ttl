@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-gostag a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18129/b9.bioc.gostag" ;
    schema1:description "A tool to use GO Subtrees to Tag and Annotate Genes within a set" ;
    schema1:keywords "Clustering",
        "RNA-Seq" ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-gostag" ;
    schema1:url "https://bioconductor.org/packages/3.8/bioc/html/goSTAG.html" .

