@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:rna-seqc a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/bts196" ;
    schema1:description "Fast, efficient RNA-Seq metrics for quality control and process optimization" ;
    schema1:identifier biotools:rna-seqc ;
    schema1:keywords "Gene Expression Profiling",
        "Gene Library",
        "High-Throughput Nucleotide Sequencing",
        "Internet",
        "Quality Control",
        "RNA",
        "RNA, Ribosomal",
        "RNA-Seq",
        "RNA-seq",
        "Sequence Analysis, RNA" ;
    schema1:license "BSD-3-Clause" ;
    schema1:name "rna-seqc" ;
    schema1:url "https://github.com/getzlab/rnaseqc" .

