@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:rna-seqc a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btab135" ;
    schema1:description "Fast, efficient RNA-Seq metrics for quality control and process optimization." ;
    schema1:downloadUrl "https://github.com/broadinstitute/rnaseqc/releases/download/v2.4.2/rnaseqc.v2.4.2.full_source.tar.gz" ;
    schema1:identifier biotools:rna-seqc ;
    schema1:license "BSD-3-Clause" ;
    schema1:name "rna-seqc" ;
    schema1:softwareHelp "https://github.com/getzlab/rnaseqc/blob/v2.4.2/README.md" ;
    schema1:softwareVersion "2.4.2" ;
    schema1:url "https://github.com/broadinstitute/rnaseqc" ;
    spdx:builtFrom biotools:rna-seqc .

