        "Phylogeny",
        "Polymorphism, Single Nucleotide",
        "Pseudomonas syringae",
        "Reproducibility of Results",
        "Sequence Alignment",
        "Sinorhizobium meliloti" ;
    schema1:license "Not available" ;
    schema1:name "realphy" ;
    schema1:url "https://realphy.unibas.ch/fcgi/realphy" .

