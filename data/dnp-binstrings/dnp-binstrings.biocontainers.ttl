@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:dnp-binstrings a schema1:SoftwareApplication ;
    schema1:description "Convert fasta strings into dinucleotide binary indicator string as 00101..." ;
    schema1:license "MIT" ;
    schema1:name "dnp-binstrings" ;
    schema1:url "https://github.com/erinijapranckeviciene/dnpatterntools" .

