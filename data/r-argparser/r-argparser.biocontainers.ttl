@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-argparser a schema1:SoftwareApplication ;
    schema1:description "Cross-platform command-line argument parser written purely in R with no external dependencies. It is useful with the Rscript front-end and facilitates turning an R script into an executable script." ;
    schema1:license "GPL (>= 3)" ;
    schema1:name "r-argparser" ;
    schema1:url "https://bitbucket.org/djhshih/argparser" .

