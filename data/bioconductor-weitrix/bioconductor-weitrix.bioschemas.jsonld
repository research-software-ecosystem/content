  "@graph": [
    {
      "@id": "https://bio.tools/bioconductor-weitrix",
      "@type": "sc:SoftwareApplication",
      "dcterms:conformsTo": "https://bioschemas.org/profiles/ComputationalTool/0.6-DRAFT",
      "sc:additionalType": [
        "Command-line tool",
        "Library"
      ],
      "sc:author": "Paul Harrison",
      "sc:citation": {
        "@id": "https://doi.org/10.18129/B9.bioc.weitrix"
      },
      "sc:description": "Data type and tools for working with matrices having precision weights and missing data. This package provides a common representation and tools that can be used with many types of high-throughput data. The meaning of the weights is compatible with usage in the base R function \"lm\" and the package \"limma\". Calibrate weights to account for known predictors of precision. Find rows with excess variability. Perform differential testing and find rows with the largest confident differences. Find PCA-like components of variation even with many missing values, rotated so that individual components may be meaningfully interpreted. DelayedArray matrices and BiocParallel are supported.",
      "sc:license": "LGPL-2.1-only",
      "sc:name": "weitrix",
      "sc:operatingSystem": [
        "Mac",
        "Linux",
        "Windows"
      ],
      "sc:softwareHelp": {
        "@id": "https://bioconductor.org/packages/weitrix"
      },
      "sc:softwareVersion": "1.22.0",
      "sc:url": "https://bioconductor.org/packages/weitrix"
    },
    {
      "@id": "https://doi.org/10.18129/B9.bioc.weitrix",
      "@type": "sc:CreativeWork"
    }
  ]
