@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-weitrix a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18129/b9.bioc.weitrix" ;
    schema1:description "Weighted matrix manipulation, finding components of variation with weighted or sparse data" ;
    schema1:keywords "RNA-Seq",
        "Transcriptomics" ;
    schema1:license "LGPL-2.1 | GNU LESSER GENERAL PUBLIC LICENSE" ;
    schema1:name "bioconductor-weitrix" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/weitrix.html" .

