@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:ccat a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btq128" ;
    schema1:description "ccat is a software package for the analysis of chip-seq data with negative control." ;
    schema1:identifier biotools:CCAT ;
    schema1:keywords "Binding Sites",
        "ChIP-seq",
        "Chromatin Immunoprecipitation",
        "Computational Biology",
        "Computer Simulation",
        "DNA packaging",
        "Gene Expression Regulation",
        "Genome",
        "Histones",
        "Models, Statistical",
        "Poisson Distribution",
        "Reproducibility of Results" ;
    schema1:license "Not available" ;
    schema1:name "ccat" ;
    schema1:url "http://cmb.gis.a-star.edu.sg/ChIPSeq/paperCCAT.htm" .

