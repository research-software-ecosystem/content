@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:ccat a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btq128" ;
    schema1:description "CCAT is a software package for the analysis of ChIP-seq data with negative control." ;
    schema1:downloadUrl "http://www.comp.nus.edu.sg/~bioinfo/CCAT3.0/CCAT3.0.tar.gz" ;
    schema1:identifier biotools:CCAT ;
    schema1:license "unknown" ;
    schema1:name "ccat" ;
    schema1:softwareVersion "3.0" ;
    schema1:url "http://cmb.gis.a-star.edu.sg/ChIPSeq/paperCCAT.htm" ;
    spdx:builtFrom biotools:CCAT .

