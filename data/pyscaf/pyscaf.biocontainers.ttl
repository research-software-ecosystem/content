@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:pyscaf a schema1:SoftwareApplication ;
    schema1:description "Genome assembly scaffolding using information from paired-end/mate-pair libraries, long reads, and synteny to closely related species." ;
    schema1:license "GPL-3.0" ;
    schema1:name "pyscaf" ;
    schema1:url "https://github.com/lpryszcz/pyScaf" .

