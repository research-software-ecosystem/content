@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-cellmapper a schema1:SoftwareApplication ;
    schema1:description "Predict genes expressed selectively in specific cell types" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/CellMapper_1.36.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/CellMapper/CellMapper_1.36.0.tar.gz', 'https://bioarchive.galaxyproject.org/CellMapper_1.36.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-cellmapper/bioconductor-cellmapper_1.36.0_src_all.tar.gz']" ;
    schema1:identifier biotools:cellmapper ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-cellmapper" ;
    schema1:softwareVersion "1.36.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/CellMapper.html" ;
    spdx:builtFrom biotools:cellmapper .

