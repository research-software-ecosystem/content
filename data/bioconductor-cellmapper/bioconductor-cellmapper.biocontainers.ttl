@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-cellmapper a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s13059-016-1062-5" ;
    schema1:description "Infers cell type-specific expression based on co-expression similarity with known cell type marker genes. can make accurate predictions using publicly available expression data, even when a cell type has not been isolated before." ;
    schema1:identifier biotools:cellmapper ;
    schema1:keywords "Animals",
        "Brain",
        "Caco-2 Cells",
        "Cell Line",
        "Cells, Cultured",
        "Computational Biology",
        "Endothelial Cells",
        "Gene Expression Profiling",
        "Gene expression",
        "Genetic Predisposition to Disease",
        "Genome-Wide Association Study",
        "Hematopoietic Stem Cells",
        "Humans",
        "Immune System",
        "Mice, Inbred C57BL",
        "Neurons",
        "Polymorphism, Single Nucleotide",
        "Reproducibility of Results",
        "Spleen" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-cellmapper" ;
    schema1:url "http://bioconductor.org/packages/release/bioc/html/CellMapper.html" .

