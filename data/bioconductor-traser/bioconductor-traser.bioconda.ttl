@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-traser a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btv741" ;
    schema1:description "GWAS trait-associated SNP enrichment analyses in genomic intervals" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/traseR_1.40.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/traseR/traseR_1.40.0.tar.gz', 'https://bioarchive.galaxyproject.org/traseR_1.40.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-traser/bioconductor-traser_1.40.0_src_all.tar.gz']" ;
    schema1:identifier biotools:traser ;
    schema1:license "GPL" ;
    schema1:name "bioconductor-traser" ;
    schema1:softwareVersion "1.40.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/traseR.html" ;
    spdx:builtFrom biotools:traser .

