@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-traser a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btv741" ;
    schema1:description "GWAS trait-associated SNP enrichment analyses in genomic intervals" ;
    schema1:identifier biotools:traser ;
    schema1:keywords "DNA polymorphism",
        "GWAS study",
        "Genetics",
        "Genome-Wide Association Study",
        "Genomics",
        "Humans",
        "Phenotype",
        "Polymorphism, Single Nucleotide" ;
    schema1:license "GPL" ;
    schema1:name "bioconductor-traser" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/traseR.html" .

