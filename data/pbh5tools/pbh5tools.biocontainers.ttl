@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:pbh5tools a schema1:SoftwareApplication ;
    schema1:description "Tools for manipulating pacific biosciences hdf5 files" ;
    schema1:license "PacBio-BSD-3-Clause" ;
    schema1:name "pbh5tools" ;
    schema1:url "https://github.com/PacificBiosciences/pbh5tools" .

