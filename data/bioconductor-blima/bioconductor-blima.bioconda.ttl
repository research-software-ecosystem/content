@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-blima a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Tools for the preprocessing and analysis of the Illumina microarrays on the detector (bead) level" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/blima_1.40.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/blima/blima_1.40.0.tar.gz', 'https://bioarchive.galaxyproject.org/blima_1.40.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-blima/bioconductor-blima_1.40.0_src_all.tar.gz']" ;
    schema1:identifier biotools:blima ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-blima" ;
    schema1:softwareVersion "1.40.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/blima.html" ;
    spdx:builtFrom biotools:blima .

