@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:raxml a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btu033" ;
    schema1:description "A tool for phylogenetic analysis and post-analysis of large phylogenies." ;
    schema1:identifier biotools:raxml ;
    schema1:keywords "High-Throughput Nucleotide Sequencing",
        "Likelihood Functions",
        "Models, Genetic",
        "Phylogenetics",
        "Phylogeny",
        "Sequence analysis" ;
    schema1:license "GPL" ;
    schema1:name "raxml" ;
    schema1:url "https://github.com/stamatak/standard-RAxML" .

