@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:raxml a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btu033" ;
    schema1:description "Phylogenetics - Randomized Axelerated Maximum Likelihood." ;
    schema1:downloadUrl "https://github.com/stamatak/standard-RAxML/archive/refs/tags/v8.2.13.tar.gz" ;
    schema1:identifier biotools:raxml ;
    schema1:license "GPL" ;
    schema1:name "raxml" ;
    schema1:softwareVersion "8.2.13" ;
    schema1:url "http://sco.h-its.org/exelixis/web/software/raxml/index.html" ;
    spdx:builtFrom biotools:raxml .

