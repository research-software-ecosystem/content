@prefix debianmed: <https://salsa.debian.org/med-team/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

debianmed:raxml a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btl446",
        "doi:10.1093/bioinformatics/btu033" ;
    schema1:description "Randomized Axelerated Maximum Likelihood of phylogenetic trees" ;
    schema1:identifier "bio.tools:raxml",
        "conda:bioconda:raxml",
        "scicrunch:SCR_006086" ;
    schema1:keywords "field::biology",
        "role::program" ;
    schema1:license "unknown" ;
    schema1:name "raxml" ;
    schema1:softwareVersion "8.2.13" ;
    schema1:url "https://cme.h-its.org/exelixis/web/software/raxml/index.html" ;
    spdx:builtFrom "raxml" .

