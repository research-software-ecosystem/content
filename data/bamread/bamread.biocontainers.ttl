@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bamread a schema1:SoftwareApplication ;
    schema1:description "Read bam files quickly into dataframes in Python" ;
    schema1:license "MIT" ;
    schema1:name "bamread" ;
    schema1:url "http://github.com/endrebak/bamread" .

