@prefix debianmed: <https://salsa.debian.org/med-team/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

debianmed:proftmb a schema1:SoftwareApplication ;
    schema1:description "per-residue prediction of bacterial transmembrane beta barrels" ;
    schema1:identifier "bio.tools:proftmb",
