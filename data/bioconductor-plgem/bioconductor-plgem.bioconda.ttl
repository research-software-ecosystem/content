@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-plgem a schema1:SoftwareApplication ;
    schema1:description "Detect differential expression in microarray and proteomics datasets with the Power Law Global Error Model (PLGEM)" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/plgem_1.78.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/plgem/plgem_1.78.0.tar.gz', 'https://bioarchive.galaxyproject.org/plgem_1.78.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-plgem/bioconductor-plgem_1.78.0_src_all.tar.gz']" ;
    schema1:identifier biotools:plgem ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-plgem" ;
    schema1:softwareVersion "1.78.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/plgem.html" ;
    spdx:builtFrom biotools:plgem .

