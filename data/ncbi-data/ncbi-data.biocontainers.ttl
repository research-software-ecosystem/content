@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:ncbi-data a schema1:SoftwareApplication ;
    schema1:description "Platform-independent data for the ncbi toolkit" ;
    schema1:license "public_domain" ;
    schema1:name "ncbi-data" ;
    schema1:url "http://www.ncbi.nlm.nih.gov/IEB/ToolBox/" .

