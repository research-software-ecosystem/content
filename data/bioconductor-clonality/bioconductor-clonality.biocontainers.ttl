@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-clonality a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btr268" ;
    schema1:description "Clonality testing" ;
    schema1:identifier biotools:clonality ;
    schema1:keywords "Artificial Intelligence",
        "Biomarkers",
        "Models, Molecular",
        "Oncology",
        "Protein Conformation",
        "Proteins",
        "Quality Control",
        "Statistics and probability" ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-clonality" ;
    schema1:url "https://www.bioconductor.org/packages/release/bioc/html/Clonality.html" .

