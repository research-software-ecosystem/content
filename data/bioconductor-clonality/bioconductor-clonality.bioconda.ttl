@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-clonality a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btr268" ;
    schema1:description "Clonality testing" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.17/bioc/src/contrib/Clonality_1.47.0.tar.gz', 'https://bioconductor.org/packages/3.17/bioc/src/contrib/Archive/Clonality/Clonality_1.47.0.tar.gz', 'https://bioarchive.galaxyproject.org/Clonality_1.47.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-clonality/bioconductor-clonality_1.47.0_src_all.tar.gz']" ;
    schema1:identifier biotools:clonality ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-clonality" ;
    schema1:softwareVersion "1.47.0" ;
    schema1:url "https://bioconductor.org/packages/3.17/bioc/html/Clonality.html" ;
    spdx:builtFrom biotools:clonality .

