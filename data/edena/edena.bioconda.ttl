@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:edena a schema1:SoftwareApplication ;
    schema1:description "De novo short reads assembler." ;
    schema1:downloadUrl "http://www.genomic.ch/edena/EdenaV3.131028.tar.gz" ;
    schema1:identifier biotools:edena ;
    schema1:license "GPL-3.0-or-later" ;
    schema1:name "edena" ;
    schema1:softwareVersion "3.131028" ;
    schema1:url "http://www.genomic.ch/edena.php" ;
    spdx:builtFrom biotools:edena .

