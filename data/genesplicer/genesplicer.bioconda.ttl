@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:genesplicer a schema1:SoftwareApplication ;
    schema1:description "GeneSplicer : A computational method for splice site prediction." ;
    schema1:downloadUrl "['https://depot.galaxyproject.org/software/genesplicer/genesplicer_0_2003.04.03_src_all.tar.gz', 'http://www.cs.jhu.edu/~genomics/GeneSplicer/GeneSplicer.tar.gz', 'ftp://ftp.ccb.jhu.edu/pub/software/genesplicer/GeneSplicer.tar.gz']" ;
    schema1:identifier biotools:genesplicer ;
    schema1:license "OSI" ;
    schema1:name "genesplicer" ;
    schema1:softwareHelp "https://ccb.jhu.edu/software/genesplicer" ;
    schema1:softwareVersion "0_2003.04.03" ;
    schema1:url "https://ccb.jhu.edu/software/genesplicer" ;
    spdx:builtFrom biotools:genesplicer .

