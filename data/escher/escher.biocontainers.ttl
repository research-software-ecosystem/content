        "Internet",
        "Metabolic Networks and Pathways",
        "Models, Biological",
        "Signal Transduction",
        "Transcriptome" ;
    schema1:license "MIT" ;
    schema1:name "escher" ;
    schema1:url "https://github.com/zakandrewking/escher" .

