@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-metaseqr2 a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/gku1273",
        "doi:10.18129/b9.bioc.metaseqr2" ;
    schema1:description "An R package for the analysis and result reporting of RNA-Seq data by combining multiple statistical algorithms" ;
    schema1:identifier biotools:metaseqr ;
    schema1:keywords "Clustering",
        "Data Interpretation, Statistical",
        "Gene Expression",
        "Gene Expression Profiling",
        "Genetics",
        "Genomics",
        "RNA Polymerase II",
        "RNA-Seq",
        "Sensitivity and Specificity",
        "Sequence Analysis, RNA",
        "Transcriptomics" ;
    schema1:license "GPL-3.0" ;
    schema1:name "bioconductor-metaseqr2" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/metaseqR2.html" .

