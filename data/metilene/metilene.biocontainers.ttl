@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:metilene a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1101/gr.196394.115" ;
    schema1:description "Fast and sensitive detection of differential dna methylation" ;
    schema1:keywords "Case-Control Studies",
        "Cerebellar Neoplasms",
        "CpG Islands",
        "DNA Methylation",
        "Humans",
        "Medulloblastoma",
        "Sequence Analysis, DNA" ;
    schema1:license "GPL-2.0" ;
    schema1:name "metilene" ;
    schema1:url "http://www.bioinf.uni-leipzig.de/Software/metilene/" .

