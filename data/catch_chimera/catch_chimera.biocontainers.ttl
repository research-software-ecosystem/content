@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:catch_chimera a schema1:SoftwareApplication ;
    schema1:description "Catch is an ensemble classifier for chimera detection in 16s rrna sequencing studies. the present bioconda recipe installs the 'catch_v1.run' binary, as suggested on authors website." ;
    schema1:license "Not available" ;
    schema1:name "catch_chimera" ;
    schema1:url "https://science.sckcen.be/en/Institutes/EHS/MCB/MIC/Bioinformatics/CATCh" .

