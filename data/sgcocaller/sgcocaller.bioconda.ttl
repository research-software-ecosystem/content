@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:sgcocaller a schema1:SoftwareApplication ;
    schema1:description "Personalized haplotype construction and crossover calling in single-cell DNA sequenced gamete cells." ;
    schema1:downloadUrl "https://github.com/ruqianl/sgcocaller/archive/refs/tags/v0.3.9.tar.gz" ;
    schema1:identifier biotools:sgcocaller ;
    schema1:license "MIT" ;
    schema1:name "sgcocaller" ;
    schema1:softwareHelp "https://gitlab.svi.edu.au/biocellgen-public/sgcocaller" ;
    schema1:softwareVersion "0.3.9" ;
    schema1:url "https://gitlab.svi.edu.au/biocellgen-public/sgcocaller" ;
    spdx:builtFrom biotools:sgcocaller .

