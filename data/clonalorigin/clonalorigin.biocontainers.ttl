@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:clonalorigin a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1534/genetics.110.120121" ;
    schema1:description "Clonalorigin is a tool for recombination detection in bacteria. clonalorigin performs a comparative analysis of the sequences of a sample of bacterial genomes in order to reconstruct the recombination events that have taken place in their ancestry." ;
    schema1:identifier biotools:clonalorigin ;
    schema1:keywords "Bacillus cereus",
        "DNA",
        "Gene Conversion",
        "Genetics",
        "Genome, Bacterial",
        "Genomics",
        "Internet",
        "Models, Theoretical",
        "Recombination, Genetic",
        "Sequences" ;
    schema1:license "GPL-3" ;
    schema1:name "clonalorigin" ;
    schema1:url "http://code.google.com/p/clonalorigin/" .

