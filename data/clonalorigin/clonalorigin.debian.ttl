@prefix debianmed: <https://salsa.debian.org/med-team/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

debianmed:clonalorigin a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1534/genetics.110.120121" ;
    schema1:description "inference of homologous recombination in bacteria using whole genome sequences" ;
    schema1:identifier "bio.tools:ClonalOrigin",
        "omictools:OMICS_18881",
        "scicrunch:SCR_016061" ;
    schema1:license "unknown" ;
    schema1:name "clonalorigin" ;
    schema1:softwareVersion "1.0" ;
    schema1:url "https://github.com/xavierdidelot/clonalorigin" ;
    spdx:builtFrom "ClonalOrigin" .

