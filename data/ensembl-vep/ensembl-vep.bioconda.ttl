@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:ensembl-vep a schema1:SoftwareApplication ;
    schema1:description "Ensembl Variant Effect Predictor" ;
    schema1:downloadUrl "https://github.com/Ensembl/ensembl-vep/archive/refs/tags/release/115.2.tar.gz" ;
    schema1:identifier biotools:vep ;
    schema1:license "Apache-2.0" ;
    schema1:name "ensembl-vep" ;
    schema1:softwareHelp "https://useast.ensembl.org/info/docs/tools/vep/script/vep_tutorial.html" ;
    schema1:softwareVersion "115.2" ;
    schema1:url "https://www.ensembl.org/info/docs/tools/vep/index.html" ;
    spdx:builtFrom biotools:vep .

