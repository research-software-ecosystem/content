@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:admixtools a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1534/genetics.112.145037" ;
    schema1:description "ADMIXTOOLS (Patterson et al. 2012) is a software package that supports formal tests of whether admixture occurred, and makes it possible to infer admixture proportions and dates." ;
    schema1:identifier biotools:AdmixTools ;
    schema1:keywords "Continental Population Groups",
        "Ethnic Groups",
        "Evolution, Molecular",
        "Gene Flow",
        "Genetics, Population",
        "Humans",
        "Hybridization, Genetic",
        "Internet",
        "Models, Genetic",
        "Polymorphism, Single Nucleotide",
        "Population genetics" ;
    schema1:license "Free for Academic Use" ;
    schema1:name "admixtools" ;
    schema1:url "https://github.com/DReichLab/AdmixTools" .

