@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:admixtools a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1534/genetics.112.145037" ;
    schema1:description "ADMIXTOOLS (Patterson et al. 2012) is a software package that supports formal tests of whether admixture occurred, and makes it possible to infer admixture proportions and dates." ;
    schema1:downloadUrl "https://github.com/DReichLab/AdmixTools/archive/refs/tags/v8.0.2.tar.gz" ;
    schema1:identifier biotools:AdmixTools ;
    schema1:license "Academic License" ;
    schema1:name "admixtools" ;
    schema1:softwareHelp "https://github.com/DReichLab/AdmixTools/blob/v8.0.2/README" ;
    schema1:softwareVersion "8.0.2" ;
    schema1:url "https://github.com/DReichLab/AdmixTools" ;
    spdx:builtFrom biotools:AdmixTools .

