@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-grmetrics a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Calculate growth-rate inhibition (GR) metrics" ;
    schema1:identifier biotools:grmetrics ;
    schema1:keywords "Cell biology",
        "Computational Biology",
        "Drug discovery",
        "Gene Expression Profiling",
        "Genomics",
        "High-Throughput Screening Assays",
        "Programming Languages",
        "User-Computer Interface" ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-grmetrics" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/GRmetrics.html" .

