@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-grmetrics a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Calculate growth-rate inhibition (GR) metrics" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/GRmetrics_1.32.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/GRmetrics/GRmetrics_1.32.0.tar.gz', 'https://bioarchive.galaxyproject.org/GRmetrics_1.32.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-grmetrics/bioconductor-grmetrics_1.32.0_src_all.tar.gz']" ;
    schema1:identifier biotools:grmetrics ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-grmetrics" ;
    schema1:softwareVersion "1.32.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/GRmetrics.html" ;
    spdx:builtFrom biotools:grmetrics .

