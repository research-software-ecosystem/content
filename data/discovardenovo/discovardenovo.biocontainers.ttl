@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:discovardenovo a schema1:SoftwareApplication ;
    schema1:description "Genome assembler designed for state-of-the-art data. it can generate de novo assemblies for both large and small genomes. it currently does not call variants." ;
    schema1:license "Not available" ;
    schema1:name "discovardenovo" ;
    schema1:url "http://www.broadinstitute.org/software/discovar/blog/" .

