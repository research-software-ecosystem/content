@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:salmon a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.4197" ;
    schema1:description "Wicked-fast transcript quantification from rna-seq data" ;
    schema1:identifier biotools:salmon ;
    schema1:keywords "Base Composition",
        "Bayes Theorem",
        "Gene Expression Profiling",
        "Gene expression",
        "Genomics",
        "RNA-Seq",
        "RNA-seq",
        "Sequence Analysis, RNA",
        "Transcriptome",
        "Transcriptomics" ;
    schema1:license "GPL-3.0" ;
    schema1:name "salmon" ;
    schema1:url "https://github.com/COMBINE-lab/salmon" .

