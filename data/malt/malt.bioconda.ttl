@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:malt a schema1:SoftwareApplication ;
    schema1:description "A tool for mapping metagenomic data" ;
    schema1:downloadUrl "https://maira.cs.uni-tuebingen.de/download/malt/MALT_unix_0_6_2.sh" ;
    schema1:identifier biotools:malt ;
    schema1:license "GPLv3" ;
    schema1:name "malt" ;
    schema1:softwareVersion "0.62" ;
    schema1:url "http://ab.inf.uni-tuebingen.de/software/malt/" ;
    spdx:builtFrom biotools:malt .

