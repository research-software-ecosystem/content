@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:malt a schema1:SoftwareApplication ;
    schema1:description "A tool for mapping metagenomic data" ;
    schema1:identifier biotools:malt ;
    schema1:license "GPL-3.0" ;
    schema1:name "malt" ;
    schema1:url "http://ab.inf.uni-tuebingen.de/software/malt/" .

