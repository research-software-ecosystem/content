@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-omicplotr a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18129/b9.bioc.omicplotr" ;
    schema1:description "Visual exploration of omic datasets using a shiny app" ;
    schema1:keywords "Genomics",
        "Metagenomics",
        "RNA-Seq",
        "Transcriptomics" ;
    schema1:license "MIT" ;
    schema1:name "bioconductor-omicplotr" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/omicplotR.html" .

