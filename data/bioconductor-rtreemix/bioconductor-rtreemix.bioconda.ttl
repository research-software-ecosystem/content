@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-rtreemix a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btn410" ;
    schema1:description "Rtreemix: Mutagenetic trees mixture models." ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/Rtreemix_1.68.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/Rtreemix/Rtreemix_1.68.0.tar.gz', 'https://bioarchive.galaxyproject.org/Rtreemix_1.68.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-rtreemix/bioconductor-rtreemix_1.68.0_src_all.tar.gz']" ;
    schema1:identifier biotools:rtreemix ;
    schema1:license "LGPL" ;
    schema1:name "bioconductor-rtreemix" ;
    schema1:softwareVersion "1.68.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/Rtreemix.html" ;
    spdx:builtFrom biotools:rtreemix .

