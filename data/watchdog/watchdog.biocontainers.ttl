@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:watchdog a schema1:SoftwareApplication ;
    schema1:description "Filesystem events monitoring" ;
    schema1:identifier biotools:watchdog ;
    schema1:license "Apache Software License" ;
    schema1:name "watchdog" ;
    schema1:url "None" .

