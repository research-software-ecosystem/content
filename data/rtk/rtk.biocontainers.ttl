@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:rtk a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btx206" ;
    schema1:description "rtk - rarefaction toolkit for OTU tables" ;
    schema1:identifier biotools:rtk ;
    schema1:keywords "Computational Biology",
        "Environment",
        "Microbial ecology",
        "Microbiology",
        "Microbiota",
        "Population genetics" ;
    schema1:license "GPL-2.0" ;
    schema1:name "rtk" ;
    schema1:url "https://github.com/hildebra/Rarefaction/" .

