@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-genegeneinter a schema1:SoftwareApplication ;
    schema1:description "Tools for Testing Gene-Gene Interaction at the Gene Level" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/GeneGeneInteR_1.32.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/GeneGeneInteR/GeneGeneInteR_1.32.0.tar.gz', 'https://bioarchive.galaxyproject.org/GeneGeneInteR_1.32.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-genegeneinter/bioconductor-genegeneinter_1.32.0_src_all.tar.gz']" ;
    schema1:identifier biotools:genegeneinter ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-genegeneinter" ;
    schema1:softwareVersion "1.32.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/GeneGeneInteR.html" ;
    spdx:builtFrom biotools:genegeneinter .

