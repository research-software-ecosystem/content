@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:plotly a schema1:SoftwareApplication ;
    schema1:description "The interactive graphing library for Python (includes Plotly Express)" ;
    schema1:license "MI" ;
    schema1:name "plotly" ;
    schema1:url "https://github.com/plotly/plotly.py" .

