@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bufet a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s12859-017-1812-8" ;
    schema1:description "Tool that performs the unbiased miRNA functional enrichment analysis (Bleazard et al.) requiring significantly reduced excution times (less than 10 minutes for 1 million iterations)." ;
    schema1:identifier biotools:BUFET ;
    schema1:keywords "Bioinformatics",
        "Computational Biology",
        "MicroRNAs" ;
    schema1:license "file" ;
    schema1:name "bufet" ;
    schema1:url "https://github.com/diwis/BUFET/" .

