@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bufet a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s12859-017-1812-8" ;
    schema1:description "Tool that performs the unbiased miRNA functional enrichment analysis (Bleazard et al.) requiring significantly reduced excution times (less than 10 minutes for 1 million iterations)." ;
    schema1:downloadUrl "https://github.com/diwis/BUFET/archive/f8bdc647b63326dabc3eb4b100995397acef7e6a.zip" ;
    schema1:identifier biotools:BUFET ;
    schema1:license "file" ;
    schema1:name "bufet" ;
    schema1:softwareVersion "1.0" ;
    schema1:url "https://github.com/diwis/BUFET/" ;
    spdx:builtFrom biotools:BUFET .

