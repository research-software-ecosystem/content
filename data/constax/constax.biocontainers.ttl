@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:constax a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s12859-017-1952-x" ;
    schema1:description "A software for accurate taxonomic classification of environmental dna markers" ;
    schema1:identifier biotools:constax ;
    schema1:keywords "DNA, Fungal",
        "DNA, Intergenic",
        "Environmental Microbiology",
        "Fungi",
        "Genome, Fungal",
        "Genomics",
        "High-Throughput Nucleotide Sequencing",
        "Taxonomy" ;
    schema1:license "Not available" ;
    schema1:name "constax" ;
    schema1:url "https://github.com/liberjul/CONSTAXv2" .

