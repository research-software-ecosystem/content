@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:coverm a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btaf147" ;
    schema1:description "CoverM aims to be a configurable, easy to use and fast DNA read coverage and relative abundance calculator focused on metagenomics applications." ;
    schema1:downloadUrl "https://github.com/wwood/coverm/archive/v0.7.0.tar.gz" ;
    schema1:identifier biotools:coverm ;
    schema1:license "GPL-3.0-or-later" ;
    schema1:name "coverm" ;
    schema1:softwareHelp "https://github.com/wwood/CoverM/blob/v0.7.0/README.md" ;
    schema1:softwareVersion "0.7.0" ;
    schema1:url "https://github.com/wwood/CoverM" ;
    spdx:builtFrom biotools:coverm .

