@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:coverm a schema1:SoftwareApplication ;
    schema1:description "CoverM aims to be a configurable, easy to use and fast DNA read coverage and relative abundance calculator focused on metagenomics applications" ;
    schema1:keywords "Genomics",
        "Metagenomics",
        "RNA-Seq" ;
    schema1:license "GPL-3.0" ;
    schema1:name "coverm" ;
    schema1:url "https://github.com/wwood/CoverM" .

