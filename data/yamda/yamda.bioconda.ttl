@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:yamda a schema1:SoftwareApplication ;
    schema1:description "A highly scalable GPU-accelerated de novo motif discovery software package" ;
    schema1:downloadUrl "https://github.com/daquang/YAMDA/archive/00e9c9d.tar.gz" ;
    schema1:identifier biotools:yamda ;
    schema1:license "MIT" ;
    schema1:name "yamda" ;
    schema1:softwareVersion "0.1.00e9c9d" ;
    schema1:url "https://github.com/daquang/YAMDA" ;
    spdx:builtFrom biotools:yamda .

