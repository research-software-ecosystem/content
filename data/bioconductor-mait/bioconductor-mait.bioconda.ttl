@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-mait a schema1:SoftwareApplication ;
    schema1:description "Statistical Analysis of Metabolomic Data" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/MAIT_1.40.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/MAIT/MAIT_1.40.0.tar.gz', 'https://bioarchive.galaxyproject.org/MAIT_1.40.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-mait/bioconductor-mait_1.40.0_src_all.tar.gz']" ;
    schema1:identifier biotools:mait ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-mait" ;
    schema1:softwareVersion "1.40.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/MAIT.html" ;
    spdx:builtFrom biotools:mait .

