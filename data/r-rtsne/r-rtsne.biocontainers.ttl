@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-rtsne a schema1:SoftwareApplication ;
    schema1:description "n R wrapper around the fast T-distributed Stochastic Neighbor Embedding implementation by Van der Maaten (see <https://github.com/lvdmaaten/bhtsne/> for more information on the original implementation)." ;
    schema1:keywords "Clustering",
        "Genomics",
        "Metagenomics" ;
    schema1:license "BSD-style licence" ;
    schema1:name "r-rtsne" ;
    schema1:url "https://CRAN.R-project.org/package=Rtsne" .

