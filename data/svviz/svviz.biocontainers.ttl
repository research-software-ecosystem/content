@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:svviz a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btv478" ;
    schema1:description "A read visualizer for structural variants" ;
    schema1:identifier biotools:svviz ;
    schema1:keywords "Alleles",
        "DNA",
        "Genomic Structural Variation",
        "Genomics",
        "Sequence Alignment",
        "Sequence analysis",
        "Sequencing" ;
    schema1:license "MIT" ;
    schema1:name "svviz" ;
    schema1:url "https://github.com/svviz/svviz" .

