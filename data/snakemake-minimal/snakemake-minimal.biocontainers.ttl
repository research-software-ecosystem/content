@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:snakemake-minimal a schema1:SoftwareApplication ;
    schema1:description "Snakemake is a workflow management system that aims to reduce the complexity of creating workflows by providing a fast and comfortable execution environment, together with a clean and modern specification language in python style." ;
    schema1:license "MIT" ;
    schema1:name "snakemake-minimal" ;
    schema1:url "https://github.com/snakemake/snakemake/" .

