@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-tximportdata a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18129/b9.bioc.tximportdata" ;
    schema1:description "This package provides the output of running various transcript abundance quantifiers on a set of 6 RNA-seq samples from the GEUVADIS project" ;
    schema1:keywords "RNA-Seq",
        "Transcriptome" ;
    schema1:license "GPL-2.0" ;
    schema1:name "bioconductor-tximportdata" ;
    schema1:url "http://bioconductor.org/packages/release/data/experiment/html/tximportData.html" .

