@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:velvetoptimiser a schema1:SoftwareApplication ;
    schema1:description "This tool is designed to run as a wrapper script for the velvet assembler (daniel zerbino, ebi uk) and to assist with optimising the assembly." ;
    schema1:identifier biotools:velvetoptimiser ;
    schema1:keywords "Genomics",
        "Sequence assembly" ;
    schema1:license "GPL-2.0" ;
    schema1:name "velvetoptimiser" ;
    schema1:url "https://github.com/Slugger70/VelvetOptimiser" .

