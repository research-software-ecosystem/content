@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:generax a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1101/779066" ;
    schema1:description "GeneRax: a parallel tool for species tree-aware maximum likelihood based gene tree inference under gene duplication, transfer, and loss." ;
    schema1:license "AGPL-3" ;
    schema1:name "generax" ;
    schema1:url "https://github.com/benoitmorel/generax" .

