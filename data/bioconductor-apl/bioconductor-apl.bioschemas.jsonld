  "@graph": [
    {
      "@id": "https://bio.tools/bioconductor-apl",
      "@type": "sc:SoftwareApplication",
      "dcterms:conformsTo": "https://bioschemas.org/profiles/ComputationalTool/0.6-DRAFT",
      "sc:additionalType": [
        "Library",
        "Command-line tool"
      ],
      "sc:author": [
        "Clemens Kohl",
        "Martin Vingron",
        "Elzbieta Gralinska"
      ],
      "sc:citation": {
        "@id": "https://doi.org/10.18129/B9.bioc.APL"
      },
      "sc:description": "APL is a package developed for computation of Association Plots (AP), a method for visualization and analysis of single cell transcriptomics data. The main focus of APL is the identification of genes characteristic for individual clusters of cells from input data. The package performs correspondence analysis (CA) and allows to identify cluster-specific genes using Association Plots. Additionally, APL computes the cluster-specificity scores for all genes which allows to rank the genes by their specificity for a selected cell cluster of interest.",
      "sc:license": "GPL-3.0-or-later",
      "sc:name": "APL",
      "sc:operatingSystem": [
        "Mac",
        "Linux",
        "Windows"
      ],
      "sc:softwareHelp": {
        "@id": "https://bioconductor.org/packages/APL"
      },
      "sc:softwareVersion": "1.14.0",
      "sc:url": "https://bioconductor.org/packages/APL"
    },
    {
      "@id": "https://doi.org/10.18129/B9.bioc.APL",
      "@type": "sc:CreativeWork"
    }
