@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-reactomegsa a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18129/b9.bioc.reactomegsa" ;
    schema1:description "Client for the reactome analysis service for comparative multi-omics gene set analysis" ;
    schema1:keywords "Proteomics",
        "Transcriptomics" ;
    schema1:license "MIT" ;
    schema1:name "bioconductor-reactomegsa" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/ReactomeGSA.html" .

