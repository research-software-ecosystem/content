@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:tagger a schema1:SoftwareApplication ;
    schema1:description "tagger allows you to tag a corpus of documents with search terms that you provide. It is often used to find mentions of proteins, species, diseases, tissues, chemicals and drugs, GO terms, and so forth, in articles in the Medline corpus." ;
    schema1:keywords "Ortholog" ;
    schema1:license "BSD 2-Clause License" ;
    schema1:name "tagger" ;
    schema1:url "https://github.com/larsjuhljensen/tagger" .

