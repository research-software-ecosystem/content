@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-sendmailr a schema1:SoftwareApplication ;
    schema1:description "Package contains a simple SMTP client which provides a portable solution for sending email, including attachment, from within R." ;
    schema1:license "GPL-2" ;
    schema1:name "r-sendmailr" ;
    schema1:url "None" .

