@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-pinfsc50 a schema1:SoftwareApplication ;
    schema1:description "Genomic data for the plant pathogen \"Phytophthora infestans.\" It includes a variant file ('VCF'), a sequence file ('FASTA') and an annotation file ('GFF'). This package is intended to be used as example data for packages that work with genomic data." ;
    schema1:license "GPL" ;
    schema1:name "r-pinfsc50" ;
    schema1:url "https://CRAN.R-project.org/package=pinfsc50" .

