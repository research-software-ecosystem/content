@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:uc-echo a schema1:SoftwareApplication ;
    schema1:description "Error correction algorithm designed for short-reads from ngs" ;
    schema1:license "BSD" ;
    schema1:name "uc-echo" ;
    schema1:url "http://uc-echo.sourceforge.net/" .

