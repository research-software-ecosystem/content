@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:ragout a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btu280" ;
    schema1:description "Chromosome-level scaffolding using multiple references" ;
    schema1:identifier biotools:ragout ;
    schema1:keywords "Chromosomes, Bacterial",
        "DNA",
        "Genome, Bacterial",
        "Genomics",
        "High-Throughput Nucleotide Sequencing",
        "Phylogeny",
        "Reference Standards",
        "Sequence Analysis, DNA",
        "Sequence analysis",
        "Sequence assembly",
        "Staphylococcus aureus",
        "Synteny" ;
    schema1:license "GPL-3.0" ;
    schema1:name "ragout" ;
    schema1:url "https://github.com/fenderglass/Ragout" .

