@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-xcell a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s13059-017-1349-1" ;
    schema1:description "Estimate immune cell proportions from gene expression data" ;
    schema1:keywords "Cells",
        "Computer Simulation",
        "Flow Cytometry",
        "Gene Expression",
        "Gene Expression Regulation, Neoplastic",
        "Humans",
        "Neoplasms",
        "Organ Specificity",
        "RNA-Seq",
        "Reproducibility of Results",
        "Transcriptome" ;
    schema1:license "GPL-3.0" ;
    schema1:name "r-xcell" ;
    schema1:url "https://github.com/dviraran/xCell" .

