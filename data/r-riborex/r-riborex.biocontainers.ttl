@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-riborex a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btx047" ;
    schema1:description "Riborex is a r package for identification of differential translation from ribo-seq data." ;
    schema1:identifier biotools:riborex ;
    schema1:keywords "Animals",
        "Computational Biology",
        "Functional, regulatory and non-coding RNA",
        "Gene expression",
        "Genomics",
        "Humans",
        "Mapping",
        "Mice",
        "Protein Biosynthesis",
        "Ribosomes",
        "Sequence Analysis, RNA",
        "Transcriptome" ;
    schema1:license "GPL-3" ;
    schema1:name "r-riborex" ;
    schema1:url "https://github.com/smithlabcode/riborex" .

