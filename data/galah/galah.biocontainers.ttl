biocontainers:galah a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/s41587-020-0501-8" ;
    schema1:description "Galah aims to be a more scalable metagenome assembled genome (MAG) dereplication method." ;
    schema1:keywords "Clustering",
        "Genomics",
