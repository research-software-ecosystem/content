@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:dssp a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/gku1028" ;
    schema1:description "Protein secondary structure assignment based on 3d structure" ;
    schema1:identifier biotools:dssp ;
    schema1:keywords "Computational Biology",
        "Databases, Protein",
        "Protein Conformation",
        "Protein secondary structure",
        "Proteins" ;
    schema1:license "custom, see /usr/share/doc/dssp/copyright" ;
    schema1:name "dssp" ;
    schema1:url "http://www.cmbi.ru.nl/dssp.html" .

