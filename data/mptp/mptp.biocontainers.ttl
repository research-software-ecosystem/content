@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:mptp a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btx025" ;
    schema1:description "Multi-rate poisson tree processes for single-locus species delimitation under maximum likelihood and markov chain monte carlo." ;
    schema1:identifier biotools:mptp ;
    schema1:keywords "Animals",
        "Classification",
        "Clustering",
        "DNA Barcoding, Taxonomic",
        "Electron Transport Complex IV",
        "Genes, Mitochondrial",
        "Machine learning",
        "Mapping",
        "Markov Chains",
        "Monte Carlo Method",
        "Phylogeny",
        "Sequence analysis" ;
    schema1:license "AFFERO-3" ;
    schema1:name "mptp" ;
    schema1:url "https://github.com/Pas-Kapli/mptp" .

