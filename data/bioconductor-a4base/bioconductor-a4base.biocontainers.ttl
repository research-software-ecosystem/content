biocontainers:bioconductor-a4base a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Automated Affymetrix Array Analysis Base Package" ;
    schema1:identifier biotools:a4base ;
    schema1:keywords "Computational Biology",
        "Gene Expression Profiling",
        "Gene expression",
        "Genomics",
        "High-Throughput Screening Assays",
        "Microarray experiment",
        "Programming Languages",
        "Statistics and probability",
        "User-Computer Interface" ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-a4base" ;
    schema1:url "http://bioconductor.org/packages/3.6/bioc/html/a4Base.html" .

