@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bamtools a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btr174" ;
    schema1:description "Bamtools provides a fast, flexible c++ api & toolkit for reading, writing, and managing bam files." ;
    schema1:identifier biotools:bamtools ;
    schema1:keywords "Data management",
        "Genomics",
        "Sequence Alignment",
        "Sequence Analysis, DNA",
        "Sequence analysis",
        "Sequencing" ;
    schema1:license "MIT" ;
    schema1:name "bamtools" ;
    schema1:url "https://github.com/pezmaster31/bamtools" .

