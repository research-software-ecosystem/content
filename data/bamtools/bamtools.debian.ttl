@prefix debianmed: <https://salsa.debian.org/med-team/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

debianmed:bamtools a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btr174" ;
    schema1:description "toolkit for manipulating BAM (genome alignment) files" ;
    schema1:identifier "bio.tools:BamTools",
        "conda:bioconda:bamtools",
        "guix:bamtools",
        "omictools:OMICS_11315",
        "scicrunch:SCR_015987" ;
    schema1:license "unknown" ;
    schema1:name "bamtools" ;
    schema1:softwareVersion "2.5.3" ;
    schema1:url "https://github.com/pezmaster31/bamtools/wiki" ;
    spdx:builtFrom "BamTools" .

