@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bamtools a schema1:SoftwareApplication ;
    schema1:description "C++ API & command-line toolkit for working with BAM data." ;
    schema1:downloadUrl "https://github.com/pezmaster31/bamtools/archive/v2.5.3.tar.gz" ;
    schema1:identifier biotools:bamtools ;
    schema1:license "MIT" ;
    schema1:name "bamtools" ;
    schema1:softwareHelp "https://github.com/pezmaster31/bamtools/wiki" ;
    schema1:softwareVersion "2.5.3" ;
    schema1:url "https://github.com/pezmaster31/bamtools" ;
    spdx:builtFrom biotools:bamtools .

