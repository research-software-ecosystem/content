@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-summarizedexperiment a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "This software contains one or more assays, each represented by a matrix-like object of numeric or other mode. the rows typically represent genomic ranges of interest and the columns represent samples." ;
    schema1:identifier biotools:summarizedexperiment ;
    schema1:keywords "Clustering",
        "Computational Biology",
        "Gene Expression Profiling",
        "Genetics",
        "Genomics",
        "High-Throughput Screening Assays",
        "Metabolomics",
        "Microarray experiment",
        "Programming Languages",
        "Proteomics",
        "Sequencing",
        "Transcriptome",
        "User-Computer Interface" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-summarizedexperiment" ;
    schema1:url "http://bioconductor.org/packages/release/bioc/html/SummarizedExperiment.html" .

