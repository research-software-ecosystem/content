@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-summarizedexperiment a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "A container (S4 class) for matrix-like assays" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/SummarizedExperiment_1.40.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/SummarizedExperiment/SummarizedExperiment_1.40.0.tar.gz', 'https://bioarchive.galaxyproject.org/SummarizedExperiment_1.40.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-summarizedexperiment/bioconductor-summarizedexperiment_1.40.0_src_all.tar.gz']" ;
    schema1:identifier biotools:summarizedexperiment ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-summarizedexperiment" ;
    schema1:softwareVersion "1.40.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/SummarizedExperiment.html" ;
    spdx:builtFrom biotools:summarizedexperiment .

