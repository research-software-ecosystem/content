@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:garli-mpi a schema1:SoftwareApplication ;
    schema1:description "Phylogenetic analysis of molecular sequence data using maximum-likelihood (mpi)" ;
    schema1:license "GPL-3.0+" ;
    schema1:name "garli-mpi" ;
    schema1:url "https://github.com/Ashod/garli" .

