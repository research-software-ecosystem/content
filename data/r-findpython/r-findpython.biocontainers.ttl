@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-findpython a schema1:SoftwareApplication ;
    schema1:description "Package designed to find an acceptable python binary." ;
    schema1:license "MIT" ;
    schema1:name "r-findpython" ;
    schema1:url "https://CRAN.R-project.org/package=findpython" .

