@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:shovill a schema1:SoftwareApplication ;
    schema1:description "Microbial assembly pipeline for Illumina paired-end reads" ;
    schema1:downloadUrl "https://github.com/tseemann/shovill/archive/v1.4.2.tar.gz" ;
    schema1:identifier biotools:shovill ;
    schema1:license "GPL2" ;
    schema1:name "shovill" ;
    schema1:softwareVersion "1.4.2" ;
    schema1:url "https://github.com/tseemann/shovill" ;
    spdx:builtFrom biotools:shovill .

