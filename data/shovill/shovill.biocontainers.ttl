@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:shovill a schema1:SoftwareApplication ;
    schema1:description "Microbial assembly pipeline for illumina paired-end reads" ;
    schema1:identifier biotools:shovill ;
    schema1:keywords "Genomics",
        "Metagenome",
        "Microbiology",
        "Sequence assembly",
        "Whole genome sequencing" ;
    schema1:license "GPL-3.0" ;
    schema1:name "shovill" ;
    schema1:url "https://github.com/tseemann/shovill" .

