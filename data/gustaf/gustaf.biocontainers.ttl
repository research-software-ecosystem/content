@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:gustaf a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btu431" ;
    schema1:description "Gustaf is a tool primarily designed for multi-split mapping of sequencing reads." ;
    schema1:keywords "Genomic Structural Variation",
        "High-Throughput Nucleotide Sequencing",
        "Humans",
        "Sequence Alignment",
        "Sequence Analysis, DNA",
        "Sequence Deletion",
        "Translocation, Genetic" ;
    schema1:license "Not available" ;
    schema1:name "gustaf" ;
    schema1:url "https://github.com/seqan/seqan/tree/master/apps/gustaf/README.rst" .

