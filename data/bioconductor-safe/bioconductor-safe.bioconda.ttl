@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-safe a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/bti260" ;
    schema1:description "Significance Analysis of Function and Expression" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/safe_3.50.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/safe/safe_3.50.0.tar.gz', 'https://bioarchive.galaxyproject.org/safe_3.50.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-safe/bioconductor-safe_3.50.0_src_all.tar.gz']" ;
    schema1:identifier biotools:safe ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-safe" ;
    schema1:softwareVersion "3.50.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/safe.html" ;
    spdx:builtFrom biotools:safe .

