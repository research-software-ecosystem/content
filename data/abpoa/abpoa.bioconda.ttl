@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:abpoa a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btaa963" ;
    schema1:description "abPOA: fast SIMD-based partial order alignment using adaptive band." ;
    schema1:downloadUrl "https://github.com/yangao07/abPOA/releases/download/v1.5.6/abPOA-v1.5.6.tar.gz" ;
    schema1:identifier biotools:abpoa ;
    schema1:license "MIT" ;
    schema1:name "abpoa" ;
    schema1:softwareHelp "https://github.com/yangao07/abPOA/blob/v1.5.6/README.md" ;
    schema1:softwareVersion "1.5.6" ;
    schema1:url "https://github.com/yangao07/abPOA" ;
    spdx:builtFrom biotools:abpoa .

