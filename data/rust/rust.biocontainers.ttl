@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:rust a schema1:SoftwareApplication ;
    schema1:description "rust is a systems programming language that runs blazingly fast, prevents segfaults, and guarantees thread safety." ;
    schema1:license "MIT" ;
    schema1:name "rust" ;
    schema1:url "https://github.com/rust-lang/rust" .

