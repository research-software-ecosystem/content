@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-rphast a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bib/bbq072" ;
    schema1:description "Provides an R interface to the 'PHAST'(<http://compgen.cshl.edu/phast/>) software" ;
    schema1:keywords "Databases, Genetic",
        "Genome",
        "Genomics",
        "Information Storage and Retrieval",
        "Internet",
        "Phylogeny" ;
    schema1:license "BSD_3_clause" ;
    schema1:name "r-rphast" ;
    schema1:url "https://github.com/CshlSiepelLab/RPHAST" .

