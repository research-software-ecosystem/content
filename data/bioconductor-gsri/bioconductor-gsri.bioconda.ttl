@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-gsri a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Gene Set Regulation Index" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/GSRI_2.54.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/GSRI/GSRI_2.54.0.tar.gz', 'https://bioarchive.galaxyproject.org/GSRI_2.54.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-gsri/bioconductor-gsri_2.54.0_src_all.tar.gz']" ;
    schema1:identifier biotools:gsri ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-gsri" ;
    schema1:softwareVersion "2.54.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/GSRI.html" ;
    spdx:builtFrom biotools:gsri .

