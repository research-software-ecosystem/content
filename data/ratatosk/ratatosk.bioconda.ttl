@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:ratatosk a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s13059-020-02244-4" ;
    schema1:description "Hybrid error correction of long reads using colored de Bruijn graphs." ;
    schema1:downloadUrl "https://github.com/DecodeGenetics/Ratatosk/archive/refs/tags/v0.9.0.tar.gz",
        "https://github.com/pmelsted/bifrost/archive/refs/tags/v1.3.5.tar.gz" ;
    schema1:identifier biotools:ratatosk ;
    schema1:license "BSD-2-Clause" ;
    schema1:name "ratatosk" ;
    schema1:softwareHelp "https://github.com/DecodeGenetics/Ratatosk/blob/v0.9.0/README.md" ;
    schema1:softwareVersion "0.9.0" ;
    schema1:url "https://github.com/DecodeGenetics/Ratatosk" ;
    spdx:builtFrom biotools:ratatosk .

