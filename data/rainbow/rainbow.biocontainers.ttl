@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:rainbow a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/bts482" ;
    schema1:description "Efficient tool for clustering and assembling short reads, especially for rad" ;
    schema1:identifier biotools:rainbow ;
    schema1:keywords "Abstracting and Indexing",
        "Assembly",
        "Base Sequence",
        "Cluster Analysis",
        "Clustering",
        "Evolution, Molecular",
        "Genetics, Population",
        "Haplotypes",
        "Humans",
        "Models, Genetic",
        "Polymorphism, Single Nucleotide",
        "Sequence Alignment",
        "Sequence Analysis, DNA" ;
    schema1:license "GPL-2.0" ;
    schema1:name "rainbow" ;
    schema1:url "https://sourceforge.net/projects/bio-rainbow/" .

