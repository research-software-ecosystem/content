@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-copynumber a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/1471-2164-13-591" ;
    schema1:description "Segmentation of single- and multi-track copy number data by penalized least squares regression." ;
    schema1:identifier biotools:copynumber ;
    schema1:keywords "Biomarkers",
        "DNA",
        "DNA Copy Number Variations",
        "Gene Dosage",
        "Genetics",
        "Genome, Human",
        "Genomic Instability",
        "Humans",
        "Lymphoma, Follicular",
        "Neoplasms",
        "Oligonucleotide Array Sequence Analysis",
        "Oncology",
        "Polymorphism, Single Nucleotide",
        "Statistics and probability" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-copynumber" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/copynumber.html" .

