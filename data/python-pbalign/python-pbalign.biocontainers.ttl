@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:python-pbalign a schema1:SoftwareApplication ;
    schema1:description "map Pacific Biosciences reads to reference DNA sequences" ;
    schema1:license "PacBio-BSD-3-Clause" ;
    schema1:name "python-pbalign" ;
    schema1:url "https://github.com/PacificBiosciences/pbalign" .

