@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:flash2 a schema1:SoftwareApplication ;
    schema1:description "Merge paired-end reads from fragments that are shorter than twice the read length" ;
    schema1:license "GPL-3.0+" ;
    schema1:name "flash2" ;
    schema1:url "https://github.com/dstreett/FLASH2" .

