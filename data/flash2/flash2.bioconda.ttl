@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:flash2 a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btr507" ;
    schema1:description "Merge paired-end reads from fragments that are shorter than twice the read length." ;
    schema1:downloadUrl "https://github.com/dstreett/FLASH2/archive/2.2.00.tar.gz" ;
    schema1:identifier biotools:flash ;
    schema1:license "GPL-3.0-or-later" ;
    schema1:name "flash2" ;
    schema1:softwareVersion "2.2.00" ;
    schema1:url "https://github.com/dstreett/FLASH2" ;
    spdx:builtFrom biotools:flash .

