@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:lcfit a schema1:SoftwareApplication ;
    schema1:description "Likelihood curve fitting by nonlinear least squares." ;
