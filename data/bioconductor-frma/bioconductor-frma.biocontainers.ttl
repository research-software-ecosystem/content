@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-frma a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/bts588",
        "doi:10.1186/1471-2105-12-369" ;
    schema1:description "Frozen RMA and Barcode" ;
    schema1:identifier biotools:frma ;
    schema1:keywords "Animals",
        "Databases, Factual",
        "Freezing",
        "Gene expression",
        "Humans",
        "Microarray experiment",
        "Molecular biology",
        "Oligonucleotide Array Sequence Analysis",
        "Preservation, Biological",
        "Probes and primers" ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-frma" ;
    schema1:url "https://www.bioconductor.org/packages/3.5/bioc/html/frma.html" .

