@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-frma a schema1:SoftwareApplication ;
    schema1:description "Frozen RMA and Barcode" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/frma_1.62.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/frma/frma_1.62.0.tar.gz', 'https://bioarchive.galaxyproject.org/frma_1.62.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-frma/bioconductor-frma_1.62.0_src_all.tar.gz']" ;
    schema1:identifier biotools:frma ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-frma" ;
    schema1:softwareVersion "1.62.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/frma.html" ;
    spdx:builtFrom biotools:frma .

