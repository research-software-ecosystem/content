@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-genetclassifier a schema1:SoftwareApplication ;
    schema1:description "Classify diseases and build associated gene networks using gene expression profiles" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/geNetClassifier_1.50.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/geNetClassifier/geNetClassifier_1.50.0.tar.gz', 'https://bioarchive.galaxyproject.org/geNetClassifier_1.50.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-genetclassifier/bioconductor-genetclassifier_1.50.0_src_all.tar.gz']" ;
    schema1:identifier biotools:genetclassifier ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-genetclassifier" ;
    schema1:softwareVersion "1.50.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/geNetClassifier.html" ;
    spdx:builtFrom biotools:genetclassifier .

