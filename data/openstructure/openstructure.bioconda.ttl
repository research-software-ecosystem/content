@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:openstructure a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1107/S0907444913007051" ;
    schema1:description "Open-Source Computational Structural Biology Framework." ;
    schema1:downloadUrl "https://git.scicore.unibas.ch/schwede/openstructure/-/archive/2.11.1/openstructure-2.11.1.tar.gz" ;
    schema1:identifier biotools:openstructure ;
    schema1:license "LGPL-3.0-or-later" ;
    schema1:name "openstructure" ;
    schema1:softwareHelp "https://openstructure.org/docs" ;
    schema1:softwareVersion "2.11.1" ;
    schema1:url "https://openstructure.org" ;
    spdx:builtFrom biotools:openstructure .

