@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:viralmsa a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btaa743" ;
    schema1:description "Reference-guided multiple sequence alignment of viral genomes" ;
    schema1:downloadUrl "https://github.com/niemasd/ViralMSA/archive/refs/tags/1.1.46.tar.gz" ;
    schema1:identifier biotools:viralmsa ;
    schema1:license "GNU General Public License v3 (GPLv3)" ;
    schema1:name "viralmsa" ;
    schema1:softwareVersion "1.1.46" ;
    schema1:url "https://github.com/niemasd/ViralMSA" ;
    spdx:builtFrom biotools:viralmsa .

