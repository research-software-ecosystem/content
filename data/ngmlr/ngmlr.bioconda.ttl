@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:ngmlr a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/s41592-018-0001-7" ;
    schema1:description "ngmlr is a long-read mapper designed to align PacBio or Oxford Nanopore reads to a reference genome and optimized for structural variation detection." ;
    schema1:downloadUrl "https://github.com/philres/ngmlr/archive/v0.2.7.tar.gz" ;
    schema1:identifier biotools:ngmlr ;
    schema1:license "MIT" ;
    schema1:name "ngmlr" ;
    schema1:softwareHelp "https://github.com/philres/ngmlr/blob/v0.2.7/README.md" ;
    schema1:softwareVersion "0.2.7" ;
    schema1:url "https://github.com/philres/ngmlr" ;
    spdx:builtFrom biotools:ngmlr .

