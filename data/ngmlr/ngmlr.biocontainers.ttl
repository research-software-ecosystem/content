@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:ngmlr a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/s41592-018-0001-7" ;
    schema1:description "A long-read mapper desigend to align pacbilo or oxford nanopore to a reference genome optimized for structural variation detection" ;
    schema1:identifier biotools:ngmlr ;
    schema1:keywords "DNA Mutational Analysis",
        "DNA structural variation",
        "Genome, Human",
        "Genomics",
        "High-Throughput Nucleotide Sequencing",
        "Humans",
        "Mapping",
        "Sequence Analysis, DNA",
        "Sequencing" ;
    schema1:license "MIT" ;
    schema1:name "ngmlr" ;
    schema1:url "https://github.com/philres/ngmlr" .

