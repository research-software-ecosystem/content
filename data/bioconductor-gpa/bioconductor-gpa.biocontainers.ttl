@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-gpa a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18129/b9.bioc.gpa" ;
    schema1:description "GPA (Genetic analysis incorporating Pleiotropy and Annotation)" ;
    schema1:keywords "Clustering",
        "Genetics" ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-gpa" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/GPA.html" .

