@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-gpa a schema1:SoftwareApplication ;
    schema1:description "GPA (Genetic analysis incorporating Pleiotropy and Annotation)" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/GPA_1.22.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/GPA/GPA_1.22.0.tar.gz', 'https://bioarchive.galaxyproject.org/GPA_1.22.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-gpa/bioconductor-gpa_1.22.0_src_all.tar.gz']" ;
    schema1:identifier biotools:GPA ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-gpa" ;
    schema1:softwareVersion "1.22.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/GPA.html" ;
    spdx:builtFrom biotools:GPA .

