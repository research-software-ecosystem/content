@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:pgsa a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1371/journal.pone.0133198" ;
    schema1:description "Pseudogenome Suffix Array is a compact index for collections of reads from sequencing." ;
    schema1:identifier biotools:pgsa ;
    schema1:keywords "Animals",
        "Caenorhabditis elegans",
        "Datasets as Topic",
        "Escherichia coli",
        "Genome",
        "Genomics",
        "High-Throughput Nucleotide Sequencing",
        "Humans",
        "RNA-Seq",
        "Sequence Analysis, RNA",
        "Sequencing" ;
    schema1:license "Creative Commons Attribution License" ;
    schema1:name "pgsa" ;
    schema1:url "http://sun.aei.polsl.pl/pgsa/" .

