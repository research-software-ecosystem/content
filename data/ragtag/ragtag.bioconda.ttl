@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:ragtag a schema1:SoftwareApplication ;
    schema1:author "malonge" ;
    schema1:citation "doi:10.1186/s13059-022-02823-7" ;
    schema1:description "Fast reference-guided genome assembly scaffolding." ;
    schema1:downloadUrl "https://pypi.org/packages/source/R/RagTag/RagTag-2.1.0.tar.gz" ;
    schema1:identifier biotools:ragtag ;
    schema1:license "MIT" ;
    schema1:maintainer "malonge" ;
    schema1:name "ragtag" ;
    schema1:softwareHelp "https://github.com/malonge/RagTag/wiki" ;
    schema1:softwareVersion "2.1.0" ;
    schema1:url "https://github.com/malonge/RagTag" ;
    spdx:builtFrom biotools:ragtag .

