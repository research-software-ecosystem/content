@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:dropseq_tools a schema1:SoftwareApplication ;
    schema1:description "Package for the analysis of drop-seq data developed by jim nemesh in the mccarroll lab." ;
    schema1:keywords "Clustering",
        "Gene Expression",
        "Genetics",
        "RNA-Seq" ;
    schema1:license "Not available" ;
    schema1:name "dropseq_tools" ;
    schema1:url "http://mccarrolllab.com/dropseq/" .

