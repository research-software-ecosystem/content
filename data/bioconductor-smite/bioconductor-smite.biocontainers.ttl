@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-smite a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s12859-017-1477-3" ;
    schema1:description "Significance-based Modules Integrating the Transcriptome and Epigenome" ;
    schema1:identifier biotools:smite ;
    schema1:keywords "Databases, Genetic",
        "Epigenesis, Genetic",
        "Epigenomics",
        "Fibroblasts",
        "Foreskin",
        "Gene Regulatory Networks",
        "Humans",
        "Male",
        "Models, Theoretical",
        "RNA-Seq",
        "Systems biology",
        "Toxoplasma",
        "Transcriptome",
        "Transcriptomics" ;
    schema1:license "GPL (>=2)" ;
    schema1:name "bioconductor-smite" ;
    schema1:url "https://bioconductor.org/packages/release/bioc/html/SMITE.html" .

