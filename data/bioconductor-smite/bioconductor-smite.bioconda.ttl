@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-smite a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s12859-017-1477-3" ;
    schema1:description "Significance-based Modules Integrating the Transcriptome and Epigenome" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/SMITE_1.34.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/SMITE/SMITE_1.34.0.tar.gz', 'https://bioarchive.galaxyproject.org/SMITE_1.34.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-smite/bioconductor-smite_1.34.0_src_all.tar.gz']" ;
    schema1:identifier biotools:smite ;
    schema1:license "GPL (>=2)" ;
    schema1:name "bioconductor-smite" ;
    schema1:softwareVersion "1.34.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/SMITE.html" ;
    spdx:builtFrom biotools:smite .

