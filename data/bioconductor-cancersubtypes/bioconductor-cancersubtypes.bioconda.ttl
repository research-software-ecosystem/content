@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-cancersubtypes a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Cancer subtypes identification, validation and visualization based on multiple genomic data sets" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.17/bioc/src/contrib/CancerSubtypes_1.26.0.tar.gz', 'https://bioconductor.org/packages/3.17/bioc/src/contrib/Archive/CancerSubtypes/CancerSubtypes_1.26.0.tar.gz', 'https://bioarchive.galaxyproject.org/CancerSubtypes_1.26.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-cancersubtypes/bioconductor-cancersubtypes_1.26.0_src_all.tar.gz']" ;
    schema1:identifier biotools:cancersubtypes ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-cancersubtypes" ;
    schema1:softwareVersion "1.26.0" ;
    schema1:url "https://bioconductor.org/packages/3.17/bioc/html/CancerSubtypes.html" ;
    spdx:builtFrom biotools:cancersubtypes .

