@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-xbseq a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/1471-2164-16-S7-S14" ;
    schema1:description "Test for differential expression for RNA-seq data" ;
    schema1:identifier biotools:xbseq ;
    schema1:keywords "Animals",
        "Gene Expression Profiling",
        "Gene Expression Regulation",
        "Gene expression",
        "Mice",
        "Models, Statistical",
        "Poisson Distribution",
        "RNA-Seq",
        "Sequence Analysis, RNA" ;
    schema1:license "GPL (>=3)" ;
    schema1:name "bioconductor-xbseq" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/XBSeq.html" .

