@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:speaq a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1371/journal.pcbi.1006018" ;
    schema1:description "The speaq package is meant to make Nuclear Magnetic Resonance spectroscopy (NMR spectroscopy) data analysis as easy as possible by only requiring a small set of functions to perform an entire analysis" ;
    schema1:identifier biotools:speaq ;
    schema1:keywords "Biomarkers",
        "Chromatography, Liquid",
        "Magnetic Resonance Imaging",
        "Magnetic Resonance Spectroscopy",
        "Metabolomics",
        "NMR",
        "Workflow" ;
    schema1:license "Apache-2.0" ;
    schema1:name "speaq" ;
    schema1:url "https://github.com/beirnaert/speaq" .

