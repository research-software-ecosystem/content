@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-genomicfeatures a schema1:SoftwareApplication ;
    schema1:description "Query the gene models of a given organism/assembly" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/GenomicFeatures_1.58.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/GenomicFeatures/GenomicFeatures_1.58.0.tar.gz', 'https://bioarchive.galaxyproject.org/GenomicFeatures_1.58.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-genomicfeatures/bioconductor-genomicfeatures_1.58.0_src_all.tar.gz']" ;
    schema1:identifier biotools:genomicfeatures ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-genomicfeatures" ;
    schema1:softwareVersion "1.58.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/GenomicFeatures.html" ;
    spdx:builtFrom biotools:genomicfeatures .

