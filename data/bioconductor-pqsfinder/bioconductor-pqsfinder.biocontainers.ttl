@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-pqsfinder a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/BIOINFORMATICS/BTZ928",
        "doi:10.1093/bioinformatics/btv272",
        "doi:10.1093/bioinformatics/btx413" ;
    schema1:description "Identification of potential quadruplex forming sequences" ;
    schema1:identifier biotools:pqsfinder ;
    schema1:keywords "Binomial Distribution",
        "Chromosomes, Human, Pair 22",
        "Computational Biology",
        "Europe",
        "Gene Expression Profiling",
        "Gene Expression Regulation",
        "Genetics, Population",
        "Haplotypes",
        "High-Throughput Nucleotide Sequencing",
        "Humans",
        "Protein Isoforms",
        "RNA",
        "Sequence Analysis, RNA",
        "Sequence analysis" ;
    schema1:license "BSD_2_clause" ;
    schema1:name "bioconductor-pqsfinder" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/pqsfinder.html" .

