@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-pqsfinder a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btv272" ;
    schema1:description "Identification of potential quadruplex forming sequences" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/pqsfinder_2.22.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/pqsfinder/pqsfinder_2.22.0.tar.gz', 'https://bioarchive.galaxyproject.org/pqsfinder_2.22.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-pqsfinder/bioconductor-pqsfinder_2.22.0_src_all.tar.gz']" ;
    schema1:identifier biotools:pqsfinder ;
    schema1:license "BSD_2_clause + file LICENSE" ;
    schema1:name "bioconductor-pqsfinder" ;
    schema1:softwareVersion "2.22.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/pqsfinder.html" ;
    spdx:builtFrom biotools:pqsfinder .

