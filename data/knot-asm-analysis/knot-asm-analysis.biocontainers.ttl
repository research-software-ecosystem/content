@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:knot-asm-analysis a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btz219" ;
    schema1:description "Knot: knowledge network overlap extraction is a tool for the investigation of fragmented long read assemblies." ;
    schema1:keywords "Bacteria",
        "Genome, Bacterial",
        "High-Throughput Nucleotide Sequencing",
        "Sequence Analysis, DNA" ;
    schema1:license "Not available" ;
    schema1:name "knot-asm-analysis" ;
    schema1:url "https://github.com/natir/knot" .

