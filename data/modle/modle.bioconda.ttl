@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:modle a schema1:SoftwareApplication ;
    schema1:author "jonnings",
        "robomics" ;
    schema1:citation "doi:10.1186/s13059-022-02815-7",
        "doi:10.5281/zenodo.6992533" ;
    schema1:description "High-performance stochastic modeling of DNA loop extrusion interactions" ;
    schema1:downloadUrl "https://github.com/paulsengroup/MoDLE/archive/refs/tags/v1.1.0.tar.gz" ;
    schema1:identifier biotools:modle ;
    schema1:license "MIT" ;
    schema1:maintainer "jonnings",
        "robomics" ;
    schema1:name "modle" ;
    schema1:softwareHelp "https://github.com/paulsengroup/MoDLE#readme" ;
    schema1:softwareVersion "1.1.0" ;
    schema1:url "https://github.com/paulsengroup/MoDLE" ;
    spdx:builtFrom biotools:modle .

