@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:tmalign a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1002/prot.20264",
        "doi:10.1093/nar/gki524" ;
    schema1:description "TM-align sequence-order independent protein structure alignment." ;
    schema1:downloadUrl "https://github.com/pylelab/USalign/archive/61b50fbe09235deb70bcec42000b723c4def49ca.tar.gz" ;
    schema1:identifier biotools:tm-score ;
    schema1:license "BSD-like" ;
    schema1:name "tmalign" ;
    schema1:softwareHelp "https://aideepmed.com/TM-align" ;
    schema1:softwareVersion "20240303" ;
    schema1:url "https://github.com/pylelab/USalign" ;
    spdx:builtFrom biotools:tm-score .

