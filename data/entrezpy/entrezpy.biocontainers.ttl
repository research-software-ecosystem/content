@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:entrezpy a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/BIOINFORMATICS/BTZ385" ;
    schema1:description "Entrezpy is a dedicated Python library to interact with NCBI Entrez databases" ;
    schema1:keywords "Databases, Factual" ;
    schema1:license "LGPL-3.0" ;
    schema1:name "entrezpy" ;
    schema1:url "https://gitlab.com/ncbipy/entrezpy" .

