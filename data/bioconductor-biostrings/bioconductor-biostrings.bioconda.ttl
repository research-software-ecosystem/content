@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-biostrings a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Efficient manipulation of biological strings" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/Biostrings_2.74.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/Biostrings/Biostrings_2.74.0.tar.gz', 'https://bioarchive.galaxyproject.org/Biostrings_2.74.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-biostrings/bioconductor-biostrings_2.74.0_src_all.tar.gz']" ;
    schema1:identifier biotools:biostrings ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-biostrings" ;
    schema1:softwareVersion "2.74.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/Biostrings.html" ;
    spdx:builtFrom biotools:biostrings .

