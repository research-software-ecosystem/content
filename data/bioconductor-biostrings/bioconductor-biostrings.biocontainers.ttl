@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-biostrings a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Gnu r string objects representing biological sequences" ;
    schema1:identifier biotools:biostrings ;
    schema1:keywords "Computational Biology",
        "Data management",
        "Gene Expression Profiling",
        "Genetics",
        "Genomics",
        "High-Throughput Screening Assays",
        "Metagenome",
        "Programming Languages",
        "Proteomics",
        "Sequence Alignment",
        "Sequence analysis",
        "User-Computer Interface" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-biostrings" ;
    schema1:url "https://bioconductor.org/packages/Biostrings/" .

