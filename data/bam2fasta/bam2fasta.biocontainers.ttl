@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bam2fasta a schema1:SoftwareApplication ;
    schema1:description "bam2fasta: cli tool to convert bam to fastas" ;
    schema1:identifier biotools:bam2fasta ;
    schema1:license "MIT" ;
    schema1:name "bam2fasta" ;
    schema1:url "https://github.com/czbiohub/bam2fasta" .

