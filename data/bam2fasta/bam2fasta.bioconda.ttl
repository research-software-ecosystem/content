@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bam2fasta a schema1:SoftwareApplication ;
    schema1:author "pranathi7" ;
    schema1:description "bam2fasta: cli tool to convert bam to fastas" ;
    schema1:downloadUrl "https://pypi.io/packages/source/b/bam2fasta/bam2fasta-1.0.8.tar.gz" ;
    schema1:identifier biotools:bam2fasta ;
    schema1:license "MIT" ;
    schema1:maintainer "pranathi7" ;
    schema1:name "bam2fasta" ;
    schema1:softwareVersion "1.0.8" ;
    schema1:url "https://github.com/czbiohub/bam2fasta" ;
    spdx:builtFrom biotools:bam2fasta .

