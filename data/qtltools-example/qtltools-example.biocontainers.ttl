@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:qtltools-example a schema1:SoftwareApplication ;
    schema1:description "Tool set for molecular qtl discovery and analysis. it allows to go from the raw sequence data to collection of molecular quantitative trait loci (qtls) in few easy-to-perform steps." ;
    schema1:license "CC-BY-NC-4.0" ;
    schema1:name "qtltools-example" ;
    schema1:url "https://qtltools.github.io/qtltools/" .

