@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:tracer a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/molbev/mss075",
        "doi:10.1093/sysbio/syy032" ;
    schema1:description "Graphical tool for visualization and diagnostics of mcmc (markov chain monte carlo) output. it can read output files from mrbayesand beast." ;
    schema1:identifier biotools:tracer ;
    schema1:keywords "Bayes Theorem",
        "Data visualisation",
        "Evolution, Molecular",
        "Genetics",
        "Markov Chains",
        "Models, Genetic",
        "Monte Carlo Method",
        "Phylogenetics",
        "Phylogeny" ;
    schema1:license "LGPLv2.1" ;
    schema1:name "tracer" ;
    schema1:url "https://github.com/beast-dev/tracer" .

