@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:pblaa a schema1:SoftwareApplication ;
    schema1:description "Pacbio tool to deconvolute mixtures of alleles and loci into phased consensus sequences." ;
    schema1:license "BSD 3-Clause Clear License" ;
    schema1:name "pblaa" ;
    schema1:url "https://github.com/PacificBiosciences/pbbioconda" .

