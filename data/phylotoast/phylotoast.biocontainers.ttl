@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:phylotoast a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.f.303",
        "doi:10.1371/journal.pone.0020956" ;
    schema1:description "Tools for phylogenetic data analysis including visualization and cluster-computing support. " ;
    schema1:keywords "Bacteria",
        "Bacteroides",
        "Chronic Periodontitis",
        "Fusobacterium",
        "Genetics",
        "Genomics",
        "Humans",
        "Phylogenetics",
        "Porphyromonas",
        "RNA, Ribosomal, 16S",
        "Streptococcus",
        "Treponema" ;
    schema1:license "MIT" ;
    schema1:name "phylotoast" ;
    schema1:url "https://github.com/smdabdoub/phylotoast" .

