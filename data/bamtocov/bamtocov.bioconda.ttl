@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bamtocov a schema1:SoftwareApplication ;
    schema1:author "telatin" ;
    schema1:citation "doi:10.3390/bioengineering8050059" ;
    schema1:description "Extract coverage information from BAM files, supporting stranded and physical coverage and streams." ;
    schema1:downloadUrl "https://github.com/telatin/bamtocov/archive/v2.8.0.tar.gz" ;
    schema1:identifier biotools:bamtocov ;
    schema1:license "MIT" ;
    schema1:maintainer "telatin" ;
    schema1:name "bamtocov" ;
    schema1:softwareVersion "2.8.0" ;
    schema1:url "https://github.com/telatin/bamtocov" ;
    spdx:builtFrom biotools:bamtocov .

