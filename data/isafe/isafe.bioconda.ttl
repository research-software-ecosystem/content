@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:isafe a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.4606" ;
    schema1:description "A program for identifying a favored mutation in positive selective sweep." ;
    schema1:downloadUrl "https://github.com/alek0991/iSAFE/archive/refs/tags/v1.1.1.tar.gz" ;
    schema1:identifier biotools:isafe ;
    schema1:license "BSD-3-Clause" ;
    schema1:name "isafe" ;
    schema1:softwareVersion "1.1.1" ;
    schema1:url "https://github.com/alek0991/iSAFE" ;
    spdx:builtFrom biotools:isafe .

