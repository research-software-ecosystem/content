@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:ropebwt2 a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1007/978-3-642-21458-5_20",
        "doi:10.1093/bioinformatics/btu541" ;
    schema1:description "Incremental construction of fm-index for dna sequences" ;
    schema1:identifier biotools:ropebwt2 ;
    schema1:keywords "DNA",
        "Genomics",
        "Sequence Analysis, DNA",
        "Sequence analysis" ;
    schema1:license "MIT" ;
    schema1:name "ropebwt2" ;
    schema1:url "https://github.com/lh3/ropebwt2" .

