@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-rcm a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18129/b9.bioc.rcm" ;
    schema1:description "Fit row-column association models with the negative binomial distribution for the microbiome" ;
    schema1:keywords "Genomics",
        "Metagenomics" ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-rcm" ;
    schema1:url "https://bioconductor.org/packages/3.9/bioc/html/RCM.html" .

