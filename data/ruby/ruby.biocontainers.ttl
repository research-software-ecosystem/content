@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:ruby a schema1:SoftwareApplication ;
    schema1:description "A dynamic, open source programming language with a focus on simplicity and productivity." ;
    schema1:license "BSD-2-Clause" ;
    schema1:name "ruby" ;
    schema1:url "https://github.com/ruby/ruby" .

