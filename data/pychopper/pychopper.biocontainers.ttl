@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:pychopper a schema1:SoftwareApplication ;
    schema1:description "A tool to identify, orient and rescue full length cdna reads from nanopore data." ;
    schema1:keywords "RNA-Seq",
        "Sequence Alignment",
        "Transcriptome",
        "Transcriptomics" ;
    schema1:license "MPL2" ;
    schema1:name "pychopper" ;
    schema1:url "https://github.com/nanoporetech/pychopper" .

