        "Escherichia coli",
        "Evolution, Molecular",
        "Functional, regulatory and non-coding RNA",
        "Gene transcripts",
        "Molecular Sequence Data",
        "Nucleic Acid Conformation",
        "Nucleic acid structure analysis",
        "Phylogeny",
        "Prokaryotic Cells",
        "RNA",
        "RNA Stability",
        "RNA, Ribosomal, 16S",
        "RNA, Ribosomal, 23S",
        "Sequence Alignment",
        "Sequence Homology, Nucleic Acid",
        "Structure prediction",
        "Thermodynamics" ;
    schema1:license "MIT" ;
    schema1:name "rnaz" ;
