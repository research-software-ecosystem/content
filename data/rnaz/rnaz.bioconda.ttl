@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:rnaz a schema1:SoftwareApplication ;
    schema1:description "Predicting structural noncoding RNAs." ;
    schema1:downloadUrl "https://github.com/ViennaRNA/RNAz/archive/v2.1.1.tar.gz" ;
    schema1:identifier biotools:rnaz ;
    schema1:license "MIT-like" ;
    schema1:name "rnaz" ;
    schema1:softwareHelp "https://www.tbi.univie.ac.at/software/RNAz" ;
    schema1:softwareVersion "2.1.1" ;
    schema1:url "https://github.com/ViennaRNA/RNAz" ;
    spdx:builtFrom biotools:rnaz .

