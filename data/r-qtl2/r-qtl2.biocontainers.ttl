@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-qtl2 a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1534/genetics.118.301595" ;
    schema1:description "R/qtl2 provides a set of tools to perform quantitative trait locus (QTL) analysis" ;
    schema1:keywords "Animals",
        "Chromosome Mapping",
        "Genetics",
        "Genome-Wide Association Study",
        "Genotyping Techniques",
        "Mice",
        "Quantitative Trait Loci" ;
    schema1:license "GPL-3" ;
    schema1:name "r-qtl2" ;
    schema1:url "https://github.com/rqtl/qtl2" .

