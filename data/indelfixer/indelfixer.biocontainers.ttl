@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:indelfixer a schema1:SoftwareApplication ;
    schema1:description "A sensitive aligner for 454, illumina and pacbio data, employing a full smith-waterman alignment against a reference." ;
    schema1:keywords "Sequence Alignment" ;
    schema1:license "GNU GPLv3" ;
    schema1:name "indelfixer" ;
    schema1:url "https://github.com/cbg-ethz/InDelFixer" .

