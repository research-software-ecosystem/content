@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-fgnet a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18129/b9.bioc.fgnet" ;
    schema1:description "Functional Gene Networks derived from biological enrichment analyses" ;
    schema1:keywords "Clustering",
        "Genomics" ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-fgnet" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/FGNet.html" .

