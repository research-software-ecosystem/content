@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bart a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/bty194" ;
    schema1:description "Transcription factor prediction tool with query gene sets or epigenomic profiles." ;
    schema1:identifier biotools:bart ;
    schema1:keywords "Animals",
        "Databases, Genetic",
        "Epigenomics",
        "Gene Expression",
        "Gene Expression Regulation",
        "Humans",
        "Mice",
        "Sequence Analysis, DNA",
        "Sequence analysis",
        "Transcription Factors",
        "Transcription factors and regulatory sites" ;
    schema1:license "BSD-3-clause" ;
    schema1:name "bart" ;
    schema1:url "https://github.com/zanglab/bart2" .

