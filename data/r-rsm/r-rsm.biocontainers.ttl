@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-rsm a schema1:SoftwareApplication ;
    schema1:description "Provides functions to generate response-surface designs, fit first- and second-order response-surface models, make surface plots, obtain the path of steepest ascent, and do canonical analysis." ;
    schema1:license "GPL-2" ;
    schema1:name "r-rsm" ;
    schema1:url "None" .

