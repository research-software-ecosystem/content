@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-mulcom a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/1471-2105-12-382" ;
    schema1:description "Calculates Mulcom test" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/Mulcom_1.56.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/Mulcom/Mulcom_1.56.0.tar.gz', 'https://bioarchive.galaxyproject.org/Mulcom_1.56.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-mulcom/bioconductor-mulcom_1.56.0_src_all.tar.gz']" ;
    schema1:identifier biotools:mulcom ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-mulcom" ;
    schema1:softwareVersion "1.56.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/Mulcom.html" ;
    spdx:builtFrom biotools:mulcom .

