@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-mulcom a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/1471-2105-12-382" ;
    schema1:description "Calculates Mulcom test" ;
    schema1:identifier biotools:mulcom ;
    schema1:keywords "Gene Expression Profiling",
        "Gene expression",
        "Humans",
        "Molecular genetics",
        "Neoplasms",
        "Oligonucleotide Array Sequence Analysis",
        "Regression Analysis" ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-mulcom" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/Mulcom.html" .

