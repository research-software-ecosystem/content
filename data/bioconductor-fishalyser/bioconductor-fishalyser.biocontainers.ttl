@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-fishalyser a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "This software provides functionality to process and analyse digital cell culture images, in particular to quantify fish probes within nuclei. furthermore, it extract the spatial location of each nucleus as well as each probe enabling spatial co-localisation analysis." ;
    schema1:identifier biotools:fishalyser ;
    schema1:keywords "Cell biology",
        "Computational Biology",
        "Gene Expression Profiling",
        "Genomics",
        "High-Throughput Screening Assays",
        "Imaging",
        "Programming Languages",
        "User-Computer Interface" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-fishalyser" ;
    schema1:url "http://bioconductor.org/packages/release/bioc/html/FISHalyseR.html" .

