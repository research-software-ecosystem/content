@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-flowutils a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/1471-2105-10-145" ;
    schema1:description "Provides utilities for flow cytometry data." ;
    schema1:identifier biotools:flowutils ;
    schema1:keywords "Antigens, CD",
        "Biophysics",
        "Cluster Analysis",
        "Data management",
        "Databases, Factual",
        "Flow Cytometry",
        "Graft vs Host Disease",
        "Laboratory techniques",
        "Models, Statistical",
        "Reproducibility of Results" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-flowutils" ;
    schema1:url "http://bioconductor.org/packages/release/bioc/html/flowUtils.html" .

