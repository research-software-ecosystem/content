@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:exonerate a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/1471-2105-6-31" ;
    schema1:description "A tool for pairwise sequence alignment. it enables alignment for dna-dna and dna-protein pairs and also gapped and ungapped alignment." ;
    schema1:identifier biotools:exonerate ;
    schema1:keywords "Artificial Intelligence",
        "Automation",
        "Computational Biology",
        "Computer Simulation",
        "DNA",
        "DNA, Complementary",
        "Databases, Factual",
        "Genome",
        "Genomics",
        "Humans",
        "Information Storage and Retrieval",
        "Mathematical Computing",
        "Models, Biological",
        "Models, Theoretical",
        "Molecular interactions, pathways and networks",
        "RNA, Messenger",
        "Sequence Alignment",
        "Sequence Analysis, DNA",
        "Sequence analysis",
        "Sequence sites, features and motifs" ;
    schema1:license "GPL-3.0" ;
    schema1:name "exonerate" ;
    schema1:url "http://www.ebi.ac.uk/%7Eguy/exonerate" .

