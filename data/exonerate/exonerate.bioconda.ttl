@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:exonerate a schema1:SoftwareApplication ;
    schema1:description "Exonerate - A generic tool for pairwise sequence comparison / alignment." ;
    schema1:downloadUrl "http://ftp.ebi.ac.uk/pub/software/vertebrategenomics/exonerate/exonerate-2.4.0.tar.gz" ;
    schema1:identifier biotools:exonerate ;
    schema1:license "GPL-3.0-or-later" ;
    schema1:name "exonerate" ;
    schema1:softwareVersion "2.4.0" ;
    schema1:url "http://ftp.ebi.ac.uk/pub/software/vertebrategenomics/exonerate" ;
    spdx:builtFrom biotools:exonerate .

