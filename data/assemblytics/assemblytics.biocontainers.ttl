@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:assemblytics a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btw369" ;
    schema1:description "Analyze a genome assembly by comparing it to a reference genome" ;
    schema1:keywords "Genetic Variation",
        "Genome",
        "Genomics",
        "Humans" ;
    schema1:license "MIT" ;
    schema1:name "assemblytics" ;
    schema1:url "http://assemblytics.com/" .

