@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:perbase a schema1:SoftwareApplication ;
    schema1:description "Highly parallelized utility for analyzing metrics at a per-base level." ;
