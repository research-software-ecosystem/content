@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-annotationdbi a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Provides user interface and database connection code for annotation data packages using sqlite data storage." ;
    schema1:identifier biotools:annotationdbi ;
    schema1:keywords "Computational Biology",
        "Data integration and warehousing",
        "Gene Expression Profiling",
        "Genomics",
        "High-Throughput Screening Assays",
        "Ortholog",
        "Programming Languages",
        "Proteomics",
        "Sequence analysis",
        "User-Computer Interface" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-annotationdbi" ;
    schema1:url "http://bioconductor.org/packages/release/bioc/html/AnnotationDbi.html" .

