@prefix debianmed: <https://salsa.debian.org/med-team/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

debianmed:gff2aplot a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btg334" ;
    schema1:description "pair-wise alignment-plots for genomic sequences in PostScript" ;
    schema1:identifier "bio.tools:gff2aplot",
        "omictools:OMICS_19949" ;
    schema1:keywords "field::biology",
        "field::biology:bioinformatics",
        "implemented-in::c",
        "implemented-in::perl",
        "interface::commandline",
        "interface::shell",
        "role::program",
        "scope::utility",
        "use::converting",
        "use::viewing",
        "works-with-format::plaintext",
        "works-with-format::postscript",
        "works-with::TODO",
        "works-with::image:vector" ;
    schema1:license "unknown" ;
    schema1:name "gff2aplot" ;
    schema1:softwareVersion "2.0" ;
    schema1:url "https://genome.crg.es/software/gfftools/GFF2APLOT.html" ;
    spdx:builtFrom "gff2aplot" .

