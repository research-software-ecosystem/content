@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:hits a schema1:SoftwareApplication ;
    schema1:description "utilities for processing high-throughput sequencing experiments" ;
    schema1:license "GPL-3.0" ;
    schema1:name "hits" ;
    schema1:url "https://github.com/jeffhussmann/hits" .

