@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:cellrank a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1101/2020.10.19.345983" ;
    schema1:description "Continuous lineage decisions uncovered by rna velocity" ;
    schema1:keywords "Clustering",
        "Gene Expression",
        "Genetics",
        "Genomics",
        "Markov Chains",
        "RNA-Seq" ;
    schema1:license "Not available" ;
    schema1:name "cellrank" ;
    schema1:url "https://github.com/theislab/cellrank" .

