@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:diffutils a schema1:SoftwareApplication ;
    schema1:description "GNU Diffutils is a package of several programs related to finding differences between files." ;
    schema1:license "GPL-3.0" ;
    schema1:name "diffutils" ;
    schema1:url "https://www.gnu.org/software/diffutils/" .

