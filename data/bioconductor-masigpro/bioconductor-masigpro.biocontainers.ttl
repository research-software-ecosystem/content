@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-masigpro a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btu333" ;
    schema1:description "Significant Gene Expression Profile Differences in Time Course Gene Expression Data" ;
    schema1:identifier biotools:masigpro ;
    schema1:keywords "Computational Biology",
        "Gene Expression",
        "Gene Expression Profiling",
        "Gene expression",
        "Linear Models",
        "Microarray experiment",
        "Molecular genetics",
        "RNA-Seq",
        "Sequence Analysis, RNA",
        "Time Factors" ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-masigpro" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/maSigPro.html" .

