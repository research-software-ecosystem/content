@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-masigpro a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btu333" ;
    schema1:description "Significant Gene Expression Profile Differences in Time Course Gene Expression Data" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/maSigPro_1.78.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/maSigPro/maSigPro_1.78.0.tar.gz', 'https://bioarchive.galaxyproject.org/maSigPro_1.78.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-masigpro/bioconductor-masigpro_1.78.0_src_all.tar.gz']" ;
    schema1:identifier biotools:masigpro ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-masigpro" ;
    schema1:softwareVersion "1.78.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/maSigPro.html" ;
    spdx:builtFrom biotools:masigpro .

