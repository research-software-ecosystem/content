@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-bcseq a schema1:SoftwareApplication ;
    schema1:description "Fast Sequence Mapping in High-Throughput shRNA and CRISPR Screens" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/bcSeq_1.32.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/bcSeq/bcSeq_1.32.0.tar.gz', 'https://bioarchive.galaxyproject.org/bcSeq_1.32.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-bcseq/bioconductor-bcseq_1.32.0_src_all.tar.gz']" ;
    schema1:identifier biotools:bcSeq ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-bcseq" ;
    schema1:softwareVersion "1.32.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/bcSeq.html" ;
    spdx:builtFrom biotools:bcSeq .

