@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:fastxtools a schema1:SoftwareApplication ;
    schema1:description "A collection of command line tools for short-reads fasta/fastq files preprocessing" ;
    schema1:license "AGPL-3.0-only" ;
    schema1:name "fastxtools" ;
    schema1:url "http://hannonlab.cshl.edu/fastx_toolkit/" .

