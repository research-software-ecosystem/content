@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-oppar a schema1:SoftwareApplication ;
    schema1:description "Outlier profile and pathway analysis in R" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/oppar_1.38.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/oppar/oppar_1.38.0.tar.gz', 'https://bioarchive.galaxyproject.org/oppar_1.38.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-oppar/bioconductor-oppar_1.38.0_src_all.tar.gz']" ;
    schema1:identifier biotools:oppar ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-oppar" ;
    schema1:softwareVersion "1.38.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/oppar.html" ;
    spdx:builtFrom biotools:oppar .

