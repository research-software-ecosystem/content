@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:alignstats a schema1:SoftwareApplication ;
    schema1:description "Comprehensive alignment, whole-genome coverage, and capture coverage statistics." ;
    schema1:keywords "Sequence Alignment" ;
    schema1:license "BSD" ;
    schema1:name "alignstats" ;
    schema1:url "https://github.com/jfarek/alignstats" .

