@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:pyasp a schema1:SoftwareApplication ;
    schema1:description "A convenience wrapper for the asp tools gringo, gringo4 and clasp." ;
    schema1:license "GPLv3 +" ;
    schema1:name "pyasp" ;
    schema1:url "http://pypi.python.org/pypi/pyasp/" .

