@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-philr a schema1:SoftwareApplication ;
    schema1:citation "doi:10.7554/eLife.21887" ;
    schema1:description "Phylogenetic partitioning based ILR transform for metagenomics data" ;
    schema1:identifier biotools:philr ;
    schema1:keywords "Biostatistics",
        "Computational Biology",
        "Evolutionary biology",
        "Genomics",
        "Humans",
        "Metagenomics",
        "Microbiota",
        "Phylogenetics",
        "Phylogeny" ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-philr" ;
    schema1:url "http://bioconductor.org/packages/3.6/bioc/html/philr.html" .

