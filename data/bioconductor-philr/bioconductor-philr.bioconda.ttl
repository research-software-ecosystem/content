@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-philr a schema1:SoftwareApplication ;
    schema1:description "Phylogenetic partitioning based ILR transform for metagenomics data" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/philr_1.36.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/philr/philr_1.36.0.tar.gz', 'https://bioarchive.galaxyproject.org/philr_1.36.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-philr/bioconductor-philr_1.36.0_src_all.tar.gz']" ;
    schema1:identifier biotools:philr ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-philr" ;
    schema1:softwareVersion "1.36.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/philr.html" ;
    spdx:builtFrom biotools:philr .

