@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:jupyter a schema1:SoftwareApplication ;
    schema1:description "Jupyter metapackage for installation, docs and chat" ;
    schema1:license "BSD 3-Clause \"New\" or \"Revised\" License" ;
    schema1:name "jupyter" ;
    schema1:url "https://github.com/jupyter/jupyter" .

