@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:lucy a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/17.12.1093" ;
    schema1:description "A program for dna sequence quality trimming and vector removal. its purpose is to process dna sequence data acquired from dna sequencers to prepare the data for downstream processing applications such as genome assembly." ;
    schema1:identifier biotools:lucy ;
    schema1:keywords "Consensus Sequence",
        "Data quality management",
        "Genetic Vectors",
        "RNA Splicing",
        "Sequence Analysis, DNA" ;
    schema1:license "GPL-2.0" ;
    schema1:name "lucy" ;
    schema1:url "https://sourceforge.net/projects/lucy/" .

