@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-bitseq a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/bts260" ;
    schema1:description "Transcript expression inference and differential expression analysis for RNA-seq data" ;
    schema1:identifier biotools:bitseq ;
    schema1:keywords "Bayes Theorem",
        "Gene Expression Profiling",
        "Gene expression",
        "Genetic Variation",
        "High-Throughput Nucleotide Sequencing",
        "Models, Statistical",
        "RNA-Seq",
        "RNA-seq",
        "Sequence Alignment",
        "Sequence Analysis, RNA",
        "Transcriptome" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-bitseq" ;
    schema1:url "https://www.bioconductor.org/packages/release/bioc/html/BitSeq.html" .

