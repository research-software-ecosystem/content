@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:savage a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1101/gr.215038.116" ;
    schema1:description "SAVAGE (Strain Aware VirAl GEnome assembly) reconstructs individual (viral) haplotypes from a mixed sample." ;
    schema1:keywords "Contig Mapping",
        "Genome, Viral",
        "Genomics",
        "Haplotypes",
        "Hepacivirus",
        "Polymorphism, Genetic",
        "Reference Standards",
        "Sequence Analysis, DNA",
        "Zika Virus" ;
    schema1:license "GPL-3.0" ;
    schema1:name "savage" ;
    schema1:url "https://github.com/HaploConduct/HaploConduct/tree/master/savage" .

