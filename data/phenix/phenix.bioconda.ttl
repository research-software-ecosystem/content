@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:phenix a schema1:SoftwareApplication ;
    schema1:description "Public Health England SNP calling pipeline" ;
    schema1:downloadUrl "https://github.com/phe-bioinformatics/PHEnix/archive/1-4-1a.tar.gz" ;
    schema1:identifier biotools:phenix ;
    schema1:license "GPL3" ;
    schema1:name "phenix" ;
    schema1:softwareVersion "1.4.1a" ;
    schema1:url "https://github.com/phe-bioinformatics/PHEnix" ;
    spdx:builtFrom biotools:phenix .

