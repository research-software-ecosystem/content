@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:pegasuspy a schema1:SoftwareApplication ;
    schema1:description "Pegasus is a tool for analyzing transcriptomes of millions of single cells. It is a command line tool, a python package and a base for Cloud-based analysis workflows." ;
    schema1:keywords "Transcriptome",
        "Transcriptomics" ;
    schema1:license "BSD" ;
    schema1:name "pegasuspy" ;
    schema1:url "https://github.com/klarman-cell-observatory/pegasus" .

