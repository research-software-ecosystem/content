@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-pcot2 a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Principal Coordinates and Hotelling's T-Square method" ;
    schema1:identifier biotools:pcot2 ;
    schema1:keywords "Computational Biology",
        "Gene Expression Profiling",
        "Gene regulation",
        "Genetics",
        "Genomics",
        "High-Throughput Screening Assays",
        "Molecular interactions, pathways and networks",
        "Programming Languages",
        "User-Computer Interface" ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-pcot2" ;
    schema1:url "http://bioconductor.org/packages/3.5/bioc/html/pcot2.html" .

