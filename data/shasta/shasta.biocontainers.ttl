@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:shasta a schema1:SoftwareApplication ;
    schema1:description "Rapidly produce accurate assembled sequence using as input DNA reads generated by Oxford Nanopore flow cells." ;
    schema1:keywords "Genomics" ;
    schema1:license "MIT" ;
    schema1:name "shasta" ;
    schema1:url "https://github.com/chanzuckerberg/shasta" .

