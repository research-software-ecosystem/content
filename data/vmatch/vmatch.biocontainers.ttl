@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:vmatch a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/bts605" ;
    schema1:description "The Vmatch large scale sequence analysis software" ;
    schema1:identifier biotools:vmatch ;
    schema1:keywords "Clustering",
        "Functional genomics",
        "Gene Expression",
        "Genetic Variation",
        "Genomics",
        "High-Throughput Nucleotide Sequencing",
        "Humans",
        "Metagenome",
        "Metagenomics",
        "Peptides",
        "Protein Sequences",
        "Proteomics",
        "RNA-Seq",
        "Sequence Alignment",
        "Sequence Analysis, DNA",
        "Sequence Analysis, RNA",
        "Sequence analysis",
        "Sequencing",
        "Transcription Factors",
        "Transcriptome" ;
    schema1:license "Not available" ;
    schema1:name "vmatch" ;
    schema1:url "http://www.vmatch.de/" .

