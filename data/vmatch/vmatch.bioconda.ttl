@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:vmatch a schema1:SoftwareApplication ;
    schema1:description "The Vmatch large scale sequence analysis software." ;
    schema1:downloadUrl "http://www.vmatch.de/distributions/vmatch-2.3.1-Darwin_i386-64bit.tar.gz",
        "http://www.vmatch.de/distributions/vmatch-2.3.1-Linux_x86_64-64bit.tar.gz" ;
    schema1:identifier biotools:vmatch ;
    schema1:license "Unknown" ;
    schema1:name "vmatch" ;
    schema1:softwareHelp "http://www.vmatch.de" ;
    schema1:softwareVersion "2.3.1" ;
    schema1:url "http://www.vmatch.de" ;
    spdx:builtFrom biotools:vmatch .

