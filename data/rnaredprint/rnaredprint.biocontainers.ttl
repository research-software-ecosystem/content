@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:rnaredprint a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s12859-019-2784-7" ;
    schema1:description "Tree-decomposition based dynamic programming algorithm for multiple target RNA design" ;
    schema1:keywords "Base Composition",
        "Models, Theoretical",
        "Nucleic Acid Conformation",
        "RNA",
        "User-Computer Interface" ;
    schema1:license "GPL" ;
    schema1:name "rnaredprint" ;
    schema1:url "https://github.com/yannponty/RNARedPrint" .

