@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:dicey a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s12864-020-6635-8" ;
    schema1:description "In-silico PCR and variant primer design." ;
    schema1:downloadUrl "https://github.com/gear-genomics/dicey/archive/v0.3.4.tar.gz" ;
    schema1:identifier biotools:Gear-Genomics ;
    schema1:license "GPL-3.0-or-later" ;
    schema1:name "dicey" ;
    schema1:softwareHelp "https://github.com/gear-genomics/dicey/blob/v0.3.4/README.md" ;
    schema1:softwareVersion "0.3.4" ;
    schema1:url "https://github.com/gear-genomics/dicey" ;
    spdx:builtFrom biotools:Gear-Genomics .

