@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:mafft a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/gkf436" ;
    schema1:description "Multiple alignment program for amino acid or nucleotide sequences" ;
    schema1:keywords "Clustering",
        "Computer Simulation",
        "DNA-Directed RNA Polymerases",
        "RNA, Ribosomal",
        "Reproducibility of Results",
        "Sequence Alignment",
        "Spectroscopy, Fourier Transform Infrared" ;
    schema1:license "mafft" ;
    schema1:name "mafft" ;
    schema1:url "http://mafft.cbrc.jp/alignment/software/" .

