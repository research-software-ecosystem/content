@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-snphood a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btw127" ;
    schema1:description "SNPhood: Investigate, quantify and visualise the epigenomic neighbourhood of SNPs using NGS data" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/SNPhood_1.36.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/SNPhood/SNPhood_1.36.0.tar.gz', 'https://bioarchive.galaxyproject.org/SNPhood_1.36.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-snphood/bioconductor-snphood_1.36.0_src_all.tar.gz']" ;
    schema1:identifier biotools:snphood ;
    schema1:license "LGPL (>= 3)" ;
    schema1:name "bioconductor-snphood" ;
    schema1:softwareVersion "1.36.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/SNPhood.html" ;
    spdx:builtFrom biotools:snphood .

