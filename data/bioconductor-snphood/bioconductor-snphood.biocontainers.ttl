@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-snphood a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btw127" ;
    schema1:description "SNPhood: Investigate, quantify and visualise the epigenomic neighbourhood of SNPs using NGS data" ;
    schema1:identifier biotools:snphood ;
    schema1:keywords "ChIP-seq",
        "Data visualisation",
        "Epigenomics",
        "Genome",
        "Humans",
        "Polymorphism, Single Nucleotide",
        "Regulatory Sequences, Nucleic Acid" ;
    schema1:license "LGPL (>= 3)" ;
    schema1:name "bioconductor-snphood" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/SNPhood.html" .

