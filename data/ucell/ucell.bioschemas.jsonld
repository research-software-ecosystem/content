      "sc:author": [
        "Massimo Andreatta",
        "Santiago Carmona"
      ],
      "sc:citation": {
        "@id": "https://doi.org/10.1016/j.csbj.2021.06.043"
      },
      "sc:description": "UCell is a package for evaluating gene signatures in single-cell datasets. UCell signature scores, based on the Mann-Whitney U statistic, are robust to dataset size and heterogeneity, and their calculation demands less computing time and memory than other available methods, enabling the processing of large datasets in a few minutes even on machines with limited computing power. UCell can be applied to any single-cell data matrix, and includes functions to directly interact with SingleCellExperiment and Seurat objects.",
      "sc:featureList": {
        "@id": "edam:operation_3435"
      },
