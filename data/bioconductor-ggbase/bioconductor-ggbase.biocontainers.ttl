@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-ggbase a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Infrastructure for genetics of gene expression package ggtools." ;
    schema1:identifier biotools:ggbase ;
    schema1:keywords "Computational Biology",
        "Gene Expression",
        "Gene Expression Profiling",
        "Gene expression",
        "Genetics",
        "Genomics",
        "High-Throughput Screening Assays",
        "Programming Languages",
        "User-Computer Interface" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-ggbase" ;
    schema1:url "http://bioconductor.org/packages/release/bioc/html/GGBase.html" .

