@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:metawrap a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s40168-018-0541-1" ;
    schema1:description "Metawrap is a pipeline for genome-resolved metagenomic data analysis" ;
    schema1:keywords "Bacteria",
        "Data Analysis",
        "Data Mining",
        "Gastrointestinal Microbiome",
        "Genome, Bacterial",
        "Humans",
        "Metagenome",
        "Metagenomics" ;
    schema1:license "MIT" ;
    schema1:name "metawrap" ;
    schema1:url "https://github.com/bxlab/metaWRAP" .

