@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:sabre a schema1:SoftwareApplication ;
    schema1:description "A barcode demultiplexing and trimming tool for FastQ files" ;
    schema1:identifier biotools:sabre ;
    schema1:keywords "Data quality management",
        "Sequence analysis" ;
    schema1:license "MIT" ;
    schema1:name "sabre" ;
    schema1:url "https://github.com/najoshi/sabre/" .

