@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:booster a schema1:SoftwareApplication ;
    schema1:description "BOOSTER is a new way of computing bootstrap supports in large phylogenies." ;
    schema1:keywords "Genetics",
        "Phylogenetics" ;
    schema1:license "GPL-2.0" ;
    schema1:name "booster" ;
    schema1:url "https://github.com/evolbioinfo/booster" .

