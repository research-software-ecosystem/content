@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:rapsearch a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/1471-2105-12-159" ;
    schema1:description "RAPSearch2 is a tool for fast protein similarity searches." ;
    schema1:identifier biotools:rapsearch ;
    schema1:keywords "Amino Acid Sequence",
        "Metagenomics",
        "Molecular Sequence Data",
        "Proteins",
        "Search Engine",
        "Sequence Alignment",
        "Sequence Analysis, Protein" ;
    schema1:license "GPL-3.0" ;
    schema1:name "rapsearch" ;
    schema1:url "https://github.com/zhaoyanswill/RAPSearch2" .

