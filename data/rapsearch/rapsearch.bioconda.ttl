@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:rapsearch a schema1:SoftwareApplication ;
    schema1:description "RAPSearch2 is a tool for fast protein similarity searches." ;
    schema1:downloadUrl "['https://depot.galaxyproject.org/software/rapsearch/rapsearch_2.24_src_all.tar.gz', 'http://downloads.sourceforge.net/project/rapsearch2/RAPSearch2.24_64bits.tar.gz']" ;
    schema1:identifier biotools:rapsearch ;
    schema1:license "GNU General Public License v3 (GPLv3)" ;
    schema1:name "rapsearch" ;
    schema1:softwareVersion "2.24" ;
    schema1:url "http://omics.informatics.indiana.edu/mg/RAPSearch2/" ;
    spdx:builtFrom biotools:rapsearch .

