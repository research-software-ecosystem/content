@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-affyio a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Bioconductor tools for parsing affymetrix data files" ;
    schema1:identifier biotools:affyio ;
    schema1:keywords "Computational Biology",
        "Data management",
        "Gene Expression Profiling",
        "Gene expression",
        "Genomics",
        "High-Throughput Screening Assays",
        "Microarray experiment",
        "Programming Languages",
        "User-Computer Interface" ;
    schema1:license "LGPL-2.1+" ;
    schema1:name "bioconductor-affyio" ;
    schema1:url "https://bioconductor.org/packages/affyio/" .

