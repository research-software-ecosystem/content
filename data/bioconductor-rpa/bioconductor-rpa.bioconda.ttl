@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-rpa a schema1:SoftwareApplication ;
    schema1:description "RPA: Robust Probabilistic Averaging for probe-level analysis" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/RPA_1.62.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/RPA/RPA_1.62.0.tar.gz', 'https://bioarchive.galaxyproject.org/RPA_1.62.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-rpa/bioconductor-rpa_1.62.0_src_all.tar.gz']" ;
    schema1:identifier biotools:rpa ;
    schema1:license "BSD_2_clause + file LICENSE" ;
    schema1:name "bioconductor-rpa" ;
    schema1:softwareVersion "1.62.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/RPA.html" ;
    spdx:builtFrom biotools:rpa .

