@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:gffcompare a schema1:SoftwareApplication ;
    schema1:description "GffCompare by Geo Pertea." ;
    schema1:downloadUrl "https://github.com/gpertea/gffcompare/releases/download/v0.12.10/gffcompare-0.12.10.tar.gz" ;
    schema1:identifier biotools:gffcompare ;
    schema1:license "Artistic License 2.0" ;
    schema1:name "gffcompare" ;
    schema1:softwareHelp "https://github.com/gpertea/gffcompare/blob/v0.12.10/README.md" ;
    schema1:softwareVersion "0.12.10" ;
    schema1:url "https://ccb.jhu.edu/software/stringtie/gffcompare.shtml" ;
    spdx:builtFrom biotools:gffcompare .

