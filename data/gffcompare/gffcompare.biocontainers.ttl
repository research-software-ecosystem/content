@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:gffcompare a schema1:SoftwareApplication ;
    schema1:citation "doi:10.12688/f1000research.23297.2" ;
    schema1:description "classify, merge, tracking and annotation of GFF files by comparing to a reference annotation GFF" ;
    schema1:identifier biotools:gffcompare ;
    schema1:keywords "Clustering",
        "Nucleic acids",
        "RNA-Seq",
        "Sequence analysis" ;
    schema1:license "MIT" ;
    schema1:name "gffcompare" ;
    schema1:url "https://github.com/gpertea/gffcompare" .

