@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-gsealm a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btn465" ;
    schema1:description "Linear Model Toolset for Gene Set Enrichment Analysis" ;
    schema1:identifier biotools:gsealm ;
    schema1:keywords "Chromosomes",
        "Gene Expression",
        "Gene Expression Profiling",
        "Gene expression",
        "Humans",
        "Leukemia, Lymphoid",
        "Linear Models",
        "Models, Genetic",
        "Molecular genetics",
        "Phenotype" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-gsealm" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/GSEAlm.html" .

