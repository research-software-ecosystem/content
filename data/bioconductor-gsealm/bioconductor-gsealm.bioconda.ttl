@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-gsealm a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btn465" ;
    schema1:description "Linear Model Toolset for Gene Set Enrichment Analysis" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/GSEAlm_1.70.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/GSEAlm/GSEAlm_1.70.0.tar.gz', 'https://bioarchive.galaxyproject.org/GSEAlm_1.70.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-gsealm/bioconductor-gsealm_1.70.0_src_all.tar.gz']" ;
    schema1:identifier biotools:gsealm ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-gsealm" ;
    schema1:softwareVersion "1.70.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/GSEAlm.html" ;
    spdx:builtFrom biotools:gsealm .

