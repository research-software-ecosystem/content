@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:scallop a schema1:SoftwareApplication ;
    schema1:description "Scallop is a reference-based transcriptome assembler for RNA-seq" ;
    schema1:keywords "Genomics",
        "RNA-Seq",
        "Transcriptome" ;
    schema1:license "BSD 3-Clause License" ;
    schema1:name "scallop" ;
    schema1:url "https://github.com/Kingsford-Group/scallop" .

