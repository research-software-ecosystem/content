@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:mobster a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s13059-014-0488-x" ;
    schema1:description "Ngs tool for detecting mei and gene retrotransposition events in wgs and wes data, see thung et al. genome biol. 2014 for more information." ;
    schema1:identifier biotools:mobster ;
    schema1:keywords "Benchmarking",
        "DNA",
        "DNA Transposable Elements",
        "Genome, Human",
        "Humans",
        "Nucleic acid sites, features and motifs",
        "Sequence Analysis, DNA",
        "Sequencing" ;
    schema1:license "GNU General Public License v3.0" ;
    schema1:name "mobster" ;
    schema1:url "https://github.com/jyhehir/mobster" .

