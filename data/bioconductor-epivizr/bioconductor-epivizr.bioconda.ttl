@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-epivizr a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3038" ;
    schema1:description "R Interface to epiviz web app" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/epivizr_2.36.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/epivizr/epivizr_2.36.0.tar.gz', 'https://bioarchive.galaxyproject.org/epivizr_2.36.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-epivizr/bioconductor-epivizr_2.36.0_src_all.tar.gz']" ;
    schema1:identifier biotools:epivizr ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-epivizr" ;
    schema1:softwareVersion "2.36.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/epivizr.html" ;
    spdx:builtFrom biotools:epivizr .

