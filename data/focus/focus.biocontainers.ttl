@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:focus a schema1:SoftwareApplication ;
    schema1:description "FOCUS is an innovative and agile model to profile and report organisms present in metagenomic samples based on composition usage without sequence length dependencies." ;
    schema1:keywords "Metagenome" ;
    schema1:license "GPL-3.0" ;
    schema1:name "focus" ;
    schema1:url "https://edwards.sdsu.edu/FOCUS" .

