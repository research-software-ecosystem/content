@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:rucs a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btx526" ;
    schema1:description "RUCS is a bioinformatics tool developed to ease the task of designing new primers." ;
    schema1:identifier biotools:rucs ;
    schema1:keywords "Base Sequence",
        "DNA Primers",
        "Laboratory information management",
        "PCR experiment",
        "Polymerase Chain Reaction",
        "Probes and primers" ;
    schema1:license "Apache-2.0" ;
    schema1:name "rucs" ;
    schema1:url "https://bitbucket.org/genomicepidemiology/rucs/src/master/" .

