@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:megan a schema1:SoftwareApplication ;
    schema1:description "A tool for studying the taxonomic content of a set of DNA reads" ;
    schema1:downloadUrl "https://maira.cs.uni-tuebingen.de/download/megan6/MEGAN_Community_unix_6_25_10.sh",
        "https://maira.cs.uni-tuebingen.de/download/megan6/MEGAN_Community_unix_ARM_6_25_10.sh" ;
    schema1:identifier biotools:megan ;
    schema1:license "GPL >=3" ;
    schema1:name "megan" ;
    schema1:softwareVersion "6.25.10" ;
    schema1:url "https://megan.cs.uni-tuebingen.de/" ;
    spdx:builtFrom biotools:megan .

