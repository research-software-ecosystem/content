@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:megan a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1101/gr.5969107" ;
    schema1:description "Metagenome analysis software - megan (metagenome analyzer\\x9D) is a new computer program that allows laptop analysis of large metagenomic datasets. in a preprocessing step, the set of dna reads (or contigs) is compared against databases of known sequences using blast or another comparison tool. megan can then be used to compute and interactively explore the taxonomical content of the dataset, employing the ncbi taxonomy to summarize and order the results." ;
    schema1:identifier biotools:megan ;
    schema1:keywords "Atlantic Ocean",
        "Biodiversity",
        "Clustering",
        "Computational Biology",
        "Ecosystem",
        "Genetic Variation",
        "Genome",
        "Genomics",
        "Metagenome",
        "Phylogeny",
        "Sequence analysis",
        "Species Specificity" ;
    schema1:license "GPL >=3" ;
    schema1:name "megan" ;
    schema1:url "http://ab.inf.uni-tuebingen.de/software/megan6/" .

