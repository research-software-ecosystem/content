@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:crisprme a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btz867" ;
    schema1:description "Crisprme, tool package for crispr experiments assessment and analysis." ;
    schema1:keywords "CRISPR-Cas Systems",
        "Clustered Regularly Interspaced Short Palindromic Repeats",
        "Gene Editing",
        "RNA, Guide" ;
    schema1:license "Affero License" ;
    schema1:name "crisprme" ;
    schema1:url "https://github.com/samuelecancellieri/CRISPRme" .

