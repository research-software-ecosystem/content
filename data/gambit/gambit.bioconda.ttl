@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:gambit a schema1:SoftwareApplication ;
    schema1:author "jlumpe" ;
    schema1:citation "doi:10.1371/journal.pone.0277575" ;
    schema1:description "Tool for rapid taxonomic identification of microbial pathogens" ;
    schema1:downloadUrl "https://github.com/jlumpe/gambit/archive/v1.1.0.tar.gz" ;
    schema1:identifier biotools:gambit_bacterial ;
    schema1:license "AGPL-3.0-or-later" ;
    schema1:maintainer "jlumpe" ;
    schema1:name "gambit" ;
    schema1:softwareHelp "https://gambit-genomics.readthedocs.io/en/latest" ;
    schema1:softwareVersion "1.1.0" ;
    schema1:url "https://github.com/jlumpe/gambit" ;
    spdx:builtFrom biotools:gambit_bacterial .

