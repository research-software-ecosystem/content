@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:smina a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1021/ci300604z" ;
    schema1:description "A fork of AutoDock Vina that is customized to better support scoring function development and high-performance energy minimization." ;
    schema1:keywords "Benchmarking",
        "Databases, Pharmaceutical",
        "Drug Discovery",
        "Molecular Docking Simulation",
        "Protein Conformation",
        "Structure-Activity Relationship" ;
    schema1:license "GPL-2.0" ;
    schema1:name "smina" ;
    schema1:url "https://sourceforge.net/projects/smina/" .

