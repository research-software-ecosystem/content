@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-nondetects a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btu239" ;
    schema1:description "Non-detects in qPCR data" ;
    schema1:identifier biotools:nondetects ;
    schema1:keywords "Animals",
        "Gene Expression Profiling",
        "Gene expression",
        "Mice",
        "Models, Theoretical",
        "PCR experiment",
        "Real-Time Polymerase Chain Reaction" ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-nondetects" ;
    schema1:url "http://bioconductor.org/packages/3.6/bioc/html/nondetects.html" .

