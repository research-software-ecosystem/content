@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-nondetects a schema1:SoftwareApplication ;
    schema1:description "Non-detects in qPCR data" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.18/bioc/src/contrib/nondetects_2.32.0.tar.gz', 'https://bioconductor.org/packages/3.18/bioc/src/contrib/Archive/nondetects/nondetects_2.32.0.tar.gz', 'https://bioarchive.galaxyproject.org/nondetects_2.32.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-nondetects/bioconductor-nondetects_2.32.0_src_all.tar.gz']" ;
    schema1:identifier biotools:nondetects ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-nondetects" ;
    schema1:softwareVersion "2.32.0" ;
    schema1:url "https://bioconductor.org/packages/3.18/bioc/html/nondetects.html" ;
    spdx:builtFrom biotools:nondetects .

