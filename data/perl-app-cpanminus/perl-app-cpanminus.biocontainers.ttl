@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:perl-app-cpanminus a schema1:SoftwareApplication ;
    schema1:description "Get, unpack, build and install modules from cpan" ;
    schema1:license "perl_5" ;
    schema1:name "perl-app-cpanminus" ;
    schema1:url "https://github.com/miyagawa/cpanminus" .

