    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-mbamethyl" ;
    schema1:softwareVersion "1.40.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/MBAmethyl.html" ;
    spdx:builtFrom biotools:mbamethyl .

