@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:dsh-bio a schema1:SoftwareApplication ;
    schema1:description "Tools for BED, FASTA, FASTQ, GFA1/2, GFF3, SAM, and VCF files" ;
    schema1:license "LGPL-3.0" ;
    schema1:name "dsh-bio" ;
    schema1:url "https://github.com/heuermh/dishevelled-bio" .

