@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-splicesites a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18129/b9.bioc.splicesites" ;
    schema1:description "Performs splice centered analysis on RNA-seq data." ;
    schema1:keywords "Proteomics",
        "RNA-Seq" ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-splicesites" ;
    schema1:url "https://bioconductor.org/packages/3.8/bioc/html/spliceSites.html" .

