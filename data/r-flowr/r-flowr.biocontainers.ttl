@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-flowr a schema1:SoftwareApplication ;
    schema1:description "This framework allows you to design and implement complex pipelines, and deploy them on your institution's computing cluster. This has been built keeping in mind the needs of bioinformatics workflows. However, it is easily extendable to any field where a series of steps (shell commands) are to be executed in a (work)flow." ;
    schema1:license "MIT" ;
    schema1:name "r-flowr" ;
    schema1:url "None" .

