@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:fastml a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/gks498" ;
    schema1:description "Fastml is a webserver for computing and reconstructing ancestral sequences using maximum likelihood." ;
    schema1:identifier biotools:fastml ;
    schema1:keywords "Computer Graphics",
        "Experimental design and studies",
        "INDEL Mutation",
        "Internet",
        "Phylogeny",
        "Probability",
        "Sequence Alignment",
        "Sequence analysis",
        "Sequencing",
        "Statistics and probability",
        "env Gene Products, Human Immunodeficiency Virus" ;
    schema1:license "GPL-2+" ;
    schema1:name "fastml" ;
    schema1:url "http://fastml.tau.ac.il/" .

