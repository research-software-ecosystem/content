@prefix debianmed: <https://salsa.debian.org/med-team/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

debianmed:fastml a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/18.8.1116",
        "doi:10.1093/nar/gks498" ;
    schema1:description "maximum likelihood ancestral amino-acid sequence reconstruction" ;
    schema1:identifier "bio.tools:fastml",
        "omictools:OMICS_08650" ;
    schema1:license "unknown" ;
    schema1:name "fastml" ;
    schema1:softwareVersion "3.11" ;
    schema1:url "http://fastml.tau.ac.il/" ;
    spdx:builtFrom "fastml" .

