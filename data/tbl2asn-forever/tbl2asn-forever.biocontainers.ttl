@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:tbl2asn-forever a schema1:SoftwareApplication ;
    schema1:description "Tbl2asn is a program that automates the creation of sequence records for submission to genbank" ;
    schema1:keywords "Gene Expression",
        "Genetics",
        "Metagenome",
        "Protein Sequences",
        "Sequence Alignment" ;
    schema1:license "Custom License" ;
    schema1:name "tbl2asn-forever" ;
    schema1:url "https://www.ncbi.nlm.nih.gov/genbank/tbl2asn2" .

