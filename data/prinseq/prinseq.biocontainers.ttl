@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:prinseq a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btr026" ;
    schema1:description "Prinseq can be used to filter, reformat, or trim your genomic and metagenomic sequence data" ;
    schema1:identifier biotools:prinseq ;
    schema1:keywords "Computer Graphics",
        "Genomics",
        "Information Storage and Retrieval",
        "Internet",
        "Metagenome",
        "Metagenomics",
        "Programming Languages",
        "Quality Control",
        "Sequence Analysis, DNA",
        "Transcriptomics" ;
    schema1:license "GPL-3.0" ;
    schema1:name "prinseq" ;
    schema1:url "http://prinseq.sourceforge.net/" .

