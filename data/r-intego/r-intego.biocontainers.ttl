@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-intego a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/1471-2105-14-42" ;
    schema1:description "An unsupervised gene clustering algorithm based on the integration of external biological knowledge, such as gene ontology annotations, into expression data." ;
    schema1:keywords "Cluster Analysis",
        "Gene Expression Profiling",
        "Humans",
        "Molecular Sequence Annotation" ;
    schema1:license "GPL-3" ;
    schema1:name "r-intego" ;
    schema1:url "http://marie.verbanck.free.fr/packages/InteGO/" .

