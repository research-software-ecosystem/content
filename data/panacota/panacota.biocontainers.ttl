@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:panacota a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1101/2020.09.11.293472" ;
    schema1:description "Large scale comparative genomics tools: annotate genomes, do pangenome, core/persistent genome, align core/persistent families, infer phylogenetic tree." ;
    schema1:keywords "Genomics" ;
    schema1:license "Not available" ;
    schema1:name "panacota" ;
    schema1:url "https://github.com/gem-pasteur/PanACoTA" .

