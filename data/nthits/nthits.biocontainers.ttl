@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:nthits a schema1:SoftwareApplication ;
    schema1:description "a method for identifying repeats in high-throughput DNA sequencing data." ;
    schema1:license "MIT" ;
    schema1:name "nthits" ;
    schema1:url "https://github.com/bcgsc/ntHits" .

