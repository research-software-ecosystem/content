  "@graph": [
    {
      "@id": "https://bio.tools/bioconductor-meskit",
      "@type": "sc:SoftwareApplication",
      "dcterms:conformsTo": "https://bioschemas.org/profiles/ComputationalTool/0.6-DRAFT",
      "sc:additionalType": [
        "Command-line tool",
        "Library"
      ],
      "sc:author": [
        "Mengni Liu",
        "Jianyu Chen",
        "Xin Wang"
      ],
      "sc:citation": {
        "@id": "https://doi.org/10.18129/B9.bioc.MesKit"
      },
      "sc:contributor": [
        "Jianyu Chen",
        "Xin Wang"
      ],
      "sc:description": "MesKit provides commonly used analysis and visualization modules based on mutational data generated by multi-region sequencing (MRS). This package allows to depict mutational profiles, measure heterogeneity within or between tumors from the same patient, track evolutionary dynamics, as well as characterize mutational patterns on different levels. Shiny application was also developed for a need of GUI-based analysis. As a handy tool, MesKit can facilitate the interpretation of tumor heterogeneity and the understanding of evolutionary relationship between regions in MRS study.",
      "sc:license": "GPL-3.0-only",
      "sc:name": "MesKit",
      "sc:operatingSystem": [
        "Windows",
        "Mac",
        "Linux"
      ],
      "sc:softwareHelp": {
        "@id": "https://bioconductor.org/packages/MesKit"
      },
      "sc:softwareVersion": "1.20.0",
      "sc:url": "https://bioconductor.org/packages/MesKit"
    },
    {
      "@id": "https://doi.org/10.18129/B9.bioc.MesKit",
      "@type": "sc:CreativeWork"
    }
