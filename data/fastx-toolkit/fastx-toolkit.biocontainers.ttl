@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:fastx-toolkit a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1006/geno.1997.4995" ;
    schema1:description "Collection of command line tools for short-reads fasta/fastq files preprocessing." ;
    schema1:identifier biotools:fastx-toolkit ;
    schema1:keywords "Amino Acid Sequence",
        "Animals",
        "Base Sequence",
        "DNA",
        "Databases, Factual",
        "Genes",
        "Genes, Bacterial",
        "Mice",
        "Molecular Sequence Data",
        "Open Reading Frames",
        "Proteins",
        "Sequence Alignment",
        "Sequence analysis" ;
    schema1:license "AGPL-3.0" ;
    schema1:name "fastx-toolkit" ;
    schema1:url "http://hannonlab.cshl.edu/fastx_toolkit/" .

