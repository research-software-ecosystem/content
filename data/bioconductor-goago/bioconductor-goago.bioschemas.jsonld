  "@graph": [
    {
      "@id": "https://bio.tools/bioconductor-goago",
      "@type": "sc:SoftwareApplication",
      "dcterms:conformsTo": "https://bioschemas.org/profiles/ComputationalTool/0.6-DRAFT",
      "sc:additionalType": [
        "Command-line tool",
        "Library"
      ],
      "sc:author": "Aleksander Jankowski",
      "sc:citation": {
        "@id": "https://doi.org/10.18129/B9.bioc.GOaGO"
      },
      "sc:description": "GO-a-GO annotates Gene Ontology terms that are enriched in a given set of gene pairs. The enrichment is calculated from a permutation test for overrepresentation of gene pairs that are associated with a shared term. Such gene pairs are counted for the original set of gene pairs and compared against randomized sets in which the structure of the pairs is preserved, but the gene identities (including the associated terms) are permuted.",
      "sc:license": "Artistic-2.0",
      "sc:name": "GOaGO",
      "sc:operatingSystem": [
        "Windows",
        "Linux",
        "Mac"
      ],
      "sc:softwareHelp": {
        "@id": "https://bioconductor.org/packages/GOaGO"
      },
      "sc:softwareVersion": "1.0.1",
      "sc:url": "https://bioconductor.org/packages/GOaGO"
    },
    {
      "@id": "https://doi.org/10.18129/B9.bioc.GOaGO",
      "@type": "sc:CreativeWork"
    }
