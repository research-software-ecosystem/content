@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:batchcorrection a schema1:SoftwareApplication ;
    schema1:description "Corrects intensities for signal drift and batch-effects" ;
    schema1:keywords "Mass spectrometry",
        "Metabolomics" ;
    schema1:license "Custom License" ;
    schema1:name "batchcorrection" ;
    schema1:url "https://github.com/phnmnl/container-batch_correction" .

