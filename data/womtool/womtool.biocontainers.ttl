@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:womtool a schema1:SoftwareApplication ;
    schema1:description "Command line utilities for interacting with wdl" ;
    schema1:identifier biotools:womtool ;
    schema1:license "BSD-3-Clause" ;
    schema1:name "womtool" ;
    schema1:url "https://github.com/broadinstitute/cromwell" .

