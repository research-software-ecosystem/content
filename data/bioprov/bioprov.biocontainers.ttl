@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioprov a schema1:SoftwareApplication ;
    schema1:description "Bioprov: provenance capture for bioinformatics workflows" ;
    schema1:license "MIT" ;
    schema1:name "bioprov" ;
    schema1:url "https://github.com/vinisalazar/BioProv" .

