@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:plasclass a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1371/journal.pcbi.1007781" ;
    schema1:description "Classification of plasmid sequences" ;
    schema1:keywords "Computational Biology",
        "DNA",
        "DNA, Bacterial",
        "Genome, Bacterial",
        "Plasmids",
        "Sequence Analysis, DNA" ;
    schema1:license "Not available" ;
    schema1:name "plasclass" ;
    schema1:url "https://github.com/Shamir-Lab/PlasClass" .

