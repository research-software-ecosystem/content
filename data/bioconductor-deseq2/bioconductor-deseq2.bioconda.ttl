@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-deseq2 a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s13059-014-0550-8" ;
    schema1:description "Differential gene expression analysis based on the negative binomial distribution" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/DESeq2_1.46.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/DESeq2/DESeq2_1.46.0.tar.gz', 'https://bioarchive.galaxyproject.org/DESeq2_1.46.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-deseq2/bioconductor-deseq2_1.46.0_src_all.tar.gz']" ;
    schema1:identifier biotools:deseq2 ;
    schema1:license "LGPL (>= 3)" ;
    schema1:name "bioconductor-deseq2" ;
    schema1:softwareVersion "1.46.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/DESeq2.html" ;
    spdx:builtFrom biotools:deseq2 .

