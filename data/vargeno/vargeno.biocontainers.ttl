@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:vargeno a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/bty641" ;
    schema1:description "Fast SNP genotyping tool for whole genome sequence data and large SNP database." ;
    schema1:keywords "Genotype",
        "Genotyping Techniques",
        "Polymorphism, Single Nucleotide",
        "Whole Genome Sequencing",
        "Whole genome sequencing" ;
    schema1:license "MIT" ;
    schema1:name "vargeno" ;
    schema1:url "https://github.com/medvedevgroup/vargeno" .

