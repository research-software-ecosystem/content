    schema1:description "A Tool for automated Optimization of XCMS Parameters" ;
    schema1:identifier biotools:ipo ;
    schema1:keywords "Animals",
        "Carbon Radioisotopes",
        "Chromatography, Liquid",
        "Electronic Data Processing",
        "Heart",
        "Humans",
        "Lipids",
        "Lung",
        "Mass Spectrometry",
        "Mass spectrometry",
        "Metabolomics",
        "Mice",
        "Muscles",
        "Programming Languages",
        "Proteomics",
        "Proteomics experiment",
        "Reproducibility of Results",
        "Saccharomyces cerevisiae" ;
    schema1:license "Custom License" ;
    schema1:name "ipo" ;
    schema1:url "https://github.com/rietho/IPO" .

