@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:figtree a schema1:SoftwareApplication ;
    schema1:description "This tool is designed as a graphical viewer of phylogenetic trees and as a program for producing publication-ready figures." ;
    schema1:identifier biotools:figtree ;
    schema1:keywords "Data visualisation",
        "Phylogenetics" ;
    schema1:license "GPL" ;
    schema1:name "figtree" ;
    schema1:url "https://github.com/rambaut/figtree" .

