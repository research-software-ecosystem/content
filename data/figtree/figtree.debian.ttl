@prefix debianmed: <https://salsa.debian.org/med-team/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

debianmed:figtree a schema1:SoftwareApplication ;
    schema1:description "graphical phylogenetic tree viewer" ;
    schema1:identifier "bio.tools:FigTree",
        "conda:bioconda:figtree",
        "omictools:OMICS_04268",
        "scicrunch:SCR_008515" ;
    schema1:license "unknown" ;
    schema1:name "figtree" ;
    schema1:softwareVersion "1.4.4" ;
    schema1:url "http://tree.bio.ed.ac.uk/software/figtree/" ;
    spdx:builtFrom "FigTree" .

