@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:mash a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s13059-016-0997-x",
        "doi:10.1186/s13059-019-1841-x" ;
    schema1:description "Fast sequence distance estimator that uses MinHash." ;
    schema1:downloadUrl "https://github.com/marbl/Mash/archive/v2.3.tar.gz" ;
    schema1:identifier biotools:mash ;
    schema1:license "https://github.com/marbl/Mash/blob/master/LICENSE.txt" ;
    schema1:name "mash" ;
    schema1:softwareHelp "https://mash.readthedocs.io/en/latest" ;
    schema1:softwareVersion "2.3" ;
    schema1:url "https://github.com/marbl/Mash" ;
    spdx:builtFrom biotools:mash .

