@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:mash a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s13059-016-0997-x" ;
    schema1:description "Fast genome and metagenome distance estimation using minhash." ;
    schema1:identifier biotools:mash ;
    schema1:keywords "Cluster Analysis",
        "DNA mutation",
        "Databases, Nucleic Acid",
        "Evolution, Molecular",
        "Genome",
        "Genomics",
        "Metagenome",
        "Metagenomics",
        "Phylogeny",
        "Sequence analysis",
        "Statistics and probability" ;
    schema1:license "CC-BY-4.0" ;
    schema1:name "mash" ;
    schema1:url "https://github.com/marbl/mash" .

