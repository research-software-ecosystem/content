@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-venn a schema1:SoftwareApplication ;
    schema1:description "Draws and displays Venn diagrams up to 7 sets, and any Boolean union of set intersections." ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "r-venn" ;
    schema1:url "https://CRAN.R-project.org/package=venn" .

