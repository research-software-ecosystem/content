@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:clame a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s12864-018-5191-y" ;
    schema1:description "CLAME is a binning software for metagenomic reads. It immplements a fm-index search algorithm for nucleotide sequence alignment. Then it uses strongly connected component strategy to bin sequences with similar DNA composition." ;
    schema1:keywords "Colombia",
        "Genes, Bacterial",
        "Genetic Markers",
        "Genome, Bacterial",
        "Genomics",
        "Metagenomics",
        "Microbiota",
        "Phylogeny",
        "Sequence Alignment",
        "Sequence Analysis, DNA",
        "Xanthomonadaceae" ;
    schema1:license "GPL-3.0" ;
    schema1:name "clame" ;
    schema1:url "https://github.com/andvides/CLAME" .

