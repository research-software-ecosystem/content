@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:rsidx a schema1:SoftwareApplication ;
    schema1:description "Library for indexing vcf files for random access searches by rsid" ;
    schema1:keywords "Genomics" ;
    schema1:license "BSD" ;
    schema1:name "rsidx" ;
    schema1:url "https://github.com/bioforensics/rsidx/" .

