@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-deepsnv a schema1:SoftwareApplication ;
    schema1:description "Detection of subclonal SNVs in deep sequencing data." ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/deepSNV_1.56.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/deepSNV/deepSNV_1.56.0.tar.gz', 'https://bioarchive.galaxyproject.org/deepSNV_1.56.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-deepsnv/bioconductor-deepsnv_1.56.0_src_all.tar.gz']" ;
    schema1:identifier biotools:deepsnv ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-deepsnv" ;
    schema1:softwareVersion "1.56.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/deepSNV.html" ;
    spdx:builtFrom biotools:deepsnv .

