@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-deepsnv a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btt750" ;
    schema1:description "Detection of subclonal SNVs in deep sequencing data." ;
    schema1:identifier biotools:deepsnv ;
    schema1:keywords "Biometry",
        "Genetics",
        "Genome, Human",
        "Humans",
        "Mutation",
        "Neoplasms",
        "Probability",
        "Prognosis",
        "Reproducibility of Results",
        "Sequencing",
        "Software Design" ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-deepsnv" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/deepSNV.html" .

