      "sc:applicationSubCategory": {
        "@id": "edam:topic_0622"
      },
      "sc:citation": {
        "@id": "https://doi.org/10.18129/B9.bioc.epivizr"
      },
      "sc:description": "This package provides connections to the epiviz web app (http://epiviz.cbcb.umd.edu) for interactive visualization of genomic data. Objects in R/bioc interactive sessions can be displayed in genome browser tracks or plots to be explored by navigation through genomic regions. Fundamental Bioconductor data structures are supported (e.g., GenomicRanges and RangedSummarizedExperiment objects), while providing an easy mechanism to support other data structures (through package epivizrData). Visualizations (using d3.js) can be easily added to the web app as well.",
      "sc:featureList": [
        {
          "@id": "edam:operation_3208"
        },
        {
          "@id": "edam:operation_0224"
        }
      ],
