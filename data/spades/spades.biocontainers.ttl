@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:spades a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1089/cmb.2012.0021",
        "doi:10.1093/bioinformatics/btz349",
        "doi:10.1093/gigascience/giz100",
        "doi:10.1101/gr.213959.116",
        "doi:10.7490/f1000research.1114334.1" ;
    schema1:description "St. petersburg genome assembler – is intended for both standard isolates and single-cell mda bacteria assemblies. spades 3.9 works with illumina or iontorrent reads and is capable of providing hybrid assemblies using pacbio, oxford nanopore and sanger reads. additional contigs can be provided and can be used as long reads." ;
    schema1:identifier biotools:spades ;
    schema1:keywords "Cloud Computing",
        "High-Throughput Nucleotide Sequencing",
        "Metagenome",
        "Metagenomics",
        "Protein Sequences",
        "RNA-Seq",
        "Sequence Analysis, DNA",
        "Sequence assembly",
        "Transcriptome" ;
    schema1:license "GPL-2.0" ;
    schema1:name "spades" ;
    schema1:url "https://github.com/ablab/spades" .

