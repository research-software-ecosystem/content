@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:spades a schema1:SoftwareApplication ;
    schema1:author "chrisjackson-pellicle",
        "druvus",
        "notestaff" ;
    schema1:citation "doi:10.1089/cmb.2012.0021",
        "doi:10.1093/bioinformatics/btz349",
        "doi:10.1093/gigascience/giz100",
        "doi:10.1101/gr.213959.116" ;
    schema1:description "SPAdes (St. Petersburg genome assembler) is intended for both standard isolates and single-cell MDA bacteria assemblies." ;
    schema1:downloadUrl "https://github.com/ablab/spades/releases/download/v4.2.0/SPAdes-4.2.0.tar.gz" ;
    schema1:identifier biotools:spades ;
    schema1:license "GPL-2.0-only" ;
    schema1:maintainer "chrisjackson-pellicle",
        "druvus",
        "notestaff" ;
    schema1:name "spades" ;
    schema1:softwareHelp "https://ablab.github.io/spades" ;
    schema1:softwareVersion "4.2.0" ;
    schema1:url "https://github.com/ablab/spades" ;
    spdx:builtFrom biotools:spades .

