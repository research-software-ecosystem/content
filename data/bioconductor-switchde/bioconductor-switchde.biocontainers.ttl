@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-switchde a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btw798" ;
    schema1:description "Switch-like differential expression across single-cell trajectories" ;
    schema1:identifier biotools:switchde ;
    schema1:keywords "Gene Expression Profiling",
        "Gene expression",
        "Models, Genetic",
        "Models, Statistical",
        "RNA-Seq",
        "Sequence Analysis, RNA",
        "Single-Cell Analysis",
        "Transcriptomics" ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-switchde" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/switchde.html" .

