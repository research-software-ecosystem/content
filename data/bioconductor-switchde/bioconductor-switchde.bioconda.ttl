@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-switchde a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btw798" ;
    schema1:description "Switch-like differential expression across single-cell trajectories" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/switchde_1.32.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/switchde/switchde_1.32.0.tar.gz', 'https://bioarchive.galaxyproject.org/switchde_1.32.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-switchde/bioconductor-switchde_1.32.0_src_all.tar.gz']" ;
    schema1:identifier biotools:switchde ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-switchde" ;
    schema1:softwareVersion "1.32.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/switchde.html" ;
    spdx:builtFrom biotools:switchde .

