@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:mosca a schema1:SoftwareApplication ;
    schema1:description "Mosca - meta-omics software for community analysis" ;
    schema1:keywords "Gene Expression",
        "Genomics",
        "Metagenomics",
        "Metaproteomics",
        "Proteomics",
        "Transcriptomics" ;
    schema1:license "Not available" ;
    schema1:name "mosca" ;
    schema1:url "https://github.com/iquasere/MOSCA" .

