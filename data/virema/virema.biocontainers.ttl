@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:virema a schema1:SoftwareApplication ;
    schema1:description "Virema (viral recombination mapper) detects and reports recombination or fusion events in virus genomes using deep sequencing datasets." ;
    schema1:license "MIT" ;
    schema1:name "virema" ;
    schema1:url "https://sourceforge.net/projects/virema/" .

