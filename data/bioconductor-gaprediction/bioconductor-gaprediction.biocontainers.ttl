    schema1:keywords "Cohort Studies",
        "CpG Islands",
        "DNA Methylation",
        "Epigenesis, Genetic",
        "Female",
        "Genetics",
        "Genome, Human",
        "Genome-Wide Association Study",
        "Geriatric medicine",
        "Gestational Age",
        "Humans",
        "Infant, Newborn",
        "Pregnancy",
        "Ultrasonography" ;
    schema1:license "GPL (>=2)" ;
    schema1:name "bioconductor-gaprediction" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/GAprediction.html" .

