@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-gaprediction a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s13059-016-1063-4" ;
    schema1:description "Prediction of gestational age with Illumina HumanMethylation450 data" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/GAprediction_1.36.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/GAprediction/GAprediction_1.36.0.tar.gz', 'https://bioarchive.galaxyproject.org/GAprediction_1.36.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-gaprediction/bioconductor-gaprediction_1.36.0_src_all.tar.gz']" ;
    schema1:identifier biotools:gaprediction ;
    schema1:license "GPL (>=2)" ;
    schema1:name "bioconductor-gaprediction" ;
    schema1:softwareVersion "1.36.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/GAprediction.html" ;
    spdx:builtFrom biotools:gaprediction .

