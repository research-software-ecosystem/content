@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:galaxy-lib a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/gkw343",
        "doi:10.1093/nar/gky379" ;
    schema1:description "Subset of Galaxy (http://galaxyproject.org/) core code base designed to be used a library." ;
    schema1:keywords "Datasets as Topic",
        "Genomics",
        "Humans",
        "Information Dissemination",
        "International Cooperation",
        "Internet",
        "Metabolomics",
        "Molecular Imaging",
        "Proteomics",
        "Reproducibility of Results",
        "User-Computer Interface" ;
    schema1:license "AFL" ;
    schema1:name "galaxy-lib" ;
    schema1:url "https://github.com/galaxyproject/galaxy-lib" .

