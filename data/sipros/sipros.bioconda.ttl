@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:sipros a schema1:SoftwareApplication ;
    schema1:author "bernt-matthias",
        "yi-xiong" ;
    schema1:citation "doi:10.1186/s40168-024-01866-1" ;
    schema1:description "Tools for stable isotopic mass spectrometry-based metaproteomics" ;
    schema1:downloadUrl "https://github.com/thepanlab/sipros5/releases/download/5.0.1/siprosRelease.zip" ;
    schema1:identifier biotools:sipros ;
    schema1:license "MIT" ;
    schema1:maintainer "bernt-matthias",
        "yi-xiong" ;
    schema1:name "sipros" ;
    schema1:softwareVersion "5.0.1" ;
    schema1:url "https://github.com/thepanlab/sipros5/" ;
    spdx:builtFrom biotools:sipros .

