@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:metabuli a schema1:SoftwareApplication ;
    schema1:author "jaebeom-kim",
        "milot-mirdita" ;
    schema1:citation "doi:10.1038/s41592-024-02273-y" ;
    schema1:description "Metabuli: specific and sensitive metagenomic classification via joint analysis of DNA and amino acid." ;
    schema1:downloadUrl "https://github.com/jaebeom-kim/MMseqs2/archive/0.0.0.tar.gz",
        "https://github.com/jaebeom-kim/fasta_validator/archive/0.0.0.tar.gz",
        "https://github.com/steineggerlab/metabuli/archive/1.2.0.tar.gz" ;
    schema1:identifier biotools:metabuli ;
    schema1:license "GPLv3" ;
    schema1:maintainer "jaebeom-kim",
        "milot-mirdita" ;
    schema1:name "metabuli" ;
    schema1:softwareVersion "1.2.0" ;
    schema1:url "https://github.com/steineggerlab/Metabuli" ;
    spdx:builtFrom biotools:metabuli .

