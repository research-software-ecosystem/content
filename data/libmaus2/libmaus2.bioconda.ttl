    schema1:identifier biotools:libmaus ;
    schema1:license "GPL-3.0-or-later" ;
    schema1:name "libmaus2" ;
    schema1:softwareVersion "2.0.813" ;
    schema1:url "https://gitlab.com/german.tischler/libmaus2" ;
    spdx:builtFrom biotools:libmaus .

