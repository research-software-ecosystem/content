@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-km.ci a schema1:SoftwareApplication ;
    schema1:description "Computes various confidence intervals for the Kaplan-Meier estimator, namely Petos CI, Rothman CI, CI's based on Greenwoods variance, Thomas and Grunkemeier CI and the simultaneous confidence bands by Nair and Hall and Wellner." ;
    schema1:license "GPL-2|GPL-3" ;
    schema1:name "r-km.ci" ;
    schema1:url "https://cran.rstudio.com/web/packages/km.ci/index.html" .

