@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:tombo a schema1:SoftwareApplication ;
    schema1:description "Tombo is a suite of tools primarily for the identification of modified nucleotides from raw nanopore sequencing data." ;
    schema1:keywords "Genetics",
        "Sequence Alignment" ;
    schema1:license "MPL-2.0" ;
    schema1:name "tombo" ;
    schema1:url "https://github.com/nanoporetech/tombo" .

