@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:cytoscape a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1101/gr.1239303" ;
    schema1:description "Cytoscape: an open source platform for network analysis and visualization." ;
    schema1:downloadUrl "https://github.com/cytoscape/cytoscape/releases/download/3.10.4/Cytoscape_3_10_4_unix.sh" ;
    schema1:identifier biotools:cytoscape ;
    schema1:license "LGPL" ;
    schema1:name "cytoscape" ;
    schema1:softwareVersion "3.10.4" ;
    schema1:url "https://cytoscape.org" ;
    spdx:builtFrom biotools:cytoscape .

