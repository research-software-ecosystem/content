@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:super-focus a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btv584" ;
    schema1:description "Super-focus: a tool for agile functional analysis of shotgun metagenomic data" ;
    schema1:identifier biotools:super-focus ;
    schema1:keywords "Coral Reefs",
        "DNA",
        "Metagenome",
        "Metagenomics",
        "Sequence Homology, Nucleic Acid",
        "Sequence analysis" ;
    schema1:license "Not available" ;
    schema1:name "super-focus" ;
    schema1:url "https://edwards.sdsu.edu/SUPERFOCUS" .

