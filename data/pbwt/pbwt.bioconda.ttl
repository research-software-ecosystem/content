@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:pbwt a schema1:SoftwareApplication ;
    schema1:description "Positional Burrows-Wheeler Transform -  methods for storing and computing on genome variation data sets" ;
    schema1:downloadUrl "https://github.com/richarddurbin/pbwt/archive/64c4ffa7880db5f85b53ccbd7e530ec4b95ea4ba.zip" ;
    schema1:identifier biotools:pbwt ;
    schema1:license "Apache-2.0" ;
    schema1:name "pbwt" ;
    schema1:softwareVersion "3.0" ;
    schema1:url "https://github.com/richarddurbin/pbwt" ;
    spdx:builtFrom biotools:pbwt .

