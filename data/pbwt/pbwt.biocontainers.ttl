@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:pbwt a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1101/2020.01.14.906487" ;
    schema1:description "Positional Burrows-Wheeler Transform -  methods for storing and computing on genome variation data sets" ;
    schema1:identifier biotools:pbwt ;
    schema1:keywords "Data management",
        "Genetic variation",
        "Genomics" ;
    schema1:license "Apache-2.0" ;
    schema1:name "pbwt" ;
    schema1:url "https://github.com/richarddurbin/pbwt" .

