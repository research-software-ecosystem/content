@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-methtargetedngs a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Perform Methylation Analysis on Next Generation Sequencing Data" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/MethTargetedNGS_1.38.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/MethTargetedNGS/MethTargetedNGS_1.38.0.tar.gz', 'https://bioarchive.galaxyproject.org/MethTargetedNGS_1.38.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-methtargetedngs/bioconductor-methtargetedngs_1.38.0_src_all.tar.gz']" ;
    schema1:identifier biotools:methtargetedngs ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-methtargetedngs" ;
    schema1:softwareVersion "1.38.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/MethTargetedNGS.html" ;
    spdx:builtFrom biotools:methtargetedngs .

