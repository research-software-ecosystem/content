@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-methtargetedngs a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Perform Methylation Analysis on Next Generation Sequencing Data" ;
    schema1:identifier biotools:methtargetedngs ;
    schema1:keywords "Computational Biology",
        "Epigenetics",
        "Gene Expression Profiling",
        "Genetics",
        "Genomics",
        "High-Throughput Screening Assays",
        "Programming Languages",
        "Sequencing",
        "User-Computer Interface" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-methtargetedngs" ;
    schema1:url "http://bioconductor.org/packages/release/bioc/html/MethTargetedNGS.html" .

