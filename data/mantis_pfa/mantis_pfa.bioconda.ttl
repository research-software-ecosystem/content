@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:mantis_pfa a schema1:SoftwareApplication ;
    schema1:author "PedroMTQ" ;
    schema1:citation "doi:10.1093/gigascience/giab042" ;
    schema1:description "Consensus-driven protein function annotation tool" ;
    schema1:downloadUrl "https://github.com/PedroMTQ/Mantis/archive/refs/tags/1.5.5.tar.gz" ;
    schema1:identifier biotools:mantis_pfa ;
    schema1:license "MIT" ;
    schema1:maintainer "PedroMTQ" ;
    schema1:name "mantis_pfa" ;
    schema1:softwareVersion "1.5.5" ;
    schema1:url "https://github.com/PedroMTQ/Mantis" ;
    spdx:builtFrom biotools:mantis_pfa .

