@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-npgsea a schema1:SoftwareApplication ;
    schema1:description "Permutation approximation methods for gene set enrichment analysis (non-permutation GSEA)" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/npGSEA_1.42.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/npGSEA/npGSEA_1.42.0.tar.gz', 'https://bioarchive.galaxyproject.org/npGSEA_1.42.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-npgsea/bioconductor-npgsea_1.42.0_src_all.tar.gz']" ;
    schema1:identifier biotools:npgsea ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-npgsea" ;
    schema1:softwareVersion "1.42.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/npGSEA.html" ;
    spdx:builtFrom biotools:npgsea .

