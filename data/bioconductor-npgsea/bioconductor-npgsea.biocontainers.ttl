@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-npgsea a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s12859-015-0571-7" ;
    schema1:description "Permutation approximation methods for gene set enrichment analysis (non-permutation GSEA)" ;
    schema1:identifier biotools:npgsea ;
    schema1:keywords "Biomarkers",
        "Data Interpretation, Statistical",
        "Gene Expression Profiling",
        "Gene expression",
        "Genomics",
        "Humans",
        "Models, Statistical",
        "Parkinson Disease",
        "Statistics and probability" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-npgsea" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/npGSEA.html" .

