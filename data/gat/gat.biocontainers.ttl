@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:gat a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btt343" ;
    schema1:description "Genomic Association Tester" ;
    schema1:identifier biotools:gat ;
    schema1:keywords "Binding Sites",
        "Chromatin Immunoprecipitation",
        "Computer Simulation",
        "Deoxyribonuclease I",
        "Genomics",
        "Sequence Analysis, DNA",
        "Sequence sites, features and motifs",
        "Transcription Factors" ;
    schema1:license "MIT" ;
    schema1:name "gat" ;
    schema1:url "https://github.com/AndreasHeger/gat" .

