@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:gat a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btt343" ;
    schema1:description "Genomic Association Tester" ;
    schema1:downloadUrl "https://pypi.io/packages/source/g/gat/gat-1.3.6.tar.gz" ;
    schema1:identifier biotools:gat ;
    schema1:license "MIT" ;
    schema1:name "gat" ;
    schema1:softwareVersion "1.3.6" ;
    schema1:url "https://github.com/AndreasHeger/gat" ;
    spdx:builtFrom biotools:gat .

