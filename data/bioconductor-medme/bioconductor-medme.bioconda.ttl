@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-medme a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1101/gr.080721.108" ;
    schema1:description "Modelling Experimental Data from MeDIP Enrichment" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/MEDME_1.66.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/MEDME/MEDME_1.66.0.tar.gz', 'https://bioarchive.galaxyproject.org/MEDME_1.66.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-medme/bioconductor-medme_1.66.0_src_all.tar.gz']" ;
    schema1:identifier biotools:medme ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-medme" ;
    schema1:softwareVersion "1.66.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/MEDME.html" ;
    spdx:builtFrom biotools:medme .

