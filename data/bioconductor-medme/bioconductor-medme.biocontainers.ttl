    schema1:description "Modelling Experimental Data from MeDIP Enrichment" ;
    schema1:identifier biotools:medme ;
    schema1:keywords "CpG Islands",
        "DNA",
        "DNA Methylation",
        "DNA, Neoplasm",
        "Epigenesis, Genetic",
        "Epigenetics",
        "Genome, Human",
        "Humans",
        "Immunoprecipitation",
        "Immunoprecipitation experiment",
        "Infant, Newborn",
        "Melanocytes",
        "Methylated DNA immunoprecipitation",
        "Oligonucleotide Array Sequence Analysis",
        "Sequence Analysis, DNA" ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-medme" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/MEDME.html" .

