@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:famli a schema1:SoftwareApplication ;
    schema1:description "Functional analysis of metagenomes by likelihood inference" ;
    schema1:keywords "Genomics",
        "Metagenome",
        "Metagenomics",
        "Peptides",
        "Protein Sequences" ;
    schema1:license "MIT" ;
    schema1:name "famli" ;
    schema1:url "https://github.com/FredHutch/FAMLI" .

