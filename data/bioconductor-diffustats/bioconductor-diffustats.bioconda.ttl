@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-diffustats a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btx632" ;
    schema1:description "Diffusion scores on biological networks" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/diffuStats_1.26.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/diffuStats/diffuStats_1.26.0.tar.gz', 'https://bioarchive.galaxyproject.org/diffuStats_1.26.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-diffustats/bioconductor-diffustats_1.26.0_src_all.tar.gz']" ;
    schema1:identifier biotools:diffuStats ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-diffustats" ;
    schema1:softwareVersion "1.26.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/diffuStats.html" ;
    spdx:builtFrom biotools:diffuStats .

