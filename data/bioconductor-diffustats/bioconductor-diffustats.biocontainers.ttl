@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-diffustats a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btx632" ;
    schema1:description "Diffusion scores on biological networks" ;
    schema1:identifier biotools:diffuStats ;
    schema1:keywords "Computational Biology",
        "Computational biology",
        "Gene Expression",
        "Metabolic Networks and Pathways",
        "Metabolomics",
        "Omics",
        "Protein Interaction Maps",
        "Yeasts" ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-diffustats" ;
    schema1:url "http://bioconductor.org/packages/3.6/bioc/html/diffuStats.html" .

