@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:tpmcalculator a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/bty896" ;
    schema1:description "This program calculates the tpm (transcript per millions) values for the exons and introns from ngs rna-seq aligned reads (bam files)" ;
    schema1:keywords "Exons",
        "Genomics",
        "RNA, Messenger",
        "RNA-Seq",
        "Sequence Analysis, RNA" ;
    schema1:license "Custom License" ;
    schema1:name "tpmcalculator" ;
    schema1:url "https://github.com/ncbi/TPMCalculator" .

