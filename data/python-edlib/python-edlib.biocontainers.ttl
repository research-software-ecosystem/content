@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:python-edlib a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btw753" ;
    schema1:description "Lightweight, super fast C/C++ (& Python) library for sequence alignment using edit (Levenshtein) distance." ;
    schema1:keywords "Sequence Alignment",
        "Sequence Analysis, DNA" ;
    schema1:license "MIT" ;
    schema1:name "python-edlib" ;
    schema1:url "https://github.com/Martinsos/edlib" .

