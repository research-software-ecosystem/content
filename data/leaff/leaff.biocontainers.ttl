@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:leaff a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btr285" ;
    schema1:description "Biological sequence library utilities and applications" ;
    schema1:keywords "Animals",
        "Base Sequence",
        "Biological Evolution",
        "DNA, Complementary",
        "Genome",
        "Humans",
        "RNA Splicing",
        "Sequence Alignment",
        "Vertebrates" ;
    schema1:license "GPL-2+" ;
    schema1:name "leaff" ;
    schema1:url "http://kmer.sourceforge.net" .

