@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:curesim a schema1:SoftwareApplication ;
    schema1:description "Curesim (customized read simulator) is a customized tool which generates synthetic new-generation sequencing reads, supporting read simulation for major letter-base sequencing platforms.." ;
    schema1:keywords "Genetics",
        "Genomics",
        "Metagenomics" ;
    schema1:license "Not available" ;
    schema1:name "curesim" ;
    schema1:url "http://www.pegase-biosciences.com/curesim-a-customized-read-simulator/" .

