@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:pbhoover a schema1:SoftwareApplication ;
    schema1:description "Variant caller for legacy and low coverage pacific biosciences' long-read sequencing data" ;
    schema1:license "Not available" ;
    schema1:name "pbhoover" ;
    schema1:url "https://gitlab.com/LPCDRP/pbhoover" .

