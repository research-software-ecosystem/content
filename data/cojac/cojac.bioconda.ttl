    schema1:identifier biotools:cojac ;
    schema1:license "GNU General Public License v3 or later (GPLv3+)" ;
    schema1:maintainer "DrYak" ;
    schema1:name "cojac" ;
    schema1:softwareVersion "0.9.3" ;
    schema1:url "https://github.com/cbg-ethz/cojac" ;
    spdx:builtFrom biotools:cojac .

