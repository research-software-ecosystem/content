@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:cojac a schema1:SoftwareApplication ;
    schema1:author "DrYak" ;
    schema1:citation "doi:10.1038/s41564-022-01185-x" ;
    schema1:description "Command-line tools to analyse co-occurrence of mutations on amplicons." ;
