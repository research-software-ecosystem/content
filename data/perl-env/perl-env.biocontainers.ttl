@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:perl-env a schema1:SoftwareApplication ;
    schema1:description "Perl module that imports environment variables as scalars or arrays" ;
    schema1:license "perl_5" ;
    schema1:name "perl-env" ;
    schema1:url "http://search.cpan.org/dist/Env" .

