@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:meta-sparse a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1007/978-3-319-89929-9_15",
        "doi:10.1101/215707" ;
    schema1:description "SPARSE indexes reference genomes in public databases into hierarchical clusters and uses it to predict origins of metagenomic reads." ;
    schema1:license "GPL-3.0" ;
    schema1:name "meta-sparse" ;
    schema1:url "https://github.com/zheminzhou/SPARSE/" .

