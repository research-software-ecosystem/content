@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:catch a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/s41587-018-0006-x",
        "doi:10.1371/journal.pone.0028272" ;
    schema1:description "A package for designing compact and comprehensive capture probe sets." ;
    schema1:identifier biotools:catch ;
    schema1:keywords "Animals",
        "ChIP-on-chip",
        "ChIP-seq",
        "Computational Biology",
        "Culicidae",
        "Disease Outbreaks",
        "Gene Library",
        "Genetic Variation",
        "Genome, Viral",
        "Genomics",
        "High-Throughput Nucleotide Sequencing",
        "Humans",
        "Lassa Fever",
        "Metagenome",
        "Metagenomics",
        "Nigeria",
        "Oligonucleotide Probes",
        "Oligonucleotides",
        "Sequence Analysis, DNA",
        "Virus Diseases" ;
    schema1:license "BSL" ;
    schema1:name "catch" ;
    schema1:url "https://github.com/broadinstitute/catch" .

