@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:cutesv a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1101/780700" ;
    schema1:description "Cutesv is a long-read based human genomic structural variation detection tool" ;
    schema1:keywords "Clustering",
        "Genetics" ;
    schema1:license "MIT" ;
    schema1:name "cutesv" ;
    schema1:url "https://github.com/tjiangHIT/cuteSV" .

