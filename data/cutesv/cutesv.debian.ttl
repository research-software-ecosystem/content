@prefix debianmed: <https://salsa.debian.org/med-team/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

debianmed:cutesv a schema1:SoftwareApplication ;
    schema1:citation "doi:https://doi.org/10.1186/s13059-020-02107-y" ;
    schema1:description "comprehensive discovery of structural variations of genomic sequences" ;
    schema1:identifier "bio.tools:cutesv",
        "conda:bioconda:cutesv" ;
    schema1:license "unknown" ;
    schema1:name "cutesv" ;
    schema1:softwareVersion "2.1.1" ;
    schema1:url "https://github.com/tjiangHIT/cuteSV" ;
    spdx:builtFrom "cutesv" .

