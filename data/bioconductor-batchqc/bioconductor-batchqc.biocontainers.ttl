@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-batchqc a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btw538" ;
    schema1:description "Batch Effects Quality Control Software" ;
    schema1:identifier biotools:batchqc ;
    schema1:keywords "Computational Biology",
        "Data quality management",
        "Genome",
        "Genomics",
        "Humans",
        "Microarray experiment",
        "Sequencing",
        "User-Computer Interface" ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-batchqc" ;
    schema1:url "http://bioconductor.org/packages/3.6/bioc/html/BatchQC.html" .

