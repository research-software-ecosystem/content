@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-batchqc a schema1:SoftwareApplication ;
    schema1:description "Batch Effects Quality Control Software" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/BatchQC_2.6.1.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/BatchQC/BatchQC_2.6.1.tar.gz', 'https://bioarchive.galaxyproject.org/BatchQC_2.6.1.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-batchqc/bioconductor-batchqc_2.6.1_src_all.tar.gz']" ;
    schema1:identifier biotools:batchqc ;
    schema1:license "MIT + file LICENSE" ;
    schema1:name "bioconductor-batchqc" ;
    schema1:softwareVersion "2.6.1" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/BatchQC.html" ;
    spdx:builtFrom biotools:batchqc .

