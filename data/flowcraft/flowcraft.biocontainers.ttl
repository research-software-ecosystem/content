@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:flowcraft a schema1:SoftwareApplication ;
    schema1:description "A Nextflow pipeline assembler for genomics. Pick your modules. Assemble them. Run the pipeline." ;
    schema1:keywords "Genomics" ;
    schema1:license "GPL-3.0" ;
    schema1:name "flowcraft" ;
    schema1:url "https://github.com/assemblerflow/flowcraft" .

