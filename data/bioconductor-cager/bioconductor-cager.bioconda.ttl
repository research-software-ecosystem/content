@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-cager a schema1:SoftwareApplication ;
    schema1:description "Analysis of CAGE (Cap Analysis of Gene Expression) sequencing data for precise mapping of transcription start sites and promoterome mining" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/CAGEr_2.12.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/CAGEr/CAGEr_2.12.0.tar.gz', 'https://bioarchive.galaxyproject.org/CAGEr_2.12.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-cager/bioconductor-cager_2.12.0_src_all.tar.gz']" ;
    schema1:identifier biotools:cager ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-cager" ;
    schema1:softwareVersion "2.12.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/CAGEr.html" ;
    spdx:builtFrom biotools:cager .

