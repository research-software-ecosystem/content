@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-cager a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/gkv054" ;
    schema1:description "Analysis of CAGE (Cap Analysis of Gene Expression) sequencing data for precise mapping of transcription start sites and promoterome mining" ;
    schema1:identifier biotools:cager ;
    schema1:keywords "Animals",
        "Clustering",
        "Data Mining",
        "Gene Expression",
        "Gene Expression Profiling",
        "Gene expression",
        "Genomics",
        "Humans",
        "Male",
        "Mice",
        "Promoter Regions, Genetic",
        "Sequencing",
        "Testis",
        "Transcription Initiation Site",
        "Transcription factors and regulatory sites" ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-cager" ;
    schema1:url "https://www.bioconductor.org/packages/release/bioc/html/CAGEr.html" .

