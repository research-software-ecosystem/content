@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:rop a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s13059-018-1403-7" ;
    schema1:description "The Read Origin Protocol (ROP) is a computational protocol that aims to discover the source of all reads, including those originating from repeat sequences, recombinant B and T cell receptors, and microbial communities." ;
    schema1:identifier biotools:rop ;
    schema1:keywords "Adult",
        "Asthma",
        "Bacteria",
        "Cell Line",
        "Functional, regulatory and non-coding RNA",
        "Gene Expression Profiling",
        "Genes, Immunoglobulin",
        "Genes, T-Cell Receptor",
        "High-Throughput Nucleotide Sequencing",
        "Humans",
        "Mapping",
        "RNA-Seq",
        "RNA-seq",
        "Sequence Analysis, RNA" ;
    schema1:license "GPL-3.0" ;
    schema1:name "rop" ;
    schema1:url "https://github.com/smangul1/rop" .

