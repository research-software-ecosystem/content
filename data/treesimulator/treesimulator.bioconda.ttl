@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:treesimulator a schema1:SoftwareApplication ;
    schema1:author "annazhukova" ;
    schema1:citation "doi:10.1101/2024.09.09.24313296" ;
    schema1:description "Simulation of rooted phylogenetic trees under a given Multitype Birth–Death (MTBD) model." ;
    schema1:downloadUrl "https://pypi.org/packages/source/t/treesimulator/treesimulator-0.2.27.tar.gz" ;
    schema1:identifier biotools:treesimulator ;
    schema1:license "GPL-3.0-only" ;
    schema1:maintainer "annazhukova" ;
    schema1:name "treesimulator" ;
    schema1:softwareHelp "https://github.com/evolbioinfo/treesimulator/blob/0.2.27/README.md" ;
    schema1:softwareVersion "0.2.27" ;
    schema1:url "https://github.com/evolbioinfo/treesimulator" ;
    spdx:builtFrom biotools:treesimulator .

