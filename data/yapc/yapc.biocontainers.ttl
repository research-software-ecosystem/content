@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:yapc a schema1:SoftwareApplication ;
    schema1:citation "doi:10.7554/eLife.37344" ;
    schema1:description "Yapc is a (yet another) peak caller for genomic high-throughput sequencing data" ;
    schema1:keywords "Aging",
        "Animals",
        "Caenorhabditis elegans",
        "Chromatin",
        "DNA",
        "Enhancer Elements, Genetic",
        "Gene Expression Regulation, Developmental",
        "Histone Code",
        "Histones",
        "Molecular Sequence Annotation",
        "Promoter Regions, Genetic",
        "Reproducibility of Results",
        "Transcription Factors",
        "Transcription Initiation Site" ;
    schema1:license "GPL-3.0" ;
    schema1:name "yapc" ;
    schema1:url "https://github.com/jurgjn/yapc" .

