@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:avro-cwl a schema1:SoftwareApplication ;
    schema1:description "Avro is a serialization and rpc framework. this package is a fork of regular avro made by the cwl team in order to fix some issues (https://github.com/common-workflow-language/cwltool/issues/524)" ;
    schema1:license "Apache-2.0" ;
    schema1:name "avro-cwl" ;
    schema1:url "https://pypi.python.org/pypi?:action=display&name=avro-cwl" .

