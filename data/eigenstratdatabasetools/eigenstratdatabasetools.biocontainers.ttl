@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:eigenstratdatabasetools a schema1:SoftwareApplication ;
    schema1:description "A set of tools to compare and manipulate the contents of eingenstrat databases, and to calculate snp coverage statistics in such databases." ;
    schema1:license "Not available" ;
    schema1:name "eigenstratdatabasetools" ;
    schema1:url "https://github.com/TCLamnidis/EigenStratDatabaseTools" .

