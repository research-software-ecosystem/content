@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-tvtb a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "The vcf tool box (tvtb) is a suite of s4 classes and methods for filtering, summarizing and visualizing genetic variation data stored in vcf files. functionalities are integrated and demonstrated in a programming free shiny web-application, the shiny variant explorer (tsve)." ;
    schema1:identifier biotools:tvtb ;
    schema1:keywords "Computational Biology",
        "Data architecture, analysis and design",
        "Data visualisation",
        "Gene Expression Profiling",
        "Genetic variation",
        "Genetics",
        "Genomics",
        "High-Throughput Screening Assays",
        "Programming Languages",
        "User-Computer Interface" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-tvtb" ;
    schema1:url "http://bioconductor.org/packages/release/bioc/html/TVTB.html" .

