@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-flowclean a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1002/cyto.a.22837" ;
    schema1:description "A quality control tool for flow cytometry data based on compositional data analysis." ;
    schema1:identifier biotools:flowclean ;
    schema1:keywords "Cell Tracking",
        "Cell biology",
        "Datasets as Topic",
        "Flow Cytometry",
        "Fluorescence",
        "Humans",
        "Quality Control" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-flowclean" ;
    schema1:url "http://bioconductor.org/packages/release/bioc/html/flowClean.html" .

