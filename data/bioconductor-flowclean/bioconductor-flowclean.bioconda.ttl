@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-flowclean a schema1:SoftwareApplication ;
    schema1:description "flowClean" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/flowClean_1.48.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/flowClean/flowClean_1.48.0.tar.gz', 'https://bioarchive.galaxyproject.org/flowClean_1.48.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-flowclean/bioconductor-flowclean_1.48.0_src_all.tar.gz']" ;
    schema1:identifier biotools:flowclean ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-flowclean" ;
    schema1:softwareVersion "1.48.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/flowClean.html" ;
    spdx:builtFrom biotools:flowclean .

