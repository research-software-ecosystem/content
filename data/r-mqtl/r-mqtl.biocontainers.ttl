@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-mqtl a schema1:SoftwareApplication ;
    schema1:description "mQTL provides a complete QTL analysis pipeline for metabolomic data.  Distinctive features include normalisation using PQN approach, peak alignment   using RSPA approach, dimensionality reduction using SRV approach and finally  QTL mapping using R/qtl package." ;
    schema1:license "GPL" ;
    schema1:name "r-mqtl" ;
    schema1:url "https://CRAN.R-project.org/package=mQTL" .

