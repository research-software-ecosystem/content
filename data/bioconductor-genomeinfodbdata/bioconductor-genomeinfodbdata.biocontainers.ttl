@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-genomeinfodbdata a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18129/b9.bioc.genomeinfodbdata" ;
    schema1:description "Species and taxonomy ID look up tables used by GenomeInfoDb" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-genomeinfodbdata" ;
    schema1:url "http://bioconductor.org/packages/release/data/annotation/html/GenomeInfoDbData.html" .

