  "@graph": [
    {
      "@id": "https://bio.tools/bioconductor-scdotplot",
      "@type": "sc:SoftwareApplication",
      "dcterms:conformsTo": "https://bioschemas.org/profiles/ComputationalTool/0.6-DRAFT",
      "sc:additionalType": [
        "Command-line tool",
        "Library"
      ],
      "sc:author": [
        "Benjamin I Laufer",
        "Brad A Friedman"
      ],
      "sc:citation": {
        "@id": "https://doi.org/10.18129/B9.bioc.scDotPlot"
      },
      "sc:description": "Dot plots of single-cell RNA-seq data allow for an examination of the relationships between cell groupings (e.g. clusters) and marker gene expression. The scDotPlot package offers a unified approach to perform a hierarchical clustering analysis and add annotations to the columns and/or rows of a scRNA-seq dot plot. It works with SingleCellExperiment and Seurat objects as well as data frames.",
      "sc:license": "Artistic-2.0",
      "sc:name": "scDotPlot",
      "sc:operatingSystem": [
        "Mac",
        "Linux",
        "Windows"
      ],
      "sc:softwareHelp": {
        "@id": "https://bioconductor.org/packages/scDotPlot"
      },
      "sc:softwareVersion": "1.4.0",
      "sc:url": "https://bioconductor.org/packages/scDotPlot"
    },
    {
      "@id": "https://doi.org/10.18129/B9.bioc.scDotPlot",
      "@type": "sc:CreativeWork"
