@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:epa-ng a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/sysbio/syy054" ;
    schema1:description "Massively parallel phylogenetic placement of genetic sequences" ;
    schema1:keywords "Classification",
        "Genetics",
        "Phylogenetics",
        "Phylogeny",
        "Sequence Analysis, DNA" ;
    schema1:license "AGPL-3" ;
    schema1:name "epa-ng" ;
    schema1:url "https://github.com/Pbdas/epa-ng" .

