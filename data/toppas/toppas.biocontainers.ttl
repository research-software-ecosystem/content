@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:toppas a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3959" ;
    schema1:description "A graphical workflow editor for the analysis of high-throughput proteomics data" ;
    schema1:keywords "Mass spectrometry",
        "Metabolomics",
        "Proteomics" ;
    schema1:license "BSD-2-Clause" ;
    schema1:name "toppas" ;
    schema1:url "http://open-ms.sourceforge.net/workflow-integration/toppasworkflows/" .

