@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:vcf2maf a schema1:SoftwareApplication ;
    schema1:citation "doi:10.5281/zenodo.593251" ;
    schema1:description "Convert a vcf into a maf where each variant is annotated to only one of all possible gene isoforms" ;
    schema1:license "Apache-2.0" ;
    schema1:name "vcf2maf" ;
    schema1:url "https://github.com/mskcc/vcf2maf" .

