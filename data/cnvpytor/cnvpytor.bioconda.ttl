@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:cnvpytor a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/gigascience/giab074" ;
    schema1:description "Python extension of CNVnator." ;
    schema1:downloadUrl "https://pypi.io/packages/source/c/cnvpytor/CNVpytor-1.3.2.tar.gz" ;
    schema1:identifier biotools:cnvpytor ;
    schema1:license "MIT" ;
    schema1:name "cnvpytor" ;
    schema1:softwareHelp "https://abyzovlab.github.io/CNVpytor" ;
    schema1:softwareVersion "1.3.2" ;
    schema1:url "https://github.com/abyzovlab/CNVpytor" ;
    spdx:builtFrom biotools:cnvpytor .

