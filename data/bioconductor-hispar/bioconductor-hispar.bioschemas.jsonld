  "@graph": [
    {
      "@id": "https://bio.tools/bioconductor-hispar",
      "@type": "sc:SoftwareApplication",
      "dcterms:conformsTo": "https://bioschemas.org/profiles/ComputationalTool/0.6-DRAFT",
      "sc:additionalType": [
        "Command-line tool",
        "Library"
      ],
      "sc:author": "Yingcheng Luo",
      "sc:citation": {
        "@id": "https://doi.org/10.18129/B9.bioc.HiSpaR"
      },
      "sc:description": "Provides R bindings for HiSpa, a hierarchical Bayesian model for inferring three-dimensional chromatin structures from Hi-C contact matrices using Markov Chain Monte Carlo (MCMC) sampling. The package implements a cluster-based hierarchical approach that efficiently handles large-scale Hi-C datasets. It uses Rcpp and RcppArmadillo for efficient C++ integration with the original HiSpa C++ implementation, enabling fast computation of chromatin structure inference through parallel MCMC sampling.",
      "sc:license": "MIT",
      "sc:name": "HiSpaR",
      "sc:operatingSystem": [
        "Linux",
        "Mac",
        "Windows"
      ],
      "sc:softwareHelp": {
        "@id": "https://bioconductor.org/packages/HiSpaR"
      },
      "sc:softwareVersion": "1.0.0",
      "sc:url": "https://bioconductor.org/packages/HiSpaR"
    },
