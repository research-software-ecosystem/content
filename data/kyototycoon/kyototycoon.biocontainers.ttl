@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:kyototycoon a schema1:SoftwareApplication ;
    schema1:description "a lightweight network server on top of the Kyoto Cabinet key-value database, built for high-performance and concurrency" ;
    schema1:license "GPL-3.0" ;
    schema1:name "kyototycoon" ;
    schema1:url "https://github.com/alticelabs/kyoto" .

