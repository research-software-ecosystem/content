@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-biomartr a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/gkl842",
        "doi:10.1093/nar/gks1195",
        "doi:10.1186/1471-2164-10-22" ;
    schema1:description "Perform large scale genomic data retrieval and functional annotation retrieval. This package aims to provide users with a standardized way to automate genome, proteome, 'RNA', coding sequence ('CDS'), 'GFF', and metagenome retrieval from 'NCBI RefSeq', 'NCBI Genbank', 'ENSEMBL', 'ENSEMBLGENOMES', and 'UniProt' databases." ;
    schema1:keywords "Base Sequence",
        "Databases, Nucleic Acid",
        "Genomics",
        "High-Throughput Nucleotide Sequencing",
        "Internet",
        "Metagenome",
        "Metagenomics",
        "Molecular Sequence Annotation",
        "Ortholog",
        "Sequence Analysis, DNA" ;
    schema1:license "GPL-2" ;
    schema1:name "r-biomartr" ;
    schema1:url "https://github.com/ropensci/biomartr" .

