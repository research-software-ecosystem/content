@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:astalavista a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1101/gr.121947.111" ;
    schema1:description "Alternative splicing trascriptional landscape visualization tool retrieves all alternative splicing events from generic transcript annotations." ;
    schema1:identifier biotools:astalavista ;
    schema1:keywords "African Continental Ancestry Group",
        "Alternative Splicing",
        "Cell Line",
        "Computational Biology",
        "European Continental Ancestry Group",
        "Gene Expression Profiling",
        "Gene Expression Regulation",
        "Genetic Variation",
        "Humans",
        "Nucleic acid structure analysis" ;
    schema1:license "BSD-3-Clause" ;
    schema1:name "astalavista" ;
    schema1:url "http://sammeth.net/confluence/display/ASTA/Home" .

