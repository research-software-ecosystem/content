@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-clusterseq a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18129/b9.bioc.clusterseq" ;
    schema1:description "Clustering of high-throughput sequencing data by identifying co-expression patterns" ;
    schema1:keywords "Clustering" ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-clusterseq" ;
    schema1:url "https://bioconductor.org/packages/3.8/bioc/html/clusterSeq.html" .

