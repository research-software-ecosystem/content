    schema1:downloadUrl "['https://bioconductor.org/packages/3.18/bioc/src/contrib/exomeCopy_1.48.0.tar.gz', 'https://bioconductor.org/packages/3.18/bioc/src/contrib/Archive/exomeCopy/exomeCopy_1.48.0.tar.gz', 'https://bioarchive.galaxyproject.org/exomeCopy_1.48.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-exomecopy/bioconductor-exomecopy_1.48.0_src_all.tar.gz']" ;
    schema1:identifier biotools:exomecopy ;
    schema1:license "GPL-3.0-or-later" ;
    schema1:name "bioconductor-exomecopy" ;
    schema1:softwareVersion "1.48.0" ;
    schema1:url "https://bioconductor.org/packages/3.18/bioc/html/exomeCopy.html" ;
    spdx:builtFrom biotools:exomecopy .

