@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:mirdeep2 a schema1:SoftwareApplication ;
    schema1:description "A completely overhauled tool which discovers microrna genes by analyzing sequenced rnas" ;
    schema1:keywords "Functional genomics",
        "Gene Expression",
        "Genetics",
        "Genomics",
        "Peptides",
        "RNA-Seq",
        "Transcription Factors",
        "Transcriptome",
        "Transcriptomics" ;
    schema1:license "Not available" ;
    schema1:name "mirdeep2" ;
    schema1:url "https://www.mdc-berlin.de/8551903/en/research/research_teams/systems_biology_of_gene_regulatory_elements/projects/miRDeep" .

