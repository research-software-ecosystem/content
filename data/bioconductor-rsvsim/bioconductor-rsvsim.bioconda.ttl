@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-rsvsim a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btt198" ;
    schema1:description "RSVSim: an R/Bioconductor package for the simulation of structural variations" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/RSVSim_1.50.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/RSVSim/RSVSim_1.50.0.tar.gz', 'https://bioarchive.galaxyproject.org/RSVSim_1.50.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-rsvsim/bioconductor-rsvsim_1.50.0_src_all.tar.gz']" ;
    schema1:identifier biotools:rsvsim ;
    schema1:license "LGPL-3" ;
    schema1:name "bioconductor-rsvsim" ;
    schema1:softwareVersion "1.50.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/RSVSim.html" ;
    spdx:builtFrom biotools:rsvsim .

