@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-rsvsim a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btt198" ;
    schema1:description "RSVSim: an R/Bioconductor package for the simulation of structural variations" ;
    schema1:identifier biotools:rsvsim ;
    schema1:keywords "Chromosome Breakpoints",
        "Computer Simulation",
        "DNA structural variation",
        "Genome",
        "Genomic Structural Variation",
        "Genomics" ;
    schema1:license "LGPL-3" ;
    schema1:name "bioconductor-rsvsim" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/RSVSim.html" .

