@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:pindel a schema1:SoftwareApplication ;
    schema1:description "Pindel can detect breakpoints of large deletions, medium sized insertions, inversions, tandem duplications and other structural variants at single-based resolution from next-gen sequence data" ;
    schema1:downloadUrl "https://github.com/genome/pindel/archive/b706fba.tar.gz" ;
    schema1:identifier biotools:pindel ;
    schema1:license "GPLv3" ;
    schema1:name "pindel" ;
    schema1:softwareVersion "0.2.5b9" ;
    schema1:url "http://gmt.genome.wustl.edu/packages/pindel/index.html" ;
    spdx:builtFrom biotools:pindel .

