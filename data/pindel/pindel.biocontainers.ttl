@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:pindel a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btp394" ;
    schema1:description "Pindel can detect breakpoints of large deletions, medium sized insertions, inversions, tandem duplications and other structural variants at single-based resolution from next-gen sequence data" ;
    schema1:identifier biotools:pindel ;
    schema1:keywords "Chromosome Breakpoints",
        "Computational Biology",
        "DNA Breaks",
        "DNA structural variation",
        "Genome",
        "INDEL Mutation",
        "Rare diseases",
        "Sequence Analysis, DNA" ;
    schema1:license "GPL-3.0" ;
    schema1:name "pindel" ;
    schema1:url "https://github.com/genome/pindel" .

