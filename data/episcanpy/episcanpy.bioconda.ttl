@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:episcanpy a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/s41467-021-25131-3" ;
    schema1:description "Epigenomics Single-Cell Analysis in Python." ;
    schema1:downloadUrl "https://pypi.io/packages/source/e/episcanpy/episcanpy-0.4.0.tar.gz" ;
    schema1:identifier biotools:epiScanpy ;
    schema1:license "BSD-3-Clause" ;
    schema1:name "episcanpy" ;
    schema1:softwareVersion "0.4.0" ;
    schema1:url "https://github.com/colomemaria/epiScanpy" ;
    spdx:builtFrom biotools:epiScanpy .

