@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:kalign2 a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/1471-2105-6-298" ;
    schema1:description "Kalign is a fast and accurate multiple sequence alignment algorithm designed to align large numbers of protein sequences." ;
    schema1:keywords "Databases, Nucleic Acid",
        "Databases, Protein",
        "Genome",
        "Genomics",
        "Reproducibility of Results",
        "Sequence Alignment",
        "Sequence Analysis, DNA",
        "Sequence Analysis, Protein" ;
    schema1:license "GPL-2.0" ;
    schema1:name "kalign2" ;
    schema1:url "http://msa.sbc.su.se/cgi-bin/msa.cgi" .

