@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:poppunk a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1101/gr.241455.118" ;
    schema1:description "PopPUNK (POPulation Partitioning Using Nucleotide Kmers)" ;
    schema1:downloadUrl "https://github.com/bacpop/poppunk/archive/v2.7.8.tar.gz" ;
    schema1:identifier biotools:poppunk ;
    schema1:license "Apache-2.0" ;
    schema1:name "poppunk" ;
    schema1:softwareHelp "https://poppunk.bacpop.org/index.html" ;
    schema1:softwareVersion "2.7.8" ;
    schema1:url "https://poppunk.bacpop.org" ;
    spdx:builtFrom biotools:poppunk .

