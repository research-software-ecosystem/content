@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-isomirs a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btv632" ;
    schema1:description "Analyze isomiRs and miRNAs from small RNA-seq" ;
    schema1:identifier biotools:isomirs ;
    schema1:keywords "Amygdala",
        "Clustering",
        "Functional, regulatory and non-coding RNA",
        "Gene expression",
        "High-Throughput Nucleotide Sequencing",
        "Humans",
        "MicroRNAs",
        "Parkinson Disease",
        "RNA",
        "RNA-Seq",
        "Sequence Analysis, RNA" ;
    schema1:license "MIT" ;
    schema1:name "bioconductor-isomirs" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/isomiRs.html" .

