@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-isomirs a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btv632" ;
    schema1:description "Analyze isomiRs and miRNAs from small RNA-seq" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/isomiRs_1.38.1.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/isomiRs/isomiRs_1.38.1.tar.gz', 'https://bioarchive.galaxyproject.org/isomiRs_1.38.1.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-isomirs/bioconductor-isomirs_1.38.1_src_all.tar.gz']" ;
    schema1:identifier biotools:isomirs ;
    schema1:license "MIT + file LICENSE" ;
    schema1:name "bioconductor-isomirs" ;
    schema1:softwareVersion "1.38.1" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/isomiRs.html" ;
    spdx:builtFrom biotools:isomirs .

