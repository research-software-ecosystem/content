@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:pirs a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/bts187" ;
    schema1:description "Profile based illumina pair-end reads simulator" ;
    schema1:keywords "Computer Simulation",
        "Genomics",
        "High-Throughput Nucleotide Sequencing",
        "Human Genome Project",
        "Humans",
        "Markov Chains",
        "Sequence Analysis, DNA" ;
    schema1:license "GPL-2+" ;
    schema1:name "pirs" ;
    schema1:url "https://github.com/galaxy001/pirs" .

