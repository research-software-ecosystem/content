@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-simat a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s12859-015-0681-2" ;
    schema1:description "GC-SIM-MS data processing and alaysis tool" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/SIMAT_1.42.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/SIMAT/SIMAT_1.42.0.tar.gz', 'https://bioarchive.galaxyproject.org/SIMAT_1.42.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-simat/bioconductor-simat_1.42.0_src_all.tar.gz']" ;
    schema1:identifier biotools:simat ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-simat" ;
    schema1:softwareVersion "1.42.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/SIMAT.html" ;
    spdx:builtFrom biotools:simat .

