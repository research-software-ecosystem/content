@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-osat a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/1471-2164-13-689" ;
    schema1:description "OSAT: Optimal Sample Assignment Tool" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/OSAT_1.58.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/OSAT/OSAT_1.58.0.tar.gz', 'https://bioarchive.galaxyproject.org/OSAT_1.58.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-osat/bioconductor-osat_1.58.0_src_all.tar.gz']" ;
    schema1:identifier biotools:osat ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-osat" ;
    schema1:softwareVersion "1.58.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/OSAT.html" ;
    spdx:builtFrom biotools:osat .

