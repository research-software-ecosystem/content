@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-pathnet a schema1:SoftwareApplication ;
    schema1:description "An R package for pathway analysis using topological information" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/PathNet_1.50.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/PathNet/PathNet_1.50.0.tar.gz', 'https://bioarchive.galaxyproject.org/PathNet_1.50.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-pathnet/bioconductor-pathnet_1.50.0_src_all.tar.gz']" ;
    schema1:identifier biotools:pathnet ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-pathnet" ;
    schema1:softwareVersion "1.50.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/PathNet.html" ;
    spdx:builtFrom biotools:pathnet .

