@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-pathnet a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/1751-0473-7-10" ;
    schema1:description "An R package for pathway analysis using topological information" ;
    schema1:identifier biotools:pathnet ;
    schema1:keywords "Gene expression",
        "Molecular interactions, pathways and networks" ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-pathnet" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/PathNet.html" .

