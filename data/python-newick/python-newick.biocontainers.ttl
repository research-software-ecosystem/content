@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:python-newick a schema1:SoftwareApplication ;
    schema1:description "A python module to read and write the newick format" ;
    schema1:license "Apache-2.0" ;
    schema1:name "python-newick" ;
    schema1:url "https://github.com/glottobank/python-newick" .

