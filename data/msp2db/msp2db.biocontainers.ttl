@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:msp2db a schema1:SoftwareApplication ;
    schema1:description "Python package to create an SQLite database from a collection of MSP mass spectromertry spectra files. Currently works with MSP files formated as MassBank records or as MoNA records. The resulting SQLite database can be used for spectral matching with msPurity Bioconductor R package," ;
    schema1:keywords "Metabolomics",
        "Proteomics" ;
    schema1:license "GPL-3.0" ;
    schema1:name "msp2db" ;
    schema1:url "https://github.com/computational-metabolomics/msp2db" .

