@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:khmer a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1073/pnas.1121464109",
        "doi:10.12688/f1000research.6924.1",
        "doi:10.1371/journal.pone.0101271",
        "doi:10.7287/peerj.preprints.890v1" ;
    schema1:description "Khmer is a set of command-line tools for working with dna shotgun sequencing data from genomes, transcriptomes, metagenomes, and single cells. khmer can make de novo assemblies faster, and sometimes better. khmer can also identify (and fix) problems with shotgun data." ;
    schema1:identifier biotools:khmer ;
    schema1:keywords "Computational Biology",
        "Humans",
        "Nucleotides",
        "Sequence Analysis, DNA",
        "Sequence assembly" ;
    schema1:license "BSD-3-Clause" ;
    schema1:name "khmer" ;
    schema1:url "https://github.com/dib-lab/khmer" .

