@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:khmer a schema1:SoftwareApplication ;
    schema1:citation "doi:10.12688/f1000research.6924.1" ;
    schema1:description "khmer k-mer counting library." ;
    schema1:downloadUrl "https://github.com/dib-lab/khmer/archive/v3.0.0a3.tar.gz" ;
    schema1:identifier biotools:khmer ;
    schema1:license "BSD-3-License" ;
    schema1:name "khmer" ;
    schema1:softwareHelp "https://khmer.readthedocs.io" ;
    schema1:softwareVersion "3.0.0a3" ;
    schema1:url "https://github.com/dib-lab/khmer" ;
    spdx:builtFrom biotools:khmer .

