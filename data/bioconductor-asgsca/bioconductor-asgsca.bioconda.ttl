@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-asgsca a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1002/gepi.21872" ;
    schema1:description "Association Studies for multiple SNPs and multiple traits using Generalized Structured Equation Models" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/ASGSCA_1.40.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/ASGSCA/ASGSCA_1.40.0.tar.gz', 'https://bioarchive.galaxyproject.org/ASGSCA_1.40.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-asgsca/bioconductor-asgsca_1.40.0_src_all.tar.gz']" ;
    schema1:identifier biotools:asgsca ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-asgsca" ;
    schema1:softwareVersion "1.40.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/ASGSCA.html" ;
    spdx:builtFrom biotools:asgsca .

