@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:sincei a schema1:SoftwareApplication ;
    schema1:citation "doi:10.5281/zenodo.8105536" ;
    schema1:description "A user-friendly toolkit for QC, counting, clustering and plotting of single-cell (epi)genomics data." ;
    schema1:downloadUrl "https://pypi.io/packages/source/s/sincei/sincei-0.5.2.tar.gz" ;
    schema1:identifier biotools:sincei ;
    schema1:license "MIT" ;
    schema1:name "sincei" ;
    schema1:softwareVersion "0.5.2" ;
    schema1:url "https://github.com/bhardwaj-lab/sincei" ;
    spdx:builtFrom biotools:sincei .

