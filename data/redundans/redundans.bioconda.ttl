@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:redundans a schema1:SoftwareApplication ;
    schema1:author "Dfupa" ;
    schema1:description "Redundans is a pipeline that assists an assembly of heterozygous/polymorphic genomes." ;
    schema1:downloadUrl "https://github.com/Gabaldonlab/redundans/archive/refs/tags/v2.01.tar.gz" ;
    schema1:identifier biotools:redundans ;
    schema1:license "GPL-3.0-or-later" ;
    schema1:maintainer "Dfupa" ;
    schema1:name "redundans" ;
    schema1:softwareVersion "2.01" ;
    schema1:url "https://github.com/Gabaldonlab/redundans/" ;
    spdx:builtFrom biotools:redundans .

