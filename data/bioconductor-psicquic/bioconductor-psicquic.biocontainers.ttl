@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-psicquic a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.1637",
        "doi:10.1038/nmeth.3252",
        "doi:10.1093/nar/gkt392" ;
    schema1:description "Project within the hupo proteomics standard initiative (hupo-psi) that standardises programmatic access to molecular interaction databases." ;
    schema1:identifier biotools:psicquic ;
    schema1:keywords "Computational Biology",
        "Data management",
        "Gene Expression Profiling",
        "Genomics",
        "High-Throughput Screening Assays",
        "Programming Languages",
        "Proteomics",
        "User-Computer Interface" ;
    schema1:license "Apache-2.0" ;
    schema1:name "bioconductor-psicquic" ;
    schema1:url "http://bioconductor.org/packages/release/bioc/html/PSICQUIC.html" .

