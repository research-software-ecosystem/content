@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:feelnc a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/gkw1306" ;
    schema1:description "Flexible extraction of lncrna" ;
    schema1:identifier biotools:feelnc ;
    schema1:keywords "Animals",
        "Benchmarking",
        "Decision Trees",
        "Dogs",
        "Functional, regulatory and non-coding RNA",
        "Gene Expression Regulation",
        "Genome",
        "Humans",
        "Mice",
        "Molecular Sequence Annotation",
        "Open Reading Frames",
        "RNA, Long Noncoding",
        "RNA, Messenger",
        "RNA-Seq",
        "RNA-seq",
        "Sequence Analysis, RNA",
        "Transcriptome" ;
    schema1:license "GPL-3.0" ;
    schema1:name "feelnc" ;
    schema1:url "https://github.com/tderrien/FEELnc" .

