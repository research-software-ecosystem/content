@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:clusterpicker a schema1:SoftwareApplication ;
    schema1:description "The cluster picker identifies clusters in newick-formatted trees containing thousands of sequences within a few minutes." ;
    schema1:license "GPL-3.0" ;
    schema1:name "clusterpicker" ;
    schema1:url "https://github.com/emmahodcroft/cluster-picker-and-cluster-matcher" .

