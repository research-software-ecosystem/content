@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:lightassembler a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btw470" ;
    schema1:description "Lightweight assembly algorithm designed to be executed on a desktop machine. It uses a pair of cache oblivious Bloom filters, one holding a uniform sample of g-spaced sequenced k-mers and the other holding k-mers classified as likely correct, using a simple statistical test." ;
    schema1:downloadUrl "https://github.com/SaraEl-Metwally/LightAssembler/archive/v1.0.0.tar.gz" ;
    schema1:identifier biotools:LightAssembler ;
    schema1:license "GPL" ;
    schema1:name "lightassembler" ;
    schema1:softwareVersion "1.0" ;
    schema1:url "https://github.com/SaraEl-Metwally/LightAssembler" ;
    spdx:builtFrom biotools:LightAssembler .

