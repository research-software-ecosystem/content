@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:funnel a schema1:SoftwareApplication ;
    schema1:description "Funnel is a toolkit for distributed task execution via a simple, standard API" ;
    schema1:license "MIT" ;
    schema1:name "funnel" ;
    schema1:url "https://github.com/ohsu-comp-bio/funnel" .

