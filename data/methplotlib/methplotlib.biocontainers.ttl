@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:methplotlib a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1101/826107" ;
    schema1:description "Plot methylation data obtained from nanopolish" ;
    schema1:identifier biotools:methplotlib ;
    schema1:keywords "DNA",
        "Epigenetics",
        "Gene expression",
        "Gene transcripts",
        "Workflows" ;
    schema1:license "MIT" ;
    schema1:name "methplotlib" ;
    schema1:url "https://github.com/wdecoster/methplotlib" .

