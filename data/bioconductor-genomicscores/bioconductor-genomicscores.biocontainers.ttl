@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-genomicscores a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18129/b9.bioc.genomicscores" ;
    schema1:description "Infrastructure to work with genomewide position-specific scores" ;
    schema1:keywords "Genetics",
        "Genomics" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-genomicscores" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/GenomicScores.html" .

