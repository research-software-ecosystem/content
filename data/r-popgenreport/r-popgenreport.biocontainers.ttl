@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-popgenreport a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s12859-015-0679-9" ;
    schema1:description "Provides beginner friendly framework to analyse population genetic data." ;
    schema1:identifier biotools:gecko ;
    schema1:keywords "Animals",
        "Bacteria",
        "Computational Biology",
        "Datasets as Topic",
        "Drosophila",
        "Genome",
        "Humans",
        "Mammals",
        "Sequence analysis",
        "Synteny",
        "Viruses" ;
    schema1:license "GPL" ;
    schema1:name "r-popgenreport" ;
    schema1:url "https://github.com/green-striped-gecko/PopGenReport" .

