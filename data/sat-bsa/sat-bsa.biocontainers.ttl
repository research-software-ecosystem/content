@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:sat-bsa a schema1:SoftwareApplication ;
    schema1:description "Sat-bsa is a package used for applying local de novo assembly and identifying the structural variants in the assembled region" ;
    schema1:identifier biotools:sta-bsa ;
    schema1:license "GPL-3.0-or-later" ;
    schema1:name "sat-bsa" ;
    schema1:url "https://github.com/SegawaTenta/Sat-BSA" .

