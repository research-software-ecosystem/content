@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:rapclust a schema1:SoftwareApplication ;
    schema1:description "Accurate, Fast and Lightweight Clustering of de novo Transcriptomes using Fragment Equivalence Classes" ;
    schema1:keywords "Clustering",
        "RNA-Seq",
        "Transcriptome" ;
    schema1:license "BSD" ;
    schema1:name "rapclust" ;
    schema1:url "https://github.com/COMBINE-lab/RapClust" .

