@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:dotter a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1016/0378-1119(95)00714-8" ;
    schema1:description "Detailed comparison of two genomic sequences" ;
    schema1:identifier biotools:dotter ;
    schema1:keywords "Amino Acid Sequence",
        "Data Display",
        "Molecular Sequence Data",
        "Sequence Alignment",
        "Sequence Analysis",
        "Sequence Homology, Amino Acid",
        "Sequence Homology, Nucleic Acid",
        "Sequence analysis" ;
    schema1:license "GPL-3.0+" ;
    schema1:name "dotter" ;
    schema1:url "http://www.sanger.ac.uk/science/tools/seqtools" .

