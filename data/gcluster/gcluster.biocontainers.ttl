@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:gcluster a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btaa212" ;
    schema1:description "Gcluster is a simple-to-use tool for visualizing and comparing genome contexts for numerous genomes" ;
    schema1:keywords "Clustering" ;
    schema1:license "perl_5" ;
    schema1:name "gcluster" ;
    schema1:url "https://github.com/Xiangyang1984/Gcluster" .

