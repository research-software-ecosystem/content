@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:n50 a schema1:SoftwareApplication ;
    schema1:description "A script to calculate n50 from one or multiple fasta/fastq files available via bioconda" ;
    schema1:identifier biotools:n50 ;
    schema1:license "mit" ;
    schema1:name "n50" ;
    schema1:url "https://metacpan.org/release/Proch-N50" .

