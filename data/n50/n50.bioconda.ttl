@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:n50 a schema1:SoftwareApplication ;
    schema1:author "telatin" ;
    schema1:citation "doi:10.3390/bioengineering8050059" ;
    schema1:description "A command-line tool to calculate the N50 value of a set of sequences and other utilities." ;
    schema1:downloadUrl "https://github.com/quadram-institute-bioscience/n50/archive/refs/tags/v1.9.3.tar.gz" ;
    schema1:identifier biotools:n50 ;
    schema1:license "MIT" ;
    schema1:maintainer "telatin" ;
    schema1:name "n50" ;
    schema1:softwareHelp "https://github.com/quadram-institute-bioscience/n50/blob/v1.9.3/README.md" ;
    schema1:softwareVersion "1.9.3" ;
    schema1:url "https://github.com/quadram-institute-bioscience/n50" ;
    spdx:builtFrom biotools:n50 .

