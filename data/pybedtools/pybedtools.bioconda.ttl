@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:pybedtools a schema1:SoftwareApplication ;
    schema1:description "Wraps BEDTools for use in Python and adds many additional features." ;
    schema1:downloadUrl "https://files.pythonhosted.org/packages/89/93/5878b1eed2e0b6662002d069763025e4374c16ad3d18d8e10a9fefac7b16/pybedtools-0.12.0.tar.gz" ;
    schema1:identifier biotools:pybedtools ;
    schema1:license "MIT" ;
    schema1:name "pybedtools" ;
    schema1:softwareHelp "https://daler.github.io/pybedtools" ;
    schema1:softwareVersion "0.12.0" ;
    schema1:url "https://github.com/daler/pybedtools" ;
    spdx:builtFrom biotools:pybedtools .

