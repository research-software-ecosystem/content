@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:pybedtools a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btr539" ;
    schema1:description "Wraps BEDTools for use in Python and adds many additional features." ;
    schema1:identifier biotools:pybedtools ;
    schema1:keywords "Animals",
        "Computational Biology",
        "Genomics",
        "Molecular Sequence Annotation" ;
    schema1:license "GPL" ;
    schema1:name "pybedtools" ;
    schema1:url "https://github.com/daler/pybedtools" .

