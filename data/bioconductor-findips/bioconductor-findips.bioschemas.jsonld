  "@graph": [
    {
      "@id": "https://bio.tools/bioconductor-findips",
      "@type": "sc:SoftwareApplication",
      "dcterms:conformsTo": "https://bioschemas.org/profiles/ComputationalTool/0.6-DRAFT",
      "sc:additionalType": [
        "Command-line tool",
        "Library"
      ],
      "sc:author": [
        "Junyan Lu",
        "Shuo Wang"
      ],
      "sc:citation": {
        "@id": "https://doi.org/10.48550/arXiv.2303.10516"
      },
      "sc:description": "Feature rankings can be distorted by a single case in the context of high-dimensional data. The cases exerts abnormal influence on feature rankings are called influential points (IPs). The package aims at detecting IPs based on case deletion and quantifies their effects by measuring the rank changes (DOI:10.48550/arXiv.2303.10516). The package applies a novel rank comparing measure using the adaptive weights that stress the top-ranked important features and adjust the weights to ranking properties.",
      "sc:license": "GPL-3.0-only",
      "sc:name": "findIPs",
      "sc:operatingSystem": [
        "Windows",
        "Linux",
        "Mac"
      ],
      "sc:softwareHelp": {
        "@id": "https://bioconductor.org/packages/findIPs"
      },
      "sc:softwareVersion": "1.6.0",
      "sc:url": "https://bioconductor.org/packages/findIPs"
    },
    {
      "@id": "https://doi.org/10.48550/arXiv.2303.10516",
      "@type": "sc:CreativeWork"
    }
  ]
