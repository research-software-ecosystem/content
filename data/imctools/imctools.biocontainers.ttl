@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:imctools a schema1:SoftwareApplication ;
    schema1:description "An image mass cytometry (imc) file conversion tool that aims to convert imc rawfiles (.mcd, .txt) into an intermediary ome.tiff, containing all the relevant metadata. further it contains tools to generate simpler tiff files that can be directly be used as input files for e.g. cellprofiller, ilastik, fiji etc" ;
    schema1:license "Custom License" ;
    schema1:name "imctools" ;
    schema1:url "https://github.com/BodenmillerGroup/imctools" .

