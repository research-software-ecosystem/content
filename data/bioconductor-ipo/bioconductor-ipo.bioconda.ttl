@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-ipo a schema1:SoftwareApplication ;
    schema1:description "Automated Optimization of XCMS Data Processing parameters" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/IPO_1.36.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/IPO/IPO_1.36.0.tar.gz', 'https://bioarchive.galaxyproject.org/IPO_1.36.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-ipo/bioconductor-ipo_1.36.0_src_all.tar.gz']" ;
    schema1:identifier biotools:ipo ;
    schema1:license "GPL (>= 2) + file LICENSE" ;
    schema1:name "bioconductor-ipo" ;
    schema1:softwareVersion "1.36.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/IPO.html" ;
    spdx:builtFrom biotools:ipo .

