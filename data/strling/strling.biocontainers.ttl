@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:strling a schema1:SoftwareApplication ;
    schema1:description "STRling (pronounced like “sterling”) is a method to detect large STR expansions from short-read sequencing data." ;
    schema1:license "MIT" ;
    schema1:name "strling" ;
    schema1:url "https://github.com/quinlan-lab/STRling" .

