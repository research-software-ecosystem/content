@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:ushuffle a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/1471-2105-9-192" ;
    schema1:description "uShuffle---a useful tool for shuffling biological sequences while preserving the k-let counts" ;
    schema1:keywords "Computer Simulation",
        "Models, Genetic",
        "Models, Statistical",
        "Sequence Analysis" ;
    schema1:license "custom" ;
    schema1:name "ushuffle" ;
    schema1:url "http://digital.cs.usu.edu/~mjiang/ushuffle/" .

