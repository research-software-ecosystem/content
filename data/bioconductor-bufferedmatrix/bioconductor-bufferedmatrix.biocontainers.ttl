@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-bufferedmatrix a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "A matrix data storage object held in temporary files" ;
    schema1:identifier biotools:bufferedmatrix ;
    schema1:keywords "Computational Biology",
        "Data architecture, analysis and design",
        "Gene Expression Profiling",
        "Genomics",
        "High-Throughput Screening Assays",
        "Programming Languages",
        "User-Computer Interface" ;
    schema1:license "LGPL (>= 2)" ;
    schema1:name "bioconductor-bufferedmatrix" ;
    schema1:url "http://bioconductor.org/packages/3.6/bioc/html/BufferedMatrix.html" .

