@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:satrap a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1371/journal.pone.0137436" ;
    schema1:description "A SOLiD assembly translation program." ;
    schema1:downloadUrl "['https://depot.galaxyproject.org/software/satrap/satrap_0.2_src_all.tar.gz', 'http://satrap.cribi.unipd.it/download/SATRAP_v0.2.tar.gz']" ;
    schema1:identifier biotools:satrap ;
    schema1:license "file" ;
    schema1:name "satrap" ;
    schema1:softwareVersion "0.2" ;
    schema1:url "http://satrap.cribi.unipd.it/cgi-bin/satrap.pl" ;
    spdx:builtFrom biotools:satrap .

