@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:biolite a schema1:SoftwareApplication ;
    schema1:description "A lightweight bioinformatics framework with automated tracking of diagnostics and provenance." ;
    schema1:license "GPL-3.0" ;
    schema1:name "biolite" ;
    schema1:url "https://bitbucket.org/caseywdunn/biolite" .

