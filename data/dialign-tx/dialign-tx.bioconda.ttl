@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:dialign-tx a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/gkq442" ;
    schema1:description "DIALIGN-TX is a greedy and progressive approaches for segment-based multiple sequence alignment." ;
    schema1:downloadUrl "https://master.dl.sourceforge.net/project/old-software-collection/DIALIGN-TX_1.0.2.tar.gz" ;
    schema1:identifier biotools:dialign-tx ;
    schema1:license "LGPL-2.1-or-later" ;
    schema1:name "dialign-tx" ;
    schema1:softwareHelp "http://dialign-tx.gobics.de" ;
    schema1:softwareVersion "1.0.2" ;
    schema1:url "https://dialign.gobics.de" ;
    spdx:builtFrom biotools:dialign-tx .

