@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:dialign-tx a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/gkq442" ;
    schema1:description "Segment-based multiple sequence alignment" ;
    schema1:identifier biotools:dialign-tx ;
    schema1:keywords "Genetics",
        "Internet",
        "Protein Sequences",
        "Protein Structure, Secondary",
        "Protein secondary structure",
        "Protein structure analysis",
        "Sequence Alignment",
        "Sequence Analysis, Protein" ;
    schema1:license "LGPL-2.1+" ;
    schema1:name "dialign-tx" ;
    schema1:url "http://dialign-tx.gobics.de/" .

