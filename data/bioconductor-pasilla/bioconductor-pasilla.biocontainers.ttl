@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-pasilla a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18129/b9.bioc.pasilla" ;
    schema1:description "Data package with per-exon and per-gene read counts of RNA-seq samples of Pasilla knock-down by Brooks et al., Genome Research 2011." ;
    schema1:keywords "Gene Expression",
        "Ortholog",
        "RNA-Seq",
        "Transcriptome" ;
    schema1:license "LGPL" ;
    schema1:name "bioconductor-pasilla" ;
    schema1:url "https://bioconductor.org/packages/3.8/data/experiment/html/pasilla.html" .

