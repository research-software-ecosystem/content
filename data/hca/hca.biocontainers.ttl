@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:hca a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1007/s000180050082" ;
    schema1:description "Human cell atlas data storage system command line interface. this repository is a command line interface (cli) and python library (api) for interacting with the data coordination platform (dcp) of the human cell atlas (hca). currently the hca package supports interaction with the upload service and data storage service (dss) for services such as uploading, downloading, and querying data." ;
    schema1:identifier biotools:hca ;
    schema1:keywords "Amino Acid Sequence",
        "Chemical Phenomena",
        "Chemistry, Physical",
        "Humans",
        "Models, Molecular",
        "Molecular Sequence Data",
        "Molecular Structure",
        "Protein secondary structure",
        "Proteins",
        "Proteomics",
        "Sequence Analysis",
        "alpha 1-Antitrypsin" ;
    schema1:license "Apache-2.0" ;
    schema1:name "hca" ;
    schema1:url "https://github.com/HumanCellAtlas/dcp-cli" .

