@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-convert a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Convert Microarray Data Objects" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/convert_1.82.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/convert/convert_1.82.0.tar.gz', 'https://bioarchive.galaxyproject.org/convert_1.82.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-convert/bioconductor-convert_1.82.0_src_all.tar.gz']" ;
    schema1:identifier biotools:convert ;
    schema1:license "LGPL" ;
    schema1:name "bioconductor-convert" ;
    schema1:softwareVersion "1.82.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/convert.html" ;
    spdx:builtFrom biotools:convert .

