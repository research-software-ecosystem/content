@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:gbsx a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s12859-015-0514-3" ;
    schema1:description "Toolkit for experimental design and demultiplexing genotyping by sequencing experiments" ;
    schema1:keywords "DNA Restriction Enzymes",
        "Genetics",
        "Genomics",
        "Genotyping Techniques",
        "High-Throughput Nucleotide Sequencing",
        "Sequence Analysis, DNA" ;
    schema1:license "GNU General Public License v3.0" ;
    schema1:name "gbsx" ;
    schema1:url "https://github.com/GenomicsCoreLeuven/GBSX" .

