@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bolt a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1007/S13361-019-02306-3" ;
    schema1:description "A variant caller for short-read sequencing data" ;
    schema1:keywords "Databases, Protein",
        "HeLa Cells",
        "Humans",
        "Peptides",
        "Proteomics",
        "Sequence Analysis, Protein",
        "Tandem Mass Spectrometry" ;
    schema1:license "MIT" ;
    schema1:name "bolt" ;
    schema1:url "https://github.com/sakkayaphab/bolt" .

