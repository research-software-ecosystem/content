@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:tandem-genotypes a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s13059-019-1667-6" ;
    schema1:description "Find tandem repeat length changes, from \"long\" dna reads aligned to a genome" ;
    schema1:keywords "Adult",
        "Computational Biology",
        "Epilepsies, Myoclonic",
        "Genetic Predisposition to Disease",
        "High-Throughput Nucleotide Sequencing",
        "Humans",
        "Sequence Analysis, DNA",
        "Tandem Repeat Sequences",
        "Whole Genome Sequencing" ;
    schema1:license "GNU General Public License v3.0" ;
    schema1:name "tandem-genotypes" ;
    schema1:url "https://github.com/mcfrith/tandem-genotypes" .

