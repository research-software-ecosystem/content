@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:dindel a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1101/gr.112326.110" ;
    schema1:description "Determines indel calls from short-read data" ;
    schema1:identifier biotools:dindel ;
    schema1:keywords "Bayes Theorem",
        "DNA polymorphism",
        "Haplotypes",
        "INDEL Mutation",
        "Likelihood Functions",
        "Models, Genetic",
        "Sequence Analysis, DNA" ;
    schema1:license "Not available" ;
    schema1:name "dindel" ;
    schema1:url "https://sites.google.com/site/keesalbers/soft/dindel" .

