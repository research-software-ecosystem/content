@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-gmrp a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "GWAS-based Mendelian Randomization and Path Analyses" ;
    schema1:identifier biotools:gmrp ;
    schema1:keywords "Computational Biology",
        "GWAS study",
        "Gene Expression Profiling",
        "Genomics",
        "High-Throughput Screening Assays",
        "Programming Languages",
        "User-Computer Interface" ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-gmrp" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/GMRP.html" .

