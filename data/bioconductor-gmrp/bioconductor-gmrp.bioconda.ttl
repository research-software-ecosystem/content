@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-gmrp a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "GWAS-based Mendelian Randomization and Path Analyses" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/GMRP_1.38.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/GMRP/GMRP_1.38.0.tar.gz', 'https://bioarchive.galaxyproject.org/GMRP_1.38.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-gmrp/bioconductor-gmrp_1.38.0_src_all.tar.gz']" ;
    schema1:identifier biotools:gmrp ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-gmrp" ;
    schema1:softwareVersion "1.38.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/GMRP.html" ;
    spdx:builtFrom biotools:gmrp .

