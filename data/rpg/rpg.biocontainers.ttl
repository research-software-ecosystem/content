@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:rpg a schema1:SoftwareApplication ;
    schema1:description "Rpg is a software dedicated to predict proteases-induced cleavage sites on amino acid sequences." ;
    schema1:keywords "Peptides",
        "Proteomics" ;
    schema1:license "GPL-3.0-or-later" ;
    schema1:name "rpg" ;
    schema1:url "https://gitlab.pasteur.fr/nmaillet/rpg" .

