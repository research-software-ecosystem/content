@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:moreutils a schema1:SoftwareApplication ;
    schema1:description "A growing collection of the unix tools that nobody thought to write long ago when unix was young" ;
    schema1:license "GPL-2" ;
    schema1:name "moreutils" ;
    schema1:url "http://joeyh.name/code/moreutils/" .

