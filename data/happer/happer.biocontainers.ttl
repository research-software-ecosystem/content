@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:happer a schema1:SoftwareApplication ;
    schema1:description "Minimal Python library for generating haplotype sequences." ;
    schema1:license "BSD" ;
    schema1:name "happer" ;
    schema1:url "https://github.com/bioforensics/happer/" .

