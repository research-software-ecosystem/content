@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:shortreadsconnector a schema1:SoftwareApplication ;
    schema1:description "Connector-counter and Short Reads Connector-linker that compare pairs of sequences datasets and output similarity information" ;
    schema1:license "Custom" ;
    schema1:name "shortreadsconnector" ;
    schema1:url "https://gatb.inria.fr/software/discosnp/" .

