@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-diffloop a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1101/087338" ;
    schema1:description "A suite of tools for subsetting, visualizing, annotating, and statistically analyzing the results of one or more chia-pet experiments or other assays that infer chromatin loops." ;
    schema1:identifier biotools:diffloop ;
    schema1:keywords "Nucleic acid structure analysis" ;
    schema1:license "MIT" ;
    schema1:name "bioconductor-diffloop" ;
    schema1:url "http://bioconductor.org/packages/release/bioc/html/diffloop.html" .

