@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-compcoder a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18129/b9.bioc.compcoder" ;
    schema1:description "RNAseq data simulation, differential expression analysis and performance comparison of differential expression methods" ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-compcoder" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/compcodeR.html" .

