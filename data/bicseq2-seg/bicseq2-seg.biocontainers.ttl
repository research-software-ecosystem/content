@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bicseq2-seg a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/gkw491" ;
    schema1:description "BICseq2-seg is for detecting CNVs based on the normalized data given by BICseq2-norm." ;
    schema1:keywords "Base Composition",
        "Bayes Theorem",
        "Carrier Proteins",
        "Chromatin Assembly and Disassembly",
        "Colorectal Neoplasms",
        "DNA Copy Number Variations",
        "DNA-Binding Proteins",
        "Genome, Human",
        "Humans",
        "Membrane Proteins",
        "Neoplasm Proteins",
        "Nucleoplasmins",
        "Receptor, ErbB-2",
        "Sequence Analysis, DNA" ;
    schema1:license "Custom" ;
    schema1:name "bicseq2-seg" ;
    schema1:url "http://compbio.med.harvard.edu/BIC-seq/" .

