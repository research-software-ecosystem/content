      ],
      "sc:description": "Genomics 2 Notebook (g2nb) combines Jupyter Notebook functionality with bioinformatics tools like those found in Galaxy and GenePattern, providing a platform for non-programming scientists to perform genomics analyses.  It is a free, public resource offering both installation options and documentation.",
      "sc:featureList": {
        "@id": "edam:operation_3208"
      },
      "sc:name": "Genomics Notebook (g2nb)",
      "sc:url": "http://g2nb.org"
    }
