@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:lambda a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/BIOINFORMATICS/BTZ295" ;
    schema1:description "Lambda is a local aligner optimized for many query sequences and searches in protein space" ;
    schema1:keywords "Sequence Analysis, RNA",
        "Single-Cell Analysis" ;
    schema1:license "AGPLv3" ;
    schema1:name "lambda" ;
    schema1:url "http://seqan.github.io/lambda/" .

