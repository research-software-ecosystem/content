@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-omicspca a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18129/b9.bioc.omicspca" ;
    schema1:description "An R package for quantitative integration and analysis of multiple omics assays from heterogeneous samples" ;
    schema1:keywords "Clustering",
        "Genetics",
        "Genomics" ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-omicspca" ;
    schema1:url "https://bioconductor.org/packages/3.9/bioc/html/OMICsPCA.html" .

