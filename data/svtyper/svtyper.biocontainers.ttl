@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:svtyper a schema1:SoftwareApplication ;
    schema1:description "Bayesian genotyper for structural variants" ;
    schema1:keywords "Genomics",
        "Whole genome sequencing" ;
    schema1:license "MIT" ;
    schema1:name "svtyper" ;
    schema1:url "https://github.com/hall-lab/svtyper" .

