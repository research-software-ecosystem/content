@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:genmap a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btaa222" ;
    schema1:description "Fast computation of genome mappability." ;
    schema1:keywords "Genome",
        "Genomics",
        "Sequence Analysis, DNA" ;
    schema1:license "BSD" ;
    schema1:name "genmap" ;
    schema1:url "https://github.com/cpockrandt/genmap" .

