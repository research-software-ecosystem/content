@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-chipseqr a schema1:SoftwareApplication ;
    schema1:description "Identifying Protein Binding Sites in High-Throughput Sequencing Data" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/ChIPseqR_1.64.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/ChIPseqR/ChIPseqR_1.64.0.tar.gz', 'https://bioarchive.galaxyproject.org/ChIPseqR_1.64.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-chipseqr/bioconductor-chipseqr_1.64.0_src_all.tar.gz']" ;
    schema1:identifier biotools:chipseqr ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-chipseqr" ;
    schema1:softwareVersion "1.64.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/ChIPseqR.html" ;
    spdx:builtFrom biotools:chipseqr .

