@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:openpyxl a schema1:SoftwareApplication ;
    schema1:description "A python library to read/write excel 2007 xlsx/xlsm files" ;
    schema1:license "MIT" ;
    schema1:name "openpyxl" ;
    schema1:url "https://bitbucket.org/openpyxl/openpyxl" .

