@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-motifmatchr a schema1:SoftwareApplication ;
    schema1:description "Fast Motif Matching in R" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/motifmatchr_1.32.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/motifmatchr/motifmatchr_1.32.0.tar.gz', 'https://bioarchive.galaxyproject.org/motifmatchr_1.32.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-motifmatchr/bioconductor-motifmatchr_1.32.0_src_all.tar.gz']" ;
    schema1:identifier biotools:motifmatchr ;
    schema1:license "GPL-3 + file LICENSE" ;
    schema1:name "bioconductor-motifmatchr" ;
    schema1:softwareVersion "1.32.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/motifmatchr.html" ;
    spdx:builtFrom biotools:motifmatchr .

