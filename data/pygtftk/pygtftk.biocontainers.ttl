@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:pygtftk a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btz116",
        "doi:10.1093/bioinformatics/btz810" ;
    schema1:description "The gtftk suite providing facilities to manipulate genomic annotations in gtf format." ;
    schema1:keywords "Genomics",
        "RNA-Seq" ;
    schema1:license "MIT" ;
    schema1:name "pygtftk" ;
    schema1:url "http://github.com/dputhier/pygtftk" .

