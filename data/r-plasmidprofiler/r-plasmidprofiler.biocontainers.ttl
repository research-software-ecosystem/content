@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-plasmidprofiler a schema1:SoftwareApplication ;
    schema1:description "Contains functions developed to combine the results of querying a plasmid database using short-read sequence typing with the results of a blast analysis against the query results." ;
    schema1:license "Apache-2.0" ;
    schema1:name "r-plasmidprofiler" ;
    schema1:url "https://CRAN.R-project.org/package=Plasmidprofiler" .

