@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-multimed a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btt633" ;
    schema1:description "Testing multiple biological mediators simultaneously" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/MultiMed_2.32.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/MultiMed/MultiMed_2.32.0.tar.gz', 'https://bioarchive.galaxyproject.org/MultiMed_2.32.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-multimed/bioconductor-multimed_2.32.0_src_all.tar.gz']" ;
    schema1:identifier biotools:multimed ;
    schema1:license "GPL (>= 2) + file LICENSE" ;
    schema1:name "bioconductor-multimed" ;
    schema1:softwareVersion "2.32.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/MultiMed.html" ;
    spdx:builtFrom biotools:multimed .

