@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:biotradis a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btw022" ;
    schema1:description "A set of tools to analyse the output from tradis analyses" ;
    schema1:keywords "Genomics" ;
    schema1:license "GPL-3.0" ;
    schema1:name "biotradis" ;
    schema1:url "https://github.com/sanger-pathogens/Bio-Tradis" .

