biocontainers:cath-tools a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1016/0022-2836(89)90084-3" ;
    schema1:description "Protein structure comparison tools such as SSAP, as used by the Orengo Group in curating CATH." ;
    schema1:keywords "Clustering",
        "Protein Structure" ;
