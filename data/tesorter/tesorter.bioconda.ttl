@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:tesorter a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/hr/uhac017" ;
    schema1:description "Lineage-level classification of transposable elements using conserved protein domains." ;
    schema1:downloadUrl "https://github.com/zhangrengang/TEsorter/archive/refs/tags/v1.5.1.tar.gz" ;
    schema1:identifier biotools:TEsorter ;
    schema1:license "GPL-3.0-or-later" ;
    schema1:name "tesorter" ;
    schema1:softwareHelp "https://github.com/zhangrengang/TEsorter/blob/v1.5.1/README.md" ;
    schema1:softwareVersion "1.5.1" ;
    schema1:url "https://github.com/zhangrengang/TEsorter" ;
    spdx:builtFrom biotools:TEsorter .

