@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-carnival a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18129/b9.bioc.carnival" ;
    schema1:description "A causal reasoning tool for network identification (from gene expression data) using integer value programming" ;
    schema1:keywords "Gene Expression",
        "Transcriptomics" ;
