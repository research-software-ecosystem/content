@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:nanosim a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/gigascience/gix010" ;
    schema1:description "NanoSim is a fast and scalable read simulator that captures the technology-specific features of ONT data, and allows for adjustments upon improvement of nanopore sequencing technology." ;
    schema1:identifier biotools:nanosim ;
    schema1:keywords "Computational Biology",
        "Genomics",
        "High-Throughput Nucleotide Sequencing",
        "Metagenome",
        "RNA-Seq",
        "Sequence Analysis, DNA",
        "Sequencing",
        "Simulation experiment",
        "Statistics and probability",
        "Transcriptome" ;
    schema1:license "GPL" ;
    schema1:name "nanosim" ;
    schema1:url "https://github.com/bcgsc/NanoSim" .

