@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:orientagraph a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1101/2021.02.02.429467" ;
    schema1:description "OrientAGraph enables Maximum Likelihood Network Orientation (MNLO), as a standalone routine or as a search heuristic within TreeMix, a popular package for estimating admixture graphs from f-statistics (or related quantities)." ;
    schema1:downloadUrl "https://github.com/sriramlab/OrientAGraph/archive/0f81b2604993285a56fbf83384481274f7c89883.zip" ;
    schema1:identifier biotools:orientagraph ;
    schema1:license "GPL3" ;
    schema1:name "orientagraph" ;
    schema1:softwareVersion "1.1" ;
    schema1:url "https://github.com/sriramlab/OrientAGraph" ;
    spdx:builtFrom biotools:orientagraph .

