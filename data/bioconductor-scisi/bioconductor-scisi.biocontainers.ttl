@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-scisi a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "In Silico Interactome" ;
    schema1:identifier biotools:scisi ;
    schema1:keywords "Computational Biology",
        "Gene Expression Profiling",
        "Genomics",
        "High-Throughput Screening Assays",
        "Molecular interactions, pathways and networks",
        "Programming Languages",
        "Proteomics",
        "User-Computer Interface" ;
    schema1:license "LGPL" ;
    schema1:name "bioconductor-scisi" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/ScISI.html" .

