@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-m3d a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btu749" ;
    schema1:description "Identifies differentially methylated regions across testing groups" ;
    schema1:identifier biotools:m3d ;
    schema1:keywords "Animals",
        "Computer Simulation",
        "DNA Methylation",
        "Embryonic Stem Cells",
        "Epigenetics",
        "Epigenomics",
        "Gene expression",
        "Humans",
        "Mice",
        "Models, Statistical",
        "Nucleic acid structure analysis" ;
    schema1:license "Artistic License 2.0" ;
    schema1:name "bioconductor-m3d" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/M3D.html" .

