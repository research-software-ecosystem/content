@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:tetyper a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1099/mgen.0.000232" ;
    schema1:description "Typing of a specific transposable element (te) of interest from paired-end sequencing data." ;
    schema1:keywords "Computational Biology",
        "DNA Transposable Elements",
        "Female",
        "Humans",
        "Klebsiella Infections",
        "Klebsiella pneumoniae",
        "Male",
        "Whole Genome Sequencing" ;
    schema1:license "GPL-3.0" ;
    schema1:name "tetyper" ;
    schema1:url "https://github.com/aesheppard/TETyper" .

