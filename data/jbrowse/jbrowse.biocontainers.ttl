@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:jbrowse a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1101/gr.094607.109" ;
    schema1:description "Slick, speedy genome browser with a responsive and dynamic ajax interface for visualization of genome data. being developed by the gmod project as a successor to gbrowse." ;
    schema1:identifier biotools:jbrowse ;
    schema1:keywords "Animals",
        "Computational Biology",
        "Database Management Systems",
        "Databases, Genetic",
        "Drosophila melanogaster",
        "Genome",
        "Genome, Insect",
        "Genomics",
        "Internet",
        "Software Design",
        "User-Computer Interface" ;
    schema1:license "LGPL-3.0-only" ;
    schema1:name "jbrowse" ;
    schema1:url "https://github.com/GMOD/jbrowse" .

