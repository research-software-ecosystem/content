@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:jbrowse a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1101/gr.094607.109" ;
    schema1:description "The JBrowse Genome Browser" ;
    schema1:downloadUrl "https://github.com/GMOD/jbrowse/archive/1.16.11-release.zip" ;
    schema1:identifier biotools:jbrowse ;
    schema1:license "LGPL" ;
    schema1:name "jbrowse" ;
    schema1:softwareVersion "1.16.11" ;
    schema1:url "https://jbrowse.org/" ;
    spdx:builtFrom biotools:jbrowse .

