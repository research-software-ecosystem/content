@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:qhull a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1.1.117.405" ;
    schema1:description "Qhull computes the convex hull, Delaunay triangulation, Voronoi diagram, halfspace intersection about a point, furthest-site Delaunay triangulation, and furthest-site Voronoi diagram." ;
    schema1:license "Custom License" ;
    schema1:name "qhull" ;
    schema1:url "https://github.com/qhull/qhull" .

