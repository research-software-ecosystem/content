@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-consensusde a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18129/b9.bioc.consensusde" ;
    schema1:description "RNA-seq analysis using multiple algorithms" ;
    schema1:keywords "Clustering",
        "RNA-Seq",
        "Transcriptomics" ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-consensusde" ;
    schema1:url "https://bioconductor.org/packages/3.8/bioc/html/consensusDE.html" .

