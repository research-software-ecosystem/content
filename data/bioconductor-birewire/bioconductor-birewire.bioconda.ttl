@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-birewire a schema1:SoftwareApplication ;
    schema1:description "High-performing routines for the randomization of a bipartite graph (or a binary event matrix), undirected and directed signed graph preserving degree distribution (or marginal totals)" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/BiRewire_3.41.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/BiRewire/BiRewire_3.41.0.tar.gz', 'https://bioarchive.galaxyproject.org/BiRewire_3.41.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-birewire/bioconductor-birewire_3.41.0_src_all.tar.gz']" ;
    schema1:identifier biotools:birewire ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-birewire" ;
    schema1:softwareVersion "3.41.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/BiRewire.html" ;
    spdx:builtFrom biotools:birewire .

