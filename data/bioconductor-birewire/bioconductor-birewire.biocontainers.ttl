@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-birewire a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btu474" ;
    schema1:description "High-performing routines for the randomization of a bipartite graph (or a binary event matrix), undirected and directed signed graph preserving degree distribution (or marginal totals)" ;
    schema1:identifier biotools:birewire ;
    schema1:keywords "Genomics",
        "Humans",
        "Markov Chains",
        "Molecular interactions, pathways and networks",
        "Monte Carlo Method",
        "Neoplasms",
        "Random Allocation" ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-birewire" ;
    schema1:url "http://bioconductor.org/packages/3.6/bioc/html/BiRewire.html" .

