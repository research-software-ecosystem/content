@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-sgseq a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1371/journal.pone.0156132" ;
    schema1:description "Package for analyzing splice events from rna-seq data. input data are sequence reads mapped to a reference genome in bam format. genes are represented as a genome-wide splice graph, which can be obtained from existing annotation or can be predicted from the data. splice events are identified from the graph and are quantified locally using structurally compatible reads at the start or end of each splice variant." ;
    schema1:identifier biotools:sgseq ;
    schema1:keywords "Alternative Splicing",
        "Computational Biology",
        "Exons",
        "Humans",
        "RNA",
        "RNA Splicing",
        "RNA splicing",
        "RNA-Seq",
        "RNA-seq",
        "Sequence Analysis, RNA" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-sgseq" ;
    schema1:url "http://bioconductor.org/packages/release/bioc/html/SGSeq.html" .

