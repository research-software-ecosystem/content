@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-sgseq a schema1:SoftwareApplication ;
    schema1:description "Splice event prediction and quantification from RNA-seq data" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/SGSeq_1.40.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/SGSeq/SGSeq_1.40.0.tar.gz', 'https://bioarchive.galaxyproject.org/SGSeq_1.40.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-sgseq/bioconductor-sgseq_1.40.0_src_all.tar.gz']" ;
    schema1:identifier biotools:sgseq ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-sgseq" ;
    schema1:softwareVersion "1.40.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/SGSeq.html" ;
    spdx:builtFrom biotools:sgseq .

