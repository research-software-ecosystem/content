@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:popscle a schema1:SoftwareApplication ;
    schema1:description "A suite of population scale analysis tools for single-cell genomics data including implementation of Demuxlet / Freemuxlet methods and auxilary tools" ;
    schema1:keywords "Clustering",
        "Genomics",
        "RNA-Seq" ;
    schema1:license "MIT" ;
    schema1:name "popscle" ;
    schema1:url "https://github.com/statgen/popscle" .

