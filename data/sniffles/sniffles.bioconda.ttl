@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:sniffles a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/s41587-023-02024-y",
        "doi:10.1038/s41592-018-0001-7" ;
    schema1:description "Sniffles is a structural variation caller using third generation sequencing (PacBio or Oxford Nanopore)." ;
    schema1:downloadUrl "https://pypi.org/packages/source/s/sniffles/sniffles-2.7.5.tar.gz" ;
    schema1:identifier biotools:sniffles ;
    schema1:license "MIT" ;
    schema1:name "sniffles" ;
    schema1:softwareHelp "https://github.com/fritzsedlazeck/Sniffles/wiki" ;
    schema1:softwareVersion "2.7.5" ;
    schema1:url "https://github.com/fritzsedlazeck/Sniffles" ;
    spdx:builtFrom biotools:sniffles .

