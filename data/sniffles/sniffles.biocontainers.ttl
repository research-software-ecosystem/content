@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:sniffles a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/s41592-018-0001-7" ;
    schema1:description "An algorithm for structural variation detection from third generation sequencing alignment." ;
    schema1:identifier biotools:sniffles ;
    schema1:keywords "DNA Mutational Analysis",
        "DNA structural variation",
        "Genome, Human",
        "Genomics",
        "High-Throughput Nucleotide Sequencing",
        "Humans",
        "Sequence Analysis, DNA",
        "Sequencing" ;
    schema1:license "MIT" ;
    schema1:name "sniffles" ;
    schema1:url "https://github.com/fritzsedlazeck/Sniffles" .

