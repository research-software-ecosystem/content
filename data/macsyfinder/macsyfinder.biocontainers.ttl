@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:macsyfinder a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1371/journal.pone.0110726" ;
    schema1:description "Program to model and detect macromolecular systems, genetic pathways... in protein datasets. in prokaryotes, these systems have often evolutionarily conserved properties: they are made of conserved components, and are encoded in compact loci (conserved genetic architecture). the user models these systems to reflect these conserved features, and to allow their efficient detection." ;
    schema1:identifier biotools:macsyfinder ;
    schema1:keywords "CRISPR-Cas Systems",
        "Data Mining",
        "Functional genomics",
        "Genome, Human",
        "Genomics",
        "Humans" ;
    schema1:license "GPL-3.0" ;
    schema1:name "macsyfinder" ;
    schema1:url "https://github.com/gem-pasteur/macsyfinder" .

