@prefix debianmed: <https://salsa.debian.org/med-team/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

debianmed:macsyfinder a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1371/journal.pone.0110726" ;
    schema1:description "detection of macromolecular systems in protein datasets" ;
    schema1:identifier "bio.tools:macsyfinder",
        "omictools:OMICS_20116" ;
    schema1:license "unknown" ;
    schema1:name "macsyfinder" ;
    schema1:softwareVersion "2.1.6" ;
    schema1:url "https://github.com/gem-pasteur/macsyfinder" ;
    spdx:builtFrom "macsyfinder" .

