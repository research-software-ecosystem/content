@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:macsyfinder a schema1:SoftwareApplication ;
    schema1:author "bneron" ;
    schema1:citation "doi:10.24072/pcjournal.250" ;
    schema1:description "MacSyFinder: Detection of macromolecular systems in protein datasets using systems modelling and similarity search" ;
    schema1:downloadUrl "https://pypi.io/packages/source/m/macsyfinder/macsyfinder-2.1.6.tar.gz" ;
    schema1:identifier biotools:macsyfinder ;
    schema1:license "GPL-3.0-or-later" ;
    schema1:maintainer "bneron" ;
    schema1:name "macsyfinder" ;
    schema1:softwareHelp "https://macsyfinder.readthedocs.io/en/latest" ;
    schema1:softwareVersion "2.1.6" ;
    schema1:url "https://github.com/gem-pasteur/macsyfinder" ;
    spdx:builtFrom biotools:macsyfinder .

