@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-ncrnatools a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18129/b9.bioc.ncrnatools" ;
    schema1:description "ncRNAtools provides a set of basic tools for handling and analyzing non-coding RNAs. These include tools to access the RNAcentral database and to predict and visualize the secondary structure of non-coding RNAs. The package also provides tools to read, write and interconvert the file formats most commonly used for representing such secondary structures." ;
    schema1:keywords "Genomics" ;
    schema1:license "GPL-3.0" ;
    schema1:name "bioconductor-ncrnatools" ;
    schema1:url "https://bioconductor.org/packages/3.12/bioc/html/ncRNAtools.html" .

