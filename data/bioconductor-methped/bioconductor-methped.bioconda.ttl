@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-methped a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s13148-015-0103-3" ;
    schema1:description "A DNA methylation classifier tool for the identification of pediatric brain tumor subtypes" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/MethPed_1.34.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/MethPed/MethPed_1.34.0.tar.gz', 'https://bioarchive.galaxyproject.org/MethPed_1.34.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-methped/bioconductor-methped_1.34.0_src_all.tar.gz']" ;
    schema1:identifier biotools:methped ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-methped" ;
    schema1:softwareVersion "1.34.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/MethPed.html" ;
    spdx:builtFrom biotools:methped .

