@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-methped a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s13148-015-0103-3" ;
    schema1:description "A DNA methylation classifier tool for the identification of pediatric brain tumor subtypes" ;
    schema1:identifier biotools:methped ;
    schema1:keywords "Cell biology",
        "Epigenetics",
        "Genetics",
        "Oncology" ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-methped" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/MethPed.html" .

