@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:python-biopython a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btp163" ;
    schema1:description "The Biopython Project is an international association of developers of freely available Python tools for computational molecular biology." ;
    schema1:identifier biotools:biopython ;
    schema1:keywords "Bioinformatics",
        "Computational Biology",
        "Computational biology",
        "Data management",
        "Databases, Factual",
        "Genetics",
        "Genomics",
        "Internet",
        "Phylogenetics",
        "Programming Languages",
        "Software engineering" ;
    schema1:license "Custom License" ;
    schema1:name "python-biopython" ;
    schema1:url "https://github.com/biopython/biopython/" .

