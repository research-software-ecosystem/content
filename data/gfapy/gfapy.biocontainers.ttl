@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:gfapy a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btx398" ;
    schema1:description "Flexible and extensible software library for handling sequence graphs in python." ;
    schema1:identifier biotools:gfapy ;
    schema1:keywords "Computer Graphics",
        "Data visualisation",
        "Genetic variation",
        "Programming Languages",
        "Sequence Analysis",
        "Sequence analysis",
        "Sequence assembly",
        "Sequencing" ;
    schema1:license "BSD" ;
    schema1:name "gfapy" ;
    schema1:url "https://github.com/ggonnella/gfapy" .

