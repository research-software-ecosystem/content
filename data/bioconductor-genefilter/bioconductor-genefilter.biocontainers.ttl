@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-genefilter a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Methods for filtering genes from microarray experiments" ;
    schema1:identifier biotools:genefilter ;
    schema1:keywords "Computational Biology",
        "Gene Expression Profiling",
        "Genomics",
        "High-Throughput Screening Assays",
        "Molecular genetics",
        "Programming Languages",
        "Proteomics",
        "Transcriptome",
        "User-Computer Interface" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-genefilter" ;
    schema1:url "https://bioconductor.org/packages/genefilter/" .

