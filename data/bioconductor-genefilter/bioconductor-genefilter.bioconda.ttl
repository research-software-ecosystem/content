@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-genefilter a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "genefilter: methods for filtering genes from high-throughput experiments" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/genefilter_1.88.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/genefilter/genefilter_1.88.0.tar.gz', 'https://bioarchive.galaxyproject.org/genefilter_1.88.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-genefilter/bioconductor-genefilter_1.88.0_src_all.tar.gz']" ;
    schema1:identifier biotools:genefilter ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-genefilter" ;
    schema1:softwareVersion "1.88.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/genefilter.html" ;
    spdx:builtFrom biotools:genefilter .

