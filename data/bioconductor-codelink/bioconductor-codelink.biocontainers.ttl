@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-codelink a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btm072" ;
    schema1:description "Manipulation of Codelink microarray data" ;
    schema1:identifier biotools:codelink ;
    schema1:keywords "Computer Graphics",
        "Data Interpretation, Statistical",
        "Gene Expression Profiling",
        "Microarray experiment",
        "Oligonucleotide Array Sequence Analysis",
        "Programming Languages",
        "User-Computer Interface" ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-codelink" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/codelink.html" .

