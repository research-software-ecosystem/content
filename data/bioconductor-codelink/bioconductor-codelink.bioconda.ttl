@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-codelink a schema1:SoftwareApplication ;
    schema1:description "Manipulation of Codelink microarray data" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/codelink_1.74.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/codelink/codelink_1.74.0.tar.gz', 'https://bioarchive.galaxyproject.org/codelink_1.74.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-codelink/bioconductor-codelink_1.74.0_src_all.tar.gz']" ;
    schema1:identifier biotools:codelink ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-codelink" ;
    schema1:softwareVersion "1.74.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/codelink.html" ;
    spdx:builtFrom biotools:codelink .

