@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:fraggenescan a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/gkq747",
        "doi:10.7490/f1000research.1114334.1" ;
    schema1:description "FragGeneScan is an application for finding (fragmented) genes in short reads. It can also be applied to predict prokaryotic genes in incomplete assemblies or complete genomes." ;
    schema1:identifier biotools:fraggenescan ;
    schema1:keywords "Codon",
        "Frameshifting, Ribosomal",
        "Genes",
        "Genetics",
        "Genomics",
        "Metagenome",
        "Metagenomics",
        "Models, Statistical",
        "Sequence Analysis, DNA",
        "Sequence analysis" ;
    schema1:license "MIT" ;
    schema1:name "fraggenescan" ;
    schema1:url "https://sourceforge.net/projects/fraggenescan/" .

