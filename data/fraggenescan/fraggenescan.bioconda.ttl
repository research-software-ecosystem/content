@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:fraggenescan a schema1:SoftwareApplication ;
    schema1:author "keuv-grvl" ;
    schema1:citation "doi:10.1093/nar/gkq747" ;
    schema1:description "FragGeneScan is an application for finding (fragmented) genes in short reads." ;
    schema1:downloadUrl "http://downloads.sourceforge.net/project/fraggenescan/FragGeneScan1.32.tar.gz" ;
    schema1:identifier biotools:fraggenescan ;
    schema1:license "BSD" ;
    schema1:maintainer "keuv-grvl" ;
    schema1:name "fraggenescan" ;
    schema1:softwareHelp "https://sourceforge.net/projects/fraggenescan" ;
    schema1:softwareVersion "1.32" ;
    schema1:url "https://sourceforge.net/projects/fraggenescan" ;
    spdx:builtFrom biotools:fraggenescan .

