@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:dedup a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s13059-016-0918-z" ;
    schema1:description "Dedup is a tool for read deduplication in paired-end read merging (e.g. for ancient dna experiments)." ;
    schema1:keywords "Chromosome Mapping",
        "Fossils",
        "Genome",
        "Sequence Analysis, DNA",
        "Workflow" ;
    schema1:license "GPL-3.0" ;
    schema1:name "dedup" ;
    schema1:url "https://github.com/apeltzer/dedup" .

