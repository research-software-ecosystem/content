@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-refplus a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btm357" ;
    schema1:description "A function set for the Extrapolation Strategy (RMA+) and Extrapolation Averaging (RMA++) methods." ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.17/bioc/src/contrib/RefPlus_1.70.0.tar.gz', 'https://bioconductor.org/packages/3.17/bioc/src/contrib/Archive/RefPlus/RefPlus_1.70.0.tar.gz', 'https://bioarchive.galaxyproject.org/RefPlus_1.70.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-refplus/bioconductor-refplus_1.70.0_src_all.tar.gz']" ;
    schema1:identifier biotools:refplus ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-refplus" ;
    schema1:softwareVersion "1.70.0" ;
    schema1:url "https://bioconductor.org/packages/3.17/bioc/html/RefPlus.html" ;
    spdx:builtFrom biotools:refplus .

