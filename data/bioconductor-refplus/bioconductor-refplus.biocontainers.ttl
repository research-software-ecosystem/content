@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-refplus a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btm357" ;
    schema1:description "A function set for the Extrapolation Strategy (RMA+) and Extrapolation Averaging (RMA++) methods." ;
    schema1:identifier biotools:refplus ;
    schema1:keywords "Data Interpretation, Statistical",
        "Gene Expression Profiling",
        "Microarray experiment",
        "Oligonucleotide Array Sequence Analysis",
        "Programming Languages" ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-refplus" ;
    schema1:url "http://bioconductor.org/packages/3.6/bioc/html/RefPlus.html" .

