@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:nanostat a schema1:SoftwareApplication ;
    schema1:description "Calculate statistics for Oxford Nanopore sequencing data and alignments" ;
    schema1:license "MIT" ;
    schema1:name "nanostat" ;
    schema1:url "https://github.com/wdecoster/nanostat" .

