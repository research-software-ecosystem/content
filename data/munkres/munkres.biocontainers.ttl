@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:munkres a schema1:SoftwareApplication ;
    schema1:description "The Munkres module provides an O(n^3) implementation of the Munkres algorithm (also called the Hungarian algorithm or the Kuhn-Munkres algorithm)." ;
    schema1:license "Apache-2.0" ;
    schema1:name "munkres" ;
    schema1:url "https://github.com/bmc/munkres" .

