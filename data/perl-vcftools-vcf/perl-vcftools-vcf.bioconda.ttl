@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:perl-vcftools-vcf a schema1:SoftwareApplication ;
    schema1:description "cpanm ready distribution of VCFtools Perl libraries." ;
    schema1:downloadUrl "https://github.com/vcftools/vcftools/releases/download/v0.1.17/vcftools-0.1.17.tar.gz" ;
    schema1:identifier biotools:vcftools ;
    schema1:license "LGPL-3.0-only" ;
    schema1:name "perl-vcftools-vcf" ;
    schema1:softwareHelp "https://vcftools.github.io" ;
    schema1:softwareVersion "0.1.17" ;
    schema1:url "https://github.com/vcftools/vcftools" ;
    spdx:builtFrom biotools:vcftools .

