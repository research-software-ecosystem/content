@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:perl-vcftools-vcf a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btr330" ;
    schema1:description "cpanm ready distribution of VCFtools Perl libraries" ;
    schema1:identifier biotools:vcftools ;
    schema1:keywords "Alleles",
        "Genetic Variation",
        "Genetic variation",
        "Genome, Human",
        "Genomics",
        "Genotype",
        "Humans",
        "Information Storage and Retrieval" ;
    schema1:license "LGPLv3" ;
    schema1:name "perl-vcftools-vcf" ;
    schema1:url "https://github.com/vcftools/vcftools" .

