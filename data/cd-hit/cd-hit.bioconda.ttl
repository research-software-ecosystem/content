@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:cd-hit a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/17.3.282",
        "doi:10.1093/bioinformatics/18.1.77" ;
    schema1:description "Clusters and compares protein or nucleotide sequences." ;
    schema1:downloadUrl "https://github.com/weizhongli/cdhit/archive/V4.8.1.tar.gz" ;
    schema1:identifier biotools:cd-hit ;
    schema1:license "GPL-2.0-or-later" ;
    schema1:name "cd-hit" ;
    schema1:softwareHelp "https://github.com/weizhongli/cdhit/wiki" ;
    schema1:softwareVersion "4.8.1" ;
    schema1:url "https://github.com/weizhongli/cdhit" ;
    spdx:builtFrom biotools:cd-hit .

