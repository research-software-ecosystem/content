@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:cd-hit a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/bts565",
        "doi:10.1093/nar/gkw343",
        "doi:10.7490/f1000research.1114334.1" ;
    schema1:description "Cluster a nucleotide dataset into representative sequences." ;
    schema1:keywords "Biomedical Research",
        "Clustering",
        "Computational Biology",
        "Databases, Genetic",
        "Datasets as Topic",
        "Humans",
        "Internet",
        "Reproducibility of Results",
        "User-Computer Interface" ;
    schema1:license "GPL-2+" ;
    schema1:name "cd-hit" ;
    schema1:url "https://github.com/weizhongli/cdhit" .

