@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:expansionhunter a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btz431" ;
    schema1:description "A tool for estimating repeat sizes" ;
    schema1:keywords "Genotype",
        "Microsatellite Repeats" ;
    schema1:license "Apache v2.0" ;
    schema1:name "expansionhunter" ;
    schema1:url "https://github.com/Illumina/ExpansionHunter" .

