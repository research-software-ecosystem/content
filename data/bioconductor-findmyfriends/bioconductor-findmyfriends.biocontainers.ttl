@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-findmyfriends a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Microbial Comparative Genomics in R" ;
    schema1:identifier biotools:findmyfriends ;
    schema1:keywords "Clustering",
        "Computational Biology",
        "Gene Expression Profiling",
        "Genomics",
        "High-Throughput Screening Assays",
        "Microbiology",
        "Programming Languages",
        "User-Computer Interface" ;
    schema1:license "GPL (>=2)" ;
    schema1:name "bioconductor-findmyfriends" ;
    schema1:url "http://bioconductor.org/packages/3.6/bioc/html/FindMyFriends.html" .

