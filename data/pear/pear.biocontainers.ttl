@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:pear a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btt593" ;
    schema1:description "paired-end read merger" ;
    schema1:identifier biotools:PEAR ;
    schema1:keywords "Genomics",
        "High-Throughput Nucleotide Sequencing",
        "Sequence Alignment",
        "Sequence Analysis, DNA",
        "Sequence assembly",
        "Staphylococcus aureus" ;
    schema1:license "Creative Commons Attribution-NonCommercial-ShareAlike 3.0 Unported" ;
    schema1:name "pear" ;
    schema1:url "http://sco.h-its.org/exelixis/web/software/pear/" .

