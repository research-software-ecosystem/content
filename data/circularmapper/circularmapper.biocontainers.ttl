@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:circularmapper a schema1:SoftwareApplication ;
    schema1:description " a method to improve mappings on circular genomes, using the bwa mapper." ;
    schema1:license "GNU General Public License v3.0" ;
    schema1:name "circularmapper" ;
    schema1:url "https://github.com/apeltzer/CircularMapper" .

