@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:polypolish a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1371/journal.pcbi.1009802" ;
    schema1:description "Polishing genome assemblies with short reads." ;
    schema1:downloadUrl "https://github.com/rrwick/Polypolish/archive/refs/tags/v0.6.1.tar.gz" ;
    schema1:identifier biotools:polypolish ;
    schema1:license "GPL-3.0-or-later" ;
    schema1:name "polypolish" ;
    schema1:softwareHelp "https://github.com/rrwick/Polypolish/wiki" ;
    schema1:softwareVersion "0.6.1" ;
    schema1:url "https://github.com/rrwick/Polypolish" ;
    spdx:builtFrom biotools:polypolish .

