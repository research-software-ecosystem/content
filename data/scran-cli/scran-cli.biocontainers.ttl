@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:scran-cli a schema1:SoftwareApplication ;
    schema1:description "A set of wrappers for individual components of the scran R package. Scran implements functions for low-level analyses of single-cell RNA-seq data.Functions R packages are hard to call when building workflows outside of R, so this package adds a set of simple wrappers with robust argument parsing." ;
    schema1:keywords "Clustering",
        "RNA-Seq" ;
    schema1:license "Apache-2.0" ;
    schema1:name "scran-cli" ;
    schema1:url "https://github.com/ebi-gene-expression-group/scran-cli" .

