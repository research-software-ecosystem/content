@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:art-nextgen-simulation-tools a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btr708" ;
    schema1:description "Simulation tools to generate synthetic next-generation sequencing reads" ;
    schema1:keywords "Gene Expression",
        "Genetics" ;
    schema1:license "GPL-3.0+" ;
    schema1:name "art-nextgen-simulation-tools" ;
    schema1:url "http://www.niehs.nih.gov/research/resources/software/biostatistics/art/" .

