@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:kmer-db a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/bty610" ;
    schema1:description "Kmer-db is a fast and memory-efficient tool for estimating evolutionary distances." ;
    schema1:keywords "Biological Evolution",
        "Computational Biology",
        "Genome" ;
    schema1:license "GPL-3" ;
    schema1:name "kmer-db" ;
    schema1:url "https://github.com/refresh-bio/kmer-db" .

