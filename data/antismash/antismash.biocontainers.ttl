@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:antismash a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/NAR/GKX319",
        "doi:10.1093/nar/gkr466",
        "doi:10.1093/nar/gkt449",
        "doi:10.1093/nar/gkv437" ;
    schema1:description "Rapid genome-wide identification, annotation and analysis of secondary metabolite biosynthesis gene clusters in bacterial and fungal genomes. it integrates and cross-links with a large number of in silico secondary metabolite analysis tools that have been published earlier." ;
    schema1:identifier biotools:antismash ;
    schema1:keywords "Anti-Bacterial Agents",
        "Biological Products",
        "Biosynthetic Pathways",
        "Codon",
        "Gene and protein families",
        "Genes",
        "Internet",
        "Molecular interactions, pathways and networks",
        "Peptide Synthases",
        "Peptides",
        "Polyketide Synthases",
        "Protein Domains",
        "Protein Processing, Post-Translational",
        "Secondary Metabolism",
        "Terpenes" ;
    schema1:license "AGPL-3.0" ;
    schema1:name "antismash" ;
    schema1:url "http://antismash.secondarymetabolites.org" .

