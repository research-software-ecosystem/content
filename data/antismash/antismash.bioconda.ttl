@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:antismash a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/gkab335",
        "doi:10.1093/nar/gkad344",
        "doi:10.1093/nar/gkr466",
        "doi:10.1093/nar/gkt449",
        "doi:10.1093/nar/gkv437",
        "doi:10.1093/nar/gkx319",
        "doi:10.1093/nar/gkz310" ;
    schema1:description "antiSMASH - the antibiotics and Secondary Metabolite Analysis SHell." ;
    schema1:downloadUrl "https://github.com/antismash/antismash/archive/refs/tags/8-0-4.tar.gz" ;
    schema1:identifier biotools:antismash ;
    schema1:license "AGPL-3.0-or-later" ;
    schema1:name "antismash" ;
    schema1:softwareHelp "https://docs.antismash.secondarymetabolites.org" ;
    schema1:softwareVersion "8.0.4" ;
    schema1:url "https://docs.antismash.secondarymetabolites.org/intro" ;
    spdx:builtFrom biotools:antismash .

