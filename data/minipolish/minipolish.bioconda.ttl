@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:minipolish a schema1:SoftwareApplication ;
    schema1:author "rrwick",
        "thanhleviet" ;
    schema1:citation "doi:10.12688/f1000research.21782.4" ;
    schema1:description "A tool for Racon polishing miniasm assemblies." ;
    schema1:downloadUrl "https://github.com/rrwick/Minipolish/archive/v0.2.1.tar.gz" ;
    schema1:identifier biotools:minipolish ;
    schema1:license "GPL-3.0-or-later" ;
    schema1:maintainer "rrwick",
        "thanhleviet" ;
    schema1:name "minipolish" ;
    schema1:softwareHelp "https://github.com/rrwick/Minipolish/blob/v0.2.1/README.md" ;
    schema1:softwareVersion "0.2.1" ;
    schema1:url "https://github.com/rrwick/Minipolish" ;
    spdx:builtFrom biotools:minipolish .

