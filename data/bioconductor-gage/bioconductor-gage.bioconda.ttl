@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-gage a schema1:SoftwareApplication ;
    schema1:description "Generally Applicable Gene-set Enrichment for Pathway Analysis" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/gage_2.60.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/gage/gage_2.60.0.tar.gz', 'https://bioarchive.galaxyproject.org/gage_2.60.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-gage/bioconductor-gage_2.60.0_src_all.tar.gz']" ;
    schema1:identifier biotools:gage ;
    schema1:license "GPL (>=2.0)" ;
    schema1:name "bioconductor-gage" ;
    schema1:softwareVersion "2.60.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/gage.html" ;
    spdx:builtFrom biotools:gage .

