@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-gage a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/1471-2105-10-161" ;
    schema1:description "Generally Applicable Gene-set Enrichment for Pathway Analysis" ;
    schema1:identifier biotools:gage ;
    schema1:keywords "Bone Morphogenetic Protein 6",
        "Computer Simulation",
        "Gene Expression Profiling",
        "Gene Regulatory Networks",
        "Genetics",
        "Humans",
        "Lung Neoplasms",
        "Models, Statistical",
        "Molecular interactions, pathways and networks",
        "Oligonucleotide Array Sequence Analysis",
        "RNA-Seq",
        "Reproducibility of Results",
        "Sensitivity and Specificity",
        "Signal Transduction" ;
    schema1:license "GPL (>=2.0)" ;
    schema1:name "bioconductor-gage" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/gage.html" .

