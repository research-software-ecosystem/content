@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:slclust a schema1:SoftwareApplication ;
    schema1:description "A utility that performs single-linkage clustering with the option of applying a jaccard similarity coefficient to break weakly bound clusters into distinct clusters." ;
    schema1:keywords "Clustering" ;
    schema1:license "Artistic License" ;
    schema1:name "slclust" ;
    schema1:url "https://sourceforge.net/projects/slclust/" .

