@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-triplex a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btt299" ;
    schema1:description "Search and visualize intramolecular triplex-forming sequences in DNA" ;
    schema1:identifier biotools:triplex ;
    schema1:keywords "Computational chemistry",
        "Computer Graphics",
        "DNA",
        "Data visualisation",
        "Genomics",
        "Molecular interactions, pathways and networks",
        "Nucleic acid structure analysis",
        "Sequence Analysis, DNA" ;
    schema1:license "BSD_2_clause" ;
    schema1:name "bioconductor-triplex" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/triplex.html" .

