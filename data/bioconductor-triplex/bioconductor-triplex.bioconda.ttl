@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-triplex a schema1:SoftwareApplication ;
    schema1:description "Search and visualize intramolecular triplex-forming sequences in DNA" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/triplex_1.46.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/triplex/triplex_1.46.0.tar.gz', 'https://bioarchive.galaxyproject.org/triplex_1.46.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-triplex/bioconductor-triplex_1.46.0_src_all.tar.gz']" ;
    schema1:identifier biotools:triplex ;
    schema1:license "BSD_2_clause + file LICENSE" ;
    schema1:name "bioconductor-triplex" ;
    schema1:softwareVersion "1.46.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/triplex.html" ;
    spdx:builtFrom biotools:triplex .

