@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:clonalframeml a schema1:SoftwareApplication ;
    schema1:description "Efficient inferencing of recombination in bacterial genomes." ;
    schema1:downloadUrl "https://github.com/xavierdidelot/ClonalFrameML/archive/refs/tags/v1.13.tar.gz" ;
    schema1:identifier biotools:clonalframeml ;
    schema1:license "GPL-3.0-or-later" ;
    schema1:name "clonalframeml" ;
    schema1:softwareHelp "https://github.com/xavierdidelot/clonalframeml/wiki" ;
    schema1:softwareVersion "1.13" ;
    schema1:url "https://github.com/xavierdidelot/ClonalFrameML" ;
    spdx:builtFrom biotools:clonalframeml .

