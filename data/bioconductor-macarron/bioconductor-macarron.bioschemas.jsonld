  "@id": "https://bio.tools/bioconductor-macarron",
  "@type": "sc:SoftwareApplication",
  "dcterms:conformsTo": "https://bioschemas.org/profiles/ComputationalTool/0.6-DRAFT",
  "sc:additionalType": [
    "Command-line tool",
    "Library"
  ],
  "sc:author": [
    "Ludwig Geistlinger",
    "Sagun Maharjan",
    "Amrisha Bhosle"
  ],
  "sc:description": "Macarron is a workflow for the prioritization of potentially bioactive metabolites from metabolomics experiments. Prioritization integrates strengths of evidences of bioactivity such as covariation with a known metabolite, abundance relative to a known metabolite and association with an environmental or phenotypic indicator of bioactivity. Broadly, the workflow consists of stratified clustering of metabolic spectral features which co-vary in abundance in a condition, transfer of functional annotations, estimation of relative abundance and differential abundance analysis to identify associations between features and phenotype/condition.",
  "sc:license": "MIT",
  "sc:name": "Macarron",
  "sc:operatingSystem": [
    "Windows",
    "Mac",
    "Linux"
  ],
  "sc:softwareHelp": {
    "@id": "https://bioconductor.org/packages/Macarron"
  },
  "sc:softwareVersion": "1.13.2",
  "sc:url": "https://bioconductor.org/packages/Macarron"
