@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-beanplot a schema1:SoftwareApplication ;
    schema1:description "Plots univariate comparison graphs, an alternative to boxplot/stripchart/violin plot." ;
    schema1:keywords "Proteomics" ;
    schema1:license "GPL-2" ;
    schema1:name "r-beanplot" ;
    schema1:url "https://CRAN.R-project.org/package=beanplot" .

