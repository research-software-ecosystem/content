@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:scg a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3867" ;
    schema1:description "Software for inference of clonal genotypes using targeted single cell nucleus sequencing." ;
    schema1:identifier biotools:scg ;
    schema1:keywords "Clone Cells",
        "Cystadenocarcinoma, Serous",
        "DNA mutation",
        "Female",
        "Genome, Human",
        "Genotype",
        "High-Throughput Nucleotide Sequencing",
        "Humans",
        "Leukemia",
        "Mammary Glands, Human",
        "Models, Statistical",
        "Oncology",
        "Ovarian Neoplasms",
        "Polymorphism, Single Nucleotide",
        "Sequence analysis",
        "Single-Cell Analysis" ;
    schema1:license "GPL-3.0" ;
    schema1:name "scg" ;
    schema1:url "https://bitbucket.org/aroth85/scg/src" .

