@prefix edam: <http://edamontology.org/> .
@prefix galaxytool: <https://github.com/galaxyproject/tools-iuc/tree/master/tools/> .
@prefix schema1: <http://schema.org/> .

galaxytool:adapter_removal a schema1:SoftwareApplication ;
    schema1:description "Removes residual adapter sequences from single-end (SE) or paired-end (PE) FASTQ reads." ;
    schema1:featureList edam:operation_0232,
        edam:operation_3192,
        edam:operation_3237 ;
    schema1:identifier "bioconda:adapterremoval",
        "biotools:adapterremoval" ;
    schema1:keywords "Fasta Manipulation",
        "Sequence Analysis" ;
    schema1:name "adapter_removal" ;
    schema1:softwareVersion "2.3.4" ;
    schema1:url "https://github.com/MikkelSchubert/adapterremoval" .

