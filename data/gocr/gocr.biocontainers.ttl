@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:gocr a schema1:SoftwareApplication ;
    schema1:description "Gocr is an ocr (optical character recognition) program." ;
    schema1:license "GPL" ;
    schema1:name "gocr" ;
    schema1:url "http://jocr.sourceforge.net/" .

