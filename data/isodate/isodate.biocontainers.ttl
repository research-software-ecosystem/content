@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:isodate a schema1:SoftwareApplication ;
    schema1:description "An iso 8601 date/time/duration parser and formatter" ;
    schema1:license "BSD" ;
    schema1:name "isodate" ;
    schema1:url "https://pypi.org/project/isodate/" .

