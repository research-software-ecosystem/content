@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-proj4 a schema1:SoftwareApplication ;
    schema1:description "A simple interface to lat/long projection and datum transformation of the PROJ.4 cartographic projections library. It allows transformation of geographic coordinates from one projection and/or datum to another." ;
    schema1:license "GPL-2" ;
    schema1:name "r-proj4" ;
    schema1:url "None" .

