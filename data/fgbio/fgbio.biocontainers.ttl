@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:fgbio a schema1:SoftwareApplication ;
    schema1:description "A set of tools for working with genomic and high throughput sequencing data, including umis" ;
    schema1:keywords "Genetics",
        "Genomics",
        "RNA-Seq" ;
    schema1:license "MIT" ;
    schema1:name "fgbio" ;
    schema1:url "https://github.com/fulcrumgenomics/fgbio" .

