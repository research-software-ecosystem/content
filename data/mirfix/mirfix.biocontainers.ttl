@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:mirfix a schema1:SoftwareApplication ;
    schema1:description "MIRfix automatically curates miRNA datasets by improving alignments of their precursors, the consistency of the annotation of mature miR and miR* sequence, and the phylogenetic coverage. MIRfix produces alignments that are comparable across families and sets the stage for improved homology search as well as quantitative analyses." ;
    schema1:identifier biotools:mirfix ;
    schema1:license "GPL-3.0" ;
    schema1:name "mirfix" ;
    schema1:url "https://github.com/Bierinformatik/MIRfix" .

