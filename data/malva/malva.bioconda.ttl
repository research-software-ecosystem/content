@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:malva a schema1:SoftwareApplication ;
    schema1:description "genotyping by Mapping-free ALternate-allele detection of known VAriants" ;
    schema1:downloadUrl "https://github.com/AlgoLab/malva/archive/v2.0.0.tar.gz" ;
    schema1:identifier biotools:malva ;
    schema1:license "GPL-3.0-or-later" ;
    schema1:name "malva" ;
    schema1:softwareVersion "2.0.0" ;
    schema1:url "https://algolab.github.io/malva/" ;
    spdx:builtFrom biotools:malva .

