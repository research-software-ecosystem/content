@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:perl-perl-osnames a schema1:SoftwareApplication ;
    schema1:description "List possible $^O ($OSNAME) values, with description" ;
    schema1:license "perl_5" ;
    schema1:name "perl-perl-osnames" ;
    schema1:url "https://metacpan.org/release/Perl-osnames" .

