@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-argparse a schema1:SoftwareApplication ;
    schema1:description "A command line parser to be used with Rscript to write \"#!\" shebang scripts that gracefully accept positional and optional arguments and automatically generate usage." ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "r-argparse" ;
    schema1:url "None" .

