@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-redseq a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18129/b9.bioc.redseq" ;
    schema1:description "Analysis of high-throughput sequencing data processed by restriction enzyme digestion" ;
    schema1:license "GPL (>=2)" ;
    schema1:name "bioconductor-redseq" ;
    schema1:url "https://bioconductor.org/packages/3.8/bioc/html/REDseq.html" .

