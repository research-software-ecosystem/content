@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-qorts a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s12859-015-0670-5" ;
    schema1:description "The QoRTs software package is a fast, efficient, and portable multifunction toolkit designed to assist in the analysis, quality control, and data management of RNA-Seq and DNA-Seq datasetsn" ;
    schema1:keywords "Gene Expression",
        "RNA-Seq" ;
    schema1:license "MIT" ;
    schema1:name "r-qorts" ;
    schema1:url "https://github.com/hartleys/QoRTs" .

