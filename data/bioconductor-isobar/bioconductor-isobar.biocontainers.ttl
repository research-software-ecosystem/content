@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-isobar a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18129/b9.bioc.isobar" ;
    schema1:description "Analysis and quantitation of isobarically tagged MSMS proteomics data" ;
    schema1:keywords "Mass spectrometry",
        "Proteomics" ;
    schema1:license "LGPL-2" ;
    schema1:name "bioconductor-isobar" ;
    schema1:url "https://bioconductor.org/packages/3.8/bioc/html/isobar.html" .

