@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:gvcfgenotyper a schema1:SoftwareApplication ;
    schema1:description "A utility for merging and genotyping Illumina-style GVCFs." ;
    schema1:license "Apache-2.0" ;
    schema1:name "gvcfgenotyper" ;
    schema1:url "https://github.com/Illumina/gvcfgenotyper" .

