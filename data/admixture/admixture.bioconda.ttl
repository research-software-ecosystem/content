@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:admixture a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1101/gr.094052.109" ;
    schema1:description "ADMIXTURE is a software tool for maximum likelihood estimation of individual ancestries from multilocus SNP genotype datasets." ;
    schema1:downloadUrl "http://www.genetics.ucla.edu/software/admixture/binaries/admixture_linux-1.3.0.tar.gz",
        "http://www.genetics.ucla.edu/software/admixture/binaries/admixture_macosx-1.3.0.tar.gz" ;
    schema1:identifier biotools:admixture ;
    schema1:license "Free for Academic Use" ;
    schema1:name "admixture" ;
    schema1:softwareVersion "1.3.0" ;
    schema1:url "http://www.genetics.ucla.edu/software/admixture/index.html" ;
    spdx:builtFrom biotools:admixture .

