@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:admixture a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1101/gr.094052.109" ;
    schema1:description "ADMIXTURE is a software tool for maximum likelihood estimation of individual ancestries from multilocus SNP genotype datasets." ;
    schema1:identifier biotools:admixture ;
    schema1:keywords "Computational Biology",
        "Europe",
        "Gene Frequency",
        "Genetic Association Studies",
        "Genetics, Population",
        "Genotype",
        "Humans",
        "Inflammatory Bowel Diseases",
        "Jews",
        "Likelihood Functions",
        "Models, Genetic",
        "Polymorphism, Single Nucleotide",
        "Population genetics",
        "Time Factors" ;
    schema1:license "Free for Academic Use" ;
    schema1:name "admixture" ;
    schema1:url "http://www.genetics.ucla.edu/software/admixture/index.html" .

