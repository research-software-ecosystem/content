@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:splitmem a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btu756" ;
    schema1:description "Graphical pan-genome analysis with suffix skips." ;
    schema1:identifier biotools:splitmem ;
    schema1:keywords "Bacillus anthracis",
        "DNA",
        "Escherichia coli",
        "Genome, Bacterial",
        "Genomics",
        "Sequence Analysis, DNA",
        "Sequencing" ;
    schema1:license "Apache License V2.0" ;
    schema1:name "splitmem" ;
    schema1:url "https://sourceforge.net/projects/splitmem/" .

