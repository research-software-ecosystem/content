@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:metaphlan a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.2066" ;
    schema1:description "MetaPhlAn is a computational tool for profiling the composition of microbial communities from metagenomic shotgun sequencing data" ;
    schema1:identifier biotools:metaphlan ;
    schema1:keywords "Bacteria",
        "Genetic Markers",
        "Genomics",
        "Humans",
        "Metagenome",
        "Metagenomics",
        "Phylogenomics",
        "Phylogeny",
        "Reproducibility of Results" ;
    schema1:license "MIT" ;
    schema1:name "metaphlan" ;
    schema1:url "https://github.com/biobakery/metaphlan" .

