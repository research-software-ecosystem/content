@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:metaphlan a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.2066" ;
    schema1:description "Metagenomic Phylogenetic Analysis." ;
    schema1:downloadUrl "https://github.com/biobakery/MetaPhlAn/archive/4.2.4.tar.gz" ;
    schema1:identifier biotools:metaphlan ;
    schema1:license "MIT" ;
    schema1:name "metaphlan" ;
    schema1:softwareHelp "https://github.com/biobakery/MetaPhlAn/wiki/MetaPhlAn-4" ;
    schema1:softwareVersion "4.2.4" ;
    schema1:url "https://github.com/biobakery/metaphlan" ;
    spdx:builtFrom biotools:metaphlan .

