@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:jaffa a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s13073-015-0167-x" ;
    schema1:description "Jaffa is a multi-step pipeline that takes either raw rna-seq reads, or pre-assembled transcripts then searches\\nfor gene fusions. this package contains the wrappers jaffa-direct, jaffa-assembly, and jaffa-hybrid. you can pass the \\\"refseq\\\" parameter in the environment variables jaffa_ref_base. otherwise, pass any paramters\\nto the wrappers as you would to the bpipe jaffa_{method} call in the manual." ;
    schema1:keywords "RNA-Seq",
        "Transcriptome" ;
    schema1:license "free software" ;
    schema1:name "jaffa" ;
    schema1:url "https://github.com/Oshlack/JAFFA" .

