@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:krakentools a schema1:SoftwareApplication ;
    schema1:description "Krakentools is a suite of scripts to be used for post-analysis of kraken/krakenuniq/kraken2/bracken results. please cite the relevant paper if using krakentools with any of the listed programs." ;
    schema1:license "Not available" ;
    schema1:name "krakentools" ;
    schema1:url "https://github.com/jenniferlu717/KrakenTools" .

