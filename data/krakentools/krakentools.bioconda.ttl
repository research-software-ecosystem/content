@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:krakentools a schema1:SoftwareApplication ;
    schema1:description "KrakenTools scripts for analysis of Kraken/KrakenUniq/Kraken2/Bracken results" ;
    schema1:downloadUrl "https://github.com/jenniferlu717/KrakenTools/archive/v1.2.1.tar.gz" ;
    schema1:identifier biotools:krakentools ;
    schema1:license "GPL-3.0" ;
    schema1:name "krakentools" ;
    schema1:softwareVersion "1.2.1" ;
    schema1:url "https://github.com/jenniferlu717/KrakenTools" ;
    spdx:builtFrom biotools:krakentools .

