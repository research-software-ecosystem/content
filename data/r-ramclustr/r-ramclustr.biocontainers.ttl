@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-ramclustr a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1021/ac501530d" ;
    schema1:description "A feature clustering algorithm for non-targeted mass spectrometric metabolomics data. This method is compatible with gas and liquid chromatography coupled mass spectrometry, including indiscriminant tandem mass spectrometry data" ;
    schema1:keywords "Animals",
        "Cerebrospinal Fluid",
        "Cluster Analysis",
        "Clustering",
        "Databases, Factual",
        "Horses",
        "Mass Spectrometry",
        "Metabolomics",
        "Signal Processing, Computer-Assisted" ;
    schema1:license "GPL-2" ;
    schema1:name "r-ramclustr" ;
    schema1:url "https://github.com/cbroeckl/RAMClustR" .

