@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:gridss a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1101/gr.222109.117",
        "doi:10.1186/s13059-021-02423-x" ;
    schema1:description "GRIDSS: The Genomic Rearrangement IDentification Software Suite." ;
    schema1:downloadUrl "https://github.com/PapenfussLab/gridss/releases/download/v2.13.2/gridss-2.13.2.tar.gz" ;
    schema1:identifier biotools:gridss ;
    schema1:license "GPL-3.0-only" ;
    schema1:name "gridss" ;
    schema1:softwareVersion "2.13.2" ;
    schema1:url "https://github.com/PapenfussLab/gridss" ;
    spdx:builtFrom biotools:gridss .

