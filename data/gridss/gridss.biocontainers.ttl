@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:gridss a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1101/110387" ;
    schema1:description "A high-speed next-gen sequencing structural variation caller. it calls variants based on alignment-guided positional de bruijn graph breakpoint assembly, split read, and read pair evidence." ;
    schema1:identifier biotools:gridss ;
    schema1:keywords "DNA structural variation",
        "Structural genomics" ;
    schema1:license "GPL-3.0" ;
    schema1:name "gridss" ;
    schema1:url "https://github.com/PapenfussLab/gridss" .

