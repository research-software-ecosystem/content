@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:jq a schema1:SoftwareApplication ;
    schema1:description "Jq is a lightweight and flexible command-line json processor." ;
    schema1:license "MIT" ;
    schema1:name "jq" ;
    schema1:url "https://github.com/stedolan/jq/" .

