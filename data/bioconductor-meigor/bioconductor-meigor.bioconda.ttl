@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-meigor a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/1471-2105-15-136" ;
    schema1:description "MEIGOR - MEtaheuristics for bIoinformatics Global Optimization" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/MEIGOR_1.44.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/MEIGOR/MEIGOR_1.44.0.tar.gz', 'https://bioarchive.galaxyproject.org/MEIGOR_1.44.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-meigor/bioconductor-meigor_1.44.0_src_all.tar.gz']" ;
    schema1:identifier biotools:meigor ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-meigor" ;
    schema1:softwareVersion "1.44.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/MEIGOR.html" ;
    spdx:builtFrom biotools:meigor .

