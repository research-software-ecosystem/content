@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:mutmap a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nbt.2095" ;
    schema1:description "Mutmap: pipeline to identify causative mutations responsible for a phenotype" ;
    schema1:identifier biotools:mutmap ;
    schema1:keywords "Chromosome Mapping",
        "Crops, Agricultural",
        "Crosses, Genetic",
        "Genome, Plant",
        "Genotype",
        "Mutation",
        "Oryza",
        "Phenotype",
        "Plant Leaves",
        "Polymorphism, Single Nucleotide",
        "Quantitative Trait Loci",
        "Sequence Analysis, DNA" ;
    schema1:license "GPL-3.0" ;
    schema1:name "mutmap" ;
    schema1:url "https://github.com/YuSugihara/MutMap" .

