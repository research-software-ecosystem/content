@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:mutmap a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nbt.2095" ;
    schema1:description "MutMap: pipeline to identify causative mutations responsible for a phenotype." ;
    schema1:downloadUrl "https://github.com/YuSugihara/MutMap/releases/download/v2.4.0/MutMap-2.4.0.tar.gz" ;
    schema1:identifier biotools:mutmap ;
    schema1:license "GPL-3.0-or-later" ;
    schema1:name "mutmap" ;
    schema1:softwareVersion "2.4.0" ;
    schema1:url "https://github.com/YuSugihara/MutMap" ;
    spdx:builtFrom biotools:mutmap .

