@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-regioner a schema1:SoftwareApplication ;
    schema1:description "Association analysis of genomic regions based on permutation tests" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/regioneR_1.42.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/regioneR/regioneR_1.42.0.tar.gz', 'https://bioarchive.galaxyproject.org/regioneR_1.42.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-regioner/bioconductor-regioner_1.42.0_src_all.tar.gz']" ;
    schema1:identifier biotools:regioner ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-regioner" ;
    schema1:softwareVersion "1.42.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/regioneR.html" ;
    spdx:builtFrom biotools:regioner .

