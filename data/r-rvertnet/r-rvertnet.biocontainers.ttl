@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-rvertnet a schema1:SoftwareApplication ;
    schema1:description "Retrieve, map and summarize data from the 'VertNet.org'. Functions allow searching by many parameters, including 'taxonomic' names, places, and dates." ;
    schema1:license "MIT" ;
    schema1:name "r-rvertnet" ;
    schema1:url "https://github.com/ropensci/rvertnet" .

