@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:finestructure a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1371/journal.pgen.1002453" ;
    schema1:description "fineSTRUCTURE is a fast and powerful algorithm for identifying population structure using dense sequencing data." ;
    schema1:downloadUrl "https://people.maths.bris.ac.uk/~madjl/finestructure/fs_4.1.1.zip" ;
    schema1:identifier biotools:fineSTRUCTURE ;
    schema1:license "OTHER" ;
    schema1:name "finestructure" ;
    schema1:softwareVersion "4.1.1" ;
    schema1:url "https://people.maths.bris.ac.uk/~madjl/finestructure/finestructure.html" ;
    spdx:builtFrom biotools:fineSTRUCTURE .

