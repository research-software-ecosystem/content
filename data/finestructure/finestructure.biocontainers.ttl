@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:finestructure a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1371/journal.pgen.1002453" ;
    schema1:description "fineSTRUCTURE is a fast and powerful algorithm for identifying population structure using dense sequencing data." ;
    schema1:identifier biotools:fineSTRUCTURE ;
    schema1:keywords "Clustering",
        "Computer Simulation",
        "Continental Population Groups",
        "Genetics",
        "Genome, Human",
        "Haplotypes",
        "Human Genome Project",
        "Humans",
        "Linkage Disequilibrium",
        "Models, Theoretical",
        "Polymorphism, Single Nucleotide",
        "Population",
        "Population genetics",
        "Principal Component Analysis",
        "Sequence analysis" ;
    schema1:license "OTHER" ;
    schema1:name "finestructure" ;
    schema1:url "https://people.maths.bris.ac.uk/~madjl/finestructure/finestructure.html" .

