@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:phigaro a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btaa250" ;
    schema1:description "Phigaro is a scalable command-line tool for predicting phages and prophages." ;
    schema1:keywords "High-Throughput Nucleotide Sequencing",
        "Metagenome",
        "Metagenomics",
        "Prophages" ;
    schema1:license "Not available" ;
    schema1:name "phigaro" ;
    schema1:url "https://phigaro.readthedocs.io/" .

