@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:emblmygff3 a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s13104-018-3686-x",
        "doi:10.5281/zenodo.2647048" ;
    schema1:description "An efficient way to convert gff3 annotation files into EMBL format ready to submit." ;
    schema1:identifier biotools:emblmygff3 ;
    schema1:keywords "Data submission, annotation and curation",
        "Databases, Nucleic Acid",
        "Europe",
        "Genome",
        "Internet",
        "Molecular Sequence Annotation",
        "Nucleotides" ;
    schema1:license "GPL-3.0" ;
    schema1:name "emblmygff3" ;
    schema1:url "https://github.com/NBISweden/EMBLmyGFF3" .

