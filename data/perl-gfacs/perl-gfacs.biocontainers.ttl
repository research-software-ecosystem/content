@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:perl-gfacs a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1016/j.gpb.2019.04.002" ;
    schema1:description "Gfacs is a filtering, analysis, and conversion tool to unify genome annotations across alignment and gene prediction frameworks." ;
    schema1:keywords "Animals",
        "Gene Conversion",
        "Genome",
        "Genomics",
        "Humans",
        "Molecular Sequence Annotation",
        "Open Reading Frames",
        "Species Specificity" ;
    schema1:license "GNU GENERAL PUBLIC LICENSE" ;
    schema1:name "perl-gfacs" ;
    schema1:url "https://gitlab.com/PlantGenomicsLab/gFACs" .

