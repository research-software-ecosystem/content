@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-keggorthology a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "graph support for KO, KEGG Orthology" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/keggorthology_2.62.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/keggorthology/keggorthology_2.62.0.tar.gz', 'https://bioarchive.galaxyproject.org/keggorthology_2.62.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-keggorthology/bioconductor-keggorthology_2.62.0_src_all.tar.gz']" ;
    schema1:identifier biotools:keggorthology ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-keggorthology" ;
    schema1:softwareVersion "2.62.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/keggorthology.html" ;
    spdx:builtFrom biotools:keggorthology .

