@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-keggorthology a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "graph support for KO, KEGG Orthology" ;
    schema1:identifier biotools:keggorthology ;
    schema1:keywords "Computational Biology",
        "Evolutionary biology",
        "Gene Expression Profiling",
        "Genomics",
        "High-Throughput Screening Assays",
        "Ortholog",
        "Programming Languages",
        "Sequence analysis",
        "User-Computer Interface" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-keggorthology" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/keggorthology.html" .

