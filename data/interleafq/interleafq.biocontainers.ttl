@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:interleafq a schema1:SoftwareApplication ;
    schema1:description "Interleave and deinterleave fastq files" ;
    schema1:identifier biotools:interleafq ;
    schema1:license "MIT" ;
    schema1:name "interleafq" ;
    schema1:url "https://github.com/quadram-institute-bioscience/interleafq/" .

