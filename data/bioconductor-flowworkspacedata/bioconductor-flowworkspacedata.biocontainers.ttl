@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-flowworkspacedata a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18129/b9.bioc.flowworkspacedata" ;
    schema1:description "A data package containing two flowJo, one diva xml workspace and the associated fcs files as well as three GatingSets for testing the flowWorkspace, openCyto and CytoML packages." ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-flowworkspacedata" ;
    schema1:url "https://bioconductor.org/packages/3.8/data/experiment/html/flowWorkspaceData.html" .

