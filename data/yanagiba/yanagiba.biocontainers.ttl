@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:yanagiba a schema1:SoftwareApplication ;
    schema1:description "Filter short or low quality oxford nanopore reads which have been basecalled with albacore." ;
    schema1:license "MIT" ;
    schema1:name "yanagiba" ;
    schema1:url "https://github.com/Adamtaranto/Yanagiba" .

