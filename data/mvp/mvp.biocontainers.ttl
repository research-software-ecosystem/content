@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:mvp a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s12864-017-3687-5" ;
    schema1:description "Detect creation/destruction of sequence motifs as a result of mutations" ;
    schema1:identifier biotools:mvp ;
    schema1:keywords "Molecular modelling",
        "Structure analysis" ;
    schema1:license "GPL (> 3)" ;
    schema1:name "mvp" ;
    schema1:url "https://gitlab.com/LPCDRP/motif-variants" .

