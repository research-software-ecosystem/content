@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:examl a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btv184" ;
    schema1:description "Exascale maximum likelihood (examl) code for phylogenetic inference" ;
    schema1:keywords "Computer Simulation",
        "Computers",
        "Genome, Human",
        "High-Throughput Nucleotide Sequencing",
        "Humans",
        "Phylogeny",
        "Sequence Analysis, DNA",
        "User-Computer Interface" ;
    schema1:license "GPL-2+" ;
    schema1:name "examl" ;
    schema1:url "https://github.com/stamatak/ExaML" .

