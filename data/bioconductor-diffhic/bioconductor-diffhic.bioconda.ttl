@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-diffhic a schema1:SoftwareApplication ;
    schema1:description "Differential Analysis of Hi-C Data" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/diffHic_1.38.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/diffHic/diffHic_1.38.0.tar.gz', 'https://bioarchive.galaxyproject.org/diffHic_1.38.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-diffhic/bioconductor-diffhic_1.38.0_src_all.tar.gz']" ;
    schema1:identifier biotools:diffhic ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-diffhic" ;
    schema1:softwareVersion "1.38.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/diffHic.html" ;
    spdx:builtFrom biotools:diffhic .

