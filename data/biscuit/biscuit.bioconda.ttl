@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:biscuit a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/gkae097" ;
    schema1:description "A utility for analyzing sodium bisulfite conversion-based DNA methylation/modification data." ;
    schema1:downloadUrl "https://github.com/huishenlab/biscuit/releases/download/v1.8.1.20260511/release-source.zip" ;
    schema1:identifier biotools:biscuit ;
    schema1:license "MIT" ;
    schema1:name "biscuit" ;
    schema1:softwareHelp "https://huishenlab.github.io/biscuit" ;
    schema1:softwareVersion "1.8.1.20260511" ;
    schema1:url "https://github.com/huishenlab/biscuit" ;
    spdx:builtFrom biotools:biscuit .

