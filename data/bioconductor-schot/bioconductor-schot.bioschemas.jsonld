      "sc:author": [
        "Yingxin Lin",
        "Shila Ghazanfar"
      ],
      "sc:citation": {
        "@id": "https://doi.org/10.18129/B9.bioc.scHOT"
      },
      "sc:description": "Single cell Higher Order Testing (scHOT) is an R package that facilitates testing changes in higher order structure of gene expression along either a developmental trajectory or across space. scHOT is general and modular in nature, can be run in multiple data contexts such as along a continuous trajectory, between discrete groups, and over spatial orientations; as well as accommodate any higher order measurement such as variability or correlation. scHOT meaningfully adds to first order effect testing, such as differential expression, and provides a framework for interrogating higher order interactions from single cell data.",
      "sc:license": "GPL-3.0-only",
      "sc:name": "scHOT",
      "sc:operatingSystem": [
        "Linux",
        "Windows",
        "Mac"
      ],
      "sc:softwareHelp": {
        "@id": "https://bioconductor.org/packages/scHOT"
      },
      "sc:softwareVersion": "1.22.0",
      "sc:url": "https://bioconductor.org/packages/scHOT"
    }
  ]
