@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:pyrodigal a schema1:SoftwareApplication ;
    schema1:citation "doi:10.5281/zenodo.4015169" ;
