@prefix debianmed: <https://salsa.debian.org/med-team/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

debianmed:norsnet a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1371/journal.pcbi.0030140" ;
    schema1:description "tool to identify unstructured loops in proteins" ;
    schema1:identifier "bio.tools:norsnet",
        "omictools:OMICS_16034" ;
    schema1:license "unknown" ;
    schema1:name "norsnet" ;
    schema1:softwareVersion "1.0.17" ;
    schema1:url "https://www.rostlab.org/owiki/index.php/Norsnet" ;
    spdx:builtFrom "norsnet" .

