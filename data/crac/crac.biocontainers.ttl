@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:crac a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.4106",
        "doi:10.1186/gb-2013-14-3-r30" ;
    schema1:description "Crac is a mapping software specialized for rna-seq data. it detects mutations, indels, splice or fusion junctions in each single read." ;
    schema1:identifier biotools:crac ;
    schema1:keywords "Benchmarking",
        "Computer Simulation",
        "Exons",
        "Gene structure",
        "Genome, Human",
        "Genomics",
        "Humans",
        "Introns",
        "Molecular Sequence Annotation",
        "Plasmodium falciparum",
        "Polymorphism, Genetic",
        "RNA Splicing",
        "RNA splicing",
        "RNA-Seq",
        "RNA-seq",
        "Sequence Alignment",
        "Sequence Analysis, RNA" ;
    schema1:license "CECILL-2.0" ;
    schema1:name "crac" ;
    schema1:url "http://crac.gforge.inria.fr" .

