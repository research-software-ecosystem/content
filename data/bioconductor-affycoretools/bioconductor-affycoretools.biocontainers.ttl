@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-affycoretools a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Functions useful for those doing repetitive analyses with Affymetrix GeneChips" ;
    schema1:identifier biotools:affycoretools ;
    schema1:keywords "Computational Biology",
        "Gene Expression Profiling",
        "Genomics",
        "High-Throughput Screening Assays",
        "Microarray experiment",
        "Programming Languages",
        "Statistics and probability",
        "User-Computer Interface" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-affycoretools" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/affycoretools.html" .

