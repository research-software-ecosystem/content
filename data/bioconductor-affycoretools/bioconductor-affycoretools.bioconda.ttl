@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-affycoretools a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Functions useful for those doing repetitive analyses with Affymetrix GeneChips" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/affycoretools_1.78.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/affycoretools/affycoretools_1.78.0.tar.gz', 'https://bioarchive.galaxyproject.org/affycoretools_1.78.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-affycoretools/bioconductor-affycoretools_1.78.0_src_all.tar.gz']" ;
    schema1:identifier biotools:affycoretools ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-affycoretools" ;
    schema1:softwareVersion "1.78.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/affycoretools.html" ;
    spdx:builtFrom biotools:affycoretools .

