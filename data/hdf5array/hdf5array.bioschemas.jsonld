  "@graph": [
    {
      "@id": "https://bio.tools/hdf5array",
      "@type": "sc:SoftwareApplication",
      "dcterms:conformsTo": "https://bioschemas.org/profiles/ComputationalTool/0.6-DRAFT",
      "sc:additionalType": [
        "Command-line tool",
        "Library"
      ],
      "sc:applicationSubCategory": {
        "@id": "edam:topic_3071"
      },
      "sc:author": "Hervé Pagès",
      "sc:citation": {
        "@id": "https://doi.org/10.18129/B9.bioc.HDF5Array"
      },
      "sc:description": "The HDF5Array package is an HDF5 backend for DelayedArray objects. It implements the HDF5Array, H5SparseMatrix, H5ADMatrix, and TENxMatrix classes, 4 convenient and memory-efficient array-like containers for representing and manipulating either: (1) a conventional (a.k.a. dense) HDF5 dataset, (2) an HDF5 sparse matrix (stored in CSR/CSC/Yale format), (3) the central matrix of an h5ad file (or any matrix in the /layers group), or (4) a 10x Genomics sparse matrix. All these containers are DelayedArray extensions and thus support all operations (delayed or block-processed) supported by DelayedArray objects.",
      "sc:featureList": {
        "@id": "edam:operation_2409"
      },
      "sc:license": "Artistic-2.0",
      "sc:name": "HDF5Array",
      "sc:operatingSystem": [
        "Windows",
        "Mac"
      ],
