@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:alfred a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/bty1007" ;
    schema1:description "BAM alignment statistics, feature counting and feature annotation" ;
    schema1:downloadUrl "https://github.com/tobiasrausch/alfred/archive/v0.5.3.tar.gz" ;
    schema1:identifier biotools:alfred ;
    schema1:license "BSD-3-Clause" ;
    schema1:name "alfred" ;
    schema1:softwareHelp "https://github.com/tobiasrausch/alfred/blob/v0.5.3/README.md" ;
    schema1:softwareVersion "0.5.3" ;
    schema1:url "https://github.com/tobiasrausch/alfred" ;
    spdx:builtFrom biotools:alfred .

