@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:alfred a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/bty1007" ;
    schema1:description "BAM alignment statistics, feature counting and feature annotation" ;
    schema1:identifier biotools:alfred ;
    schema1:keywords "Bioinformatics",
        "Data Accuracy",
        "Genetics",
        "Genomics",
        "High-Throughput Nucleotide Sequencing",
        "Quality Control",
        "Sequence analysis" ;
    schema1:license "BSD" ;
    schema1:name "alfred" ;
    schema1:url "https://github.com/tobiasrausch/alfred" .

