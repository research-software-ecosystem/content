@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:gawk a schema1:SoftwareApplication ;
    schema1:description "The gawk utility interprets a special-purpose programming language that makes it possible to handle simple data-reformatting jobs with just a few lines of code." ;
    schema1:license "GPL-3.0" ;
    schema1:name "gawk" ;
    schema1:url "http://ftpmirror.gnu.org/gawk/" .

