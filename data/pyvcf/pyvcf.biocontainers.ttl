@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:pyvcf a schema1:SoftwareApplication ;
    schema1:description "Helper scripts for variant call format (vcf) parser" ;
    schema1:license "BSD-3-clause" ;
    schema1:name "pyvcf" ;
    schema1:url "https://pypi.python.org/pypi/PyVCF" .

