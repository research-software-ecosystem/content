@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:swarm a schema1:SoftwareApplication ;
    schema1:citation "doi:10.7717/peerj.1420",
        "doi:10.7717/peerj.593" ;
    schema1:description "Robust and fast clustering method for amplicon-based studies" ;
    schema1:identifier biotools:swarm ;
    schema1:keywords "Biodiversity",
        "Clustering",
        "Microbiology",
        "Molecular biology",
        "Sequence analysis" ;
    schema1:license "Affero-GPL-3" ;
    schema1:name "swarm" ;
    schema1:url "https://github.com/torognes/swarm" .

