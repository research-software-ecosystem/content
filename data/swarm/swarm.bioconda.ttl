@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:swarm a schema1:SoftwareApplication ;
    schema1:citation "doi:10.7717/peerj.593" ;
    schema1:description "A robust and fast clustering method for amplicon-based studies." ;
    schema1:downloadUrl "https://github.com/torognes/swarm/archive/v3.1.6.tar.gz" ;
    schema1:identifier biotools:swarm ;
    schema1:license "AGPL-3.0-or-later" ;
    schema1:name "swarm" ;
    schema1:softwareHelp "https://github.com/torognes/swarm/blob/v3.1.6/man/swarm_manual.pdf" ;
    schema1:softwareVersion "3.1.6" ;
    schema1:url "https://github.com/torognes/swarm" ;
    spdx:builtFrom biotools:swarm .

