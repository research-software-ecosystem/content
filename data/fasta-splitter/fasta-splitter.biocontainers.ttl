@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:fasta-splitter a schema1:SoftwareApplication ;
    schema1:description "Divides a large fasta file into a set of smaller, approximately equally sized files" ;
    schema1:license "Not available" ;
    schema1:name "fasta-splitter" ;
    schema1:url "http://kirill-kryukov.com/study/tools/fasta-splitter/" .

