@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:fastahack a schema1:SoftwareApplication ;
    schema1:description "Utility for indexing and sequence extraction from fasta files" ;
    schema1:license "custom, see /usr/share/doc/fastahack/copyright" ;
    schema1:name "fastahack" ;
    schema1:url "https://github.com/ekg/fastahack" .

