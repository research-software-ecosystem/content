@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:slivar a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s13073-020-00761-2" ;
    schema1:description "filter/annotate variants in VCF/BCF format with simple expressions." ;
    schema1:downloadUrl "https://github.com/brentp/slivar/archive/refs/tags/v0.3.3.tar.gz" ;
    schema1:identifier biotools:somalier ;
    schema1:license "MIT" ;
    schema1:name "slivar" ;
    schema1:softwareHelp "https://github.com/brentp/slivar/blob/v0.3.3/README.md" ;
    schema1:softwareVersion "0.3.3" ;
    schema1:url "https://github.com/brentp/slivar" ;
    spdx:builtFrom biotools:somalier .

