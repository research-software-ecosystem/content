@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:getorganelle a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s13059-020-02154-5" ;
    schema1:description "Get organelle genomes from genome skimming data" ;
    schema1:downloadUrl "https://github.com/Kinggerm/GetOrganelle/archive/1.7.7.1.tar.gz" ;
    schema1:identifier biotools:getorganelle ;
    schema1:license "GPL-3.0-or-later" ;
    schema1:name "getorganelle" ;
    schema1:softwareHelp "https://github.com/Kinggerm/GetOrganelle/wiki" ;
    schema1:softwareVersion "1.7.7.1" ;
    schema1:url "https://github.com/Kinggerm/GetOrganelle" ;
    spdx:builtFrom biotools:getorganelle .

