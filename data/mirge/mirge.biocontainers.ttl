@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:mirge a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s12859-018-2287-y" ;
    schema1:description "Comprehensive analysis of mirna sequencing data" ;
    schema1:keywords "Animals",
        "Computational Biology",
        "High-Throughput Nucleotide Sequencing",
        "Humans",
        "Mice",
        "MicroRNAs",
        "Phylogeny",
        "RNA-Seq",
        "Rats",
        "Sequence Analysis, RNA" ;
    schema1:license "GPL-3.0" ;
    schema1:name "mirge" ;
    schema1:url "https://github.com/mhalushka/miRge" .

