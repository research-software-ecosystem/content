@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-tofsims a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18129/b9.bioc.tofsims" ;
    schema1:description "Import, process and analysis of Time-of-Flight Secondary Ion Mass Spectrometry (ToF-SIMS) imaging data" ;
    schema1:keywords "Mass spectrometry",
        "Metabolomics",
        "Proteomics" ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-tofsims" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/tofsims.html" .

