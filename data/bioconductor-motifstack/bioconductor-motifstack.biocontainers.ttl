@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-motifstack a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Plot stacked logos for single or multiple DNA, RNA and amino acid sequence" ;
    schema1:identifier biotools:motifstack ;
    schema1:keywords "ChIP-seq",
        "Computational Biology",
        "Data visualisation",
        "Gene Expression Profiling",
        "Genetics",
        "Genomics",
        "High-Throughput Screening Assays",
        "Microarray experiment",
        "Nucleic acid sites, features and motifs",
        "Programming Languages",
        "Protein sites, features and motifs",
        "Sequencing",
        "User-Computer Interface" ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-motifstack" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/motifStack.html" .

