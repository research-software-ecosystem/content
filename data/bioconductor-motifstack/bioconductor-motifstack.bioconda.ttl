@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-motifstack a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Plot stacked logos for single or multiple DNA, RNA and amino acid sequence" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/motifStack_1.54.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/motifStack/motifStack_1.54.0.tar.gz', 'https://bioarchive.galaxyproject.org/motifStack_1.54.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-motifstack/bioconductor-motifstack_1.54.0_src_all.tar.gz']" ;
    schema1:identifier biotools:motifstack ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-motifstack" ;
    schema1:softwareVersion "1.54.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/motifStack.html" ;
    spdx:builtFrom biotools:motifstack .

