@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-interactivedisplay a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252",
        "doi:10.18129/b9.bioc.interactivedisplay" ;
    schema1:description "Package for enabling powerful shiny web displays of bioconductor objects" ;
    schema1:identifier biotools:interactivedisplay ;
    schema1:keywords "Bioinformatics",
        "Computational Biology",
        "Gene Expression Profiling",
        "Genetics",
        "Genomics",
        "High-Throughput Screening Assays",
        "Metagenome",
        "Programming Languages",
        "Software engineering",
        "User-Computer Interface" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-interactivedisplay" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/interactiveDisplay.html" .

