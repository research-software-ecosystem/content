@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-interactivedisplay a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Package for enabling powerful shiny web displays of Bioconductor objects" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/interactiveDisplay_1.48.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/interactiveDisplay/interactiveDisplay_1.48.0.tar.gz', 'https://bioarchive.galaxyproject.org/interactiveDisplay_1.48.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-interactivedisplay/bioconductor-interactivedisplay_1.48.0_src_all.tar.gz']" ;
    schema1:identifier biotools:interactivedisplay ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-interactivedisplay" ;
    schema1:softwareVersion "1.48.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/interactiveDisplay.html" ;
    spdx:builtFrom biotools:interactivedisplay .

