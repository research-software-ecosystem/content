@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:physher a schema1:SoftwareApplication ;
    schema1:author "4ment" ;
    schema1:citation "doi:10.1186/s12862-014-0163-6" ;
    schema1:description "A multi-algorithmic framework for phylogenetic inference." ;
    schema1:downloadUrl "https://github.com/4ment/physher/archive/refs/tags/v2.0.1.tar.gz" ;
    schema1:identifier biotools:physher ;
    schema1:license "GPL-2.0-or-later" ;
    schema1:maintainer "4ment" ;
    schema1:name "physher" ;
    schema1:softwareVersion "2.0.1" ;
    schema1:url "https://github.com/4ment/physher" ;
    spdx:builtFrom biotools:physher .

