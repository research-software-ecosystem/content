@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:gffmunger a schema1:SoftwareApplication ;
    schema1:description "Munges gff3 files exported from chado database to make them suitable for loading into webapollo" ;
    schema1:license "GNU General Public License v3.0" ;
    schema1:name "gffmunger" ;
    schema1:url "https://github.com/sanger-pathogens/gffmunger" .

