@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-badregionfinder a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "BadRegionFinder: an R/Bioconductor package for identifying regions with bad coverage" ;
    schema1:identifier biotools:badregionfinder ;
    schema1:keywords "Computational Biology",
        "Gene Expression Profiling",
        "Genomics",
        "High-Throughput Screening Assays",
        "Nucleic acids",
        "Programming Languages",
        "Proteins",
        "Sequence Alignment",
        "Sequence analysis",
        "User-Computer Interface" ;
    schema1:license "LGPL-3" ;
    schema1:name "bioconductor-badregionfinder" ;
    schema1:url "https://bioconductor.org/packages/release/bioc/html/BadRegionFinder.html" .

