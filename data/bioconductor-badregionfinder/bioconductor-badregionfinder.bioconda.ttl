@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-badregionfinder a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "BadRegionFinder: an R/Bioconductor package for identifying regions with bad coverage" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/BadRegionFinder_1.38.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/BadRegionFinder/BadRegionFinder_1.38.0.tar.gz', 'https://bioarchive.galaxyproject.org/BadRegionFinder_1.38.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-badregionfinder/bioconductor-badregionfinder_1.38.0_src_all.tar.gz']" ;
    schema1:identifier biotools:badregionfinder ;
    schema1:license "LGPL-3" ;
    schema1:name "bioconductor-badregionfinder" ;
    schema1:softwareVersion "1.38.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/BadRegionFinder.html" ;
    spdx:builtFrom biotools:badregionfinder .

