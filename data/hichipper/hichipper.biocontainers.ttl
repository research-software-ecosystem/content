@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:hichipper a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1101/192302" ;
    schema1:description "Processing hichip data into loops." ;
    schema1:identifier biotools:hichipper ;
    schema1:keywords "Genetics",
        "Immunoprecipitation experiment",
        "Laboratory information management",
        "Nucleic acid structure analysis" ;
    schema1:license "MIT" ;
    schema1:name "hichipper" ;
    schema1:url "https://github.com/aryeelab/hichipper" .

