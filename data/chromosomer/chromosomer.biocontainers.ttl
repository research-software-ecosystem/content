@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:chromosomer a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s13742-016-0141-6" ;
    schema1:description "A reference-assisted assembly tool for producing draft chromosome sequences." ;
    schema1:keywords "Chromosome Mapping",
        "Contig Mapping",
        "Genome",
        "Sequence Alignment" ;
    schema1:license "MIT" ;
    schema1:name "chromosomer" ;
    schema1:url "https://github.com/gtamazian/chromosomer" .

