@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:ismapper a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s12864-015-1860-2" ;
    schema1:description "A mapping-based tool for identification of the site and orientation of IS insertions in bacterial genomes." ;
    schema1:keywords "Acinetobacter baumannii",
        "Base Sequence",
        "Computer Simulation",
        "Drug Resistance, Microbial",
        "Genome, Bacterial",
        "Genomics",
        "Molecular Sequence Data",
        "Mutagenesis, Insertional",
        "Mycobacterium tuberculosis",
        "Polymerase Chain Reaction",
        "Reproducibility of Results",
        "Sequence Analysis, DNA",
        "Transposases" ;
    schema1:license "BSD" ;
    schema1:name "ismapper" ;
    schema1:url "https://github.com/jhawkey/IS_mapper/" .

