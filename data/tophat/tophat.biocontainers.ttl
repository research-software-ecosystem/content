@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:tophat a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btp120",
        "doi:10.7490/f1000research.1114334.1" ;
    schema1:description "Program that aligns rna-seq reads to a genome in order to identify exon-exon splice junctions. it is built on the ultrafast short read mapping program bowtie. a stable samtools version is now packaged with the program." ;
    schema1:identifier biotools:tophat ;
    schema1:keywords "Gene Expression Profiling",
        "Mapping",
        "Models, Genetic",
        "RNA Splicing",
        "RNA, Messenger",
        "RNA-Seq",
        "RNA-seq",
        "Rare diseases",
        "Sequence Alignment",
        "Sequence Analysis, RNA" ;
    schema1:license "BSL-1.0" ;
    schema1:name "tophat" ;
    schema1:url "https://github.com/DaehwanKimLab/tophat" .

