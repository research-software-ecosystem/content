@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:tophat a schema1:SoftwareApplication ;
    schema1:description "A spliced read mapper for RNA-Seq." ;
    schema1:downloadUrl "https://github.com/infphilo/tophat/archive/refs/tags/v2.1.2.tar.gz" ;
    schema1:identifier biotools:tophat2 ;
    schema1:license "Boost Software License" ;
    schema1:name "tophat" ;
    schema1:softwareHelp "http://ccb.jhu.edu/software/tophat" ;
    schema1:softwareVersion "2.1.2" ;
    schema1:url "http://ccb.jhu.edu/software/tophat" ;
    spdx:builtFrom biotools:tophat2 .

