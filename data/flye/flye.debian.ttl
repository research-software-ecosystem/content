@prefix debianmed: <https://salsa.debian.org/med-team/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

debianmed:flye a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/s41587-019-0072-8",
        "doi:10.1073/pnas.1604560113" ;
    schema1:description "de novo assembler for single molecule sequencing reads using repeat graphs" ;
    schema1:identifier "bio.tools:Flye",
        "conda:bioconda:flye" ;
    schema1:license "unknown" ;
    schema1:name "flye" ;
    schema1:softwareVersion "2.9.6" ;
    schema1:url "https://github.com/fenderglass/Flye" ;
    spdx:builtFrom "Flye" .

