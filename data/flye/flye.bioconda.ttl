@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:flye a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/s41587-019-0072-8",
        "doi:10.1038/s41592-020-00971-x",
        "doi:10.1073/pnas.1604560113" ;
    schema1:description "A fast and accurate de novo assembler for single molecule sequencing reads using repeat graphs." ;
    schema1:downloadUrl "https://github.com/fenderglass/Flye/archive/2.9.6.tar.gz" ;
    schema1:identifier biotools:Flye ;
    schema1:license "BSD-3-Clause" ;
    schema1:name "flye" ;
    schema1:softwareHelp "https://github.com/mikolmogorov/Flye/blob/flye/docs/USAGE.md" ;
    schema1:softwareVersion "2.9.6" ;
    schema1:url "https://github.com/mikolmogorov/Flye" ;
    spdx:builtFrom biotools:Flye .

