@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:snap a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/1471-2105-5-59" ;
    schema1:description "Semi-HMM-based Nucleic Acid Parser - a gene prediction tool." ;
    schema1:identifier biotools:snap ;
    schema1:license "MIT" ;
    schema1:name "snap" ;
    schema1:softwareHelp "https://github.com/KorfLab/SNAP/blob/master/README.md" ;
    schema1:softwareVersion "20170301" ;
    schema1:url "https://github.com/KorfLab/SNAP" ;
    spdx:builtFrom biotools:snap .

