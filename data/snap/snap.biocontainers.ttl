@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:snap a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/1471-2105-5-59" ;
    schema1:description "The semi-hmm-based nucleic acid parser is a gene prediction tool." ;
    schema1:identifier biotools:snap ;
    schema1:keywords "Animals",
        "Arabidopsis",
        "Caenorhabditis elegans",
        "Computational Biology",
        "DNA",
        "DNA polymorphism",
        "Databases, Genetic",
        "Drosophila melanogaster",
        "Genes",
        "Genes, Helminth",
        "Genes, Insect",
        "Genes, Plant",
        "Genetic Variation",
        "Genetics",
        "Genome",
        "Genome, Plant",
        "Predictive Value of Tests" ;
    schema1:license "GPL-2.0+" ;
    schema1:name "snap" ;
    schema1:url "https://github.com/KorfLab/SNAP" .

