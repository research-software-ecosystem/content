@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:lsd a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/gkq1169" ;
    schema1:description "The LAPPS Grid Services DSL (LSD). Used to invoke LAPPS web services from the command line." ;
    schema1:identifier biotools:lsd ;
    schema1:keywords "Cellular Senescence",
        "Databases, Genetic",
        "Functional, regulatory and non-coding RNA",
        "Genes, Plant",
        "Genotype and phenotype",
        "Molecular Sequence Annotation",
        "Molecular interactions, pathways and networks",
        "Plant Leaves",
        "Plant biology",
        "Sequence Analysis" ;
    schema1:license "Apache-2.0" ;
    schema1:name "lsd" ;
    schema1:url "http://github.com/lappsgrid-incubator/org.anc.lapps.dsl" .

