@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:padloc a schema1:SoftwareApplication ;
    schema1:author "leightonpayne",
        "pentamorfico" ;
    schema1:description "Locate antiviral defence systems in prokaryotic genomes" ;
    schema1:downloadUrl "https://github.com/padlocbio/padloc/archive/refs/tags/v2.0.0.tar.gz" ;
    schema1:identifier biotools:padloc ;
    schema1:license "MIT" ;
    schema1:maintainer "leightonpayne",
        "pentamorfico" ;
    schema1:name "padloc" ;
    schema1:softwareVersion "2.0.0" ;
    schema1:url "https://github.com/padlocbio/padloc" ;
    spdx:builtFrom biotools:padloc .

