@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:crispresso2 a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/s41587-019-0046-x" ;
    schema1:description "A software pipeline designed to enable rapid and intuitive interpretation of genome editing experiments." ;
    schema1:downloadUrl "https://github.com/pinellolab/CRISPResso2/archive/v2.3.3.tar.gz" ;
    schema1:identifier biotools:crispresso2 ;
    schema1:license "CC0-1.0" ;
    schema1:name "crispresso2" ;
    schema1:softwareHelp "https://docs.crispresso.com" ;
    schema1:softwareVersion "2.3.3" ;
    schema1:url "https://github.com/pinellolab/CRISPResso2" ;
    spdx:builtFrom biotools:crispresso2 .

