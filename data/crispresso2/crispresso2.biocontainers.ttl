@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:crispresso2 a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/s41587-019-0032-3" ;
    schema1:description "A software pipeline designed to enable rapid and intuitive interpretation of genome editing experiments" ;
    schema1:keywords "CRISPR-Cas Systems",
        "Gene Editing",
        "Genome, Human",
        "Humans",
        "Polymorphism, Single Nucleotide",
        "RNA Editing",
        "Sequence Alignment",
        "Sequence Analysis",
        "Whole genome sequencing" ;
    schema1:license "Custom License" ;
    schema1:name "crispresso2" ;
    schema1:url "https://github.com/pinellolab/CRISPResso2" .

