@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:impute2 a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1534/g3.111.001198" ;
    schema1:description "Genotype imputation and haplotype phasing" ;
    schema1:downloadUrl "https://mathgen.stats.ox.ac.uk/impute/impute_v2.3.2_MacOSX_Intel.tgz",
        "https://mathgen.stats.ox.ac.uk/impute/impute_v2.3.2_x86_64_static.tgz" ;
    schema1:identifier biotools:IMPUTE2 ;
    schema1:license "Academic use, commerically restricted (http://www.stats.ox.ac.uk/~marchini/software/gwas/gwas.html#licence)" ;
    schema1:name "impute2" ;
    schema1:softwareVersion "2.3.2" ;
    schema1:url "https://mathgen.stats.ox.ac.uk/impute/impute_v2.html" ;
    spdx:builtFrom biotools:IMPUTE2 .

