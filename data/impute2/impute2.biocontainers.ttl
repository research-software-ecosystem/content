@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:impute2 a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1371/journal.pgen.1000529",
        "doi:10.1534/g3.111.001198" ;
    schema1:description "Genotype imputation and haplotype phasing" ;
    schema1:identifier biotools:impute2 ;
    schema1:keywords "Genetic variation",
        "Genetics",
        "Genetics, Population",
        "Genome-Wide Association Study",
        "Genomics",
        "Genotype",
        "Humans",
        "Polymorphism, Single Nucleotide",
        "Population genetics" ;
    schema1:license "Academic use, commerically restricted (http://www.stats.ox.ac.uk/~marchini/software/gwas/gwas.html#licence)" ;
    schema1:name "impute2" ;
    schema1:url "https://mathgen.stats.ox.ac.uk/impute/impute_v2.html" .

