@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:pycoqc a schema1:SoftwareApplication ;
    schema1:description "Pycoqc computes metrics and generates interactive qc plots for oxford nanopore technologies sequencing data" ;
    schema1:license "GPL-3.0" ;
    schema1:name "pycoqc" ;
    schema1:url "https://github.com/a-slide/pycoQC" .

