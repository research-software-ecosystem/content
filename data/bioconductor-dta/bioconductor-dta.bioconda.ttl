@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-dta a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/bts052" ;
    schema1:description "Dynamic Transcriptome Analysis" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/DTA_2.56.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/DTA/DTA_2.56.0.tar.gz', 'https://bioarchive.galaxyproject.org/DTA_2.56.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-dta/bioconductor-dta_2.56.0_src_all.tar.gz']" ;
    schema1:identifier biotools:dta ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-dta" ;
    schema1:softwareVersion "2.56.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/DTA.html" ;
    spdx:builtFrom biotools:dta .

