@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:maaslin a schema1:SoftwareApplication ;
    schema1:description "MaAsLin is a multivariate statistical framework that finds associations between clinical metadata and microbial community abundance or function." ;
    schema1:keywords "Metagenome" ;
    schema1:license "Custom" ;
    schema1:name "maaslin" ;
    schema1:url "https://huttenhower.sph.harvard.edu/maaslin" .

