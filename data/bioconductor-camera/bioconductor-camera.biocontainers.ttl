@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-camera a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1021/ac202450g" ;
    schema1:description "Collection of annotation related methods for mass spectrometry data" ;
    schema1:identifier biotools:camera ;
    schema1:keywords "Chromatography, Liquid",
        "Mass spectrometry",
        "Metabolomics",
        "Plants",
        "Spectrometry, Mass, Electrospray Ionization" ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-camera" ;
    schema1:url "https://www.bioconductor.org/packages/release/bioc/html/CAMERA.html" .

