@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-camera a schema1:SoftwareApplication ;
    schema1:description "Collection of annotation related methods for mass spectrometry data" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/CAMERA_1.66.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/CAMERA/CAMERA_1.66.0.tar.gz', 'https://bioarchive.galaxyproject.org/CAMERA_1.66.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-camera/bioconductor-camera_1.66.0_src_all.tar.gz']" ;
    schema1:identifier biotools:camera ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-camera" ;
    schema1:softwareVersion "1.66.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/CAMERA.html" ;
    spdx:builtFrom biotools:camera .

