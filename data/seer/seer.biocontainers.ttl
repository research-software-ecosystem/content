@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:seer a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/ncomms12797" ;
    schema1:description "Genomic sequence element (kmer) enrichment analysis" ;
    schema1:keywords "Computer Simulation",
        "DNA, Bacterial",
        "Genome, Bacterial",
        "Genome-Wide Association Study",
        "Models, Genetic",
        "Nucleic Acid Amplification Techniques",
        "Streptococcus pneumoniae",
        "Streptococcus pyogenes" ;
    schema1:license "custom, see /usr/share/doc/seer/copyright" ;
    schema1:name "seer" ;
    schema1:url "https://github.com/johnlees/seer" .

