@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:sim4 a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1101/gr.8.9.967" ;
    schema1:description "Align cdna with genomic dna, allowing for introns and small number of sequencing errors." ;
    schema1:identifier biotools:sim4 ;
    schema1:keywords "Animals",
        "Computational Biology",
        "DNA",
        "DNA, Complementary",
        "Drosophila melanogaster",
        "Expressed Sequence Tags",
        "Gene transcripts",
        "Genome",
        "Genomics",
        "Humans",
        "Mice",
        "RNA, Messenger",
        "Sequence Alignment",
        "Sequence Homology, Nucleic Acid",
        "Sequence analysis",
        "Sequencing",
        "Transcriptomics" ;
    schema1:license "GPL-2+" ;
    schema1:name "sim4" ;
    schema1:url "http://globin.bx.psu.edu/html/docs/sim4.html" .

