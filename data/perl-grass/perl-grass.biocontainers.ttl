@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:perl-grass a schema1:SoftwareApplication ;
    schema1:description "Gene Rearrangement AnalySiS: Takes pairs of coordinates describing potential rearrangement events and predicts the 'most interesting' fusion consequences that could occurs" ;
    schema1:license "AGPL-3.0" ;
    schema1:name "perl-grass" ;
    schema1:url "https://github.com/cancerit/grass" .

