@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-phantasus a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18129/b9.bioc.phantasus" ;
    schema1:description "Visual and interactive gene expression analysis" ;
    schema1:keywords "Clustering",
        "Gene Expression",
        "Transcriptomics" ;
    schema1:license "MIT" ;
    schema1:name "bioconductor-phantasus" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/phantasus.html" .

