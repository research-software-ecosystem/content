@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:astir a schema1:SoftwareApplication ;
    schema1:description "astir is a modelling framework for the assignment of cell type and cell state across a range of single-cell technologies such as Imaging Mass Cytometry (IMC)." ;
    schema1:keywords "Proteomics" ;
    schema1:license "GPL-2.0" ;
    schema1:name "astir" ;
    schema1:url "https://github.com/camlab-bioml/astir" .

