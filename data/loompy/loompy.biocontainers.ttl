@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:loompy a schema1:SoftwareApplication ;
    schema1:description "Work with .loom files for single-cell RNA-seq data" ;
    schema1:license "BSD-2-Clause" ;
    schema1:name "loompy" ;
    schema1:url "https://github.com/linnarsson-lab/loompy" .

