@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-pcan a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s12859-016-1401-2" ;
    schema1:description "Phenotypes comparison based on a pathway consensus approach. assess the relationship between candidate genes and a set of phenotypes based on additional genes related to the candidate (e.g. pathways or network neighbors)." ;
    schema1:identifier biotools:pcan ;
    schema1:keywords "Abnormalities, Multiple",
        "Cerebellum",
        "Disease",
        "Eye Abnormalities",
        "Genes",
        "Genetics",
        "Genotype",
        "Genotype and phenotype",
        "Humans",
        "Kidney Diseases, Cystic",
        "Molecular interactions, pathways and networks",
        "Phenotype",
        "Retina",
        "Signal Transduction" ;
    schema1:license "CC-BY-NC-ND-4.0" ;
    schema1:name "bioconductor-pcan" ;
    schema1:url "http://bioconductor.org/packages/release/bioc/html/PCAN.html" .

