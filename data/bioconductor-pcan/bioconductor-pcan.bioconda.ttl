@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-pcan a schema1:SoftwareApplication ;
    schema1:description "Phenotype Consensus ANalysis (PCAN)" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/PCAN_1.38.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/PCAN/PCAN_1.38.0.tar.gz', 'https://bioarchive.galaxyproject.org/PCAN_1.38.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-pcan/bioconductor-pcan_1.38.0_src_all.tar.gz']" ;
    schema1:identifier biotools:pcan ;
    schema1:license "CC BY-NC-ND 4.0" ;
    schema1:name "bioconductor-pcan" ;
    schema1:softwareVersion "1.38.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/PCAN.html" ;
    spdx:builtFrom biotools:pcan .

