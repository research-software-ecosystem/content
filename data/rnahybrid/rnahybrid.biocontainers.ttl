@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:rnahybrid a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1261/rna.5248604" ;
    schema1:description "Tool for finding the minimum free energy hybridization of a long and a short rna. the hybridization is performed in a kind of domain mode, ie. the short sequence is hybridized to the best fitting part of the long one. the tool is primarily meant as a means for microrna target prediction." ;
    schema1:identifier biotools:rnahybrid ;
    schema1:keywords "3' Untranslated Regions",
        "Animals",
        "Binding Sites",
        "Body Patterning",
        "Computational Biology",
        "Databases, Nucleic Acid",
        "Drosophila",
        "Genes, Insect",
        "MicroRNAs",
        "Nucleic Acid Conformation",
        "Nucleic acid structure analysis",
        "RNA Processing, Post-Transcriptional",
        "RNA, Messenger",
        "Sequence sites, features and motifs",
        "Thermodynamics" ;
    schema1:license "GPL-2+" ;
    schema1:name "rnahybrid" ;
    schema1:url "http://bibiserv.cebitec.uni-bielefeld.de/rnahybrid" .

