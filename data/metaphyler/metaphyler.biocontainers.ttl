    schema1:description "Estimating Bacterial Composition from Metagenomic Sequences" ;
    schema1:identifier biotools:metaphyler ;
    schema1:keywords "Archaea",
        "Bacteria",
        "Databases, Genetic",
        "Genes, rRNA",
        "Genetic Markers",
        "Genome, Bacterial",
        "Genomics",
        "Humans",
        "Metagenomics",
        "Microbial ecology",
        "Phylogenetics",
        "Phylogeny",
        "RNA, Ribosomal, 16S",
        "Sequence Alignment",
        "Taxonomy",
        "Time Factors" ;
    schema1:license "Artistic License 2.0" ;
    schema1:name "metaphyler" ;
    schema1:url "http://metaphyler.cbcb.umd.edu/" .

