@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:oakvar a schema1:SoftwareApplication ;
    schema1:author "rkimoakbioinformatics" ;
    schema1:description "OakVar - Genomic Variant Analysis Platform" ;
    schema1:downloadUrl "https://pypi.org/packages/source/O/OakVar/oakvar-2.13.0.tar.gz" ;
    schema1:identifier biotools:oakvar ;
    schema1:license "AGPL-3.0-or-later" ;
    schema1:maintainer "rkimoakbioinformatics" ;
    schema1:name "oakvar" ;
    schema1:softwareHelp "https://rkimoakbioinformatics.github.io/oakvar" ;
    schema1:softwareVersion "2.13.0" ;
    schema1:url "https://github.com/rkimoakbioinformatics/oakvar" ;
    spdx:builtFrom biotools:oakvar .

