@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-chronos a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btv673" ;
    schema1:description "CHRONOS: A time-varying method for microRNA-mediated sub-pathway enrichment analysis" ;
    schema1:identifier biotools:CHRONOS ;
    schema1:keywords "Functional, regulatory and non-coding RNA",
        "MicroRNAs",
        "Molecular interactions, pathways and networks",
        "Signal Transduction",
        "Systems biology",
        "Transcriptomics" ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-chronos" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/CHRONOS.html" .

