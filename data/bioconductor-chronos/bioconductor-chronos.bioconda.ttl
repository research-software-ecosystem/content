@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-chronos a schema1:SoftwareApplication ;
    schema1:description "CHRONOS: A time-varying method for microRNA-mediated sub-pathway enrichment analysis" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/CHRONOS_1.34.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/CHRONOS/CHRONOS_1.34.0.tar.gz', 'https://bioarchive.galaxyproject.org/CHRONOS_1.34.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-chronos/bioconductor-chronos_1.34.0_src_all.tar.gz']" ;
    schema1:identifier biotools:CHRONOS ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-chronos" ;
    schema1:softwareVersion "1.34.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/CHRONOS.html" ;
    spdx:builtFrom biotools:CHRONOS .

