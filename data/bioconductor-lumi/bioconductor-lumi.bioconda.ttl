@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-lumi a schema1:SoftwareApplication ;
    schema1:description "BeadArray Specific Methods for Illumina Methylation and Expression Microarrays" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/lumi_2.62.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/lumi/lumi_2.62.0.tar.gz', 'https://bioarchive.galaxyproject.org/lumi_2.62.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-lumi/bioconductor-lumi_2.62.0_src_all.tar.gz']" ;
    schema1:identifier biotools:lumi ;
    schema1:license "LGPL (>= 2)" ;
    schema1:name "bioconductor-lumi" ;
    schema1:softwareVersion "2.62.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/lumi.html" ;
    spdx:builtFrom biotools:lumi .

