@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-flowpeaks a schema1:SoftwareApplication ;
    schema1:description "An R package for flow data clustering" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/flowPeaks_1.52.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/flowPeaks/flowPeaks_1.52.0.tar.gz', 'https://bioarchive.galaxyproject.org/flowPeaks_1.52.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-flowpeaks/bioconductor-flowpeaks_1.52.0_src_all.tar.gz']" ;
    schema1:identifier biotools:flowpeaks ;
    schema1:license "Artistic-1.0" ;
    schema1:name "bioconductor-flowpeaks" ;
    schema1:softwareVersion "1.52.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/flowPeaks.html" ;
    spdx:builtFrom biotools:flowpeaks .

