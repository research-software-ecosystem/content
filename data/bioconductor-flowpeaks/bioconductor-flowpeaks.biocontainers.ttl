@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-flowpeaks a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/bts300" ;
    schema1:description "An R package for flow data clustering" ;
    schema1:identifier biotools:flowpeaks ;
    schema1:keywords "Cell biology",
        "Cluster Analysis",
        "Clustering",
        "Computational Biology",
        "Flow Cytometry",
        "Models, Theoretical" ;
    schema1:license "Artistic-1.0" ;
    schema1:name "bioconductor-flowpeaks" ;
    schema1:url "https://bioconductor.org/packages/release/bioc/html/flowPeaks.html" .

