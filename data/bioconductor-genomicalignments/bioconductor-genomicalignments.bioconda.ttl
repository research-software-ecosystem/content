@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-genomicalignments a schema1:SoftwareApplication ;
    schema1:description "Representation and manipulation of short genomic alignments" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/GenomicAlignments_1.46.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/GenomicAlignments/GenomicAlignments_1.46.0.tar.gz', 'https://bioarchive.galaxyproject.org/GenomicAlignments_1.46.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-genomicalignments/bioconductor-genomicalignments_1.46.0_src_all.tar.gz']" ;
    schema1:identifier biotools:genomicalignments ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-genomicalignments" ;
    schema1:softwareVersion "1.46.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/GenomicAlignments.html" ;
    spdx:builtFrom biotools:genomicalignments .

