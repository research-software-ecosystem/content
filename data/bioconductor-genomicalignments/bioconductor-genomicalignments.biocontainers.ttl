    schema1:keywords "Animals",
        "Databases, Genetic",
        "Genetics",
        "Genomics",
        "Humans",
        "Mice",
        "Sequence Alignment",
        "Sequence Analysis, DNA",
        "Sequence analysis" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-genomicalignments" ;
    schema1:url "https://bioconductor.org/packages/GenomicAlignments/" .

