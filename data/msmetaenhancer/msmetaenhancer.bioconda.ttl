@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:msmetaenhancer a schema1:SoftwareApplication ;
    schema1:author "hechth",
        "martenson",
        "xtrojak" ;
    schema1:citation "doi:10.21105/joss.04494" ;
    schema1:description "MSMetaEnhancer is a Python tool that adds more annotations (e.g. SMILES, InChI, CAS number) to MSP files." ;
    schema1:downloadUrl "https://pypi.io/packages/source/m/msmetaenhancer/msmetaenhancer-0.5.1.tar.gz" ;
    schema1:identifier biotools:msmetaenhancer ;
    schema1:license "MIT" ;
    schema1:maintainer "hechth",
        "martenson",
        "xtrojak" ;
    schema1:name "msmetaenhancer" ;
    schema1:softwareHelp "https://msmetaenhancer.readthedocs.io" ;
    schema1:softwareVersion "0.5.1" ;
    schema1:url "https://github.com/RECETOX/MSMetaEnhancer" ;
    spdx:builtFrom biotools:msmetaenhancer .

