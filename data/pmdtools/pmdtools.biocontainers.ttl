@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:pmdtools a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1073/pnas.1318934111" ;
    schema1:description "Compute postmortem damage patterns and decontaminate ancient genomes" ;
    schema1:keywords "Animals",
        "DNA, Mitochondrial",
        "Humans",
        "Molecular Sequence Data",
        "Neanderthals",
        "Siberia" ;
    schema1:license "Not available" ;
    schema1:name "pmdtools" ;
    schema1:url "https://github.com/pontussk/PMDtools" .

