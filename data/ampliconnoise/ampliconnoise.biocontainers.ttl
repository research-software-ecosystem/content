@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:ampliconnoise a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/bty096" ;
    schema1:description "Removal of noise from 454 sequenced pcr amplicons" ;
    schema1:identifier biotools:ampliconnoise ;
    schema1:license "GPL-3" ;
    schema1:name "ampliconnoise" ;
    schema1:url "https://github.com/lanzen/ampliconnoise" .

