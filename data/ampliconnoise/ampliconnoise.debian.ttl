@prefix debianmed: <https://salsa.debian.org/med-team/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

debianmed:ampliconnoise a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/1471-2105-12-38" ;
    schema1:description "removal of noise from 454 sequenced PCR amplicons" ;
    schema1:identifier "bio.tools:pyronoise",
        "omictools:OMICS_01112",
        "scicrunch:SCR_007814" ;
    schema1:keywords "role::program" ;
    schema1:license "unknown" ;
    schema1:name "ampliconnoise" ;
    schema1:softwareVersion "1.29" ;
    schema1:url "https://github.com/lanzen/ampliconnoise" ;
    spdx:builtFrom "pyronoise" .

