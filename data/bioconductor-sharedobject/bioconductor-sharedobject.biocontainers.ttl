@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-sharedobject a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18129/b9.bioc.sharedobject" ;
    schema1:description "Sharing R objects across multiple R processes without memory duplication" ;
    schema1:license "GPL-3.0" ;
    schema1:name "bioconductor-sharedobject" ;
    schema1:url "https://bioconductor.org/packages/3.10/bioc/html/SharedObject.html" .

