@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bmge a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/1471-2148-10-210" ;
    schema1:description "Bmge (block mapping and gathering with entropy) is a program that selects regions in a multiple sequence alignment that are suited for phylogenetic inference." ;
    schema1:identifier biotools:bmge ;
    schema1:keywords "Computational Biology",
        "Computer Simulation",
        "Phylogeny",
        "Sequence Alignment",
        "Sequence Analysis, DNA" ;
    schema1:license "Not available" ;
    schema1:name "bmge" ;
    schema1:url "https://bioweb.pasteur.fr/packages/pack@BMGE@1.12" .

