@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:fpa a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btaa262" ;
    schema1:description "Filter Pairwise Alignment filter long read mapping information to save disk space" ;
    schema1:keywords "High-Throughput Nucleotide Sequencing",
        "Sequence Analysis, DNA" ;
    schema1:license "MIT" ;
    schema1:name "fpa" ;
    schema1:url "https://github.com/natir/yacrd" .

