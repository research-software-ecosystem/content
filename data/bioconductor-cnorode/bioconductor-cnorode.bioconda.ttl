@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-cnorode a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/1752-0509-6-133" ;
    schema1:description "ODE add-on to CellNOptR" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/CNORode_1.48.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/CNORode/CNORode_1.48.0.tar.gz', 'https://bioarchive.galaxyproject.org/CNORode_1.48.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-cnorode/bioconductor-cnorode_1.48.0_src_all.tar.gz']" ;
    schema1:identifier biotools:cnorode ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-cnorode" ;
    schema1:softwareVersion "1.48.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/CNORode.html" ;
    spdx:builtFrom biotools:cnorode .

