@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:spread-phy a schema1:SoftwareApplication ;
    schema1:description "Analyze and visualize phylogeographic reconstructions" ;
    schema1:license "LGPL-3.0+" ;
    schema1:name "spread-phy" ;
    schema1:url "https://github.com/phylogeography/SPREAD" .

