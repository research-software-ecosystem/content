@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:gofasta a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btg412" ;
    schema1:description "Some functions for working on alignments in fasta format" ;
    schema1:keywords "Biological Evolution",
        "Computer Graphics",
        "Evolution, Molecular",
        "Gene Expression Profiling",
        "Genetics, Population",
        "Phylogeny",
        "Programming Languages",
        "User-Computer Interface" ;
    schema1:license "MIT" ;
    schema1:name "gofasta" ;
    schema1:url "https://github.com/cov-ert/gofasta" .

