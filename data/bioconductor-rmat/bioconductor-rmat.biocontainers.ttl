@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-rmat a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18129/b9.bioc.rmat" ;
    schema1:description "This package is an R version of the package MAT and contains functions to parse and merge Affymetrix BPMAP and CEL tiling array files (using C++ based Fusion SDK and Bioconductor package affxparser), normalize tiling arrays using sequence specific models, detect enriched regions from ChIP-chip experiments. Note: users should have GSL and GenomeGraphs installed. Windows users: 'consult the README file available in the inst directory of the source distribution for necessary configuration instructions'. Snow Leopard users can take advantage of increase speed with Grand Central Dispatch!" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-rmat" ;
    schema1:url "http://bioconductor.org/packages/3.5/bioc/html/rMAT.html" .

