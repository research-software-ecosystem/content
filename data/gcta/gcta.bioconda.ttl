@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:gcta a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1016/j.ajhg.2010.11.011" ;
    schema1:description "GCTA (Genome-wide Complex Trait Analysis) estimates the proportion of phenotypic variance explained by all genome-wide SNPs for complex traits." ;
    schema1:downloadUrl "https://yanglab.westlake.edu.cn/software/gcta/bin/gcta-1.94.1-linux-kernel-3-x86_64.zip",
        "https://yanglab.westlake.edu.cn/software/gcta/bin/gcta-1.94.1-macOS-x86_64.zip" ;
    schema1:identifier biotools:gcta ;
    schema1:license "GPL-3.0-only" ;
    schema1:name "gcta" ;
    schema1:softwareVersion "1.94.1" ;
    schema1:url "https://yanglab.westlake.edu.cn/software/gcta" ;
    spdx:builtFrom biotools:gcta .

