@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-annotationforge a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Provides code for generating annotation packages and their databases. packages produced are intended to be used with annotationdbi." ;
    schema1:identifier biotools:annotationforge ;
    schema1:keywords "Computational Biology",
        "Data integration and warehousing",
        "Database management",
        "Gene Expression Profiling",
        "Genomics",
        "High-Throughput Screening Assays",
        "Programming Languages",
        "User-Computer Interface" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-annotationforge" ;
    schema1:url "http://bioconductor.org/packages/release/bioc/html/AnnotationForge.html" .

