@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-annotationforge a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Tools for building SQLite-based annotation data packages" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/AnnotationForge_1.52.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/AnnotationForge/AnnotationForge_1.52.0.tar.gz', 'https://bioarchive.galaxyproject.org/AnnotationForge_1.52.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-annotationforge/bioconductor-annotationforge_1.52.0_src_all.tar.gz']" ;
    schema1:identifier biotools:annotationforge ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-annotationforge" ;
    schema1:softwareVersion "1.52.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/AnnotationForge.html" ;
    spdx:builtFrom biotools:annotationforge .

