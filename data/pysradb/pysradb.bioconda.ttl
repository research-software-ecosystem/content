@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:pysradb a schema1:SoftwareApplication ;
    schema1:author "saketkc" ;
    schema1:citation "doi:10.12688/f1000research.18676.1" ;
    schema1:description "Python package for retrieving metadata and downloading datasets from SRA/ENA/GEO" ;
    schema1:downloadUrl "https://pypi.io/packages/source/p/pysradb/pysradb-2.5.1.tar.gz" ;
    schema1:identifier biotools:pysradb ;
    schema1:license "BSD-3-Clause" ;
    schema1:maintainer "saketkc" ;
    schema1:name "pysradb" ;
    schema1:softwareHelp "https://saketkc.github.io/pysradb" ;
    schema1:softwareVersion "2.5.1" ;
    schema1:url "https://github.com/saketkc/pysradb" ;
    spdx:builtFrom biotools:pysradb .

