@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:pysradb a schema1:SoftwareApplication ;
    schema1:citation "doi:10.12688/f1000research.18676.1" ;
    schema1:description "Python package to query next-generation sequencing metadata and data from ncbi sequence read archive." ;
    schema1:identifier biotools:pysradb ;
    schema1:keywords "Bioinformatics",
        "Databases, Factual",
        "Gene transcripts",
        "High-Throughput Nucleotide Sequencing",
        "Metadata",
        "RNA-Seq",
        "Reproducibility of Results",
        "Sequencing" ;
    schema1:license "BSD-3-Clause" ;
    schema1:name "pysradb" ;
    schema1:url "https://github.com/saketkc/pysradb" .

