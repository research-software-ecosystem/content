@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:python-pbconsensuscore a schema1:SoftwareApplication ;
    schema1:description "ConsensusCore is a library of C++ algorithms for Pacific Biosciences multiple sequence consensus that powers Quiver (Python) and ConsensusTools (.NET). This library primarily exists as the backend for GenomicConsensus, which implements Quiver." ;
    schema1:license "Custom License" ;
    schema1:name "python-pbconsensuscore" ;
    schema1:url "https://github.com/PacificBiosciences/ConsensusCore" .

