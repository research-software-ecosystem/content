@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-cummerbund a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nprot.2012.016" ;
    schema1:description "Analysis, exploration, manipulation, and visualization of Cufflinks high-throughput sequencing data." ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/cummeRbund_2.48.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/cummeRbund/cummeRbund_2.48.0.tar.gz', 'https://bioarchive.galaxyproject.org/cummeRbund_2.48.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-cummerbund/bioconductor-cummerbund_2.48.0_src_all.tar.gz']" ;
    schema1:identifier biotools:cummerbund ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-cummerbund" ;
    schema1:softwareVersion "2.48.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/cummeRbund.html" ;
    spdx:builtFrom biotools:cummerbund .

