@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-cummerbund a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nprot.2012.016" ;
    schema1:description "Allows for persistent storage, access, exploration, and manipulation of cufflinks high-throughput sequencing data. in addition, provides numerous plotting functions for commonly used visualizations." ;
    schema1:identifier biotools:cummerbund ;
    schema1:keywords "Clustering",
        "DNA, Complementary",
        "Gene Expression Profiling",
        "Genetic Association Studies",
        "Genomics",
        "Sequence Analysis, DNA",
        "Sequencing" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-cummerbund" ;
    schema1:url "http://bioconductor.org/packages/release/bioc/html/cummeRbund.html" .

