@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-seqpattern a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Visualising oligonucleotide patterns and motif occurrences across a set of sorted sequences" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/seqPattern_1.38.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/seqPattern/seqPattern_1.38.0.tar.gz', 'https://bioarchive.galaxyproject.org/seqPattern_1.38.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-seqpattern/bioconductor-seqpattern_1.38.0_src_all.tar.gz']" ;
    schema1:identifier biotools:seqpattern ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-seqpattern" ;
    schema1:softwareVersion "1.38.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/seqPattern.html" ;
    spdx:builtFrom biotools:seqpattern .

