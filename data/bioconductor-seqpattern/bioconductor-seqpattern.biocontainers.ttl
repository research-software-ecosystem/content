@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-seqpattern a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Visualising oligonucleotide patterns and motif occurrences across a set of sorted sequences" ;
    schema1:identifier biotools:seqpattern ;
    schema1:keywords "Computational Biology",
        "Gene Expression Profiling",
        "Genomics",
        "High-Throughput Screening Assays",
        "Programming Languages",
        "Sequence sites, features and motifs",
        "User-Computer Interface" ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-seqpattern" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/seqPattern.html" .

