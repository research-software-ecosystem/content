@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:pybda a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s12859-019-3087-8" ;
    schema1:description "Big biological data analytics powered by Apache Spark" ;
    schema1:keywords "Automation",
        "Clustering",
        "Computational Biology",
        "Computing Methodologies",
        "HeLa Cells",
        "Humans",
        "Image Processing, Computer-Assisted",
        "Machine Learning" ;
    schema1:license "GPL-3.0" ;
    schema1:name "pybda" ;
    schema1:url "https://github.com/cbg-ethz/pybda" .

