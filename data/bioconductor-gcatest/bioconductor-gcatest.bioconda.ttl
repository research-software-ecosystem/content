@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-gcatest a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1101/012682" ;
    schema1:description "Genotype Conditional Association TEST" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/gcatest_2.6.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/gcatest/gcatest_2.6.0.tar.gz', 'https://bioarchive.galaxyproject.org/gcatest_2.6.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-gcatest/bioconductor-gcatest_2.6.0_src_all.tar.gz']" ;
    schema1:identifier biotools:gcatest ;
    schema1:license "GPL (>= 3)" ;
    schema1:name "bioconductor-gcatest" ;
    schema1:softwareVersion "2.6.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/gcatest.html" ;
    spdx:builtFrom biotools:gcatest .

