@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-scimpute a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/s41467-018-03405-7" ;
    schema1:description "scImpute is accurate and robust imputation of single-cell RNA sequencing data." ;
    schema1:keywords "Animals",
        "Clustering",
        "Data Interpretation, Statistical",
        "Gene Expression",
        "Gene Expression Profiling",
        "Humans",
        "RNA",
        "RNA-Seq",
        "Sequence Analysis, RNA",
        "Single-Cell Analysis" ;
    schema1:license "GPL" ;
    schema1:name "r-scimpute" ;
    schema1:url "https://github.com/Vivianstats/scImpute" .

