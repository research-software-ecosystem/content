@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:rtg-tools a schema1:SoftwareApplication ;
    schema1:description "RealTimeGenomics Tools -- Utilities for accurate VCF comparison and manipulation." ;
    schema1:downloadUrl "https://github.com/RealTimeGenomics/rtg-tools/releases/download/3.13/rtg-tools-3.13-nojre.zip" ;
    schema1:identifier biotools:rtg_core ;
    schema1:license "BSD-2-Clause" ;
    schema1:name "rtg-tools" ;
    schema1:softwareHelp "https://realtimegenomics.github.io/rtg-tools/index.html" ;
    schema1:softwareVersion "3.13" ;
    schema1:url "https://github.com/RealTimeGenomics/rtg-tools" ;
    spdx:builtFrom biotools:rtg_core .

