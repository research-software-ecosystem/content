@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-flowploidy a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Analyze flow cytometer data to determine sample ploidy" ;
    schema1:identifier biotools:flowploidy ;
    schema1:keywords "Cell biology",
        "Computational Biology",
        "Gene Expression Profiling",
        "Genomics",
        "High-Throughput Screening Assays",
        "Programming Languages",
        "User-Computer Interface" ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-flowploidy" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/flowPloidy.html" .

