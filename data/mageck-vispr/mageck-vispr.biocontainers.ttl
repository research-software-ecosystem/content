@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:mageck-vispr a schema1:SoftwareApplication ;
    schema1:description "Mageck-vispr is a comprehensive quality control, analysis and visualization workflow for crispr/cas9 screens based on mageck, vispr, snakemake, fastqc and cutadapt." ;
    schema1:license "MIT" ;
    schema1:name "mageck-vispr" ;
    schema1:url "https://bitbucket.org/liulab/mageck-vispr" .

