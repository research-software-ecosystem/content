@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-sights a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1177/1087057114548853" ;
    schema1:description "Suite of normalization methods, statistical tests, and diagnostic graphical tools for high throughput screening (hts) assays. hts assays use microtitre plates to screen large libraries of compounds for their biological, chemical, or biochemical activity." ;
    schema1:identifier biotools:sights ;
    schema1:keywords "Automation",
        "Compound libraries and screening",
        "Data quality management",
        "Data visualisation",
        "Drug Discovery",
        "HeLa Cells",
        "High-Throughput Screening Assays",
        "Humans",
        "Models, Statistical",
        "Quality Control",
        "Reproducibility of Results",
        "Small Molecule Libraries",
        "Statistics and probability" ;
    schema1:license "GPL-3.0" ;
    schema1:name "bioconductor-sights" ;
    schema1:url "http://bioconductor.org/packages/release/bioc/html/sights.html" .

