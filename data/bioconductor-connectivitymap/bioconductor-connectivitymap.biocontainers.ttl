@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-connectivitymap a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18129/b9.bioc.connectivitymap" ;
    schema1:description "Functional connections between drugs, genes and diseases as revealed by common gene-expression changes" ;
    schema1:keywords "Gene Expression" ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-connectivitymap" ;
    schema1:url "https://bioconductor.org/packages/3.8/data/experiment/html/ConnectivityMap.html" .

