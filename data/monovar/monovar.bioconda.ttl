@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:monovar a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3835" ;
    schema1:description "single cell joint genotyper" ;
    schema1:downloadUrl "https://bitbucket.org/dlaehnemann/monovar/get/v0.0.1.tar.gz" ;
    schema1:identifier biotools:Monovar ;
    schema1:license "MIT" ;
    schema1:name "monovar" ;
    schema1:softwareVersion "0.0.1" ;
    schema1:url "https://bitbucket.org/hamimzafar/monovar" ;
    spdx:builtFrom biotools:Monovar .

