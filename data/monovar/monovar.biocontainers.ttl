@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:monovar a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3835" ;
    schema1:description "Single cell joint genotyper" ;
    schema1:identifier biotools:Monovar ;
    schema1:keywords "Benchmarking",
        "Cell Line",
        "Exome",
        "Genetic variation",
        "Genomics",
        "High-Throughput Nucleotide Sequencing",
        "Humans",
        "Polymorphism, Single Nucleotide",
        "Sensitivity and Specificity",
        "Sequence Analysis, DNA",
        "Single-Cell Analysis" ;
    schema1:license "MIT" ;
    schema1:name "monovar" ;
    schema1:url "https://bitbucket.org/hamimzafar/monovar" .

