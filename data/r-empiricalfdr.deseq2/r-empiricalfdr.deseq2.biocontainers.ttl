@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-empiricalfdr.deseq2 a schema1:SoftwareApplication ;
    schema1:description "Auxiliary functions for the deseq2 package to simulate read counts according to the null hypothesis (i.e., with empirical sample size factors, per-gene total counts and dispersions, but without effects of predictor variables) and to compute the empirical false discovery rate." ;
    schema1:keywords "RNA-Seq" ;
    schema1:license "GPL-3" ;
    schema1:name "r-empiricalfdr.deseq2" ;
    schema1:url "https://CRAN.R-project.org/package=empiricalFDR.DESeq2" .

