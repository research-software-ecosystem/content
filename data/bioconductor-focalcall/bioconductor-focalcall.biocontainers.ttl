@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-focalcall a schema1:SoftwareApplication ;
    schema1:citation "doi:10.4137/cin.s19519" ;
    schema1:description "Detection of focal aberrations in DNA copy number data" ;
    schema1:identifier biotools:focalcall ;
    schema1:keywords "DNA",
        "Sequence analysis" ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-focalcall" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/focalCall.html" .

