@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-methylpipe a schema1:SoftwareApplication ;
    schema1:description "Base resolution DNA methylation data analysis" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/methylPipe_1.44.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/methylPipe/methylPipe_1.44.0.tar.gz', 'https://bioarchive.galaxyproject.org/methylPipe_1.44.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-methylpipe/bioconductor-methylpipe_1.44.0_src_all.tar.gz']" ;
    schema1:identifier biotools:methylpipe ;
    schema1:license "GPL(>=2)" ;
    schema1:name "bioconductor-methylpipe" ;
    schema1:softwareVersion "1.44.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/methylPipe.html" ;
    spdx:builtFrom biotools:methylpipe .

