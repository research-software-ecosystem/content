@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-methylpipe a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s12859-015-0742-6" ;
    schema1:description "Base resolution DNA methylation data analysis" ;
    schema1:identifier biotools:methylpipe ;
    schema1:keywords "CpG Islands",
        "DNA",
        "DNA Methylation",
        "Epigenomics",
        "Genetics",
        "High-Throughput Nucleotide Sequencing",
        "Histone Code",
        "Internet",
        "RNA",
        "Sequence Analysis, DNA",
        "Transcription Factors",
        "Transcription factors and regulatory sites",
        "User-Computer Interface" ;
    schema1:license "GPL(>=2)" ;
    schema1:name "bioconductor-methylpipe" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/methylPipe.html" .

