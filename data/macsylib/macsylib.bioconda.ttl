@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:macsylib a schema1:SoftwareApplication ;
    schema1:author "bneron" ;
    schema1:citation "doi:10.24072/pcjournal.250" ;
    schema1:description "MacSyLib: Python library that help to detect of macromolecular, systems genetic pathways… in prokaryotes protein datasets using systems modelling and similarity search." ;
    schema1:downloadUrl "https://pypi.org/packages/source/m/macsylib/macsylib-1.0.4.tar.gz" ;
    schema1:identifier biotools:macsylib ;
    schema1:license "GPL-3.0-or-later" ;
    schema1:maintainer "bneron" ;
    schema1:name "macsylib" ;
    schema1:softwareHelp "https://macsylib.readthedocs.io/en/latest" ;
    schema1:softwareVersion "1.0.4" ;
    schema1:url "https://github.com/gem-pasteur/macsylib" ;
    spdx:builtFrom biotools:macsylib .

