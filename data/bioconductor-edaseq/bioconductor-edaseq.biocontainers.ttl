@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-edaseq a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/1471-2105-15-188" ;
    schema1:description "Numerical and graphical summaries of rna-seq read data. within-lane normalization procedures to adjust for gc-content effect (or other gene-level effects) on read counts: loess robust local regression, global-scaling, and full-quantile normalization (risso et al., 2011). between-lane normalization procedures to adjust for distributional differences between lanes (e.g., sequencing depth): global-scaling and full-quantile normalization (bullard et al., 2010)." ;
    schema1:identifier biotools:edaseq ;
    schema1:keywords "Animals",
        "Calibration",
        "Gene Expression Profiling",
        "High-Throughput Nucleotide Sequencing",
        "Humans",
        "RNA",
        "RNA-Seq",
        "RNA-seq",
        "Sequence Analysis, RNA",
        "Sequence analysis",
        "Transcription, Genetic" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-edaseq" ;
    schema1:url "http://bioconductor.org/packages/release/bioc/html/EDASeq.html" .

