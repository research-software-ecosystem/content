@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-edaseq a schema1:SoftwareApplication ;
    schema1:description "Exploratory Data Analysis and Normalization for RNA-Seq" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/EDASeq_2.40.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/EDASeq/EDASeq_2.40.0.tar.gz', 'https://bioarchive.galaxyproject.org/EDASeq_2.40.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-edaseq/bioconductor-edaseq_2.40.0_src_all.tar.gz']" ;
    schema1:identifier biotools:edaseq ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-edaseq" ;
    schema1:softwareVersion "2.40.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/EDASeq.html" ;
    spdx:builtFrom biotools:edaseq .

