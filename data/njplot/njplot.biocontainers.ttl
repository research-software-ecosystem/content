@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:njplot a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1016/0300-9084(96)84768-7" ;
    schema1:description "Njplot is a tool for visualizing binary trees such as the phylogenetic trees output from the phylip programs. available for several platforms including windows, macos, linux and solaris." ;
    schema1:identifier biotools:njplot ;
    schema1:keywords "Amino Acid Sequence",
        "Base Sequence",
        "Computer Communication Networks",
        "Gene expression",
        "Genetics",
        "Information Systems",
        "Molecular Sequence Data",
        "Phylogenetics",
        "Phylogeny",
        "Sequence Alignment",
        "Sequence Homology, Amino Acid",
        "Sequence analysis",
        "Sequencing" ;
    schema1:license "Artistic" ;
    schema1:name "njplot" ;
    schema1:url "http://pbil.univ-lyon1.fr/software/njplot.html" .

