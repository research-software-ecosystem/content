@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:ghostscript a schema1:SoftwareApplication ;
    schema1:description "An interpreter for the PostScript language and for PDF." ;
    schema1:license "Affero GPL" ;
    schema1:name "ghostscript" ;
    schema1:url "https://github.com/mephraim/ghostscriptsharp" .

