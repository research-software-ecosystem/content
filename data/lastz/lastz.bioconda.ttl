@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:lastz a schema1:SoftwareApplication ;
    schema1:description "LASTZ is a program for aligning DNA sequences, a pairwise aligner." ;
    schema1:downloadUrl "https://github.com/lastz/lastz/archive/refs/tags/1.04.52.tar.gz" ;
    schema1:identifier biotools:lastz ;
    schema1:license "MIT" ;
    schema1:name "lastz" ;
    schema1:softwareHelp "https://lastz.github.io/lastz" ;
    schema1:softwareVersion "1.04.52" ;
    schema1:url "https://www.bx.psu.edu/~rsharris/lastz" ;
    spdx:builtFrom biotools:lastz .

