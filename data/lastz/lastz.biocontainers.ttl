@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:lastz a schema1:SoftwareApplication ;
    schema1:description "LASTZ is a program for aligning DNA sequences, a pairwise aligner." ;
    schema1:identifier biotools:lastz ;
    schema1:keywords "Genomics" ;
    schema1:license "MIT" ;
    schema1:name "lastz" ;
    schema1:url "http://www.bx.psu.edu/~rsharris/lastz/" .

