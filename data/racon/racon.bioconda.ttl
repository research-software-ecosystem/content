@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:racon a schema1:SoftwareApplication ;
    schema1:description "Ultrafast consensus module for raw de novo genome assembly of long uncorrected reads." ;
    schema1:downloadUrl "https://github.com/lbcb-sci/racon/archive/refs/tags/1.5.0.tar.gz" ;
    schema1:identifier biotools:Racon ;
    schema1:license "MIT" ;
    schema1:name "racon" ;
    schema1:softwareHelp "https://github.com/lbcb-sci/racon/blob/1.5.0/README.md" ;
    schema1:softwareVersion "1.5.0" ;
    schema1:url "https://github.com/lbcb-sci/racon" ;
    spdx:builtFrom biotools:Racon .

