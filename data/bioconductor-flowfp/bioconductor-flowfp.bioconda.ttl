@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-flowfp a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1155/2009/193947" ;
    schema1:description "Fingerprinting for Flow Cytometry" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/flowFP_1.64.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/flowFP/flowFP_1.64.0.tar.gz', 'https://bioarchive.galaxyproject.org/flowFP_1.64.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-flowfp/bioconductor-flowfp_1.64.0_src_all.tar.gz']" ;
    schema1:identifier biotools:flowfp ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-flowfp" ;
    schema1:softwareVersion "1.64.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/flowFP.html" ;
    spdx:builtFrom biotools:flowfp .

