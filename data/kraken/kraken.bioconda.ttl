@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:kraken a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/gb-2014-15-3-r46" ;
    schema1:description "Kraken is a system for assigning taxonomic labels to short DNA sequences, usually obtained through metagenomic studies." ;
    schema1:downloadUrl "https://github.com/DerrickWood/kraken/archive/v1.1.1.tar.gz" ;
    schema1:identifier biotools:kraken ;
    schema1:license "GPL-3.0-or-later" ;
    schema1:name "kraken" ;
    schema1:softwareHelp "https://ccb.jhu.edu/software/kraken" ;
    schema1:softwareVersion "1.1.1" ;
    schema1:url "https://ccb.jhu.edu/software/kraken" ;
    spdx:builtFrom biotools:kraken .

