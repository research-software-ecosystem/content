@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:purge_dups a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btaa025" ;
    schema1:description "purge_dups is a package used to purge haplotigs and overlaps in an assembly based on read depth." ;
    schema1:downloadUrl "https://github.com/dfguan/purge_dups/archive/v1.2.6.tar.gz" ;
    schema1:identifier biotools:purge_dups ;
    schema1:license "MIT" ;
    schema1:name "purge_dups" ;
    schema1:softwareHelp "https://github.com/dfguan/purge_dups/blob/v{[ version }}/README.md" ;
    schema1:softwareVersion "1.2.6" ;
    schema1:url "https://github.com/dfguan/purge_dups" ;
    spdx:builtFrom biotools:purge_dups .

