@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-mirnatap a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "miRNAtap: microRNA Targets - Aggregated Predictions" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/miRNAtap_1.40.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/miRNAtap/miRNAtap_1.40.0.tar.gz', 'https://bioarchive.galaxyproject.org/miRNAtap_1.40.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-mirnatap/bioconductor-mirnatap_1.40.0_src_all.tar.gz']" ;
    schema1:identifier biotools:mirnatap ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-mirnatap" ;
    schema1:softwareVersion "1.40.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/miRNAtap.html" ;
    spdx:builtFrom biotools:mirnatap .

