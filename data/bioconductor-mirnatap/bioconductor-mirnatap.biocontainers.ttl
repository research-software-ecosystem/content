@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-mirnatap a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "miRNAtap: microRNA Targets - Aggregated Predictions" ;
    schema1:identifier biotools:mirnatap ;
    schema1:keywords "Computational Biology",
        "Functional, regulatory and non-coding RNA",
        "Gene Expression Profiling",
        "Genomics",
        "High-Throughput Screening Assays",
        "Human biology",
        "Microarray experiment",
        "Model organisms",
        "Programming Languages",
        "Sequencing",
        "User-Computer Interface" ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-mirnatap" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/miRNAtap.html" .

