@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:populations a schema1:SoftwareApplication ;
    schema1:description "Population genetic software" ;
    schema1:keywords "Genetics" ;
    schema1:license "GPL-2" ;
    schema1:name "populations" ;
    schema1:url "http://www.bioinformatics.org/~tryphon/populations/" .

