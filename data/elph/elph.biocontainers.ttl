@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:elph a schema1:SoftwareApplication ;
    schema1:description "Dna/protein sequence motif finder" ;
    schema1:keywords "Genomics",
        "Metagenomics",
        "Protein Sequences" ;
    schema1:license "Artistic-1.0" ;
    schema1:name "elph" ;
    schema1:url "http://www.cbcb.umd.edu/software/ELPH/" .

