@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-oncosimulr a schema1:SoftwareApplication ;
    schema1:description "Forward Genetic Simulation of Cancer Progression with Epistasis" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/OncoSimulR_4.12.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/OncoSimulR/OncoSimulR_4.12.0.tar.gz', 'https://bioarchive.galaxyproject.org/OncoSimulR_4.12.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-oncosimulr/bioconductor-oncosimulr_4.12.0_src_all.tar.gz']" ;
    schema1:identifier biotools:oncosimulr ;
    schema1:license "GPL (>= 3)" ;
    schema1:name "bioconductor-oncosimulr" ;
    schema1:softwareVersion "4.12.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/OncoSimulR.html" ;
    spdx:builtFrom biotools:oncosimulr .

