        "Cell Transformation, Neoplastic",
        "Cross-Sectional Studies",
        "Disease Progression",
        "Humans",
        "Models, Theoretical",
        "Mutation",
        "Neoplasm Proteins",
        "Neoplasms",
        "Oncology",
        "Population genetics",
        "Sample Size",
        "Simulation experiment" ;
    schema1:license "GPL (>= 3)" ;
    schema1:name "bioconductor-oncosimulr" ;
    schema1:url "http://bioconductor.org/packages/3.6/bioc/html/OncoSimulR.html" .

