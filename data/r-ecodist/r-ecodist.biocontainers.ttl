@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-ecodist a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1007/s11258-009-9641-0",
        "doi:10.18637/jss.v022.i07" ;
    schema1:description "Dissimilarity-based analysis functions including ordination and Mantel test functions, intended for use with spatial and community data." ;
