@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:biopython a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btp163" ;
    schema1:description "Python library for bioinformatics (implemented in python 3)" ;
    schema1:identifier biotools:biopython ;
    schema1:keywords "Bioinformatics",
        "Computational Biology",
        "Computational biology",
        "Data management",
        "Databases, Factual",
        "Internet",
        "Programming Languages",
        "Software engineering" ;
    schema1:license "other" ;
    schema1:name "biopython" ;
    schema1:url "http://biopython.org" .

