@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:picard a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1101/gr.107524.110" ;
    schema1:description "A set of command line tools for manipulating high-throughput sequencing (hts) data in formats such as sam/bam/cram and vcf. available as a standalone program or within the gatk4 program." ;
    schema1:identifier biotools:picard_tools ;
    schema1:keywords "Data management",
        "Sequencing" ;
    schema1:license "MIT" ;
    schema1:name "picard" ;
    schema1:url "https://github.com/broadinstitute/picard" .

