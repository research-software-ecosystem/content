  "@graph": [
    {
      "@id": "https://bio.tools/bioconductor-outrider",
      "@type": "sc:SoftwareApplication",
      "dcterms:conformsTo": "https://bioschemas.org/profiles/ComputationalTool/0.6-DRAFT",
      "sc:additionalType": [
        "Library",
        "Command-line tool"
      ],
      "sc:author": [
        "Christian Mertes",
        "Vicente Yepez",
        "Agne Matuseviciute",
        "Julien Gagneur",
        "Felix Brechtmann"
      ],
      "sc:citation": {
        "@id": "https://doi.org/10.1016/j.ajhg.2018.10.025"
      },
      "sc:contributor": [
        "Andrea Raithel",
        "Michaela Fee Müller"
      ],
      "sc:description": "Identification of aberrant gene expression in RNA-seq data. Read count expectations are modeled by an autoencoder to control for confounders in the data. Given these expectations, the RNA-seq read counts are assumed to follow a negative binomial distribution with a gene-specific dispersion. Outliers are then identified as read counts that significantly deviate from this distribution. Furthermore, OUTRIDER provides useful plotting functions to analyze and visualize the results.",
      "sc:name": "OUTRIDER",
      "sc:operatingSystem": [
        "Mac",
        "Linux",
        "Windows"
      ],
      "sc:softwareHelp": {
        "@id": "https://bioconductor.org/packages/OUTRIDER"
      },
      "sc:softwareVersion": "1.28.1",
      "sc:url": "https://bioconductor.org/packages/OUTRIDER"
    },
    {
      "@id": "https://doi.org/10.1016/j.ajhg.2018.10.025",
      "@type": "sc:CreativeWork"
    }
  ]
