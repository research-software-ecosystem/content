@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:checkv a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/s41587-020-00774-7" ;
    schema1:description "Assess the quality of metagenome-assembled viral genomes." ;
    schema1:downloadUrl "https://pypi.io/packages/source/c/checkv/checkv-1.1.1.tar.gz" ;
    schema1:identifier biotools:checkv ;
    schema1:license "BSD-3-Clause-LBNL" ;
    schema1:name "checkv" ;
    schema1:softwareVersion "1.1.1" ;
    schema1:url "https://bitbucket.org/berkeleylab/checkv" ;
    spdx:builtFrom biotools:checkv .

