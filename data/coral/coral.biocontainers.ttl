@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:coral a schema1:SoftwareApplication ;
    schema1:description "Coral is an efficient tool to bridge paire-end RNA-seq reads." ;
    schema1:identifier biotools:coral ;
    schema1:keywords "Genomics",
        "RNA-Seq",
        "Sequence analysis",
        "Transcriptome" ;
    schema1:license "BSD-3-Clause" ;
    schema1:name "coral" ;
    schema1:url "https://github.com/Shao-Group/coral" .

