@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:odgi a schema1:SoftwareApplication ;
    schema1:author "AndreaGuarracino" ;
    schema1:citation "doi:10.1093/bioinformatics/btac308" ;
    schema1:description "An optimized dynamic genome/graph implementation." ;
    schema1:downloadUrl "https://github.com/pangenome/odgi/releases/download/v0.9.4/odgi-v0.9.4.tar.gz" ;
    schema1:identifier biotools:odgi ;
    schema1:license "MIT" ;
    schema1:maintainer "AndreaGuarracino" ;
    schema1:name "odgi" ;
    schema1:softwareHelp "https://github.com/pangenome/odgi/blob/v0.9.4/README.md" ;
    schema1:softwareVersion "0.9.4" ;
    schema1:url "https://github.com/pangenome/odgi" ;
    spdx:builtFrom biotools:odgi .

