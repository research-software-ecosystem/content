@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:trimmomatic a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btu170",
        "doi:10.1093/nar/gks540" ;
    schema1:description "A flexible read trimming tool for illumina ngs data" ;
    schema1:identifier biotools:trimmomatic ;
    schema1:keywords "Computational Biology",
        "Data quality management",
        "Databases, Genetic",
        "Genetics",
        "High-Throughput Nucleotide Sequencing",
        "Sequence analysis",
        "Sequencing" ;
    schema1:license "GPL-3.0" ;
    schema1:name "trimmomatic" ;
    schema1:url "http://www.usadellab.org/cms/index.php?page=trimmomatic" .

