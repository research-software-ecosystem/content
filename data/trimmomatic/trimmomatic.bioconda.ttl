@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:trimmomatic a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btu170" ;
    schema1:description "A flexible read trimming tool for Illumina NGS data." ;
    schema1:downloadUrl "https://github.com/usadellab/Trimmomatic/releases/download/v0.40/Trimmomatic-0.40.zip" ;
    schema1:identifier biotools:trimmomatic ;
    schema1:license "GPL-3.0-or-later" ;
    schema1:name "trimmomatic" ;
    schema1:softwareHelp "https://www.plabipd.de/trimmomatic_main.html" ;
    schema1:softwareVersion "0.4" ;
    schema1:url "https://www.plabipd.de/trimmomatic_main.html" ;
    spdx:builtFrom biotools:trimmomatic .

