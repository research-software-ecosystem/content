@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-ntw a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btq629" ;
    schema1:description "Predict gene network using an Ordinary Differential Equation (ODE) based method" ;
    schema1:identifier biotools:ntw ;
    schema1:keywords "Bifidobacterium",
        "Gene Regulatory Networks",
        "Genetics",
        "Molecular interactions, pathways and networks",
        "Transcription factors and regulatory sites" ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-ntw" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/NTW.html" .

