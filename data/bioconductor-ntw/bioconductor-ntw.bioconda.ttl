@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-ntw a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btq629" ;
    schema1:description "Predict gene network using an Ordinary Differential Equation (ODE) based method" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/NTW_1.56.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/NTW/NTW_1.56.0.tar.gz', 'https://bioarchive.galaxyproject.org/NTW_1.56.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-ntw/bioconductor-ntw_1.56.0_src_all.tar.gz']" ;
    schema1:identifier biotools:ntw ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-ntw" ;
    schema1:softwareVersion "1.56.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/NTW.html" ;
    spdx:builtFrom biotools:ntw .

