@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-abaenrichment a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btw392" ;
    schema1:description "Gene expression enrichment in human brain regions" ;
    schema1:identifier biotools:abaenrichment ;
    schema1:keywords "Adult",
        "Brain",
        "Gene Expression",
        "Gene expression",
        "Humans",
        "Neurobiology" ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-abaenrichment" ;
    schema1:url "http://bioconductor.org/packages/3.6/bioc/html/ABAEnrichment.html" .

