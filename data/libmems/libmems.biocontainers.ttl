@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:libmems a schema1:SoftwareApplication ;
    schema1:description "libMems is a freely available software development library to support DNA string matching and comparative genomics." ;
    schema1:keywords "Genomics" ;
    schema1:license "GPL-2.0" ;
    schema1:name "libmems" ;
    schema1:url "https://github.com/koadman/libMems" .

