@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:duphold a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/gigascience/giz040" ;
    schema1:description "SV callers like lumpy look at split-reads and pair distances to find structural variants. This tool is a fast way to add depth information to those calls." ;
    schema1:keywords "Genetics",
        "Genomics" ;
    schema1:license "MIT" ;
    schema1:name "duphold" ;
    schema1:url "https://github.com/brentp/duphold" .

