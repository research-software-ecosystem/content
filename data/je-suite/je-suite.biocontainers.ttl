@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:je-suite a schema1:SoftwareApplication ;
    schema1:description "Je is a suite to handle barcoded fastq files with (or without) unique molecule identifiers (umis) and filter read duplicates using these umis" ;
    schema1:license "MIT" ;
    schema1:name "je-suite" ;
    schema1:url "https://gbcs.embl.de/Je" .

