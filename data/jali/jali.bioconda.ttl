@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:jali a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1089/106652702761034172" ;
    schema1:description "Alignment method for comparing a protein sequence to a protein family, represented by a multiple alignment. It can also be used for sensitive protein database searches. The algorithm is a generalization of the Smith-Waterman algorithm." ;
    schema1:downloadUrl "https://bibiserv.cebitec.uni-bielefeld.de/applications/jali/resources/downloads/jali-1.3.src.tar.gz" ;
    schema1:identifier biotools:jali ;
    schema1:license "file" ;
    schema1:name "jali" ;
    schema1:softwareVersion "1.3" ;
    schema1:url "http://bibiserv.cebitec.uni-bielefeld.de/jali" ;
    spdx:builtFrom biotools:jali .

