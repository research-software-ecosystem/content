@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:translatorx a schema1:SoftwareApplication ;
    schema1:description "Multiple alignment of nucleotide sequences guided by amino acid information" ;
    schema1:downloadUrl "http://pc16141.mncn.csic.es/cgi-bin/translatorx_vLocal.pl" ;
    schema1:identifier biotools:translatorx ;
    schema1:license "unknown" ;
    schema1:name "translatorx" ;
    schema1:softwareVersion "1.1" ;
    schema1:url "http://pc16141.mncn.csic.es/" ;
    spdx:builtFrom biotools:translatorx .

