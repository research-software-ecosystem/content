@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:burst a schema1:SoftwareApplication ;
    schema1:citation "doi:10.5281/zenodo.806850" ;
    schema1:description "Burst (formerly known as embalmer) is an optimal, high-speed pairwise sequence aligner specialized in aligning many ngs short reads against large reference databases." ;
    schema1:keywords "Clustering" ;
    schema1:license "Not available" ;
    schema1:name "burst" ;
    schema1:url "https://github.com/knights-lab/BURST" .

