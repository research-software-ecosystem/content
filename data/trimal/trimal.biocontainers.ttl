@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:trimal a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btp348" ;
    schema1:description "A tool for the automated removal of spurious sequences or poorly aligned regions from a multiple sequence alignment" ;
    schema1:identifier biotools:trimAl ;
    schema1:keywords "Computational Biology",
        "Genomics",
        "Phylogeny",
        "Sequence Alignment",
        "Sequence Analysis, Protein",
        "Sequence analysis",
        "Sequence sites, features and motifs",
        "Sequencing",
        "User-Computer Interface" ;
    schema1:license "GPL-3.0" ;
    schema1:name "trimal" ;
    schema1:url "http://trimal.cgenomics.org" .

