@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:trimal a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btp348" ;
    schema1:description "A tool for the automated removal of spurious sequences or poorly aligned regions from a multiple sequence alignment" ;
    schema1:downloadUrl "https://github.com/inab/trimal/archive/refs/tags/v1.5.1.tar.gz" ;
    schema1:identifier biotools:trimAl ;
    schema1:license "GPL-3.0-or-later" ;
    schema1:name "trimal" ;
    schema1:softwareHelp "https://trimal.readthedocs.io" ;
    schema1:softwareVersion "1.5.1" ;
    schema1:url "https://trimal.readthedocs.io" ;
    spdx:builtFrom biotools:trimAl .

