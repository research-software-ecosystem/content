@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:fastindep a schema1:SoftwareApplication ;
    schema1:description "A fast random heuristic algorithm for identifying large sets of unrelated individuals and unrelated markers" ;
    schema1:license "MIT" ;
    schema1:name "fastindep" ;
    schema1:url "https://github.com/endrebak/fastindep" .

