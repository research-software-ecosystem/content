@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:mango a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btv336" ;
    schema1:description "A scalable genomic visualization tool" ;
    schema1:identifier biotools:mango ;
    schema1:keywords "Chromatin",
        "Chromatin Immunoprecipitation",
        "Humans",
        "K562 Cells",
        "Nucleic Acid Conformation",
        "Sequence Analysis, DNA",
        "Statistics and probability",
        "Statistics as Topic",
        "Structural genomics" ;
    schema1:license "Apache-2.0" ;
    schema1:name "mango" ;
    schema1:url "https://github.com/bdgenomics/mango" .

