@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:correlationplus a schema1:SoftwareApplication ;
    schema1:description "Python package to plot and analyze dynamical correlations maps of proteins." ;
    schema1:identifier biotools:correlationplus ;
    schema1:keywords "Protein interactions",
        "Protein sites, features and motifs",
        "Protein structural motifs and surfaces" ;
    schema1:license "Not available" ;
    schema1:name "correlationplus" ;
    schema1:url "https://github.com/tekpinar/correlationplus" .

