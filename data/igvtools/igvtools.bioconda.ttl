@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:igvtools a schema1:SoftwareApplication ;
    schema1:description "Command line tools for IGV" ;
    schema1:downloadUrl "http://data.broadinstitute.org/igv/projects/downloads/2.17/IGV_2.17.3.zip" ;
    schema1:identifier biotools:IGVtools ;
    schema1:license "MIT" ;
    schema1:name "igvtools" ;
    schema1:softwareVersion "2.17.3" ;
    schema1:url "http://www.broadinstitute.org/igv/" ;
    spdx:builtFrom biotools:IGVtools .

