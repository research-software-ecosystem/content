@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:igvtools a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bib/bbs017" ;
    schema1:description "Command line tools for igv" ;
    schema1:identifier biotools:IGVtools ;
    schema1:keywords "Computational Biology",
        "Computer Graphics",
        "Data Display",
        "Data Mining",
        "Databases, Genetic",
        "Genomics",
        "High-Throughput Nucleotide Sequencing",
        "Humans",
        "Information Storage and Retrieval",
        "Sequence Alignment",
        "Sequence analysis",
        "User-Computer Interface" ;
    schema1:license "MIT" ;
    schema1:name "igvtools" ;
    schema1:url "http://www.broadinstitute.org/igv/" .

