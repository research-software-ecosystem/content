    schema1:description "ultraheatmaps facilitates the production of deepTools heatmaps" ;
    schema1:keywords "Clustering",
        "Gene Expression" ;
    schema1:license "MIT" ;
    schema1:name "ultraheatmap" ;
    schema1:url "https://github.com/maxplanck-ie/ultraheatmap/" .

