@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:gmap-fusion a schema1:SoftwareApplication ;
    schema1:description "Gmap-fusion is a utility for identifying candidate fusion transcripts based on transcript sequences reconstructed via rna-seq de novo transcriptome assembly." ;
    schema1:license "BSD 3-Clause \"New\" or \"Revised\" License" ;
    schema1:name "gmap-fusion" ;
    schema1:url "https://github.com/GMAP-fusion/GMAP-fusion" .

