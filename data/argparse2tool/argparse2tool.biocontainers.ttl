@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:argparse2tool a schema1:SoftwareApplication ;
    schema1:description "Instrument for forming galaxy xml and cwl tool descriptions from argparse arguments" ;
    schema1:license "Not available" ;
    schema1:name "argparse2tool" ;
    schema1:url "https://github.com/erasche/argparse2tool" .

