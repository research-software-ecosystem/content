@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-imagehts a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Analysis of high-throughput microscopy-based screens" ;
    schema1:identifier biotools:imagehts ;
    schema1:keywords "Biological imaging",
        "Computational Biology",
        "Data visualisation",
        "Gene Expression Profiling",
        "Genomics",
        "High-Throughput Screening Assays",
        "Programming Languages",
        "User-Computer Interface" ;
    schema1:license "LGPL-2.1" ;
    schema1:name "bioconductor-imagehts" ;
    schema1:url "https://bioconductor.org/packages/release/bioc/html/imageHTS.html" .

