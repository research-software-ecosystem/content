@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:minvar a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1016/j.jviromet.2016.11.008" ;
    schema1:description "A tool to detect minority variants in hiv-1 and hcv populations" ;
    schema1:keywords "Anti-HIV Agents",
        "Drug Resistance, Viral",
        "Genotype",
        "HIV Infections",
        "HIV-1",
        "High-Throughput Nucleotide Sequencing",
        "Humans",
        "INDEL Mutation",
        "Microbial Sensitivity Tests",
        "Mutation",
        "Sequence Analysis, DNA" ;
    schema1:license "See relevant page on documentation website" ;
    schema1:name "minvar" ;
    schema1:url "https://git.io/minvar" .

