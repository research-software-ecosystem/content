  "@graph": [
    {
      "@id": "https://bio.tools/bioconductor-tidysinglecellexperiment",
      "@type": "sc:SoftwareApplication",
      "dcterms:conformsTo": "https://bioschemas.org/profiles/ComputationalTool/0.6-DRAFT",
      "sc:additionalType": [
        "Library",
        "Command-line tool"
      ],
      "sc:author": "Stefano Mangiola",
      "sc:citation": {
        "@id": "https://doi.org/10.1038/s41592-024-02299-2"
      },
      "sc:description": "'tidySingleCellExperiment' is an adapter that abstracts the 'SingleCellExperiment' container in the form of a 'tibble'. This allows *tidy* data manipulation, nesting, and plotting. For example, a 'tidySingleCellExperiment' is directly compatible with functions from 'tidyverse' packages `dplyr` and `tidyr`, as well as plotting with `ggplot2` and `plotly`. In addition, the package provides various utility functions specific to single-cell omics data analysis (e.g., aggregation of cell-level data to pseudobulks).",
      "sc:license": "GPL-3.0-only",
      "sc:name": "tidySingleCellExperiment",
      "sc:operatingSystem": [
        "Windows",
        "Mac",
        "Linux"
      ],
      "sc:softwareHelp": {
        "@id": "https://bioconductor.org/packages/tidySingleCellExperiment"
      },
      "sc:softwareVersion": "1.20.1",
      "sc:url": "https://bioconductor.org/packages/tidySingleCellExperiment"
    },
    {
      "@id": "https://doi.org/10.1038/s41592-024-02299-2",
      "@type": "sc:CreativeWork"
    }
