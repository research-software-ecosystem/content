@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:sspace a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btq683" ;
    schema1:description "Stand-alone scaffolder of pre-assembled contigs using paired-read data." ;
    schema1:identifier biotools:sspace ;
    schema1:keywords "Contig Mapping",
        "Gene Expression",
        "Gene Library",
        "Genetics",
        "Genome",
        "Genomics",
        "Metagenomics",
        "RNA-Seq",
        "Sequence Analysis, DNA",
        "Transcriptome",
        "Transcriptomics" ;
    schema1:license "GPL-2+" ;
    schema1:name "sspace" ;
    schema1:url "https://www.baseclear.com/genomics/bioinformatics/basetools/SSPACE" .

