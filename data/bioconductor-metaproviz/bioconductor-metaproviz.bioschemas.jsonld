      "sc:citation": {
        "@id": "https://doi.org/10.1101/2025.08.18.670781"
      },
      "sc:contributor": "Christina Schmidt",
      "sc:description": "MetaProViz can analyse standard metabolomics and exometabolomics data (CoRe). It performs pre-processing including feature filtering, missing value imputation, normalisation and outlier detection. It performs functional analysis including differential metabolite analysis (DMA), clustering based on regulatory rules (MCA) and contains different visualisation methods to extract biological interpretable graphs and saves them in a publication ready format.",
      "sc:license": "BSD-3-Clause",
      "sc:name": "MetaProViz",
      "sc:operatingSystem": [
        "Linux",
        "Windows",
        "Mac"
      ],
