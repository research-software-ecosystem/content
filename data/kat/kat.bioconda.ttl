@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:kat a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btw663" ;
    schema1:description "KAT is a suite of tools that analyse jellyfish hashes or sequence files (fasta or fastq) using kmer counts." ;
    schema1:downloadUrl "https://github.com/TGAC/KAT/archive/Release-2.4.2.tar.gz" ;
    schema1:identifier biotools:kat ;
    schema1:license "GPL-3.0-or-later" ;
    schema1:name "kat" ;
    schema1:softwareHelp "https://kat.readthedocs.io/en/latest" ;
    schema1:softwareVersion "2.4.2" ;
    schema1:url "https://github.com/TGAC/KAT" ;
    spdx:builtFrom biotools:kat .

