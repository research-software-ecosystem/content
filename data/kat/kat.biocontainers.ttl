@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:kat a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btw663" ;
    schema1:description "KAT is a suite of tools that analyse jellyfish hashes or sequence files (fasta or fastq) using kmer counts" ;
    schema1:identifier biotools:KAT ;
    schema1:keywords "Fraxinus",
        "Genome, Plant",
        "Genomics",
        "High-Throughput Nucleotide Sequencing",
        "Quality Control",
        "Sequence Analysis, DNA",
        "Sequence analysis" ;
    schema1:license "GPL-3.0" ;
    schema1:name "kat" ;
    schema1:url "https://github.com/TGAC/KAT" .

