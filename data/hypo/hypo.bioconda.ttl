@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:hypo a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1101/2019.12.19.882506" ;
    schema1:description "Super Fast and Accurate Polisher for Long Read Genome Assemblies." ;
    schema1:downloadUrl "https://github.com/kensung-lab/hypo/releases/download/v1.0.3/hypo-v1.0.3.tar.gz" ;
    schema1:identifier biotools:hypo ;
    schema1:license "GPL-3.0-or-later" ;
    schema1:name "hypo" ;
    schema1:softwareHelp "https://github.com/kensung-lab/hypo/blob/v1.0.3/README.md" ;
    schema1:softwareVersion "1.0.3" ;
    schema1:url "https://github.com/kensung-lab/hypo" ;
    spdx:builtFrom biotools:hypo .

