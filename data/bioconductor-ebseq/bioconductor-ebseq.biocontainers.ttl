@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-ebseq a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btt087" ;
    schema1:description "Differential expression analysis at both gene and isoform level using rna-seq data." ;
    schema1:identifier biotools:ebseq ;
    schema1:keywords "Bayes Theorem",
        "Cell Line",
        "Embryonic Stem Cells",
        "Gene Expression Profiling",
        "Gene expression",
        "Genome",
        "Models, Statistical",
        "Molecular interactions, pathways and networks",
        "RNA Isoforms",
        "RNA, Messenger",
        "RNA-Seq",
        "Sequence Analysis, RNA",
        "Statistics and probability" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-ebseq" ;
    schema1:url "http://bioconductor.org/packages/release/bioc/html/EBSeq.html" .

