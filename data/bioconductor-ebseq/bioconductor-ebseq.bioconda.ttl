@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-ebseq a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btt087" ;
    schema1:description "An R package for gene and isoform differential expression analysis of RNA-seq data" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/EBSeq_2.4.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/EBSeq/EBSeq_2.4.0.tar.gz', 'https://bioarchive.galaxyproject.org/EBSeq_2.4.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-ebseq/bioconductor-ebseq_2.4.0_src_all.tar.gz']" ;
    schema1:identifier biotools:ebseq ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-ebseq" ;
    schema1:softwareVersion "2.4.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/EBSeq.html" ;
    spdx:builtFrom biotools:ebseq .

