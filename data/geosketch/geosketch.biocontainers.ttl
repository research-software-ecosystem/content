@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:geosketch a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1016/j.cels.2019.05.003" ;
    schema1:description "Geometry-preserving random sampling" ;
    schema1:keywords "Animals",
        "Data Analysis",
        "Datasets as Topic",
        "Genetic Heterogeneity",
        "Humans",
        "Macrophages",
        "RNA-Seq",
        "Single-Cell Analysis",
        "Transcriptome" ;
    schema1:license "MIT" ;
    schema1:name "geosketch" ;
    schema1:url "https://github.com/brianhie/geosketch/" .

