@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:assembly_finder a schema1:SoftwareApplication ;
    schema1:author "farchaab",
        "tpillone" ;
    schema1:description "Snakemake-powered cli pipeline to download genomes with NCBI datasets" ;
    schema1:downloadUrl "https://github.com/metagenlab/assembly_finder/archive/refs/tags/v0.9.0.tar.gz" ;
    schema1:identifier biotools:assembly_finder ;
    schema1:license "MIT" ;
    schema1:maintainer "farchaab",
        "tpillone" ;
    schema1:name "assembly_finder" ;
    schema1:softwareHelp "https://metagenlab.github.io/assembly_finder" ;
    schema1:softwareVersion "0.9.0" ;
    schema1:url "https://github.com/metagenlab/assembly_finder" ;
    spdx:builtFrom biotools:assembly_finder .

