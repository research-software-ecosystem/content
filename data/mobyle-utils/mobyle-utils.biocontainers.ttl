    schema1:description "Binary tools used by mobyle" ;
    schema1:keywords "Computational Biology",
        "Databases, Factual",
        "Internet",
        "User-Computer Interface" ;
    schema1:license "GPL-2+" ;
    schema1:name "mobyle-utils" ;
    schema1:url "https://projets.pasteur.fr/projects/mobyle" .

