@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:r-facets a schema1:SoftwareApplication ;
    schema1:description "Cellular Fraction and Copy Numbers from Tumor Sequencing" ;
    schema1:downloadUrl "https://github.com/mskcc/facets/archive/refs/tags/v0.6.2.tar.gz" ;
    schema1:identifier biotools:facets ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "r-facets" ;
    schema1:softwareVersion "0.6.2" ;
    schema1:url "https://github.com/mskcc/facets" ;
    spdx:builtFrom biotools:facets .

