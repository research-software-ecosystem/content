@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-facets a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/gkw520" ;
    schema1:description "Cellular Fraction and Copy Numbers from Tumor Sequencing" ;
    schema1:identifier biotools:facets ;
    schema1:keywords "Adenocarcinoma",
        "Adenocarcinoma of Lung",
        "Alleles",
        "Clone Cells",
        "DNA Copy Number Variations",
        "Databases, Nucleic Acid",
        "Exome",
        "Gene Dosage",
        "Genetic Heterogeneity",
        "High-Throughput Nucleotide Sequencing",
        "Human genetics",
        "Humans",
        "Loss of Heterozygosity",
        "Lung Neoplasms",
        "Oncology",
        "Public health and epidemiology",
        "Sequence Analysis, DNA" ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "r-facets" ;
    schema1:url "https://github.com/mskcc/facets" .

