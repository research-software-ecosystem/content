@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:snmf a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1534/genetics.113.160572" ;
    schema1:description "Fast and efficient program for estimating individual admixture coefficients based on sparse non-negative matrix factorization and population genetics" ;
    schema1:identifier biotools:snmf ;
    schema1:keywords "Computational Biology",
        "Gene Frequency",
        "Genetic Association Studies",
        "Genetics",
        "Genetics, Population",
        "Genotype",
        "Humans",
        "Likelihood Functions",
        "Plants",
        "Population Groups",
        "Population genetics",
        "Time Factors" ;
    schema1:license "GNU GPL v3" ;
    schema1:name "snmf" ;
    schema1:url "http://membres-timc.imag.fr/Olivier.Francois/snmf/index.htm" .

