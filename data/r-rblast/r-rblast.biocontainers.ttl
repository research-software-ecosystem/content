@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-rblast a schema1:SoftwareApplication ;
    schema1:description "Seamlessly interfaces the basic local alignment search tool (blast) to search genetic sequence data bases. this work was partially supported by grant no. r21hg005912 from the national human genome research institute." ;
