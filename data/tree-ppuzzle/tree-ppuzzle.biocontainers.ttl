@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:tree-ppuzzle a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/18.3.502" ;
    schema1:description "Parallelized reconstruction of phylogenetic trees by maximum likelihood" ;
    schema1:identifier biotools:tree-puzzle ;
    schema1:keywords "Computing Methodologies",
        "DNA",
        "Database Management Systems",
        "Databases, Genetic",
        "Genetics",
        "Internet",
        "Likelihood Functions",
        "Mathematical Computing",
        "Molecular Sequence Data",
        "Phylogenetics",
        "Phylogeny",
        "Protein Structure",
        "Sequence Alignment",
        "Sequence Analysis",
        "Sequence analysis" ;
    schema1:license "Not available" ;
    schema1:name "tree-ppuzzle" ;
    schema1:url "http://www.tree-puzzle.de" .

