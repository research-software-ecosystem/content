@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:tpp a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18129/b9.bioc.tpp" ;
    schema1:description "Analyze thermal proteome profiling (tpp) experiments with varying temperatures (tr) or compound concentrations (ccr)." ;
    schema1:identifier biotools:tpp ;
    schema1:keywords "Drug discovery",
        "Proteomics",
        "Proteomics experiment" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "tpp" ;
    schema1:url "https://bioconductor.org/packages/TPP/" .

