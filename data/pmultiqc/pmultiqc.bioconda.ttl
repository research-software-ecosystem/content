@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:pmultiqc a schema1:SoftwareApplication ;
    schema1:author "ypriverol" ;
    schema1:description "Python package for quality control of proteomics datasets, based on multiqc package." ;
    schema1:downloadUrl "https://pypi.org/packages/source/p/pmultiqc/pmultiqc-0.0.44.tar.gz" ;
    schema1:identifier biotools:pmultiqc ;
    schema1:license "MIT" ;
    schema1:maintainer "ypriverol" ;
    schema1:name "pmultiqc" ;
    schema1:softwareHelp "https://pmultiqc.quantms.org" ;
    schema1:softwareVersion "0.0.44" ;
    schema1:url "https://github.com/bigbio/pmultiqc" ;
    spdx:builtFrom biotools:pmultiqc .

