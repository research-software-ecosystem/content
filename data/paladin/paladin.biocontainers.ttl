@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:paladin a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btx021" ;
    schema1:description "Protein Alignment and Detection Interface" ;
    schema1:identifier biotools:paladin ;
    schema1:keywords "Bacteria",
        "High-Throughput Nucleotide Sequencing",
        "Humans",
        "Metagenome",
        "Metagenomics",
        "Microbiota",
        "Nucleic acid structure analysis",
        "Protein Sequences",
        "Proteins",
        "Sequence Alignment",
        "Sequence Analysis, DNA" ;
    schema1:license "MIT" ;
    schema1:name "paladin" ;
    schema1:url "https://github.com/twestbrookunh/paladin" .

