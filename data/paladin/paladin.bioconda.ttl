@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:paladin a schema1:SoftwareApplication ;
    schema1:author "keuv-grvl" ;
    schema1:citation "doi:10.1093/bioinformatics/btx021" ;
    schema1:description "Protein Alignment and Detection Interface." ;
    schema1:downloadUrl "https://github.com/ToniWestbrook/paladin/archive/refs/tags/v.1.6.0.tar.gz" ;
    schema1:identifier biotools:paladin ;
    schema1:license "MIT" ;
    schema1:maintainer "keuv-grvl" ;
    schema1:name "paladin" ;
    schema1:softwareHelp "https://genomebio.org/paladin" ;
    schema1:softwareVersion "1.6.0" ;
    schema1:url "https://github.com/ToniWestbrook/paladin" ;
    spdx:builtFrom biotools:paladin .

