@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:fastq-screen a schema1:SoftwareApplication ;
    schema1:description "Fastq screen allows you to screen a library of sequences in fastq format against a set of sequence databases so you can see if the composition of the library matches with what you expect" ;
    schema1:keywords "Genomics",
        "Metagenomics" ;
    schema1:license "GPL-3.0" ;
    schema1:name "fastq-screen" ;
    schema1:url "https://github.com/StevenWingett/FastQ-Screen" .

