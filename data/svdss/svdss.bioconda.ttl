@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:svdss a schema1:SoftwareApplication ;
    schema1:author "ldenti" ;
    schema1:citation "doi:10.1038/s41592-022-01674-1" ;
    schema1:description "Structural Variant Discovery from Sample-specific Strings." ;
    schema1:downloadUrl "https://github.com/Parsoa/SVDSS/archive/refs/tags/v2.1.1.tar.gz" ;
    schema1:identifier biotools:svdss ;
    schema1:license "MIT" ;
    schema1:maintainer "ldenti" ;
    schema1:name "svdss" ;
    schema1:softwareHelp "https://github.com/Parsoa/SVDSS/blob/v2.1.1/README.md" ;
    schema1:softwareVersion "2.1.1" ;
    schema1:url "https://github.com/Parsoa/SVDSS" ;
    spdx:builtFrom biotools:svdss .

