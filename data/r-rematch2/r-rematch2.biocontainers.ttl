@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-rematch2 a schema1:SoftwareApplication ;
    schema1:description "Wrappers on 'regexpr' and 'gregexpr' to return the match results in tidy data frames." ;
    schema1:license "MIT" ;
    schema1:name "r-rematch2" ;
    schema1:url "https://github.com/r-lib/rematch2#readme" .

