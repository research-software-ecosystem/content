@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:perlprimer a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/bth254" ;
    schema1:description "Graphical design of primers for pcr" ;
    schema1:keywords "Chromosome Mapping",
        "DNA Primers",
        "Oligonucleotide Array Sequence Analysis",
        "Online Systems",
        "Polymerase Chain Reaction",
        "Sequence Alignment",
        "Sequence Analysis, DNA",
        "Sulfites",
        "User-Computer Interface" ;
    schema1:license "GPL-2+" ;
    schema1:name "perlprimer" ;
    schema1:url "http://perlprimer.sourceforge.net" .

