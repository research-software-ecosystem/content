@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:trtools a schema1:SoftwareApplication ;
    schema1:author "LiterallyUniqueLogin",
        "aryarm" ;
    schema1:citation "doi:10.1093/bioinformatics/btaa736" ;
    schema1:description "Toolkit for genome-wide analysis of tandem repeats." ;
    schema1:downloadUrl "https://pypi.org/packages/source/t/trtools/trtools-6.1.0.tar.gz" ;
    schema1:identifier biotools:trtools ;
    schema1:license "MIT" ;
    schema1:maintainer "LiterallyUniqueLogin",
        "aryarm" ;
    schema1:name "trtools" ;
    schema1:softwareHelp "https://trtools.readthedocs.io" ;
    schema1:softwareVersion "6.1.0" ;
    schema1:url "https://github.com/gymreklab/TRTools" ;
    spdx:builtFrom biotools:trtools .

