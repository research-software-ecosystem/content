@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:goenrichment a schema1:SoftwareApplication ;
    schema1:description "Goenrichment analyses a set of gene products for go term enrichment" ;
    schema1:identifier biotools:goenrichment ;
    schema1:keywords "Transcriptomics" ;
    schema1:license "Apache-2.0" ;
    schema1:name "goenrichment" ;
    schema1:url "https://github.com/DanFaria/GOEnrichment" .

