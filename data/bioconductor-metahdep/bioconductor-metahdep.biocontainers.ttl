@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-metahdep a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btp468" ;
    schema1:description "Hierarchical Dependence in Meta-Analysis" ;
    schema1:identifier biotools:metahdep ;
    schema1:keywords "Computational Biology",
        "Data architecture, analysis and design",
        "Databases, Genetic",
        "Gene Expression",
        "Gene Expression Profiling",
        "Gene expression",
        "Meta-Analysis as Topic",
        "Oligonucleotide Array Sequence Analysis" ;
    schema1:license "GPL-3.0" ;
    schema1:name "bioconductor-metahdep" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/metahdep.html" .

