@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-metahdep a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btp468" ;
    schema1:description "Hierarchical Dependence in Meta-Analysis" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/metahdep_1.64.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/metahdep/metahdep_1.64.0.tar.gz', 'https://bioarchive.galaxyproject.org/metahdep_1.64.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-metahdep/bioconductor-metahdep_1.64.0_src_all.tar.gz']" ;
    schema1:identifier biotools:metahdep ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-metahdep" ;
    schema1:softwareVersion "1.64.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/metahdep.html" ;
    spdx:builtFrom biotools:metahdep .

