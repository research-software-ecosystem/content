@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-mousefm a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18129/b9.bioc.mousefm" ;
    schema1:description "This package provides methods for genetic finemapping in inbred mice by taking advantage of their very high homozygosity rate (>95%)." ;
    schema1:keywords "Genetics",
        "Genomics" ;
    schema1:license "GPL-3.0" ;
    schema1:name "bioconductor-mousefm" ;
    schema1:url "https://bioconductor.org/packages/3.12/bioc/html/MouseFM.html" .

