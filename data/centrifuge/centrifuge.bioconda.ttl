@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:centrifuge a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1101/gr.210641.116" ;
    schema1:description "Classifier for metagenomic sequences. Supports classifier scripts" ;
    schema1:downloadUrl "https://github.com/DaehwanKimLab/centrifuge/archive/refs/tags/v1.0.4.2.tar.gz" ;
    schema1:identifier biotools:Centrifuge ;
    schema1:license "GPL-3.0-only" ;
    schema1:name "centrifuge" ;
    schema1:softwareVersion "1.0.4.2" ;
    schema1:url "https://github.com/DaehwanKimLab/centrifuge" ;
    spdx:builtFrom biotools:Centrifuge .

