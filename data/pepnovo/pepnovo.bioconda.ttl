@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:pepnovo a schema1:SoftwareApplication ;
    schema1:description "PepNovo serves as a high throughput de novo peptide sequencing tool for tandem mass spectrometry data" ;
    schema1:downloadUrl "http://proteomics.ucsd.edu/Software/PepNovo/PepNovo.20120423.zip" ;
    schema1:identifier biotools:pepnovo ;
    schema1:license "BSD" ;
    schema1:name "pepnovo" ;
    schema1:softwareVersion "20101117" ;
    schema1:url "http://proteomics.ucsd.edu/Software/PepNovo/" ;
    spdx:builtFrom biotools:pepnovo .

