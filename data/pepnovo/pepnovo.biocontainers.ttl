@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:pepnovo a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1021/ac048788h" ;
    schema1:description "De novo sequencing using probabilistic network modeling." ;
    schema1:identifier biotools:pepnovo ;
    schema1:keywords "Likelihood Functions",
        "Mass Spectrometry",
        "Mass spectrometry",
        "Peptides",
        "Probability",
        "Proteomics",
        "Proteomics experiment",
        "Sequence Analysis, Protein" ;
    schema1:license "CC-BY-NC-4.0" ;
    schema1:name "pepnovo" ;
    schema1:url "http://proteomics.ucsd.edu/Software/PepNovo/" .

