@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-genomicfiles a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Distributed computing by file or by range" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/GenomicFiles_1.42.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/GenomicFiles/GenomicFiles_1.42.0.tar.gz', 'https://bioarchive.galaxyproject.org/GenomicFiles_1.42.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-genomicfiles/bioconductor-genomicfiles_1.42.0_src_all.tar.gz']" ;
    schema1:identifier biotools:genomicfiles ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-genomicfiles" ;
    schema1:softwareVersion "1.42.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/GenomicFiles.html" ;
    spdx:builtFrom biotools:genomicfiles .

