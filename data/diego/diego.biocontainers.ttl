@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:diego a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btx690" ;
    schema1:description "Detection of differential alternative splicing using aitchinson`s geometry" ;
    schema1:keywords "Alternative Splicing",
        "Protein Isoforms",
        "RNA",
        "Sequence Analysis, RNA" ;
    schema1:license "The software is published under the GNU GPL v2.0 license." ;
    schema1:name "diego" ;
    schema1:url "http://www.bioinf.uni-leipzig.de/Software/DIEGO" .

