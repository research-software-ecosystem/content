@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:perm a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btp486" ;
    schema1:description "Perm (periodic seed mapping) uses periodic spaced seeds to significantly improve mapping efficiency for large reference genomes when compared to state-of-the-art programs." ;
    schema1:identifier biotools:perm ;
    schema1:keywords "Base Sequence",
        "Computational Biology",
        "Genomics",
        "Molecular Sequence Data",
        "Sequence Analysis, DNA" ;
    schema1:license "Apache-2.0" ;
    schema1:name "perm" ;
    schema1:url "http://code.google.com/p/perm/" .

