@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-rcgh a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btv718" ;
    schema1:description "A comprehensive pipeline for analyzing and interactively visualizing genomic profiles generated through commercial or custom acgh arrays. this package takes all the steps required for individual genomic profiles analysis, from reading files to profiles segmentation and gene annotations. it also provides several visualization functions which facilitate individual profiles interpretation." ;
    schema1:identifier biotools:rcgh ;
    schema1:keywords "Comparative Genomic Hybridization",
        "Genomics",
        "Humans",
        "Microarray experiment",
        "Personalised medicine",
        "Precision Medicine" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-rcgh" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/rCGH.html" .

