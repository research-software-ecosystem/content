@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-rcgh a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btv718" ;
    schema1:description "Comprehensive Pipeline for Analyzing and Visualizing Array-Based CGH Data" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/rCGH_1.36.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/rCGH/rCGH_1.36.0.tar.gz', 'https://bioarchive.galaxyproject.org/rCGH_1.36.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-rcgh/bioconductor-rcgh_1.36.0_src_all.tar.gz']" ;
    schema1:identifier biotools:rcgh ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-rcgh" ;
    schema1:softwareVersion "1.36.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/rCGH.html" ;
    spdx:builtFrom biotools:rcgh .

