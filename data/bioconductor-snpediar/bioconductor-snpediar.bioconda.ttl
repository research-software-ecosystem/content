bioconda:bioconductor-snpediar a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1007/978-1-4419-9863-7_1039" ;
    schema1:description "Query data from SNPedia" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/SNPediaR_1.32.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/SNPediaR/SNPediaR_1.32.0.tar.gz', 'https://bioarchive.galaxyproject.org/SNPediaR_1.32.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-snpediar/bioconductor-snpediar_1.32.0_src_all.tar.gz']" ;
    schema1:identifier biotools:snpediar ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-snpediar" ;
    schema1:softwareVersion "1.32.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/SNPediaR.html" ;
    spdx:builtFrom biotools:snpediar .

