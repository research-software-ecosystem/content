@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-prettyunits a schema1:SoftwareApplication ;
    schema1:description "human readable formatting of quantities." ;
    schema1:license "MIT" ;
    schema1:name "r-prettyunits" ;
    schema1:url "https://github.com/gaborcsardi/prettyunits" .

