@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-meshes a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "MeSH Enrichment and Semantic analyses" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/meshes_1.36.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/meshes/meshes_1.36.0.tar.gz', 'https://bioarchive.galaxyproject.org/meshes_1.36.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-meshes/bioconductor-meshes_1.36.0_src_all.tar.gz']" ;
    schema1:identifier biotools:meshes ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-meshes" ;
    schema1:softwareVersion "1.36.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/meshes.html" ;
    spdx:builtFrom biotools:meshes .

