@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-meshes a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "MeSH Enrichment and Semantic analyses" ;
    schema1:identifier biotools:meshes ;
    schema1:keywords "Biomedical science",
        "Clustering",
        "Computational Biology",
        "Gene Expression Profiling",
        "Genomics",
        "High-Throughput Screening Assays",
        "Literature and language",
        "Programming Languages",
        "User-Computer Interface" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-meshes" ;
    schema1:url "http://bioconductor.org/packages/release/bioc/html/meshes.html" .

