        "Gene Ontology",
        "Humans",
        "Multigene Family",
        "Ortholog",
        "RNA-Seq",
        "Reproducibility of Results" ;
    schema1:license "LGPL-3.0" ;
    schema1:name "clust" ;
    schema1:url "https://github.com/baselabujamous/clust" .

