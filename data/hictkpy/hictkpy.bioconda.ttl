@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:hictkpy a schema1:SoftwareApplication ;
    schema1:author "jonnings",
        "robomics" ;
    schema1:citation "doi:10.5281/zenodo.8220300" ;
    schema1:description "Python bindings for hictk: read and write .cool and .hic files directly from Python" ;
    schema1:downloadUrl "https://pypi.python.org/packages/source/h/hictkpy/hictkpy-1.4.0.tar.gz" ;
    schema1:identifier biotools:hictkpy ;
    schema1:license "MIT" ;
    schema1:maintainer "jonnings",
        "robomics" ;
    schema1:name "hictkpy" ;
    schema1:softwareHelp "https://hictkpy.readthedocs.io/en/stable/" ;
    schema1:softwareVersion "1.4.0" ;
    schema1:url "https://github.com/paulsengroup/hictkpy" ;
    spdx:builtFrom biotools:hictkpy .

