@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:extract_fullseq a schema1:SoftwareApplication ;
    schema1:description "Extract_fullseq is part of bmtagger aka best match tagger, for removing human reads from metagenomics datasets" ;
    schema1:license "Public Domain" ;
    schema1:name "extract_fullseq" ;
    schema1:url "ftp://ftp.ncbi.nlm.nih.gov/pub/agarwala/bmtagger/" .

