@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:hardklor a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1002/0471250953.bi1318s37" ;
    schema1:description "Open-source application for identification of features from mass spectra." ;
    schema1:keywords "Chromatography, Liquid",
