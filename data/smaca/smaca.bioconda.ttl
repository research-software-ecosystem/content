@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:smaca a schema1:SoftwareApplication ;
    schema1:author "erdanieee",
        "loucerac" ;
    schema1:citation "doi:10.1002/humu.24120",
        "doi:10.5281/zenodo.3731299" ;
    schema1:description "smaca is a python tool to detect putative SMA carriers and estimate the absolute SMN1 copy-number in a population." ;
    schema1:downloadUrl "https://pypi.org/packages/source/s/smaca/smaca-1.2.4rc11.tar.gz" ;
    schema1:identifier biotools:smaca ;
    schema1:license "GPL-3.0-or-later" ;
    schema1:maintainer "erdanieee",
        "loucerac" ;
    schema1:name "smaca" ;
    schema1:softwareVersion "1.2.4rc11" ;
    schema1:url "https://github.com/babelomics/SMAca" ;
    spdx:builtFrom biotools:smaca .

