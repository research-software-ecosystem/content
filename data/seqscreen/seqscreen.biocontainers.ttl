@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:seqscreen a schema1:SoftwareApplication ;
    schema1:description "Seqscreen was created to sensitively assign taxonomic classifications, functional annotations, and biological processes of interest to single, short dna sequences (50bp-1,000bp)." ;
    schema1:license "Not available" ;
    schema1:name "seqscreen" ;
    schema1:url "https://gitlab.com/treangenlab/seqscreen/-/wikis/home" .

