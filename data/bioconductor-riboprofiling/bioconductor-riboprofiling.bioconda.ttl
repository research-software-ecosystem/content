bioconda:bioconductor-riboprofiling a schema1:SoftwareApplication ;
    schema1:citation "doi:10.12688/f1000research.8964.1" ;
    schema1:description "Ribosome Profiling Data Analysis: from BAM to Data Representation and Interpretation" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/RiboProfiling_1.36.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/RiboProfiling/RiboProfiling_1.36.0.tar.gz', 'https://bioarchive.galaxyproject.org/RiboProfiling_1.36.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-riboprofiling/bioconductor-riboprofiling_1.36.0_src_all.tar.gz']" ;
    schema1:identifier biotools:riboprofiling ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-riboprofiling" ;
    schema1:softwareVersion "1.36.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/RiboProfiling.html" ;
    spdx:builtFrom biotools:riboprofiling .

