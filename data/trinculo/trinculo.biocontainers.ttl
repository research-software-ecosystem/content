@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:trinculo a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btw075" ;
    schema1:description "A toolkit for carrying out genetic association for multi-category phenotypes. implements multinomial and ordinal nassociation incorporating covariates, conditional analysis,nempirical and non-emperical priors and fine-mapping." ;
    schema1:identifier biotools:trinculo ;
    schema1:keywords "Bayes Theorem",
        "GWAS study",
        "Genetics",
        "Genome-Wide Association Study",
        "Genotype and phenotype",
        "Humans",
        "Logistic Models",
        "Pathology",
        "Phenotype" ;
    schema1:license "MIT" ;
    schema1:name "trinculo" ;
    schema1:url "https://sourceforge.net/projects/trinculo/" .

