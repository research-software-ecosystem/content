@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:soapdenovo-trans a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btu077" ;
    schema1:description "SOAPdenovo-Trans is a de novo transcriptome assembler basing on the SOAPdenovo framework, adapt to alternative splicing and different expression level among transcripts." ;
    schema1:keywords "Alternative Splicing",
        "Animals",
        "Gene Expression Profiling",
        "Genomics",
        "High-Throughput Nucleotide Sequencing",
        "Mice",
        "Oryza",
        "Sequence Analysis, RNA" ;
    schema1:license "GPL-3.0" ;
    schema1:name "soapdenovo-trans" ;
    schema1:url "http://soap.genomics.org.cn/SOAPdenovo-Trans.html" .

