@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:metapi a schema1:SoftwareApplication ;
    schema1:description "A general metagenomics data mining system focus on robust microbiome research" ;
    schema1:identifier biotools:metapi ;
    schema1:keywords "Genomics",
        "Metagenome",
        "Metagenomics" ;
    schema1:license "GPL3" ;
    schema1:name "metapi" ;
    schema1:url "https://github.com/ohmeta/metapi" .

