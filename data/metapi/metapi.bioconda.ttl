@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:metapi a schema1:SoftwareApplication ;
    schema1:author "alienzj" ;
    schema1:description "A general metagenomics data mining system focus on robust microbiome research" ;
    schema1:downloadUrl "https://github.com/ohmeta/metapi/archive/v3.0.0.tar.gz" ;
    schema1:identifier biotools:metapi ;
    schema1:license "GPL-3.0-only" ;
    schema1:maintainer "alienzj" ;
    schema1:name "metapi" ;
    schema1:softwareVersion "3.0.0" ;
    schema1:url "https://github.com/ohmeta/metapi" ;
    spdx:builtFrom biotools:metapi .

