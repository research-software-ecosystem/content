@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:hivtrace a schema1:SoftwareApplication ;
    schema1:description "HIV TRACE is an application that identifies potential transmission clusters within a supplied FASTA file with an option to find potential links against the Los Alamos HIV Sequence Database." ;
    schema1:keywords "Gene Expression" ;
    schema1:license "MIT" ;
    schema1:name "hivtrace" ;
    schema1:url "https://github.com/veg/hivtrace" .

