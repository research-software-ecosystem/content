@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:readfq a schema1:SoftwareApplication ;
    schema1:description "A high-speed tool to calculate reads number and total base count in FASTQ file, forked from Li Heng's original version" ;
    schema1:license "MIT" ;
    schema1:name "readfq" ;
    schema1:url "https://github.com/billzt/readfq" .

