@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-director a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "A dynamic visualization tool of multi-level data" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/Director_1.32.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/Director/Director_1.32.0.tar.gz', 'https://bioarchive.galaxyproject.org/Director_1.32.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-director/bioconductor-director_1.32.0_src_all.tar.gz']" ;
    schema1:identifier biotools:director ;
    schema1:license "GPL-3 + file LICENSE" ;
    schema1:name "bioconductor-director" ;
    schema1:softwareVersion "1.32.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/Director.html" ;
    spdx:builtFrom biotools:director .

