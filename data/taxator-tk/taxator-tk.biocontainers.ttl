@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:taxator-tk a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btu745" ;
    schema1:description "Taxator-tk sequence taxonomic annotaion" ;
    schema1:identifier biotools:taxator-tk ;
    schema1:keywords "Bacteria",
        "Genomics",
        "Metagenome",
        "Phylogenetics",
        "Phylogeny",
        "Sequence analysis",
        "Taxonomy" ;
    schema1:license "GPL-3.0" ;
    schema1:name "taxator-tk" ;
    schema1:url "https://github.com/fungs/taxator-tk" .

