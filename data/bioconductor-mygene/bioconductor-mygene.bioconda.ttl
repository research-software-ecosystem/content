@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-mygene a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1101/009333" ;
    schema1:description "Access MyGene.Info_ services" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/mygene_1.42.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/mygene/mygene_1.42.0.tar.gz', 'https://bioarchive.galaxyproject.org/mygene_1.42.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-mygene/bioconductor-mygene_1.42.0_src_all.tar.gz']" ;
    schema1:identifier biotools:mygene ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-mygene" ;
    schema1:softwareVersion "1.42.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/mygene.html" ;
    spdx:builtFrom biotools:mygene .

