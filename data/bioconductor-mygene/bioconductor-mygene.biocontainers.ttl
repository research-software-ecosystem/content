@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-mygene a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1101/009332",
        "doi:10.1101/009333" ;
    schema1:description "This package provides simple-to-use rest web services to query/retrieve gene annotation data." ;
    schema1:identifier biotools:mygene ;
    schema1:keywords "Molecular genetics" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-mygene" ;
    schema1:url "http://bioconductor.org/packages/release/bioc/html/mygene.html" .

