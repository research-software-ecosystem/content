@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:tinyfasta a schema1:SoftwareApplication ;
    schema1:description "Tiny python package, with no external dependencies, for parsing fasta sequence files." ;
    schema1:license "MIT" ;
    schema1:name "tinyfasta" ;
    schema1:url "https://github.com/tjelvar-olsson/tinyfasta" .

