@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-dfp a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Gene Selection" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/DFP_1.64.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/DFP/DFP_1.64.0.tar.gz', 'https://bioarchive.galaxyproject.org/DFP_1.64.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-dfp/bioconductor-dfp_1.64.0_src_all.tar.gz']" ;
    schema1:identifier biotools:dfp ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-dfp" ;
    schema1:softwareVersion "1.64.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/DFP.html" ;
    spdx:builtFrom biotools:dfp .

