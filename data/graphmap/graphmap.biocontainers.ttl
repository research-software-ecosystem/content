@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:graphmap a schema1:SoftwareApplication ;
    schema1:description "a highly sensitive and accurate mapper for long, error-prone reads." ;
    schema1:keywords "RNA-Seq",
        "Transcriptome" ;
    schema1:license "MIT" ;
    schema1:name "graphmap" ;
    schema1:url "https://github.com/lbcb-sci/graphmap2" .

