@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-rcppparallel a schema1:SoftwareApplication ;
    schema1:description "High level functions for parallel programming with 'Rcpp'. For example, the 'parallelFor()' function can be used to convert the work of a standard serial \"for\" loop into a parallel one and the 'parallelReduce()' function can be used for accumulating aggregate or other values." ;
    schema1:license "GPL-2" ;
    schema1:name "r-rcppparallel" ;
    schema1:url "None" .

