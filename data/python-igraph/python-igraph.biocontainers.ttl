@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:python-igraph a schema1:SoftwareApplication ;
    schema1:description "graph is a library for creating and manipulating graphs. It is intended to be as powerful (ie. fast) as possible to enable the analysis of large graphs." ;
    schema1:license "GLP-2" ;
    schema1:name "python-igraph" ;
    schema1:url "https://github.com/igraph/python-igraph" .

