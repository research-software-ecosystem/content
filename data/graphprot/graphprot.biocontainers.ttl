@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:graphprot a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/gb-2014-15-1-r17" ;
    schema1:description "GraphProt is a tool for modelling binding preferences of RNA-binding proteins from high-throughput experiments such as CLIP-seq and RNAcompete." ;
    schema1:identifier biotools:graphprot ;
    schema1:keywords "Binding Sites",
        "Computer Simulation",
        "Humans",
        "Models, Molecular",
        "Nucleic Acid Conformation",
        "Proteins",
        "RNA",
        "RNA-Binding Proteins",
        "RNA-Seq",
        "Sequence Analysis, RNA",
        "Transcriptome" ;
    schema1:license "MIT" ;
    schema1:name "graphprot" ;
    schema1:url "https://github.com/dmaticzka/graphprot" .

