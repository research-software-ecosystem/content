@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-venndiagram a schema1:SoftwareApplication ;
    schema1:description "A set of functions to generate high-resolution Venn and Euler plots. Includes handling for several special cases, including two-case scaling, and extensive customization of plot shape and structure." ;
    schema1:keywords "Proteomics" ;
    schema1:license "GPL-2" ;
    schema1:name "r-venndiagram" ;
    schema1:url "https://cran.r-project.org/package=VennDiagram" .

