@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:ibdseq a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1016/j.ajhg.2013.09.014" ;
    schema1:description "IBDseq is a software program for detecting segments of identity-by-descent (IBD) and homozygosity-by-descent (HBD) in unphased genetic sequence data." ;
    schema1:downloadUrl "http://faculty.washington.edu/browning/ibdseq/ibdseq.r1206.jar" ;
    schema1:identifier biotools:IBDseq ;
    schema1:license "Apache v2.0" ;
    schema1:name "ibdseq" ;
    schema1:softwareVersion "r1206" ;
    schema1:url "http://faculty.washington.edu/browning/ibdseq.html" ;
    spdx:builtFrom biotools:IBDseq .

