@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:ibdseq a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1016/j.ajhg.2013.09.014" ;
    schema1:description "Ibdseq is a software program for detecting segments of identity-by-descent (ibd) and homozygosity-by-descent (hbd) in unphased genetic sequence data." ;
    schema1:identifier biotools:IBDseq ;
    schema1:keywords "Alleles",
        "Cohort Studies",
        "Europe",
        "European Continental Ancestry Group",
        "Gene Frequency",
        "Genetics",
        "Genetics, Population",
        "Genotype",
        "Homozygote",
        "Humans",
        "Lod Score",
        "Mapping",
        "Models, Genetic",
        "Polymorphism, Single Nucleotide",
        "Probability",
        "Sequence Analysis, DNA" ;
    schema1:license "Apache v2.0" ;
    schema1:name "ibdseq" ;
    schema1:url "http://faculty.washington.edu/browning/ibdseq.html" .

