@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-basespacer a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "R SDK for BaseSpace RESTful API" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/BaseSpaceR_1.50.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/BaseSpaceR/BaseSpaceR_1.50.0.tar.gz', 'https://bioarchive.galaxyproject.org/BaseSpaceR_1.50.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-basespacer/bioconductor-basespacer_1.50.0_src_all.tar.gz']" ;
    schema1:identifier biotools:basespacer ;
    schema1:license "Apache License 2.0" ;
    schema1:name "bioconductor-basespacer" ;
    schema1:softwareVersion "1.50.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/BaseSpaceR.html" ;
    spdx:builtFrom biotools:basespacer .

