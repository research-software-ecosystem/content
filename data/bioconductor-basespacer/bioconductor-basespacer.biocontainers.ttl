@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-basespacer a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "A rich r interface to illumina's basespace cloud computing environment, enabling the fast development of data analysis and visualisation tools." ;
    schema1:identifier biotools:basespacer ;
    schema1:keywords "Computational Biology",
        "Data visualisation",
        "Gene Expression Profiling",
        "Genetics",
        "Genomics",
        "High-Throughput Screening Assays",
        "Programming Languages",
        "Sequence analysis",
        "Software engineering",
        "User-Computer Interface" ;
    schema1:license "Apache-2.0" ;
    schema1:name "bioconductor-basespacer" ;
    schema1:url "http://bioconductor.org/packages/release/bioc/html/BaseSpaceR.html" .

