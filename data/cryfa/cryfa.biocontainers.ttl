@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:cryfa a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/bty645" ;
    schema1:description "A secure encryption tool for genomic data" ;
    schema1:keywords "Computational Biology",
        "Data Compression",
        "Genomics",
        "High-Throughput Nucleotide Sequencing" ;
    schema1:license "GPL-3.0" ;
    schema1:name "cryfa" ;
    schema1:url "https://github.com/smortezah/cryfa" .

