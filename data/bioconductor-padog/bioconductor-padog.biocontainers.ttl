@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-padog a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/1471-2105-13-136" ;
    schema1:description "Pathway Analysis with Down-weighting of Overlapping Genes (PADOG)" ;
    schema1:identifier biotools:padog ;
    schema1:keywords "Computational Biology",
        "Databases, Genetic",
        "Gene Expression Profiling",
        "Gene Regulatory Networks",
        "Gene expression",
        "Gene regulation",
        "Genes, Overlapping",
        "Genetics",
        "Humans",
        "Metabolic Networks and Pathways",
        "Oligonucleotide Array Sequence Analysis",
        "Statistics as Topic" ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-padog" ;
    schema1:url "http://bioconductor.org/packages/3.6/bioc/html/PADOG.html" .

