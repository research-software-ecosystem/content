@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-padog a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/1471-2105-13-136" ;
    schema1:description "Pathway Analysis with Down-weighting of Overlapping Genes (PADOG)" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/PADOG_1.52.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/PADOG/PADOG_1.52.0.tar.gz', 'https://bioarchive.galaxyproject.org/PADOG_1.52.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-padog/bioconductor-padog_1.52.0_src_all.tar.gz']" ;
    schema1:identifier biotools:padog ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-padog" ;
    schema1:softwareVersion "1.52.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/PADOG.html" ;
    spdx:builtFrom biotools:padog .

