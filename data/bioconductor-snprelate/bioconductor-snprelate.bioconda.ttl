@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-snprelate a schema1:SoftwareApplication ;
    schema1:description "Parallel Computing Toolset for Relatedness and Principal Component Analysis of SNP Data" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/SNPRelate_1.40.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/SNPRelate/SNPRelate_1.40.0.tar.gz', 'https://bioarchive.galaxyproject.org/SNPRelate_1.40.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-snprelate/bioconductor-snprelate_1.40.0_src_all.tar.gz']" ;
    schema1:identifier biotools:snprelate ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-snprelate" ;
    schema1:softwareVersion "1.40.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/SNPRelate.html" ;
    spdx:builtFrom biotools:snprelate .

