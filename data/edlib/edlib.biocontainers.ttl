@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:edlib a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btw753" ;
    schema1:description "Library for sequence alignment using edit distance (python3 module)" ;
    schema1:keywords "Sequence Alignment",
        "Sequence Analysis, DNA" ;
    schema1:license "MIT" ;
    schema1:name "edlib" ;
    schema1:url "https://github.com/Martinsos/edlib" .

