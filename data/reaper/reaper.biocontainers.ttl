@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:reaper a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/gkv1352" ;
    schema1:description "Tool for demultiplexing, trimming and filtering sequencing data." ;
    schema1:identifier biotools:reaper ;
    schema1:keywords "Computational Biology",
        "Databases, Chemical",
        "Databases, Factual",
        "Databases, Nucleic Acid",
        "Databases, Protein",
        "Genes",
        "Genetic Variation",
        "Genome",
        "Microscopy, Electron",
        "Sequence Analysis, DNA",
        "Sequence Analysis, RNA",
        "Sequencing",
        "Systems Integration" ;
    schema1:license "GPL-3.0" ;
    schema1:name "reaper" ;
    schema1:url "https://www.ebi.ac.uk/~stijn/reaper/reaper.html" .

