@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:pyclone a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.2883",
        "doi:10.1186/s12859-020-03919-2" ;
    schema1:description "Pyclone: a probabilistic model for inferring clonal population structure from deep ngs sequencing." ;
    schema1:keywords "Bayes Theorem",
        "Clustering",
        "Databases, Genetic",
        "Genome, Human",
        "Humans",
        "Mutation",
        "Neoplasms",
        "User-Computer Interface",
        "Whole Genome Sequencing" ;
    schema1:license "Not available" ;
    schema1:name "pyclone" ;
    schema1:url "https://github.com/Roth-Lab/pyclone/" .

