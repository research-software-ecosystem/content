@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:exparna a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btp065" ;
    schema1:description "The program finds the longest common subsequence of exact pattern matches (lcs-epm)" ;
    schema1:identifier biotools:exparna ;
    schema1:keywords "Base Sequence",
        "Computational Biology",
        "Nucleic Acid Conformation",
        "RNA",
        "Sequence Alignment",
        "Sequence Analysis, RNA",
        "Sequence analysis" ;
    schema1:license "GPL-2.0" ;
    schema1:name "exparna" ;
    schema1:url "https://github.com/BackofenLab/ExpaRNA" .

