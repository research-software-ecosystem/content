    schema1:identifier biotools:trio ;
    schema1:keywords "Applied mathematics",
        "Computational Biology",
        "Gene Expression Profiling",
        "Genetic variation",
        "Genetics",
        "Genomics",
        "Genotyping experiment",
        "High-Throughput Screening Assays",
        "Medical informatics",
        "Programming Languages",
        "User-Computer Interface" ;
    schema1:license "LGPL-2" ;
    schema1:name "bioconductor-trio" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/trio.html" .

