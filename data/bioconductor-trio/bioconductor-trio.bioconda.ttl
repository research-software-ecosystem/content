@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-trio a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Testing of SNPs and SNP Interactions in Case-Parent Trio Studies" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/trio_3.44.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/trio/trio_3.44.0.tar.gz', 'https://bioarchive.galaxyproject.org/trio_3.44.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-trio/bioconductor-trio_3.44.0_src_all.tar.gz']" ;
    schema1:identifier biotools:trio ;
    schema1:license "LGPL-2" ;
    schema1:name "bioconductor-trio" ;
    schema1:softwareVersion "3.44.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/trio.html" ;
    spdx:builtFrom biotools:trio .

