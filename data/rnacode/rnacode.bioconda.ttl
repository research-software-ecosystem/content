@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:rnacode a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1261/rna.2536111" ;
    schema1:description "RNAcode - Analyze the protein coding potential in multiple sequence alignments RNAcode relies on evolutionary signatures including synonymous/conservative mutations and conservation of the reading frame. It does not use any species specific sequence characteristics whatsoever and does not use any machine learning techniques." ;
    schema1:downloadUrl "https://github.com/ViennaRNA/RNAcode/releases/download/v0.3.1/RNAcode-0.3.1.tar.gz" ;
    schema1:identifier biotools:rnacode ;
    schema1:license "Unknown" ;
    schema1:name "rnacode" ;
    schema1:softwareHelp "https://viennarna.github.io/RNAcode" ;
    schema1:softwareVersion "0.3.1" ;
    schema1:url "https://github.com/ViennaRNA/RNAcode" ;
    spdx:builtFrom biotools:rnacode .

