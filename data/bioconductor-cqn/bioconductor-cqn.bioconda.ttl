@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-cqn a schema1:SoftwareApplication ;
    schema1:description "Conditional quantile normalization" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/cqn_1.52.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/cqn/cqn_1.52.0.tar.gz', 'https://bioarchive.galaxyproject.org/cqn_1.52.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-cqn/bioconductor-cqn_1.52.0_src_all.tar.gz']" ;
    schema1:identifier biotools:cqn ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-cqn" ;
    schema1:softwareVersion "1.52.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/cqn.html" ;
    spdx:builtFrom biotools:cqn .

