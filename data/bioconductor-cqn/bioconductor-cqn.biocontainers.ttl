@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-cqn a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/biostatistics/kxr054" ;
    schema1:description "A normalization tool for rna-seq data, implementing the conditional quantile normalization method." ;
    schema1:identifier biotools:cqn ;
    schema1:keywords "Analysis of Variance",
        "Base Composition",
        "Biostatistics",
        "Databases, Nucleic Acid",
        "Gene Expression Profiling",
        "High-Throughput Nucleotide Sequencing",
        "Humans",
        "Oligonucleotide Array Sequence Analysis",
        "RNA-Seq",
        "RNA-seq",
        "Sequence Analysis, RNA" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-cqn" ;
    schema1:url "http://bioconductor.org/packages/release/bioc/html/cqn.html" .

