@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:entrez-direct a schema1:SoftwareApplication ;
    schema1:description "Entrez Direct (EDirect) is an advanced method for accessing the NCBI’s set of interconnected databases (publication, sequence, structure, gene, variation, expression, etc.) from a UNIX terminal window." ;
    schema1:license "Custom License" ;
    schema1:name "entrez-direct" ;
    schema1:url "ftp://ftp.ncbi.nlm.nih.gov/entrez/entrezdirect/" .

