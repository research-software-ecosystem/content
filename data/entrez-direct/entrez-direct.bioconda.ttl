@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:entrez-direct a schema1:SoftwareApplication ;
    schema1:description "Entrez Direct (EDirect) - Access to NCBI's Entrez databases" ;
    schema1:downloadUrl "https://ftp.ncbi.nlm.nih.gov/entrez/entrezdirect/versions/25.3.20260410/edirect.tar.gz" ;
    schema1:identifier biotools:entrez ;
    schema1:license "Public Domain" ;
    schema1:name "entrez-direct" ;
    schema1:softwareHelp "https://ftp.ncbi.nlm.nih.gov/entrez/entrezdirect/versions/25.3.20260410/README" ;
    schema1:softwareVersion "25.3" ;
    schema1:url "https://ftp.ncbi.nlm.nih.gov/entrez/entrezdirect/versions/25.3.20260410/README" ;
    spdx:builtFrom biotools:entrez .

