@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:perl-snap a schema1:SoftwareApplication ;
    schema1:description "Snap calculates pairwise synonymous and nonsynonymous distances according to the nei and gojobori method for an alignment in table format." ;
    schema1:keywords "Genetics" ;
    schema1:license "Not available" ;
    schema1:name "perl-snap" ;
    schema1:url "https://www.hiv.lanl.gov/content/sequence/SNAP/SNAP.html" .

