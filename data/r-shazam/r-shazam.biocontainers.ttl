@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-shazam a schema1:SoftwareApplication ;
    schema1:description "Provides a computational framework for analyzing mutations in immunoglobulin (ig) sequences. includes methods for bayesian estimation of antigen-driven selection pressure, mutational load quantification, building of somatic hypermutation (shm) models, and model-dependent distance calculations. also includes empirically derived models of shm for both mice and humans. citations:  gupta and vander heiden, et al (2015) <doi:10.1093/bioinformatics/btv359>,  yaari, et al (2012) <doi:10.1093/nar/gks457>,  yaari, et al (2013) <doi:10.3389/fimmu.2013.00358>,  cui, et al (2016) <doi:10.4049/jimmunol.1502263>." ;
    schema1:license "AGPL-3" ;
    schema1:name "r-shazam" ;
    schema1:url "http://shazam.readthedocs.io" .

