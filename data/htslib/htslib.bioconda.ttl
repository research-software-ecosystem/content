@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:htslib a schema1:SoftwareApplication ;
    schema1:description "C library for high-throughput sequencing data formats." ;
    schema1:downloadUrl "https://github.com/samtools/htslib/releases/download/1.23.1/htslib-1.23.1.tar.bz2" ;
    schema1:identifier biotools:HTSlib ;
    schema1:license "MIT" ;
    schema1:name "htslib" ;
    schema1:softwareHelp "http://www.htslib.org/" ;
    schema1:softwareVersion "1.23.1" ;
    schema1:url "https://github.com/samtools/htslib" ;
    spdx:builtFrom biotools:HTSlib .

