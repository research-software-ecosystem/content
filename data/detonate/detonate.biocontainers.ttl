@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:detonate a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s13059-014-0553-5" ;
    schema1:description "Detonate (de novo transcriptome rna-seq assembly with or without the truth evaluation) consists of two component packages, rsem-eval and ref-eval." ;
    schema1:identifier biotools:detonate ;
    schema1:keywords "Animals",
        "Assembly",
        "Computational Biology",
        "Computer Simulation",
        "Gene Expression Profiling",
        "RNA",
        "RNA-Seq",
        "RNA-seq",
        "Sequence Analysis, RNA",
        "Sequences",
        "Transcriptome" ;
    schema1:license "GPL" ;
    schema1:name "detonate" ;
    schema1:url "https://github.com/deweylab/detonate" .

