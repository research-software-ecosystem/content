@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:openms-tools a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1007/978-1-60761-987-1_23",
        "doi:10.1038/nmeth.3959" ;
    schema1:description "OpenMS is an open-source software C++ library for LC-MS data management and analyses" ;
    schema1:identifier biotools:openms ;
    schema1:keywords "Animals",
        "Cattle",
        "Chromatography, High Pressure Liquid",
        "Databases, Protein",
        "Humans",
        "Mass Spectrometry",
        "Mass spectrometry",
        "Metabolomics",
        "Peptides",
        "Proteomics",
        "Proteomics experiment",
        "Statistics as Topic" ;
    schema1:license "BSD" ;
    schema1:name "openms-tools" ;
    schema1:url "https://github.com/OpenMS/OpenMS" .

