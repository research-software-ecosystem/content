@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:snostrip a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btt604" ;
    schema1:description "Automatic snoRNA annotation pipeline" ;
    schema1:identifier biotools:snostrip ;
    schema1:keywords "Base Sequence",
        "Conserved Sequence",
        "High-Throughput Nucleotide Sequencing",
        "Ortholog",
        "RNA, Small Nucleolar",
        "RNA-Seq",
        "Sequence Analysis, RNA",
        "Sequence analysis" ;
    schema1:license "GPL-3.0" ;
    schema1:name "snostrip" ;
    schema1:url "http://snostrip.bioinf.uni-leipzig.de/help.py" .

