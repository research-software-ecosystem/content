@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-copa a schema1:SoftwareApplication ;
    schema1:description "Functions to perform cancer outlier profile analysis." ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/copa_1.78.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/copa/copa_1.78.0.tar.gz', 'https://bioarchive.galaxyproject.org/copa_1.78.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-copa/bioconductor-copa_1.78.0_src_all.tar.gz']" ;
    schema1:identifier biotools:copa ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-copa" ;
    schema1:softwareVersion "1.78.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/copa.html" ;
    spdx:builtFrom biotools:copa .

