@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:perl-git-wrapper a schema1:SoftwareApplication ;
    schema1:description "Wrap git(7) command-line interface" ;
    schema1:license "perl_5" ;
    schema1:name "perl-git-wrapper" ;
    schema1:url "http://genehack.github.com/Git-Wrapper/" .

