@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-tiledbarray a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18129/b9.bioc.tiledbarray" ;
    schema1:description "Implements a DelayedArray backend for reading and writing dense or sparse arrays in the TileDB format. The resulting TileDBArrays are compatible with all Bioconductor pipelines that can accept DelayedArray instances." ;
    schema1:license "MIT" ;
    schema1:name "bioconductor-tiledbarray" ;
    schema1:url "https://bioconductor.org/packages/3.12/bioc/html/TileDBArray.html" .

