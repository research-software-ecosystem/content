@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:arb-bio a schema1:SoftwareApplication ;
    schema1:author "epruesse" ;
    schema1:citation "doi:10.1002/9781118010518.ch46" ;
    schema1:description "ARB 6 Sequence Analysis Suite" ;
    schema1:downloadUrl "http://download.arb-home.de/release/arb-6.0.6/arb-6.0.6-source.tgz" ;
    schema1:identifier biotools:arb ;
    schema1:license "ARB" ;
    schema1:maintainer "epruesse" ;
    schema1:name "arb-bio" ;
    schema1:softwareHelp "http://www.arb-home.de/documentation.html" ;
    schema1:softwareVersion "6.0.6" ;
    schema1:url "http://www.arb-home.de" ;
    spdx:builtFrom biotools:arb .

