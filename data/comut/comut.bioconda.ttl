@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:comut a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1101/2020.03.18.997361" ;
    schema1:description "A Python library for creating comutation plots to visualize genomic and phenotypic information" ;
    schema1:downloadUrl "https://github.com/vanallenlab/comut/archive/v0.0.3.tar.gz" ;
    schema1:identifier biotools:comut ;
    schema1:license "MIT" ;
    schema1:name "comut" ;
    schema1:softwareVersion "0.0.3" ;
    schema1:url "https://github.com/vanallenlab/comut" ;
    spdx:builtFrom biotools:comut .

