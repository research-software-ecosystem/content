@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:qualimap a schema1:SoftwareApplication ;
    schema1:description "Quality control of alignment sequencing data and its derivatives like feature counts" ;
    schema1:downloadUrl "https://bitbucket.org/kokonech/qualimap/downloads/qualimap_v2.3.zip" ;
    schema1:identifier biotools:qualimap ;
    schema1:license "GPL-2.0-or-later" ;
    schema1:name "qualimap" ;
    schema1:softwareVersion "2.3" ;
    schema1:url "http://qualimap.bioinfo.cipf.es/" ;
    spdx:builtFrom biotools:qualimap .

