@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:qualimap a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/bts503" ;
    schema1:description "Platform-independent application written in java and r that provides both a graphical user inteface (gui) and a command-line interface to facilitate the quality control of alignment sequencing data." ;
    schema1:identifier biotools:qualimap ;
    schema1:keywords "Data quality management",
        "Genomics",
        "High-Throughput Nucleotide Sequencing",
        "Humans",
        "Quality Control",
        "Sequence Alignment" ;
    schema1:license "GPL-2.0" ;
    schema1:name "qualimap" ;
    schema1:url "https://bitbucket.org/kokonech/qualimap/src/master/" .

