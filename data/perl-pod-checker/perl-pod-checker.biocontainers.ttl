@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:perl-pod-checker a schema1:SoftwareApplication ;
    schema1:description "Pod::checker verifies pod documentation contents for compliance with the pod format specifications" ;
    schema1:license "perl_5" ;
    schema1:name "perl-pod-checker" ;
    schema1:url "http://metacpan.org/pod/Pod::Checker" .

