@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:tagore a schema1:SoftwareApplication ;
    schema1:description "A simple way to visualize features on human chromosome ideograms" ;
    schema1:keywords "Genetics" ;
    schema1:license "GPL-3.0" ;
    schema1:name "tagore" ;
    schema1:url "https://github.com/jordanlab/tagore" .

