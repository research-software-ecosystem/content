@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-vega a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btq586" ;
    schema1:description "An R package for copy number data segmentation" ;
    schema1:identifier biotools:vega ;
    schema1:keywords "Brain Neoplasms",
        "Chromosome Aberrations",
        "Comparative Genomic Hybridization",
        "Computational Biology",
        "DNA Copy Number Variations",
        "DNA mutation",
        "Genome",
        "Glioblastoma",
        "Humans",
        "Lymphoma, Mantle-Cell",
        "Microarray experiment" ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-vega" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/Vega.html" .

