@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:strike a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btr587" ;
    schema1:description "A program to evaluate protein multiple sequence alignments using a single protein structure." ;
    schema1:identifier biotools:STRIKE ;
    schema1:keywords "Computational Biology",
        "Genomics",
        "Internet",
        "Nucleic acid structure analysis",
        "Protein Structure",
        "Protein structure analysis",
        "Proteins",
        "Sequence Alignment" ;
    schema1:license "file" ;
    schema1:name "strike" ;
    schema1:url "http://www.tcoffee.org/Projects/strike/index.html" .

