@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:strike a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btr587" ;
    schema1:description "A program to evaluate protein multiple sequence alignments using a single protein structure." ;
    schema1:downloadUrl "http://www.tcoffee.org/Projects/strike/download/strike_v1.2.tar.bz2" ;
    schema1:identifier biotools:STRIKE ;
    schema1:license "file" ;
    schema1:name "strike" ;
    schema1:softwareVersion "1.2" ;
    schema1:url "http://www.tcoffee.org/Projects/strike/index.html" ;
    spdx:builtFrom biotools:STRIKE .

