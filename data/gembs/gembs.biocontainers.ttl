@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:gembs a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1101/201988" ;
    schema1:description "gemBS is a bioinformatics pipeline designed for high throughput analysis of DNA methylation from Whole Genome Bisulfite Sequencing data (WGBS)." ;
    schema1:license "GPL-3.0" ;
    schema1:name "gembs" ;
    schema1:url "https://github.com/heathsc/gemBS" .

