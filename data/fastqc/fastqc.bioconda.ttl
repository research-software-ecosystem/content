@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:fastqc a schema1:SoftwareApplication ;
    schema1:description "A quality control tool for high throughput sequence data." ;
    schema1:downloadUrl "https://www.bioinformatics.babraham.ac.uk/projects/fastqc/fastqc_v0.12.1.zip" ;
    schema1:identifier biotools:fastqc ;
    schema1:license "GPL >=3" ;
    schema1:name "fastqc" ;
    schema1:softwareVersion "0.12.1" ;
    schema1:url "http://www.bioinformatics.babraham.ac.uk/projects/fastqc/" ;
    spdx:builtFrom biotools:fastqc .

