@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconvert a schema1:SoftwareApplication ;
    schema1:description "convert various bioinformatics formats" ;
    schema1:license "GPL-3.0" ;
    schema1:name "bioconvert" ;
    schema1:url "https://github.com/bioconvert/bioconvert" .

