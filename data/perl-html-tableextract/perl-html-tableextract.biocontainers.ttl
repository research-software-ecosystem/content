@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:perl-html-tableextract a schema1:SoftwareApplication ;
    schema1:description "Perl module for extracting the content contained in tables within an HTML document, either as text or encoded element trees." ;
