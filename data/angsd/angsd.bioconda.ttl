@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:angsd a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s12859-014-0356-4" ;
    schema1:description "ANGSD: Analysis of next generation Sequencing Data" ;
    schema1:downloadUrl "http://popgen.dk/software/download/angsd/angsd0.940.tar.gz" ;
    schema1:identifier biotools:angsd ;
    schema1:license "GPLv3, MIT" ;
    schema1:name "angsd" ;
    schema1:softwareVersion "0.94" ;
    schema1:url "http://www.popgen.dk/angsd/index.php/ANGSD" ;
    spdx:builtFrom biotools:angsd .

