@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:angsd a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s12859-014-0356-4" ;
    schema1:description "ANGSD: Analysis of next generation Sequencing Data" ;
    schema1:identifier biotools:angsd ;
    schema1:keywords "Gene Frequency",
        "Genetics, Population",
        "Genotype",
        "High-Throughput Nucleotide Sequencing",
        "Likelihood Functions",
        "Polymorphism, Single Nucleotide",
        "Population genetics",
        "Statistics and probability" ;
    schema1:license "GPL-3.0" ;
    schema1:name "angsd" ;
    schema1:url "https://github.com/ANGSD/angsd" .

