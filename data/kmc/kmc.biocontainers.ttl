@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:kmc a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btv022",
        "doi:10.1093/bioinformatics/btx304" ;
    schema1:description "Kmc is a utility designed for counting k-mers (sequences of consecutive k symbols) in a set of reads from genome sequencing projects." ;
    schema1:identifier biotools:KMC ;
    schema1:keywords "Animals",
        "Chickens",
        "Computational Biology",
        "Databases, Factual",
        "Genomics",
        "Humans",
        "Sequence Alignment",
        "Sequence assembly",
        "Whole genome sequencing" ;
    schema1:license "MIT" ;
    schema1:name "kmc" ;
    schema1:url "http://sun.aei.polsl.pl/REFRESH/index.php?page=projects&project=kmc&subpage=about" .

