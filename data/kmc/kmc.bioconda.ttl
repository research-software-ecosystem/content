@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:kmc a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btv022",
        "doi:10.1093/bioinformatics/btx304",
        "doi:10.1186/1471-2105-14-160" ;
    schema1:description "Tools for efficient k-mer counting and filtering of reads based on k-mer content." ;
    schema1:identifier biotools:kmc ;
    schema1:license "GPL-3.0-or-later" ;
    schema1:name "kmc" ;
    schema1:softwareHelp "https://github.com/refresh-bio/KMC/blob/v3.2.4/README.md" ;
    schema1:softwareVersion "3.2.4" ;
    schema1:url "https://github.com/refresh-bio/kmc" ;
    spdx:builtFrom biotools:kmc .

