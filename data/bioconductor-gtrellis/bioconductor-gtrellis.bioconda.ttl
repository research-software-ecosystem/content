@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-gtrellis a schema1:SoftwareApplication ;
    schema1:description "Genome Level Trellis Layout" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/gtrellis_1.42.1.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/gtrellis/gtrellis_1.42.1.tar.gz', 'https://bioarchive.galaxyproject.org/gtrellis_1.42.1.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-gtrellis/bioconductor-gtrellis_1.42.1_src_all.tar.gz']" ;
    schema1:identifier biotools:gtrellis ;
    schema1:license "MIT + file LICENSE" ;
    schema1:name "bioconductor-gtrellis" ;
    schema1:softwareVersion "1.42.1" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/gtrellis.html" ;
    spdx:builtFrom biotools:gtrellis .

