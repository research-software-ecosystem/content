@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-gtrellis a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s12859-016-1051-4" ;
    schema1:description "Visualize genomic data conditioned by genomic categories (e.g. chromosomes). for each genomic category, multiple dimensional data which are represented as tracks describe different features from different aspects. this package provides high flexibility to arrange genomic categories and to add self-defined graphics in the plot." ;
    schema1:identifier biotools:gtrellis ;
    schema1:keywords "Computer Graphics",
        "Databases, Genetic",
        "Genome, Human",
        "Genomics",
        "Humans",
        "Models, Theoretical",
        "Omics",
        "Sequence Alignment",
        "Sequencing" ;
    schema1:license "GPL-2.0" ;
    schema1:name "bioconductor-gtrellis" ;
    schema1:url "http://bioconductor.org/packages/release/bioc/html/gtrellis.html" .

