@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:rcorrector a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s13742-015-0089-y" ;
    schema1:description "Rcorrector(RNA-seq error CORRECTOR) is a kmer-based error correction method for RNA-seq data. Rcorrector can also be applied to other type of sequencing data where the read coverage is non-uniform, such as single-cell sequencing." ;
    schema1:identifier biotools:rcorrector ;
    schema1:keywords "RNA",
        "RNA-Seq",
        "Sequence Analysis, RNA",
        "Sequencing" ;
    schema1:license "GPL" ;
    schema1:name "rcorrector" ;
    schema1:url "https://github.com/mourisl/Rcorrector/" .

