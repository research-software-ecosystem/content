@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:rcorrector a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s13742-015-0089-y" ;
    schema1:description "Rcorrector (RNA-seq error CORRECTOR) is a kmer-based error correction method for RNA-seq data. Rcorrector can also be applied to other type of sequencing data where the read coverage is non-uniform, such as single-cell sequencing." ;
    schema1:downloadUrl "https://github.com/mourisl/Rcorrector/archive/refs/tags/v1.0.7.tar.gz" ;
    schema1:identifier biotools:rcorrector ;
    schema1:license "GPL-3.0-only" ;
    schema1:name "rcorrector" ;
    schema1:softwareHelp "https://github.com/mourisl/Rcorrector/blob/v1.0.7/README.md" ;
    schema1:softwareVersion "1.0.7" ;
    schema1:url "https://github.com/mourisl/Rcorrector" ;
    spdx:builtFrom biotools:rcorrector .

