@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:unitig-counter a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1371/journal.pgen.1007758" ;
    schema1:description "Uses a compressed de Bruijn graph (implemented in GATB) to count unitigs in bacterial populations." ;
    schema1:keywords "Computer Graphics",
        "DNA, Bacterial",
        "Databases, Genetic",
        "Drug Resistance, Bacterial",
        "Genetic Variation",
        "Genetics",
        "Genome, Bacterial",
        "Genome-Wide Association Study",
        "Interspersed Repetitive Sequences",
        "Models, Genetic",
        "Mycobacterium tuberculosis",
        "Phenotype",
        "Pseudomonas aeruginosa",
        "Sequence Analysis, DNA",
        "Staphylococcus aureus" ;
    schema1:license "GNU Affero General Public License" ;
    schema1:name "unitig-counter" ;
    schema1:url "https://github.com/johnlees/unitig-counter" .

