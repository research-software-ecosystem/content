@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-vision a schema1:SoftwareApplication ;
    schema1:description "A high-throughput and unbiased module for interpreting scRNA-seq data." ;
    schema1:keywords "Clustering",
        "RNA-Seq" ;
    schema1:license "MIT" ;
    schema1:name "r-vision" ;
    schema1:url "https://github.com/YosefLab/VISION" .

