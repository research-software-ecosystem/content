@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:rxdock a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1023/b:jcam.0000035199.48747.1e",
        "doi:10.1371/journal.pcbi.1003571" ;
    schema1:description "A fast, versatile, and open-source program for docking ligands to proteins and nucleic acids" ;
    schema1:keywords "Fluorescence Resonance Energy Transfer",
        "Hydrogen Bonding",
        "Ligands",
        "Models, Molecular",
        "RNA" ;
    schema1:license "LGPL-3.0" ;
    schema1:name "rxdock" ;
    schema1:url "https://github.com/rxdock/rxdock" .

