@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-nebulosa a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18129/b9.bioc.nebulosa" ;
    schema1:description "This package provides a enhanced visualization of single-cell data based on gene-weighted density estimation. Nebulosa recovers the signal from dropped-out features and allows the inspection of the joint expression from multiple features (e.g. genes). Seurat and SingleCellExperiment objects can be used within Nebulosa." ;
    schema1:keywords "Data visualisation",
        "Gene Expression",
        "Genomics" ;
    schema1:license "GPL-3.0" ;
    schema1:name "bioconductor-nebulosa" ;
    schema1:url "https://bioconductor.org/packages/3.12/bioc/html/Nebulosa.html" .

