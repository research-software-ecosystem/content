@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:plncpro a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/gkx866" ;
    schema1:description "PlncPRO is a program to predict long non-coding (lncRNAs) transcripts using Random Forests." ;
    schema1:identifier biotools:plncpro ;
    schema1:keywords "Adaptation, Physiological",
        "Cicer",
        "Computational Biology",
        "Droughts",
        "Gene Expression Profiling",
        "Gene Expression Regulation, Plant",
        "Oryza",
        "RNA",
        "RNA, Long Noncoding",
        "RNA, Plant",
        "Reproducibility of Results",
        "Reverse Transcriptase Polymerase Chain Reaction",
        "Salinity" ;
    schema1:license "GPL" ;
    schema1:name "plncpro" ;
    schema1:url "https://github.com/urmi-21/PLncPRO" .

