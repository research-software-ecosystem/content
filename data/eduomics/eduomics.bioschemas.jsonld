      "sc:citation": {
        "@id": "https://doi.org/10.1101/2025.11.24.690117"
      },
      "sc:description": "eduomics is a Nextflow pipeline designed to simulate -omics data for educational purposes, enabling students to gain practical bioinformatics skills and interpret results within a realistic biological context. It simplifies the simulation process by automating the workflow and removing dependencies typically required by data simulation tools.",
