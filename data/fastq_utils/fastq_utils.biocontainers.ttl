@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:fastq_utils a schema1:SoftwareApplication ;
    schema1:description "Validation and manipulation of FASTQ files, scRNA-seq barcode pre-processing and UMI quantification." ;
    schema1:keywords "RNA-Seq" ;
    schema1:license "GPL-3" ;
    schema1:name "fastq_utils" ;
    schema1:url "https://github.com/nunofonseca/fastq_utils" .

