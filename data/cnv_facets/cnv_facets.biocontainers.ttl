@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:cnv_facets a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/gkw520" ;
    schema1:description "Detect somatic copy number variants (CNV) in tumour-normal samples using next generation sequencing data" ;
    schema1:keywords "Adenocarcinoma",
        "Adenocarcinoma of Lung",
        "Alleles",
        "Clone Cells",
        "DNA Copy Number Variations",
        "Databases, Nucleic Acid",
        "Exome",
        "Gene Dosage",
        "Genetic Heterogeneity",
        "High-Throughput Nucleotide Sequencing",
        "Humans",
        "Loss of Heterozygosity",
        "Lung Neoplasms",
        "Sequence Analysis, DNA" ;
    schema1:license "MIT" ;
    schema1:name "cnv_facets" ;
    schema1:url "https://github.com/dariober/cnv_facets" .

