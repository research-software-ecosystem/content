@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:clipcontext a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s12864-020-07297-0" ;
    schema1:description "Extract CLIP-seq binding regions with both genomic and transcript context" ;
    schema1:keywords "Genomics",
        "Transcriptome" ;
    schema1:license "MIT" ;
    schema1:name "clipcontext" ;
    schema1:url "https://github.com/BackofenLab/CLIPcontext" .

