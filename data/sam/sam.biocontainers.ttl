@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:sam a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1177/0962280211428386" ;
    schema1:description "Sam - sequence alignment and modeling system." ;
    schema1:identifier biotools:sam ;
    schema1:keywords "Data mining",
        "Genetics",
        "Humans",
        "Microarray experiment",
        "Sequence Alignment",
        "Sequence Analysis, RNA",
        "Statistics, Nonparametric" ;
    schema1:license "academic" ;
    schema1:name "sam" ;
    schema1:url "https://compbio.soe.ucsc.edu/sam2src/" .

