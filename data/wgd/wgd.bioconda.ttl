@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:wgd a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1007/978-1-0716-2561-3_1",
        "doi:10.1093/bioinformatics/btae272" ;
    schema1:description "wgd v2: a suite of tools to uncover and date ancient polyploidy and whole-genome duplication" ;
    schema1:downloadUrl "https://pypi.io/packages/source/w/wgd/wgd-2.0.38.tar.gz" ;
    schema1:identifier biotools:wgd ;
    schema1:license "GPL-3.0-or-later" ;
    schema1:name "wgd" ;
    schema1:softwareHelp "https://wgdv2.readthedocs.io/en/latest/" ;
    schema1:softwareVersion "2.0.38" ;
    schema1:url "https://github.com/heche-psb/wgd" ;
    spdx:builtFrom biotools:wgd .

