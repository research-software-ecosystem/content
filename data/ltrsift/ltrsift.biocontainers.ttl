@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:ltrsift a schema1:SoftwareApplication ;
    schema1:description "Postprocessing and classification of ltr retrotransposons" ;
    schema1:license "custom, see /usr/share/doc/ltrsift/copyright" ;
    schema1:name "ltrsift" ;
    schema1:url "http://www.zbh.uni-hamburg.de/LTRsift" .

