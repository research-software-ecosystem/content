    schema1:description "co-expression of lincRNAs and protein-coding genes" ;
    schema1:identifier biotools:linc ;
    schema1:keywords "Computational Biology",
        "Gene Expression Profiling",
        "Gene expression",
        "Genomics",
        "High-Throughput Screening Assays",
        "Molecular interactions, pathways and networks",
        "Programming Languages",
        "User-Computer Interface" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-linc" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/LINC.html" .

