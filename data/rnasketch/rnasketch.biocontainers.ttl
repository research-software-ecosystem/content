@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:rnasketch a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btx263" ;
    schema1:description "Rnasketch library for designing rna molecules. glue between rnablueprint/rnaredprint and viennarna, nupack, hotknots, pkiss." ;
    schema1:keywords "Models, Molecular",
        "Nucleic Acid Conformation",
        "RNA",
        "Synthetic Biology" ;
    schema1:license "GNU General Public License v3.0" ;
    schema1:name "rnasketch" ;
    schema1:url "https://github.com/ViennaRNA/RNAsketch" .

