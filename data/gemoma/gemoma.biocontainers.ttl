@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:gemoma a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/gkw092",
        "doi:10.1186/s12859-018-2203-5" ;
    schema1:description "Gene model mapper (gemoma) is a homology-based gene prediction program. gemoma uses the annotation of protein-coding genes in a reference genome to infer the annotation of protein-coding genes in a target genome. thereby, gemoma utilizes amino acid sequence and intron position conservation. in addition, gemoma allows to incorporate rna-seq evidence for splice site prediction." ;
    schema1:identifier biotools:gemoma ;
    schema1:keywords "Animals",
        "Arabidopsis",
        "Base Sequence",
        "Carica",
        "Chickens",
        "Computational Biology",
        "Genomics",
        "High-Throughput Nucleotide Sequencing",
        "Homology modeling",
        "Humans",
        "Introns",
        "Mice",
        "Models, Genetic",
        "Molecular Sequence Annotation",
        "Oryza",
        "Polymerase Chain Reaction",
        "RNA, Messenger",
        "RNA-Seq",
        "Sequence Analysis, RNA",
        "Sequence Homology, Nucleic Acid",
        "Solanum tuberosum",
        "Tobacco" ;
    schema1:license "GPL-3" ;
    schema1:name "gemoma" ;
    schema1:url "http://www.jstacs.de/index.php/GeMoMa" .

