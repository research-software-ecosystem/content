  "@graph": [
    {
      "@id": "https://bio.tools/bioconductor-deconvr",
      "@type": "sc:SoftwareApplication",
      "dcterms:conformsTo": "https://bioschemas.org/profiles/ComputationalTool/0.6-DRAFT",
      "sc:additionalType": [
        "Library",
        "Command-line tool"
      ],
      "sc:author": [
        "Veronika Ebenal",
        "Irem B. Gündüz",
        "Altuna Akalin"
      ],
      "sc:citation": {
        "@id": "https://doi.org/10.18129/B9.bioc.deconvR"
      },
      "sc:description": "This package provides a collection of functions designed for analyzing deconvolution of the bulk sample(s) using an atlas of reference omic signature profiles and a user-selected model. Users are given the option to create or extend a reference atlas and,also simulate the desired size of the bulk signature profile of the reference cell types.The package includes the cell-type-specific methylation atlas and, Illumina Epic B5 probe ids that can be used in deconvolution. Additionally,we included BSmeth2Probe, to make mapping WGBS data to their probe IDs easier.",
      "sc:license": "Artistic-2.0",
      "sc:name": "deconvR",
      "sc:operatingSystem": [
        "Windows",
        "Linux",
        "Mac"
      ],
      "sc:softwareHelp": {
        "@id": "https://bioconductor.org/packages/deconvR"
      },
      "sc:softwareVersion": "1.16.0",
      "sc:url": "https://bioconductor.org/packages/deconvR"
    },
