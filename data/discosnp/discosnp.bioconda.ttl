@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:discosnp a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/gkn000" ;
    schema1:description "Reference-free small variant caller for short read sequencing data." ;
    schema1:downloadUrl "https://github.com/GATB/DiscoSnp/releases/download/v2.6.2/DiscoSNP.-v2.6.2-Source.tar.gz" ;
    schema1:identifier biotools:discosnp ;
    schema1:license "AGPL-3.0-or-later" ;
    schema1:name "discosnp" ;
    schema1:softwareHelp "https://gatb.inria.fr/software/discosnp" ;
    schema1:softwareVersion "2.6.2" ;
    schema1:url "https://github.com/GATB/DiscoSnp" ;
    spdx:builtFrom biotools:discosnp .

