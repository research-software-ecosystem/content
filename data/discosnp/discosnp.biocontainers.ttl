@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:discosnp a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/gkn000",
        "doi:10.1093/nar/gku1187" ;
    schema1:description "This software is designed for discovering single nucleotide polymorphism (snp) from raw set(s) of reads obtained with next generation sequencers (ngs)." ;
    schema1:identifier biotools:discosnp ;
    schema1:keywords "Animals",
        "Chromosomes, Human, Pair 1",
        "DNA polymorphism",
        "Escherichia coli",
        "Genetic variation",
        "Genetics",
        "Genomics",
        "Genotyping Techniques",
        "Humans",
        "Ixodes",
        "Mice",
        "Mice, Inbred C57BL",
        "Polymorphism, Single Nucleotide",
        "Saccharomyces cerevisiae",
        "Sequencing" ;
    schema1:license "CECILL-2.0" ;
    schema1:name "discosnp" ;
    schema1:url "https://github.com/GATB/DiscoSnp" .

