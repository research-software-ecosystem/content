@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-beclear a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1371/journal.pone.0159921" ;
    schema1:description "Correction of batch effects in DNA methylation data" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/BEclear_2.26.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/BEclear/BEclear_2.26.0.tar.gz', 'https://bioarchive.galaxyproject.org/BEclear_2.26.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-beclear/bioconductor-beclear_2.26.0_src_all.tar.gz']" ;
    schema1:identifier biotools:beclear ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-beclear" ;
    schema1:softwareVersion "2.26.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/BEclear.html" ;
    spdx:builtFrom biotools:beclear .

