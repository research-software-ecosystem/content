@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:refgenie a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1101/698704" ;
    schema1:description "Refgenie creates a standardized folder structure for reference genome files and indexes. you can download pre-built genomes or build your own for any fasta file" ;
    schema1:license "BSD-2-Clause" ;
    schema1:name "refgenie" ;
    schema1:url "https://github.com/databio/refgenie/" .

