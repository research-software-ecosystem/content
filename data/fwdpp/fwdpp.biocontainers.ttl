@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:fwdpp a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1534/genetics.114.165019" ;
    schema1:description "A C++ template library for forward-time population genetic simulation. " ;
    schema1:keywords "Genetics, Population",
        "Models, Genetic" ;
    schema1:license "https://raw.githubusercontent.com/molpopgen/fwdpp/master/LICENSE" ;
    schema1:name "fwdpp" ;
    schema1:url "https://www.github.com/molpopgen/fwdpp" .

