      "sc:citation": {
        "@id": "https://doi.org/10.1101/2025.10.05.680545"
      },
      "sc:description": "MS2extract is an R package for creating MS/MS spectral libraries by importing mass spectrometry data, extracting desired spectra, and exporting them in .msp format.  It facilitates the creation of in-house libraries suitable for compound identification and is compatible with GNPS2.",
