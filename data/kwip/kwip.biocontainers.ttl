@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:kwip a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1371/JOURNAL.PCBI.1005727",
        "doi:10.1371/journal.pcbi.1005727" ;
    schema1:description "kWIP implements a de novo, alignment free measure of sample genetic dissimilarity" ;
    schema1:identifier biotools:kWIP ;
    schema1:keywords "Chlamydomonas",
        "Comparative genomics",
        "Genetic Variation",
        "Genetics, Population",
        "Genomics",
        "Models, Genetic",
        "Models, Statistical",
        "Sequence Analysis, DNA",
        "Sequence analysis" ;
    schema1:license "GPL-3.0" ;
    schema1:name "kwip" ;
    schema1:url "https://github.com/kdmurray91/kWIP" .

