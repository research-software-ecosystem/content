@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:kwip a schema1:SoftwareApplication ;
    schema1:citation "doi:https://doi.org/10.1371/journal.pcbi.1005727" ;
    schema1:description "kWIP implements a de novo, alignment free measure of sample genetic dissimilarity" ;
    schema1:downloadUrl "https://github.com/kdmurray91/kWIP/archive/0.2.0.tar.gz" ;
    schema1:identifier biotools:kWIP ;
    schema1:license "GNU General Public License version 3" ;
    schema1:name "kwip" ;
    schema1:softwareVersion "0.2.0" ;
    schema1:url "https://github.com/kdmurray91/kWIP" ;
    spdx:builtFrom biotools:kWIP .

