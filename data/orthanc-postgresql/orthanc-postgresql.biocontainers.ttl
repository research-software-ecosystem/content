@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:orthanc-postgresql a schema1:SoftwareApplication ;
    schema1:description "Plugins to use postgresql as a database back-end to orthanc" ;
    schema1:license "AGPL-3" ;
    schema1:name "orthanc-postgresql" ;
    schema1:url "https://www.orthanc-server.com/static.php?page=postgresql" .

