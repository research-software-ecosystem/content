@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:tabix a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btq671" ;
    schema1:description "Library for reading/writing high-throughput sequencing data. is utilized and incorporated into both samtools and bcftools." ;
    schema1:keywords "Computational Biology",
        "Genome",
        "Genomics",
        "Information Storage and Retrieval",
        "Sequence Analysis, DNA" ;
    schema1:license "MIT" ;
    schema1:name "tabix" ;
    schema1:url "https://github.com/samtools/htslib" .

