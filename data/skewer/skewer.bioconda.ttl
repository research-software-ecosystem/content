@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:skewer a schema1:SoftwareApplication ;
    schema1:description "A fast and accurate adapter trimmer for paired-end reads." ;
    schema1:downloadUrl "https://github.com/relipmoc/skewer/archive/0.2.2.zip" ;
    schema1:identifier biotools:skewer ;
    schema1:license "MIT" ;
    schema1:name "skewer" ;
    schema1:softwareVersion "0.2.2" ;
    schema1:url "https://github.com/relipmoc/skewer.git" ;
    spdx:builtFrom biotools:skewer .

