@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:skewer a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/1471-2105-15-182" ;
    schema1:description "A fast and accurate adapter trimmer for paired-end reads." ;
    schema1:identifier biotools:skewer ;
    schema1:keywords "Animals",
        "Arabidopsis",
        "Caenorhabditis elegans",
        "Drosophila",
        "High-Throughput Nucleotide Sequencing",
        "Humans",
        "RNA-Seq",
        "Sequence Analysis, RNA",
        "Sequence assembly",
        "Sequencing",
        "Time Factors" ;
    schema1:license "MIT" ;
    schema1:name "skewer" ;
    schema1:url "https://github.com/relipmoc/skewer.git" .

