  "@graph": [
    {
      "@id": "https://bio.tools/bioconductor-podcall",
      "@type": "sc:SoftwareApplication",
      "dcterms:conformsTo": "https://bioschemas.org/profiles/ComputationalTool/0.6-DRAFT",
      "sc:additionalType": [
        "Command-line tool",
        "Library"
      ],
      "sc:author": [
        "Hans Petter Brodal",
        "Marine Jeanmougin",
        "Guro Elisabeth Lind"
      ],
      "sc:citation": {
        "@id": "https://doi.org/10.18129/B9.bioc.PoDCall"
      },
      "sc:description": "Reads files exported from 'QX Manager or QuantaSoft' containing amplitude values from a run of ddPCR (96 well plate) and robustly sets thresholds to determine positive droplets for each channel of each individual well. Concentration and normalized concentration in addition to other metrics is then calculated for each well. Results are returned as a table, optionally written to file, as well as optional plots (scatterplot and histogram) for both channels per well written to file. The package includes a shiny application which provides an interactive and user-friendly interface to the full functionality of PoDCall.",
      "sc:license": "GPL-3.0-only",
      "sc:name": "PoDCall",
      "sc:operatingSystem": [
        "Linux",
        "Windows",
        "Mac"
      ],
      "sc:softwareHelp": {
        "@id": "https://bioconductor.org/packages/PoDCall"
      },
      "sc:softwareVersion": "1.18.0",
      "sc:url": "https://bioconductor.org/packages/PoDCall"
    },
    {
      "@id": "https://doi.org/10.18129/B9.bioc.PoDCall",
      "@type": "sc:CreativeWork"
    }
  ]
