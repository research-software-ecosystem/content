@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:e-mem a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btu687" ;
    schema1:description "Efficient computation of maximal exact matches for very large genomes" ;
    schema1:keywords "Animals",
        "Databases, Factual",
        "Genome",
        "Humans",
        "Mice",
        "Programming Languages",
        "Sequence Alignment",
        "Sequence Analysis, DNA",
        "Species Specificity",
        "Systems Biology",
        "Triticum" ;
    schema1:license "GPL-3.0+" ;
    schema1:name "e-mem" ;
    schema1:url "https://github.com/lucian-ilie/E-MEM" .

