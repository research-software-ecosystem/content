@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:lua a schema1:SoftwareApplication ;
    schema1:description "Lua is a powerful, fast, lightweight, embeddable scripting language" ;
    schema1:license "MIT" ;
    schema1:name "lua" ;
    schema1:url "https://www.lua.org/start.html" .

