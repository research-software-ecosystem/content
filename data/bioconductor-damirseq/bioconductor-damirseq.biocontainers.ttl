@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-damirseq a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18129/b9.bioc.damirseq" ;
    schema1:description "Data Mining for RNA-seq data: normalization, feature selection and classification" ;
    schema1:keywords "Clustering",
        "RNA-Seq" ;
    schema1:license "GPL-2.0" ;
    schema1:name "bioconductor-damirseq" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/DaMiRseq.html" .

