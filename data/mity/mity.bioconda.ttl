@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:mity a schema1:SoftwareApplication ;
    schema1:author "tm4zza" ;
    schema1:citation "doi:10.26502/jbsb.5107074" ;
    schema1:description "Mity is a bioinformatic analysis pipeline designed to call mitochondrial SNV and INDEL variants from Whole Genome Sequencing (WGS) data." ;
    schema1:downloadUrl "https://github.com/KCCG/mity/archive/refs/tags/2.0.1.zip" ;
    schema1:identifier biotools:mity ;
    schema1:license "MIT" ;
    schema1:maintainer "tm4zza" ;
    schema1:name "mity" ;
    schema1:softwareHelp "https://github.com/KCCG/mity/blob/2.0.1/README.md" ;
    schema1:softwareVersion "2.0.1" ;
    schema1:url "https://github.com/KCCG/mity" ;
    spdx:builtFrom biotools:mity .

