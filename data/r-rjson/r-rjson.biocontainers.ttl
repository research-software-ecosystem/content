@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-rjson a schema1:SoftwareApplication ;
    schema1:description "Converts R object into JSON objects and vice-versa." ;
    schema1:license "GPL-2.0" ;
    schema1:name "r-rjson" ;
    schema1:url "https://CRAN.R-project.org/package=rjson" .

