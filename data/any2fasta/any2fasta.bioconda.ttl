@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:any2fasta a schema1:SoftwareApplication ;
    schema1:description "Convert various sequence formats to FASTA" ;
    schema1:downloadUrl "https://github.com/tseemann/any2fasta/archive/v0.8.1.tar.gz" ;
    schema1:identifier biotools:any2fasta ;
    schema1:license "GPL-3.0" ;
    schema1:name "any2fasta" ;
    schema1:softwareVersion "0.8.1" ;
    schema1:url "https://github.com/tseemann/any2fasta" ;
    spdx:builtFrom biotools:any2fasta .

