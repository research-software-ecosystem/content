@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:spectra-cluster-cli a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3902" ;
    schema1:description "This is a stand-alone implementation of the new updated pride cluster algorithm. it is based on the spectra-cluster api and uses a highly similar logic as the hadoop implementation spectra-cluster-hadoop used to build the pride cluster resource." ;
    schema1:keywords "Clustering",
        "Mass Spectrometry",
        "Proteomics" ;
    schema1:license "Apache-2.0" ;
    schema1:name "spectra-cluster-cli" ;
    schema1:url "https://github.com/spectra-cluster/spectra-cluster-cli" .

