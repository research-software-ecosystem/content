@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:nerpa a schema1:SoftwareApplication ;
    schema1:author "alexeigurevich" ;
    schema1:citation "doi:10.1101/2024.11.19.624380v3",
        "doi:10.3390/metabo11100693" ;
    schema1:description "A tool for discovering biosynthetic gene clusters of nonribosomal peptides." ;
    schema1:downloadUrl "https://github.com/gurevichlab/nerpa/releases/download/nerpa_2.1.0/nerpa-2.1.0.tar.gz" ;
    schema1:identifier biotools:nerpa ;
    schema1:license "Dual-licensed under GPLv3 or CC BY-NC-SA 4.0" ;
    schema1:maintainer "alexeigurevich" ;
    schema1:name "nerpa" ;
    schema1:softwareHelp "https://github.com/gurevichlab/nerpa/blob/nerpa_2.1.0/README.md" ;
    schema1:softwareVersion "2.1.0" ;
    schema1:url "https://github.com/gurevichlab/nerpa" ;
    spdx:builtFrom biotools:nerpa .

