@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:nerpa a schema1:SoftwareApplication ;
    schema1:author "alexeigurevich" ;
    schema1:description "A tool for discovering biosynthetic gene clusters of nonribosomal peptides." ;
    schema1:downloadUrl "https://github.com/ablab/nerpa/releases/download/v1.0.0/nerpa-1.0.0.tar.gz" ;
    schema1:identifier biotools:nerpa ;
    schema1:license "Dual-licensed under GPLv3 or CC BY-NC-SA 4.0" ;
    schema1:maintainer "alexeigurevich" ;
    schema1:name "nerpa" ;
    schema1:softwareHelp "https://github.com/ablab/nerpa" ;
    schema1:softwareVersion "1.0.0" ;
    schema1:url "https://cab.spbu.ru/software/nerpa" ;
    spdx:builtFrom biotools:nerpa .

