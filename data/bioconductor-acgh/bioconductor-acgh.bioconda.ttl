@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-acgh a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/bti677" ;
    schema1:description "Classes and functions for Array Comparative Genomic Hybridization data" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/aCGH_1.84.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/aCGH/aCGH_1.84.0.tar.gz', 'https://bioarchive.galaxyproject.org/aCGH_1.84.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-acgh/bioconductor-acgh_1.84.0_src_all.tar.gz']" ;
    schema1:identifier biotools:acgh ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-acgh" ;
    schema1:softwareVersion "1.84.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/aCGH.html" ;
    spdx:builtFrom biotools:acgh .

