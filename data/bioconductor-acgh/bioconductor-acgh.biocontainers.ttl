@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-acgh a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/bti677" ;
    schema1:description "Classes and functions for Array Comparative Genomic Hybridization data" ;
    schema1:identifier biotools:acgh ;
    schema1:keywords "Carcinoma, Squamous Cell",
        "Computational Biology",
        "Computer Simulation",
        "DNA",
        "DNA structural variation",
        "Data Interpretation, Statistical",
        "Databases, Genetic",
        "Gene Expression Regulation, Neoplastic",
        "Gene Library",
        "Genetic Techniques",
        "Genetics",
        "Genome",
        "Genomics",
        "Humans",
        "Internet",
        "Microarray experiment",
        "Mouth Neoplasms",
        "Nucleic Acid Hybridization",
        "Sequence Analysis, DNA" ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-acgh" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/aCGH.html" .

