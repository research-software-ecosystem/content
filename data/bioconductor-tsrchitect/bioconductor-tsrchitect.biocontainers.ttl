@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-tsrchitect a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18129/b9.bioc.tsrchitect" ;
    schema1:description "Promoter identification from large-scale TSS profiling data" ;
    schema1:keywords "Clustering",
        "Gene Expression",
        "Genomics" ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-tsrchitect" ;
    schema1:url "https://bioconductor.org/packages/3.8/bioc/html/TSRchitect.html" .

