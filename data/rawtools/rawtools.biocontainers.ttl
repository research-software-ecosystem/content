@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:rawtools a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1021/acs.jproteome.8b00721" ;
    schema1:description "RawTools is an open-source and freely available package designed to perform scan data parsing and quantification, and quality control analysis of Thermo Orbitrap raw mass spectrometer files." ;
    schema1:identifier biotools:rawtools ;
    schema1:keywords "Data Analysis",
        "Database Management Systems",
        "Information Storage and Retrieval",
        "Mass Spectrometry",
        "Proteomics",
        "Proteomics experiment" ;
    schema1:license "Apache License, Version 2.0" ;
    schema1:name "rawtools" ;
    schema1:url "https://github.com/kevinkovalchik/RawTools" .

