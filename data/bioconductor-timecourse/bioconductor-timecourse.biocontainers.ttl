@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-timecourse a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Statistical Analysis for Developmental Microarray Time Course Data" ;
    schema1:identifier biotools:timecourse ;
    schema1:keywords "Computational Biology",
        "Gene Expression Profiling",
        "Genomics",
        "High-Throughput Screening Assays",
        "Microarray experiment",
        "Programming Languages",
        "User-Computer Interface" ;
    schema1:license "LGPL" ;
    schema1:name "bioconductor-timecourse" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/timecourse.html" .

