@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-timecourse a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Statistical Analysis for Developmental Microarray Time Course Data" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/timecourse_1.82.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/timecourse/timecourse_1.82.0.tar.gz', 'https://bioarchive.galaxyproject.org/timecourse_1.82.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-timecourse/bioconductor-timecourse_1.82.0_src_all.tar.gz']" ;
    schema1:identifier biotools:timecourse ;
    schema1:license "LGPL" ;
    schema1:name "bioconductor-timecourse" ;
    schema1:softwareVersion "1.82.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/timecourse.html" ;
    spdx:builtFrom biotools:timecourse .

