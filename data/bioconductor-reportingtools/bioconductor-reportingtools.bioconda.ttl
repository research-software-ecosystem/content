@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-reportingtools a schema1:SoftwareApplication ;
    schema1:description "Tools for making reports in various formats" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/ReportingTools_2.46.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/ReportingTools/ReportingTools_2.46.0.tar.gz', 'https://bioarchive.galaxyproject.org/ReportingTools_2.46.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-reportingtools/bioconductor-reportingtools_2.46.0_src_all.tar.gz']" ;
    schema1:identifier biotools:reportingtools ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-reportingtools" ;
    schema1:softwareVersion "2.46.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/ReportingTools.html" ;
    spdx:builtFrom biotools:reportingtools .

