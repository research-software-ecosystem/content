@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:mashmap a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s13059-016-0997-x" ;
    schema1:description "a fast and approximate long read mapper" ;
    schema1:identifier biotools:mash ;
    schema1:keywords "Cluster Analysis",
        "DNA mutation",
        "Databases, Nucleic Acid",
        "Evolution, Molecular",
        "Genome",
        "Genomics",
        "Metagenome",
        "Metagenomics",
        "Ortholog",
        "Phylogeny",
        "Sequence Alignment",
        "Sequence analysis",
        "Statistics and probability" ;
    schema1:license "Custom" ;
    schema1:name "mashmap" ;
    schema1:url "https://github.com/marbl/MashMap" .

