@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:mashmap a schema1:SoftwareApplication ;
    schema1:author "bkille",
        "mjsteinbaugh" ;
    schema1:citation "doi:10.1007/978-3-319-56970-3_5",
        "doi:10.1093/bioinformatics/bty597",
        "doi:10.1101/2023.05.16.540882" ;
    schema1:description "A fast approximate aligner for long DNA sequences." ;
    schema1:downloadUrl "https://github.com/marbl/MashMap/archive/v3.1.3.tar.gz" ;
    schema1:identifier biotools:mashmap ;
    schema1:license "Custom" ;
    schema1:maintainer "bkille",
        "mjsteinbaugh" ;
    schema1:name "mashmap" ;
    schema1:softwareHelp "https://github.com/marbl/MashMap/blob/v3.1.3/README.md" ;
    schema1:softwareVersion "3.1.3" ;
    schema1:url "https://github.com/marbl/MashMap" ;
    spdx:builtFrom biotools:mashmap .

