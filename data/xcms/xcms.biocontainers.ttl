@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:xcms a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btq441" ;
    schema1:description "This is the git repository matching the Bioconductor package xcms: LC/MS and GC/MS Data Analysis" ;
    schema1:identifier biotools:xcms ;
    schema1:keywords "Biological imaging",
        "Calibration",
        "Chromatography, Liquid",
        "Data visualisation",
        "Databases, Factual",
        "Mass Spectrometry",
        "Metabolomics",
        "Proteome" ;
    schema1:license "Custom Licesnse" ;
    schema1:name "xcms" ;
    schema1:url "https://github.com/sneumann/xcms" .

