@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:openjdk a schema1:SoftwareApplication ;
    schema1:description "Open-source implementation of the Java Platform, Standard Edition, and related projects." ;
    schema1:license "GPLv2" ;
    schema1:name "openjdk" ;
    schema1:url "https://openjdk.java.net/" .

