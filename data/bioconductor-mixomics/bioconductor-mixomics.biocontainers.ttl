    schema1:description "Omics Data Integration Project" ;
    schema1:keywords "Genomics",
        "Metabolomics",
        "Metagenomics",
        "Proteomics",
        "Transcriptomics" ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-mixomics" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/mixOmics.html" .

