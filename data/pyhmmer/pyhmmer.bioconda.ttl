@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:pyhmmer a schema1:SoftwareApplication ;
    schema1:author "althonos" ;
    schema1:citation "doi:10.1093/bioinformatics/btad214" ;
    schema1:description "Cython bindings and Python interface to HMMER3." ;
    schema1:downloadUrl "https://pypi.org/packages/source/p/pyhmmer/pyhmmer-0.12.1.tar.gz" ;
    schema1:identifier biotools:pyhmmer ;
    schema1:license "MIT" ;
    schema1:maintainer "althonos" ;
    schema1:name "pyhmmer" ;
    schema1:softwareHelp "https://pyhmmer.readthedocs.io" ;
    schema1:softwareVersion "0.12.1" ;
    schema1:url "https://github.com/althonos/pyhmmer" ;
    spdx:builtFrom biotools:pyhmmer .

