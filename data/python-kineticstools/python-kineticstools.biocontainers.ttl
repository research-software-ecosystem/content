@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:python-kineticstools a schema1:SoftwareApplication ;
    schema1:description "Tools for detecting DNA modifications from single molecule, real-time sequencing data" ;
    schema1:license "Custom License" ;
    schema1:name "python-kineticstools" ;
    schema1:url "https://github.com/PacificBiosciences/kineticsTools" .

