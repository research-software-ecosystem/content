@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:hera a schema1:SoftwareApplication ;
    schema1:description "hera is a bioinformatics tool that helps analyze RNA-seq data, providing base-to-base alignment BAM files, transcript abundance estimation, and fusion gene detection." ;
    schema1:keywords "RNA-Seq",
        "Transcriptome",
        "Transcriptomics" ;
    schema1:license "MIT" ;
    schema1:name "hera" ;
    schema1:url "https://github.com/bioturing/hera" .

