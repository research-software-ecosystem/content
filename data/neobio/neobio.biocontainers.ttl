@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:neobio a schema1:SoftwareApplication ;
    schema1:description "Neobio is a java class library of computational biology algorithms. the current version consists mainly of pairwise sequence alignment algorithms such as the classical dynamic programming methods of needleman-wunsch and smith-waterman." ;
    schema1:identifier biotools:neobio ;
    schema1:keywords "Algorithms",
        "Biology",
        "Computational biology",
        "Protein Sequences",
        "Protein Structure",
        "Sequence Alignment" ;
    schema1:license "GPL-2+" ;
    schema1:name "neobio" ;
    schema1:url "http://neobio.sourceforge.net/" .

