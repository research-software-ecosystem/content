@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:genome_updater a schema1:SoftwareApplication ;
    schema1:description "Genome_updater: bash script to download and update snapshots of the ncbi genomes" ;
