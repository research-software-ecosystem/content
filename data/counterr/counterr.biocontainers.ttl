@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:counterr a schema1:SoftwareApplication ;
    schema1:description "Counterr is a light-weight command line tool that computes errors in sequencing data by comparing the reads to a reference genome." ;
    schema1:license "GNU General Public License v3.0" ;
    schema1:name "counterr" ;
    schema1:url "https://github.com/dayzerodx/counterr" .

