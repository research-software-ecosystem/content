@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-beadarray a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btm311" ;
    schema1:description "Quality assessment and low-level analysis for Illumina BeadArray data" ;
    schema1:identifier biotools:beadarray ;
    schema1:keywords "Data management",
        "Data quality management",
        "Databases, Genetic",
        "Image Interpretation, Computer-Assisted",
        "Imaging",
        "In Situ Hybridization, Fluorescence",
        "Microspheres",
        "Oligonucleotide Array Sequence Analysis",
        "Programming Languages",
        "Sequence Analysis, DNA" ;
    schema1:license "MIT" ;
    schema1:name "bioconductor-beadarray" ;
    schema1:url "https://bioconductor.org/packages/release/bioc/html/beadarray.html" .

