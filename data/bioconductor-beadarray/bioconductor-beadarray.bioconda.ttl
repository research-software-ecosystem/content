@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-beadarray a schema1:SoftwareApplication ;
    schema1:description "Quality assessment and low-level analysis for Illumina BeadArray data" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/beadarray_2.56.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/beadarray/beadarray_2.56.0.tar.gz', 'https://bioarchive.galaxyproject.org/beadarray_2.56.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-beadarray/bioconductor-beadarray_2.56.0_src_all.tar.gz']" ;
    schema1:identifier biotools:beadarray ;
    schema1:license "MIT + file LICENSE" ;
    schema1:name "bioconductor-beadarray" ;
    schema1:softwareVersion "2.56.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/beadarray.html" ;
    spdx:builtFrom biotools:beadarray .

