@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bcool a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/BIOINFORMATICS/BTZ548" ;
    schema1:description "Bcool is a read corrector for ngs sequencing data that align reads on a de bruijn graph. version described at (https://arxiv.org/abs/1711.03336) presented at recomb-seq 2018" ;
    schema1:license "GNU Affero General Public License" ;
    schema1:name "bcool" ;
    schema1:url "https://github.com/Malfoy/BCOOL" .

