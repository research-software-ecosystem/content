@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:yaggo a schema1:SoftwareApplication ;
    schema1:description "Yaggo is a tool to generate command line parsers for c++. yaggo stands for (yet another gengetopt) and is inspired by gnu gengetopt." ;
    schema1:license "GNU" ;
    schema1:name "yaggo" ;
    schema1:url "https://github.com/gmarcais/yaggo" .

