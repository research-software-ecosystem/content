@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-correp a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Multivariate Correlation Estimator and Statistical Inference Procedures." ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.18/bioc/src/contrib/CORREP_1.68.0.tar.gz', 'https://bioconductor.org/packages/3.18/bioc/src/contrib/Archive/CORREP/CORREP_1.68.0.tar.gz', 'https://bioarchive.galaxyproject.org/CORREP_1.68.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-correp/bioconductor-correp_1.68.0_src_all.tar.gz']" ;
    schema1:identifier biotools:correp ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-correp" ;
    schema1:softwareVersion "1.68.0" ;
    schema1:url "https://bioconductor.org/packages/3.18/bioc/html/CORREP.html" ;
    spdx:builtFrom biotools:correp .

