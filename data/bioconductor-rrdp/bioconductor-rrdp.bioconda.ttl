@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-rrdp a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Interface to the RDP Classifier" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/rRDP_1.44.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/rRDP/rRDP_1.44.0.tar.gz', 'https://bioarchive.galaxyproject.org/rRDP_1.44.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-rrdp/bioconductor-rrdp_1.44.0_src_all.tar.gz']" ;
    schema1:identifier biotools:rrdp ;
    schema1:license "GPL-2 + file LICENSE" ;
    schema1:name "bioconductor-rrdp" ;
    schema1:softwareVersion "1.44.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/rRDP.html" ;
    spdx:builtFrom biotools:rrdp .

