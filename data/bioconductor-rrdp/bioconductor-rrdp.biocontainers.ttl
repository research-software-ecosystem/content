        "High-Throughput Screening Assays",
        "Microbiology",
        "Programming Languages",
        "Sequence analysis",
        "User-Computer Interface" ;
    schema1:license "GPL-2.0" ;
    schema1:name "bioconductor-rrdp" ;
    schema1:url "http://bioconductor.org/packages/release/bioc/html/rRDP.html" .

