@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:spacedust a schema1:SoftwareApplication ;
    schema1:author "milot-mirdita" ;
    schema1:citation "doi:10.1101/2024.10.02.616292v1" ;
    schema1:description "De novo discovery of conserved gene clusters in microbial genomes with Spacedust" ;
    schema1:downloadUrl "https://github.com/soedinglab/spacedust/archive/2-e56c505.tar.gz" ;
    schema1:identifier biotools:spacedust ;
    schema1:license "GPL-3" ;
    schema1:maintainer "milot-mirdita" ;
    schema1:name "spacedust" ;
    schema1:softwareVersion "2.e56c505" ;
    schema1:url "https://github.com/soedinglab/spacedust" ;
    spdx:builtFrom biotools:spacedust .

