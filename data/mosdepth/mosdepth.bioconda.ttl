@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:mosdepth a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btx699" ;
    schema1:description "Fast BAM/CRAM depth calculation for WGS, exome, or targeted sequencing." ;
    schema1:downloadUrl "https://github.com/brentp/mosdepth/archive/refs/tags/v0.3.13.tar.gz" ;
    schema1:identifier biotools:mosdepth ;
    schema1:license "MIT" ;
    schema1:name "mosdepth" ;
    schema1:softwareHelp "https://github.com/brentp/mosdepth/blob/v0.3.13/README.md" ;
    schema1:softwareVersion "0.3.13" ;
    schema1:url "https://github.com/brentp/mosdepth" ;
    spdx:builtFrom biotools:mosdepth .

