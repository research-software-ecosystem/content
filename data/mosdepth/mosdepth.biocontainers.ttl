@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:mosdepth a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btx699" ;
    schema1:description "Fast BAM/CRAM depth calculation for WGS, exome, or targeted sequencing." ;
    schema1:identifier biotools:mosdepth ;
    schema1:keywords "Data quality management",
        "Genetics",
        "Genome, Human",
        "Genomics",
        "High-Throughput Nucleotide Sequencing",
        "Humans",
        "Sequence Analysis, DNA",
        "Statistics and probability",
        "Whole Exome Sequencing" ;
    schema1:license "MIT" ;
    schema1:name "mosdepth" ;
    schema1:url "https://github.com/brentp/mosdepth/" .

