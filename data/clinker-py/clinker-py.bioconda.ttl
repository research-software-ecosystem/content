@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:clinker-py a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btab007" ;
    schema1:description "Gene cluster comparison figure generator" ;
    schema1:downloadUrl "https://pypi.io/packages/source/c/clinker/clinker-0.0.32.tar.gz" ;
    schema1:identifier biotools:clinker ;
    schema1:license "MIT" ;
    schema1:name "clinker-py" ;
    schema1:softwareHelp "https://github.com/gamcil/clinker/blob/master/README.md" ;
    schema1:softwareVersion "0.0.32" ;
    schema1:url "https://github.com/gamcil/clinker" ;
    spdx:builtFrom biotools:clinker .

