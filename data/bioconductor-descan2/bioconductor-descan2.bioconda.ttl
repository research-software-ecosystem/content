    schema1:identifier biotools:descan2 ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-descan2" ;
    schema1:softwareVersion "1.30.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/DEScan2.html" ;
    spdx:builtFrom biotools:descan2 .

