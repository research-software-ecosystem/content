@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:spydrpick a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/gkz656" ;
    schema1:description "Mutual information based detection of pairs of genomic loci co-evolving under a shared selective pressure" ;
    schema1:keywords "Computational Biology",
        "Drug Resistance, Microbial",
        "Epistasis, Genetic",
        "Genome, Bacterial",
        "Genomics",
        "Humans",
        "Metagenomics",
        "Neisseria meningitidis",
        "Streptococcus pneumoniae",
        "Virulence" ;
    schema1:license "GNU Affero General Public License" ;
    schema1:name "spydrpick" ;
    schema1:url "https://github.com/santeripuranen/SpydrPick" .

