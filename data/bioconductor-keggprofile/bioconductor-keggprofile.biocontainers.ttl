@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-keggprofile a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18129/b9.bioc.keggprofile" ;
    schema1:description "An annotation and visualization package for multi-types and multi-groups expression data in KEGG pathway" ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-keggprofile" ;
    schema1:url "https://bioconductor.org/packages/3.8/bioc/html/KEGGprofile.html" .

