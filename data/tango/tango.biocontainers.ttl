@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:tango a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nbt1012" ;
    schema1:description "Assign taxonomy to metagenomic contigs" ;
    schema1:identifier biotools:tango ;
    schema1:keywords "Amino Acid Substitution",
        "Binding Sites",
        "Computer Simulation",
        "Dimerization",
        "Genomics",
        "Metagenomics",
        "Models, Chemical",
        "Models, Molecular",
        "Models, Statistical",
        "Multiprotein Complexes",
        "Mutagenesis, Site-Directed",
        "Mutation",
        "Peptides",
        "Protein Binding",
        "Protein Conformation",
        "Protein sites, features and motifs",
        "Proteins",
        "Structure analysis",
        "Structure-Activity Relationship",
        "Transcriptomics" ;
    schema1:license "MIT" ;
    schema1:name "tango" ;
    schema1:url "https://github.com/johnne/tango" .

