@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:binsanity a schema1:SoftwareApplication ;
    schema1:citation "doi:10.7717/peerj.3035" ;
    schema1:description "Method to cluster contigs based a biphasic method with coverage and composition" ;
    schema1:identifier biotools:binsanity ;
    schema1:keywords "Clustering",
        "Metagenomics" ;
    schema1:license "GPL-3.0" ;
    schema1:name "binsanity" ;
    schema1:url "https://github.com/edgraham/BinSanity" .

