@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:metagenome-atlas a schema1:SoftwareApplication ;
    schema1:description "Atlas - three commands to start analysing your metagenome data" ;
    schema1:keywords "Genomics",
        "Metagenome",
