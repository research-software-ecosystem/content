@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-monocle a schema1:SoftwareApplication ;
    schema1:description "Clustering, differential expression, and trajectory analysis for single- cell RNA-Seq" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/monocle_2.38.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/monocle/monocle_2.38.0.tar.gz', 'https://bioarchive.galaxyproject.org/monocle_2.38.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-monocle/bioconductor-monocle_2.38.0_src_all.tar.gz']" ;
    schema1:identifier biotools:monocle ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-monocle" ;
    schema1:softwareVersion "2.38.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/monocle.html" ;
    spdx:builtFrom biotools:monocle .

