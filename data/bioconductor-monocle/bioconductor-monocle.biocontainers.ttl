@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-monocle a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.4150",
        "doi:10.1038/nmeth.4402" ;
    schema1:description "Clustering, differential expression, and trajectory analysis for single- cell RNA-Seq" ;
    schema1:identifier biotools:monocle ;
    schema1:keywords "Animals",
        "Cell Differentiation",
        "Cell biology",
        "Clustering",
        "Computer Simulation",
        "Gene Expression Regulation, Developmental",
        "Gene expression",
        "Models, Biological",
        "Mutation",
        "PCR experiment",
        "RNA-Seq",
        "RNA-seq",
        "Transcription Factors",
        "Transcriptome" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-monocle" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/monocle.html" .

