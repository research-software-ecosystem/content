@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:perl-estscan1 a schema1:SoftwareApplication ;
    schema1:description "Detects coding regions in dna sequences even if they are of low quality. estscan.pm contains the perl part of the code that reads in the matrices file. the c code that does the actual computation is located in estscan.c." ;
    schema1:keywords "Protein Sequences" ;
    schema1:license "Not available" ;
    schema1:name "perl-estscan1" ;
    schema1:url "http://estscan.sourceforge.net" .

