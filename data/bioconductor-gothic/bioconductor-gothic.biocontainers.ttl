@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-gothic a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1101/gr.185272.114" ;
    schema1:description "This is a hi-c analysis package using a cumulative binomial test to detect interactions between distal genomic loci that have significantly more reads than expected by chance in hi-c experiments. it takes mapped paired ngs reads as input and gives back the list of significant interactions for a given bin size in the genome." ;
    schema1:identifier biotools:gothic ;
    schema1:keywords "Animals",
        "Binding Sites",
        "Chromatin",
        "Embryonic Stem Cells",
        "Enhancer Elements, Genetic",
        "Epigenesis, Genetic",
        "Epigenetics",
        "Gene Expression",
        "Gene Expression Regulation, Developmental",
        "Histones",
        "Liver",
        "Mapping",
        "Mice",
        "Mice, Inbred C57BL",
        "Molecular interactions, pathways and networks",
        "Promoter Regions, Genetic",
        "Transcription Factors",
        "Transcription factors and regulatory sites",
        "Transcriptomics" ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-gothic" ;
    schema1:url "https://bioconductor.org/packages/devel/bioc/html/MetaVolcanoR.html" .

