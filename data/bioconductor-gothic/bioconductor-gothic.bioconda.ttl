    schema1:license "GPL-3" ;
    schema1:name "bioconductor-gothic" ;
    schema1:softwareVersion "1.42.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/GOTHiC.html" ;
    spdx:builtFrom biotools:gothic .

