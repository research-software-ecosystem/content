@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-maldirppa a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btx628" ;
    schema1:description "Provides methods for quality control and robust pre-processing and analysis of MALDI mass spectrometry data." ;
    schema1:keywords "Mass spectra",
        "Mass spectrometry",
        "Proteomics" ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "r-maldirppa" ;
    schema1:url "https://CRAN.R-project.org/package=MALDIrppa" .

