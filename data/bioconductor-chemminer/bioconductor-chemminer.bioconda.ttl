@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-chemminer a schema1:SoftwareApplication ;
    schema1:description "Cheminformatics Toolkit for R" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/ChemmineR_3.62.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/ChemmineR/ChemmineR_3.62.0.tar.gz', 'https://bioarchive.galaxyproject.org/ChemmineR_3.62.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-chemminer/bioconductor-chemminer_3.62.0_src_all.tar.gz']" ;
    schema1:identifier biotools:chemminer ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-chemminer" ;
    schema1:softwareVersion "3.62.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/ChemmineR.html" ;
    spdx:builtFrom biotools:chemminer .

