@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-chemminer a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btn307" ;
    schema1:description "Cheminformatics Toolkit for R" ;
    schema1:identifier biotools:chemminer ;
    schema1:keywords "Biopolymers",
        "Cheminformatics",
        "Clustering",
        "Database Management Systems",
        "Databases, Factual",
        "Genetics",
        "Genomics",
        "Information Storage and Retrieval",
        "Metabolomics",
        "Programming Languages",
        "Proteomics" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-chemminer" ;
    schema1:url "https://bioconductor.org/packages/release/bioc/html/ChemmineR.html" .

