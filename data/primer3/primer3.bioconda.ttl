@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:primer3 a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/gks596" ;
    schema1:description "Design PCR primers from DNA sequence. From mispriming libraries to sequence quality data to the generation of internal oligos, primer3 does it." ;
    schema1:downloadUrl "https://github.com/primer3-org/primer3/archive/v2.6.1.tar.gz" ;
    schema1:identifier biotools:primer3 ;
    schema1:license "GPLv2" ;
    schema1:name "primer3" ;
    schema1:softwareVersion "2.6.1" ;
    schema1:url "https://github.com/primer3-org/primer3" ;
    spdx:builtFrom biotools:primer3 .

