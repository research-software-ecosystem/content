@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:pgcgap a schema1:SoftwareApplication ;
    schema1:author "liaochenlanruo" ;
    schema1:description "A prokaryotic genomics and comparative genomics analysis pipeline" ;
    schema1:downloadUrl "https://github.com/liaochenlanruo/pgcgap/archive/v1.0.35.tar.gz" ;
    schema1:identifier biotools:pgcgap ;
    schema1:license "GPLv3" ;
    schema1:maintainer "liaochenlanruo" ;
    schema1:name "pgcgap" ;
    schema1:softwareHelp "https://liaochenlanruo.fun/pgcgap/" ;
    schema1:softwareVersion "1.0.35" ;
    schema1:url "https://github.com/liaochenlanruo/pgcgap/blob/master/README.md" ;
    spdx:builtFrom biotools:pgcgap .

