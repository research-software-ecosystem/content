@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-rhtslib a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "HTSlib high-throughput sequencing library as an R package" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/Rhtslib_3.2.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/Rhtslib/Rhtslib_3.2.0.tar.gz', 'https://bioarchive.galaxyproject.org/Rhtslib_3.2.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-rhtslib/bioconductor-rhtslib_3.2.0_src_all.tar.gz']" ;
    schema1:identifier biotools:rhtslib ;
    schema1:license "LGPL (>= 2)" ;
    schema1:name "bioconductor-rhtslib" ;
    schema1:softwareVersion "3.2.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/Rhtslib.html" ;
    spdx:builtFrom biotools:rhtslib .

