@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-rhtslib a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "HTSlib high-throughput sequencing library as an R package" ;
    schema1:identifier biotools:rhtslib ;
    schema1:keywords "Computational Biology",
        "Gene Expression Profiling",
        "Genomics",
        "High-Throughput Screening Assays",
        "Programming Languages",
        "Sequencing",
        "User-Computer Interface" ;
    schema1:license "LGPL (>= 2)" ;
    schema1:name "bioconductor-rhtslib" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/Rhtslib.html" .

