@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-globaltest a schema1:SoftwareApplication ;
    schema1:description "Testing Groups of Covariates/Features for Association with a Response Variable, with Applications to Gene Set Testing" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/globaltest_5.64.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/globaltest/globaltest_5.64.0.tar.gz', 'https://bioarchive.galaxyproject.org/globaltest_5.64.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-globaltest/bioconductor-globaltest_5.64.0_src_all.tar.gz']" ;
    schema1:identifier biotools:globaltest ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-globaltest" ;
    schema1:softwareVersion "5.64.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/globaltest.html" ;
    spdx:builtFrom biotools:globaltest .

