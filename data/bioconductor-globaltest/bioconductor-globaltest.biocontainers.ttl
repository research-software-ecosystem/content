@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-globaltest a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1002/gepi.21915" ;
    schema1:description "Testing Groups of Covariates/Features for Association with a Response Variable, with Applications to Gene Set Testing" ;
    schema1:identifier biotools:globaltest ;
    schema1:keywords "Genetic Association Studies",
        "Genetic Variation",
        "Genetics",
        "Genotype",
        "Humans",
        "Hypertension",
        "Linkage Disequilibrium",
        "Logistic Models",
        "Models, Genetic",
        "Phenotype" ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-globaltest" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/globaltest.html" .

