@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:toil a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nbt.3772" ;
    schema1:description "A scalable, efficient, cross-platform and easy-to-use workflow engine in pure Python" ;
    schema1:keywords "Biomedical Research",
        "Electronic Data Processing",
        "Genomics",
        "Humans" ;
    schema1:license "Apache 2.0" ;
    schema1:name "toil" ;
    schema1:url "https://github.com/DataBiosphere/toil" .

