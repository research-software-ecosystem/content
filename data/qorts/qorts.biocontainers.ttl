@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:qorts a schema1:SoftwareApplication ;
    schema1:description "Qorts toolkit for analysis, quality control, and data management of rna-seq datasets." ;
    schema1:keywords "Gene Expression",
        "RNA-Seq" ;
    schema1:license "MIT" ;
    schema1:name "qorts" ;
    schema1:url "https://github.com/hartleys/QoRTs" .

