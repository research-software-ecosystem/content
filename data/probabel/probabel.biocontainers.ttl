@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:probabel a schema1:SoftwareApplication ;
    schema1:description "Toolset for genome-wide association analysis" ;
    schema1:license "GPL-2.0+" ;
    schema1:name "probabel" ;
    schema1:url "http://www.genabel.org" .

