@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-medips a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btt650" ;
    schema1:description "DNA IP-seq data analysis" ;
    schema1:identifier biotools:medips ;
    schema1:keywords "Adenoma",
        "Animals",
        "Chromatin Immunoprecipitation",
        "CpG Islands",
        "DNA Methylation",
        "DNA-Binding Proteins",
        "Databases, Factual",
        "Epigenetics",
        "Epigenomics",
        "Genetics",
        "Genome-Wide Association Study",
        "Genomics",
        "Intestinal Neoplasms",
        "Methylated DNA immunoprecipitation",
        "Mice",
        "Quality Control",
        "Sequence Analysis, DNA",
        "Sequencing" ;
    schema1:license "GPL (>=2)" ;
    schema1:name "bioconductor-medips" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/MEDIPS.html" .

