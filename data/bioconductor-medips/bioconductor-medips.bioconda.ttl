@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-medips a schema1:SoftwareApplication ;
    schema1:description "DNA IP-seq data analysis" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/MEDIPS_1.62.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/MEDIPS/MEDIPS_1.62.0.tar.gz', 'https://bioarchive.galaxyproject.org/MEDIPS_1.62.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-medips/bioconductor-medips_1.62.0_src_all.tar.gz']" ;
    schema1:identifier biotools:medips ;
    schema1:license "GPL (>=2)" ;
    schema1:name "bioconductor-medips" ;
    schema1:softwareVersion "1.62.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/MEDIPS.html" ;
    spdx:builtFrom biotools:medips .

