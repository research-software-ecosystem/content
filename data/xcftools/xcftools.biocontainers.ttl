@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:xcftools a schema1:SoftwareApplication ;
    schema1:description "Provides xcf2pnm, xcf2png, and xcfinfo binaries" ;
    schema1:license "GPL v2" ;
    schema1:name "xcftools" ;
    schema1:url "https://github.com/j-jorge/xcftools" .

