@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:dinamo a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s12859-018-2215-1" ;
    schema1:description "An exact and efficient method for IUPAC motif discovery in DNA sequences" ;
    schema1:identifier biotools:DiNAMO ;
    schema1:keywords "ChIP-seq",
        "Chromatin Immunoprecipitation",
        "Computational Biology",
        "DNA-Seq",
        "High-Throughput Nucleotide Sequencing",
        "Humans",
        "Nucleotide Motifs",
        "Sequence Analysis, DNA",
        "Sequence sites, features and motifs" ;
    schema1:license "GPL-3.0" ;
    schema1:name "dinamo" ;
    schema1:url "https://github.com/bonsai-team/DiNAMO/" .

