@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:dinamo a schema1:SoftwareApplication ;
    schema1:author "simonvh" ;
    schema1:citation "doi:10.1186/s12859-018-2215-1" ;
    schema1:description "An exact and efficient method for IUPAC motif discovery in DNA sequences." ;
    schema1:downloadUrl "https://github.com/bonsai-team/DiNAMO/archive/V1.0.tar.gz" ;
    schema1:identifier biotools:DiNAMO ;
    schema1:license "GPL-3.0-or-later" ;
    schema1:maintainer "simonvh" ;
    schema1:name "dinamo" ;
    schema1:softwareVersion "1.0" ;
    schema1:url "https://github.com/bonsai-team/DiNAMO" ;
    spdx:builtFrom biotools:DiNAMO .

