@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-asafe a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btw220" ;
    schema1:description "Given admixed individuals' bi-allelic snp genotypes and ancestry pairs (where each ancestry can take one of three values) for multiple snps, perform an em algorithm to deal with the fact that snp genotypes are unphased with respect to ancestry pairs, in order to estimate ancestry-specific allele frequencies for all snps." ;
    schema1:identifier biotools:asafe ;
    schema1:keywords "Computational Biology",
        "GWAS study",
        "Gene Frequency",
        "Genetics",
        "Genetics, Population",
        "Genome, Human",
        "Genome-Wide Association Study",
        "Genotype",
        "Humans",
        "Population genetics" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-asafe" ;
    schema1:url "http://bioconductor.org/packages/release/bioc/html/ASAFE.html" .

