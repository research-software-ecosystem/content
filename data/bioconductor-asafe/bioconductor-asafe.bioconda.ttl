@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-asafe a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btw220" ;
    schema1:description "Ancestry Specific Allele Frequency Estimation" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/ASAFE_1.36.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/ASAFE/ASAFE_1.36.0.tar.gz', 'https://bioarchive.galaxyproject.org/ASAFE_1.36.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-asafe/bioconductor-asafe_1.36.0_src_all.tar.gz']" ;
    schema1:identifier biotools:asafe ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-asafe" ;
    schema1:softwareVersion "1.36.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/ASAFE.html" ;
    spdx:builtFrom biotools:asafe .

