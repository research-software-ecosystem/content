@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:nanosv a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/s41467-017-01343-4" ;
    schema1:description "Structural variation detection tool for oxford nanopore data." ;
    schema1:keywords "Abnormalities, Multiple",
        "Chromosome Mapping",
        "Chromothripsis",
        "Clustering",
        "Computational Biology",
        "DNA Mutational Analysis",
        "Gene Rearrangement",
        "Genetic Variation",
        "Genetics",
        "High-Throughput Nucleotide Sequencing",
        "Humans",
        "Nanopores" ;
    schema1:license "MIT" ;
    schema1:name "nanosv" ;
    schema1:url "https://github.com/mroosmalen/nanosv" .

