@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-dada2 a schema1:SoftwareApplication ;
    schema1:description "Accurate, high-resolution sample inference from amplicon sequencing data" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/dada2_1.38.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/dada2/dada2_1.38.0.tar.gz', 'https://bioarchive.galaxyproject.org/dada2_1.38.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-dada2/bioconductor-dada2_1.38.0_src_all.tar.gz']" ;
    schema1:identifier biotools:dada2 ;
    schema1:license "LGPL-2" ;
    schema1:name "bioconductor-dada2" ;
    schema1:softwareVersion "1.38.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/dada2.html" ;
    spdx:builtFrom biotools:dada2 .

