@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:pecat a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/s41467-024-47349-7" ;
    schema1:description "A phased error correction and assembly tool." ;
    schema1:downloadUrl "https://github.com/lemene/PECAT/releases/download/v0.0.3/pecat_source_v0.0.3.tar.gz" ;
    schema1:identifier biotools:pecat ;
    schema1:license "BSD-2-Clause" ;
    schema1:name "pecat" ;
    schema1:softwareVersion "0.0.3" ;
    schema1:url "https://github.com/lemene/PECAT" ;
    spdx:builtFrom biotools:pecat .

