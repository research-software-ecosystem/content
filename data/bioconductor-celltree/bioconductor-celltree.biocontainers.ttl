@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-celltree a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18129/b9.bioc.celltree" ;
    schema1:description "Inference and visualisation of single-cell rna-seq data as a hierarchical tree structure" ;
    schema1:keywords "Clustering",
        "Genomics",
        "RNA-Seq" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-celltree" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/cellTree.html" .

