@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-iseq a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1111/j.1541-0420.2009.01379.x" ;
    schema1:description "Bayesian Hierarchical Modeling of ChIP-seq Data Through Hidden Ising Models" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/iSeq_1.62.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/iSeq/iSeq_1.62.0.tar.gz', 'https://bioarchive.galaxyproject.org/iSeq_1.62.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-iseq/bioconductor-iseq_1.62.0_src_all.tar.gz']" ;
    schema1:identifier biotools:iseq ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-iseq" ;
    schema1:softwareVersion "1.62.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/iSeq.html" ;
    spdx:builtFrom biotools:iseq .

