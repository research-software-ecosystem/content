@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-iseq a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1111/j.1541-0420.2009.01379.x" ;
    schema1:description "Bayesian Hierarchical Modeling of ChIP-seq Data Through Hidden Ising Models" ;
    schema1:identifier biotools:iseq ;
    schema1:keywords "Bayes Theorem",
        "ChIP-seq",
        "Chromatin Immunoprecipitation",
        "Humans",
        "Methods",
        "Oligonucleotide Array Sequence Analysis",
        "Sensitivity and Specificity",
        "Sequencing" ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-iseq" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/iSeq.html" .

