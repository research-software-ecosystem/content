@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:pygenometracks a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btaa692" ;
    schema1:description "Standalone program and library to plot beautiful genome browser tracks." ;
    schema1:license "GPL-3.0" ;
    schema1:name "pygenometracks" ;
    schema1:url "https://github.com/deeptools/pyGenomeTracks/" .

