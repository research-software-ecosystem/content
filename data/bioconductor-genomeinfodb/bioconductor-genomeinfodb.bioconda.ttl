@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-genomeinfodb a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Utilities for manipulating chromosome names, including modifying them to follow a particular naming style" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/GenomeInfoDb_1.42.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/GenomeInfoDb/GenomeInfoDb_1.42.0.tar.gz', 'https://bioarchive.galaxyproject.org/GenomeInfoDb_1.42.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-genomeinfodb/bioconductor-genomeinfodb_1.42.0_src_all.tar.gz']" ;
    schema1:identifier biotools:genomeinfodb ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-genomeinfodb" ;
    schema1:softwareVersion "1.42.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/GenomeInfoDb.html" ;
    spdx:builtFrom biotools:genomeinfodb .

