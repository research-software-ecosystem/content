@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-genomeinfodb a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Contains data and functions that define and allow translation between different chromosome sequence naming conventions (e.g., chr1 versus 1), including a function that attempts to place sequence names in their natural, rather than lexicographic, order." ;
    schema1:identifier biotools:genomeinfodb ;
    schema1:keywords "Computational Biology",
        "Data management",
        "Gene Expression Profiling",
        "Genetics",
        "Genomics",
        "High-Throughput Screening Assays",
        "Programming Languages",
        "Proteomics",
        "User-Computer Interface" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-genomeinfodb" ;
    schema1:url "http://bioconductor.org/packages/release/bioc/html/GenomeInfoDb.html" .

