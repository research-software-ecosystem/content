@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:flapjack a schema1:SoftwareApplication ;
    schema1:description "Flapjack provides interactive visualizations of high-throughput genotyping data." ;
