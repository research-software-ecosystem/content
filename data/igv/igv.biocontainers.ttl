@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:igv a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nbt.1754",
        "doi:10.1093/BIB/BBS017" ;
    schema1:description "High-performance visualization tool for interactive exploration of large, integrated datasets. it supports a wide variety of data types and format, including short-read alignments in the sam/bam format. data can be viewed from local files or over the web via http." ;
    schema1:identifier biotools:igv ;
    schema1:keywords "Chromosome Mapping",
        "Computational Biology",
        "Computer Graphics",
        "Data visualisation",
        "Gene Dosage",
        "Gene Expression Profiling",
        "Genomics",
        "Glioblastoma",
        "Humans",
        "Information Storage and Retrieval",
        "Internet",
        "Neoplasms",
        "Oligonucleotide Array Sequence Analysis",
        "Online Systems",
        "Polymorphism, Single Nucleotide",
        "Sequence analysis" ;
    schema1:license "LGPL-2.1" ;
    schema1:name "igv" ;
    schema1:url "http://www.broadinstitute.org/igv/" .

