@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-genextender a schema1:SoftwareApplication ;
    schema1:description "Optimized Functional Annotation Of ChIP-seq Data" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/geneXtendeR_1.36.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/geneXtendeR/geneXtendeR_1.36.0.tar.gz', 'https://bioarchive.galaxyproject.org/geneXtendeR_1.36.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-genextender/bioconductor-genextender_1.36.0_src_all.tar.gz']" ;
    schema1:identifier biotools:genextender ;
    schema1:license "GPL (>= 3)" ;
    schema1:name "bioconductor-genextender" ;
    schema1:softwareVersion "1.36.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/geneXtendeR.html" ;
    spdx:builtFrom biotools:genextender .

