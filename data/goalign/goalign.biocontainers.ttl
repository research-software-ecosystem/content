@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:goalign a schema1:SoftwareApplication ;
    schema1:description "goalign is a set of command line tools to manipulate multiple alignments" ;
    schema1:identifier biotools:goalign ;
    schema1:keywords "Sequence analysis" ;
    schema1:license "GPL-2.0" ;
    schema1:name "goalign" ;
    schema1:url "https://github.com/evolbioinfo/goalign" .

