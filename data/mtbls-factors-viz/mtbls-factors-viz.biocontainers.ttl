@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:mtbls-factors-viz a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/ng.1054",
        "doi:10.5281/zenodo.163640" ;
    schema1:description "Visualize factors and their values for a MetaboLights study" ;
    schema1:keywords "Genetics",
        "Metabolomics" ;
    schema1:license "Custom License" ;
    schema1:name "mtbls-factors-viz" ;
    schema1:url "https://github.com/phnmnl/container-mtbls-factors-viz" .

