@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:genotyphi a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/ncomms12827",
        "doi:10.1128/mBio.00105-18",
        "doi:10.1371/journal.pntd.0006408" ;
    schema1:description "Assign genotypes to salmonella typhi genomes based on vcf files (mapped to typhi ct18 reference genome)" ;
    schema1:keywords "Anti-Bacterial Agents",
        "Cephalosporins",
        "Drug Resistance, Multiple, Bacterial",
        "Fluoroquinolones",
        "Haplotypes",
        "Pakistan",
        "Plasmids",
        "Salmonella typhi",
        "Typhoid Fever",
        "Whole Genome Sequencing" ;
    schema1:license "Not available" ;
    schema1:name "genotyphi" ;
    schema1:url "https://github.com/katholt/genotyphi" .

