@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:solexaqa a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/1471-2105-11-485" ;
    schema1:description "Quality statistics and visual representations for second-generation sequencing data" ;
    schema1:identifier biotools:solexaqa ;
    schema1:keywords "Base Sequence",
        "Data quality management",
        "Data visualisation",
        "Genomics",
        "Internet",
        "Sequence Analysis, DNA",
        "Sequence Analysis, RNA" ;
    schema1:license "GPL-3.0" ;
    schema1:name "solexaqa" ;
    schema1:url "http://solexaqa.sourceforge.net/" .

