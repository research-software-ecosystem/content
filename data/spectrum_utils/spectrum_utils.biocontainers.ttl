@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:spectrum_utils a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1101/725036" ;
    schema1:description "Mass spectrometry utility functions" ;
    schema1:identifier biotools:spectrum_utils ;
    schema1:keywords "Mass spectrometry",
        "Metabolomics",
        "Proteomics experiment",
        "Small molecules" ;
    schema1:license "Apache-2.0" ;
    schema1:name "spectrum_utils" ;
    schema1:url "https://github.com/bittremieux/spectrum_utils" .

