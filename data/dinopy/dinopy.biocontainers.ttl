@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:dinopy a schema1:SoftwareApplication ;
    schema1:description "DNA input and output library for Python and Cython. Includes reader and writer for FASTA and FASTQ files, support for samtools faidx files, and generators for solid and gapped q-grams (k-mers)." ;
    schema1:license "MIT" ;
    schema1:name "dinopy" ;
    schema1:url "https://bitbucket.org/HenningTimm/dinopy" .

