@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:galaxy-k8s-runtime a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/gkw343",
        "doi:10.1093/nar/gky379" ;
    schema1:description "First version of a PhenoMeNal runtime for Galaxy running inside a container orchestrator" ;
    schema1:keywords "Datasets as Topic",
        "Genomics",
        "Humans",
        "Information Dissemination",
        "International Cooperation",
        "Internet",
        "Metabolomics",
        "Molecular Imaging",
        "Proteomics",
        "Reproducibility of Results",
        "User-Computer Interface" ;
    schema1:license "Apache-2.0" ;
    schema1:name "galaxy-k8s-runtime" ;
    schema1:url "https://github.com/phnmnl/container-galaxy-k8s-runtime" .

