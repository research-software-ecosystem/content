@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-spectra a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18129/b9.bioc.spectra" ;
    schema1:description "Spectra infrastructure for mass spectrometry data" ;
    schema1:keywords "Mass spectrometry",
        "Metabolomics",
        "Proteomics" ;
    schema1:license "Not available" ;
    schema1:name "bioconductor-spectra" ;
    schema1:url "https://bioconductor.org/packages/3.12/bioc/html/Spectra.html" .

