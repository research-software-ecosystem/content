@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-shortread a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btp450" ;
    schema1:description "Gnu r classes and methods for high-throughput short-read sequencing data" ;
    schema1:identifier biotools:shortread ;
    schema1:keywords "Computational Biology",
        "Databases, Genetic",
        "Gene Expression Profiling",
        "Sequence Analysis, DNA",
        "Sequencing" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-shortread" ;
    schema1:url "https://bioconductor.org/packages/ShortRead/" .

