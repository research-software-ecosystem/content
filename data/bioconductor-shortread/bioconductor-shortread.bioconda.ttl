@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-shortread a schema1:SoftwareApplication ;
    schema1:description "FASTQ input and manipulation" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/ShortRead_1.64.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/ShortRead/ShortRead_1.64.0.tar.gz', 'https://bioarchive.galaxyproject.org/ShortRead_1.64.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-shortread/bioconductor-shortread_1.64.0_src_all.tar.gz']" ;
    schema1:identifier biotools:shortread ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-shortread" ;
    schema1:softwareVersion "1.64.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/ShortRead.html" ;
    spdx:builtFrom biotools:shortread .

