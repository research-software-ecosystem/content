@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-matter a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "A framework for rapid prototyping with file-based data structures" ;
    schema1:identifier biotools:matter ;
    schema1:keywords "Computational Biology",
        "Data management",
        "Gene Expression Profiling",
        "Genomics",
        "High-Throughput Screening Assays",
        "Imaging",
        "Mass spectrometry",
        "Programming Languages",
        "Proteomics",
        "User-Computer Interface" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-matter" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/matter.html" .

