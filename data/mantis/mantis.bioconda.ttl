@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:mantis a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1016/j.cels.2018.05.021" ;
    schema1:description "Mantis: A Fast, Small, and Exact Large-Scale Sequence-Search Index." ;
    schema1:downloadUrl "https://github.com/splatlab/mantis/archive/0fb7dbb60e4a38aa21da7c85f98565786af5fe62.tar.gz" ;
    schema1:identifier biotools:mantis_index ;
    schema1:license "BSD-3-Clause" ;
    schema1:name "mantis" ;
    schema1:softwareVersion "0.2" ;
    schema1:url "https://github.com/splatlab/mantis" ;
    spdx:builtFrom biotools:mantis_index .

