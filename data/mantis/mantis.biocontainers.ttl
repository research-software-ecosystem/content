@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:mantis a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1016/j.cels.2018.05.021",
        "doi:10.1186/S12859-015-0598-9" ;
    schema1:description "Mantis: A Fast, Small, and Exact Large-Scale Sequence-Search Index" ;
    schema1:identifier biotools:mantis ;
    schema1:keywords "Animals",
        "Databases, Genetic",
        "Evolutionary biology",
        "Humans",
        "Infectious disease",
        "Phylogeny",
        "RNA",
        "Sequence Analysis, RNA",
        "Simulation experiment",
        "Time Factors",
        "Transcriptome" ;
    schema1:license "BSD-3-Clause" ;
    schema1:name "mantis" ;
    schema1:url "https://github.com/splatlab/mantis" .

