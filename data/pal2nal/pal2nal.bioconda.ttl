@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:pal2nal a schema1:SoftwareApplication ;
    schema1:author "liaochenlanruo" ;
    schema1:description "robust conversion of protein sequence alignments into the corresponding codon alignments" ;
    schema1:downloadUrl "https://github.com/liaochenlanruo/PAL2NAL/archive/v14.1.tar.gz" ;
    schema1:identifier biotools:pal2nal ;
    schema1:license "GPLv2.0" ;
    schema1:maintainer "liaochenlanruo" ;
    schema1:name "pal2nal" ;
    schema1:softwareVersion "14.1" ;
    schema1:url "http://www.bork.embl.de/pal2nal/" ;
    spdx:builtFrom biotools:pal2nal .

