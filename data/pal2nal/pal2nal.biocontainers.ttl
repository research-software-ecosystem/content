@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:pal2nal a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/gkl315" ;
    schema1:description "Pal2nal converts a multiple sequence alignment of proteins and the corresponding dna (or mrna) sequences into a codon alignment. synonymous (ks) and non-synonymous (ka) substitution rates can be calculated." ;
    schema1:identifier biotools:pal2nal ;
    schema1:keywords "Codon",
        "DNA",
        "Exons",
        "Gene expression",
        "Gene transcripts",
        "Internet",
        "Proteins",
        "Sequence Alignment",
        "Sequence Analysis, DNA",
        "Sequence Analysis, Protein",
        "Sequence analysis",
        "User-Computer Interface" ;
    schema1:license "GPL-2.0" ;
    schema1:name "pal2nal" ;
    schema1:url "http://www.bork.embl.de/pal2nal/" .

