@prefix debianmed: <https://salsa.debian.org/med-team/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

debianmed:pal2nal a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/gkl315" ;
    schema1:description "converts proteins to genomic DNA alignment" ;
    schema1:identifier "bio.tools:pal2nal",
        "conda:bioconda:pal2nal",
        "omictools:OMICS_20386" ;
    schema1:license "unknown" ;
    schema1:name "pal2nal" ;
    schema1:softwareVersion "14.1" ;
    schema1:url "http://www.bork.embl.de/pal2nal" ;
    spdx:builtFrom "pal2nal" .

