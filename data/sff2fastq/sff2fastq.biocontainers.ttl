@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:sff2fastq a schema1:SoftwareApplication ;
    schema1:description "Extract 454 Genome Sequencer reads from a SFF file and convert them into a FASTQ formatted output" ;
    schema1:identifier biotools:sff2fastq ;
    schema1:keywords "Sequence analysis",
        "Sequence assembly",
        "Sequencing" ;
    schema1:license "GPL-3.0" ;
    schema1:name "sff2fastq" ;
    schema1:url "https://github.com/indraniel/sff2fastq" .

