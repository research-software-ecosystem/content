@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:sff2fastq a schema1:SoftwareApplication ;
    schema1:author "keuv-grvl" ;
    schema1:description "Extract 454 Genome Sequencer reads from a SFF file and convert them into a FASTQ formatted output" ;
    schema1:downloadUrl "https://github.com/indraniel/sff2fastq/archive/v0.9.2.tar.gz" ;
    schema1:identifier biotools:sff2fastq ;
    schema1:license "GPL-3" ;
    schema1:maintainer "keuv-grvl" ;
    schema1:name "sff2fastq" ;
    schema1:softwareVersion "0.9.2" ;
    schema1:url "https://github.com/indraniel/sff2fastq" ;
    spdx:builtFrom biotools:sff2fastq .

