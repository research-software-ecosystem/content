@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:maf2synteny a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1101/gr.236273.118" ;
    schema1:description "A tool that postprocesses whole genome alignment (for two or more genomes) and produces coarse-grained synteny blocks." ;
    schema1:keywords "Animals",
        "Contig Mapping",
        "Genomics",
        "Mice",
        "Reference Standards",
        "Whole Genome Sequencing" ;
    schema1:license "BSD" ;
    schema1:name "maf2synteny" ;
    schema1:url "https://github.com/fenderglass/maf2synteny" .

