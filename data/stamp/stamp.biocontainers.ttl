@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:stamp a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btu494",
        "doi:10.1093/nar/gkm272",
        "doi:10.1371/journal.pcbi.0030061" ;
    schema1:description "A graphical software package for analyzing taxonomic and functional profiles." ;
    schema1:identifier biotools:stamp ;
    schema1:keywords "Bacteria",
        "Classification",
        "Confidence Intervals",
        "Cyanobacteria",
        "Data Interpretation, Statistical",
        "Gene expression",
        "Genome, Bacterial",
        "Humans",
        "Protein structural motifs and surfaces",
        "Sequence analysis",
        "Sequence sites, features and motifs",
        "Transcription factors and regulatory sites" ;
    schema1:license "Not available" ;
    schema1:name "stamp" ;
    schema1:url "http://pypi.python.org/pypi/stamp/" .

