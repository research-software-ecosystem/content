@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:python-rnacentral a schema1:SoftwareApplication ;
    schema1:description "This tool exploits the rnacentral public apis to automatically retrieve sequences (converted to the fasta format) and the related metadata, starting with one or a list of rnacentral ids" ;
    schema1:license "BSD 2-Clause \"Simplified\" License" ;
    schema1:name "python-rnacentral" ;
    schema1:url "https://github.com/fabio-cumbo/RNAcentral-data-retrieval-tool" .

