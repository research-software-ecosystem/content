@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:red a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s12859-015-0654-5",
        "doi:10.1371/journal.pone.0150465" ;
    schema1:description "Red (RepeatsDetector): an intelligent, rapid, accurate tool for detecting repeats de-novo on the genomic scale." ;
    schema1:identifier biotools:red ;
    schema1:keywords "DNA",
        "Data visualisation",
        "Genome, Bacterial",
        "Genome, Human",
        "Genome, Plant",
        "Genomics",
        "Humans",
        "Interspersed Repetitive Sequences",
        "Markov Chains",
        "Plants",
        "RNA",
        "Sequencing" ;
    schema1:license "Custom OSS" ;
    schema1:name "red" ;
    schema1:url "http://toolsmith.ens.utulsa.edu" .

