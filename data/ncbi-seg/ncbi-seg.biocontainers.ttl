@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:ncbi-seg a schema1:SoftwareApplication ;
    schema1:description "Tool to mask segments of low compositional complexity in amino acid sequences" ;
    schema1:license "public-domain" ;
    schema1:name "ncbi-seg" ;
    schema1:url "ftp://ftp.ncbi.nih.gov/pub/seg/seg/" .

