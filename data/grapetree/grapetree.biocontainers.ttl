@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:grapetree a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1101/gr.232397.117" ;
    schema1:description "Web interface of grapetree, which is a program for phylogenetic analysis." ;
    schema1:keywords "Alleles",
        "Bacteria",
        "DNA Barcoding, Taxonomic",
        "Genetics",
        "Genome, Bacterial",
        "Phylogeny",
        "Sequence Alignment" ;
    schema1:license "Not available" ;
    schema1:name "grapetree" ;
    schema1:url "https://github.com/achtman-lab/GrapeTree" .

