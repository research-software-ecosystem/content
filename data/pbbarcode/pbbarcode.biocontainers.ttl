@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:pbbarcode a schema1:SoftwareApplication ;
    schema1:description "Annotate pacbio sequencing reads with barcode information" ;
    schema1:license "PacBio-BSD-3-Clause" ;
    schema1:name "pbbarcode" ;
    schema1:url "https://github.com/PacificBiosciences/pbbarcode" .

