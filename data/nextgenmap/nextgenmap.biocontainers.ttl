@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:nextgenmap a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btt468" ;
    schema1:description "NextGenMap is a flexible highly sensitive short read mapping tool that" ;
    schema1:keywords "Genome",
        "Genomics",
        "High-Throughput Nucleotide Sequencing",
        "Polymorphism, Genetic",
        "Sequence Alignment" ;
    schema1:license "MIT" ;
    schema1:name "nextgenmap" ;
    schema1:url "https://github.com/Cibiv/NextGenMap" .

