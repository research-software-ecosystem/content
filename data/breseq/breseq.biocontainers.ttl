@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:breseq a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/gkw343",
        "doi:10.1186/1471-2164-15-1039",
        "doi:10.7490/f1000research.1114334.1" ;
    schema1:description "A computational pipeline for finding mutations relative to a reference sequence in short-read dna re-sequencing data." ;
    schema1:keywords "Computational Biology",
        "Directed Molecular Evolution",
        "Escherichia coli",
        "Genome, Microbial",
        "Genomic Structural Variation",
        "Haploidy",
        "High-Throughput Nucleotide Sequencing",
        "Interspersed Repetitive Sequences",
        "Mutation",
        "Sequence Analysis, DNA" ;
    schema1:license "GPL-3.0" ;
    schema1:name "breseq" ;
    schema1:url "https://github.com/barricklab/breseq" .

