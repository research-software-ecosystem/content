@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:breseq a schema1:SoftwareApplication ;
    schema1:description "A computational pipeline for finding mutations relative to a reference sequence in short-read DNA re-sequencing data." ;
    schema1:downloadUrl "https://github.com/barricklab/breseq/releases/download/v0.40.1/breseq-0.40.1-Source.tar.gz" ;
    schema1:identifier biotools:breseq ;
    schema1:license "GPL-2.0-or-later" ;
    schema1:name "breseq" ;
    schema1:softwareHelp "https://barricklab.org/twiki/pub/Lab/ToolsBacterialGenomeResequencing/documentation/" ;
    schema1:softwareVersion "0.40.1" ;
    schema1:url "https://github.com/barricklab/breseq" ;
    spdx:builtFrom biotools:breseq .

