@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:contigtax a schema1:SoftwareApplication ;
    schema1:description "Assign taxonomy to metagenomic contigs (previously know as tango)" ;
    schema1:identifier biotools:contigtax ;
    schema1:keywords "Genomics",
        "Metagenomics",
        "Transcriptomics" ;
    schema1:license "MIT" ;
    schema1:name "contigtax" ;
    schema1:url "https://github.com/NBISweden/contigtax" .

