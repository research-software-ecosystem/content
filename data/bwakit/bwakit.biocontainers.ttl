@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bwakit a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btp324",
        "doi:10.1093/bioinformatics/btp698" ;
    schema1:description "A self-consistent installation-free package of scripts and precompiled binaries, providing an end-to-end solution to read mapping" ;
    schema1:keywords "Base Sequence",
        "Genome, Human",
        "Genomics",
        "Humans",
        "Sequence Alignment",
        "Sequence Analysis, DNA" ;
    schema1:license "GPL-3.0" ;
    schema1:name "bwakit" ;
    schema1:url "https://github.com/lh3/bwa" .

