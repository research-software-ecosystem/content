@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:diamond a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/s41592-021-01101-x" ;
    schema1:description "Accelerated BLAST compatible local sequence aligner." ;
    schema1:downloadUrl "https://github.com/bbuchfink/diamond/archive/v2.2.1.tar.gz" ;
    schema1:identifier biotools:diamond ;
    schema1:license "GPL-3.0-or-later" ;
    schema1:name "diamond" ;
    schema1:softwareHelp "https://github.com/bbuchfink/diamond/wiki" ;
    schema1:softwareVersion "2.2.1" ;
    schema1:url "https://github.com/bbuchfink/diamond" ;
    spdx:builtFrom biotools:diamond .

