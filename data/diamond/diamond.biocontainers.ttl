@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:diamond a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3176" ;
    schema1:description "Accelerated blast compatible local sequence aligner" ;
    schema1:identifier biotools:Diamond ;
    schema1:keywords "Base Sequence",
        "Humans",
        "Metagenomics",
        "Microbiota",
        "Proteins",
        "Sensitivity and Specificity",
        "Sequence Alignment",
        "Sequence Analysis, DNA",
        "Sequence analysis" ;
    schema1:license "GPL-3.0" ;
    schema1:name "diamond" ;
    schema1:url "https://github.com/bbuchfink/diamond/" .

