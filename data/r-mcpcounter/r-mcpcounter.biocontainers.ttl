    schema1:description "Estimating tissue-infiltrating immune and other stromal subpopulations abundances using gene expression" ;
    schema1:keywords "Adenocarcinoma",
        "Adenocarcinoma of Lung",
        "Biomarkers, Tumor",
        "Breast Neoplasms",
        "Cell Tracking",
        "Colorectal Neoplasms",
        "Computational Biology",
        "Female",
        "Gene Expression",
        "Gene Expression Profiling",
        "Humans",
        "Lung Neoplasms",
        "RNA, Messenger",
        "Stromal Cells",
        "Transcriptome",
        "Tumor Microenvironment" ;
    schema1:license "GPL-3" ;
    schema1:name "r-mcpcounter" ;
    schema1:url "https://github.com/ebecht/MCPcounter" .

