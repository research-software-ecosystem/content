@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-altcdfenvs a schema1:SoftwareApplication ;
    schema1:description "alternative CDF environments (aka probeset mappings)" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/altcdfenvs_2.68.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/altcdfenvs/altcdfenvs_2.68.0.tar.gz', 'https://bioarchive.galaxyproject.org/altcdfenvs_2.68.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-altcdfenvs/bioconductor-altcdfenvs_2.68.0_src_all.tar.gz']" ;
    schema1:identifier biotools:altcdfenvs ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-altcdfenvs" ;
    schema1:softwareVersion "2.68.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/altcdfenvs.html" ;
    spdx:builtFrom biotools:altcdfenvs .

