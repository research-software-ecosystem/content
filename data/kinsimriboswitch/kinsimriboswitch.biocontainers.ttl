@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:kinsimriboswitch a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s12859-017-1823-5" ;
    schema1:description "Pipeline for the simulation of RNA--ligand interaction kinetics as outlined in Kuehnl et al. 2017." ;
    schema1:keywords "Dimerization",
        "Kinetics",
        "Ligands",
        "Models, Theoretical",
        "Nucleic Acid Conformation",
        "Ortholog",
        "Probability",
        "RNA",
        "Thermodynamics" ;
    schema1:license "GPL-3.0" ;
    schema1:name "kinsimriboswitch" ;
    schema1:url "http://www.bioinf.uni-leipzig.de/~felix/" .

