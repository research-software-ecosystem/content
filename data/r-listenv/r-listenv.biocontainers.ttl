@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-listenv a schema1:SoftwareApplication ;
    schema1:description "List environments are environments that can be indexed similarly to lists, e.g. 'x <- listenv(); x[[2]] <- \"b\"; names(x)[2] <- \"B\"; print(x$B)'." ;
    schema1:license "LGPL (>= 2.1)" ;
    schema1:name "r-listenv" ;
    schema1:url "None" .

