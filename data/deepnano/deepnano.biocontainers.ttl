@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:deepnano a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1371/journal.pone.0178751" ;
    schema1:description "Alternative basecaller for minion reads of genomic sequences" ;
    schema1:keywords "Datasets as Topic",
        "Escherichia coli",
        "High-Throughput Nucleotide Sequencing",
        "Klebsiella pneumoniae",
        "Nanopores",
        "Neural Networks, Computer",
        "Sequence Analysis, DNA" ;
    schema1:license "BSD-3-clause" ;
    schema1:name "deepnano" ;
    schema1:url "https://bitbucket.org/vboza/deepnano" .

