@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-cohcap a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/gkt242" ;
    schema1:description "CpG Island Analysis Pipeline for Illumina Methylation Array and Targeted BS-Seq Data" ;
    schema1:identifier biotools:cohcap ;
    schema1:keywords "Breast Neoplasms",
        "Cell Line, Tumor",
        "CpG Islands",
        "DNA Methylation",
        "Female",
        "Gene Expression",
        "Gene expression",
        "Genetics",
        "Genomics",
        "Humans",
        "Microarray experiment",
        "Oligonucleotide Array Sequence Analysis",
        "Sequence Analysis, DNA",
        "Sulfites" ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-cohcap" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/COHCAP.html" .

