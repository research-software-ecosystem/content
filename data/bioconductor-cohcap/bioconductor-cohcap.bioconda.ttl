@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-cohcap a schema1:SoftwareApplication ;
    schema1:description "CpG Island Analysis Pipeline for Illumina Methylation Array and Targeted BS-Seq Data" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.18/bioc/src/contrib/COHCAP_1.48.0.tar.gz', 'https://bioconductor.org/packages/3.18/bioc/src/contrib/Archive/COHCAP/COHCAP_1.48.0.tar.gz', 'https://bioarchive.galaxyproject.org/COHCAP_1.48.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-cohcap/bioconductor-cohcap_1.48.0_src_all.tar.gz']" ;
    schema1:identifier biotools:cohcap ;
    schema1:license "GPL-3.0-only" ;
    schema1:name "bioconductor-cohcap" ;
    schema1:softwareVersion "1.48.0" ;
    schema1:url "https://bioconductor.org/packages/3.18/bioc/html/COHCAP.html" ;
    spdx:builtFrom biotools:cohcap .

