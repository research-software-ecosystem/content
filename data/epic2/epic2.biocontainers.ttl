@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:epic2 a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btz232" ;
    schema1:description "Ultraperformant Chip-Seq broad domain finder based on SICER." ;
    schema1:keywords "Chromatin Immunoprecipitation",
        "Chromatin Immunoprecipitation Sequencing",
        "High-Throughput Nucleotide Sequencing",
        "Sequence Analysis, DNA" ;
    schema1:license "MIT" ;
    schema1:name "epic2" ;
    schema1:url "http://github.com/endrebak/epic2" .

