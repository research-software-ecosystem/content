@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-gcrma a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/1471-2105-9-452" ;
    schema1:description "Background Adjustment Using Sequence Information" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/gcrma_2.82.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/gcrma/gcrma_2.82.0.tar.gz', 'https://bioarchive.galaxyproject.org/gcrma_2.82.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-gcrma/bioconductor-gcrma_2.82.0_src_all.tar.gz']" ;
    schema1:identifier biotools:gcrma ;
    schema1:license "LGPL" ;
    schema1:name "bioconductor-gcrma" ;
    schema1:softwareVersion "2.82.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/gcrma.html" ;
    spdx:builtFrom biotools:gcrma .

