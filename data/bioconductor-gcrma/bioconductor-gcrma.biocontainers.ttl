@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-gcrma a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/1471-2105-9-452" ;
    schema1:description "Background adjustment using sequence information" ;
    schema1:identifier biotools:gcrma ;
    schema1:keywords "Animals",
        "Artifacts",
        "Cluster Analysis",
        "Computational Biology",
        "Energy Transfer",
        "Gene Expression Profiling",
        "Humans",
        "Oligonucleotide Array Sequence Analysis",
        "Oligonucleotide Probes",
        "Reproducibility of Results",
        "Sequence analysis" ;
    schema1:license "LGPL" ;
    schema1:name "bioconductor-gcrma" ;
    schema1:url "https://www.bioconductor.org/packages/release/bioc/html/gcrma.html" .

