@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:modeltest-ng a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/MOLBEV/MSZ189" ;
    schema1:description "ModelTest-NG is a tool for selecting the best-fit model of evolution for DNA and protein alignments. ModelTest-NG supersedes jModelTest and ProtTest in one single tool, with graphical and command console interfaces." ;
    schema1:keywords "Amino Acid Substitution",
        "Evolution, Molecular",
        "Genetic Techniques",
        "Models, Genetic" ;
    schema1:license "GPL-3.0" ;
    schema1:name "modeltest-ng" ;
    schema1:url "https://github.com/ddarriba/modeltest" .

