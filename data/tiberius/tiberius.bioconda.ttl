@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:tiberius a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btae685" ;
    schema1:description "Tiberius is a deep learning gene-finder." ;
    schema1:downloadUrl "https://github.com/Gaius-Augustus/Tiberius/archive/refs/tags/v2.0.3.tar.gz" ;
    schema1:identifier biotools:tiberius ;
    schema1:license "MIT" ;
    schema1:name "tiberius" ;
    schema1:softwareHelp "https://github.com/Gaius-Augustus/Tiberius/blob/v2.0.3/README.md" ;
    schema1:softwareVersion "2.0.3" ;
    schema1:url "https://github.com/Gaius-Augustus/Tiberius" ;
    spdx:builtFrom biotools:tiberius .

