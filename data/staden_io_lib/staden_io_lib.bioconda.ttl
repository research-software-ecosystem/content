@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:staden_io_lib a schema1:SoftwareApplication ;
    schema1:description "Staden io_lib is a library of file reading and writing code e.g. for SAM/BAM/CRAM." ;
    schema1:downloadUrl "https://github.com/jkbonfield/io_lib/releases/download/io_lib-1-15-1/io_lib-1.15.1.tar.gz" ;
    schema1:identifier biotools:staden_io_lib ;
    schema1:license "BSD-3-Clause" ;
    schema1:name "staden_io_lib" ;
    schema1:softwareHelp "https://github.com/jkbonfield/io_lib/blob/io_lib-1-15-1/README.md" ;
    schema1:softwareVersion "1.15.1" ;
    schema1:url "https://github.com/jkbonfield/io_lib" ;
    spdx:builtFrom biotools:staden_io_lib .

