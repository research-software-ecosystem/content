@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:staden_io_lib a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btu390" ;
    schema1:description "Staden io_lib is a library of file reading and writing code e.g. for SAM/BAM/CRAM" ;
