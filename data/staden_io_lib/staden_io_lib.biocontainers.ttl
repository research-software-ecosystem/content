    schema1:keywords "Bioinformatics",
        "Computational Biology",
        "Computers",
        "Data management",
        "Escherichia coli",
        "Genome, Bacterial",
        "Genome, Human",
        "Humans",
        "Information Storage and Retrieval",
        "Programming Languages",
        "Sequencing" ;
    schema1:license "BSD" ;
    schema1:name "staden_io_lib" ;
    schema1:url "https://github.com/jkbonfield/io_lib/" .

