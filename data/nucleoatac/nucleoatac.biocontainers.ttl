@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:nucleoatac a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1101/gr.192294.115" ;
    schema1:description "Python package for calling nucleosomes using ATAC-Seq data. Also includes general scripts for working with paired-end ATAC-Seq data (or potentially other paired-end data)." ;
    schema1:keywords "Cell Line",
        "Chromatin",
        "Chromatin Assembly and Disassembly",
        "Chromosome Mapping",
        "DNA, Fungal",
        "Databases, Genetic",
        "Gene Rearrangement",
        "Humans",
        "Nucleosomes",
        "Promoter Regions, Genetic",
        "Regulatory Sequences, Nucleic Acid",
        "Saccharomyces cerevisiae",
        "Schizosaccharomyces",
        "Sequence Analysis, DNA",
        "Transcription Factors",
        "Transcription, Genetic" ;
    schema1:license "MIT" ;
    schema1:name "nucleoatac" ;
    schema1:url "https://github.com/GreenleafLab/NucleoATAC" .

