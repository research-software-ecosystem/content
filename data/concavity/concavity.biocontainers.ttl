@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:concavity a schema1:SoftwareApplication ;
    schema1:description "Predictor of protein ligand binding sites from structure and conservation" ;
    schema1:license "GPL-3.0+" ;
    schema1:name "concavity" ;
    schema1:url "http://compbio.cs.princeton.edu/concavity/" .

