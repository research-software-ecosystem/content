@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:frc a schema1:SoftwareApplication ;
    schema1:description "Computes FRC from SAM/BAM file and not from afg files" ;
    schema1:license "GPL-3.0" ;
    schema1:name "frc" ;
    schema1:url "https://github.com/vezzi/FRC_align" .

