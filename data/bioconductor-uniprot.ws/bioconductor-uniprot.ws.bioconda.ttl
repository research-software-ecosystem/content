@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-uniprot.ws a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "R Interface to UniProt Web Services" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/UniProt.ws_2.50.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/UniProt.ws/UniProt.ws_2.50.0.tar.gz', 'https://bioarchive.galaxyproject.org/UniProt.ws_2.50.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-uniprot.ws/bioconductor-uniprot.ws_2.50.0_src_all.tar.gz']" ;
    schema1:identifier biotools:uniprot.ws ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-uniprot.ws" ;
    schema1:softwareVersion "2.50.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/UniProt.ws.html" ;
    spdx:builtFrom biotools:uniprot.ws .

