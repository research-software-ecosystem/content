@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-uniprot.ws a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "A collection of functions for retrieving, processing and repackaging the uniprot web services." ;
    schema1:identifier biotools:uniprot.ws ;
    schema1:keywords "Computational Biology",
        "Gene Expression Profiling",
        "Genomics",
        "High-Throughput Screening Assays",
        "Programming Languages",
        "User-Computer Interface" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-uniprot.ws" ;
    schema1:url "http://bioconductor.org/packages/release/bioc/html/UniProt.ws.html" .

