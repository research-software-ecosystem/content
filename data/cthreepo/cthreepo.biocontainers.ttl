@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:cthreepo a schema1:SoftwareApplication ;
    schema1:description "A python script to interconvert seq-ids in gff3, gtf, bed and other files." ;
    schema1:license "MIT" ;
    schema1:name "cthreepo" ;
    schema1:url "https://github.com/vkkodali/cthreepo" .

