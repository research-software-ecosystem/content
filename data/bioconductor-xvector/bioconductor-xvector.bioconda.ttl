@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-xvector a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Foundation of external vector representation and manipulation in Bioconductor" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/XVector_0.46.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/XVector/XVector_0.46.0.tar.gz', 'https://bioarchive.galaxyproject.org/XVector_0.46.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-xvector/bioconductor-xvector_0.46.0_src_all.tar.gz']" ;
    schema1:identifier biotools:xvector ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-xvector" ;
    schema1:softwareVersion "0.46.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/XVector.html" ;
    spdx:builtFrom biotools:xvector .

