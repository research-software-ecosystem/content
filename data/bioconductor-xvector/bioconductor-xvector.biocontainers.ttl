@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-xvector a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Bioconductor representation and manpulation of external sequences" ;
    schema1:identifier biotools:xvector ;
    schema1:keywords "Computational Biology",
        "Data integration and warehousing",
        "Gene Expression Profiling",
        "Genomics",
        "High-Throughput Screening Assays",
        "Programming Languages",
        "Sequencing",
        "Software engineering",
        "User-Computer Interface" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-xvector" ;
    schema1:url "https://bioconductor.org/packages/XVector/" .

