@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:pneumocat a schema1:SoftwareApplication ;
    schema1:description "PneumoCaT (Pneumococcal Capsular Typing) uses a two-step step approach to assign capsular type to S.pneumoniae genomic data (Illumina)" ;
    schema1:license "GPL-3.0" ;
    schema1:name "pneumocat" ;
    schema1:url "https://github.com/phe-bioinformatics/pneumocat" .

