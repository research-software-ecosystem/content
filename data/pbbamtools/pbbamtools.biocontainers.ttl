@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:pbbamtools a schema1:SoftwareApplication ;
    schema1:description "Processing pacific biosciences binary alignment/map files" ;
    schema1:license "PacBio-BSD-3-Clause" ;
    schema1:name "pbbamtools" ;
    schema1:url "http://pbbam.readthedocs.org/en/latest/index.html" .

