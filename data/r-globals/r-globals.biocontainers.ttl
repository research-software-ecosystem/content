@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-globals a schema1:SoftwareApplication ;
    schema1:description "Identifies global (\"unknown\") objects in R expressions by code inspection using various strategies, e.g. conservative or liberal. The objective of this package is to make it as simple as possible to identify global objects for the purpose of exporting them in distributed compute environments." ;
    schema1:license "LGPL (>= 2.1)" ;
    schema1:name "r-globals" ;
    schema1:url "None" .

