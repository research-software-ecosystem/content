@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bio-tradis a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btw022" ;
    schema1:description "This software contains a set of tools to analyse the output from transposon directed insertion sequencing (tradis)  analyses." ;
    schema1:identifier biotools:bio-tradis ;
    schema1:keywords "DNA",
        "DNA Transposable Elements",
        "Gene Library",
        "Genomics",
        "High-Throughput Nucleotide Sequencing",
        "Mobile genetic elements",
        "Sequencing" ;
    schema1:license "GPL-3" ;
    schema1:name "bio-tradis" ;
    schema1:url "https://github.com/sanger-pathogens/Bio-Tradis" .

