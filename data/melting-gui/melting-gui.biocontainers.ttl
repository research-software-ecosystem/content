@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:melting-gui a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/17.12.1226",
        "doi:10.1186/1471-2105-13-101" ;
    schema1:description "Graphical interface to compute the melting temperature of nucleic acid duplex" ;
    schema1:keywords "DNA",
        "Nucleic Acid Denaturation",
        "Nucleic Acid Hybridization",
        "Nucleic Acids",
        "RNA",
        "Temperature",
        "Thermodynamics",
        "User-Computer Interface" ;
    schema1:license "GPL-2+" ;
    schema1:name "melting-gui" ;
    schema1:url "http://www.ebi.ac.uk/compneur-srv/melting/" .

