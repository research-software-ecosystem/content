@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:emboss a schema1:SoftwareApplication ;
    schema1:description "The European Molecular Biology Open Software Suite." ;
    schema1:downloadUrl "ftp://emboss.open-bio.org/pub/EMBOSS/EMBOSS-6.6.0.tar.gz" ;
    schema1:identifier biotools:emboss ;
    schema1:license "GPL-2.0-only" ;
    schema1:name "emboss" ;
    schema1:softwareHelp "https://emboss.sourceforge.net" ;
    schema1:softwareVersion "6.6.0" ;
    schema1:url "https://emboss.sourceforge.net" ;
    spdx:builtFrom biotools:emboss .

