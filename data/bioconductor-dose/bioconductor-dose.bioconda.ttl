@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-dose a schema1:SoftwareApplication ;
    schema1:description "Disease Ontology Semantic and Enrichment analysis" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/DOSE_4.0.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/DOSE/DOSE_4.0.0.tar.gz', 'https://bioarchive.galaxyproject.org/DOSE_4.0.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-dose/bioconductor-dose_4.0.0_src_all.tar.gz']" ;
    schema1:identifier biotools:dose ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-dose" ;
    schema1:softwareVersion "4.0.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/DOSE.html" ;
    spdx:builtFrom biotools:dose .

