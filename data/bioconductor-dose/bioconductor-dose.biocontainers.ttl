@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-dose a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btu684" ;
    schema1:description "This package implements five methods proposed by resnik, schlicker, jiang, lin and wang respectively for measuring semantic similarities among do terms and gene products. enrichment analyses including hypergeometric model and gene set enrichment analysis are also implemented for discovering disease associations of high-throughput biological data." ;
    schema1:identifier biotools:dose ;
    schema1:keywords "Computational Biology",
        "Data quality management",
        "Databases, Genetic",
        "Disease",
        "Gene Ontology",
        "Humans",
        "Medical informatics",
        "Multigene Family",
        "Programming Languages",
        "Semantics" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-dose" ;
    schema1:url "http://bioconductor.org/packages/release/bioc/html/DOSE.html" .

