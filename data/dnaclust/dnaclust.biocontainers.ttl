@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:dnaclust a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/1471-2105-12-271" ;
    schema1:description "Tool for clustering millions of short dna sequences" ;
    schema1:identifier biotools:dnaclust ;
    schema1:keywords "Cluster Analysis",
        "Clustering",
        "DNA",
        "Genetic Markers",
        "Phylogeny",
        "Sequence Alignment",
        "Sequence Analysis, DNA",
        "Sequences" ;
    schema1:license "custom, see /usr/share/doc/dnaclust/copyright" ;
    schema1:name "dnaclust" ;
    schema1:url "http://dnaclust.sourceforge.net/" .

