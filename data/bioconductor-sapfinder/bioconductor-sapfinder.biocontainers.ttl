@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-sapfinder a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18129/b9.bioc.sapfinder" ;
    schema1:description "A package for variant peptides detection and visualization in shotgun proteomics." ;
    schema1:keywords "Peptides",
        "Proteomics" ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-sapfinder" ;
    schema1:url "https://bioconductor.org/packages/3.8/bioc/html/sapFinder.html" .

