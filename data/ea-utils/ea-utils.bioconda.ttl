@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:ea-utils a schema1:SoftwareApplication ;
    schema1:citation "doi:10.2174/1875036201307010001" ;
    schema1:description "Command-line tools for processing biological sequencing data." ;
    schema1:downloadUrl "https://github.com/ExpressionAnalysis/ea-utils/archive/1.04.807.tar.gz" ;
    schema1:identifier biotools:ea-utils ;
    schema1:license "MIT" ;
    schema1:name "ea-utils" ;
    schema1:softwareVersion "1.1.2.779" ;
    schema1:url "https://expressionanalysis.github.io/ea-utils/" ;
    spdx:builtFrom biotools:ea-utils .

