@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:stellar a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/1471-2105-12-S9-S15" ;
    schema1:description "Stellar is a tool for finding pairwise local alignments between long genomic or very many short sequences." ;
    schema1:identifier biotools:stellar ;
    schema1:keywords "Animals",
        "Data quality management",
        "Drosophila",
        "Genomics",
        "Sequence Alignment",
        "Sequence analysis" ;
    schema1:license "Custom License" ;
    schema1:name "stellar" ;
    schema1:url "https://github.com/seqan/seqan/" .

