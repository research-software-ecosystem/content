@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:megahit a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1016/j.ymeth.2016.02.020",
        "doi:10.1093/bioinformatics/btv033" ;
    schema1:description "MEGAHIT: An ultra-fast single-node solution for large and complex metagenomics assembly via succinct de Bruijn graph." ;
    schema1:downloadUrl "https://github.com/voutcn/megahit/archive/v1.2.9.tar.gz" ;
    schema1:identifier biotools:megahit ;
    schema1:license "GPL-3.0-or-later" ;
    schema1:name "megahit" ;
    schema1:softwareHelp "https://github.com/voutcn/megahit/blob/v1.2.9/README.md" ;
    schema1:softwareVersion "1.2.9" ;
    schema1:url "https://github.com/voutcn/megahit" ;
    spdx:builtFrom biotools:megahit .

