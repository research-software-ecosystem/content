@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:megahit a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btv033" ;
    schema1:description "An ultra-fast single-node solution for large and complex metagenomics assembly via succinct de bruijn graph" ;
    schema1:identifier biotools:megahit ;
    schema1:keywords "Ecology",
        "Genomics",
        "High-Throughput Nucleotide Sequencing",
        "Metagenome",
        "Metagenomics",
        "Sequence assembly",
        "Sequencing",
        "Soil" ;
    schema1:license "GNU" ;
    schema1:name "megahit" ;
    schema1:url "https://github.com/voutcn/megahit" .

