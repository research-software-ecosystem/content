@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-metacoder a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1371/journal.pcbi.1005404" ;
    schema1:description "A set of tools for parsing, manipulating, and graphing data classified by a hierarchy" ;
    schema1:keywords "Genomics",
        "Metagenomics" ;
    schema1:license "GPL-3.0" ;
    schema1:name "r-metacoder" ;
    schema1:url "https://github.com/grunwaldlab/metacoder" .

