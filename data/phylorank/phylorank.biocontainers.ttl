@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:phylorank a schema1:SoftwareApplication ;
    schema1:description "Phylorank provides functionality for calculating the relative evolutionary divergence (red) of taxa in a tree and for finding the best placement of taxonomic labels in a tree." ;
    schema1:keywords "Genomics" ;
    schema1:license "GPL-3.0" ;
    schema1:name "phylorank" ;
    schema1:url "https://github.com/dparks1134/PhyloRank" .

