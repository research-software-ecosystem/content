@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:fermi-lite a schema1:SoftwareApplication ;
    schema1:description "Fermi-lite is a standalone C library as well as a command-line tool for assembling Illumina short reads in regions from 100bp to 10 million bp in size." ;
    schema1:keywords "Genomics" ;
    schema1:license "MIT" ;
    schema1:name "fermi-lite" ;
    schema1:url "https://github.com/lh3/fermi-lite" .

