@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:mirmachine a schema1:SoftwareApplication ;
    schema1:description "A command line to tool detect mirna homologs in genome sequences." ;
    schema1:license "MIT" ;
    schema1:name "mirmachine" ;
    schema1:url "https://github.com/sinanugur/MirMachine" .

