@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bcov a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btt555" ;
    schema1:description "BCov is a software package designed for predicting protein beta-sheet topology from amino acid sequence." ;
    schema1:downloadUrl "https://biocomp.unibo.it/savojard/bcov/bcov-1.0.tar.gz" ;
    schema1:identifier biotools:bcov ;
    schema1:license "file" ;
    schema1:name "bcov" ;
    schema1:softwareHelp "https://biocomp.unibo.it/savojard/bcov/index.html" ;
    schema1:softwareVersion "1.0" ;
    schema1:url "https://biocomp.unibo.it/savojard/bcov/index.html" ;
    spdx:builtFrom biotools:bcov .

