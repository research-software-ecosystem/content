@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bcov a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btt555" ;
    schema1:description "BCov is a software package designed for predicting protein beta-sheet topology from amino acid sequence." ;
    schema1:identifier biotools:bcov ;
    schema1:keywords "DNA Mutational Analysis",
        "Machine learning",
        "Models, Statistical",
        "Mutation",
        "Protein Structure, Secondary",
        "Proteins",
        "Sequence Alignment",
        "Sequence Analysis, Protein",
        "Structure prediction" ;
    schema1:license "GPL-3.0" ;
    schema1:name "bcov" ;
    schema1:url "http://biocomp.unibo.it/savojard/bcov/index.html" .

