@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:snoscan a schema1:SoftwareApplication ;
    schema1:description "Search for C/D box methylation guide snoRNA genes in a genomic sequence" ;
    schema1:downloadUrl "http://lowelab.ucsc.edu/software/snoscan-1.0.tar.gz" ;
    schema1:identifier biotools:snoscan ;
    schema1:license "GNU General Public License, version 2" ;
    schema1:name "snoscan" ;
    schema1:softwareVersion "1.0" ;
    schema1:url "http://lowelab.ucsc.edu/snoscan" ;
    spdx:builtFrom biotools:snoscan .

