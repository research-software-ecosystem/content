@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:snoscan a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1126/science.283.5405.1168" ;
    schema1:description "Search for C/D box methylation guide snoRNA genes in a genomic sequence" ;
    schema1:identifier biotools:snoscan ;
    schema1:keywords "Base Pairing",
        "Cell Nucleolus",
        "Epigenetics",
        "Functional, regulatory and non-coding RNA",
        "Methylated DNA immunoprecipitation",
        "Methylation",
        "Models, Genetic",
        "Models, Statistical",
        "RNA",
        "RNA, Fungal",
        "RNA, Ribosomal",
        "RNA, Small Nuclear",
        "Ribose",
        "Saccharomyces cerevisiae" ;
    schema1:license "GPL-2.0" ;
    schema1:name "snoscan" ;
    schema1:url "http://lowelab.ucsc.edu/snoscan" .

