@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-pathostat a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "PathoStat Statistical Microbiome Analysis Package" ;
    schema1:identifier biotools:pathostat ;
    schema1:keywords "Computational Biology",
        "Gene Expression Profiling",
        "Genomics",
        "High-Throughput Screening Assays",
        "Metagenomics",
        "Microbiology",
        "Programming Languages",
        "Sequence analysis",
        "Sequencing",
        "User-Computer Interface" ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-pathostat" ;
    schema1:url "http://bioconductor.org/packages/3.6/bioc/html/PathoStat.html" .

