@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-pathostat a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "PathoStat Statistical Microbiome Analysis Package" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/PathoStat_1.32.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/PathoStat/PathoStat_1.32.0.tar.gz', 'https://bioarchive.galaxyproject.org/PathoStat_1.32.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-pathostat/bioconductor-pathostat_1.32.0_src_all.tar.gz']" ;
    schema1:identifier biotools:pathostat ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-pathostat" ;
    schema1:softwareVersion "1.32.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/PathoStat.html" ;
    spdx:builtFrom biotools:pathostat .

