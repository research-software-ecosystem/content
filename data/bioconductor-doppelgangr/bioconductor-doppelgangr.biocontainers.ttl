@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-doppelgangr a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/jnci/djw146" ;
    schema1:description "Identify likely duplicate samples from genomic or meta-data" ;
    schema1:identifier biotools:doppelgangr ;
    schema1:keywords "Databases, Genetic",
        "Gene Expression Profiling",
        "Genomics",
        "Humans",
        "Microarray Analysis",
        "Neoplasms",
        "Oligonucleotide Array Sequence Analysis",
        "Quality Assurance, Health Care",
        "Transcriptome" ;
    schema1:license "GPL (>=2.0)" ;
    schema1:name "bioconductor-doppelgangr" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/doppelgangR.html" .

