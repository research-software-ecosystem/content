@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:piler a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/bti1003" ;
    schema1:description "PILER is public domain software for analyzing repetitive DNA found in genome sequences." ;
    schema1:keywords "Animals",
        "Arabidopsis",
        "Computational Biology",
        "Drosophila melanogaster",
        "Gene Library",
        "Genome",
        "Genome, Human",
        "Genomics",
        "Humans",
        "Microsatellite Repeats",
        "Models, Genetic",
        "Terminal Repeat Sequences" ;
    schema1:license "Apache-2.0" ;
    schema1:name "piler" ;
    schema1:url "http://www.drive5.com/piler/" .

