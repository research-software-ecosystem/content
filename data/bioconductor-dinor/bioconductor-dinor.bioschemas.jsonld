  "@graph": [
    {
      "@id": "https://doi.org/10.18129/B9.bioc.dinoR",
      "@type": "sc:CreativeWork"
    },
    {
      "@id": "https://bio.tools/bioconductor-dinor",
      "@type": "sc:SoftwareApplication",
      "dcterms:conformsTo": "https://bioschemas.org/profiles/ComputationalTool/0.6-DRAFT",
      "sc:additionalType": [
        "Command-line tool",
        "Library"
      ],
      "sc:author": "Michaela Schwaiger",
      "sc:citation": {
        "@id": "https://doi.org/10.18129/B9.bioc.dinoR"
      },
      "sc:description": "dinoR tests for significant differences in NOMe-seq footprints between two conditions, using genomic regions of interest (ROI) centered around a landmark, for example a transcription factor (TF) motif. This package takes NOMe-seq data (GCH methylation/protection) in the form of a Ranged Summarized Experiment as input. dinoR can be used to group sequencing fragments into 3 or 5 categories representing characteristic footprints (TF bound, nculeosome bound, open chromatin), plot the percentage of fragments in each category in a heatmap, or averaged across different ROI groups, for example, containing a common TF motif. It is designed to compare footprints between two sample groups, using edgeR's quasi-likelihood methods on the total fragment counts per ROI, sample, and footprint category.",
      "sc:license": "MIT",
      "sc:name": "dinoR",
      "sc:operatingSystem": [
        "Linux",
        "Windows",
        "Mac"
      ],
      "sc:softwareHelp": {
        "@id": "https://bioconductor.org/packages/dinoR"
      },
      "sc:softwareVersion": "1.6.0",
      "sc:url": "https://bioconductor.org/packages/dinoR"
    }
  ]
