@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:gecko a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s12859-015-0679-9" ;
    schema1:description "A pairwise genome comparison software for the detection of High-scoring Segment Pairs" ;
    schema1:identifier biotools:gecko ;
    schema1:keywords "Animals",
        "Bacteria",
        "Computational Biology",
        "Datasets as Topic",
        "Drosophila",
        "Genome",
        "Humans",
        "Mammals",
        "Sequence analysis",
        "Synteny",
        "Viruses" ;
    schema1:license "GPL-3" ;
    schema1:name "gecko" ;
    schema1:url "https://github.com/otorreno/gecko" .

