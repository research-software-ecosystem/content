@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:influx_si a schema1:SoftwareApplication ;
    schema1:description "Metabolic flux and concentration estimation based on stable isotope labeling" ;
    schema1:license "GPL" ;
    schema1:name "influx_si" ;
    schema1:url "https://github.com/sgsokol/influx" .

