@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:weeder a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1002/0471250953.bi0211s47" ;
    schema1:description "Motif (transcription factor binding sites) discovery in sequences from coregulated genes of a single species. This is a new Weeder release rewritten to be faster and optimized for large ChIP-Seq data." ;
    schema1:downloadUrl "http://159.149.160.88/modtools/downloads/weeder2.0.tar.gz" ;
    schema1:identifier biotools:weeder ;
    schema1:license "GPL-3.0-or-later" ;
    schema1:name "weeder" ;
    schema1:softwareHelp "http://159.149.160.88/modtools" ;
    schema1:softwareVersion "2.0" ;
    schema1:url "http://159.149.160.88/modtools" ;
    spdx:builtFrom biotools:weeder .

