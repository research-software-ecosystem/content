@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:weeder a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1002/0471250953.bi0211s47" ;
    schema1:description "Motif (transcription factor binding sites) discovery in sequences from coregulated genes of a single species. This is a new Weeder release rewritten to be faster and optimized for large ChIP-Seq data." ;
    schema1:identifier biotools:weeder ;
    schema1:keywords "Binding Sites",
        "Chromatin Immunoprecipitation",
        "DNA",
        "Gene Expression Regulation",
        "Promoter Regions, Genetic",
        "Sequence sites, features and motifs",
        "Transcription Factors",
        "Transcription, Genetic",
        "User-Computer Interface" ;
    schema1:license "GPL-3.0" ;
    schema1:name "weeder" ;
    schema1:url "http://159.149.160.51/modtools/" .

