@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:krakenuniq a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s13059-018-1568-0" ;
    schema1:description "Metagenomics classifier with unique k-mer counting for more specific results" ;
    schema1:identifier biotools:krakenhll ;
    schema1:keywords "Genomics",
        "Infections",
        "Metagenomics" ;
    schema1:license "GPL-3.0" ;
    schema1:name "krakenuniq" ;
    schema1:url "https://github.com/fbreitwieser/krakenuniq" .

