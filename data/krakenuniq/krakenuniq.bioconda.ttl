@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:krakenuniq a schema1:SoftwareApplication ;
    schema1:description "Metagenomics classifier with unique k-mer counting for more specific results" ;
    schema1:downloadUrl "https://github.com/fbreitwieser/krakenuniq/archive/v1.0.4.tar.gz" ;
    schema1:identifier biotools:krakenhll ;
    schema1:license "GPLv3" ;
    schema1:name "krakenuniq" ;
    schema1:softwareVersion "1.0.4" ;
    schema1:url "https://github.com/fbreitwieser/krakenuniq" ;
    spdx:builtFrom biotools:krakenhll .

