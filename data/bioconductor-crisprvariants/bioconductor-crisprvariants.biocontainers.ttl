@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-crisprvariants a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nbt.3628" ;
    schema1:description "Tools for counting and visualising mutations in a target location" ;
    schema1:identifier biotools:crisprvariants ;
    schema1:keywords "Clustered Regularly Interspaced Short Palindromic Repeats",
        "DNA Mutational Analysis",
        "Gene Editing",
        "Genetic variation",
        "Genome",
        "High-Throughput Nucleotide Sequencing",
        "Programming Languages",
        "Sequence Analysis, DNA",
        "Sequencing" ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-crisprvariants" ;
    schema1:url "http://bioconductor.org/packages/3.6/bioc/html/CrispRVariants.html" .

