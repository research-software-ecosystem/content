@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-crisprvariants a schema1:SoftwareApplication ;
    schema1:description "Tools for counting and visualising mutations in a target location" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/CrispRVariants_1.38.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/CrispRVariants/CrispRVariants_1.38.0.tar.gz', 'https://bioarchive.galaxyproject.org/CrispRVariants_1.38.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-crisprvariants/bioconductor-crisprvariants_1.38.0_src_all.tar.gz']" ;
    schema1:identifier biotools:crisprvariants ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-crisprvariants" ;
    schema1:softwareVersion "1.38.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/CrispRVariants.html" ;
    spdx:builtFrom biotools:crisprvariants .

