@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-sc3 a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.4236" ;
    schema1:description "Single-Cell Consensus Clustering" ;
    schema1:identifier biotools:sc3 ;
    schema1:keywords "Cluster Analysis",
        "Clustering",
        "Datasets as Topic",
        "Gene Expression Profiling",
        "Hematopoietic Stem Cells",
        "High-Throughput Nucleotide Sequencing",
        "Humans",
        "RNA-Seq",
        "RNA-seq",
        "Sequence Analysis, RNA",
        "Single-Cell Analysis",
        "Support Vector Machine",
        "Transcriptomics" ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-sc3" ;
    schema1:url "http://bioconductor.org/packages/3.6/bioc/html/SC3.html" .

