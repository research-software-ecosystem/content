@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-sc3 a schema1:SoftwareApplication ;
    schema1:description "Single-Cell Consensus Clustering" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/SC3_1.38.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/SC3/SC3_1.38.0.tar.gz', 'https://bioarchive.galaxyproject.org/SC3_1.38.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-sc3/bioconductor-sc3_1.38.0_src_all.tar.gz']" ;
    schema1:identifier biotools:sc3 ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-sc3" ;
    schema1:softwareVersion "1.38.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/SC3.html" ;
    spdx:builtFrom biotools:sc3 .

