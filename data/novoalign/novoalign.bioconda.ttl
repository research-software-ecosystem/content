@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:novoalign a schema1:SoftwareApplication ;
    schema1:description "Powerful tool designed for mapping of short reads onto a reference genome from Illumina, Ion Torrent, and 454 NGS platforms" ;
    schema1:downloadUrl "http://www.novocraft.com/bioconda/novocraftV4.03.04.Linux3.10.0.tar.gz" ;
    schema1:identifier biotools:Novoalign ;
    schema1:license "Commercial (requires license for use)" ;
    schema1:name "novoalign" ;
    schema1:softwareVersion "4.03.04" ;
    schema1:url "http://www.novocraft.com/products/novoalign/" ;
    spdx:builtFrom biotools:Novoalign .

