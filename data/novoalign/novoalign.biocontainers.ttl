@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:novoalign a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1016/j.ygeno.2017.03.001",
        "doi:10.1038/nmeth.4106",
        "doi:10.1186/1471-2105-14-184",
        "doi:10.1186/1471-2164-15-264" ;
    schema1:description "Powerful tool designed for mapping of short reads onto a reference genome from Illumina, Ion Torrent, and 454 NGS platforms" ;
    schema1:identifier biotools:Novoalign ;
    schema1:keywords "Chromosome Mapping",
        "Computational Biology",
        "Databases, Nucleic Acid",
        "Genomics",
        "High-Throughput Nucleotide Sequencing",
        "Internet",
        "Methylated DNA immunoprecipitation",
        "RNA-seq",
        "Reproducibility of Results",
        "Sensitivity and Specificity",
        "Sequence analysis" ;
    schema1:license "Commercial (requires license for use)" ;
    schema1:name "novoalign" ;
    schema1:url "http://www.novocraft.com/products/novoalign/" .

