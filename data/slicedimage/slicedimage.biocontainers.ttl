@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:slicedimage a schema1:SoftwareApplication ;
    schema1:description "Python module to access sliced imaging data" ;
    schema1:license "MIT" ;
    schema1:name "slicedimage" ;
    schema1:url "https://github.com/spacetx/slicedimage" .

