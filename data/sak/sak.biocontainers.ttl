@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:sak a schema1:SoftwareApplication ;
    schema1:description "This tool allows one to cut sequences and parts of sequences out of sequence files." ;
    schema1:license "Custom License" ;
    schema1:name "sak" ;
    schema1:url "https://github.com/seqan/seqan/" .

