@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:hotspot3d a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/ng.3586" ;
    schema1:description "This 3D proximity tool can be used to identify mutation hotspots from linear protein sequence and correlate the hotspots with known or potentially interacting domains, mutations, or drugs. Mutation-mutation and mutation-drug clusters can also be identified and viewed." ;
    schema1:keywords "Clustering" ;
    schema1:license "GPL-3.0" ;
    schema1:name "hotspot3d" ;
    schema1:url "https://github.com/ding-lab/hotspot3d" .

