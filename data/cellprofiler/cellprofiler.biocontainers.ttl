@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:cellprofiler a schema1:SoftwareApplication ;
    schema1:citation "doi:10.2144/000112257" ;
    schema1:description "CellProfiler is free, open-source software for quantitative analysis of biological images" ;
    schema1:keywords "Cell Count",
        "Colony Count, Microbial",
        "Cytological Techniques",
        "Image Processing, Computer-Assisted",
        "Saccharomyces cerevisiae",
        "Tissue Array Analysis",
        "Wound Healing" ;
    schema1:license "3-clause BSD" ;
    schema1:name "cellprofiler" ;
    schema1:url "https://github.com/CellProfiler/CellProfiler" .

