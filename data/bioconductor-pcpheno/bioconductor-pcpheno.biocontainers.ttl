@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-pcpheno a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Tools to integrate, annotate, and link phenotypes to cellular organizational units such as protein complexes and pathways." ;
    schema1:identifier biotools:pcpheno ;
    schema1:keywords "Computational Biology",
        "Gene Expression Profiling",
        "Genomics",
        "Genotype and phenotype",
        "High-Throughput Screening Assays",
        "Molecular interactions, pathways and networks",
        "Programming Languages",
        "Proteins",
        "Proteomics",
        "User-Computer Interface" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-pcpheno" ;
    schema1:url "http://bioconductor.org/packages/release/bioc/html/PCpheno.html" .

