@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:fqtrim a schema1:SoftwareApplication ;
    schema1:citation "doi:10.5281/zenodo.593893" ;
    schema1:description "fqtrim is a versatile stand-alone utility that can be used to trim adapters, poly-A tails, terminal unknown bases (Ns) and low quality 3' regions in reads from high-throughput next-generation sequencing machines." ;
    schema1:identifier biotools:fqtrim ;
    schema1:keywords "DNA",
        "Genetics",
        "Nucleic acid sites, features and motifs",
        "RNA-Seq",
        "Transcriptome" ;
    schema1:license "Artistic License 2.0" ;
    schema1:name "fqtrim" ;
    schema1:url "https://ccb.jhu.edu/software/fqtrim/" .

