@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:migmap a schema1:SoftwareApplication ;
    schema1:description "A wrapper for igblast v-(d)-j mapping tool designed to facilitate analysis immune receptor libraries profiled using high-throughput sequencing." ;
    schema1:keywords "Genomics" ;
    schema1:license "Apache-2.0" ;
    schema1:name "migmap" ;
    schema1:url "https://github.com/mikessh/migmap" .

