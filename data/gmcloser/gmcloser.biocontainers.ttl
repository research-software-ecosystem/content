@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:gmcloser a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btv465" ;
    schema1:description "GMcloser fills and closes the gaps present in scaffold assemblies, especially those generated by the de novo assembly of whole genomes with next-generation sequencing (NGS) reads." ;
    schema1:identifier biotools:gmcloser ;
    schema1:keywords "Contig Mapping",
        "DNA",
        "High-Throughput Nucleotide Sequencing",
        "Likelihood Functions",
        "Sequence Alignment",
        "Sequence Analysis, DNA",
        "Sequence analysis",
        "Sequence assembly",
        "Sequencing" ;
    schema1:license "GPL-3.0" ;
    schema1:name "gmcloser" ;
    schema1:url "https://sourceforge.net/projects/gmcloser/" .

