@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:opsin a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1021/ci100384d" ;
    schema1:description "Opsin is a java(1.6+) library for iupac name-to-structure conversion offering high recall and precision on organic chemical nomenclature." ;
    schema1:keywords "Models, Molecular",
        "Terminology as Topic" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "opsin" ;
    schema1:url "https://github.com/dan2097/opsin" .

