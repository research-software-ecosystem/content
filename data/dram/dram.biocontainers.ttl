@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:dram a schema1:SoftwareApplication ;
    schema1:description "Distilled and refined annotation of metabolism: a tool for the annotation and curation of function for microbial and viral genomes" ;
    schema1:keywords "Genomics",
        "Metagenome",
        "Metagenomics",
        "Ortholog" ;
    schema1:license "Not available" ;
    schema1:name "dram" ;
