@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:calib a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btm159" ;
    schema1:description "Clustering without alignment using (locality sensitive hashing) LSH and MinHashing of barcoded reads" ;
    schema1:identifier biotools:calib ;
    schema1:keywords "Calibration",
        "Clustering",
        "Gene Expression Profiling",
        "Gene Targeting",
        "Gene expression",
        "Image Interpretation, Computer-Assisted",
        "Microarray experiment",
        "Microscopy, Fluorescence, Multiphoton",
        "Oligonucleotide Array Sequence Analysis",
        "Sequence Alignment" ;
    schema1:license "MIT" ;
    schema1:name "calib" ;
    schema1:url "https://github.com/vpc-ccg/calib" .

