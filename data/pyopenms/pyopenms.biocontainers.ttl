@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:pyopenms a schema1:SoftwareApplication ;
    schema1:citation "doi:10.7287/PEERJ.PREPRINTS.27736" ;
    schema1:description "pyOpenMS is an open-source Python library for mass spectrometry, specifically for the analysis of proteomics and metabolomics data in Python. pyOpenMS implements a set of Python bindings to the OpenMS library for computational mass spectrometry." ;
    schema1:identifier biotools:pyOpenMS ;
    schema1:keywords "Mass spectrometry",
        "Metabolomics",
        "Protein modifications",
        "Proteomics",
        "Proteomics experiment" ;
    schema1:license "BSD-3-Clause" ;
    schema1:name "pyopenms" ;
    schema1:url "https://github.com/OpenMS/OpenMS" .

