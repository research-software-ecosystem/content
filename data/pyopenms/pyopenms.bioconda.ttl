@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:pyopenms a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/s41592-024-02197-7" ;
    schema1:description "Python bindings for OpenMS, an open-source software C++ library for LC-MS data management and analyses." ;
    schema1:downloadUrl "https://github.com/OpenMS/OpenMS/releases/download/release%2F3.4.1/OpenMS-3.4.1.tar.gz" ;
    schema1:identifier biotools:openms ;
    schema1:license "BSD-3-Clause" ;
    schema1:name "pyopenms" ;
    schema1:softwareHelp "https://openms.readthedocs.io/en/latest" ;
    schema1:softwareVersion "3.4.1" ;
    schema1:url "https://github.com/OpenMS/OpenMS" ;
    spdx:builtFrom biotools:openms .

