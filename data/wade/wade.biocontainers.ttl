@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:wade a schema1:SoftwareApplication ;
    schema1:description "WADE provides a flexible and customizable method to extract specific genes from a large number of genomes at once." ;
    schema1:license "Apache-2.0" ;
    schema1:name "wade" ;
    schema1:url "https://github.com/phac-nml/wade" .

