@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:vcf-annotator a schema1:SoftwareApplication ;
    schema1:description "Use the reference genbank file to add biological annotations to the variant calls in a vcf." ;
    schema1:license "MIT" ;
    schema1:name "vcf-annotator" ;
    schema1:url "https://github.com/rpetit3/vcf-annotator" .

