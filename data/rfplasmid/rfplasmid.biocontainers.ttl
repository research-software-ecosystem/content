@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:rfplasmid a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1101/2020.07.31.230631" ;
    schema1:description "Rfplasmid predicts plasmid contigs from assemblies using single copy marker genes, plasmid genes, and kmers." ;
    schema1:keywords "Genomics",
        "Metagenomics" ;
    schema1:license "GPL-3" ;
    schema1:name "rfplasmid" ;
    schema1:url "https://github.com/aldertzomer/RFPlasmid" .

