    schema1:downloadUrl "['https://bioconductor.org/packages/3.18/bioc/src/contrib/DeepBlueR_1.27.0.tar.gz', 'https://bioconductor.org/packages/3.18/bioc/src/contrib/Archive/DeepBlueR/DeepBlueR_1.27.0.tar.gz', 'https://bioarchive.galaxyproject.org/DeepBlueR_1.27.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-deepbluer/bioconductor-deepbluer_1.27.0_src_all.tar.gz']" ;
