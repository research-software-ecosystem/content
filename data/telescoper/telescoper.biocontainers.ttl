@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:telescoper a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/bts399" ;
    schema1:description "De novo assembly of highly repetitive regions" ;
    schema1:identifier biotools:telescoper ;
    schema1:keywords "DNA",
        "Genome",
        "Genomics",
        "High-Throughput Nucleotide Sequencing",
        "Repetitive Sequences, Nucleic Acid",
        "Saccharomyces cerevisiae",
        "Sequence Analysis, DNA",
        "Sequence analysis",
        "Sequence assembly",
        "Sequencing" ;
    schema1:license "Custom" ;
    schema1:name "telescoper" ;
    schema1:url "https://sourceforge.net/projects/telescoper/" .

