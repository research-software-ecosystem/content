@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-stattarget a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18129/b9.bioc.stattarget" ;
    schema1:description "Statistical Analysis of Molecular Profiles" ;
    schema1:keywords "Metabolomics",
        "Proteomics" ;
    schema1:license "LGPL (>= 3)" ;
    schema1:name "bioconductor-stattarget" ;
    schema1:url "https://www.bioconductor.org/packages/release/bioc/html/statTarget.html" .

