@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-customprodb a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btt543",
        "doi:10.18129/b9.bioc.customprodb" ;
    schema1:description "Generate customized protein database from ngs data, with a focus on rna-seq data, for proteomics search" ;
    schema1:identifier biotools:customprodb ;
    schema1:keywords "Biomarkers, Tumor",
        "Colonic Neoplasms",
        "Data integration and warehousing",
        "Databases, Protein",
        "Genomics",
        "High-Throughput Nucleotide Sequencing",
        "Humans",
        "Mass spectrometry",
        "Peptide Fragments",
        "Proteins",
        "Proteomics",
        "RNA-Seq",
        "Sequencing" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-customprodb" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/customProDB.html" .

