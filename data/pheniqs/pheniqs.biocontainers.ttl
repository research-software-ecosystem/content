@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:pheniqs a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1101/128512" ;
    schema1:description "Pheniqs is a generic high throughput DNA sequence demultiplexer and quality analyzer written in multi threaded C++11. Pheniqs is pronounced phoe·nix and stands for PHilology ENcoder wIth Quality Statistics." ;
    schema1:keywords "Genetics",
        "Genomics" ;
    schema1:license "GPL-3.0" ;
    schema1:name "pheniqs" ;
    schema1:url "http://biosails.github.io/pheniqs" .

