@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:metaxa a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1007/s10482-011-9598-6",
        "doi:10.1093/bioinformatics/bty482",
        "doi:10.1111/1755-0998.12399" ;
    schema1:description "Metaxa uses hidden markov models to identify, extract and classify small-subunit (ssu) rrna sequences (12s/16s/18s) of bacterial, archaeal, eukaryotic, chloroplast and mitochondrial origin in metagenomes and other large sequence sets" ;
    schema1:identifier biotools:metaxa ;
    schema1:keywords "Computational Biology",
        "DNA Barcoding, Taxonomic",
        "Genetic Markers",
        "Genomics",
        "Metagenome",
        "Metagenomics",
        "Microbial ecology",
        "Phylogenetics",
        "Phylogeny",
        "Sequence analysis" ;
    schema1:license "GPL-3.0" ;
    schema1:name "metaxa" ;
    schema1:url "http://microbiology.se/software/metaxa/" .

