@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:metaxa a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/bty482",
        "doi:10.1111/1755-0998.12399" ;
    schema1:description "Improved Identification and Taxonomic Classification of Small and Large Subunit rRNA in Metagenomic Data." ;
    schema1:downloadUrl "http://microbiology.se/sw/Metaxa2_2.2.3.tar.gz" ;
    schema1:identifier biotools:metaxa ;
    schema1:license "GPL-3.0" ;
    schema1:name "metaxa" ;
    schema1:softwareVersion "2.2.3" ;
    schema1:url "http://microbiology.se/software/metaxa2/" ;
    spdx:builtFrom biotools:metaxa .

