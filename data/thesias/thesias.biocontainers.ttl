@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:thesias a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/sj.ejhg.5201238",
        "doi:10.1093/bioinformatics/btm058",
        "doi:10.1093/hmg/11.17.2015" ;
    schema1:description "Testing Haplotype Effects In Association Studies" ;
    schema1:identifier biotools:THESIAS ;
    schema1:keywords "Adult",
        "Case-Control Studies",
        "Gene Frequency",
        "Genetic Predisposition to Disease",
        "Genetics",
        "Genomics",
        "Haplotypes",
        "Humans",
        "Linkage Disequilibrium",
        "Middle Aged",
        "Myocardial Infarction",
        "P-Selectin",
        "Polymorphism, Genetic",
        "Promoter Regions, Genetic",
        "Quantitative genetics" ;
    schema1:license "GPL-3.0" ;
    schema1:name "thesias" ;
    schema1:url "https://github.com/daissi/thesias" .

