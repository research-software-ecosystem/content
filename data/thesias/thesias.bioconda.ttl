@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:thesias a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btm058" ;
    schema1:description "Testing Haplotype Effects In Association Studies" ;
    schema1:downloadUrl "https://github.com/daissi/thesias/archive/3.1.1.tar.gz" ;
    schema1:identifier biotools:THESIAS ;
    schema1:license "GPL-3+" ;
    schema1:name "thesias" ;
    schema1:softwareVersion "3.1.1" ;
    schema1:url "https://github.com/daissi/thesias" ;
    spdx:builtFrom biotools:THESIAS .

