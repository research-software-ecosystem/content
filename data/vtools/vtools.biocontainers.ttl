@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:vtools a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btr667" ;
    schema1:description "Various tools operating over VCF files. Uses cyvcf2 and cython under the hood for speed" ;
    schema1:identifier biotools:vtools ;
    schema1:keywords "Exome sequencing",
        "Genetic Variation",
        "Genome, Human",
        "Genotype and phenotype",
        "High-Throughput Nucleotide Sequencing",
        "Humans",
        "Metabolic Networks and Pathways",
        "Molecular Sequence Annotation",
        "User-Computer Interface",
        "Workflows" ;
    schema1:license "MIT" ;
    schema1:name "vtools" ;
    schema1:url "https://github.com/LUMC/vtools" .

