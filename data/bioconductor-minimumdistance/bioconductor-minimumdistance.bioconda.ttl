@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-minimumdistance a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/1471-2105-13-330" ;
    schema1:description "A Package for De Novo CNV Detection in Case-Parent Trios" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/MinimumDistance_1.50.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/MinimumDistance/MinimumDistance_1.50.0.tar.gz', 'https://bioarchive.galaxyproject.org/MinimumDistance_1.50.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-minimumdistance/bioconductor-minimumdistance_1.50.0_src_all.tar.gz']" ;
    schema1:identifier biotools:minimumdistance ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-minimumdistance" ;
    schema1:softwareVersion "1.50.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/MinimumDistance.html" ;
    spdx:builtFrom biotools:minimumdistance .

