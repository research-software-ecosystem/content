@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-minimumdistance a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/1471-2105-13-330" ;
    schema1:description "Analysis of de novo copy number variants in trios from high-dimensional genotyping platforms." ;
    schema1:identifier biotools:minimumdistance ;
    schema1:keywords "Child",
        "Cleft Palate",
        "DNA Copy Number Variations",
        "Genome, Human",
        "Genotype and phenotype",
        "Genotyping experiment",
        "Humans",
        "Oligonucleotide Array Sequence Analysis",
        "Parents",
        "Polymorphism, Single Nucleotide",
        "Regression Analysis" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-minimumdistance" ;
    schema1:url "http://bioconductor.org/packages/release/bioc/html/MinimumDistance.html" .

