@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-sseq a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btt143" ;
    schema1:description "Shrinkage estimation of dispersion in Negative Binomial models for RNA-seq experiments with small sample size" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/sSeq_1.44.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/sSeq/sSeq_1.44.0.tar.gz', 'https://bioarchive.galaxyproject.org/sSeq_1.44.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-sseq/bioconductor-sseq_1.44.0_src_all.tar.gz']" ;
    schema1:identifier biotools:sseq ;
    schema1:license "GPL (>= 3)" ;
    schema1:name "bioconductor-sseq" ;
    schema1:softwareVersion "1.44.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/sSeq.html" ;
    spdx:builtFrom biotools:sseq .

