@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-sseq a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btt143" ;
    schema1:description "Shrinkage estimation of dispersion in Negative Binomial models for RNA-seq experiments with small sample size" ;
    schema1:identifier biotools:sseq ;
    schema1:keywords "Binomial Distribution",
        "Gene Expression",
        "Gene expression",
        "Models, Statistical",
        "Probability",
        "RNA",
        "RNA-Seq",
        "Sample Size",
        "Sequence Analysis, RNA",
        "Transcriptome" ;
    schema1:license "GPL-3.0" ;
    schema1:name "bioconductor-sseq" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/sSeq.html" .

