@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-chicago a schema1:SoftwareApplication ;
    schema1:description "CHiCAGO: Capture Hi-C Analysis of Genomic Organization" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/Chicago_1.34.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/Chicago/Chicago_1.34.0.tar.gz', 'https://bioarchive.galaxyproject.org/Chicago_1.34.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-chicago/bioconductor-chicago_1.34.0_src_all.tar.gz']" ;
    schema1:identifier biotools:chicago ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-chicago" ;
    schema1:softwareVersion "1.34.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/Chicago.html" ;
    spdx:builtFrom biotools:chicago .

