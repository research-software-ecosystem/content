@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-genomictools a schema1:SoftwareApplication ;
    schema1:description "A loose collection of tools for the analysis of expression and genotype data, currently with the main focus on (e)QTL and MDR analysis." ;
    schema1:license "GPL-2" ;
    schema1:name "r-genomictools" ;
    schema1:url "https://CRAN.R-project.org/package=GenomicTools" .

