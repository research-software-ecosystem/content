@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-gsva a schema1:SoftwareApplication ;
    schema1:description "Gene Set Variation Analysis for Microarray and RNA-Seq Data" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/GSVA_2.4.4.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/GSVA/GSVA_2.4.4.tar.gz', 'https://bioarchive.galaxyproject.org/GSVA_2.4.4.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-gsva/bioconductor-gsva_2.4.4_src_all.tar.gz']" ;
    schema1:identifier biotools:gsva ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-gsva" ;
    schema1:softwareVersion "2.4.4" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/GSVA.html" ;
    spdx:builtFrom biotools:gsva .

