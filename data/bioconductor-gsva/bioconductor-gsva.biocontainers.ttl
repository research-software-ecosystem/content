@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-gsva a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/1471-2105-14-7" ;
    schema1:description "Gene Set Variation Analysis for microarray and RNA-seq data" ;
    schema1:identifier biotools:gsva ;
    schema1:keywords "Analysis of Variance",
        "Clustering",
        "Female",
        "Gene Expression Profiling",
        "Gene expression",
        "Genetic Variation",
        "Humans",
        "Leukemia, Biphenotypic, Acute",
        "Molecular genetics",
        "Oligonucleotide Array Sequence Analysis",
        "Ovarian Neoplasms",
        "Precursor Cell Lymphoblastic Leukemia-Lymphoma",
        "RNA-Seq",
        "Sequence Analysis, RNA",
        "Statistics, Nonparametric",
        "Survival Analysis" ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-gsva" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/GSVA.html" .

