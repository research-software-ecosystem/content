@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-keggrest a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1007/s11845-015-1283-8" ;
    schema1:description "A package that provides a client interface to the kegg rest server. based on keggsoap by j. zhang, r. gentleman, and marc carlson, and kegg (python package) by aurelien mazurie." ;
    schema1:identifier biotools:keggrest ;
    schema1:keywords "Adult",
        "Bioinformatics",
        "CDC2 Protein Kinase",
        "Cell Cycle",
        "Cyclin-Dependent Kinases",
        "Down-Regulation",
        "Early Detection of Cancer",
        "Female",
        "Gene Expression Profiling",
        "Gene Regulatory Networks",
        "Humans",
        "Middle Aged",
        "Up-Regulation",
        "Uterine Cervical Neoplasms" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-keggrest" ;
    schema1:url "http://bioconductor.org/packages/release/bioc/html/KEGGREST.html" .

