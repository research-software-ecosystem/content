@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-keggrest a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1007/s11845-015-1283-8" ;
    schema1:description "Client-side REST access to the Kyoto Encyclopedia of Genes and Genomes (KEGG)" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/KEGGREST_1.46.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/KEGGREST/KEGGREST_1.46.0.tar.gz', 'https://bioarchive.galaxyproject.org/KEGGREST_1.46.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-keggrest/bioconductor-keggrest_1.46.0_src_all.tar.gz']" ;
    schema1:identifier biotools:keggrest ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-keggrest" ;
    schema1:softwareVersion "1.46.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/KEGGREST.html" ;
    spdx:builtFrom biotools:keggrest .

