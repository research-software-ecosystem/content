@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:biopython-sql a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btp163" ;
    schema1:description "Biopython support for the biosql database schema (python 3)" ;
    schema1:identifier biotools:biopython ;
    schema1:keywords "Bioinformatics",
        "Computational Biology",
        "Computational biology",
        "Data management",
        "Databases, Factual",
        "Genetics",
        "Genomics",
        "Internet",
        "Phylogenetics",
        "Programming Languages",
        "Software engineering" ;
    schema1:license "other" ;
    schema1:name "biopython-sql" ;
    schema1:url "https://github.com/biopython/biopython" .

