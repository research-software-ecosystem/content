@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-macat a schema1:SoftwareApplication ;
    schema1:description "MicroArray Chromosome Analysis Tool" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.18/bioc/src/contrib/macat_1.76.0.tar.gz', 'https://bioconductor.org/packages/3.18/bioc/src/contrib/Archive/macat/macat_1.76.0.tar.gz', 'https://bioarchive.galaxyproject.org/macat_1.76.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-macat/bioconductor-macat_1.76.0_src_all.tar.gz']" ;
    schema1:identifier biotools:macat ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-macat" ;
    schema1:softwareVersion "1.76.0" ;
    schema1:url "https://bioconductor.org/packages/3.18/bioc/html/macat.html" ;
    spdx:builtFrom biotools:macat .

