@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-macat a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/bti183" ;
    schema1:description "This library contains functions to investigate links between differential gene expression and the chromosomal localization of the genes. it implements an statistical approach for identifying significantly differentially expressed chromosome regions. the functions have been tested on a publicly available data set about acute lymphoblastic leukemia." ;
    schema1:identifier biotools:macat ;
    schema1:keywords "Chromosome Mapping",
        "Computer Simulation",
        "Gene Expression",
        "Gene Expression Profiling",
        "Gene Frequency",
        "Gene expression",
        "Genetics",
        "Linkage Disequilibrium",
        "Models, Genetic",
        "Models, Statistical",
        "Nucleic acids",
        "Oligonucleotide Array Sequence Analysis" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-macat" ;
    schema1:url "http://bioconductor.org/packages/release/bioc/html/macat.html" .

