@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-scuttle a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18129/b9.bioc.scuttle" ;
    schema1:description "Provides basic utility functions for performing single-cell analyses, focusing on simple normalization, quality control and data transformations. Also provides some helper functions to assist development of other packages." ;
    schema1:keywords "RNA-Seq",
        "Transcriptomics" ;
    schema1:license "GPL-3.0" ;
    schema1:name "bioconductor-scuttle" ;
    schema1:url "https://bioconductor.org/packages/3.12/bioc/html/scuttle.html" .

