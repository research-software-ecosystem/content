@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:demuxem a schema1:SoftwareApplication ;
    schema1:description "Demuxem is the demultiplexing module of pegasus, which works on cell-hashing and nucleus-hashing genomics data." ;
    schema1:keywords "Genomics" ;
    schema1:license "BSD" ;
    schema1:name "demuxem" ;
    schema1:url "https://github.com/klarman-cell-observatory/demuxEM" .

