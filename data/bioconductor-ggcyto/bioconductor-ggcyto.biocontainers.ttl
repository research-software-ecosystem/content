@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-ggcyto a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252",
        "doi:10.18129/b9.bioc.ggcyto" ;
    schema1:description "With the dedicated fority method implemented for flowset, ncdfflowset and gatingset classes, both raw and gated flow cytometry data can be plotted directly with ggplot. this wrapper and some customized layers also make it easy to add gates and population statistics to the plot." ;
    schema1:identifier biotools:ggcyto ;
    schema1:keywords "Cell biology",
        "Computational Biology",
        "Data visualisation",
        "Gene Expression Profiling",
        "Genomics",
        "High-Throughput Screening Assays",
        "Programming Languages",
        "User-Computer Interface" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-ggcyto" ;
    schema1:url "http://bioconductor.org/packages/release/bioc/html/ggcyto.html" .

