@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-ggcyto a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Visualize Cytometry data with ggplot" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/ggcyto_1.38.1.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/ggcyto/ggcyto_1.38.1.tar.gz', 'https://bioarchive.galaxyproject.org/ggcyto_1.38.1.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-ggcyto/bioconductor-ggcyto_1.38.1_src_all.tar.gz']" ;
    schema1:identifier biotools:ggcyto ;
    schema1:license "file LICENSE" ;
    schema1:name "bioconductor-ggcyto" ;
    schema1:softwareVersion "1.38.1" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/ggcyto.html" ;
    spdx:builtFrom biotools:ggcyto .

