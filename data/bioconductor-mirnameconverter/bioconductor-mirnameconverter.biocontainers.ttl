@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-mirnameconverter a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btw660" ;
    schema1:description "Package containing an s4 class for translating mature mirna names to different mirbase versions, sequence retrieval, checking names for validity and detecting mirbase version of a given set of names." ;
    schema1:identifier biotools:mirnameconverter ;
    schema1:keywords "Animals",
        "Functional, regulatory and non-coding RNA",
        "Gene Ontology",
        "Gene transcripts",
        "Humans",
        "Mice",
        "MicroRNAs",
        "Molecular Sequence Annotation",
        "RNA",
        "Terminology as Topic" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-mirnameconverter" ;
    schema1:url "http://bioconductor.org/packages/release/bioc/html/miRNAmeConverter.html" .

