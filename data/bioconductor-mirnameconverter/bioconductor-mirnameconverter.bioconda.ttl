@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-mirnameconverter a schema1:SoftwareApplication ;
    schema1:description "Convert miRNA Names to Different miRBase Versions" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/miRNAmeConverter_1.38.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/miRNAmeConverter/miRNAmeConverter_1.38.0.tar.gz', 'https://bioarchive.galaxyproject.org/miRNAmeConverter_1.38.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-mirnameconverter/bioconductor-mirnameconverter_1.38.0_src_all.tar.gz']" ;
    schema1:identifier biotools:mirnameconverter ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-mirnameconverter" ;
    schema1:softwareVersion "1.38.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/miRNAmeConverter.html" ;
    spdx:builtFrom biotools:mirnameconverter .

