@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:mvicuna a schema1:SoftwareApplication ;
    schema1:description "M-vicuna is a modularized version of vicuna, a de novo assembly program targeting populations with high mutation rates." ;
    schema1:keywords "Genetics",
        "Genomics",
        "Metabolomics",
        "Proteomics",
        "Sequence Alignment" ;
    schema1:license "https://www.broadinstitute.org/node/4238" ;
    schema1:name "mvicuna" ;
    schema1:url "https://www.broadinstitute.org/scientific-community/science/projects/viral-genomics/vicuna" .

