@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:magicblast a schema1:SoftwareApplication ;
    schema1:author "boratyng" ;
    schema1:citation "doi:10.1186/s12859-019-2996-x" ;
    schema1:description "NCBI BLAST next generation read mapper" ;
    schema1:downloadUrl "ftp://ftp.ncbi.nlm.nih.gov/blast/executables/magicblast/1.7.0/ncbi-magicblast-1.7.0-src.tar.gz" ;
    schema1:identifier biotools:magicblast ;
    schema1:license "Public Domain" ;
    schema1:maintainer "boratyng" ;
    schema1:name "magicblast" ;
    schema1:softwareVersion "1.7.0" ;
    schema1:url "https://ncbi.github.io/magicblast/" ;
    spdx:builtFrom biotools:magicblast .

