@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:magicblast a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s12859-019-2996-x" ;
    schema1:description "Magic-blast is a new tool for mapping large sets of next-generation rna or dna sequencing runs against a whole genome or transcriptome" ;
    schema1:identifier biotools:magicblast ;
    schema1:keywords "Base Sequence",
        "Databases, Nucleic Acid",
        "Humans",
        "Introns",
        "RNA",
        "RNA-Seq",
        "ROC Curve",
        "Sequence Alignment",
        "Sequence Analysis, RNA",
        "Time Factors" ;
    schema1:license "MIT" ;
    schema1:name "magicblast" ;
    schema1:url "https://github.com/ncbi/magicblast" .

