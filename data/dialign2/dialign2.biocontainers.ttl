@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:dialign2 a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/gkt283" ;
    schema1:description "DIALIGN multiple sequence alignment using various sources of external information" ;
    schema1:identifier biotools:dialign ;
    schema1:keywords "Genetics",
        "Internet",
        "Sequence Alignment",
        "Sequence Analysis, DNA",
        "Sequence Analysis, Protein",
        "Sequence analysis",
        "Sequence assembly" ;
    schema1:license "LGPL" ;
    schema1:name "dialign2" ;
    schema1:url "http://dialign.gobics.de" .

