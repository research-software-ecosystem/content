@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:pourrna a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btz583" ;
    schema1:description "Compute local minima and respective transition rates of an RNA energy landscape." ;
    schema1:keywords "Heuristics",
        "Kinetics",
        "RNA",
        "RNA Folding" ;
    schema1:license "GPL-2.0" ;
    schema1:name "pourrna" ;
    schema1:url "https://github.com/ViennaRNA/pourRNA/" .

