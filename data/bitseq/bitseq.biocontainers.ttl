@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bitseq a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/bts260" ;
    schema1:description "This package is targeted for transcript expression analysis and de analysis of rna-seq data in a two-stage process. in the first stage it uses bayesian methodology to infer expression of individual transcripts from individual rna-seq experiments. the second stage embraces the de analysis of transcript expression by providing expression estimates from replicates of multiple conditions." ;
    schema1:identifier biotools:bitseq ;
    schema1:keywords "Bayes Theorem",
        "Gene Expression Profiling",
        "Gene expression",
        "Genetic Variation",
        "High-Throughput Nucleotide Sequencing",
        "Models, Statistical",
        "RNA-Seq",
        "RNA-seq",
        "Sequence Alignment",
        "Sequence Analysis, RNA",
        "Transcriptome" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bitseq" ;
    schema1:url "http://bioconductor.org/packages/release/bioc/html/BitSeq.html" .

