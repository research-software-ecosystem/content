@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-biodist a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Different distance measures" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/bioDist_1.78.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/bioDist/bioDist_1.78.0.tar.gz', 'https://bioarchive.galaxyproject.org/bioDist_1.78.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-biodist/bioconductor-biodist_1.78.0_src_all.tar.gz']" ;
    schema1:identifier biotools:biodist ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-biodist" ;
    schema1:softwareVersion "1.78.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/bioDist.html" ;
    spdx:builtFrom biotools:biodist .

