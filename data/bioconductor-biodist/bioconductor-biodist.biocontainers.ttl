@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-biodist a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "A collection of software tools for calculating distance measures." ;
    schema1:identifier biotools:biodist ;
    schema1:keywords "Clustering",
        "Computational Biology",
        "Gene Expression Profiling",
        "Genomics",
        "High-Throughput Screening Assays",
        "Programming Languages",
        "Structure analysis",
        "User-Computer Interface" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-biodist" ;
    schema1:url "http://bioconductor.org/packages/release/bioc/html/bioDist.html" .

