      },
      "sc:contributor": [
        "Michael Duff",
        "Ollivier Hyrien",
        "Kellie MacPhee",
        "Jason Taylor"
      ],
      "sc:description": "The igblastr package provides functions to conveniently install and use a local IgBLAST installation from within R. The package also includes a set of built-in IgBLAST-compatible germline databases from OGRDB, the AIRR Community’s Open Germline Receptor Database, for various organisms. It provides functions to create additional IgBLAST-compatible germline databases using reference sequences retrieved from IMGT/V-QUEST or local FASTA files supplied by the user. When possible, the FWR/CDR boundaries on the V alleles (a.k.a \"internal data\") are computed and stored in the germline database, so can be used as a replacement for the internal data shipped with IgBLAST. IgBLAST is described at <https://pubmed.ncbi.nlm.nih.gov/23671333/>. IgBLAST web interface: <https://www.ncbi.nlm.nih.gov/igblast/>. OGRDB: <https://ogrdb.airr-community.org/>. IMGT/V-QUEST download site: <https://www.imgt.org/download/V-QUEST/>.",
      "sc:license": "Artistic-2.0",
      "sc:name": "igblastr",
      "sc:operatingSystem": [
        "Windows",
        "Mac",
        "Linux"
      ],
