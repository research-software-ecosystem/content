@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-shinybs a schema1:SoftwareApplication ;
    schema1:description "shinyBS is a package that adds several additional Twitter Boostrap components to shiny. In January RStudio updated shiny to work with Bootstrap3 which completely broke the original shinyBS." ;
    schema1:license "Custom License" ;
    schema1:name "r-shinybs" ;
    schema1:url "https://github.com/ebailey78/shinyBS" .

