@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:k-slam a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/gkw1248" ;
    schema1:description "k-SLAM is a program for alignment based metagenomic analysis of large sets of high-throughput sequence data." ;
    schema1:keywords "Genomics",
        "Metagenomics",
        "Sequence Alignment" ;
    schema1:license "GPL-3.0" ;
    schema1:name "k-slam" ;
    schema1:url "https://github.com/aindj/k-SLAM" .

