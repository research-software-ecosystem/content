@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-msnbase a schema1:SoftwareApplication ;
    schema1:description "Base Functions and Classes for Mass Spectrometry and Proteomics" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/MSnbase_2.32.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/MSnbase/MSnbase_2.32.0.tar.gz', 'https://bioarchive.galaxyproject.org/MSnbase_2.32.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-msnbase/bioconductor-msnbase_2.32.0_src_all.tar.gz']" ;
    schema1:identifier biotools:msnbase ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-msnbase" ;
    schema1:softwareVersion "2.32.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/MSnbase.html" ;
    spdx:builtFrom biotools:msnbase .

