@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-pviz a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1007/978-1-4939-3037-1_10" ;
    schema1:description "Peptide Annotation and Data Visualization using Gviz" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/Pviz_1.40.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/Pviz/Pviz_1.40.0.tar.gz', 'https://bioarchive.galaxyproject.org/Pviz_1.40.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-pviz/bioconductor-pviz_1.40.0_src_all.tar.gz']" ;
    schema1:identifier biotools:pviz ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-pviz" ;
    schema1:softwareVersion "1.40.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/Pviz.html" ;
    spdx:builtFrom biotools:pviz .

