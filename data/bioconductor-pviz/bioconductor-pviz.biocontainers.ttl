@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-pviz a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1007/978-1-4939-3037-1_10" ;
    schema1:description "This tool adapts the gviz package for protein sequences and data." ;
    schema1:identifier biotools:pviz ;
    schema1:keywords "Antibodies",
        "Clinical Trials as Topic",
        "Humans",
        "Peptides",
        "Protein Array Analysis",
        "Protein Sequences",
        "Proteins",
        "Proteomics",
        "Sequence analysis",
        "Statistics as Topic",
        "Vaccines" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-pviz" ;
    schema1:url "http://bioconductor.org/packages/release/bioc/html/Pviz.html" .

