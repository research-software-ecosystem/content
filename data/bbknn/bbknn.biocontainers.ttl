@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bbknn a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1101/397042" ;
    schema1:description "Batch balanced KNN" ;
    schema1:identifier biotools:bbknn ;
    schema1:keywords "Clustering",
        "Statistics and probability",
        "Transcriptome",
        "Transcriptomics" ;
    schema1:license "MIT" ;
    schema1:name "bbknn" ;
    schema1:url "https://github.com/Teichlab/bbknn" .

