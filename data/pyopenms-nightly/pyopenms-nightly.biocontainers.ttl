@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:pyopenms-nightly a schema1:SoftwareApplication ;
    schema1:citation "doi:10.7287/PEERJ.PREPRINTS.27736" ;
    schema1:description "This package contains Python bindings for a large part of the OpenMS library for mass spectrometry based proteomics. It thus provides providing facile access to a feature-rich, open-source algorithm library for mass-spectrometry based proteomics analysis. These Python bindings allow raw access to the data-structures and algorithms implemented in OpenMS, specifically those for file access (mzXML, mzML, TraML, mzIdentML among others), basic signal processing (smoothing, filtering, de-isotoping and peak-picking) and complex data analysis (including label-free, SILAC, iTRAQ and SWATH analysis tools)." ;
    schema1:identifier biotools:pyOpenMS ;
    schema1:keywords "Mass spectrometry",
        "Metabolomics",
        "Protein modifications",
        "Proteomics",
        "Proteomics experiment" ;
    schema1:license "BSD" ;
    schema1:name "pyopenms-nightly" ;
    schema1:url "https://pypi.org/project/pyopenms-nightly/" .

