@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-genrank a schema1:SoftwareApplication ;
    schema1:citation "doi:10.12688/f1000research.11223.1" ;
    schema1:description "Methods for ranking genes based on convergent evidence obtained from multiple independent evidence layers. this package adapts three methods that are popular for meta-analysis." ;
    schema1:identifier biotools:genrank ;
    schema1:keywords "Genetics" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-genrank" ;
    schema1:url "http://bioconductor.org/packages/release/bioc/html/GenRank.html" .

