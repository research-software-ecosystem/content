@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:maker a schema1:SoftwareApplication ;
    schema1:description "MAKER is a portable and easily configurable genome annotation pipeline." ;
    schema1:downloadUrl "http://weatherby.genetics.utah.edu/maker_downloads/static/maker-3.01.04.tgz" ;
    schema1:identifier biotools:maker ;
    schema1:license "GPL-3.0-or-later" ;
    schema1:name "maker" ;
    schema1:softwareHelp "https://www.yandell-lab.org/software/maker.html" ;
    schema1:softwareVersion "3.01.04" ;
    schema1:url "https://www.yandell-lab.org/software/maker.html" ;
    spdx:builtFrom biotools:maker .

