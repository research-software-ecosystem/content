@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:unifrac a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/s41592-018-0187-8" ;
    schema1:description "Fast phylogenetic diversity calculations" ;
    schema1:keywords "Bacteria",
        "Computational Biology",
        "Computer Simulation",
        "Humans",
        "Metagenome",
        "Microbiota",
        "Models, Statistical",
        "Phylogeny" ;
    schema1:license "BSD-3-Clause" ;
    schema1:name "unifrac" ;
    schema1:url "https://github.com/biocore/unifrac" .

