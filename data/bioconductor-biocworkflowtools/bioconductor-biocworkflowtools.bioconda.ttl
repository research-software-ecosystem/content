@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-biocworkflowtools a schema1:SoftwareApplication ;
    schema1:description "Tools to aid the development of Bioconductor Workflow packages" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/BiocWorkflowTools_1.36.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/BiocWorkflowTools/BiocWorkflowTools_1.36.0.tar.gz', 'https://bioarchive.galaxyproject.org/BiocWorkflowTools_1.36.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-biocworkflowtools/bioconductor-biocworkflowtools_1.36.0_src_all.tar.gz']" ;
    schema1:identifier biotools:BiocWorkflowTools ;
    schema1:license "MIT + file LICENSE" ;
    schema1:name "bioconductor-biocworkflowtools" ;
    schema1:softwareVersion "1.36.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/BiocWorkflowTools.html" ;
    spdx:builtFrom biotools:BiocWorkflowTools .

