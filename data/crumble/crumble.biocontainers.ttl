@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:crumble a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/bty608" ;
    schema1:description "Controllable lossy compression of BAM/CRAM files" ;
    schema1:keywords "Data Compression",
        "High-Throughput Nucleotide Sequencing" ;
    schema1:license "BSD" ;
    schema1:name "crumble" ;
    schema1:url "https://github.com/jkbonfield/crumble" .

