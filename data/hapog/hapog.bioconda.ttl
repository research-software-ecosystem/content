@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:hapog a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nargab/lqab034" ;
    schema1:description "Haplotype-Aware Polishing of Genomes." ;
    schema1:downloadUrl "https://github.com/institut-de-genomique/HAPO-G/archive/refs/tags/1.3.8.tar.gz" ;
    schema1:identifier biotools:hapog ;
    schema1:license "CECILL-2.1" ;
    schema1:name "hapog" ;
    schema1:softwareHelp "https://www.genoscope.cns.fr/hapog" ;
    schema1:softwareVersion "1.3.8" ;
    schema1:url "https://github.com/institut-de-genomique/HAPO-G" ;
    spdx:builtFrom biotools:hapog .

