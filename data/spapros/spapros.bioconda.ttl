@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:spapros a schema1:SoftwareApplication ;
    schema1:author "heylf" ;
    schema1:citation "doi:10.1038/s41592-024-02496-z" ;
    schema1:description "Probe set selection for targeted spatial transcriptomics." ;
    schema1:downloadUrl "https://pypi.org/packages/source/s/spapros/spapros-0.1.6.tar.gz" ;
    schema1:identifier biotools:spapros ;
    schema1:license "MIT" ;
    schema1:maintainer "heylf" ;
    schema1:name "spapros" ;
    schema1:softwareHelp "https://spapros.readthedocs.io/en/latest" ;
    schema1:softwareVersion "0.1.6" ;
    schema1:url "https://github.com/theislab/spapros" ;
    spdx:builtFrom biotools:spapros .

