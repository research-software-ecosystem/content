@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-ellipse a schema1:SoftwareApplication ;
    schema1:description "This package contains various routines for drawing ellipses and ellipse-like confidence regions, implementing the plots described in Murdoch and Chow (1996), A graphical display of large correlation matrices, The American Statistician 50, 178-180. There are also routines implementing the profile plots described in Bates and Watts (1988), Nonlinear Regression Analysis and its Applications." ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "r-ellipse" ;
    schema1:url "None" .

