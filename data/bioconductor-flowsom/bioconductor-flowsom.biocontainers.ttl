@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-flowsom a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1002/cyto.a.22625" ;
    schema1:description "Using self-organizing maps for visualization and interpretation of cytometry data" ;
    schema1:identifier biotools:flowsom ;
    schema1:keywords "Biomarkers",
        "Cell biology",
        "Cluster Analysis",
        "Clustering",
        "Computational Biology",
        "Flow Cytometry",
        "Graft vs Host Disease",
        "Hematopoietic Stem Cell Transplantation",
        "Humans",
        "Lymphoma, B-Cell",
        "West Nile Fever" ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-flowsom" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/FlowSOM.html" .

