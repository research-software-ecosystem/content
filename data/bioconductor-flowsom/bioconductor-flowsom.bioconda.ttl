@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-flowsom a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1002/cyto.a.22625" ;
    schema1:description "Using self-organizing maps for visualization and interpretation of cytometry data" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/FlowSOM_2.14.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/FlowSOM/FlowSOM_2.14.0.tar.gz', 'https://bioarchive.galaxyproject.org/FlowSOM_2.14.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-flowsom/bioconductor-flowsom_2.14.0_src_all.tar.gz']" ;
    schema1:identifier biotools:flowsom ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-flowsom" ;
    schema1:softwareVersion "2.14.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/FlowSOM.html" ;
    spdx:builtFrom biotools:flowsom .

