@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:galaxyxml a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/gkw343",
        "doi:10.1093/nar/gky379" ;
    schema1:description "Galaxy xml generation library" ;
    schema1:keywords "Datasets as Topic",
        "Genomics",
        "Humans",
        "Information Dissemination",
        "International Cooperation",
        "Internet",
        "Metabolomics",
        "Molecular Imaging",
        "Proteomics",
        "Reproducibility of Results",
        "User-Computer Interface" ;
    schema1:license "Not available" ;
    schema1:name "galaxyxml" ;
    schema1:url "https://github.com/hexylena/galaxyxml/" .

