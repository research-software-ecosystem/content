@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-promise a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btp357" ;
    schema1:description "PRojection Onto the Most Interesting Statistical Evidence" ;
    schema1:identifier biotools:promise ;
    schema1:keywords "Biometry",
        "Gene Expression Profiling",
        "Genomics",
        "Oligonucleotide Array Sequence Analysis" ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-promise" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/PROMISE.html" .

