@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-promise a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btp357" ;
    schema1:description "PRojection Onto the Most Interesting Statistical Evidence" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/PROMISE_1.62.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/PROMISE/PROMISE_1.62.0.tar.gz', 'https://bioarchive.galaxyproject.org/PROMISE_1.62.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-promise/bioconductor-promise_1.62.0_src_all.tar.gz']" ;
    schema1:identifier biotools:promise ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-promise" ;
    schema1:softwareVersion "1.62.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/PROMISE.html" ;
    spdx:builtFrom biotools:promise .

