@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-hitc a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/bts521" ;
    schema1:description "This package was developed to explore high-throughput 'c' data such as 5c or hi-c. dedicated r classes as well as standard methods for quality controls, normalization, visualization, and further analysis are also provided." ;
    schema1:identifier biotools:hitc ;
    schema1:keywords "Animals",
        "Chromosome Mapping",
        "Chromosomes, Human, Pair 14",
        "Data Display",
        "Humans",
        "Mice",
        "Molecular Conformation",
        "Nucleic acid structure analysis",
        "Nucleic acids",
        "Restriction Mapping" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-hitc" ;
    schema1:url "http://bioconductor.org/packages/release/bioc/html/HiTC.html" .

