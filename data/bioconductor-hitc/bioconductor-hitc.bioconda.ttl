@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-hitc a schema1:SoftwareApplication ;
    schema1:description "High Throughput Chromosome Conformation Capture analysis" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/HiTC_1.50.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/HiTC/HiTC_1.50.0.tar.gz', 'https://bioarchive.galaxyproject.org/HiTC_1.50.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-hitc/bioconductor-hitc_1.50.0_src_all.tar.gz']" ;
    schema1:identifier biotools:hitc ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-hitc" ;
    schema1:softwareVersion "1.50.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/HiTC.html" ;
    spdx:builtFrom biotools:hitc .

