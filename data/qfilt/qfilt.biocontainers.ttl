@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:qfilt a schema1:SoftwareApplication ;
    schema1:description "Filter sequencing data using some simple heuristics" ;
    schema1:license "MIT" ;
    schema1:name "qfilt" ;
    schema1:url "https://github.com/veg/qfilt" .

