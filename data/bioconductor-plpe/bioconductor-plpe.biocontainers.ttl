@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-plpe a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Local Pooled Error Test for Differential Expression with Paired High-throughput Data" ;
    schema1:identifier biotools:plpe ;
    schema1:keywords "Computational Biology",
        "Data architecture, analysis and design",
        "Gene Expression Profiling",
        "Genomics",
        "High-Throughput Screening Assays",
        "Programming Languages",
        "Proteomics",
        "Sequencing",
        "User-Computer Interface" ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-plpe" ;
    schema1:url "http://bioconductor.org/packages/3.6/bioc/html/PLPE.html" .

