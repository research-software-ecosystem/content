    {
      "@id": "https://bio.tools/bioconductor-sparsenetgls",
      "@type": "sc:SoftwareApplication",
      "dcterms:conformsTo": "https://bioschemas.org/profiles/ComputationalTool/0.6-DRAFT",
      "sc:additionalType": [
        "Command-line tool",
        "Library"
      ],
      "sc:author": "Irene Zeng",
      "sc:citation": {
        "@id": "https://doi.org/10.18129/B9.bioc.sparsenetgls"
      },
      "sc:contributor": "Thomas Lumley",
      "sc:description": "The package provides methods of combining the graph structure learning and generalized least squares regression to improve the regression estimation. The main function sparsenetgls() provides solutions for multivariate regression with Gaussian distributed dependant variables and explanatory variables utlizing multiple well-known graph structure learning approaches to estimating the precision matrix, and uses a penalized variance covariance matrix with a distance tuning parameter of the graph structure in deriving the sandwich estimators in generalized least squares (gls) regression. This package also provides functions for assessing a Gaussian graphical model which uses the penalized approach. It uses Receiver Operative Characteristics curve as a visualization tool in the assessment.",
      "sc:license": "GPL-3.0-only",
      "sc:name": "sparsenetgls",
      "sc:operatingSystem": [
        "Linux",
        "Windows",
        "Mac"
      ],
      "sc:softwareHelp": {
        "@id": "https://bioconductor.org/packages/sparsenetgls"
      },
      "sc:softwareVersion": "1.28.0",
      "sc:url": "https://bioconductor.org/packages/sparsenetgls"
    }
  ]
