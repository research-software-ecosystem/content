@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:dbcan a schema1:SoftwareApplication ;
    schema1:author "Xinpeng021001" ;
    schema1:citation "doi:10.1093/nar/gkad328",
        "doi:10.1093/nar/gkx894",
        "doi:10.1093/nar/gky418" ;
    schema1:description "Standalone version of dbCAN annotation tool for automated CAZyme annotation." ;
    schema1:downloadUrl "https://github.com/bcb-unl/run_dbcan/archive/v5.2.9.tar.gz" ;
    schema1:identifier biotools:dbcan2 ;
    schema1:license "GPL-3.0-only" ;
    schema1:maintainer "Xinpeng021001" ;
    schema1:name "dbcan" ;
    schema1:softwareHelp "https://run-dbcan.readthedocs.io/en/latest" ;
    schema1:softwareVersion "5.2.9" ;
    schema1:url "https://bcb.unl.edu/dbCAN2" ;
    spdx:builtFrom biotools:dbcan2 .

