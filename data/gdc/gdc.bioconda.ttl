@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:gdc a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/srep11565" ;
    schema1:description "Utility designed for compression of genome collections from the same species." ;
    schema1:downloadUrl "http://sun.aei.polsl.pl/REFRESH/gdc/downloads/2.0/gdc2.tar.gz" ;
    schema1:identifier biotools:GDC ;
    schema1:license "GPL2" ;
    schema1:name "gdc" ;
    schema1:softwareVersion "2.0" ;
    schema1:url "http://sun.aei.polsl.pl/REFRESH/index.php?page=projects&project=gdc&subpage=about" ;
    spdx:builtFrom biotools:GDC .

