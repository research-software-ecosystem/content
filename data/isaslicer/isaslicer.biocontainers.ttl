@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:isaslicer a schema1:SoftwareApplication ;
    schema1:description "A container using the ISA-API for slice querying ISA-Tab metadata." ;
    schema1:keywords "Genetics",
        "Metabolomics" ;
    schema1:license "Apache-2.0" ;
    schema1:name "isaslicer" ;
    schema1:url "https://github.com/phnmnl/container-isaslicer" .

