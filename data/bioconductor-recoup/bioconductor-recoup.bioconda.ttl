@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-recoup a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "An R package for the creation of complex genomic profile plots" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/recoup_1.34.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/recoup/recoup_1.34.0.tar.gz', 'https://bioarchive.galaxyproject.org/recoup_1.34.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-recoup/bioconductor-recoup_1.34.0_src_all.tar.gz']" ;
    schema1:identifier biotools:recoup ;
    schema1:license "GPL (>= 3)" ;
    schema1:name "bioconductor-recoup" ;
    schema1:softwareVersion "1.34.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/recoup.html" ;
    spdx:builtFrom biotools:recoup .

