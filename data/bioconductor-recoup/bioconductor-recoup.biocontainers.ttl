@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-recoup a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "An R package for the creation of complex genomic profile plots" ;
    schema1:identifier biotools:recoup ;
    schema1:keywords "Computational Biology",
        "Gene Expression Profiling",
        "Genomics",
        "High-Throughput Screening Assays",
        "Programming Languages",
        "RNA-Seq",
        "User-Computer Interface" ;
    schema1:license "GPL-3.0" ;
    schema1:name "bioconductor-recoup" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/recoup.html" .

