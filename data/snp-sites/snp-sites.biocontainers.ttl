@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:snp-sites a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1099/mgen.0.000056" ;
    schema1:description "Binary code for the package snp-sites" ;
    schema1:keywords "Base Sequence",
        "Genome",
        "Genomics",
        "High-Throughput Nucleotide Sequencing",
        "Polymorphism, Single Nucleotide",
        "Sequence Alignment",
        "Sequence Analysis, DNA" ;
    schema1:license "GPL-3.0+" ;
    schema1:name "snp-sites" ;
    schema1:url "https://github.com/sanger-pathogens/snp-sites" .

