@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:pypiper a schema1:SoftwareApplication ;
    schema1:description "Pypiper is a lightweight python toolkit that helps you write slick pipelines in python." ;
    schema1:license "BSD 2-Clause \"Simplified\" License" ;
    schema1:name "pypiper" ;
    schema1:url "https://github.com/databio/pypiper/" .

