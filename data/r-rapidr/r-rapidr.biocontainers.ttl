@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-rapidr a schema1:SoftwareApplication ;
    schema1:description "Package to perform non-invasive fetal testing for aneuploidies using sequencing count data from cell-free DNA" ;
    schema1:license "GPL-3" ;
    schema1:name "r-rapidr" ;
    schema1:url "https://CRAN.R-project.org/package=RAPIDR" .

