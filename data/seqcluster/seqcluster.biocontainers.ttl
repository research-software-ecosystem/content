@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:seqcluster a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btr527",
        "doi:10.1093/bioinformatics/btv632" ;
    schema1:description "Analysis of small rna sequencing data. it detect unit of transcription over the genome, annotate them and create an html interactive report that helps to explore the data quickly." ;
    schema1:identifier biotools:seqcluster ;
    schema1:keywords "Animals",
        "Clustering",
        "Genomics",
        "Humans",
        "Mice",
        "MicroRNAs",
        "Molecular Sequence Annotation",
        "RNA, Small Untranslated",
        "RNA-Seq",
        "Sequence Analysis, RNA",
        "Transcriptome",
        "Transcriptomics" ;
    schema1:license "MIT" ;
    schema1:name "seqcluster" ;
    schema1:url "https://github.com/lpantano/seqcluster" .

