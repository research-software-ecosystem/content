@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:seqcluster a schema1:SoftwareApplication ;
    schema1:description "small RNA analysis from NGS data" ;
    schema1:downloadUrl "https://github.com/lpantano/seqcluster/archive/v1.2.9.tar.gz" ;
    schema1:identifier biotools:seqcluster ;
    schema1:license "MIT" ;
    schema1:name "seqcluster" ;
    schema1:softwareVersion "1.2.9" ;
    schema1:url "https://github.com/lpantano/seqclsuter" ;
    spdx:builtFrom biotools:seqcluster .

