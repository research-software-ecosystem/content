@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:python-corepywrap a schema1:SoftwareApplication ;
    schema1:description "The RCSB Core Wrapper library was developed to provide an object-oriented application interface to information in mmCIF format. It includes several classes for accessing data dictionaries and mmCIF format data files." ;
    schema1:license "MIT" ;
    schema1:name "python-corepywrap" ;
    schema1:url "https://sw-tools.rcsb.org/apps/CORE-WRAPPER/index.html" .

