@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-birte a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btv379" ;
    schema1:description "Expression levels of mRNA molecules are regulated by different processes, comprising inhibition or activation by transcription factors and post-transcriptional degradation by microRNAs. biRte uses regulatory networks of TFs, miRNAs and possibly other factors, together with mRNA, miRNA and other available expression data to predict the relative influence of a regulator on the expression of its target genes. Inference is done in a Bayesian modeling framework using Markov-Chain-Monte-Carlo. A special feature is the possibility for follow-up network reverse engineering between active regulators." ;
    schema1:keywords "Bayes Theorem",
        "Computer Simulation",
        "Escherichia coli",
        "Gene Expression",
        "Gene Expression Profiling",
        "Gene Regulatory Networks",
        "Humans",
        "Male",
        "MicroRNAs",
        "Prostatic Neoplasms",
        "RNA, Messenger",
        "Transcription Factors" ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-birte" ;
    schema1:url "https://www.bioconductor.org/packages/release/bioc/html/birte.html" .

