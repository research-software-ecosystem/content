@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:perl-image-exiftool a schema1:SoftwareApplication ;
    schema1:description "Exiftool is a platform-independent perl library plus a command-line application for reading, writing and editing meta information in a wide variety of files." ;
    schema1:license "perl_5" ;
    schema1:name "perl-image-exiftool" ;
    schema1:url "http://metacpan.org/pod/Image::ExifTool" .

