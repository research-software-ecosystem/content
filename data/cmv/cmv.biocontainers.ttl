@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:cmv a schema1:SoftwareApplication ;
    schema1:description "A collection of tools for the visualisation of Hidden Markov Models (HMMV) and RNA-family models (CMV)." ;
    schema1:license "GPL-3" ;
    schema1:name "cmv" ;
    schema1:url "https://github.com/eggzilla/cmv" .

