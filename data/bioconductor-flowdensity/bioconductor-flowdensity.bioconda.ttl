@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-flowdensity a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btu677" ;
    schema1:description "Sequential Flow Cytometry Data Gating" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/flowDensity_1.44.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/flowDensity/flowDensity_1.44.0.tar.gz', 'https://bioarchive.galaxyproject.org/flowDensity_1.44.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-flowdensity/bioconductor-flowdensity_1.44.0_src_all.tar.gz']" ;
    schema1:identifier biotools:flowdensity ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-flowdensity" ;
    schema1:softwareVersion "1.44.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/flowDensity.html" ;
    spdx:builtFrom biotools:flowdensity .

