@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-flowdensity a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btu677" ;
    schema1:description "This package provides tools for automated sequential gating analogous to the manual gating strategy based on the density of the data." ;
    schema1:identifier biotools:flowdensity ;
    schema1:keywords "Biomarkers",
        "Cell Physiological Phenomena",
        "Cell biology",
        "Cluster Analysis",
        "Clustering",
        "Computational Biology",
        "Databases, Factual",
        "Flow Cytometry",
        "Humans" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-flowdensity" ;
    schema1:url "http://bioconductor.org/packages/release/bioc/html/flowDensity.html" .

