@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-iaseq a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/1471-2164-13-681" ;
    schema1:description "iASeq: integrating multiple sequencing datasets for detecting allele-specific events" ;
    schema1:identifier biotools:iaseq ;
    schema1:keywords "Alleles",
        "Base Sequence",
        "Bayes Theorem",
        "ChIP-seq",
        "Chromatin Immunoprecipitation",
        "DNA",
        "DNA-Binding Proteins",
        "Data Interpretation, Statistical",
        "Data Mining",
        "High-Throughput Nucleotide Sequencing",
        "Histones",
        "Models, Theoretical",
        "Oligonucleotide Array Sequence Analysis",
        "Polymorphism, Single Nucleotide",
        "RNA-Seq",
        "Sequence Analysis, DNA",
        "Transcription Factors" ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-iaseq" ;
    schema1:url "http://bioconductor.org/packages/3.6/bioc/html/iASeq.html" .

