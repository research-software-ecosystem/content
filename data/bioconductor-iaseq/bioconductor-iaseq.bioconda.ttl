@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-iaseq a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/1471-2164-13-681" ;
    schema1:description "iASeq: integrating multiple sequencing datasets for detecting allele-specific events" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/iASeq_1.50.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/iASeq/iASeq_1.50.0.tar.gz', 'https://bioarchive.galaxyproject.org/iASeq_1.50.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-iaseq/bioconductor-iaseq_1.50.0_src_all.tar.gz']" ;
    schema1:identifier biotools:iaseq ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-iaseq" ;
    schema1:softwareVersion "1.50.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/iASeq.html" ;
    spdx:builtFrom biotools:iaseq .

