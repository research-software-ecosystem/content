@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:pyrad a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btu121" ;
    schema1:description "Assembly and analysis of radseq data sets" ;
    schema1:identifier biotools:pyrad ;
    schema1:keywords "Cluster Analysis",
        "Genetic Loci",
        "High-Throughput Nucleotide Sequencing",
        "Phylogenetics",
        "Phylogeny",
        "Sequence Analysis, DNA",
        "Sequence analysis",
        "Sequence assembly" ;
    schema1:license "GNU General Public License v3.0" ;
    schema1:name "pyrad" ;
    schema1:url "https://github.com/dereneaton/pyrad" .

