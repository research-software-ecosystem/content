@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:drop a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/gki361",
        "doi:10.1128/JB.186.16.5473-5479.2004" ;
    schema1:description "Detection of rna outlier pipeline" ;
    schema1:identifier biotools:brop ;
    schema1:keywords "Bacterial Capsules",
        "Bacterial Proteins",
        "Biological Evolution",
        "DNA Transposable Elements",
        "Gene Transfer, Horizontal",
        "Gene expression",
        "Genes, Bacterial",
        "Genetic Variation",
        "Genome, Bacterial",
        "Genomic Islands",
        "Integrases",
        "Microarray experiment",
        "Oligonucleotide Array Sequence Analysis",
        "Operon",
        "Pathology",
        "Polysaccharides, Bacterial",
        "Porphyromonas gingivalis",
        "RNA, Transfer",
        "RNA-Seq",
        "Virulence",
        "Virulence Factors" ;
    schema1:license "Not available" ;
    schema1:name "drop" ;
    schema1:url "https://github.com/gagneurlab/drop" .

