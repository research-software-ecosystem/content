@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-hilda a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18129/b9.bioc.hilda" ;
    schema1:description "Conducting statistical inference on comparing the mutational exposures of mutational signatures by using hierarchical latent Dirichlet allocation" ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-hilda" ;
    schema1:url "https://bioconductor.org/packages/3.10/bioc/html/HiLDA.html" .

