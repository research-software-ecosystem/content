@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-heatmaps a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18129/b9.bioc.heatmaps" ;
    schema1:description "Flexible heatmaps for functional genomics and sequence features" ;
    schema1:keywords "Functional genomics",
        "Genomics" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-heatmaps" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/heatmaps.html" .

