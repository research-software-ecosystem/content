@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-seqlogo a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Sequence logos for DNA sequence alignments" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/seqLogo_1.72.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/seqLogo/seqLogo_1.72.0.tar.gz', 'https://bioarchive.galaxyproject.org/seqLogo_1.72.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-seqlogo/bioconductor-seqlogo_1.72.0_src_all.tar.gz']" ;
    schema1:identifier biotools:seqlogo ;
    schema1:license "LGPL (>= 2)" ;
    schema1:name "bioconductor-seqlogo" ;
    schema1:softwareVersion "1.72.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/seqLogo.html" ;
    spdx:builtFrom biotools:seqlogo .

