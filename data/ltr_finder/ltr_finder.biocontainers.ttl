@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:ltr_finder a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/gkm286" ;
    schema1:description "LTR_Finder is an efficient program for finding full-length LTR retrotranspsons in genome sequences." ;
    schema1:identifier biotools:ltr_finder ;
    schema1:keywords "Base Sequence",
        "Computational Biology",
        "Database Management Systems",
        "Databases, Nucleic Acid",
        "Genomics",
        "Information Storage and Retrieval",
        "Internet",
        "Molecular Sequence Data",
        "Retroelements",
        "Saccharomyces cerevisiae",
        "Sequence Alignment",
        "Sequence Analysis, DNA",
        "Sequence composition, complexity and repeats",
        "Sequencing",
        "Terminal Repeat Sequences",
        "Transcription factors and regulatory sites",
        "Whole genome sequencing" ;
    schema1:license "MIT" ;
    schema1:name "ltr_finder" ;
    schema1:url "https://github.com/NBISweden/LTR_Finder/" .

