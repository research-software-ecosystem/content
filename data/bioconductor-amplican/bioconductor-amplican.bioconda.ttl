@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-amplican a schema1:SoftwareApplication ;
    schema1:description "Automated analysis of CRISPR experiments" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/amplican_1.32.1.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/amplican/amplican_1.32.1.tar.gz', 'https://bioarchive.galaxyproject.org/amplican_1.32.1.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-amplican/bioconductor-amplican_1.32.1_src_all.tar.gz']" ;
    schema1:identifier biotools:amplican ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-amplican" ;
    schema1:softwareVersion "1.32.1" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/amplican.html" ;
    spdx:builtFrom biotools:amplican .

