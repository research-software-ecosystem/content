@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:libsequence a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btg316" ;
    schema1:description "A C++ class library for evolutionary genetics." ;
    schema1:keywords "Evolution, Molecular",
        "Gene Expression Profiling",
        "Genetic Variation",
        "Polymorphism, Genetic",
        "Polymorphism, Single Nucleotide",
        "Programming Languages",
        "Sequence Alignment",
        "Sequence Analysis, DNA" ;
    schema1:license "GNU Lesser General Public License v3 or later (LGPLv3+)" ;
    schema1:name "libsequence" ;
    schema1:url "http://http://molpopgen.github.io/libsequence/" .

