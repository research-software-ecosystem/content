@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:treemix a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1371/journal.pgen.1002967" ;
    schema1:description "TreeMix is a method for inferring the patterns of population splits and mixtures in the history of a set of populations." ;
    schema1:downloadUrl "https://bitbucket.org/nygcresearch/treemix/downloads/treemix-1.13.tar.gz" ;
    schema1:identifier biotools:TreeMix ;
    schema1:license "GPLv3" ;
    schema1:name "treemix" ;
    schema1:softwareVersion "1.13" ;
    schema1:url "http://pritchardlab.stanford.edu/software.html" ;
    spdx:builtFrom biotools:TreeMix .

