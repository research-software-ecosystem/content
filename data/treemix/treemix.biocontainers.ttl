@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:treemix a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1371/journal.pgen.1002967" ;
    schema1:description "Treemix is a method for inferring the patterns of  population splits and mixtures in the history of a set of populations" ;
    schema1:identifier biotools:TreeMix ;
    schema1:keywords "Animals",
        "Breeding",
        "Dogs",
        "Gene Frequency",
        "Genetic Drift",
        "Genome-Wide Association Study",
        "Humans",
        "Models, Genetic",
        "Polymorphism, Single Nucleotide",
        "Population",
        "Population genetics",
        "Wolves" ;
    schema1:license "GPL-3.0" ;
    schema1:name "treemix" ;
    schema1:url "https://bitbucket.org/nygcresearch/treemix/src" .

