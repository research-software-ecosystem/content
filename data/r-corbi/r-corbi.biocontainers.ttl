@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-corbi a schema1:SoftwareApplication ;
    schema1:description "Provides a bundle of basic and fundamental bioinformatics tools, such as network querying and alignment, subnetwork extraction and search, network biomarker identification." ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "r-corbi" ;
    schema1:url "https://github.com/wulingyun/Corbi" .

