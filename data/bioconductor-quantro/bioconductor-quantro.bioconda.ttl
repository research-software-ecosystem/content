@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-quantro a schema1:SoftwareApplication ;
    schema1:description "A test for when to use quantile normalization" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/quantro_1.40.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/quantro/quantro_1.40.0.tar.gz', 'https://bioarchive.galaxyproject.org/quantro_1.40.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-quantro/bioconductor-quantro_1.40.0_src_all.tar.gz']" ;
    schema1:identifier biotools:quantro ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-quantro" ;
    schema1:softwareVersion "1.40.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/quantro.html" ;
    spdx:builtFrom biotools:quantro .

