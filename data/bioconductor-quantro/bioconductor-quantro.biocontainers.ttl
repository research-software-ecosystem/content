@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-quantro a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s13059-015-0679-0" ;
    schema1:description "A test for when to use quantile normalization" ;
    schema1:identifier biotools:quantro ;
    schema1:keywords "CpG Islands",
        "DNA Methylation",
        "Gene Expression Profiling",
        "High-Throughput Nucleotide Sequencing",
        "Humans",
        "Male",
        "Normal Distribution",
        "Oligonucleotide Array Sequence Analysis",
        "Sequence analysis" ;
    schema1:license "GPL (>=3)" ;
    schema1:name "bioconductor-quantro" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/quantro.html" .

