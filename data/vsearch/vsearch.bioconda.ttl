@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:vsearch a schema1:SoftwareApplication ;
    schema1:citation "doi:10.7717/peerj.2584" ;
    schema1:description "A versatile open source tool for metagenomics (USEARCH alternative)." ;
    schema1:downloadUrl "https://github.com/torognes/vsearch/archive/v2.31.0.tar.gz" ;
    schema1:identifier biotools:vsearch ;
    schema1:license "GPL-3.0-or-later OR BSD-2-Clause" ;
    schema1:name "vsearch" ;
    schema1:softwareHelp "https://torognes.github.io/vsearch" ;
    schema1:softwareVersion "2.31.0" ;
    schema1:url "https://github.com/torognes/vsearch" ;
    spdx:builtFrom biotools:vsearch .

