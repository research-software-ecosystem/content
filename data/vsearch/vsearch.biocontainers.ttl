@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:vsearch a schema1:SoftwareApplication ;
    schema1:citation "doi:10.7717/peerj.2584" ;
    schema1:description "High-throughput search and clustering sequence analysis tool. it supports de novo and reference based chimera detection, clustering, full-length and prefix dereplication, reverse complementation, masking, all-vs-all pairwise global alignment, exact and global alignment searching, shuffling, subsampling and sorting. it also supports fastq file analysis, filtering and conversion." ;
    schema1:identifier biotools:vsearch ;
    schema1:keywords "Clustering",
        "Genomics",
        "Metagenomics",
        "Sequence Alignment",
        "Sequence analysis" ;
    schema1:license "GPL-3.0" ;
    schema1:name "vsearch" ;
    schema1:url "https://github.com/torognes/vsearch" .

