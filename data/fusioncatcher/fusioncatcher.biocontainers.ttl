@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:fusioncatcher a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1101/011650" ;
    schema1:description "Finder of Somatic Fusion Genes in RNA-seq data." ;
    schema1:identifier biotools:fusioncatcher ;
    schema1:keywords "Gene structure",
        "RNA-Seq" ;
    schema1:license "GPL-3.0" ;
    schema1:name "fusioncatcher" ;
    schema1:url "https://github.com/ndaniel/fusioncatcher" .

