@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:fusioncatcher a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1101/011650" ;
    schema1:description "Finder of Somatic Fusion Genes in RNA-seq data." ;
    schema1:downloadUrl "https://github.com/bioinformaticsorphanage/fusioncatcher/archive/refs/tags/1.33b.tar.gz" ;
    schema1:identifier biotools:fusioncatcher ;
    schema1:license "GPL-3.0-or-later" ;
    schema1:name "fusioncatcher" ;
    schema1:softwareVersion "1.33b" ;
    schema1:url "https://github.com/bioinformaticsorphanage/fusioncatcher" ;
    spdx:builtFrom biotools:fusioncatcher .

