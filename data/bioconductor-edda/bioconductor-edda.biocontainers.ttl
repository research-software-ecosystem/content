@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-edda a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s13059-014-0527-7" ;
    schema1:description "Experimental Design in Differential Abundance analysis" ;
    schema1:identifier biotools:edda ;
    schema1:keywords "Computational Biology",
        "Gene Expression Profiling",
        "Genomics",
        "High-Throughput Nucleotide Sequencing",
        "Humans",
        "K562 Cells",
        "Metagenomics",
        "RNA-Seq",
        "Sequence Analysis, RNA",
        "Single-Cell Analysis" ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-edda" ;
    schema1:url "http://bioconductor.org/packages/3.6/bioc/html/EDDA.html" .

