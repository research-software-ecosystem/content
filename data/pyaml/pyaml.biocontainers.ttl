@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:pyaml a schema1:SoftwareApplication ;
    schema1:description "Pyyaml-based module to produce pretty and readable yaml-serialized data." ;
    schema1:license "WTFPL" ;
    schema1:name "pyaml" ;
    schema1:url "https://pypi.python.org/packages/source/p/pyaml/pyaml-15.8.2.tar.gz" .

