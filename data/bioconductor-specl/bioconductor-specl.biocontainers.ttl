@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-specl a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btv105" ;
    schema1:description "specL - Prepare Peptide Spectrum Matches for Use in Targeted Proteomics" ;
    schema1:identifier biotools:specl ;
    schema1:keywords "Functional genomics",
        "Genomics",
        "Humans",
        "Mass Spectrometry",
        "Peptide Fragments",
        "Proteins",
        "Proteomics",
        "Proteomics experiment" ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-specl" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/specL.html" .

