@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-specl a schema1:SoftwareApplication ;
    schema1:description "specL - Prepare Peptide Spectrum Matches for Use in Targeted Proteomics" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/specL_1.44.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/specL/specL_1.44.0.tar.gz', 'https://bioarchive.galaxyproject.org/specL_1.44.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-specl/bioconductor-specl_1.44.0_src_all.tar.gz']" ;
    schema1:identifier biotools:specl ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-specl" ;
    schema1:softwareVersion "1.44.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/specL.html" ;
    spdx:builtFrom biotools:specl .

