@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-cghmcr a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btv298" ;
    schema1:description "Find chromosome regions showing common gains/losses" ;
    schema1:identifier biotools:cghmcr ;
    schema1:keywords "DNA Copy Number Variations",
        "Data Interpretation, Statistical",
        "Databases, Genetic",
        "Genome, Human",
        "Genomics",
        "Humans",
        "Neoplasms",
        "Nucleic acid sites, features and motifs",
        "Oligonucleotide Array Sequence Analysis",
        "Polymorphism, Single Nucleotide",
        "Sequence analysis" ;
    schema1:license "LGPL" ;
    schema1:name "bioconductor-cghmcr" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/cghMCR.html" .

