@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-cghmcr a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btv298" ;
    schema1:description "Find chromosome regions showing common gains/losses" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/cghMCR_1.68.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/cghMCR/cghMCR_1.68.0.tar.gz', 'https://bioarchive.galaxyproject.org/cghMCR_1.68.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-cghmcr/bioconductor-cghmcr_1.68.0_src_all.tar.gz']" ;
    schema1:identifier biotools:cghmcr ;
    schema1:license "LGPL" ;
    schema1:name "bioconductor-cghmcr" ;
    schema1:softwareVersion "1.68.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/cghMCR.html" ;
    spdx:builtFrom biotools:cghmcr .

