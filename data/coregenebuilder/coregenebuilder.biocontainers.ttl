@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:coregenebuilder a schema1:SoftwareApplication ;
    schema1:description "Coregenebuilder can be used to extract a core genome (or a persistent genome) from a given set of bacterial genomes." ;
    schema1:keywords "Genomics" ;
    schema1:license "GPL-3.0-only" ;
    schema1:name "coregenebuilder" ;
    schema1:url "https://github.com/C3BI-pasteur-fr/CoreGeneBuilder" .

