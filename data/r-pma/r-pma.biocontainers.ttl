        "Gene Dosage",
        "Genomics",
        "Humans",
        "Models, Statistical",
        "Principal Component Analysis" ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "r-pma" ;
    schema1:url "https://CRAN.R-project.org/package=PMA" .

