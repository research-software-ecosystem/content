@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:stacks a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1111/mec.12354" ;
    schema1:description "Stacks is a software pipeline for building loci from short-read sequences." ;
    schema1:downloadUrl "https://catchenlab.life.illinois.edu/stacks/source/stacks-2.68.tar.gz" ;
    schema1:identifier biotools:stacks ;
    schema1:license "GPL-3.0-or-later" ;
    schema1:name "stacks" ;
    schema1:softwareHelp "https://catchenlab.life.illinois.edu/stacks" ;
    schema1:softwareVersion "2.68" ;
    schema1:url "https://catchenlab.life.illinois.edu/stacks" ;
    spdx:builtFrom biotools:stacks .

