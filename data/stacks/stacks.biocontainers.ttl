@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:stacks a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1111/mec.12354" ;
    schema1:description "Developed to work with restriction enzyme based sequence data, such as radseq, for building genetic maps and conducting population genomics and phylogeography analysis." ;
    schema1:identifier biotools:Stacks ;
    schema1:keywords "Databases, Nucleic Acid",
        "Electronic Data Processing",
        "Genetic Markers",
        "Genetics",
        "Genomics",
        "Genotype",
        "High-Throughput Nucleotide Sequencing",
        "Mapping",
        "Metagenomics",
        "Phylogenetics",
        "Polymorphism, Single Nucleotide",
        "Population genetics",
        "RNA-Seq",
        "Sequence Analysis, DNA" ;
    schema1:license "GPL-3.0" ;
    schema1:name "stacks" ;
    schema1:url "http://catchenlab.life.illinois.edu/stacks/" .

