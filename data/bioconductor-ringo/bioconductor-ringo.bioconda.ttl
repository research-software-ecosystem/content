@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-ringo a schema1:SoftwareApplication ;
    schema1:description "R Investigation of ChIP-chip Oligoarrays" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.18/bioc/src/contrib/Ringo_1.66.0.tar.gz', 'https://bioconductor.org/packages/3.18/bioc/src/contrib/Archive/Ringo/Ringo_1.66.0.tar.gz', 'https://bioarchive.galaxyproject.org/Ringo_1.66.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-ringo/bioconductor-ringo_1.66.0_src_all.tar.gz']" ;
    schema1:identifier biotools:ringo ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-ringo" ;
    schema1:softwareVersion "1.66.0" ;
    schema1:url "https://bioconductor.org/packages/3.18/bioc/html/Ringo.html" ;
    spdx:builtFrom biotools:ringo .

