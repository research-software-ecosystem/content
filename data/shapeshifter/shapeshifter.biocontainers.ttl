@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:shapeshifter a schema1:SoftwareApplication ;
    schema1:description "A tool for managing large datasets" ;
    schema1:keywords "Gene Expression",
        "Genomics",
        "RNA-Seq" ;
