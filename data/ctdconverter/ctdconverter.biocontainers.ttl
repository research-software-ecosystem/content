@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:ctdconverter a schema1:SoftwareApplication ;
    schema1:description "Convert ctd files into galaxy tool and cwl commandlinetool files" ;
    schema1:license "custom, see /usr/share/doc/ctdconverter/copyright" ;
    schema1:name "ctdconverter" ;
    schema1:url "https://github.com/WorkflowConversion/CTDConverter" .

