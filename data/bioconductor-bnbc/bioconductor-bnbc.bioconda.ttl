@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-bnbc a schema1:SoftwareApplication ;
    schema1:description "Bandwise normalization and batch correction of Hi-C data" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/bnbc_1.28.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/bnbc/bnbc_1.28.0.tar.gz', 'https://bioarchive.galaxyproject.org/bnbc_1.28.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-bnbc/bioconductor-bnbc_1.28.0_src_all.tar.gz']" ;
    schema1:identifier biotools:bnbc ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-bnbc" ;
    schema1:softwareVersion "1.28.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/bnbc.html" ;
    spdx:builtFrom biotools:bnbc .

