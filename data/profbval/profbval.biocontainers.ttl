@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:profbval a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btl032" ;
    schema1:description "Predictor of flexible/rigid protein residues from sequence" ;
    schema1:keywords "Protein Structure",
        "Sequence Alignment" ;
    schema1:license "GPL-3.0+" ;
    schema1:name "profbval" ;
    schema1:url "https://www.rostlab.org/owiki/index.php/PROFbval" .

