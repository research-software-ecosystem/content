@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:nemo a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btl415" ;
    schema1:description "Individual-based forward-time genetics simulation software" ;
    schema1:keywords "Genetic variation",
        "Genetics",
        "Genomics" ;
    schema1:license "GPL-2.0" ;
    schema1:name "nemo" ;
    schema1:url "http://nemo2.sourceforge.net" .

