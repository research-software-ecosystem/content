@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:fido a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1021/pr100594k" ;
    schema1:description "A method for protein identification in MS/MS proteomics. Think of it like a protein delivery dog. You bring it the scored matches between peptides and spectra, and it fetches a list of proteins ranked by posterior probability by doing clever tricks." ;
    schema1:keywords "Animals",
        "Bacterial Proteins",
        "Bayes Theorem",
        "Caenorhabditis elegans",
        "Caenorhabditis elegans Proteins",
        "Haemophilus influenzae",
        "Mass Spectrometry",
        "Peptides",
        "Probability",
        "Proteins",
        "Proteomics",
        "Reproducibility of Results",
        "Saccharomyces cerevisiae",
        "Saccharomyces cerevisiae Proteins" ;
    schema1:license "MIT" ;
    schema1:name "fido" ;
    schema1:url "https://noble.gs.washington.edu/proj/fido/" .

