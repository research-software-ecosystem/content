@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-fastmatch a schema1:SoftwareApplication ;
    schema1:description "Package providing a fast match() replacement for cases that require repeated look-ups. It is slightly faster that Rs built-in match() function on first match against a table, but extremely fast on any subsequent lookup as it keeps the hash table in memory." ;
    schema1:license "GPL-2.0" ;
    schema1:name "r-fastmatch" ;
    schema1:url "https://cran.r-project.org/package=fastmatch" .

