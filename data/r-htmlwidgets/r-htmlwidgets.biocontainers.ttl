@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-htmlwidgets a schema1:SoftwareApplication ;
    schema1:description "The htmlwidgets package provides a framework for easily creating R bindings to JavaScript libraries." ;
    schema1:license "Custom" ;
    schema1:name "r-htmlwidgets" ;
    schema1:url "https://github.com/ramnathv/htmlwidgets" .

