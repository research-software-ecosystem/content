@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-biosigner a schema1:SoftwareApplication ;
    schema1:citation "doi:10.3389/fmolb.2016.00026" ;
    schema1:description "This package implements a new method to assess the relevance of the variables for the prediction performances of the classifier. the approach can be run in parallel with the pls-da, random forest, and svm binary classifiers. the signatures and the corresponding 'restricted' models are returned, enabling future predictions on new datasets." ;
    schema1:identifier biotools:biosigner ;
    schema1:keywords "Gene and protein families",
        "Genomics",
        "Metabolomics",
        "Proteomics",
        "Transcriptomics" ;
    schema1:license "CECILL-2.1" ;
    schema1:name "bioconductor-biosigner" ;
    schema1:url "http://bioconductor.org/packages/release/bioc/html/biosigner.html" .

