@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-biosigner a schema1:SoftwareApplication ;
    schema1:citation "doi:10.3389/fmolb.2016.00026" ;
    schema1:description "Signature discovery from omics data" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/biosigner_1.38.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/biosigner/biosigner_1.38.0.tar.gz', 'https://bioarchive.galaxyproject.org/biosigner_1.38.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-biosigner/bioconductor-biosigner_1.38.0_src_all.tar.gz']" ;
    schema1:identifier biotools:biosigner ;
    schema1:license "CeCILL" ;
    schema1:name "bioconductor-biosigner" ;
    schema1:softwareVersion "1.38.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/biosigner.html" ;
    spdx:builtFrom biotools:biosigner .

