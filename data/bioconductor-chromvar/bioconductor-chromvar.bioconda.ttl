bioconda:bioconductor-chromvar a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.4401" ;
    schema1:description "Chromatin Variation Across Regions." ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.21/bioc/src/contrib/chromVAR_1.30.1.tar.gz', 'https://bioconductor.org/packages/3.21/bioc/src/contrib/Archive/chromVAR/chromVAR_1.30.1.tar.gz', 'https://bioarchive.galaxyproject.org/chromVAR_1.30.1.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-chromvar/bioconductor-chromvar_1.30.1_src_all.tar.gz']" ;
    schema1:identifier biotools:chromvar ;
    schema1:license "MIT" ;
    schema1:name "bioconductor-chromvar" ;
    schema1:softwareHelp "https://bioconductor.org/packages/3.21/bioc/html/chromVAR.html" ;
    schema1:softwareVersion "1.30.1" ;
    schema1:url "https://bioconductor.org/packages/3.21/bioc/html/chromVAR.html" ;
    spdx:builtFrom biotools:chromvar .

