@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-chromvar a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.4401" ;
    schema1:description "Chromatin Variation Across Regions" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/chromVAR_1.32.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/chromVAR/chromVAR_1.32.0.tar.gz', 'https://bioarchive.galaxyproject.org/chromVAR_1.32.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-chromvar/bioconductor-chromvar_1.32.0_src_all.tar.gz']" ;
    schema1:identifier biotools:chromvar ;
    schema1:license "MIT + file LICENSE" ;
    schema1:name "bioconductor-chromvar" ;
    schema1:softwareVersion "1.32.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/chromVAR.html" ;
    spdx:builtFrom biotools:chromvar .

