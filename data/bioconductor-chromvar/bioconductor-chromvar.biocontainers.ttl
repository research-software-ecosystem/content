@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-chromvar a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/NMETH.4401" ;
    schema1:description "Chromatin Variation Across Regions" ;
    schema1:identifier biotools:chromvar ;
    schema1:keywords "Animals",
        "Cell Line",
        "Epigenomics",
        "Gene Expression Regulation",
        "Nucleic acid structure analysis",
        "Sequence Analysis, DNA",
        "Transcription Factors",
        "Transcription factors and regulatory sites" ;
    schema1:license "MIT" ;
    schema1:name "bioconductor-chromvar" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/chromVAR.html" .

