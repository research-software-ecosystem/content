@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-mirintegrator a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/srep29251" ;
    schema1:description "Integrating microRNA expression into signaling pathways for pathway analysis" ;
    schema1:identifier biotools:mirintegrator ;
    schema1:keywords "Datasets as Topic",
        "Functional, regulatory and non-coding RNA",
        "Gene Regulatory Networks",
        "Gene transcripts",
        "Humans",
        "MicroRNAs",
        "RNA",
        "RNA, Messenger" ;
    schema1:license "GPL (>=3)" ;
    schema1:name "bioconductor-mirintegrator" ;
    schema1:url "http://bioconductor.org/packages/3.6/bioc/html/mirIntegrator.html" .

