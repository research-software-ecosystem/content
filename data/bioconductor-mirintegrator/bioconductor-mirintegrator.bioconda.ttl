@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-mirintegrator a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/srep29251" ;
    schema1:description "Integrating microRNA expression into signaling pathways for pathway analysis" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/mirIntegrator_1.36.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/mirIntegrator/mirIntegrator_1.36.0.tar.gz', 'https://bioarchive.galaxyproject.org/mirIntegrator_1.36.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-mirintegrator/bioconductor-mirintegrator_1.36.0_src_all.tar.gz']" ;
    schema1:identifier biotools:mirintegrator ;
    schema1:license "GPL (>=3)" ;
    schema1:name "bioconductor-mirintegrator" ;
    schema1:softwareVersion "1.36.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/mirIntegrator.html" ;
    spdx:builtFrom biotools:mirintegrator .

