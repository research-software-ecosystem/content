@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-inspect a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btv288" ;
    schema1:description "Modeling RNA synthesis, processing and degradation with RNA-seq data" ;
    schema1:identifier biotools:inspect ;
    schema1:keywords "Animals",
        "Cells, Cultured",
        "Gene Expression Regulation",
        "High-Throughput Nucleotide Sequencing",
        "Mice",
        "Nucleic acid sites, features and motifs",
        "RNA",
        "RNA Precursors",
        "RNA Stability",
        "RNA, Messenger",
        "RNA-Seq",
        "Sequence Analysis, RNA",
        "Transcription, Genetic" ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-inspect" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/INSPEcT.html" .

