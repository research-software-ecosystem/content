@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-inspect a schema1:SoftwareApplication ;
    schema1:description "Modeling RNA synthesis, processing and degradation with RNA-seq data" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/INSPEcT_1.36.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/INSPEcT/INSPEcT_1.36.0.tar.gz', 'https://bioarchive.galaxyproject.org/INSPEcT_1.36.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-inspect/bioconductor-inspect_1.36.0_src_all.tar.gz']" ;
    schema1:identifier biotools:inspect ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-inspect" ;
    schema1:softwareVersion "1.36.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/INSPEcT.html" ;
    spdx:builtFrom biotools:inspect .

