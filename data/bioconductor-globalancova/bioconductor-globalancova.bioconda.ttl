@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-globalancova a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btm531" ;
    schema1:description "Global test for groups of variables via model comparisons" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/GlobalAncova_4.24.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/GlobalAncova/GlobalAncova_4.24.0.tar.gz', 'https://bioarchive.galaxyproject.org/GlobalAncova_4.24.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-globalancova/bioconductor-globalancova_4.24.0_src_all.tar.gz']" ;
    schema1:identifier biotools:globalancova ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-globalancova" ;
    schema1:softwareVersion "4.24.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/GlobalAncova.html" ;
    spdx:builtFrom biotools:globalancova .

