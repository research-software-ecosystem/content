@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-globalancova a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btm531" ;
    schema1:description "Global test for groups of variables via model comparisons" ;
    schema1:identifier biotools:globalancova ;
    schema1:keywords "Computer Simulation",
        "Gene Expression",
        "Gene Expression Profiling",
        "Gene expression",
        "Models, Biological",
        "Multigene Family",
        "Proteome",
        "Signal Transduction",
        "User-Computer Interface" ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-globalancova" ;
    schema1:url "http://bioconductor.org/packages/3.6/bioc/html/GlobalAncova.html" .

