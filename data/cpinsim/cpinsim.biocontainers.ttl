@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:cpinsim a schema1:SoftwareApplication ;
    schema1:description "Cpinsim is a package for the simulation of protein complex assembly with constrained\\nprotein interaction networks." ;
    schema1:license "MIT" ;
    schema1:name "cpinsim" ;
    schema1:url "https://github.com/BiancaStoecker/cpinsim" .

