@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-amountain a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1101/056952" ;
    schema1:description "Active modules for multilayer weighted gene co-expression networks: a continuous optimization approach" ;
    schema1:identifier biotools:amountain ;
    schema1:keywords "Gene expression",
        "Molecular interactions, pathways and networks" ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-amountain" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/AMOUNTAIN.html" .

