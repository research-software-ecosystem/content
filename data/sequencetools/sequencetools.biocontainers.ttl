@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:sequencetools a schema1:SoftwareApplication ;
    schema1:description "Tools for population genetics on sequencing data" ;
    schema1:license "MIT" ;
    schema1:name "sequencetools" ;
    schema1:url "https://github.com/stschiff/sequenceTools" .

