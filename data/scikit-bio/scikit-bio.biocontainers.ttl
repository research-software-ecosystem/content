@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:scikit-bio a schema1:SoftwareApplication ;
    schema1:description "Python package providing data structures, algorithms, and educational resources for bioinformatics." ;
    schema1:license "BSD" ;
    schema1:name "scikit-bio" ;
    schema1:url "https://github.com/biocore/scikit-bio" .

