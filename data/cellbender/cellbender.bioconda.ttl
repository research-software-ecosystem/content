@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:cellbender a schema1:SoftwareApplication ;
    schema1:author "mencian" ;
    schema1:citation "doi:10.1038/s41592-023-01943-7" ;
    schema1:description "A software package for eliminating technical artifacts from high-throughput single-cell RNA sequencing (scRNA-seq) data" ;
    schema1:downloadUrl "https://github.com/broadinstitute/CellBender/archive/v0.3.2.tar.gz" ;
    schema1:identifier biotools:CellBender ;
    schema1:license "BSD-3-Clause" ;
    schema1:maintainer "mencian" ;
    schema1:name "cellbender" ;
    schema1:softwareHelp "https://cellbender.readthedocs.io/en/latest" ;
    schema1:softwareVersion "0.3.2" ;
    schema1:url "https://github.com/broadinstitute/CellBender" ;
    spdx:builtFrom biotools:CellBender .

