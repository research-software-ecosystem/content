@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-heatplus a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Heatmaps with row and/or column covariates and colored clusters" ;
    schema1:identifier biotools:heatplus ;
    schema1:keywords "Clustering",
        "Computational Biology",
        "Data visualisation",
        "Gene Expression Profiling",
        "Genomics",
        "High-Throughput Screening Assays",
        "Programming Languages",
        "Proteomics",
        "User-Computer Interface" ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-heatplus" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/Heatplus.html" .

