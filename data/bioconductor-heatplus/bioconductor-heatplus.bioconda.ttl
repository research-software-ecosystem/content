@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-heatplus a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Heatmaps with row and/or column covariates and colored clusters" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/Heatplus_3.14.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/Heatplus/Heatplus_3.14.0.tar.gz', 'https://bioarchive.galaxyproject.org/Heatplus_3.14.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-heatplus/bioconductor-heatplus_3.14.0_src_all.tar.gz']" ;
    schema1:identifier biotools:heatplus ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-heatplus" ;
    schema1:softwareVersion "3.14.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/Heatplus.html" ;
    spdx:builtFrom biotools:heatplus .

