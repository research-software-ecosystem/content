@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:rnmr a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1002/mrc.2526" ;
    schema1:description "rNMR: open source software for identifying and quantifying metabolites in NMR spectra, developed by the team around Ian A. Lewis (University of Calgary)" ;
    schema1:identifier biotools:rnmr ;
    schema1:keywords "Data visualisation",
        "Erythrocytes",
        "Humans",
        "Magnetic Resonance Spectroscopy",
        "Metabolomics",
        "NMR" ;
    schema1:license "Custom License" ;
    schema1:name "rnmr" ;
    schema1:url "https://github.com/phnmnl/container-rnmr" .

