@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-bedr a schema1:SoftwareApplication ;
    schema1:description "Genomic regions processing using open-source command line tools such as 'BEDTools', 'BEDOPS' and 'Tabix'.  These tools offer scalable and efficient utilities to perform genome arithmetic e.g indexing, formatting and merging. bedr API enhances access to these tools as well as offers additional utilities for genomic regions processing." ;
    schema1:license "GPL-2" ;
    schema1:name "r-bedr" ;
    schema1:url "https://CRAN.R-project.org/package=bedr" .

