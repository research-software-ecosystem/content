@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:semibin a schema1:SoftwareApplication ;
    schema1:author "luispedro",
        "psj1997" ;
    schema1:citation "doi:10.1038/s41467-022-29843-y",
        "doi:10.1093/bioinformatics/btad209" ;
    schema1:description "Metagenomic binning with siamese neural networks" ;
    schema1:downloadUrl "https://pypi.io/packages/source/S/SemiBin/semibin-2.2.1.tar.gz" ;
    schema1:identifier biotools:semibin ;
    schema1:license "MIT" ;
    schema1:maintainer "luispedro",
        "psj1997" ;
    schema1:name "semibin" ;
    schema1:softwareHelp "https://semibin.readthedocs.io/en/latest/" ;
    schema1:softwareVersion "2.2.1" ;
    schema1:url "https://github.com/BigDataBiology/SemiBin" ;
    spdx:builtFrom biotools:semibin .

