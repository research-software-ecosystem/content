@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:git-lfs a schema1:SoftwareApplication ;
    schema1:description "An open source Git extension for versioning large files" ;
    schema1:license "MIT" ;
    schema1:name "git-lfs" ;
    schema1:url "https://github.com/git-lfs/git-lfs" .

