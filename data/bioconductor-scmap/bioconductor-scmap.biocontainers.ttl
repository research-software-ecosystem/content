@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-scmap a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18129/b9.bioc.scmap" ;
    schema1:description "A tool for unsupervised projection of single cell RNA-seq data" ;
    schema1:keywords "Clustering",
        "RNA-Seq",
        "Transcriptome",
        "Transcriptomics" ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-scmap" ;
    schema1:url "https://bioconductor.org/packages/3.8/bioc/html/scmap.html" .

