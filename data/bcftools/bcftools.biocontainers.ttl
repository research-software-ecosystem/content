@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bcftools a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btp352" ;
    schema1:description "Set of utilities that manipulate variant calls in the variant call format (vcf) and its binary counterpart bcf. all commands work transparently with both vcfs and bcfs, both uncompressed and bgzf-compressed." ;
    schema1:identifier biotools:bcftools ;
    schema1:keywords "Base Sequence",
        "Clustering",
        "Computational Biology",
        "DNA polymorphism",
        "GWAS study",
        "Genetic variation",
        "Genome",
        "Genomics",
        "Genotyping experiment",
        "Molecular Sequence Data",
        "Sequence Alignment",
        "Sequence Analysis, DNA" ;
    schema1:license "MIT" ;
    schema1:name "bcftools" ;
    schema1:url "https://github.com/samtools/bcftools" .

