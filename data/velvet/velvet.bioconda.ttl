@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:velvet a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1101/gr.074492.107" ;
    schema1:description "Sequence Assembler for short reads." ;
    schema1:downloadUrl "https://github.com/dzerbino/velvet/archive/refs/tags/v1.2.10.tar.gz" ;
    schema1:identifier biotools:velvet ;
    schema1:license "GPL-2.0-only" ;
    schema1:name "velvet" ;
    schema1:softwareHelp "https://github.com/dzerbino/velvet/blob/master/Manual.pdf" ;
    schema1:softwareVersion "1.2.10" ;
    schema1:url "https://github.com/dzerbino/velvet" ;
    spdx:builtFrom biotools:velvet .

