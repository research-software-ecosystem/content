@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:anvio a schema1:SoftwareApplication ;
    schema1:description "An interactive analysis and visualization platform for omics data" ;
    schema1:keywords "Genetics",
        "Genomics",
        "Metagenome",
        "Metagenomics",
        "Protein Structure",
        "Transcriptomics" ;
    schema1:license "GPL-3.0" ;
    schema1:name "anvio" ;
    schema1:url "http://merenlab.org/software/anvio/index.html" .

