@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-bhc a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/1471-2105-10-242" ;
    schema1:description "Bayesian Hierarchical Clustering" ;
    schema1:identifier biotools:bhc ;
    schema1:keywords "Arabidopsis",
        "Bayes Theorem",
        "Cluster Analysis",
        "Clustering",
        "Gene Expression Profiling",
        "Oligonucleotide Array Sequence Analysis",
        "Software Design",
        "Statistics and probability",
        "Time Factors" ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-bhc" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/BHC.html" .

