    schema1:downloadUrl "['https://bioconductor.org/packages/3.18/bioc/src/contrib/BHC_1.54.0.tar.gz', 'https://bioconductor.org/packages/3.18/bioc/src/contrib/Archive/BHC/BHC_1.54.0.tar.gz', 'https://bioarchive.galaxyproject.org/BHC_1.54.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-bhc/bioconductor-bhc_1.54.0_src_all.tar.gz']" ;
    schema1:identifier biotools:bhc ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-bhc" ;
    schema1:softwareVersion "1.54.0" ;
    schema1:url "https://bioconductor.org/packages/3.18/bioc/html/BHC.html" ;
    spdx:builtFrom biotools:bhc .

