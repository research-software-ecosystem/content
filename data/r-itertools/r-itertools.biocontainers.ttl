@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-itertools a schema1:SoftwareApplication ;
    schema1:description "Various tools for creating iterators, many patterned after functions in the Python itertools module, and others patterned after functions in the snow package" ;
    schema1:license "GPL-2.0" ;
    schema1:name "r-itertools" ;
    schema1:url "https://CRAN.R-project.org/package=itertools" .

