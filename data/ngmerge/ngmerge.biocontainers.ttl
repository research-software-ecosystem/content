@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:ngmerge a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s12859-018-2579-2" ;
    schema1:description "Merging paired-end reads and removing sequencing adapters." ;
    schema1:identifier biotools:ngmerge ;
    schema1:keywords "High-Throughput Nucleotide Sequencing",
        "Humans",
        "Sequence Analysis, DNA" ;
    schema1:license "MIT" ;
    schema1:name "ngmerge" ;
    schema1:url "https://github.com/harvardinformatics/NGmerge" .

