@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:ngmerge a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s12859-018-2579-2" ;
    schema1:description "Merging paired-end reads and removing sequencing adapters." ;
    schema1:downloadUrl "https://github.com/jsh58/NGmerge/archive/v0.5.tar.gz" ;
    schema1:identifier biotools:ngmerge ;
    schema1:license "MIT" ;
    schema1:name "ngmerge" ;
    schema1:softwareHelp "https://github.com/jsh58/NGmerge/blob/v0.5/README.md" ;
    schema1:softwareVersion "0.5" ;
    schema1:url "https://github.com/jsh58/NGmerge" ;
    spdx:builtFrom biotools:ngmerge .

