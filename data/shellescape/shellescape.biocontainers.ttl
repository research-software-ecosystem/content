@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:shellescape a schema1:SoftwareApplication ;
    schema1:description "Shell escape a string to safely use it as a token in a shell command (backport of Python shlex.quote for Python versions 2.x & < 3.3)" ;
    schema1:license "MIT" ;
    schema1:name "shellescape" ;
    schema1:url "None" .

