@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:seqtk a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s13104-017-2616-7" ;
    schema1:description "A tool for processing sequences in the fasta or fastq format. it parses both fasta and fastq files which can also be optionally compressed by gzip." ;
    schema1:identifier biotools:seqtk ;
    schema1:keywords "Base Sequence",
        "Data management",
        "Sequence Analysis, DNA" ;
    schema1:license "MIT" ;
    schema1:name "seqtk" ;
    schema1:url "https://github.com/lh3/seqtk" .

