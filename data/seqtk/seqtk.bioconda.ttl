@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:seqtk a schema1:SoftwareApplication ;
    schema1:description "Seqtk is a fast and lightweight tool for processing sequences in the FASTA or FASTQ format." ;
    schema1:downloadUrl "https://github.com/lh3/seqtk/archive/v1.5.tar.gz" ;
    schema1:identifier biotools:seqtk ;
    schema1:license "MIT" ;
    schema1:name "seqtk" ;
    schema1:softwareHelp "https://github.com/lh3/seqtk/blob/v1.5/README.md" ;
    schema1:softwareVersion "1.5" ;
    schema1:url "https://github.com/lh3/seqtk" ;
    spdx:builtFrom biotools:seqtk .

