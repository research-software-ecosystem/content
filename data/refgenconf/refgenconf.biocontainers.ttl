@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:refgenconf a schema1:SoftwareApplication ;
    schema1:description "A standardized configuration object for reference genome assemblies" ;
    schema1:license "BSD 2-Clause \"Simplified\" License" ;
    schema1:name "refgenconf" ;
    schema1:url "https://github.com/databio/refgenie/" .

