@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-generxcluster a schema1:SoftwareApplication ;
    schema1:description "gRx Differential Clustering" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/geneRxCluster_1.42.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/geneRxCluster/geneRxCluster_1.42.0.tar.gz', 'https://bioarchive.galaxyproject.org/geneRxCluster_1.42.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-generxcluster/bioconductor-generxcluster_1.42.0_src_all.tar.gz']" ;
    schema1:identifier biotools:generxcluster ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-generxcluster" ;
    schema1:softwareVersion "1.42.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/geneRxCluster.html" ;
    spdx:builtFrom biotools:generxcluster .

