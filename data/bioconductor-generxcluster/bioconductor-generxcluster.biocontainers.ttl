@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-generxcluster a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btu035" ;
    schema1:description "gRx Differential Clustering" ;
    schema1:identifier biotools:generxcluster ;
    schema1:keywords "Artificial Intelligence",
        "Clustering",
        "DNA",
        "Data Interpretation, Statistical",
        "Genetic Vectors",
        "Genetics",
        "Genomics",
        "HIV",
        "Humans",
        "Jurkat Cells",
        "Virus Integration" ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-generxcluster" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/geneRxCluster.html" .

