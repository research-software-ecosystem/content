@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:chewiesnake a schema1:SoftwareApplication ;
    schema1:description "Chewiesnake is a snakemake workflow that performs cgmlst allele calling for a set of assembled genomes using chewbbaca." ;
    schema1:license "BSD-3" ;
    schema1:name "chewiesnake" ;
    schema1:url "https://gitlab.com/bfr_bioinformatics/chewieSnake" .

