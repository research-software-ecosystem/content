@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-txrevise a schema1:SoftwareApplication ;
    schema1:citation "doi:10.7554/eLife.41673" ;
    schema1:description "Construct custom transcript annotations for salmon and kallisto" ;
    schema1:keywords "Female",
        "Gene Expression Regulation",
        "Humans",
        "Macrophages",
        "Male",
        "Promoter Regions, Genetic",
        "Quantitative Trait Loci",
        "Quantitative Trait, Heritable",
        "RNA, Messenger" ;
    schema1:license "Apache-2.0" ;
    schema1:name "r-txrevise" ;
    schema1:url "https://github.com/kauralasoo/txrevise" .

