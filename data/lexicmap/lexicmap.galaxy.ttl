@prefix galaxytool: <https://github.com/galaxyproject/tools-iuc/tree/master/tools/> .
@prefix schema1: <http://schema.org/> .

galaxytool:lexicmap a schema1:SoftwareApplication ;
    schema1:description "LexicMap is a nucleotide sequence alignment tool for efficiently querying genomes." ;
    schema1:identifier "bioconda:lexicmap",
        "biotools:lexicmap" ;
    schema1:keywords "Next Gen Mappers" ;
    schema1:name "lexicmap" ;
    schema1:softwareVersion "0.8.1" ;
    schema1:url "https://github.com/shenwei356/LexicMap" .

