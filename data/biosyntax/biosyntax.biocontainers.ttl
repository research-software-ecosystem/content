@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:biosyntax a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1101/235820" ;
    schema1:description "Syntax highlighting for computational biology (metapackage)" ;
    schema1:identifier biotools:biosyntax ;
    schema1:keywords "Biology",
        "Genetics",
        "Genomics" ;
    schema1:license "GPL-3" ;
    schema1:name "biosyntax" ;
    schema1:url "https://github.com/bioSyntax/bioSyntax" .

