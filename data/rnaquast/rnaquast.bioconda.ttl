@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:rnaquast a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btw218" ;
    schema1:description "rnaQUAST is a tool for evaluating RNA-Seq assemblies using reference genome and gene database. In addition, rnaQUAST is also capable of estimating gene database coverage by raw reads and de novo quality assessment using third-party software." ;
    schema1:downloadUrl "https://github.com/ablab/rnaquast/releases/download/v2.3.2/rnaQUAST-2.3.2.tar.gz" ;
    schema1:identifier biotools:rnaQUAST ;
    schema1:license "GPL-2.0-or-later" ;
    schema1:name "rnaquast" ;
    schema1:softwareVersion "2.3.2" ;
    schema1:url "https://github.com/ablab/rnaquast" ;
    spdx:builtFrom biotools:rnaQUAST .

