@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-pore a schema1:SoftwareApplication ;
    schema1:description "An R package to enable organisation and visualisation of nanopore sequencing data" ;
    schema1:keywords "Protein Sequences",
        "Sequence Alignment" ;
    schema1:license "BSD" ;
    schema1:name "r-pore" ;
    schema1:url "http://sourceforge.net/projects/rpore/" .

