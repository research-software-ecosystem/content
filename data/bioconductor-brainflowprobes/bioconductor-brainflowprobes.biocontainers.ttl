@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-brainflowprobes a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18129/b9.bioc.brainflowprobes" ;
    schema1:description "Plots and annotation for choosing brainflow target probe sequence" ;
    schema1:keywords "Genomics",
        "Transcriptomics" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-brainflowprobes" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/brainflowprobes.html" .

