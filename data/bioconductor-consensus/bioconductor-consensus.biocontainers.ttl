@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-consensus a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18129/b9.bioc.consensus" ;
    schema1:description "Cross-platform consensus analysis of genomic measurements via interlaboratory testing method" ;
    schema1:license "BSD-3-Clause" ;
    schema1:name "bioconductor-consensus" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/consensus.html" .

