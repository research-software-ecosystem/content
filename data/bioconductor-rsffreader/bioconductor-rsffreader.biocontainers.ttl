@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-rsffreader a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18129/b9.bioc.rsffreader" ;
    schema1:description "rSFFreader reads sequence, qualities and clip point values from sff files generated by Roche 454 and Life Sciences Ion Torrent sequencers into similar classes as are present for fastq files." ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-rsffreader" ;
    schema1:url "https://bioconductor.org/packages/3.8/bioc/html/rSFFreader.html" .

