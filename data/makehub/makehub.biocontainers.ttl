@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:makehub a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1101/550145" ;
    schema1:description "MakeHub is a command line tool for the fully automatic generation of of track data hubs for visualizing genomes with the UCSC genome browser." ;
    schema1:keywords "Functional genomics",
        "Genomics",
        "RNA-Seq",
        "Sequence Alignment" ;
    schema1:license "GPL-3.0" ;
    schema1:name "makehub" ;
    schema1:url "https://github.com/Gaius-Augustus/MakeHub" .

