@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:sansa a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/bts378" ;
    schema1:description "Structural variant annotation" ;
    schema1:keywords "Chromosome Mapping",
        "Genome, Human",
        "Genomic Structural Variation",
        "Genomics",
        "High-Throughput Nucleotide Sequencing",
        "Humans",
        "Sequence Analysis, DNA",
        "Sequence Deletion" ;
    schema1:license "BSD" ;
    schema1:name "sansa" ;
    schema1:url "https://github.com/dellytools/sansa" .

