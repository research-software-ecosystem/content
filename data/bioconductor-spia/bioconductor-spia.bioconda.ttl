@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-spia a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btn577" ;
    schema1:description "Signaling Pathway Impact Analysis (SPIA) using combined evidence of pathway over-representation and unusual signaling perturbations" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/SPIA_2.62.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/SPIA/SPIA_2.62.0.tar.gz', 'https://bioarchive.galaxyproject.org/SPIA_2.62.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-spia/bioconductor-spia_2.62.0_src_all.tar.gz']" ;
    schema1:identifier biotools:spia ;
    schema1:license "file LICENSE" ;
    schema1:name "bioconductor-spia" ;
    schema1:softwareVersion "2.62.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/SPIA.html" ;
    spdx:builtFrom biotools:spia .

