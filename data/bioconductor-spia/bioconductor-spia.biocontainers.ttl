@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-spia a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btn577" ;
    schema1:description "Signaling Pathway Impact Analysis (SPIA) using combined evidence of pathway over-representation and unusual signaling perturbations" ;
    schema1:identifier biotools:spia ;
    schema1:keywords "Colorectal Neoplasms",
        "Computational Biology",
        "Databases, Genetic",
        "False Positive Reactions",
        "Female",
        "Gene expression",
        "Humans",
        "Labor, Obstetric",
        "Microarray experiment",
        "Models, Genetic",
        "Molecular interactions, pathways and networks",
        "Pregnancy",
        "Signal Transduction" ;
    schema1:license "file LICENSE" ;
    schema1:name "bioconductor-spia" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/SPIA.html" .

