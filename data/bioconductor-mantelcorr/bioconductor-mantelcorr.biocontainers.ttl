@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-mantelcorr a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Compute Mantel Cluster Correlations" ;
    schema1:identifier biotools:mantelcorr ;
    schema1:keywords "Clustering",
        "Computational Biology",
        "Gene Expression Profiling",
        "Gene expression",
        "Genomics",
        "High-Throughput Screening Assays",
        "Microarray experiment",
        "Programming Languages",
        "User-Computer Interface" ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-mantelcorr" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/MantelCorr.html" .

