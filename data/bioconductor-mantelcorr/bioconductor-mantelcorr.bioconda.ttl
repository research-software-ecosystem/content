@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-mantelcorr a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Compute Mantel Cluster Correlations" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/MantelCorr_1.76.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/MantelCorr/MantelCorr_1.76.0.tar.gz', 'https://bioarchive.galaxyproject.org/MantelCorr_1.76.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-mantelcorr/bioconductor-mantelcorr_1.76.0_src_all.tar.gz']" ;
    schema1:identifier biotools:mantelcorr ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-mantelcorr" ;
    schema1:softwareVersion "1.76.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/MantelCorr.html" ;
    spdx:builtFrom biotools:mantelcorr .

