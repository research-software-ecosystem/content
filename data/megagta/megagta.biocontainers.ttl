@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:megagta a schema1:SoftwareApplication ;
    schema1:citation "doi:10.3389/FGENE.2019.00957" ;
