@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:sparcc a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1371/journal.pcbi.1002687" ;
    schema1:description "SparCC is a python module for computing correlations in compositional data (16S, metagenomics, etc)." ;
    schema1:keywords "Chromosome Mapping",
        "Computer Simulation",
        "Genetics, Population",
        "Genome, Bacterial",
        "Humans",
        "Microbial Consortia",
        "Models, Genetic",
        "Recombination, Genetic",
        "Statistics as Topic" ;
    schema1:license "MIT" ;
    schema1:name "sparcc" ;
    schema1:url "https://bitbucket.org/yonatanf/sparcc" .

