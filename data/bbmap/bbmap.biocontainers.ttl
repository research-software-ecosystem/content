@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bbmap a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1371/journal.pone.0185056" ;
    schema1:description "Bbmap is a fast splice-aware aligner for rna and dna. it is faster than almost all short-read aligners, yet retains unrivaled sensitivity and specificity, particularly for reads with many errors and indels." ;
    schema1:identifier biotools:bbmap ;
    schema1:keywords "Computational Biology",
        "High-Throughput Nucleotide Sequencing",
        "Metagenome",
        "Metagenomics",
        "Phylogenetics",
        "RNA splicing",
        "RNA-Seq",
        "RNA-seq",
        "Sequence Alignment",
        "Sequencing",
        "Whole genome sequencing" ;
    schema1:license "BSD-3-Clause" ;
    schema1:name "bbmap" ;
    schema1:url "https://sourceforge.net/projects/bbmap/" .

