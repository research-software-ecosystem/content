@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bbmap a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1371/journal.pone.0185056" ;
    schema1:description "BBMap is a short read aligner, as well as various other bioinformatic tools." ;
    schema1:downloadUrl "https://downloads.sourceforge.net/project/bbmap/BBMap_39.81b.tar.gz" ;
    schema1:identifier biotools:bbmap ;
    schema1:license "BSD-3-Clause-LBNL" ;
    schema1:name "bbmap" ;
    schema1:softwareHelp "https://bbmap.org" ;
    schema1:softwareVersion "39.81" ;
    schema1:url "https://sourceforge.net/projects/bbmap" ;
    spdx:builtFrom biotools:bbmap .

