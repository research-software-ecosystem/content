@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-tibble a schema1:SoftwareApplication ;
    schema1:description "Provides a tbl_df class (the tibble) that provides stricter checking and better formatting than the traditional data frame." ;
    schema1:license "MIT" ;
    schema1:name "r-tibble" ;
    schema1:url "https://cran.r-project.org/package=tibble" .

