@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:kcounter a schema1:SoftwareApplication ;
    schema1:description "A simple package for counting DNA k-mers in Python. Written in Rust." ;
    schema1:license "GPL-3" ;
    schema1:name "kcounter" ;
    schema1:url "http://apcamargo.github.io/kcounter/" .

