@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:gepard a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btm039" ;
    schema1:description "Genome pair rapid dotter (gepard)." ;
    schema1:identifier biotools:gepard ;
    schema1:keywords "Chromosome Mapping",
        "Comparative genomics",
        "Computer Graphics",
        "Sensitivity and Specificity",
        "User-Computer Interface" ;
    schema1:license "MIT" ;
    schema1:name "gepard" ;
    schema1:url "https://github.com/univieCUBE/gepard" .

