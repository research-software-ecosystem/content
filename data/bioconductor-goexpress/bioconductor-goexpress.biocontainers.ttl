@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-goexpress a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18129/b9.bioc.goexpress" ;
    schema1:description "Visualise microarray and RNAseq data using gene ontology annotations" ;
    schema1:keywords "Clustering",
        "Gene Expression",
        "RNA-Seq" ;
    schema1:license "GPL (>= 3)" ;
    schema1:name "bioconductor-goexpress" ;
    schema1:url "https://bioconductor.org/packages/3.8/bioc/html/GOexpress.html" .

