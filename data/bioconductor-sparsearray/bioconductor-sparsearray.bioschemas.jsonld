      "@id": "https://bio.tools/bioconductor-sparsearray",
      "@type": "sc:SoftwareApplication",
      "dcterms:conformsTo": "https://bioschemas.org/profiles/ComputationalTool/0.6-DRAFT",
      "sc:additionalType": [
        "Command-line tool",
        "Library"
      ],
      "sc:author": "Hervé Pagès",
      "sc:citation": {
        "@id": "https://doi.org/10.18129/B9.bioc.SparseArray"
      },
      "sc:contributor": [
        "Vince Carey",
        "Rafael A. Irizarry",
        "Jacques Serizay"
      ],
      "sc:description": "The SparseArray package provides array-like containers for efficient in-memory representation of multidimensional sparse data in R (arrays and matrices). The package defines the SparseArray virtual class and two concrete subclasses: COO_SparseArray and SVT_SparseArray. Each subclass uses its own internal representation of the nonzero multidimensional data: the \"COO layout\" and the \"SVT layout\", respectively. SVT_SparseArray objects mimic as much as possible the behavior of ordinary matrix and array objects in base R. In particular, they suppport most of the \"standard matrix and array API\" defined in base R and in the matrixStats package from CRAN.",
      "sc:funder": [
        "Vince Carey",
        "Rafael A. Irizarry"
      ],
      "sc:license": "Artistic-2.0",
      "sc:name": "SparseArray",
      "sc:operatingSystem": [
        "Linux",
        "Windows",
        "Mac"
      ],
      "sc:softwareHelp": {
        "@id": "https://bioconductor.org/packages/SparseArray"
      },
      "sc:softwareVersion": "1.10.9",
