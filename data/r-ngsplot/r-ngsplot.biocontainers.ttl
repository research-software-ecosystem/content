@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-ngsplot a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/1471-2164-15-284" ;
    schema1:description "Quick mining and visualization of ngs data by integrating genomic databases" ;
    schema1:keywords "Animals",
        "Clustering",
        "Computational Biology",
        "Data Mining",
        "Databases, Genetic",
        "Embryonic Stem Cells",
        "Epigenomics",
        "Gene Expression",
        "Genomics",
        "High-Throughput Nucleotide Sequencing",
        "Humans",
        "Promoter Regions, Genetic",
        "RNA-Seq",
        "Reproducibility of Results",
        "Sequence Analysis, DNA",
        "Sequence Analysis, RNA",
        "Web Browser",
        "Workflow" ;
    schema1:license "GNU General Public License v2.0" ;
    schema1:name "r-ngsplot" ;
    schema1:url "https://github.com/shenlab-sinai/ngsplot" .

