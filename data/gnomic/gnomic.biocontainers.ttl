@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:gnomic a schema1:SoftwareApplication ;
    schema1:description "A grammar for describing microbial genotypes and phenotypes" ;
    schema1:keywords "Genomics" ;
    schema1:license "Apache-2.0" ;
    schema1:name "gnomic" ;
    schema1:url "https://github.com/biosustain/gnomic" .

