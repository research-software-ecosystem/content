@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:metaphlan2 a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3589" ;
    schema1:description "Metagenomic phylogenetic analysis" ;
    schema1:keywords "DNA Barcoding, Taxonomic",
        "Genomics",
        "Humans",
        "Metagenome",
        "Metagenomics",
        "Phylogeny",
        "Propionibacterium acnes",
        "Reproducibility of Results",
        "Skin" ;
    schema1:license "MIT" ;
    schema1:name "metaphlan2" ;
    schema1:url "https://github.com/biobakery/metaphlan" .

