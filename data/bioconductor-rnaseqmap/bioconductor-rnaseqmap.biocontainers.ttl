@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-rnaseqmap a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/1471-2105-12-200" ;
    schema1:description "rnaSeq secondary analyses" ;
    schema1:identifier biotools:rnaseqmap ;
    schema1:keywords "Animals",
        "Gene Expression Profiling",
        "Gene expression",
        "Genome",
        "Humans",
        "Oligonucleotide Array Sequence Analysis",
        "RNA-Seq",
        "Sequence Analysis, RNA" ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-rnaseqmap" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/rnaSeqMap.html" .

