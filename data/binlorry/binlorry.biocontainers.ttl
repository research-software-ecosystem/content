@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:binlorry a schema1:SoftwareApplication ;
    schema1:description "Binlorry, a flexible tool for binning and filtering sequencing reads" ;
    schema1:license "GNU General Public License v3.0" ;
    schema1:name "binlorry" ;
    schema1:url "https://github.com/rambaut/binlorry" .

