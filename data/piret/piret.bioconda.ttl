@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:piret a schema1:SoftwareApplication ;
    schema1:description "A tool for conducting RNA seq analysis." ;
    schema1:downloadUrl "https://github.com/mshakya/piret/archive/0.3.4.tar.gz" ;
    schema1:identifier biotools:piret ;
    schema1:license "GPL-2.0-or-later" ;
    schema1:name "piret" ;
    schema1:softwareVersion "0.3.4" ;
    schema1:url "https://github.com/mshakya/PyPiReT" ;
    spdx:builtFrom biotools:piret .

