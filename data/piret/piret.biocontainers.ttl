@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:piret a schema1:SoftwareApplication ;
    schema1:description "A tool for conducting rna seq analysis." ;
    schema1:identifier biotools:piret ;
    schema1:keywords "RNA-Seq",
        "Sequence Alignment",
        "Transcriptome",
        "Transcriptomics" ;
    schema1:license "GPL-2.0" ;
    schema1:name "piret" ;
    schema1:url "https://github.com/mshakya/PyPiReT" .

