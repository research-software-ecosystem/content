@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:gap2seq a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1007/978-3-319-16706-0_29" ;
    schema1:description "Gap2Seq is a tool for filling gaps between contigs in genome assemblies." ;
    schema1:license "GPL-3.0" ;
    schema1:name "gap2seq" ;
    schema1:url "https://github.com/rikuu/Gap2Seq/" .

