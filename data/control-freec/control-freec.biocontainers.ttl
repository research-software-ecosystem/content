@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:control-freec a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btq635" ;
    schema1:description "A tool for control-free copy number alteration (cna) and allelic imbalances (loh) detection using deep-sequencing data, particularly useful for cancer studies." ;
    schema1:identifier biotools:freec ;
    schema1:keywords "Base Composition",
        "Cell Line, Tumor",
        "Cytosine",
        "DNA Copy Number Variations",
        "DNA structural variation",
        "Data mining",
        "Genomics",
        "Guanine",
        "High-Throughput Nucleotide Sequencing",
        "Human genetics",
        "Humans",
        "Neoplasms",
        "Oncology",
        "Whole genome sequencing" ;
    schema1:license "GPL-2.0" ;
    schema1:name "control-freec" ;
    schema1:url "https://github.com/BoevaLab/FREEC" .

