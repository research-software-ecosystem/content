@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:metaprokka a schema1:SoftwareApplication ;
    schema1:description "A specialized version of prokka to quickly annotate metagenome assemblies." ;
    schema1:identifier biotools:metaprokka ;
    schema1:keywords "Metagenome" ;
    schema1:license "GPL-3.0" ;
    schema1:name "metaprokka" ;
    schema1:url "https://github.com/telatin/metaprokka" .

