@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:metaprokka a schema1:SoftwareApplication ;
    schema1:description "A fork of Prokka using Prodigal-GV for phage annotation and metagenome/metavirome tweaks" ;
    schema1:downloadUrl "https://github.com/telatin/metaprokka/archive/v1.15.0.tar.gz" ;
    schema1:identifier biotools:metaprokka ;
    schema1:license "GPL-3.0-only" ;
    schema1:name "metaprokka" ;
    schema1:softwareVersion "1.15.0" ;
    schema1:url "https://github.com/telatin/metaprokka" ;
    spdx:builtFrom biotools:metaprokka .

