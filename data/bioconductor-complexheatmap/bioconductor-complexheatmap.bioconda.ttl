@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-complexheatmap a schema1:SoftwareApplication ;
    schema1:description "Make Complex Heatmaps" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/ComplexHeatmap_2.26.1.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/ComplexHeatmap/ComplexHeatmap_2.26.1.tar.gz', 'https://bioarchive.galaxyproject.org/ComplexHeatmap_2.26.1.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-complexheatmap/bioconductor-complexheatmap_2.26.1_src_all.tar.gz']" ;
    schema1:identifier biotools:complexheatmap ;
    schema1:license "MIT + file LICENSE" ;
    schema1:name "bioconductor-complexheatmap" ;
    schema1:softwareVersion "2.26.1" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/ComplexHeatmap.html" ;
    spdx:builtFrom biotools:complexheatmap .

