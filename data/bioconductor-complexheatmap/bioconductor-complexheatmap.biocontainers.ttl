@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-complexheatmap a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btw313" ;
    schema1:description "Make Complex Heatmaps" ;
    schema1:identifier biotools:complexheatmap ;
    schema1:keywords "Computer Graphics",
        "Data visualisation",
        "Gene Expression",
        "Genomics",
        "Humans",
        "Metabolic Networks and Pathways" ;
    schema1:license "MIT" ;
    schema1:name "bioconductor-complexheatmap" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/ComplexHeatmap.html" .

