@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-mipp a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/bti1020" ;
    schema1:description "Misclassification Penalized Posterior Classification" ;
    schema1:identifier biotools:mipp ;
    schema1:keywords "Computational Biology",
        "Databases, Genetic",
        "Databases, Protein",
        "Gene Expression Profiling",
        "Gene Expression Regulation, Neoplastic",
        "Gene and protein families",
        "Genes, Neoplasm",
        "Genetics",
        "Humans",
        "Internet",
        "Leukemia",
        "Models, Statistical",
        "Oligonucleotide Array Sequence Analysis",
        "Pattern Recognition, Automated" ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-mipp" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/MiPP.html" .

