@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-mipp a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/bti1020" ;
    schema1:description "Misclassification Penalized Posterior Classification" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/MiPP_1.82.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/MiPP/MiPP_1.82.0.tar.gz', 'https://bioarchive.galaxyproject.org/MiPP_1.82.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-mipp/bioconductor-mipp_1.82.0_src_all.tar.gz']" ;
    schema1:identifier biotools:mipp ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-mipp" ;
    schema1:softwareVersion "1.82.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/MiPP.html" ;
    spdx:builtFrom biotools:mipp .

