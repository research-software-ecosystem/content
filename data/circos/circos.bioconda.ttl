@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:circos a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1101/gr.092759.109" ;
    schema1:description "Circos is a software package for visualizing data and information. It visualizes data in a circular layout" ;
    schema1:downloadUrl "http://circos.ca/distribution/circos-0.69-9.tgz" ;
    schema1:identifier biotools:circos ;
    schema1:license "GNU General Public License v2 (GPLv2)" ;
    schema1:name "circos" ;
    schema1:softwareVersion "0.69.9" ;
    schema1:url "http://circos.ca" ;
    spdx:builtFrom biotools:circos .

