@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:circos a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1101/gr.092759.109",
        "doi:10.7490/f1000research.1114334.1" ;
    schema1:description "Circos is tool for visualizing data in a circular format. it was developed for genomic data but can work for many other kinds of data as well." ;
    schema1:identifier biotools:circos ;
    schema1:keywords "Animals",
        "Chromosome Mapping",
        "Chromosomes, Artificial, Bacterial",
        "Chromosomes, Human, Pair 17",
        "Chromosomes, Human, Pair 6",
        "Comparative genomics",
        "Contig Mapping",
        "Data visualisation",
        "Dogs",
        "Gene Dosage",
        "Gene Expression",
        "Genetics",
        "Genome",
        "Genomics",
        "Humans",
        "Lymphoma, Follicular",
        "Metagenome",
        "Transcriptome" ;
    schema1:license "GPL-2.0" ;
    schema1:name "circos" ;
    schema1:url "http://circos.ca/" .

