@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:jass_preprocessing a schema1:SoftwareApplication ;
    schema1:description "Harmonizing raw GWAS summary statistic for further analysis with jass" ;
    schema1:keywords "Genetics" ;
    schema1:license "MIT" ;
    schema1:name "jass_preprocessing" ;
    schema1:url "http://statistical-genetics.pages.pasteur.fr/jass_preprocessing/" .

