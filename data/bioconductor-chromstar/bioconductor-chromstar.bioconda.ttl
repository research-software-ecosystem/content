@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-chromstar a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1101/038612" ;
    schema1:description "Combinatorial and Differential Chromatin State Analysis for ChIP-Seq Data" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.18/bioc/src/contrib/chromstaR_1.28.0.tar.gz', 'https://bioconductor.org/packages/3.18/bioc/src/contrib/Archive/chromstaR/chromstaR_1.28.0.tar.gz', 'https://bioarchive.galaxyproject.org/chromstaR_1.28.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-chromstar/bioconductor-chromstar_1.28.0_src_all.tar.gz']" ;
    schema1:identifier biotools:chromstar ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-chromstar" ;
    schema1:softwareVersion "1.28.0" ;
    schema1:url "https://bioconductor.org/packages/3.18/bioc/html/chromstaR.html" ;
    spdx:builtFrom biotools:chromstar .

