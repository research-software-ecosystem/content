@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:sambamba a schema1:SoftwareApplication ;
    schema1:author "mjsteinbaugh" ;
    schema1:citation "doi:10.1093/bioinformatics/btv098" ;
    schema1:description "Tools for working with SAM/BAM data." ;
    schema1:downloadUrl "https://github.com/biod/sambamba/archive/refs/tags/v1.0.1.tar.gz" ;
    schema1:identifier biotools:sambamba ;
    schema1:license "GPL-2.0-only" ;
    schema1:maintainer "mjsteinbaugh" ;
    schema1:name "sambamba" ;
    schema1:softwareHelp "https://lomereiter.github.io/sambamba/docs/sambamba-view.html" ;
    schema1:softwareVersion "1.0.1" ;
    schema1:url "https://github.com/biod/sambamba" ;
    spdx:builtFrom biotools:sambamba .

