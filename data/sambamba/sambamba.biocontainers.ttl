@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:sambamba a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btv098" ;
    schema1:description "Tools for working with sam/bam data" ;
    schema1:identifier biotools:sambamba ;
    schema1:keywords "DNA",
        "Genomics",
        "High-Throughput Nucleotide Sequencing",
        "Humans",
        "RNA-Seq",
        "Sequence Alignment",
        "Sequence Analysis, DNA",
        "Sequence analysis" ;
    schema1:license "GPL-2.0" ;
    schema1:name "sambamba" ;
    schema1:url "https://github.com/lomereiter/sambamba" .

