@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:prosampler a schema1:SoftwareApplication ;
    schema1:description "An ultra-fast motif finding program in large ChIP-seq datasets." ;
    schema1:downloadUrl "https://github.com/zhengchangsulab/ProSampler/raw/master/PROSMPLER_v1.5.tar.gz" ;
    schema1:identifier biotools:prosampler ;
    schema1:license "GPL-3.0-or-later" ;
    schema1:name "prosampler" ;
    schema1:softwareVersion "1.5" ;
    schema1:url "https://github.com/zhengchangsulab/ProSampler" ;
    spdx:builtFrom biotools:prosampler .

