@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-rcas a schema1:SoftwareApplication ;
    schema1:description "RNA Centric Annotation System" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/RCAS_1.36.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/RCAS/RCAS_1.36.0.tar.gz', 'https://bioarchive.galaxyproject.org/RCAS_1.36.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-rcas/bioconductor-rcas_1.36.0_src_all.tar.gz']" ;
    schema1:identifier biotools:rcas ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-rcas" ;
    schema1:softwareVersion "1.36.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/RCAS.html" ;
    spdx:builtFrom biotools:rcas .

