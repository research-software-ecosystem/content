biocontainers:bioconductor-junctionseq a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/gkw501" ;
    schema1:description "JunctionSeq: A Utility for Detection of Differential Exon and Splice-Junction Usage in RNA-Seq data" ;
    schema1:identifier biotools:junctionseq ;
    schema1:keywords "Alternative Splicing",
        "Animals",
        "Circadian Rhythm",
        "Computer Graphics",
        "Datasets as Topic",
        "Exons",
        "Gene expression",
        "Humans",
        "Molecular Sequence Annotation",
        "Pineal Gland",
        "Protein Isoforms",
        "RNA Splice Sites",
        "RNA-Seq",
        "RNA-seq",
        "Rats",
        "Reproducibility of Results",
        "Sequence Analysis, RNA",
        "Toxoplasma" ;
    schema1:license "file LICENSE" ;
    schema1:name "bioconductor-junctionseq" ;
    schema1:url "http://bioconductor.org/packages/3.6/bioc/html/JunctionSeq.html" .

