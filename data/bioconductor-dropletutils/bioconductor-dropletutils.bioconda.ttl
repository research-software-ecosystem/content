@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-dropletutils a schema1:SoftwareApplication ;
    schema1:description "Utilities for Handling Single-Cell Droplet Data" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/DropletUtils_1.30.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/DropletUtils/DropletUtils_1.30.0.tar.gz', 'https://bioarchive.galaxyproject.org/DropletUtils_1.30.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-dropletutils/bioconductor-dropletutils_1.30.0_src_all.tar.gz']" ;
    schema1:identifier biotools:DropletUtils ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-dropletutils" ;
    schema1:softwareVersion "1.30.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/DropletUtils.html" ;
    spdx:builtFrom biotools:DropletUtils .

