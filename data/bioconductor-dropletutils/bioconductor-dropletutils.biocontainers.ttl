@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-dropletutils a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1101/177048",
        "doi:10.1101/234872" ;
    schema1:description "Utilities for Handling Single-Cell Droplet Data" ;
    schema1:identifier biotools:DropletUtils ;
    schema1:keywords "Gene expression",
        "Genomics",
        "RNA-Seq",
        "RNA-seq",
        "Sequencing",
        "Transcriptomics" ;
    schema1:license "GPL-3.0" ;
    schema1:name "bioconductor-dropletutils" ;
    schema1:url "https://bioconductor.org/packages/release/bioc/html/DropletUtils.html" .

