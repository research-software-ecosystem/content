@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:maxbin2 a schema1:SoftwareApplication ;
    schema1:description "Software for binning assembled metagenomic sequences based on an expectation-maximization algorithm" ;
    schema1:license "BSD-3-Clause" ;
    schema1:name "maxbin2" ;
    schema1:url "https://sourceforgenet/projects/maxbin2/" .

