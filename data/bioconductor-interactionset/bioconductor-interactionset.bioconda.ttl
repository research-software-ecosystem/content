@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-interactionset a schema1:SoftwareApplication ;
    schema1:description "Base Classes for Storing Genomic Interaction Data" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/InteractionSet_1.34.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/InteractionSet/InteractionSet_1.34.0.tar.gz', 'https://bioarchive.galaxyproject.org/InteractionSet_1.34.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-interactionset/bioconductor-interactionset_1.34.0_src_all.tar.gz']" ;
    schema1:identifier biotools:interactionset ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-interactionset" ;
    schema1:softwareVersion "1.34.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/InteractionSet.html" ;
    spdx:builtFrom biotools:interactionset .

