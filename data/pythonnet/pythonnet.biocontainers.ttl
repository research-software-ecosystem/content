@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:pythonnet a schema1:SoftwareApplication ;
    schema1:description "Python.NET is a package that gives Python programmers nearly seamless integration with the .NET Common Language Runtime (CLR) and provides a powerful application scripting tool for .NET developers." ;
    schema1:license "MIT" ;
    schema1:name "pythonnet" ;
    schema1:url "https://github.com/pythonnet/pythonnet" .

