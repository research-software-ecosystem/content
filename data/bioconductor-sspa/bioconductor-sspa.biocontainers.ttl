        "Genomics",
        "High-Throughput Nucleotide Sequencing",
        "Humans",
        "Linear Models",
        "Microarray experiment",
        "Models, Genetic",
        "Oligonucleotide Array Sequence Analysis",
        "RNA-seq",
        "Sample Size",
        "Sequence Analysis, RNA" ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-sspa" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/SSPA.html" .

