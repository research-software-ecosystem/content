@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:fastp a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/bty560" ;
    schema1:description "A tool designed to provide fast all-in-one preprocessing for fastq files" ;
    schema1:keywords "Humans",
        "Programming Languages",
        "Quality Control",
        "RNA-Seq" ;
    schema1:license "GPL-3.0" ;
    schema1:name "fastp" ;
    schema1:url "https://github.com/OpenGene/fastp/" .

