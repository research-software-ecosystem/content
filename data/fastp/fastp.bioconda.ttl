@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:fastp a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1002/imt2.107" ;
    schema1:description "A ultra-fast FASTQ preprocessor with full features (QC/adapters/trimming/filtering/splitting...)." ;
    schema1:downloadUrl "https://github.com/OpenGene/fastp/archive/v1.3.3.tar.gz" ;
    schema1:identifier biotools:fastp ;
    schema1:license "MIT" ;
    schema1:name "fastp" ;
    schema1:softwareHelp "https://github.com/OpenGene/fastp/blob/v1.3.3/README.md" ;
    schema1:softwareVersion "1.3.3" ;
    schema1:url "https://github.com/OpenGene/fastp" ;
    spdx:builtFrom biotools:fastp .

