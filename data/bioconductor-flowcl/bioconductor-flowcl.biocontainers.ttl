@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-flowcl a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btu807" ;
    schema1:description "Semantic labelling of flow cytometric cell populations." ;
    schema1:identifier biotools:flowcl ;
    schema1:keywords "Cell Physiological Phenomena",
        "Cell biology",
        "Flow Cytometry",
        "Gene Ontology",
        "Humans",
        "Immunophenotyping",
        "Leukocyte Common Antigens",
        "Receptors, CCR7" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-flowcl" ;
    schema1:url "http://bioconductor.org/packages/release/bioc/html/flowCL.html" .

