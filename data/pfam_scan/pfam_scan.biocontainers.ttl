@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:pfam_scan a schema1:SoftwareApplication ;
    schema1:description "Pfam_scan.pl is a perl script calling hmmer v3 to search a fasta file against a library of pfam hmms." ;
    schema1:license "GPL-2.0" ;
    schema1:name "pfam_scan" ;
    schema1:url "http://ftp.ebi.ac.uk/pub/databases/Pfam/Tools/" .

