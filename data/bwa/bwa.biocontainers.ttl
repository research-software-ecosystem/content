@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bwa a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1016/j.ygeno.2017.03.001",
        "doi:10.1093/bioinformatics/btp324",
        "doi:10.1093/bioinformatics/btp698",
        "doi:10.1093/bioinformatics/btu146",
        "doi:10.1186/1471-2105-14-184",
        "doi:10.1186/1471-2164-15-264" ;
    schema1:description "Fast, accurate, memory-efficient aligner for short and long sequencing reads" ;
    schema1:identifier biotools:bwa ;
    schema1:keywords "Base Sequence",
        "Genome, Human",
        "Genomics",
        "Humans",
        "Mapping",
        "Sequence Alignment",
        "Sequence Analysis, DNA" ;
    schema1:license "MIT" ;
    schema1:name "bwa" ;
    schema1:url "http://bio-bwa.sourceforge.net" .

