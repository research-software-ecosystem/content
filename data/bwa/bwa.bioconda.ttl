@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bwa a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btp324",
        "doi:10.1093/bioinformatics/btp698",
        "doi:10.48550/arXiv.1303.3997" ;
    schema1:description "The BWA read mapper." ;
    schema1:downloadUrl "https://github.com/lh3/bwa/archive/v0.7.19.tar.gz" ;
    schema1:identifier biotools:bwa ;
    schema1:license "GPL-3.0-or-later" ;
    schema1:name "bwa" ;
    schema1:softwareHelp "https://github.com/lh3/bwa/blob/v0.7.19/README.md" ;
    schema1:softwareVersion "0.7.19" ;
    schema1:url "https://github.com/lh3/bwa" ;
    spdx:builtFrom biotools:bwa .

