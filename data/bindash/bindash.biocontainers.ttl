@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bindash a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1371/journal.pgen.1007758" ;
    schema1:description "Fast and precise comparison of genomes and metagenomes (in the order of terabytes) on a typical personal laptop" ;
    schema1:keywords "Computer Graphics",
        "DNA, Bacterial",
        "Databases, Genetic",
        "Drug Resistance, Bacterial",
        "Genetic Variation",
        "Genome, Bacterial",
        "Genome-Wide Association Study",
        "Interspersed Repetitive Sequences",
        "Metagenome",
        "Models, Genetic",
        "Mycobacterium tuberculosis",
        "Phenotype",
        "Pseudomonas aeruginosa",
        "Sequence Analysis, DNA",
        "Staphylococcus aureus" ;
    schema1:license "Apache-2.0" ;
    schema1:name "bindash" ;
    schema1:url "https://github.com/zhaoxiaofei/bindash" .

