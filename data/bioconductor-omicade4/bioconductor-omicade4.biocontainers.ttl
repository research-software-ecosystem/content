    schema1:identifier biotools:omicade4 ;
    schema1:keywords "Bioinformatics",
        "Biomarkers, Tumor",
        "Cell Line, Tumor",
        "Cell biology",
        "Clustering",
        "Female",
        "Gene expression",
        "Genomics",
        "High-Throughput Nucleotide Sequencing",
        "Humans",
        "Medicine",
        "Microarray experiment",
        "Omics",
        "Ovarian Neoplasms",
        "Proteome" ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-omicade4" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/omicade4.html" .

