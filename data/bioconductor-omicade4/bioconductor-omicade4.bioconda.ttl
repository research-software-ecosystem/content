@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-omicade4 a schema1:SoftwareApplication ;
    schema1:description "Multiple co-inertia analysis of omics datasets" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/omicade4_1.50.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/omicade4/omicade4_1.50.0.tar.gz', 'https://bioarchive.galaxyproject.org/omicade4_1.50.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-omicade4/bioconductor-omicade4_1.50.0_src_all.tar.gz']" ;
    schema1:identifier biotools:omicade4 ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-omicade4" ;
    schema1:softwareVersion "1.50.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/omicade4.html" ;
    spdx:builtFrom biotools:omicade4 .

