@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-pigengene a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18129/b9.bioc.pigengene" ;
    schema1:description "Infers biological signatures from gene expression data" ;
    schema1:keywords "Clustering",
        "Gene Expression",
        "Transcriptomics" ;
    schema1:license "GPL (>=2)" ;
    schema1:name "bioconductor-pigengene" ;
    schema1:url "https://bioconductor.org/packages/3.8/bioc/html/Pigengene.html" .

