@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-genomictuples a schema1:SoftwareApplication ;
    schema1:citation "doi:10.21105/joss.00020" ;
    schema1:description "Representation and Manipulation of Genomic Tuples" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/GenomicTuples_1.44.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/GenomicTuples/GenomicTuples_1.44.0.tar.gz', 'https://bioarchive.galaxyproject.org/GenomicTuples_1.44.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-genomictuples/bioconductor-genomictuples_1.44.0_src_all.tar.gz']" ;
    schema1:identifier biotools:genomictuples ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-genomictuples" ;
    schema1:softwareVersion "1.44.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/GenomicTuples.html" ;
    spdx:builtFrom biotools:genomictuples .

