@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bwa-mem2 a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1109/IPDPS.2019.00041" ;
    schema1:description "The next version of bwa-mem." ;
    schema1:downloadUrl "https://github.com/bwa-mem2/bwa-mem2/releases/download/v2.3/Source_code_including_submodules.tar.gz" ;
    schema1:identifier biotools:bwa-mem2 ;
    schema1:license "MIT" ;
    schema1:name "bwa-mem2" ;
    schema1:softwareHelp "https://github.com/bwa-mem2/bwa-mem2/blob/v2.3/README.md" ;
    schema1:softwareVersion "2.3" ;
    schema1:url "https://github.com/bwa-mem2/bwa-mem2" ;
    spdx:builtFrom biotools:bwa-mem2 .

