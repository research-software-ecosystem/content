@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:unfazed a schema1:SoftwareApplication ;
    schema1:description "Extended read-backed and allele-balance phasing for de novo variation (snvs, indels, svs, and cnvs)" ;
    schema1:license "MIT" ;
    schema1:name "unfazed" ;
    schema1:url "https://github.com/jbelyeu/unfazed" .

