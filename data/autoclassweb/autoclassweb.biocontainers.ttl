@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:autoclassweb a schema1:SoftwareApplication ;
    schema1:description "A web app to run autoclass c bayesian clustering" ;
    schema1:identifier biotools:autoclassweb ;
    schema1:keywords "Clustering",
        "genomics",
        "omics",
        "proteomics" ;
    schema1:license "SPDX:BSD-3-Clause" ;
    schema1:name "autoclassweb" ;
    schema1:url "https://github.com/pierrepo/autoclassweb" .

