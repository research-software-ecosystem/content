@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:squid a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s13059-018-1421-5" ;
    schema1:description "Detector for fusion-gene and non-fusion-gene transcriptomic structural variations from RNA-seq data" ;
    schema1:keywords "Cell Line, Tumor",
        "Gene Expression Profiling",
        "Gene Fusion",
        "Genes, Tumor Suppressor",
        "Genomic Structural Variation",
        "Humans",
        "RNA-Seq",
        "Sequence Alignment",
        "Sequence Analysis, RNA" ;
    schema1:license "BSD 3" ;
    schema1:name "squid" ;
    schema1:url "https://github.com/Kingsford-Group/squid" .

