@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:anvio-minimal a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/s41564-020-00834-3" ;
    schema1:description "An interactive analysis and visualization platform for omics data" ;
    schema1:downloadUrl "https://github.com/merenlab/anvio/releases/download/v9/anvio-9.tar.gz" ;
    schema1:identifier biotools:anvio ;
    schema1:license "GPL-3.0-or-later" ;
    schema1:name "anvio-minimal" ;
    schema1:softwareHelp "https://anvio.org/learn/" ;
    schema1:softwareVersion "9" ;
    schema1:url "https://merenlab.org/software/anvio/" ;
    spdx:builtFrom biotools:anvio .

