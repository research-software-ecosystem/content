@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:anvio-minimal a schema1:SoftwareApplication ;
    schema1:description "An interactive analysis and visualization platform for omics data" ;
    schema1:keywords "Genetics",
        "Genomics",
        "Metagenomics",
        "Transcriptomics" ;
    schema1:license "GPL-3.0" ;
    schema1:name "anvio-minimal" ;
    schema1:url "https://github.com/merenlab/anvio" .

