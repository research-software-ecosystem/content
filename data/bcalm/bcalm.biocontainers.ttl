@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bcalm a schema1:SoftwareApplication ;
    schema1:description "BCALM 2 is a bioinformatics tool for constructing the compacted de Bruijn graph from sequencing data." ;
    schema1:license "MIT" ;
    schema1:name "bcalm" ;
    schema1:url "https://github.com/GATB/bcalm" .

