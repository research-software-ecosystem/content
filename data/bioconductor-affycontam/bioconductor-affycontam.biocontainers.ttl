    schema1:keywords "Computational Biology",
        "Data architecture, analysis and design",
        "Gene Expression Profiling",
        "Genomics",
        "High-Throughput Screening Assays",
        "Microarray experiment",
        "Programming Languages",
        "User-Computer Interface" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-affycontam" ;
    schema1:url "http://bioconductor.org/packages/release/bioc/html/affyContam.html" .

