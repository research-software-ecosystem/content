@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:zagros a schema1:SoftwareApplication ;
    schema1:description "Zagros is a motif-discovery tool for clip-seq data." ;
    schema1:identifier biotools:zagros ;
    schema1:keywords "DNA",
        "Genomics",
        "Protein-RNA interaction",
        "RNA",
        "Sequences" ;
    schema1:license "GPL-3.0" ;
    schema1:name "zagros" ;
    schema1:url "http://smithlabresearch.org/software/zagros/" .

