@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:ngsutils a schema1:SoftwareApplication ;
    schema1:description "Tools for next-generation sequencing analysis http://ngsutils.org" ;
    schema1:downloadUrl "https://github.com/ngsutils/ngsutils/archive/ngsutils-0.5.9.tar.gz" ;
    schema1:identifier biotools:ngsutils ;
    schema1:license "BSD" ;
    schema1:name "ngsutils" ;
    schema1:softwareVersion "0.5.9" ;
    schema1:url "http://ngsutils.org" ;
    spdx:builtFrom biotools:ngsutils .

