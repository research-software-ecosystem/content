@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:ngsutils a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/bts731" ;
    schema1:description "Tools for next-gen sequencing analysis" ;
    schema1:identifier biotools:ngsutils ;
    schema1:keywords "Genomics",
        "High-Throughput Nucleotide Sequencing",
        "Transcriptomics" ;
    schema1:license "BSD-3-Clause" ;
    schema1:name "ngsutils" ;
    schema1:url "https://github.com/ngsutils/ngsutils" .

