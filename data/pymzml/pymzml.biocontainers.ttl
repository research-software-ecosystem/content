@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:pymzml a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/bts066",
        "doi:10.1093/bioinformatics/bty046" ;
    schema1:description "Python module to parse mzml data based on celementtree." ;
    schema1:identifier biotools:pymzml ;
    schema1:keywords "Data Compression",
        "Mass Spectrometry",
        "Mass spectrometry",
        "Proteomics",
        "Proteomics experiment" ;
    schema1:license "MIT" ;
    schema1:name "pymzml" ;
    schema1:url "https://github.com/pymzml/pymzML" .

