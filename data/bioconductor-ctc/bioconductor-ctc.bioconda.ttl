@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-ctc a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Cluster and Tree Conversion." ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/ctc_1.80.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/ctc/ctc_1.80.0.tar.gz', 'https://bioarchive.galaxyproject.org/ctc_1.80.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-ctc/bioconductor-ctc_1.80.0_src_all.tar.gz']" ;
    schema1:identifier biotools:ctc ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-ctc" ;
    schema1:softwareVersion "1.80.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/ctc.html" ;
    spdx:builtFrom biotools:ctc .

