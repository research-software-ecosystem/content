@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:gapcloser a schema1:SoftwareApplication ;
    schema1:description "A novel short-read assembly method that can build a de novo draft assembly for the human-sized genomes" ;
    schema1:license "GPL-3.0-only" ;
    schema1:name "gapcloser" ;
    schema1:url "http://soap.genomics.org.cn/gapcloser.html" .

