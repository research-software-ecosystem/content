@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:fit_nbinom a schema1:SoftwareApplication ;
    schema1:description "Script to fit negative binomial distributions via maximum likelihood estimation." ;
    schema1:license "GNU General Public License v3.0" ;
    schema1:name "fit_nbinom" ;
    schema1:url "https://github.com/joachimwolff/fit_nbinom/" .

