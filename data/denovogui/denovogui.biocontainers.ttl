@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:denovogui a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1021/pr4008078" ;
    schema1:description "Graphical user interface for de novo sequencing of tandem mass spectra." ;
    schema1:identifier biotools:denovogui ;
    schema1:keywords "Computer Graphics",
        "Mass Spectrometry",
        "Mass spectra",
        "Proteins",
        "Proteomics",
        "Proteomics experiment",
        "Sequence Analysis, Protein",
        "User-Computer Interface" ;
    schema1:license "Apache-2.0" ;
    schema1:name "denovogui" ;
    schema1:url "https://github.com/compomics/denovogui" .

