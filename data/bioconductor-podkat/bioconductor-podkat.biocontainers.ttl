@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-podkat a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Position-Dependent Kernel Association Test" ;
    schema1:identifier biotools:podkat ;
    schema1:keywords "Computational Biology",
        "Epigenomics",
        "Gene Expression Profiling",
        "Genetics",
        "Genomics",
        "Genotype and phenotype",
        "High-Throughput Screening Assays",
        "Machine learning",
        "Programming Languages",
        "User-Computer Interface",
        "Whole genome sequencing" ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-podkat" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/podkat.html" .

