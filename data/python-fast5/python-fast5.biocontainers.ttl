@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:python-fast5 a schema1:SoftwareApplication ;
    schema1:description "Library for reading Oxford Nanopore Fast5 files" ;
    schema1:license "MIT" ;
    schema1:name "python-fast5" ;
    schema1:url "https://github.com/mateidavid/fast5" .

