@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:trf a schema1:SoftwareApplication ;
    schema1:description "Tandem Repeats Finder is a program to locate and display tandem repeats in DNA sequences." ;
    schema1:downloadUrl "https://github.com/Benson-Genomics-Lab/TRF/archive/v4.10.0-rc.2.tar.gz" ;
    schema1:identifier biotools:trf ;
    schema1:license "AGPL-3.0-or-later" ;
    schema1:name "trf" ;
    schema1:softwareHelp "https://tandem.bu.edu/trf/trf.html" ;
    schema1:softwareVersion "4.10.0rc2" ;
    schema1:url "https://tandem.bu.edu/trf/trf.html" ;
    spdx:builtFrom biotools:trf .

