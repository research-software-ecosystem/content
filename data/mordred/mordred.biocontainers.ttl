@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:mordred a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s13321-018-0258-y" ;
    schema1:description "A molecular descriptor calculator" ;
    schema1:identifier biotools:mordred ;
    schema1:keywords "Molecular modelling",
        "Small molecules",
        "Structure analysis" ;
    schema1:license "BSD-3-Clause" ;
    schema1:name "mordred" ;
    schema1:url "https://github.com/mordred-descriptor/mordred" .

