@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:phylommand a schema1:SoftwareApplication ;
    schema1:citation "doi:10.12688/F1000RESEARCH.10446.1" ;
    schema1:description "Command-line phylogenetics tools." ;
    schema1:identifier biotools:phylommand ;
    schema1:keywords "Clustering",
        "Genetics",
        "Phylogeny",
        "Sequence Alignment" ;
    schema1:license "GPL-3.0" ;
    schema1:name "phylommand" ;
    schema1:url "https://github.com/mr-y/phylommand" .

