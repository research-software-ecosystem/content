@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:genblastg a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btr342" ;
    schema1:description "Genblast is a program suite, consisting of two programs: genblasta and genblastg. genblasta parses local alignments, or high-scoring segment pairs (hsps) produced by local sequence alignment programs such as blast and wu-blast and identify groups of hsps." ;
    schema1:keywords "Animals",
        "Arabidopsis",
        "Caenorhabditis elegans",
        "Computational Biology",
        "Genomics",
        "Models, Genetic",
        "Sequence Alignment" ;
    schema1:license "GNU" ;
    schema1:name "genblastg" ;
    schema1:url "http://genome.sfu.ca/genblast/download.html" .

