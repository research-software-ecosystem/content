@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:pp-sketchlib a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1101/gr.241455.118" ;
    schema1:description "Library of sketching functions used by PopPUNK" ;
    schema1:keywords "Bacteria",
        "Bacterial Infections",
        "Bacterial Typing Techniques",
        "Genetic Variation",
        "Genome, Bacterial",
        "Genomics" ;
    schema1:license "Apache-2.0" ;
    schema1:name "pp-sketchlib" ;
    schema1:url "https://github.com/johnlees/pp-sketchlib" .

