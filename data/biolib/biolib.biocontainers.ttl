@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:biolib a schema1:SoftwareApplication ;
    schema1:description "Package for common tasks in bioinformatics." ;
    schema1:license "GPL-3.0" ;
    schema1:name "biolib" ;
    schema1:url "http://pypi.python.org/pypi/biolib/" .

