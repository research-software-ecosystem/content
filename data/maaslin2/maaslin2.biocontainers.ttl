@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:maaslin2 a schema1:SoftwareApplication ;
    schema1:description "MaAsLin2 is comprehensive R package for efficiently determining multivariable association between microbial meta'omic features and clinical metadata." ;
    schema1:keywords "Genomics",
        "Metagenome",
        "Metagenomics" ;
    schema1:license "Custom License" ;
    schema1:name "maaslin2" ;
    schema1:url "https://github.com/biobakery/Maaslin2" .

