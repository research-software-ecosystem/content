@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:riboseed a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/gky212" ;
    schema1:description "Riboseed: assemble across rdna regions." ;
    schema1:keywords "Base Sequence",
        "Chromosome Mapping",
        "DNA, Bacterial",
        "DNA, Ribosomal",
        "Escherichia coli",
        "Genome, Bacterial",
        "Genomics",
        "High-Throughput Nucleotide Sequencing",
        "Klebsiella pneumoniae",
        "Sequence Analysis, DNA" ;
    schema1:license "MIT" ;
    schema1:name "riboseed" ;
    schema1:url "https://github.com/nickp60/riboSeed" .

