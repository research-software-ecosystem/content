@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:dig2 a schema1:SoftwareApplication ;
    schema1:description "dig2 is a simple but flexible in silico digester of protein sequences in the FASTA format. It allows for almost any enzyme to be simulated, including MS/MS enzymes to generate CID or ECD/ETD fragments." ;
    schema1:downloadUrl "http://www.ms-utils.org/dig2/dig2.c" ;
    schema1:identifier biotools:dig2 ;
    schema1:license "GPL3" ;
    schema1:name "dig2" ;
    schema1:softwareVersion "1.0" ;
    schema1:url "http://www.ms-utils.org/dig2/dig2.html" ;
    spdx:builtFrom biotools:dig2 .

