@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-simbindprofiles a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Similar Binding Profiles" ;
    schema1:identifier biotools:simbindprofiles ;
    schema1:keywords "Computational Biology",
        "DNA binding sites",
        "Gene Expression Profiling",
        "Genomics",
        "High-Throughput Screening Assays",
        "Microarray experiment",
        "Programming Languages",
        "User-Computer Interface" ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-simbindprofiles" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/SimBindProfiles.html" .

