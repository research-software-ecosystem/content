@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-simbindprofiles a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Similar Binding Profiles" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.18/bioc/src/contrib/SimBindProfiles_1.40.0.tar.gz', 'https://bioconductor.org/packages/3.18/bioc/src/contrib/Archive/SimBindProfiles/SimBindProfiles_1.40.0.tar.gz', 'https://bioarchive.galaxyproject.org/SimBindProfiles_1.40.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-simbindprofiles/bioconductor-simbindprofiles_1.40.0_src_all.tar.gz']" ;
    schema1:identifier biotools:simbindprofiles ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-simbindprofiles" ;
    schema1:softwareVersion "1.40.0" ;
    schema1:url "https://bioconductor.org/packages/3.18/bioc/html/SimBindProfiles.html" ;
    spdx:builtFrom biotools:simbindprofiles .

