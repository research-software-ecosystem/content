@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:hhsuite a schema1:SoftwareApplication ;
    schema1:author "milot-mirdita" ;
    schema1:citation "doi:10.1186/s12859-019-3019-7" ;
    schema1:description "HH-suite3 for fast remote homology detection and deep protein annotation." ;
    schema1:downloadUrl "https://github.com/soedinglab/hh-suite/archive/v3.3.0.tar.gz" ;
    schema1:identifier biotools:hh-suite ;
    schema1:license "GPL-3.0-or-later" ;
    schema1:maintainer "milot-mirdita" ;
    schema1:name "hhsuite" ;
    schema1:softwareHelp "https://github.com/soedinglab/hh-suite/wiki" ;
    schema1:softwareVersion "3.3.0" ;
    schema1:url "https://github.com/soedinglab/hh-suite" ;
    spdx:builtFrom biotools:hh-suite .

