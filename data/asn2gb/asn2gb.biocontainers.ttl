@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:asn2gb a schema1:SoftwareApplication ;
    schema1:description "Asn2gb converts asn1 format sequence records to genbank format" ;
