@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:pysamstats a schema1:SoftwareApplication ;
    schema1:description "Calculate read mapping stats from SAM/BAM/CRAM" ;
    schema1:downloadUrl "https://github.com/alimanfoo/pysamstats/archive/v1.1.2.tar.gz" ;
    schema1:identifier biotools:pysamstats ;
    schema1:license "MIT" ;
    schema1:name "pysamstats" ;
    schema1:softwareVersion "1.1.2" ;
    schema1:url "https://github.com/alimanfoo/pysamstats" ;
    spdx:builtFrom biotools:pysamstats .

