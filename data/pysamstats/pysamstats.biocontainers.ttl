@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:pysamstats a schema1:SoftwareApplication ;
    schema1:description "Calculate read mapping stats from SAM/BAM/CRAM" ;
    schema1:identifier biotools:pysamstats ;
    schema1:keywords "Sequence Alignment",
        "Sequencing",
        "Statistics and probability" ;
    schema1:license "MIT" ;
    schema1:name "pysamstats" ;
    schema1:url "https://github.com/alimanfoo/pysamstats" .

