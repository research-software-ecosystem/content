@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-dmrcaller a schema1:SoftwareApplication ;
    schema1:description "Differentially Methylated Regions Caller" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/DMRcaller_1.42.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/DMRcaller/DMRcaller_1.42.0.tar.gz', 'https://bioarchive.galaxyproject.org/DMRcaller_1.42.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-dmrcaller/bioconductor-dmrcaller_1.42.0_src_all.tar.gz']" ;
    schema1:identifier biotools:dmrcaller ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-dmrcaller" ;
    schema1:softwareVersion "1.42.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/DMRcaller.html" ;
    spdx:builtFrom biotools:dmrcaller .

