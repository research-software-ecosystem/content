@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-cispath a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/1752-0509-9-s1-s1" ;
    schema1:description "Visualization and management of the protein-protein interaction networks." ;
    schema1:identifier biotools:cispath ;
    schema1:keywords "Computational Biology",
        "Computer Graphics",
        "Data visualisation",
        "Humans",
        "Information Dissemination",
        "Internet",
        "Protein Interaction Maps",
        "Protein interactions",
        "Proteomics",
        "User-Computer Interface" ;
    schema1:license "GPL (>= 3)" ;
    schema1:name "bioconductor-cispath" ;
    schema1:url "http://bioconductor.org/packages/3.6/bioc/html/cisPath.html" .

