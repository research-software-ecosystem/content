@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-cispath a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/1752-0509-9-s1-s1" ;
    schema1:description "Visualization and management of the protein-protein interaction networks." ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/cisPath_1.46.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/cisPath/cisPath_1.46.0.tar.gz', 'https://bioarchive.galaxyproject.org/cisPath_1.46.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-cispath/bioconductor-cispath_1.46.0_src_all.tar.gz']" ;
    schema1:identifier biotools:cispath ;
    schema1:license "GPL (>= 3)" ;
    schema1:name "bioconductor-cispath" ;
    schema1:softwareVersion "1.46.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/cisPath.html" ;
    spdx:builtFrom biotools:cispath .

