@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:agat a schema1:SoftwareApplication ;
    schema1:citation "doi:10.5281/zenodo.3552717" ;
    schema1:description "Another gff analysis toolkit (agat). suite of tools to handle gene annotations in any gtf/gff format." ;
    schema1:keywords "Genomics",
        "Transcriptome" ;
    schema1:license "GPL-3.0" ;
    schema1:name "agat" ;
    schema1:url "https://github.com/NBISweden/AGAT" .

