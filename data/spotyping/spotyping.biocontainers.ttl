@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:spotyping a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/S13073-016-0270-7",
        "doi:10.1186/s13073-016-0270-7" ;
    schema1:description "Spotyping: fast and accurate in silico mycobacterium spoligotyping from sequence reads" ;
    schema1:identifier biotools:spotyping ;
    schema1:keywords "Bacterial Typing Techniques",
        "Computer Simulation",
        "Genetic variation",
        "High-Throughput Nucleotide Sequencing",
        "Humans",
        "Microbiology",
        "Mycobacterium tuberculosis",
        "Sequence Analysis, DNA",
        "Sequence composition, complexity and repeats",
        "Sequencing",
        "Time Factors",
        "Tuberculosis" ;
    schema1:license "Apache-2.0" ;
    schema1:name "spotyping" ;
    schema1:url "https://github.com/xiaeryu/SpoTyping" .

