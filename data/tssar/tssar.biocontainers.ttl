@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:tssar a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/1471-2105-15-89" ;
    schema1:description "TSSAR is a Web Service for predicting bacterial Transcription Start Sites from dRNA-seq data." ;
    schema1:identifier biotools:tssar ;
    schema1:keywords "Base Sequence",
        "Databases, Nucleic Acid",
        "Gene transcripts",
        "Genome",
        "Genomics",
        "Helicobacter pylori",
        "High-Throughput Nucleotide Sequencing",
        "Humans",
        "RNA-Seq",
        "RNA-seq",
        "Sequence Alignment",
        "Sequence Analysis, RNA",
        "Sequencing",
        "Stenotrophomonas maltophilia",
        "Transcriptomics" ;
    schema1:license "GNU General Public License v2.0" ;
    schema1:name "tssar" ;
    schema1:url "http://rna.tbi.univie.ac.at/TSSAR" .

