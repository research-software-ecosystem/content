@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-idpmisc a schema1:SoftwareApplication ;
    schema1:description "Different high-level graphics functions for displaying large datasets, displaying circular data in a very flexible way, finding local maxima, brewing color ramps, drawing nice arrows, zooming 2D-plots, creating figures with differently colored margin and plot region" ;
    schema1:license "GPL (≥ 3)" ;
    schema1:name "r-idpmisc" ;
    schema1:url "https://CRAN.R-project.org/package=IDPmisc" .

