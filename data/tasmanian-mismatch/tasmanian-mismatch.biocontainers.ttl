@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:tasmanian-mismatch a schema1:SoftwareApplication ;
    schema1:description "Tasmanian tool to analyze mismatches at read and position in high throughput sequencing data" ;
    schema1:license "GPL-3.0" ;
    schema1:name "tasmanian-mismatch" ;
    schema1:url "https://github.com/nebiolabs/tasmanian-mismatch" .

