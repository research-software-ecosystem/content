@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:deltapd a schema1:SoftwareApplication ;
    schema1:citation "doi:10.5281/zenodo.4301163" ;
    schema1:description "DeltaPD is a tool used to determine outliers in a gene tree when compared against a reference tree." ;
    schema1:keywords "Genomics" ;
    schema1:license "AGPL-3" ;
    schema1:name "deltapd" ;
    schema1:url "https://github.com/Ecogenomics/DeltaPD" .

