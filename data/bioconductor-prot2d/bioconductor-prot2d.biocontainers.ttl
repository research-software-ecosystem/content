@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-prot2d a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18129/b9.bioc.prot2d" ;
    schema1:description "The purpose of this package is to analyze (i.e. Normalize and select significant spots) data issued from 2D GEl experiments" ;
    schema1:keywords "Proteomics" ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-prot2d" ;
    schema1:url "http://bioconductor.org/packages/3.6/bioc/html/prot2D.html" .

