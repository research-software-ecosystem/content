@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:dfast a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btx713" ;
    schema1:description "DDBJ Fast Annotation and Submission Tool - Prokaryotic genome annotation pipeline" ;
    schema1:identifier biotools:dfast ;
    schema1:keywords "Bacteria",
        "Databases, Nucleic Acid",
        "Genetics",
        "Genome, Bacterial",
        "Genomics",
        "Molecular Sequence Annotation",
        "Nucleic acid structure analysis",
        "Sequence Analysis, DNA",
        "Sequence analysis" ;
    schema1:license "GPL-3.0" ;
    schema1:name "dfast" ;
    schema1:url "https://dfast.nig.ac.jp" .

