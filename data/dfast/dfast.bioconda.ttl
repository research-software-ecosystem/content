@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:dfast a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btx713" ;
    schema1:description "DDBJ Fast Annotation and Submission Tool - Prokaryotic genome annotation pipeline" ;
    schema1:downloadUrl "https://github.com/nigyta/dfast_core/archive/1.3.9.tar.gz" ;
    schema1:identifier biotools:dfast ;
    schema1:license "GPL-3.0-only" ;
    schema1:name "dfast" ;
    schema1:softwareHelp "https://github.com/nigyta/dfast_core/blob/1.3.9/README.md" ;
    schema1:softwareVersion "1.3.9" ;
    schema1:url "https://dfast.nig.ac.jp" ;
    spdx:builtFrom biotools:dfast .

