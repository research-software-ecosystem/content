@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:sequana a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/bty034",
        "doi:10.1101/162701" ;
    schema1:description "A set of standalone application and snakemake pipelines dedicated to NGS (new generation sequencing) analysis" ;
    schema1:keywords "RNA-Seq",
        "Transcriptomics" ;
    schema1:license "BSD 3-clause" ;
    schema1:name "sequana" ;
    schema1:url "https://github.com/sequana/sequana/" .

