@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:vcfpy a schema1:SoftwareApplication ;
    schema1:description "Python 3 VCF library with good support for both reading and writing" ;
    schema1:license "MIT" ;
    schema1:name "vcfpy" ;
    schema1:url "https://github.com/bihealth/vcfpy" .

