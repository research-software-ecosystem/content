@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-gpseq a schema1:SoftwareApplication ;
    schema1:description "Some functions for modeling sequence read counts as a generalized poisson model and to use this model for detecting differentially expressed genes in different conditions and differentially spliced exons." ;
    schema1:license "GPL-2" ;
    schema1:name "r-gpseq" ;
    schema1:url "https://CRAN.R-project.org/package=GPseq" .

