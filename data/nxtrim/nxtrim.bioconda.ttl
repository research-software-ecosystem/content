@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:nxtrim a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btv057" ;
    schema1:description "Software to remove Nextera Mate Pair adapters and categorise reads according to the orientation implied by the adapter location." ;
    schema1:downloadUrl "https://github.com/sequencing/NxTrim/archive/v0.4.3.tar.gz" ;
    schema1:identifier biotools:nxtrim ;
    schema1:license "BSD-2-Clause" ;
    schema1:name "nxtrim" ;
    schema1:softwareHelp "https://github.com/sequencing/NxTrim" ;
    schema1:softwareVersion "0.4.3" ;
    schema1:url "https://github.com/sequencing/NxTrim" ;
    spdx:builtFrom biotools:nxtrim .

