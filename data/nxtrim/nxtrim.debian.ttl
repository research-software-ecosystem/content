@prefix debianmed: <https://salsa.debian.org/med-team/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

debianmed:nxtrim a schema1:SoftwareApplication ;
    schema1:identifier "bio.tools:nxtrim",
        "conda:bioconda:nxtrim" ;
    schema1:license "unknown" ;
    schema1:name "nxtrim" ;
    schema1:softwareVersion "0.4.3" ;
    schema1:url "https://github.com/sequencing/NxTrim" ;
    spdx:builtFrom "nxtrim" .

