@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-reactomepa a schema1:SoftwareApplication ;
    schema1:description "Reactome Pathway Analysis" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/ReactomePA_1.50.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/ReactomePA/ReactomePA_1.50.0.tar.gz', 'https://bioarchive.galaxyproject.org/ReactomePA_1.50.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-reactomepa/bioconductor-reactomepa_1.50.0_src_all.tar.gz']" ;
    schema1:identifier biotools:reactomepa ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-reactomepa" ;
    schema1:softwareVersion "1.50.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/ReactomePA.html" ;
    spdx:builtFrom biotools:reactomepa .

