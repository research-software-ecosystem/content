@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-reactomepa a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1039/c5mb00663e" ;
    schema1:description "Reactome Pathway Analysis" ;
    schema1:identifier biotools:reactomepa ;
    schema1:keywords "Animals",
        "Chromatin Immunoprecipitation",
        "Data visualisation",
        "Databases, Factual",
        "High-Throughput Nucleotide Sequencing",
        "Humans",
        "Metabolic Networks and Pathways",
        "Molecular interactions, pathways and networks",
        "Protein Interaction Maps",
        "Proteomics",
        "Signal Transduction" ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-reactomepa" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/ReactomePA.html" .

