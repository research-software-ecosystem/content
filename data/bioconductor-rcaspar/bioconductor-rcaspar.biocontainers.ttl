@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-rcaspar a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "A package for survival time prediction based on a piecewise baseline hazard Cox regression model." ;
    schema1:identifier biotools:rcaspar ;
    schema1:keywords "Computational Biology",
        "Data visualisation",
        "Gene Expression",
        "Gene Expression Profiling",
        "Gene expression",
        "Genetics",
        "Genomics",
        "High-Throughput Screening Assays",
        "Microarray experiment",
        "Programming Languages",
        "Proteomics",
        "User-Computer Interface" ;
    schema1:license "GPL (>=3)" ;
    schema1:name "bioconductor-rcaspar" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/RCASPAR.html" .

