@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-rcaspar a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "A package for survival time prediction based on a piecewise baseline hazard Cox regression model." ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/RCASPAR_1.56.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/RCASPAR/RCASPAR_1.56.0.tar.gz', 'https://bioarchive.galaxyproject.org/RCASPAR_1.56.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-rcaspar/bioconductor-rcaspar_1.56.0_src_all.tar.gz']" ;
    schema1:identifier biotools:rcaspar ;
    schema1:license "GPL (>=3)" ;
    schema1:name "bioconductor-rcaspar" ;
    schema1:softwareVersion "1.56.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/RCASPAR.html" ;
    spdx:builtFrom biotools:rcaspar .

