@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-ncdfflow a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1016/j.copbio.2012.09.003" ;
    schema1:description "ncdfFlow: A package that provides HDF5 based storage for flow cytometry data." ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/ncdfFlow_2.56.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/ncdfFlow/ncdfFlow_2.56.0.tar.gz', 'https://bioarchive.galaxyproject.org/ncdfFlow_2.56.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-ncdfflow/bioconductor-ncdfflow_2.56.0_src_all.tar.gz']" ;
    schema1:identifier biotools:ncdfflow ;
    schema1:license "AGPL-3.0-only" ;
    schema1:name "bioconductor-ncdfflow" ;
    schema1:softwareVersion "2.56.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/ncdfFlow.html" ;
    spdx:builtFrom biotools:ncdfflow .

