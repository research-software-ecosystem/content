@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:libdeflate a schema1:SoftwareApplication ;
    schema1:description "libdeflate is a library for fast, whole-buffer DEFLATE-based compression and decompression." ;
    schema1:license "MIT" ;
    schema1:name "libdeflate" ;
    schema1:url "https://github.com/ebiggers/libdeflate" .

