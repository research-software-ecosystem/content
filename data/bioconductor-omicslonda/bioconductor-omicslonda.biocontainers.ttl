    schema1:description "Omics longitudinal differential analysis" ;
    schema1:keywords "Metabolomics",
        "Proteomics",
        "Transcriptomics" ;
    schema1:license "MIT" ;
    schema1:name "bioconductor-omicslonda" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/OmicsLonDA.html" .

