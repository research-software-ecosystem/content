@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:gcen a schema1:SoftwareApplication ;
    schema1:citation "doi:10.3390/cimb44040100" ;
    schema1:description "GCEN: an easy-to-use toolkit for Gene Co-Expression Network analysis and lncRNAs annotation." ;
    schema1:downloadUrl "https://github.com/wen-chen/gcen/releases/download/v0.6.3/gcen-0.6.3-source.tar.gz" ;
    schema1:identifier biotools:gcen ;
    schema1:license "GPL-3.0-or-later" ;
    schema1:name "gcen" ;
    schema1:softwareHelp "https://www.biochen.org/gcen" ;
    schema1:softwareVersion "0.6.3" ;
    schema1:url "https://www.biochen.org/gcen" ;
    spdx:builtFrom biotools:gcen .

