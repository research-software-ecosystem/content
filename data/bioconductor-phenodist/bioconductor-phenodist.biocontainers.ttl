@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-phenodist a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18129/b9.bioc.phenodist" ;
    schema1:description "PhenoDist is designed for measuring phenotypic distance in image-based high-throughput screening, in order to identify strong phenotypes and to group treatments into functional clusters." ;
    schema1:license "LGPL-2.1" ;
    schema1:name "bioconductor-phenodist" ;
    schema1:url "http://bioconductor.org/packages/3.6/bioc/html/phenoDist.html" .

