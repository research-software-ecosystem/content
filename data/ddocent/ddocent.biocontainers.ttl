biocontainers:ddocent a schema1:SoftwareApplication ;
    schema1:citation "doi:10.7287/peerj.preprints.314v1" ;
    schema1:description " ddocent is  an interactive bash wrapper to qc, assemble, map, and call snps from all types of rad data" ;
