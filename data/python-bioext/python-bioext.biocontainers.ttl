@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:python-bioext a schema1:SoftwareApplication ;
    schema1:description "A few handy bioinformatics tools not already in biopython" ;
    schema1:license "GPL-3.0" ;
    schema1:name "python-bioext" ;
    schema1:url "https://github.com/veg/BioExt.git" .

