@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:ray a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/gb-2012-13-12-r122" ;
    schema1:description "Parallel genome assemblies for parallel DNA sequencing" ;
    schema1:downloadUrl "https://downloads.sourceforge.net/project/denovoassembler/Ray-2.3.1.tar.bz2" ;
    schema1:identifier biotools:ray ;
    schema1:license "GPL3" ;
    schema1:name "ray" ;
    schema1:softwareVersion "2.3.1" ;
    schema1:url "http://denovoassembler.sourceforge.net/index.html" ;
    spdx:builtFrom biotools:ray .

