@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:ray a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1089/cmb.2009.0238",
        "doi:10.1186/gb-2012-13-12-r122" ;
    schema1:description "De novoassembly of single genomes and metagenomes. also analyses microbe abundance and performs taxonomic profiling as well as making gene ontology profiling. it can also compare genomic content between samples." ;
    schema1:identifier biotools:ray ;
    schema1:keywords "Base Sequence",
        "Biology",
        "Computational Biology",
        "Contig Mapping",
        "Genome",
        "High-Throughput Nucleotide Sequencing",
        "Metagenome",
        "Sequence Analysis, DNA" ;
    schema1:license "GPL-3.0" ;
    schema1:name "ray" ;
    schema1:url "http://denovoassembler.sourceforge.net" .

