@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:unitas a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s12864-017-4031-9" ;
    schema1:description "Unitas is a convenient tool for efficient annotation of small non-coding rna sequence datasets produced by next generation sequencing." ;
    schema1:identifier biotools:unitas ;
    schema1:keywords "HeLa Cells",
        "High-Throughput Nucleotide Sequencing",
        "Humans",
        "Molecular Sequence Annotation",
        "Nucleic acid structure analysis",
        "RNA",
        "RNA, Small Untranslated",
        "Sequence analysis" ;
    schema1:license "Not available" ;
    schema1:name "unitas" ;
    schema1:url "http://www.smallrnagroup.uni-mainz.de/software.html" .

