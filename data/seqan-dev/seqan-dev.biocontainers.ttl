@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:seqan-dev a schema1:SoftwareApplication ;
    schema1:description "An open source c++ library of efficient algorithms and data structures for the analysis of sequences with the focus on biological data. our library applies a unique generic design that guarantees high performance, generality, extensibility, and integration with other libraries. the library is easy to use and simplifies the development of new software tools with a minimal loss of performance. additionally, it includes several ready-made command line tools for common tasks in sequence analysis." ;
    schema1:keywords "Genomics" ;
    schema1:license "BSD-3-Clause" ;
    schema1:name "seqan-dev" ;
    schema1:url "http://www.seqan.de" .

