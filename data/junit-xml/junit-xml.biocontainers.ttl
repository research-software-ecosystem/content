@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:junit-xml a schema1:SoftwareApplication ;
    schema1:description "Creates JUnit XML test result documents that can be read by tools such as Jenkins" ;
    schema1:license "MIT" ;
    schema1:name "junit-xml" ;
    schema1:url "None" .

