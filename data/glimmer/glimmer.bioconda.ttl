@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:glimmer a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btm009" ;
    schema1:description "Glimmer is a system for finding genes in microbial DNA" ;
    schema1:downloadUrl "https://ccb.jhu.edu/software/glimmer/glimmer302b.tar.gz" ;
    schema1:identifier biotools:glimmer ;
    schema1:license "Custom" ;
    schema1:name "glimmer" ;
    schema1:softwareVersion "3.02" ;
    schema1:url "https://ccb.jhu.edu/software/glimmer/index.shtml" ;
    spdx:builtFrom biotools:glimmer .

