@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:glimmer a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btm009" ;
    schema1:description "Glimmer is a system for finding genes in microbial dna" ;
    schema1:identifier biotools:glimmer ;
    schema1:keywords "Animals",
        "Artifacts",
        "Chromosome Mapping",
        "Clustering",
        "DNA, Bacterial",
        "Decapodiformes",
        "Gene structure",
        "Genome, Bacterial",
        "Genomics",
        "Metagenomics",
        "Prochloron",
        "Reproducibility of Results",
        "Sensitivity and Specificity",
        "Sequence Analysis, DNA",
        "Symbiosis" ;
    schema1:license "Custom License" ;
    schema1:name "glimmer" ;
    schema1:url "https://github.com/davek44/Glimmer-MG" .

