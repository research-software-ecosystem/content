@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:htstream a schema1:SoftwareApplication ;
    schema1:description "A high throughput sequence read toolset using a streaming approach facilitated by Linux pipes" ;
    schema1:keywords "Genomics" ;
    schema1:license "Apache-2.0" ;
    schema1:name "htstream" ;
    schema1:url "https://github.com/s4hts/HTStream" .

