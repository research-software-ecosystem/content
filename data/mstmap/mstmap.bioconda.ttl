@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:mstmap a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1371/journal.pgen.1000212" ;
    schema1:description "Accurate construction of genetic maps (Wu et al., PLoS Genetics, 4(10):e1000212, 2008)" ;
    schema1:downloadUrl "http://www.cs.ucr.edu/~stelo/pub/mstmap_v1.tar.gz" ;
    schema1:identifier biotools:mstmap ;
    schema1:license "GPL3" ;
    schema1:name "mstmap" ;
    schema1:softwareVersion "1" ;
    schema1:url "http://mstmap.org/" ;
    spdx:builtFrom biotools:mstmap .

