@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:sepp a schema1:SoftwareApplication ;
    schema1:description "SATe-enabled phylogenetic placement." ;
    schema1:downloadUrl "https://github.com/smirarab/sepp/archive/v4.5.6.tar.gz" ;
    schema1:identifier biotools:sepp ;
    schema1:license "GPL-3.0-or-later" ;
    schema1:name "sepp" ;
    schema1:softwareHelp "https://github.com/smirarab/sepp/blob/v4.5.6/README.md" ;
    schema1:softwareVersion "4.5.6" ;
    schema1:url "https://github.com/smirarab/sepp" ;
    spdx:builtFrom biotools:sepp .

