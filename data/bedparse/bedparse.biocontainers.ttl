@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bedparse a schema1:SoftwareApplication ;
    schema1:citation "doi:10.21105/joss.01228",
        "doi:10.5281/zenodo.2578820" ;
    schema1:description "A simple library and cli tool to manipulate bed files" ;
    schema1:license "MIT" ;
    schema1:name "bedparse" ;
    schema1:url "https://github.com/tleonardi/bedparse" .

