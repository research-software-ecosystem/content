@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:gmap a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/bti310",
        "doi:10.1093/bioinformatics/btq057",
        "doi:10.7490/f1000research.1114334.1" ;
    schema1:description "Genomic mapping and alignment program for mrna and est sequences." ;
    schema1:identifier biotools:gmap ;
    schema1:keywords "Base Sequence",
        "DNA, Recombinant",
        "Genetic Variation",
        "Genomics",
        "Mapping",
        "Polymorphism, Single Nucleotide",
        "RNA Splicing",
        "RNA-Seq",
        "Transcriptome" ;
    schema1:license "Apache-2.0" ;
    schema1:name "gmap" ;
    schema1:url "http://research-pub.gene.com/gmap/" .

