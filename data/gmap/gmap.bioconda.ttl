@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:gmap a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/bti310",
        "doi:10.1093/bioinformatics/btq057" ;
    schema1:description "Genomic mapping and alignment program for mRNA and EST sequences." ;
    schema1:downloadUrl "http://research-pub.gene.com/gmap/src/gmap-gsnap-2025-07-31.tar.gz" ;
    schema1:identifier biotools:gmap ;
    schema1:license "Apache-2.0" ;
    schema1:name "gmap" ;
    schema1:softwareHelp "http://research-pub.gene.com/gmap" ;
    schema1:softwareVersion "2025.07.31" ;
    schema1:url "http://research-pub.gene.com/gmap" ;
    spdx:builtFrom biotools:gmap .

