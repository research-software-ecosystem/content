@prefix debianmed: <https://salsa.debian.org/med-team/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

debianmed:gmap a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/bti310",
        "doi:10.1093/bioinformatics/btq057" ;
    schema1:description "spliced and SNP-tolerant alignment for mRNA and short reads" ;
    schema1:identifier "bio.tools:gmap",
        "conda:bioconda:gmap",
        "omictools:OMICS_15072",
        "scicrunch:SCR_008992" ;
    schema1:keywords "field::biology",
        "field::biology:bioinformatics",
        "field::biology:structural",
        "role::program",
        "use::analysing" ;
    schema1:license "unknown" ;
    schema1:name "gmap" ;
    schema1:softwareVersion "2025-07-31+ds" ;
    schema1:url "http://research-pub.gene.com/gmap" ;
    spdx:builtFrom "gmap" .

