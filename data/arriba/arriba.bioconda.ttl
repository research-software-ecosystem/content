@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:arriba a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1101/gr.257246.119" ;
    schema1:description "Fast and accurate gene fusion detection from RNA-Seq data." ;
    schema1:downloadUrl "https://github.com/suhrig/arriba/releases/download/v2.5.1/arriba_v2.5.1.tar.gz" ;
    schema1:identifier biotools:Arriba ;
    schema1:license "MIT" ;
    schema1:name "arriba" ;
    schema1:softwareHelp "https://github.com/suhrig/arriba/wiki/01-Home" ;
    schema1:softwareVersion "2.5.1" ;
    schema1:url "https://github.com/suhrig/arriba" ;
    spdx:builtFrom biotools:Arriba .

