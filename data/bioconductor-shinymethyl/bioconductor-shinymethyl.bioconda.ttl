@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-shinymethyl a schema1:SoftwareApplication ;
    schema1:description "Interactive visualization for Illumina methylation arrays" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/shinyMethyl_1.46.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/shinyMethyl/shinyMethyl_1.46.0.tar.gz', 'https://bioarchive.galaxyproject.org/shinyMethyl_1.46.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-shinymethyl/bioconductor-shinymethyl_1.46.0_src_all.tar.gz']" ;
    schema1:identifier biotools:shinymethyl ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-shinymethyl" ;
    schema1:softwareVersion "1.46.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/shinyMethyl.html" ;
    spdx:builtFrom biotools:shinymethyl .

