@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:seqstats a schema1:SoftwareApplication ;
    schema1:description "Quick summary statistics on fasta/fastq(.gz) files" ;
    schema1:license "MIT" ;
    schema1:name "seqstats" ;
    schema1:url "https://github.com/clwgg/seqstats" .

