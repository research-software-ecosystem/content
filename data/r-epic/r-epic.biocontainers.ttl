@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-epic a schema1:SoftwareApplication ;
    schema1:citation "doi:10.7554/eLife.26476.001" ;
    schema1:description "Estimate the Proportion of Immune and Cancer cells from bulk gene expression data." ;
    schema1:keywords "Gene Expression",
        "RNA-Seq" ;
    schema1:license "Custom License" ;
    schema1:name "r-epic" ;
    schema1:url "https://github.com/GfellerLab/EPIC" .

