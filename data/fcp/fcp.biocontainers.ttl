@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:fcp a schema1:SoftwareApplication ;
    schema1:description "Homology- and composition-based classifiers for assigning a taxonomic attribution to metagenomic fragments." ;
    schema1:license "GPL-3.0" ;
    schema1:name "fcp" ;
    schema1:url "https://github.com/dparks1134/FragmentClassificationPackage" .

