@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:nucleosome_prediction a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/gkr246" ;
    schema1:description "This tool allows you to submit a genomic sequence and to recieve a prediction of the nucleosomes positions on it," ;
    schema1:identifier biotools:genie ;
    schema1:keywords "Animals",
        "Data mining",
        "Gene Expression Profiling",
        "Genes",
        "Genomics",
        "Heart",
        "Humans",
        "Internet",
        "MEDLINE",
        "Mice",
        "Models, Animal",
        "Zebrafish" ;
    schema1:license "LGPLv2" ;
    schema1:name "nucleosome_prediction" ;
    schema1:url "https://genie.weizmann.ac.il/software/nucleo_prediction.html" .

