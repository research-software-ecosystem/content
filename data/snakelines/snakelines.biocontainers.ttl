@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:snakelines a schema1:SoftwareApplication ;
    schema1:description "Computational pipelines for processing of paired-end sequencing reads." ;
    schema1:keywords "Genomics",
        "Metagenomics",
        "RNA-Seq",
        "Transcriptomics" ;
    schema1:license "Not available" ;
    schema1:name "snakelines" ;
    schema1:url "https://github.com/jbudis/snakelines" .

