@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-rnaseqpower a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1089/cmb.2012.0283" ;
    schema1:description "Sample size for RNAseq studies" ;
    schema1:identifier biotools:rnaseqpower ;
    schema1:keywords "Animals",
        "Gene Expression Profiling",
        "High-Throughput Nucleotide Sequencing",
        "Humans",
        "Models, Biological",
        "RNA, Messenger",
        "RNA-Seq",
        "Sample Size" ;
    schema1:license "LGPL-2.0" ;
    schema1:name "bioconductor-rnaseqpower" ;
    schema1:url "https://bioconductor.org/packages/release/bioc/html/RNASeqPower.html" .

