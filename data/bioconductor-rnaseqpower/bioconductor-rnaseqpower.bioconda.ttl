@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-rnaseqpower a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1089/cmb.2012.0283" ;
    schema1:description "Sample size for RNAseq studies" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/RNASeqPower_1.46.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/RNASeqPower/RNASeqPower_1.46.0.tar.gz', 'https://bioarchive.galaxyproject.org/RNASeqPower_1.46.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-rnaseqpower/bioconductor-rnaseqpower_1.46.0_src_all.tar.gz']" ;
    schema1:identifier biotools:rnaseqpower ;
    schema1:license "LGPL (>=2)" ;
    schema1:name "bioconductor-rnaseqpower" ;
    schema1:softwareVersion "1.46.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/RNASeqPower.html" ;
    spdx:builtFrom biotools:rnaseqpower .

