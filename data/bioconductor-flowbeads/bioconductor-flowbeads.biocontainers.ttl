@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-flowbeads a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "This package extends flowcore to provide functionality specific to bead data. one of the goals of this package is to automate analysis of bead data for the purpose of normalisation." ;
    schema1:identifier biotools:flowbeads ;
    schema1:keywords "Biophysics",
        "Computational Biology",
        "Data management",
        "Gene Expression Profiling",
        "Genomics",
        "High-Throughput Screening Assays",
        "Laboratory techniques",
        "Programming Languages",
        "User-Computer Interface" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-flowbeads" ;
    schema1:url "http://bioconductor.org/packages/release/bioc/html/flowBeads.html" .

