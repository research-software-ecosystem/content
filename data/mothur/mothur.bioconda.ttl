@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:mothur a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1128/AEM.01541-09" ;
    schema1:description "This project seeks to develop a single piece of open-source, expandable software to fill the bioinformatics needs of the microbial ecology community." ;
    schema1:downloadUrl "https://github.com/mothur/mothur/archive/refs/tags/v1.48.5.tar.gz" ;
    schema1:identifier biotools:mothur ;
    schema1:license "GPL-3.0-or-later" ;
    schema1:name "mothur" ;
    schema1:softwareHelp "https://mothur.org/wiki/mothur_manual" ;
    schema1:softwareVersion "1.48.5" ;
    schema1:url "https://www.mothur.org" ;
    spdx:builtFrom biotools:mothur .

