@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:mothur a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1128/AEM.01541-09" ;
    schema1:description "Sequence analysis suite for research on microbiota" ;
    schema1:keywords "Biodiversity",
        "Computational Biology",
        "Environmental Microbiology",
        "Metagenomics",
        "Sequence Analysis, DNA" ;
    schema1:license "GPL-3.0+" ;
    schema1:name "mothur" ;
    schema1:url "https://github.com/mothur/mothur" .

