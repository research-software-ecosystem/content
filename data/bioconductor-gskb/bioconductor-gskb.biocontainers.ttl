@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-gskb a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18129/b9.bioc.gskb" ;
    schema1:description "Gene set data for pathway analysis in mouse" ;
    schema1:keywords "Functional genomics",
        "Gene Expression",
        "Genetics",
        "Genomics" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-gskb" ;
    schema1:url "https://bioconductor.org/packages/3.11/data/experiment/html/gskb.html" .

