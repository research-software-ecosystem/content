@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:ngsep a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btz275" ;
    schema1:description "NGSEP - Next Generation Sequencing Experience Platform" ;
    schema1:downloadUrl "https://master.dl.sourceforge.net/project/ngsep/Library/NGSEPcore_4.0.1.jar" ;
    schema1:identifier biotools:ngsep ;
    schema1:license "GPL-3" ;
    schema1:name "ngsep" ;
    schema1:softwareVersion "4.0.1" ;
    schema1:url "https://github.com/NGSEP/NGSEPcore" ;
    spdx:builtFrom biotools:ngsep .

