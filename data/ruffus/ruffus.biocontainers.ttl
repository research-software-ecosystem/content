@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:ruffus a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btq524" ;
    schema1:description "Light-weight python computational pipeline management" ;
    schema1:keywords "Computational Biology",
        "Databases, Factual",
        "Internet" ;
    schema1:license "MIT" ;
    schema1:name "ruffus" ;
    schema1:url "http://www.ruffus.org.uk/" .

