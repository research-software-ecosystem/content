@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:spliceai a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1016/j.cell.2018.12.015" ;
    schema1:description "A deep learning-based tool to identify splice variants." ;
    schema1:keywords "Alternative Splicing",
        "Autistic Disorder",
        "Deep Learning",
        "Exons",
        "Forecasting",
        "Humans",
        "Intellectual Disability",
        "Introns",
        "Neural Networks, Computer",
        "RNA Precursors",
        "RNA Splice Sites",
        "RNA Splicing" ;
    schema1:license "GPL-3.0" ;
    schema1:name "spliceai" ;
    schema1:url "https://github.com/Illumina/SpliceAI" .

