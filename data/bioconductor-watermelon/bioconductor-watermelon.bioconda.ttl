@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-watermelon a schema1:SoftwareApplication ;
    schema1:description "Illumina DNA methylation array normalization and metrics" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/wateRmelon_2.16.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/wateRmelon/wateRmelon_2.16.0.tar.gz', 'https://bioarchive.galaxyproject.org/wateRmelon_2.16.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-watermelon/bioconductor-watermelon_2.16.0_src_all.tar.gz']" ;
    schema1:identifier biotools:watermelon ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-watermelon" ;
    schema1:softwareVersion "2.16.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/wateRmelon.html" ;
    spdx:builtFrom biotools:watermelon .

