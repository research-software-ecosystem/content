@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:seaview a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/molbev/msp259" ;
    schema1:description "Multiplatform graphical user interface designed to facilitate alignment and phylogenic tree building from molecular sequences." ;
    schema1:identifier biotools:seaview ;
    schema1:keywords "Computer Graphics",
        "Data visualisation",
        "Phylogeny",
        "Sequence Alignment",
        "Sequence analysis",
        "User-Computer Interface" ;
    schema1:license "GPL-3.0+ with PHYLIP exception" ;
    schema1:name "seaview" ;
    schema1:url "http://doua.prabi.fr/software/seaview" .

