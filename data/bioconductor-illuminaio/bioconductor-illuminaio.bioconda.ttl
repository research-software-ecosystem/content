@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-illuminaio a schema1:SoftwareApplication ;
    schema1:description "Parsing Illumina Microarray Output Files" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/illuminaio_0.52.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/illuminaio/illuminaio_0.52.0.tar.gz', 'https://bioarchive.galaxyproject.org/illuminaio_0.52.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-illuminaio/bioconductor-illuminaio_0.52.0_src_all.tar.gz']" ;
    schema1:identifier biotools:illuminaio ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-illuminaio" ;
    schema1:softwareVersion "0.52.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/illuminaio.html" ;
    spdx:builtFrom biotools:illuminaio .

