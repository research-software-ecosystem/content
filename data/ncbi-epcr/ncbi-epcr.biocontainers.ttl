@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:ncbi-epcr a schema1:SoftwareApplication ;
    schema1:description "Tool to test a dna sequence for the presence of sequence tagged sites" ;
    schema1:license "public-domain" ;
    schema1:name "ncbi-epcr" ;
    schema1:url "https://www.ncbi.nlm.nih.gov/tools/epcr/" .

