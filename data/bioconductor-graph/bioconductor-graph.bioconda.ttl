@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-graph a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "graph: A package to handle graph data structures" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/graph_1.84.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/graph/graph_1.84.0.tar.gz', 'https://bioarchive.galaxyproject.org/graph_1.84.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-graph/bioconductor-graph_1.84.0_src_all.tar.gz']" ;
    schema1:identifier biotools:graph ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-graph" ;
    schema1:softwareVersion "1.84.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/graph.html" ;
    spdx:builtFrom biotools:graph .

