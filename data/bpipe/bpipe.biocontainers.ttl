@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bpipe a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/bts167" ;
    schema1:description "This software provides a platform for running big bioinformatics jobs that consist of a series of processing stages – known as ‘pipelines’." ;
    schema1:identifier biotools:bpipe ;
    schema1:keywords "Bioinformatics",
        "Computational Biology",
        "Informatics",
        "Programming Languages",
        "Workflow",
        "Workflows" ;
    schema1:license "BSD-3-clause" ;
    schema1:name "bpipe" ;
    schema1:url "https://github.com/ssadedin/bpipe" .

