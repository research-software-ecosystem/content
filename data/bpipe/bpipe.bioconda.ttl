@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bpipe a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/bts167" ;
    schema1:description "Bpipe - a tool for running and managing bioinformatics pipelines" ;
    schema1:downloadUrl "https://github.com/ssadedin/bpipe/releases/download/0.9.13/bpipe-0.9.13.tar.gz" ;
    schema1:identifier biotools:bpipe ;
    schema1:license "BSD-3-Clause" ;
    schema1:name "bpipe" ;
    schema1:softwareVersion "0.9.13" ;
    schema1:url "http://docs.bpipe.org/" ;
    spdx:builtFrom biotools:bpipe .

