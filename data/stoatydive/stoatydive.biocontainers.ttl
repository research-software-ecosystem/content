@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:stoatydive a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1101/799114" ;
    schema1:description "Stoatydive is a tool to evaluate and classify predicted peak profiles to assess the binding specificity of a protein to its targets." ;
    schema1:keywords "Clustering" ;
    schema1:license "GPL-3.0" ;
    schema1:name "stoatydive" ;
    schema1:url "https://github.com/BackofenLab/StoatyDive" .

