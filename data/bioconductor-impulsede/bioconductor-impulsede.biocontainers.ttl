@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-impulsede a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btw665" ;
    schema1:description "Detection of DE genes in time series data using impulse models" ;
    schema1:identifier biotools:impulsede ;
    schema1:keywords "Animals",
        "Clustering",
        "Gene Expression Profiling",
        "Gene Expression Regulation",
        "Gene expression",
        "Mice",
        "Sequence Analysis, RNA",
        "Sequencing",
        "T-Lymphocytes",
        "Time" ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-impulsede" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/ImpulseDE.html" .

