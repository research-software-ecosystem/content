@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-knowseq a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18129/b9.bioc.knowseq" ;
    schema1:description "KnowSeq R/Bioc package Beyond the traditional Transcriptomic pipeline" ;
    schema1:keywords "Gene Expression",
        "Genetics",
        "Metabolomics",
        "Proteomics",
        "RNA-Seq",
        "Transcriptomics" ;
    schema1:license "GPL (>=2)" ;
    schema1:name "bioconductor-knowseq" ;
    schema1:url "https://bioconductor.org/packages/3.10/bioc/html/KnowSeq.html" .

