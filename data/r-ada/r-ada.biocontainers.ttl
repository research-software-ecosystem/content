@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-ada a schema1:SoftwareApplication ;
    schema1:description "Performs discrete, real, and gentle boost under both exponential and logistic loss on a given data set. The package ada provides a straightforward, well-documented, and broad boosting routine for classification, ideally suited for small to moderate-sized data sets." ;
    schema1:license "GPL" ;
    schema1:name "r-ada" ;
    schema1:url "https://CRAN.R-project.org/package=ada" .

