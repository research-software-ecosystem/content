@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:cafe a schema1:SoftwareApplication ;
    schema1:description "Computational Analysis of gene Family Evolution (CAFE)" ;
    schema1:downloadUrl "https://github.com/hahnlab/CAFE5/releases/download/v5.1/CAFE5-5.1.0.tar.gz" ;
    schema1:identifier biotools:cafe ;
    schema1:license "IU OPEN SOURCE LICENSE (see https://github.com/hahnlab/CAFE5/blob/master/LICENSE)" ;
    schema1:name "cafe" ;
    schema1:softwareVersion "5.1.0" ;
    schema1:url "https://github.com/hahnlab/CAFE5" ;
    spdx:builtFrom biotools:cafe .

