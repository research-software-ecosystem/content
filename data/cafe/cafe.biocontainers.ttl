@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:cafe a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btu028" ;
    schema1:description "Computational Analysis of gene Family Evolution (CAFE)" ;
    schema1:identifier biotools:cafe ;
    schema1:keywords "Chromosome Aberrations",
        "Gene Expression",
        "Genetics",
        "Markov Chains",
        "Microarray experiment",
        "Molecular genetics",
        "Oligonucleotide Array Sequence Analysis" ;
    schema1:license "Custom License" ;
    schema1:name "cafe" ;
    schema1:url "https://hahnlab.github.io/CAFE/" .

