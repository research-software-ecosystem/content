@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-swath2stats a schema1:SoftwareApplication ;
    schema1:description "Transform and Filter SWATH Data for Statistical Packages" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/SWATH2stats_1.40.1.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/SWATH2stats/SWATH2stats_1.40.1.tar.gz', 'https://bioarchive.galaxyproject.org/SWATH2stats_1.40.1.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-swath2stats/bioconductor-swath2stats_1.40.1_src_all.tar.gz']" ;
    schema1:identifier biotools:swath2stats ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-swath2stats" ;
    schema1:softwareVersion "1.40.1" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/SWATH2stats.html" ;
    spdx:builtFrom biotools:swath2stats .

