@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:alder a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1534/genetics.112.147330" ;
    schema1:description "The ALDER software computes the weighted linkage disequilibrium (LD) statistic for making inference about population admixture" ;
    schema1:downloadUrl "http://cb.csail.mit.edu/cb/alder/alder_v1.03.tar.gz" ;
    schema1:identifier biotools:alder ;
    schema1:license "Custom OSS" ;
    schema1:name "alder" ;
    schema1:softwareVersion "1.03" ;
    schema1:url "http://cb.csail.mit.edu/cb/alder/" ;
    spdx:builtFrom biotools:alder .

