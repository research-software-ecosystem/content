@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-geoquery a schema1:SoftwareApplication ;
    schema1:description "Get data from NCBI Gene Expression Omnibus (GEO)" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/GEOquery_2.78.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/GEOquery/GEOquery_2.78.0.tar.gz', 'https://bioarchive.galaxyproject.org/GEOquery_2.78.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-geoquery/bioconductor-geoquery_2.78.0_src_all.tar.gz']" ;
    schema1:identifier biotools:geoquery ;
    schema1:license "MIT + file LICENSE" ;
    schema1:name "bioconductor-geoquery" ;
    schema1:softwareVersion "2.78.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/GEOquery.html" ;
    spdx:builtFrom biotools:geoquery .

