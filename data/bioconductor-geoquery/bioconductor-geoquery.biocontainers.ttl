@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-geoquery a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btm254" ;
    schema1:description "Get data from NCBI Gene Expression Omnibus (GEO)" ;
    schema1:identifier biotools:geoquery ;
    schema1:keywords "Cluster Analysis",
        "Computational Biology",
        "Computers",
        "Data Interpretation, Statistical",
        "Data management",
        "Databases, Factual",
        "Databases, Genetic",
        "Gene Expression",
        "Gene Expression Profiling",
        "Gene expression",
        "Information Storage and Retrieval",
        "Oligonucleotide Array Sequence Analysis",
        "Programming Languages" ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-geoquery" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/GEOquery.html" .

