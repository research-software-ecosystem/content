@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:spotyping3 a schema1:SoftwareApplication ;
    schema1:citation "DOI:10.1186/s13073-016-0270-7" ;
    schema1:description "SpoTyping3: fast and accurate in silico Mycobacterium spoligotyping from sequence reads, compatible with Python3" ;
    schema1:license "GPL-3.0" ;
    schema1:name "spotyping3" ;
    schema1:url "https://github.com/matnguyen/SpoTyping" .

