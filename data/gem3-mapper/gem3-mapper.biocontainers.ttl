@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:gem3-mapper a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.2221" ;
    schema1:description "The GEM read mapper (v3)." ;
    schema1:identifier biotools:GEM_Mapper ;
    schema1:keywords "Base Sequence",
        "Computational Biology",
        "Genome",
        "Genomics",
        "Humans",
        "Sequence Alignment",
        "Sequence Analysis, DNA" ;
    schema1:license "GPL-3.0" ;
    schema1:name "gem3-mapper" ;
    schema1:url "https://github.com/smarco/gem3-mapper" .

