@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:gem3-mapper a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.2221" ;
    schema1:description "The GEM read mapper (v3)." ;
    schema1:downloadUrl "https://github.com/smarco/gem3-mapper/archive/v3.6.1.tar.gz" ;
    schema1:identifier biotools:GEM_Mapper ;
    schema1:license "GPL-3.0" ;
    schema1:name "gem3-mapper" ;
    schema1:softwareVersion "3.6.1" ;
    schema1:url "https://github.com/smarco/gem3-mapper" ;
    spdx:builtFrom biotools:GEM_Mapper .

