@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:pbccs a schema1:SoftwareApplication ;
    schema1:description "Pbccs - generate accurate consensus sequences from a single smrtbell" ;
    schema1:license "BSD-3-Clause-Clear" ;
    schema1:name "pbccs" ;
    schema1:url "https://github.com/PacificBiosciences/pbbioconda" .

