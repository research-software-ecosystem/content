@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-xmapbridge a schema1:SoftwareApplication ;
    schema1:description "Export plotting files to the xmapBridge for visualisation in X:Map" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/xmapbridge_1.68.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/xmapbridge/xmapbridge_1.68.0.tar.gz', 'https://bioarchive.galaxyproject.org/xmapbridge_1.68.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-xmapbridge/bioconductor-xmapbridge_1.68.0_src_all.tar.gz']" ;
    schema1:identifier biotools:xmapbridge ;
    schema1:license "LGPL-3" ;
    schema1:name "bioconductor-xmapbridge" ;
    schema1:softwareVersion "1.68.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/xmapbridge.html" ;
    spdx:builtFrom biotools:xmapbridge .

