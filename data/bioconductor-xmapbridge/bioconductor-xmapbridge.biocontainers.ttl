    schema1:description "Export plotting files to the xmapBridge for visualisation in X:Map" ;
    schema1:identifier biotools:xmapbridge ;
    schema1:keywords "Alternative Splicing",
        "Animals",
        "Chromosome Mapping",
        "Computer Graphics",
        "Databases, Genetic",
        "Exons",
        "Gene Expression Profiling",
        "Genomics",
        "Humans",
        "Internet",
        "Mapping",
        "Mice",
        "Oligonucleotide Array Sequence Analysis",
        "Rats",
        "User-Computer Interface" ;
    schema1:license "LGPL-3" ;
    schema1:name "bioconductor-xmapbridge" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/xmapbridge.html" .

