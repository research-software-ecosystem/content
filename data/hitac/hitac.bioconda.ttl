@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:hitac a schema1:SoftwareApplication ;
    schema1:author "mirand863" ;
    schema1:description "A hierarchical taxonomic classifier for fungal ITS sequences" ;
    schema1:downloadUrl "https://pypi.io/packages/source/h/hitac/hitac-2.2.2.tar.gz" ;
    schema1:identifier biotools:hitac ;
    schema1:license "BSD-3-Clause" ;
    schema1:maintainer "mirand863" ;
    schema1:name "hitac" ;
    schema1:softwareVersion "2.2.2" ;
    schema1:url "https://gitlab.com/dacs-hpi/hitac" ;
    spdx:builtFrom biotools:hitac .

