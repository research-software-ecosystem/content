@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:hitac a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1101/2020.04.24.014852" ;
    schema1:description "A hierarchical taxonomy classifier for fungal its sequences" ;
    schema1:identifier biotools:hitac ;
    schema1:license "GPL-3.0" ;
    schema1:name "hitac" ;
    schema1:url "https://gitlab.com/dacs-hpi/hitac" .

