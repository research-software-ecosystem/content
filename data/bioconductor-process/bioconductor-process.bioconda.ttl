@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-process a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Ciphergen SELDI-TOF Processing" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/PROcess_1.82.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/PROcess/PROcess_1.82.0.tar.gz', 'https://bioarchive.galaxyproject.org/PROcess_1.82.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-process/bioconductor-process_1.82.0_src_all.tar.gz']" ;
    schema1:identifier biotools:process ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-process" ;
    schema1:softwareVersion "1.82.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/PROcess.html" ;
    spdx:builtFrom biotools:process .

