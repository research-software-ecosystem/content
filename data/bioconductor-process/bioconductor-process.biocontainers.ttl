@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-process a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "A package for processing protein mass spectrometry data." ;
    schema1:identifier biotools:process ;
    schema1:keywords "Biochemistry",
        "Computational Biology",
        "Gene Expression Profiling",
        "Genomics",
        "High-Throughput Screening Assays",
        "Mass spectrometry",
        "Programming Languages",
        "Proteomics",
        "Proteomics experiment",
        "User-Computer Interface" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-process" ;
    schema1:url "http://bioconductor.org/packages/release/bioc/html/PROcess.html" .

