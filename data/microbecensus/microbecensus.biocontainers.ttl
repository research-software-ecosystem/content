@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:microbecensus a schema1:SoftwareApplication ;
    schema1:description "A command-line tool for estimating average genome size from shotgun sequence data" ;
    schema1:keywords "Genomics",
        "Metagenome",
        "Metagenomics" ;
    schema1:license "GNU General Public License v3.0" ;
    schema1:name "microbecensus" ;
    schema1:url "https://github.com/snayfach/MicrobeCensus" .

