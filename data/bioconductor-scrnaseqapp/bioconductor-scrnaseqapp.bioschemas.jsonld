      "sc:author": "Jianhong Ou",
      "sc:citation": {
        "@id": "https://doi.org/10.18129/B9.bioc.scRNAseqApp"
      },
      "sc:description": "The scRNAseqApp is a Shiny app package designed for interactive visualization of single-cell data. It is an enhanced version derived from the ShinyCell, repackaged to accommodate multiple datasets. The app enables users to visualize data containing various types of information simultaneously, facilitating comprehensive analysis. Additionally, it includes a user management system to regulate database accessibility for different users.",
      "sc:license": "GPL-3.0-only",
