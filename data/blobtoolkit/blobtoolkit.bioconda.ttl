@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:blobtoolkit a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1534/g3.119.400908" ;
    schema1:description "Interactive quality assessment of genome assemblies." ;
    schema1:downloadUrl "https://github.com/genomehubs/blobtoolkit/archive/4.5.3.tar.gz" ;
    schema1:identifier biotools:BlobToolKit ;
    schema1:license "MIT" ;
    schema1:name "blobtoolkit" ;
    schema1:softwareHelp "https://blobtoolkit.genomehubs.org" ;
    schema1:softwareVersion "4.5.3" ;
    schema1:url "https://github.com/blobtoolkit/blobtoolkit" ;
    spdx:builtFrom biotools:BlobToolKit .

