@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioinfokit a schema1:SoftwareApplication ;
    schema1:citation "doi:10.5281/zenodo.3629446",
        "doi:10.5281/zenodo.3965241" ;
    schema1:description "The bioinfokit toolkit aimed to provide various easy-to-use functionalities to analyze, visualize, and interpret the biological data generated from genome-scale omics experiments." ;
    schema1:keywords "Clustering",
        "Gene Expression",
        "Transcriptome" ;
    schema1:license "Not available" ;
    schema1:name "bioinfokit" ;
    schema1:url "https://reneshbedre.github.io/blog/howtoinstall.html" .

