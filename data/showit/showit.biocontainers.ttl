@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:showit a schema1:SoftwareApplication ;
    schema1:description "Simple and sensible display of images in python" ;
    schema1:license "MIT" ;
    schema1:name "showit" ;
    schema1:url "https://github.com/freeman-lab/showit" .

