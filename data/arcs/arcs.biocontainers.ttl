@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:arcs a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1101/100750",
        "doi:10.1186/s12859-018-2243-x" ;
    schema1:description "Scaffolding genome sequence assemblies using 10X Genomics data" ;
    schema1:keywords "Genomics" ;
    schema1:license "GPL-3.0" ;
    schema1:name "arcs" ;
    schema1:url "https://github.com/bcgsc/arcs" .

