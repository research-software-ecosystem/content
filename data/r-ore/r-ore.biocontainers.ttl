@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-ore a schema1:SoftwareApplication ;
    schema1:description "Provides an alternative to R's built-in functionality for handling regular expressions, based on the Oniguruma library. Offers first-class compiled regex objects, partial matching and function-based substitutions, amongst other features." ;
    schema1:license "BSD_3_clause + file LICENCE" ;
    schema1:name "r-ore" ;
    schema1:url "None" .

