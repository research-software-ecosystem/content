@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:ectyper a schema1:SoftwareApplication ;
    schema1:description "ECtyper is a python program for serotyping E. coli genomes" ;
    schema1:license "Apache-2.0" ;
    schema1:name "ectyper" ;
    schema1:url "https://github.com/phac-nml/ecoli_serotyping" .

