@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-preda a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btr404" ;
    schema1:description "Position Related Data Analysis" ;
    schema1:identifier biotools:preda ;
    schema1:keywords "Functional genomics",
        "Genetic Variation",
        "Genetics",
        "Genomics",
        "Oncology",
        "Quantitative genetics" ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-preda" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/PREDA.html" .

