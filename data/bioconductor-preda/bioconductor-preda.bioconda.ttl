@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-preda a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btr404" ;
    schema1:description "Position Related Data Analysis" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/PREDA_1.52.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/PREDA/PREDA_1.52.0.tar.gz', 'https://bioarchive.galaxyproject.org/PREDA_1.52.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-preda/bioconductor-preda_1.52.0_src_all.tar.gz']" ;
    schema1:identifier biotools:preda ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-preda" ;
    schema1:softwareVersion "1.52.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/PREDA.html" ;
    spdx:builtFrom biotools:preda .

