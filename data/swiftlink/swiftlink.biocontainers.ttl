@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:swiftlink a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/bts704" ;
    schema1:description "A multipoint parametric linkage analysis tool for large consanguineous pedigrees and is primarily targeted at pedigrees that cannot be analysed by a Lander-Green algorithm based program, i.e. many markers, but larger pedigrees." ;
    schema1:keywords "Markov Chains" ;
    schema1:license "GPL-3.0" ;
    schema1:name "swiftlink" ;
    schema1:url "https://github.com/ajm/swiftlink" .

