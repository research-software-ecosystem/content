@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:hmftools-linx a schema1:SoftwareApplication ;
    schema1:description "Linx is an annotation, interpretation and visualisation tool for structural variants" ;
    schema1:keywords "Clustering",
        "Genetics",
        "Genomics",
        "Sequence Alignment" ;
    schema1:license "GPL-3" ;
    schema1:name "hmftools-linx" ;
    schema1:url "https://github.com/hartwigmedical/hmftools/tree/master/sv-linx" .

