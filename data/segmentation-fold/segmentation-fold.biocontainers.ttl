@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:segmentation-fold a schema1:SoftwareApplication ;
    schema1:description "RNA-Folding with predefined segments including K-turns and loop-E-motifs" ;
    schema1:license "GPL-3.0" ;
    schema1:name "segmentation-fold" ;
    schema1:url "https://github.com/yhoogstrate/segmentation-fold" .

