@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-lncpipereporter a schema1:SoftwareApplication ;
    schema1:description "Automatically Aggregating and Summarizing lncRNA Analysis Results for Interactive Report" ;
    schema1:license "GPL-2" ;
    schema1:name "r-lncpipereporter" ;
    schema1:url "https://github.com/bioinformatist/LncPipeReporter" .

