@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:nebulizer a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/gkw343",
        "doi:10.1093/nar/gky379" ;
    schema1:description "Command-line utilities to help with managing users, data libraries and tools in a galaxy instance" ;
    schema1:keywords "Datasets as Topic",
        "Genomics",
        "Humans",
        "Information Dissemination",
        "International Cooperation",
        "Internet",
        "Metabolomics",
        "Molecular Imaging",
        "Proteomics",
        "Reproducibility of Results",
        "User-Computer Interface" ;
    schema1:license "Academic Free License" ;
    schema1:name "nebulizer" ;
    schema1:url "https://github.com/pjbriggs/nebulizer" .

