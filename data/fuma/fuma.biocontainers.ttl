@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:fuma a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btv721" ;
    schema1:description "FuMa: reporting overlap in RNA-seq detected fusion genes" ;
    schema1:identifier biotools:fuma ;
    schema1:keywords "DNA",
        "Gene structure",
        "Genetics",
        "Genome",
        "Genomics",
        "Humans",
        "RNA",
        "RNA-Seq",
        "Sequence Analysis, RNA",
        "Transcriptome" ;
    schema1:license "GPL-3.0" ;
    schema1:name "fuma" ;
    schema1:url "https://github.com/yhoogstrate/fuma/" .

