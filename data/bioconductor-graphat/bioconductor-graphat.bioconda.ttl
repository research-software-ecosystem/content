@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-graphat a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/bth405" ;
    schema1:description "Graph Theoretic Association Tests" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/GraphAT_1.82.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/GraphAT/GraphAT_1.82.0.tar.gz', 'https://bioarchive.galaxyproject.org/GraphAT_1.82.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-graphat/bioconductor-graphat_1.82.0_src_all.tar.gz']" ;
    schema1:identifier biotools:graphat ;
    schema1:license "LGPL" ;
    schema1:name "bioconductor-graphat" ;
    schema1:softwareVersion "1.82.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/GraphAT.html" ;
    spdx:builtFrom biotools:graphat .

