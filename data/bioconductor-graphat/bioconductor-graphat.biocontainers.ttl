@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-graphat a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/bth405" ;
    schema1:description "Graph Theoretic Association Tests" ;
    schema1:identifier biotools:graphat ;
    schema1:keywords "Chromosome Mapping",
        "GWAS study",
        "Gene Expression Profiling",
        "Numerical Analysis, Computer-Assisted",
        "Reproducibility of Results",
        "Saccharomyces cerevisiae",
        "Sensitivity and Specificity",
        "Sequence Alignment",
        "Sequence Analysis, DNA" ;
    schema1:license "LGPL" ;
    schema1:name "bioconductor-graphat" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/GraphAT.html" .

