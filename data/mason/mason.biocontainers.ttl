biocontainers:mason a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1371/journal.pone.0049110" ;
    schema1:description "A fast, feature-rich and hackable read simulator for the simulation of ngs and sanger data." ;
    schema1:identifier biotools:mason ;
    schema1:keywords "Base Composition",
        "Electronic Data Processing",
        "Genomics",
        "Humans",
        "Sequence Analysis, DNA" ;
    schema1:license "Custom License" ;
    schema1:name "mason" ;
    schema1:url "https://github.com/seqan/seqan/" .

