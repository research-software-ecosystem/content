@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:mason a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1371/journal.pone.0049110" ;
    schema1:description "Mason is a collection of tools for the simulation of biological sequences." ;
    schema1:downloadUrl "https://github.com/seqan/seqan/archive/refs/tags/seqan-v2.5.2.tar.gz" ;
    schema1:identifier biotools:mason ;
    schema1:license "BSD 3-Clause" ;
    schema1:name "mason" ;
    schema1:softwareHelp "https://github.com/seqan/seqan/tree/seqan-v2.5.2/apps/mason2/README" ;
    schema1:softwareVersion "2.0.13" ;
    schema1:url "https://www.seqan.de/apps/mason.html" ;
    spdx:builtFrom biotools:mason .

