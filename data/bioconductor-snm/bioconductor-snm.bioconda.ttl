@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-snm a schema1:SoftwareApplication ;
    schema1:description "Supervised Normalization of Microarrays" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/snm_1.58.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/snm/snm_1.58.0.tar.gz', 'https://bioarchive.galaxyproject.org/snm_1.58.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-snm/bioconductor-snm_1.58.0_src_all.tar.gz']" ;
    schema1:identifier biotools:snm ;
    schema1:license "LGPL" ;
    schema1:name "bioconductor-snm" ;
    schema1:softwareVersion "1.58.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/snm.html" ;
    spdx:builtFrom biotools:snm .

