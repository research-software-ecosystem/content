@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-snm a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btq118" ;
    schema1:description "Supervised Normalization of Microarrays" ;
    schema1:identifier biotools:snm ;
    schema1:keywords "Computational Biology",
        "Data quality management",
        "Gene Expression Profiling",
        "Gene expression",
        "Microarray experiment",
        "Oligonucleotide Array Sequence Analysis" ;
    schema1:license "LGPL" ;
    schema1:name "bioconductor-snm" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/snm.html" .

