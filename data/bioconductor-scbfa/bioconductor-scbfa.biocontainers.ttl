    schema1:keywords "RNA-Seq",
        "Transcriptomics" ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-scbfa" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/scBFA.html" .

