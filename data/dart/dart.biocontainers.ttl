@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:dart a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btx558",
        "doi:10.1186/1471-2407-10-604" ;
    schema1:description "Dart: a fast and accurate RNA-seq mapper" ;
    schema1:identifier biotools:dart ;
    schema1:keywords "Gene expression",
        "RNA-Seq" ;
    schema1:license "MIT" ;
    schema1:name "dart" ;
    schema1:url "https://github.com/hsinnan75/Dart" .

