@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-metavizr a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18129/b9.bioc.metavizr" ;
    schema1:description "R interface to the metaviz web app for interactive metagenomics data analysis and visualization" ;
    schema1:keywords "Genomics",
        "Metagenome",
        "Metagenomics" ;
    schema1:license "MIT" ;
    schema1:name "bioconductor-metavizr" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/metavizr.html" .

