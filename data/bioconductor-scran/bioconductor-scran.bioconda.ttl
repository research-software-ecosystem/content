@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-scran a schema1:SoftwareApplication ;
    schema1:description "Methods for Single-Cell RNA-Seq Data Analysis" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/scran_1.34.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/scran/scran_1.34.0.tar.gz', 'https://bioarchive.galaxyproject.org/scran_1.34.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-scran/bioconductor-scran_1.34.0_src_all.tar.gz']" ;
    schema1:identifier biotools:scran ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-scran" ;
    schema1:softwareVersion "1.34.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/scran.html" ;
    spdx:builtFrom biotools:scran .

