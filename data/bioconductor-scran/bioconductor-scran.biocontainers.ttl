biocontainers:bioconductor-scran a schema1:SoftwareApplication ;
    schema1:citation "doi:10.12688/f1000research.9501.1" ;
    schema1:description "Methods for Single-Cell RNA-Seq Data Analysis" ;
    schema1:identifier biotools:scran ;
    schema1:keywords "Cell biology",
        "Clustering",
        "RNA-Seq",
        "RNA-seq",
        "Transcriptomics" ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-scran" ;
    schema1:url "https://bioconductor.org/packages/release/bioc/html/scran.html" .

