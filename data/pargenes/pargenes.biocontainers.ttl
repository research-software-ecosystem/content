@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:pargenes a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/bty839",
        "doi:10.1101/447110" ;
    schema1:description "A massively parallel tool for model selection and tree inference on thousands of genes" ;
    schema1:keywords "Genomics",
        "Phylogeny",
        "Probability",
        "Sequence Alignment" ;
    schema1:license "GPL-3" ;
    schema1:name "pargenes" ;
    schema1:url "https://github.com/BenoitMorel/ParGenes" .

