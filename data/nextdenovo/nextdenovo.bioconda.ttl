@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:nextdenovo a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1101/2023.03.09.531669" ;
    schema1:description "String graph-based de novo assembler for long reads (CLR, HiFi and ONT)" ;
    schema1:identifier biotools:nextdenovo ;
    schema1:license "GPL-3.0-or-later" ;
    schema1:name "nextdenovo" ;
    schema1:softwareHelp "https://nextdenovo.readthedocs.io/en/latest" ;
    schema1:softwareVersion "2.5.2" ;
    schema1:url "https://github.com/Nextomics/NextDenovo" ;
    spdx:builtFrom biotools:nextdenovo .

