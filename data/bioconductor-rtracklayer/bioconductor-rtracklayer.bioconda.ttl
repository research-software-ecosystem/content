@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-rtracklayer a schema1:SoftwareApplication ;
    schema1:description "R interface to genome annotation files and the UCSC genome browser" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/rtracklayer_1.70.1.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/rtracklayer/rtracklayer_1.70.1.tar.gz', 'https://bioarchive.galaxyproject.org/rtracklayer_1.70.1.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-rtracklayer/bioconductor-rtracklayer_1.70.1_src_all.tar.gz']" ;
    schema1:identifier biotools:rtracklayer ;
    schema1:license "Artistic-2.0 + file LICENSE" ;
    schema1:name "bioconductor-rtracklayer" ;
    schema1:softwareVersion "1.70.1" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/rtracklayer.html" ;
    spdx:builtFrom biotools:rtracklayer .

