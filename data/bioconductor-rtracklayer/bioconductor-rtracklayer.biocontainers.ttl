@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-rtracklayer a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btp328" ;
    schema1:description "Gnu r interface to genome browsers and their annotation tracks" ;
    schema1:identifier biotools:rtracklayer ;
    schema1:keywords "Databases, Genetic",
        "Genetics",
        "Genome",
        "Genomics",
        "Molecular biology",
        "User-Computer Interface" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-rtracklayer" ;
    schema1:url "https://bioconductor.org/packages/rtracklayer/" .

