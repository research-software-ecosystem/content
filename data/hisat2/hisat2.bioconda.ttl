@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:hisat2 a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3317",
        "doi:10.1038/s41587-019-0201-4" ;
    schema1:description "Graph-based alignment of next generation sequencing reads to a population of genomes." ;
    schema1:downloadUrl "https://github.com/DaehwanKimLab/hisat2/archive/v2.2.2.tar.gz" ;
    schema1:identifier biotools:HISAT2 ;
    schema1:license "GPL-3.0" ;
    schema1:name "hisat2" ;
    schema1:softwareHelp "https://daehwankimlab.github.io/hisat2/manual/" ;
    schema1:softwareVersion "2.2.2" ;
    schema1:url "http://daehwankimlab.github.io/hisat2" ;
    spdx:builtFrom biotools:HISAT2 .

