@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:hisat2 a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3317",
        "doi:10.1038/nmeth.4106",
        "doi:10.1038/nprot.2016.095",
        "doi:10.1038/s41587-019-0201-4" ;
    schema1:description "Alignment program for mapping next-generation sequencing reads (both dna and rna) to a population of human genomes (as well as to a single reference genome)." ;
    schema1:identifier biotools:HISAT2 ;
    schema1:keywords "Base Sequence",
        "Benchmarking",
        "Genetic Variation",
        "Genome, Human",
        "Genomics",
        "Genotype",
        "Humans",
        "RNA-seq",
        "Reproducibility of Results",
        "Sequence Analysis, DNA",
        "Sequence Analysis, RNA",
        "Transcriptome",
        "Whole genome sequencing" ;
    schema1:license "GPL-3.0" ;
    schema1:name "hisat2" ;
    schema1:url "https://github.com/DaehwanKimLab/hisat2" .

