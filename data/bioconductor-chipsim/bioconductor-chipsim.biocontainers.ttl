@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-chipsim a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Simulation of ChIP-seq experiments" ;
    schema1:identifier biotools:chipsim ;
    schema1:keywords "ChIP-seq",
        "Computational Biology",
        "Gene Expression Profiling",
        "Genomics",
        "High-Throughput Screening Assays",
        "Programming Languages",
        "Simulation experiment",
        "User-Computer Interface" ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-chipsim" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/ChIPsim.html" .

