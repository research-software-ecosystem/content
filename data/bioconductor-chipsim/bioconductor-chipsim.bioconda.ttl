@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-chipsim a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Simulation of ChIP-seq experiments" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/ChIPsim_1.60.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/ChIPsim/ChIPsim_1.60.0.tar.gz', 'https://bioarchive.galaxyproject.org/ChIPsim_1.60.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-chipsim/bioconductor-chipsim_1.60.0_src_all.tar.gz']" ;
    schema1:identifier biotools:chipsim ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-chipsim" ;
    schema1:softwareVersion "1.60.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/ChIPsim.html" ;
    spdx:builtFrom biotools:chipsim .

