@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:lzstring a schema1:SoftwareApplication ;
    schema1:description "Lz-based compression algorithm for python (python 3 version)" ;
