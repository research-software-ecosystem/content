@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:nanoplotter a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/bty149" ;
    schema1:description "Plotting functions of oxford nanopore sequencing data for nanopack" ;
    schema1:license "GPL-3" ;
    schema1:name "nanoplotter" ;
    schema1:url "https://github.com/wdecoster/nanoplotter" .

