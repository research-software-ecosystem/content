@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-rbgl a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/bth458" ;
    schema1:description "An interface to the BOOST graph library" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/RBGL_1.86.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/RBGL/RBGL_1.86.0.tar.gz', 'https://bioarchive.galaxyproject.org/RBGL_1.86.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-rbgl/bioconductor-rbgl_1.86.0_src_all.tar.gz']" ;
    schema1:identifier biotools:rbgl ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-rbgl" ;
    schema1:softwareVersion "1.86.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/RBGL.html" ;
    spdx:builtFrom biotools:rbgl .

