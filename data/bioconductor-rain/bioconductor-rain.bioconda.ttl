@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-rain a schema1:SoftwareApplication ;
    schema1:description "Rhythmicity Analysis Incorporating Non-parametric Methods" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/rain_1.44.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/rain/rain_1.44.0.tar.gz', 'https://bioarchive.galaxyproject.org/rain_1.44.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-rain/bioconductor-rain_1.44.0_src_all.tar.gz']" ;
    schema1:identifier biotools:rain ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-rain" ;
    schema1:softwareVersion "1.44.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/rain.html" ;
    spdx:builtFrom biotools:rain .

