@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:vsnp a schema1:SoftwareApplication ;
    schema1:description "Rapidly call, validate, and compare SNPs from FASTQ files in a timely manner utilizing large data sets." ;
    schema1:keywords "Genetics",
        "Genomics",
        "Phylogenetics",
        "Whole genome sequencing" ;
    schema1:license "GPL-3.0" ;
    schema1:name "vsnp" ;
    schema1:url "https://github.com/USDA-VS/vSNP" .

