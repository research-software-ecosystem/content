@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:schicexplorer a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/gkaa220" ;
    schema1:description "Set of programs to process, analyze and visualize single-cell hi-c data." ;
    schema1:keywords "Chromatin",
        "Computer Graphics",
        "Genetic Techniques",
        "Internet",
        "Molecular Conformation",
        "Reproducibility of Results",
        "Single-Cell Analysis" ;
    schema1:license "MIT" ;
    schema1:name "schicexplorer" ;
    schema1:url "https://github.com/joachimwolff/scHiCExplorer" .

