@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-decipher a schema1:SoftwareApplication ;
    schema1:description "Tools for curating, analyzing, and manipulating biological sequences" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/DECIPHER_3.6.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/DECIPHER/DECIPHER_3.6.0.tar.gz', 'https://bioarchive.galaxyproject.org/DECIPHER_3.6.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-decipher/bioconductor-decipher_3.6.0_src_all.tar.gz']" ;
    schema1:identifier biotools:DECIPHER ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-decipher" ;
    schema1:softwareVersion "3.6.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/DECIPHER.html" ;
    spdx:builtFrom biotools:DECIPHER .

