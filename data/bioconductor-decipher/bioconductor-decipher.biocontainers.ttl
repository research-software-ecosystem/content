@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-decipher a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Tools for curating, analyzing, and manipulating biological sequences" ;
    schema1:identifier biotools:DECIPHER ;
    schema1:keywords "Clustering",
        "Computational Biology",
        "Data visualisation",
        "Gene Expression Profiling",
        "Genetics",
        "Genomics",
        "High-Throughput Screening Assays",
        "Metagenome",
        "Programming Languages",
        "Proteomics",
        "Sequence Alignment",
        "User-Computer Interface" ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-decipher" ;
    schema1:url "https://bioconductor.org/packages/release/bioc/html/DECIPHER.html" .

