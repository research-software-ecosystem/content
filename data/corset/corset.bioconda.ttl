@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:corset a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s13059-014-0410-6" ;
    schema1:description "Software for clustering de novo assembled transcripts and counting overlapping reads." ;
    schema1:downloadUrl "https://github.com/Oshlack/Corset/archive/version-1.09.tar.gz" ;
    schema1:identifier biotools:corset ;
    schema1:license "GPL-3.0-or-later" ;
    schema1:name "corset" ;
    schema1:softwareHelp "https://github.com/Oshlack/Corset/wiki" ;
    schema1:softwareVersion "1.09" ;
    schema1:url "https://github.com/Oshlack/Corset" ;
    spdx:builtFrom biotools:corset .

