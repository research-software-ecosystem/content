@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:corset a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s13059-014-0410-6" ;
    schema1:description "Software for clustering de novo assembled transcripts and counting overlapping reads." ;
    schema1:identifier biotools:corset ;
    schema1:keywords "Animals",
        "Chick Embryo",
        "Cluster Analysis",
        "Clustering",
        "Humans",
        "Models, Statistical",
        "Omics",
        "Sequence Analysis, RNA",
        "Transcriptome",
        "Yeasts" ;
    schema1:license "GPL-3.0" ;
    schema1:name "corset" ;
    schema1:url "https://github.com/Oshlack/Corset" .

