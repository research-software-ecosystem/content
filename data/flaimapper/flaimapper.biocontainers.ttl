@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:flaimapper a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btu696" ;
    schema1:description "Flaimapper: detecting small ncrna derived fragments in small rna-seq data" ;
    schema1:identifier biotools:flaimapper ;
    schema1:keywords "Data submission, annotation and curation",
        "Functional, regulatory and non-coding RNA",
        "High-Throughput Nucleotide Sequencing",
        "Humans",
        "MicroRNAs",
        "Molecular Sequence Annotation",
        "RNA",
        "RNA, Small Untranslated",
        "RNA-Seq",
        "Sequence Analysis, RNA",
        "Transcriptome" ;
    schema1:license "Custom License" ;
    schema1:name "flaimapper" ;
    schema1:url "https://github.com/yhoogstrate/flaimapper/" .

