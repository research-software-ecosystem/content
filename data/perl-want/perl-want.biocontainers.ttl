@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:perl-want a schema1:SoftwareApplication ;
    schema1:description "This module generalises the mechanism of the wantarray function, allowing a function to determine in some detail how its return value is going to be immediately used." ;
    schema1:license "Not available" ;
    schema1:name "perl-want" ;
    schema1:url "http://search.cpan.org/~robin/Want-0.29/Want.pm" .

