@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:hamstr1s a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/1471-2148-9-157" ;
    schema1:description "Feature-aware orthology prediction tool. Provided data package: Quest for Orthologs reference gene sets 2019." ;
    schema1:keywords "Animals",
        "Cluster Analysis",
        "Expressed Sequence Tags",
        "Fungi",
        "Genome, Fungal",
        "Genomics",
        "Humans",
        "Markov Chains",
        "Models, Genetic",
        "Ortholog",
        "Phylogeny",
        "Sequence Analysis, DNA" ;
    schema1:license "GPL-3.0" ;
    schema1:name "hamstr1s" ;
    schema1:url "https://github.com/BIONF/HaMStR" .

