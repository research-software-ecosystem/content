@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:simplesam a schema1:SoftwareApplication ;
    schema1:description "Simple pure python sam parser and objects for working with sam records" ;
    schema1:keywords "Genomics" ;
    schema1:license "MIT" ;
    schema1:name "simplesam" ;
    schema1:url "https://github.com/mdshw5/simplesam" .

