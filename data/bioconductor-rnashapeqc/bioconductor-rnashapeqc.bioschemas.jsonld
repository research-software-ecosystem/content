    {
      "@id": "https://bio.tools/bioconductor-rnashapeqc",
      "@type": "sc:SoftwareApplication",
      "dcterms:conformsTo": "https://bioschemas.org/profiles/ComputationalTool/0.6-DRAFT",
      "sc:additionalType": [
        "Library",
        "Command-line tool"
      ],
      "sc:author": [
        "Katherine A. Hoadley",
        "Hyo Young Choi",
        "Miyeon Yeon",
        "Won-Young Choi",
        "D. Neil Hayes"
      ],
      "sc:citation": {
        "@id": "https://doi.org/10.18129/B9.bioc.RNAshapeQC"
      },
      "sc:contributor": [
        "D. Neil Hayes",
        "Jin Young Lee"
      ],
      "sc:description": "RNAshapeQC provides coverage-shape-based quality control (QC) metrics for mRNA-seq and total RNA-seq data. It supports per-gene pileup construction from BAM files as well as toy datasets for quick-start examples. The package implements protocol-specific metrics, including decay rate (DR), degradation score (DS), mean coverage depth (MCD), window coefficient of variation (wCV), area under the curve (AUC), and shape-based sample-level indices. RNAshapeQC also includes HPC-friendly functions for per-gene batch processing and cross-study pileup generation. This package enables interpretable, protocol-specific QC assessments for diverse RNA-seq workflows.",
      "sc:license": "MIT",
      "sc:name": "RNAshapeQC",
      "sc:operatingSystem": [
        "Windows",
        "Mac",
        "Linux"
      ],
      "sc:softwareHelp": {
        "@id": "https://bioconductor.org/packages/RNAshapeQC"
      },
      "sc:softwareVersion": "1.0.0",
      "sc:url": "https://bioconductor.org/packages/RNAshapeQC"
    }
  ]
