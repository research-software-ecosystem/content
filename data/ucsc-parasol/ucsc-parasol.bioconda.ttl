@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:ucsc-parasol a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bib/bbs038" ;
    schema1:description " Parasol is the name given to the overall system for managing jobs on a computer cluster and to this specific command.  This command is intended primarily for system administrators.  The 'para' command is the primary command for users. " ;
    schema1:downloadUrl "http://hgdownload.cse.ucsc.edu/admin/exe/userApps.archive/userApps.v469.src.tgz" ;
    schema1:identifier biotools:UCSC_Genome_Browser_Utilities ;
    schema1:license "Varies; see http://genome.ucsc.edu/license" ;
    schema1:name "ucsc-parasol" ;
    schema1:softwareHelp "https://github.com/ucscGenomeBrowser/kent/blob/master/README" ;
    schema1:softwareVersion "469" ;
    schema1:url "https://hgdownload.cse.ucsc.edu/admin/exe/" ;
    spdx:builtFrom biotools:UCSC_Genome_Browser_Utilities .

