@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:cpat a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/gkt006" ;
    schema1:description "Coding potential assessment tool" ;
    schema1:keywords "Logistic Models",
        "Open Reading Frames",
        "Ortholog",
        "RNA, Untranslated",
        "RNA-Seq",
        "Sequence Analysis, RNA",
        "Transcriptome" ;
    schema1:license "GPL-2.0+" ;
    schema1:name "cpat" ;
    schema1:url "http://rna-cpat.sourceforge.net/" .

