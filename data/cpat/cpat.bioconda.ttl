@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:cpat a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/gkt006" ;
    schema1:description "Coding Potential Assessment Tool." ;
    schema1:downloadUrl "https://pypi.io/packages/source/C/CPAT/CPAT-3.0.5.tar.gz" ;
    schema1:identifier biotools:cpat ;
    schema1:license "GPL-2.0-or-later" ;
    schema1:name "cpat" ;
    schema1:softwareHelp "https://cpat.readthedocs.io/en/latest" ;
    schema1:softwareVersion "3.0.5" ;
    schema1:url "https://github.com/liguowang/cpat" ;
    spdx:builtFrom biotools:cpat .

