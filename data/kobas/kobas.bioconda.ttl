@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:kobas a schema1:SoftwareApplication ;
    schema1:description "KEGG Orthology Based Annotation System" ;
    schema1:downloadUrl "http://kobas.cbi.pku.edu.cn/kobas-2.1.1/kobas-3.0.3.tar.gz" ;
    schema1:identifier biotools:kobas ;
    schema1:license "Biopython License Agreement" ;
    schema1:name "kobas" ;
    schema1:softwareVersion "3.0.3" ;
    schema1:url "http://kobas.cbi.pku.edu.cn" ;
    spdx:builtFrom biotools:kobas .

