@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:kobas a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/bti430",
        "doi:10.1093/nar/gkl167" ;
    schema1:description "Kegg orthology-based annotation system (kobas) annotates sequences with kegg orthology terms and identifies the frequently occurring (or significantly enriched) pathways among the queried sequences compared against a background distribution. 5 pathway databases are used (kegg pathway, pid, biocyc, reactome, panther) and 5 human databases (omim, kegg disease, fundo, gad, nhgri gwas)." ;
    schema1:identifier biotools:kobas ;
    schema1:keywords "Alzheimer Disease",
        "Computer Graphics",
        "Data Interpretation, Statistical",
        "Databases, Genetic",
        "Genes",
        "Hippocampus",
        "Internet",
        "Models, Biological",
        "Molecular interactions, pathways and networks",
        "Pathology",
        "Proteins",
        "Sequence Analysis",
        "Sequence analysis",
        "Signal Transduction",
        "Up-Regulation",
        "User-Computer Interface",
        "Vocabulary, Controlled" ;
    schema1:license "Biopython License Agreement" ;
    schema1:name "kobas" ;
    schema1:url "http://kobas.cbi.pku.edu.cn" .

