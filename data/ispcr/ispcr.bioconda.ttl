@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:ispcr a schema1:SoftwareApplication ;
    schema1:description "In silico PCR" ;
    schema1:downloadUrl "https://users.soe.ucsc.edu/~kent/src/isPcr33.zip" ;
    schema1:identifier biotools:ispcr ;
    schema1:license "License is hereby granted for personal, academic, and non-profit use." ;
    schema1:name "ispcr" ;
    schema1:softwareVersion "33" ;
    schema1:url "https://users.soe.ucsc.edu/~kent/" ;
    spdx:builtFrom biotools:ispcr .

