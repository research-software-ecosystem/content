@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-ngscopydata a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18129/b9.bioc.ngscopydata" ;
    schema1:description "Subset of BAM files of human tumor and pooled normal sequencing data (Zhao et al. 2014) for the NGScopy package" ;
    schema1:license "GPL-2.0" ;
    schema1:name "bioconductor-ngscopydata" ;
    schema1:url "https://bioconductor.org/packages/release/data/experiment/html/NGScopyData.html" .

