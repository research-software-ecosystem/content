@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-rnaither a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btp014" ;
    schema1:description "This tool analyzes cell-based rnai screens, including quality assessment, customizable normalization and statistical tests, leading to lists of significant genes and biological processes." ;
    schema1:identifier biotools:rnaither ;
    schema1:keywords "Computational Biology",
        "Computer science",
        "Data Interpretation, Statistical",
        "Gene Expression Profiling",
        "RNA Interference",
        "RNA, Small Interfering" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-rnaither" ;
    schema1:url "http://bioconductor.org/packages/release/bioc/html/RNAither.html" .

