@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:emperor a schema1:SoftwareApplication ;
    schema1:description "Emperor a tool for the analysis and visualization of large microbial ecology datasets" ;
    schema1:license "Not available" ;
    schema1:name "emperor" ;
    schema1:url "http://github.com/biocore/emperor" .

