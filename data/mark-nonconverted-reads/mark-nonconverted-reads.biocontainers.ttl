@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:mark-nonconverted-reads a schema1:SoftwareApplication ;
    schema1:description "A simple filter to mark potential nonconverted reads from methylation experiments" ;
    schema1:license "AGPL-3.0" ;
    schema1:name "mark-nonconverted-reads" ;
    schema1:url "https://github.com/nebiolabs/mark-nonconverted-reads" .

