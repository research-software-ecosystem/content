@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:ribodetector a schema1:SoftwareApplication ;
    schema1:author "alienzj" ;
    schema1:description "Accurate and rapid RiboRNA sequences Detector based on deep learning" ;
    schema1:downloadUrl "https://files.pythonhosted.org/packages/ed/92/ddeb9ca3e7cc936669f19d6ad181cca2ce8ca7afab00cbbee9f88ad50a84/ribodetector-0.3.3.tar.gz" ;
    schema1:identifier biotools:ribodetector ;
    schema1:license "GPL-3.0-or-later" ;
    schema1:maintainer "alienzj" ;
    schema1:name "ribodetector" ;
    schema1:softwareVersion "0.3.3" ;
    schema1:url "https://github.com/hzi-bifo/RiboDetector" ;
    spdx:builtFrom biotools:ribodetector .

