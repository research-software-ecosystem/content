@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:fargene a schema1:SoftwareApplication ;
    schema1:description "Fragmented antibiotic resistance gene ienntifier takes either fragmented metagenomic data or longer sequences as input and predicts and delivers full-length antiobiotic resistance genes as output" ;
    schema1:keywords "Metagenome",
        "Peptides",
        "Protein Sequences" ;
    schema1:license "MIT" ;
    schema1:name "fargene" ;
    schema1:url "https://github.com/fannyhb/fargene" .

