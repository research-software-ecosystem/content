@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:nanoplot a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/bty149" ;
    schema1:description "Plotting suite for long read sequencing data and alignments" ;
    schema1:keywords "Escherichia coli",
        "High-Throughput Nucleotide Sequencing",
        "Sequence Analysis, DNA" ;
    schema1:license "GPL-3.0" ;
    schema1:name "nanoplot" ;
    schema1:url "https://github.com/wdecoster/NanoPlot" .

