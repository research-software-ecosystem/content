@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:start-asap a schema1:SoftwareApplication ;
    schema1:description "Prepare project directory and project sheet for ASA3P" ;
    schema1:downloadUrl "https://github.com/quadram-institute-bioscience/start-asap/archive/v1.3.0.tar.gz" ;
    schema1:identifier biotools:start-asap ;
    schema1:license "MIT" ;
    schema1:name "start-asap" ;
    schema1:softwareVersion "1.3.0" ;
    schema1:url "http://github.com/quadram-institute-bioscience/start-asap/" ;
    spdx:builtFrom biotools:start-asap .

