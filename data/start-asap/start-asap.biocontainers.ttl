@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:start-asap a schema1:SoftwareApplication ;
    schema1:description "Prepare the input directory for 'asa3p', creating automatically a _config.xls_ file from the reads provided.\\nrequires one or more reference files (.gbk recommended) and a directory with fastq files (.fq or .fastq, gzipped).\\nmetadata can be supplied via command line or with a json file." ;
    schema1:identifier biotools:start-asap ;
    schema1:license "MIT" ;
    schema1:name "start-asap" ;
    schema1:url "http://github.com/quadram-institute-bioscience/start-asap/" .

