@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:checkqc a schema1:SoftwareApplication ;
    schema1:citation "doi:10.21105/joss.00556" ;
    schema1:description "A simple program to parse Illumina NGS data and check it for quality criteria." ;
    schema1:keywords "Genomics" ;
    schema1:license "GPL-3.0" ;
    schema1:name "checkqc" ;
    schema1:url "https://www.github.com/Molmed/checkQC" .

