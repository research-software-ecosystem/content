@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-snapcount a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18129/b9.bioc.snapcount" ;
    schema1:description "R/bioconductor package for interfacing with snaptron for rapid querying of expression counts" ;
    schema1:keywords "RNA-Seq" ;
    schema1:license "MIT" ;
    schema1:name "bioconductor-snapcount" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/snapcount.html" .

