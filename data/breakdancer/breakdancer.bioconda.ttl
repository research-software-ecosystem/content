@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:breakdancer a schema1:SoftwareApplication ;
    schema1:description "SV detection from paired end reads mapping" ;
    schema1:downloadUrl "https://github.com/genome/breakdancer/archive/v1.4.5.tar.gz" ;
    schema1:identifier biotools:breakdancer ;
    schema1:license "GPLv3" ;
    schema1:name "breakdancer" ;
    schema1:softwareVersion "1.4.5" ;
    schema1:url "https://github.com/genome/breakdancer" ;
    spdx:builtFrom biotools:breakdancer .

