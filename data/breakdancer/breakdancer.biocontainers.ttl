@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:breakdancer a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.1363" ;
    schema1:description "SV detection from paired end reads mapping" ;
    schema1:identifier biotools:breakdancer ;
    schema1:keywords "Base Sequence",
        "Computer Simulation",
        "DNA",
        "DNA structural variation",
        "Genetic Variation",
        "Genome, Human",
        "Genomics",
        "Humans",
        "Leukemia, Myeloid, Acute",
        "Sequence Analysis, DNA" ;
    schema1:license "GPL-3.0" ;
    schema1:name "breakdancer" ;
    schema1:url "https://github.com/genome/breakdancer" .

