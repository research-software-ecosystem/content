@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:readseq a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1002/0471250953.bia01es00" ;
    schema1:description "Convert biosequences between a selection of common biological sequence formats." ;
    schema1:identifier biotools:readseq ;
    schema1:keywords "Data management",
        "Database Management Systems",
        "Databases, Genetic",
        "Information Storage and Retrieval",
        "Internet",
        "Programming Languages",
        "Sequence Analysis",
        "User-Computer Interface" ;
    schema1:license "Apache-2.0" ;
    schema1:name "readseq" ;
    schema1:url "http://www.ebi.ac.uk/Tools/sfc/readseq/" .

