        "conda:bioconda:readseq",
        "omictools:OMICS_17576" ;
    schema1:keywords "field::biology",
        "field::biology:bioinformatics",
        "implemented-in::c",
        "interface::commandline",
        "role::program",
        "scope::utility",
        "use::converting",
        "works-with-format::plaintext",
        "works-with::TODO" ;
    schema1:license "unknown" ;
    schema1:name "readseq" ;
    schema1:softwareVersion "1" ;
    schema1:url "http://iubio.bio.indiana.edu/soft/molbio/readseq/" ;
    spdx:builtFrom "readseq" .

