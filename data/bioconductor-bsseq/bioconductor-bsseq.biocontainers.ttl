@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-bsseq a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/gb-2012-13-10-r83" ;
    schema1:description "Analyze, manage and store bisulfite sequencing data" ;
    schema1:identifier biotools:bsseq ;
    schema1:keywords "Cell Line",
        "CpG Islands",
        "DNA Methylation",
        "Genome, Human",
        "Genomics",
        "Humans",
        "Immunoprecipitation experiment",
        "Sequence Alignment",
        "Sequence Analysis, DNA",
        "Sequencing" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-bsseq" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/bsseq.html" .

