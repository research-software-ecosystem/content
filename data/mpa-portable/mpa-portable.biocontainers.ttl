@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:mpa-portable a schema1:SoftwareApplication ;
    schema1:description "MPA Portable is a light-weight and stand-alone software for the identification of proteins and in-depth analysis of metaproteomics (and also proteomics) data." ;
    schema1:keywords "Metaproteomics",
        "Peptides",
        "Proteomics" ;
    schema1:license "Apache-2.0" ;
    schema1:name "mpa-portable" ;
    schema1:url "https://github.com/compomics/meta-proteome-analyzer" .

