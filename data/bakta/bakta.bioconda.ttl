@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bakta a schema1:SoftwareApplication ;
    schema1:author "oschwengers" ;
    schema1:citation "doi:10.1099/mgen.0.000685",
        "doi:10.5281/zenodo.4247252" ;
    schema1:description "Rapid & standardized annotation of bacterial genomes, MAGs & plasmids." ;
    schema1:downloadUrl "https://github.com/oschwengers/bakta/archive/v1.12.0.tar.gz" ;
    schema1:identifier biotools:bakta ;
    schema1:license "GPL-3.0-or-later" ;
    schema1:maintainer "oschwengers" ;
    schema1:name "bakta" ;
    schema1:softwareHelp "https://github.com/oschwengers/bakta/blob/v1.12.0/README.md" ;
    schema1:softwareVersion "1.12.0" ;
    schema1:url "https://github.com/oschwengers/bakta" ;
    spdx:builtFrom biotools:bakta .

