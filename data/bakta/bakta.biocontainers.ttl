@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bakta a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/s41597-019-0180-9",
        "doi:10.1093/nar/gkaa1100",
        "doi:10.1093/nar/gkh152",
        "doi:10.1101/614032",
        "doi:10.5281/zenodo.4247252" ;
    schema1:description "Rapid & standardized annotation of bacterial genomes & plasmids." ;
    schema1:identifier biotools:bakta ;
    schema1:keywords "Genomics",
        "Protein Sequences" ;
    schema1:license "GPLv3" ;
    schema1:name "bakta" ;
    schema1:url "https://github.com/oschwengers/bakta" .

