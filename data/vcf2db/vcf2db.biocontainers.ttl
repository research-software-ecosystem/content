@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:vcf2db a schema1:SoftwareApplication ;
    schema1:description "Create a gemini-compatible database from a vcf" ;
    schema1:license "Not available" ;
    schema1:name "vcf2db" ;
    schema1:url "https://github.com/quinlan-lab/vcf2db" .

