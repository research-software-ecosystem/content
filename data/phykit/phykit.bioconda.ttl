@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:phykit a schema1:SoftwareApplication ;
    schema1:author "pauldg" ;
    schema1:citation "doi:10.1093/bioinformatics/btab096" ;
    schema1:description "PhyKIT is a UNIX shell toolkit for processing and analyzing phylogenomic data." ;
    schema1:downloadUrl "https://pypi.io/packages/source/p/phykit/phykit-2.1.90.tar.gz" ;
    schema1:identifier biotools:phykit ;
    schema1:license "MIT" ;
    schema1:maintainer "pauldg" ;
    schema1:name "phykit" ;
    schema1:softwareHelp "https://jlsteenwyk.com/PhyKIT" ;
    schema1:softwareVersion "2.1.90" ;
    schema1:url "https://github.com/jlsteenwyk/phykit" ;
    spdx:builtFrom biotools:phykit .

