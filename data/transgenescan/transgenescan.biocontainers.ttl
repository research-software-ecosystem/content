@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:transgenescan a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/gkq747",
        "doi:10.1186/1471-2105-15-S9-S8" ;
    schema1:description "Software tool for finding genes in assembled transcripts from metatranscriptomic sequences." ;
    schema1:identifier biotools:TransGeneScan ;
    schema1:keywords "Codon",
        "DNA",
        "Frameshifting, Ribosomal",
        "Genes",
        "Metagenome",
        "Metagenomics",
        "Models, Statistical",
        "Sequence Analysis, DNA",
        "Sequence analysis",
        "Transcriptomics" ;
    schema1:license "file" ;
    schema1:name "transgenescan" ;
    schema1:url "https://github.com/COL-IU/TransGeneScan" .

