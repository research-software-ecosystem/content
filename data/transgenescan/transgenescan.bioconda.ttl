@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:transgenescan a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/1471-2105-15-S9-S8" ;
    schema1:description "Software tool for finding genes in assembled transcripts from metatranscriptomic sequences." ;
    schema1:downloadUrl "https://github.com/COL-IU/TransGeneScan/archive/refs/tags/v1.3.0.tar.gz" ;
    schema1:identifier biotools:TransGeneScan ;
    schema1:license "GPL-3.0-only" ;
    schema1:name "transgenescan" ;
    schema1:softwareVersion "1.3.0" ;
    schema1:url "https://github.com/COL-IU/TransGeneScan" ;
    spdx:builtFrom biotools:TransGeneScan .

