@prefix debianmed: <https://salsa.debian.org/med-team/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

debianmed:samblaster a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btu314" ;
    schema1:description "marks duplicates, extracts discordant/split reads" ;
    schema1:identifier "bio.tools:samblaster",
        "conda:bioconda:samblaster",
        "guix:samblaster",
        "omictools:OMICS_04682",
        "scicrunch:SCR_000468" ;
    schema1:license "unknown" ;
    schema1:name "samblaster" ;
    schema1:softwareVersion "0.1.26" ;
    schema1:url "https://github.com/GregoryFaust/samblaster" ;
    spdx:builtFrom "samblaster" .

