@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:samblaster a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btu314" ;
    schema1:description "Mark duplicates in and extract discordant and split reads from SAM files." ;
    schema1:downloadUrl "https://github.com/GregoryFaust/samblaster/releases/download/v.0.1.26/samblaster-v.0.1.26.tar.gz" ;
    schema1:identifier biotools:samblaster ;
    schema1:license "MIT" ;
    schema1:name "samblaster" ;
    schema1:softwareHelp "https://github.com/GregoryFaust/samblaster/blob/v.0.1.26/README.md" ;
    schema1:softwareVersion "0.1.26" ;
    schema1:url "https://github.com/GregoryFaust/samblaster" ;
    spdx:builtFrom biotools:samblaster .

