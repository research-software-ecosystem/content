@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:samblaster a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btu314" ;
    schema1:description "A tool to mark duplicates and extract discordant and split reads from sam files." ;
    schema1:identifier biotools:samblaster ;
    schema1:keywords "DNA",
        "Genomic Structural Variation",
        "Genomics",
        "Mapping",
        "Sequence Alignment",
        "Sequence Analysis, DNA",
        "Sequencing" ;
    schema1:license "MIT" ;
    schema1:name "samblaster" ;
    schema1:url "https://github.com/GregoryFaust/samblaster" .

