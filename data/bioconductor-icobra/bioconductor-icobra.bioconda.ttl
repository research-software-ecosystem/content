@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-icobra a schema1:SoftwareApplication ;
    schema1:description "Comparison and Visualization of Ranking and Assignment Methods" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/iCOBRA_1.34.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/iCOBRA/iCOBRA_1.34.0.tar.gz', 'https://bioarchive.galaxyproject.org/iCOBRA_1.34.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-icobra/bioconductor-icobra_1.34.0_src_all.tar.gz']" ;
    schema1:identifier biotools:icobra ;
    schema1:license "GPL (>=2)" ;
    schema1:name "bioconductor-icobra" ;
    schema1:softwareVersion "1.34.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/iCOBRA.html" ;
    spdx:builtFrom biotools:icobra .

