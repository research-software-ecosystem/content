@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:fastq-count a schema1:SoftwareApplication ;
    schema1:description "Simple fastq read and base counter for paired data." ;
    schema1:license "MIT" ;
    schema1:name "fastq-count" ;
    schema1:url "https://github.com/sndrtj/fastq-count" .

