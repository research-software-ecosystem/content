  "@graph": [
    {
      "@id": "https://bio.tools/bioconductor-busseq",
      "@type": "sc:SoftwareApplication",
      "dcterms:conformsTo": "https://bioschemas.org/profiles/ComputationalTool/0.6-DRAFT",
      "sc:additionalType": [
        "Command-line tool",
        "Library"
      ],
      "sc:author": [
        "Yingying Wei",
        "Ga Ming Chan",
        "Fangda Song"
      ],
      "sc:citation": {
        "@id": "https://doi.org/10.18129/B9.bioc.BUSseq"
      },
      "sc:description": "BUSseq R package fits an interpretable Bayesian hierarchical model---the Batch Effects Correction with Unknown Subtypes for scRNA seq Data (BUSseq)---to correct batch effects in the presence of unknown cell types. BUSseq is able to simultaneously correct batch effects, clusters cell types, and takes care of the count data nature, the overdispersion, the dropout events, and the cell-specific sequencing depth of scRNA-seq data. After correcting the batch effects with BUSseq, the corrected value can be used for downstream analysis as if all cells were sequenced in a single batch. BUSseq can integrate read count matrices obtained from different scRNA-seq platforms and allow cell types to be measured in some but not all of the batches as long as the experimental design fulfills the conditions listed in our manuscript.",
      "sc:license": "Artistic-2.0",
      "sc:name": "BUSseq",
      "sc:operatingSystem": [
        "Mac",
        "Linux",
        "Windows"
      ],
      "sc:softwareHelp": {
        "@id": "https://bioconductor.org/packages/BUSseq"
      },
      "sc:softwareVersion": "1.16.0",
      "sc:url": "https://bioconductor.org/packages/BUSseq"
    },
    {
      "@id": "https://doi.org/10.18129/B9.bioc.BUSseq",
      "@type": "sc:CreativeWork"
    }
  ]
