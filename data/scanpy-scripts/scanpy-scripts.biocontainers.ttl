@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:scanpy-scripts a schema1:SoftwareApplication ;
    schema1:description "A set of wrappers for individual components of the scanpy package. functions in python packages are hard to call when building workflows outside of python, so this package adds a set of simple wrappers with robust argument parsing." ;
    schema1:keywords "Clustering" ;
    schema1:license "Apache-2.0" ;
    schema1:name "scanpy-scripts" ;
    schema1:url "https://github.com/ebi-gene-expression-group/scanpy-scripts" .

