@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-ggplot2 a schema1:SoftwareApplication ;
    schema1:description "A system for declaratively creating graphics. You provide the data, tell ggplot2 how to map variables to aesthetics, what graphical primitives to use, and it takes care of the details." ;
    schema1:license "BSD-3-Clause" ;
    schema1:name "r-ggplot2" ;
    schema1:url "https://github.com/conda-forge/r-ggplot2-feedstock" .

