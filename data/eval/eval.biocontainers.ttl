@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:eval a schema1:SoftwareApplication ;
    schema1:description "Eval is a flexible tool for analyzing the performance of gene-structure prediction programs." ;
    schema1:license "BSD 2-Clause" ;
    schema1:name "eval" ;
    schema1:url "http://mblab.wustl.edu/software.html" .

