@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:chromhmm a schema1:SoftwareApplication ;
    schema1:description "ChromHMM is software for learning and characterizing chromatin states. ChromHMM can integrate multiple chromatin datasets such as ChIP-seq data of various histone modifications to discover de novo the major re-occuring combinatorial and spatial patterns of marks." ;
    schema1:downloadUrl "https://github.com/jernst98/ChromHMM/archive/v1.27.tar.gz" ;
    schema1:identifier biotools:chromhmm ;
    schema1:license "GPLv3" ;
    schema1:name "chromhmm" ;
    schema1:softwareVersion "1.27" ;
    schema1:url "https://github.com/jernst98/ChromHMM" ;
    spdx:builtFrom biotools:chromhmm .

