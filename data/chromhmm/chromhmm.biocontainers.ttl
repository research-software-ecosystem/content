@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:chromhmm a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.1906" ;
    schema1:description "Chromhmm is software for learning and characterizing chromatin states." ;
    schema1:identifier biotools:chromhmm ;
    schema1:keywords "Animals",
        "Chromosome Mapping",
        "Chromosomes",
        "Computer Simulation",
        "Epigenomics",
        "Humans",
        "Models, Genetic",
        "Models, Statistical" ;
    schema1:license "GPL-3.0" ;
    schema1:name "chromhmm" ;
    schema1:url "https://github.com/jernst98/ChromHMM" .

