@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:nseg a schema1:SoftwareApplication ;
    schema1:description "nseg identifies and masks regions of low complexity in nucleic acid sequences" ;
