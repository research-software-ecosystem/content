@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:demuxlet a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nbt.4042" ;
    schema1:description "Genetic multiplexing of barcoded single cell RNA-seq." ;
    schema1:downloadUrl "https://github.com/statgen/demuxlet/archive/f5044eb9ed5c6678aa3a80a8f2be7db7748ee732.zip" ;
    schema1:identifier biotools:demuxlet ;
    schema1:license "GPL-3.0-or-later" ;
    schema1:name "demuxlet" ;
    schema1:softwareHelp "https://github.com/statgen/demuxlet" ;
    schema1:softwareVersion "1.0" ;
    schema1:url "https://github.com/statgen/demuxlet" ;
    spdx:builtFrom biotools:demuxlet .

