@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-sincell a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btv368" ;
    schema1:description "R package for the statistical assessment of cell state hierarchies from single-cell RNA-seq data" ;
    schema1:identifier biotools:sincell ;
    schema1:keywords "Cell Differentiation",
        "Clustering",
        "Data Interpretation, Statistical",
        "Gene Expression Profiling",
        "Genomics",
        "RNA",
        "RNA-Seq",
        "RNA-seq",
        "Sequence Analysis, RNA",
        "Single-Cell Analysis",
        "Taxonomy",
        "Transcriptomics" ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-sincell" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/sincell.html" .

