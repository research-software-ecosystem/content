@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-sincell a schema1:SoftwareApplication ;
    schema1:description "R package for the statistical assessment of cell state hierarchies from single-cell RNA-seq data" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/sincell_1.38.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/sincell/sincell_1.38.0.tar.gz', 'https://bioarchive.galaxyproject.org/sincell_1.38.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-sincell/bioconductor-sincell_1.38.0_src_all.tar.gz']" ;
    schema1:identifier biotools:sincell ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-sincell" ;
    schema1:softwareVersion "1.38.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/sincell.html" ;
    spdx:builtFrom biotools:sincell .

