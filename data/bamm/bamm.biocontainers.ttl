@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bamm a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/gky431" ;
    schema1:description "Metagenomics-focused BAM file manipulation" ;
    schema1:identifier biotools:bamm ;
    schema1:keywords "Animals",
        "Bayes Theorem",
        "ChIP-seq",
        "Databases, Nucleic Acid",
        "Genomics",
        "Humans",
        "Internet",
        "Markov Chains",
        "Metagenomics",
        "Mice",
        "Nucleotide Motifs",
        "Rats",
        "Regulatory Sequences, Nucleic Acid",
        "Sequence Analysis",
        "Sequence sites, features and motifs",
        "Transcription Factors" ;
    schema1:license "LGPL-3.0" ;
    schema1:name "bamm" ;
    schema1:url "https://github.com/Ecogenomics/BamM" .

