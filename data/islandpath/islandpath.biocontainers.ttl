@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:islandpath a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btg004" ;
    schema1:description "Islandpath-dimob is a standalone software to predict genomic islands in bacterial and archaeal genomes based on the presence of dinucleotide biases and mobility genes.\\n\\ngenomic islands (gis) are clusters of genes in prokaryotic genomes of probable horizontal origin. gis are disproportionately associated with microbial adaptations of medical or environmental interest." ;
    schema1:identifier biotools:islandpath ;
    schema1:keywords "Archaea",
        "Bacteria",
        "CpG Islands",
        "Database Management Systems",
        "Gene Transfer, Horizontal",
        "Gene structure",
        "Genetics",
        "Genome, Archaeal",
        "Genome, Bacterial",
        "Genomics",
        "Model organisms",
        "Phylogeny",
        "Sequence Alignment",
        "Sequence Analysis, DNA",
        "Transcription factors and regulatory sites" ;
    schema1:license "Not available" ;
    schema1:name "islandpath" ;
    schema1:url "http://www.pathogenomics.sfu.ca/islandpath/" .

