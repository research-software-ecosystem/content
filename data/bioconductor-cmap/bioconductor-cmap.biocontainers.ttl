@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-cmap a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18129/b9.bioc.cmap" ;
    schema1:description "Annotation data file for cMAP assembled using data from public data repositories" ;
    schema1:license "LGPL" ;
    schema1:name "bioconductor-cmap" ;
    schema1:url "http://bioconductor.org/packages/3.6/data/annotation/html/cMAP.html" .

