@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:scanorama a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/s41587-019-0113-3" ;
    schema1:description "Panoramic stitching of heterogeneous single-cell transcriptomic data" ;
    schema1:keywords "Cell Differentiation",
        "Clustering",
        "Gene Expression Profiling",
        "Genomics",
        "Humans",
        "Macrophages",
        "Monocytes",
        "RNA-Seq",
        "Sequence Analysis, RNA",
        "Single-Cell Analysis",
        "Transcriptome" ;
    schema1:license "MIT" ;
    schema1:name "scanorama" ;
    schema1:url "https://github.com/brianhie/scanorama/" .

