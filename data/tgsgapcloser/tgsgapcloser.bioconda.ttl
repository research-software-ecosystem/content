@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:tgsgapcloser a schema1:SoftwareApplication ;
    schema1:author "cchd0001" ;
    schema1:citation "doi:10.1093/gigascience/giaa094" ;
    schema1:description "A gap-closing software tool that uses error-prone long reads generated by third-generation-sequence techniques (Pacbio, Oxford Nanopore, etc.) or preassembled contigs to fill N-gap in the genome assembly." ;
    schema1:downloadUrl "https://github.com/BGI-Qingdao/TGS-GapCloser/releases/download/v1.2.1/TGS-GapCloser-1.2.1_ml.zip" ;
    schema1:identifier biotools:TGS-GapCloser ;
    schema1:license "GPL-3.0-only" ;
    schema1:maintainer "cchd0001" ;
    schema1:name "tgsgapcloser" ;
    schema1:softwareHelp "https://github.com/BGI-Qingdao/TGS-GapCloser/blob/v1.2.1/README.md" ;
    schema1:softwareVersion "1.2.1" ;
    schema1:url "https://github.com/BGI-Qingdao/TGS-GapCloser" ;
    spdx:builtFrom biotools:TGS-GapCloser .

