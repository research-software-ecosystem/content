@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-chipseeker a schema1:SoftwareApplication ;
    schema1:description "ChIPseeker for ChIP peak Annotation, Comparison, and Visualization" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/ChIPseeker_1.42.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/ChIPseeker/ChIPseeker_1.42.0.tar.gz', 'https://bioarchive.galaxyproject.org/ChIPseeker_1.42.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-chipseeker/bioconductor-chipseeker_1.42.0_src_all.tar.gz']" ;
    schema1:identifier biotools:chipseeker ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-chipseeker" ;
    schema1:softwareVersion "1.42.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/ChIPseeker.html" ;
    spdx:builtFrom biotools:chipseeker .

