@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-chipseeker a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btv145" ;
    schema1:description "This package implements functions to retrieve the nearest genes around the peak, annotate the genomic region of the peak, statistical methods for estimating the significance of overlap among chip peak data sets, and incorporate geo database to compare the own dataset with those deposited in database. the comparison can be used to infer cooperative regulation and thus can be used to generate hypotheses." ;
    schema1:identifier biotools:chipseeker ;
    schema1:keywords "Binding Sites",
        "ChIP-seq",
        "Chromatin Immunoprecipitation",
        "Computer Graphics",
        "DNA",
        "Data mining",
        "Data visualisation",
        "High-Throughput Nucleotide Sequencing",
        "Molecular Sequence Annotation",
        "Sequence Analysis, DNA",
        "Transcription Factors",
        "Transcription Initiation Site" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-chipseeker" ;
    schema1:url "http://bioconductor.org/packages/release/bioc/html/ChIPseeker.html" .

