@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:clipandmerge a schema1:SoftwareApplication ;
    schema1:description "Clip&merge is a tool to clip off adapters from sequencing reads and merge overlapping paired end reads together." ;
    schema1:license "GNU General Public License v3.0" ;
    schema1:name "clipandmerge" ;
    schema1:url "https://github.com/apeltzer/ClipAndMerge" .

