@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:taxonomy_ranks a schema1:SoftwareApplication ;
    schema1:author "linzhi2013" ;
    schema1:description "To get taxonomy ranks information for taxid, species name, or higher ranks (e.g., genus, family) with ETE3 from NCBI Taxonomy database." ;
    schema1:downloadUrl "https://pypi.io/packages/source/t/taxonomy_ranks/taxonomy_ranks-0.0.10.tar.gz" ;
    schema1:identifier biotools:taxonomy_ranks ;
    schema1:license "GPL-3.0-or-later" ;
    schema1:maintainer "linzhi2013" ;
    schema1:name "taxonomy_ranks" ;
    schema1:softwareVersion "0.0.10" ;
    schema1:url "https://github.com/linzhi2013/taxonomy_ranks" ;
    spdx:builtFrom biotools:taxonomy_ranks .

