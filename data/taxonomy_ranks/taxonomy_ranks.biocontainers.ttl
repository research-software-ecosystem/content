@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:taxonomy_ranks a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/gkz173" ;
    schema1:description "To get taxonomy ranks information for taxid, species name, or higher ranks (e.g., genus, family) with ete3 from ncbi taxonomy database." ;
    schema1:identifier biotools:taxonomy_ranks ;
    schema1:keywords "Animals",
        "Computational Biology",
        "DNA, Mitochondrial",
        "Genes, Mitochondrial",
        "Genome, Mitochondrial",
        "Genomics",
        "High-Throughput Nucleotide Sequencing",
        "Internet",
        "Molecular Sequence Annotation",
        "Sequence Analysis, DNA" ;
    schema1:license "GPL-3.0" ;
    schema1:name "taxonomy_ranks" ;
    schema1:url "https://github.com/linzhi2013/taxonomy_ranks" .

