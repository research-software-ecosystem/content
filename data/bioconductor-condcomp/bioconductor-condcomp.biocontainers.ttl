@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-condcomp a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18129/b9.bioc.condcomp" ;
    schema1:description "For a given clustered data, which can also be split into two conditions, this package provides a way to perform a condition comparison on said clustered data. The comparison is performed on each cluster. Several statistics are used and, when analysed in conjunction, they might give some insight regarding the heterogeneity of some of the clusters." ;
    schema1:keywords "Clustering",
        "RNA-Seq" ;
    schema1:license "GPL (>=2) | file LICENSE" ;
    schema1:name "bioconductor-condcomp" ;
    schema1:url "https://bioconductor.org/packages/3.8/bioc/html/condcomp.html" .

