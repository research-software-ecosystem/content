@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:hmftools-gripss a schema1:SoftwareApplication ;
    schema1:description "Gripss applies a set of filtering and post processing steps on gridss paired tumor-normal output to produce a high confidence set of somatic sv for a tumor sample." ;
    schema1:keywords "Genomics",
        "Sequence Alignment" ;
    schema1:license "Not available" ;
    schema1:name "hmftools-gripss" ;
    schema1:url "https://github.com/hartwigmedical/hmftools/tree/master/gripss" .

