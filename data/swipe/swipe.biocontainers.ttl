@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:swipe a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/1471-2105-12-221" ;
    schema1:description "Tool for performing rapid local alignment searches in amino acid or nucleotide" ;
    schema1:identifier biotools:swipe ;
    schema1:keywords "Amino Acid Sequence",
        "Computers",
        "Databases, Protein",
        "Molecular Sequence Data",
        "Molecular biology",
        "Programming Languages",
        "Proteins",
        "Sequence Alignment",
        "Sequence analysis" ;
    schema1:license "AGPL-3.0" ;
    schema1:name "swipe" ;
    schema1:url "https://github.com/torognes/swipe" .

