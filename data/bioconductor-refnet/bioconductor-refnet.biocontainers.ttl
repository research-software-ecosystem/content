@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-refnet a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Molecular interactions with metadata, some archived, some dynamically obtained." ;
    schema1:identifier biotools:refnet ;
    schema1:keywords "Computational Biology",
        "Data management",
        "Gene Expression Profiling",
        "Genomics",
        "High-Throughput Screening Assays",
        "Molecular interactions, pathways and networks",
        "Programming Languages",
        "User-Computer Interface" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-refnet" ;
    schema1:url "http://bioconductor.org/packages/release/bioc/html/RefNet.html" .

