@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:perl-moose a schema1:SoftwareApplication ;
    schema1:description "A postmodern object system for Perl 5" ;
    schema1:license "perl_5" ;
    schema1:name "perl-moose" ;
    schema1:url "http://moose.perl.org/" .

