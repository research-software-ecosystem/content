@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:phate a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/s41587-019-0336-3" ;
    schema1:description "Phate (potential of heat-diffusion for affinity-based transition embedding) is a tool for visualizing high dimensional data." ;
    schema1:keywords "Animals",
        "Big Data",
        "Cell Differentiation",
        "Cells, Cultured",
        "Computer Simulation",
        "Databases, Genetic",
        "Gastrointestinal Microbiome",
        "Genomics",
        "High-Throughput Screening Assays",
        "Humans",
        "Image Processing, Computer-Assisted",
        "Mice",
        "RNA-Seq",
        "Sequence Analysis, RNA",
        "Single-Cell Analysis" ;
    schema1:license "GNU General Public License v2.0" ;
    schema1:name "phate" ;
    schema1:url "https://github.com/KrishnaswamyLab/PHATE" .

