@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:rmap a schema1:SoftwareApplication ;
    schema1:description "rmap is a short reads mapper for next-generation sequencing data" ;
    schema1:downloadUrl "http://smithlabresearch.org/downloads/rmap-2.1.tar.bz2" ;
    schema1:identifier biotools:rmap ;
    schema1:license "GNU General Public License v3 (GPLv3)" ;
    schema1:name "rmap" ;
    schema1:softwareVersion "2.1" ;
    schema1:url "http://smithlabresearch.org/software/rmap/" ;
    spdx:builtFrom biotools:rmap .

