@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:rmap a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/1471-2105-14-184",
        "doi:10.1186/1471-2105-9-128" ;
    schema1:description "rmap is a short reads mapper for next-generation sequencing data" ;
    schema1:identifier biotools:rmap ;
    schema1:keywords "Benchmarking",
        "Epigenetics",
        "Genome",
        "High-Throughput Nucleotide Sequencing",
        "Sequence Alignment",
        "Sequence Analysis, DNA" ;
    schema1:license "GPL-3.0" ;
    schema1:name "rmap" ;
    schema1:url "https://github.com/smithlabcode/rmap" .

