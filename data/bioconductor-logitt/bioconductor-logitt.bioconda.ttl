@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-logitt a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "logit-t Package" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.17/bioc/src/contrib/logitT_1.58.0.tar.gz', 'https://bioconductor.org/packages/3.17/bioc/src/contrib/Archive/logitT/logitT_1.58.0.tar.gz', 'https://bioarchive.galaxyproject.org/logitT_1.58.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-logitt/bioconductor-logitt_1.58.0_src_all.tar.gz']" ;
    schema1:identifier biotools:logitt ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-logitt" ;
    schema1:softwareVersion "1.58.0" ;
    schema1:url "https://bioconductor.org/packages/3.17/bioc/html/logitT.html" ;
    spdx:builtFrom biotools:logitt .

