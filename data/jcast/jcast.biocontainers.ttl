@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:jcast a schema1:SoftwareApplication ;
    schema1:description "Jcast retrieves splice junction information and translates into amino acids" ;
    schema1:keywords "Protein Sequences",
        "Proteomics",
        "RNA-Seq" ;
    schema1:license "Not available" ;
    schema1:name "jcast" ;
    schema1:url "https://github.com/ed-lau/jcast" .

