@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-annmap a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/gkm779" ;
    schema1:description "Genome annotation and visualisation package pertaining to Affymetrix arrays and NGS analysis." ;
    schema1:identifier biotools:annmap ;
    schema1:keywords "Alternative Splicing",
        "Animals",
        "Chromosome Mapping",
        "Computer Graphics",
        "Data visualisation",
        "Databases, Genetic",
        "Exons",
        "Gene Expression Profiling",
        "Genomics",
        "Humans",
        "Internet",
        "Mice",
        "Nucleic acids",
        "Oligonucleotide Array Sequence Analysis",
        "Rats",
        "User-Computer Interface" ;
    schema1:license "GPL-2.0" ;
    schema1:name "bioconductor-annmap" ;
    schema1:url "https://www.bioconductor.org/packages/release/bioc/html/annmap.html" .

