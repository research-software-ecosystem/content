@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-annmap a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/gkm779" ;
    schema1:description "Genome annotation and visualisation package pertaining to Affymetrix arrays and NGS analysis." ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/annmap_1.52.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/annmap/annmap_1.52.0.tar.gz', 'https://bioarchive.galaxyproject.org/annmap_1.52.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-annmap/bioconductor-annmap_1.52.0_src_all.tar.gz']" ;
    schema1:identifier biotools:annmap ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-annmap" ;
    schema1:softwareVersion "1.52.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/annmap.html" ;
    spdx:builtFrom biotools:annmap .

