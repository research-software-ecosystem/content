@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-rariant a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Identification and Assessment of Single Nucleotide Variants through Shifts in Non-Consensus Base Call Frequencies" ;
    schema1:identifier biotools:rariant ;
    schema1:keywords "Computational Biology",
        "Gene Expression Profiling",
        "Genetic variation",
        "Genomics",
        "High-Throughput Screening Assays",
        "Programming Languages",
        "User-Computer Interface" ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-rariant" ;
    schema1:url "http://bioconductor.org/packages/3.6/bioc/html/Rariant.html" .

