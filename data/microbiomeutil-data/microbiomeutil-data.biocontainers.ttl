@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:microbiomeutil-data a schema1:SoftwareApplication ;
    schema1:description "Reference 16s sequences and nast-alignments used by microbiomeutil tools" ;
    schema1:keywords "Clustering",
        "Sequence Alignment" ;
    schema1:license "BSD-3-clause" ;
    schema1:name "microbiomeutil-data" ;
    schema1:url "http://microbiomeutil.sourceforge.net/" .

