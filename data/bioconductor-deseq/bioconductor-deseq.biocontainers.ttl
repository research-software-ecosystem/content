@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-deseq a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/gb-2010-11-10-r106",
        "doi:10.7490/f1000research.1114334.1" ;
    schema1:description "Differential gene expression analysis based on the negative binomial distribution" ;
    schema1:identifier biotools:deseq ;
    schema1:keywords "Animals",
        "Binomial Distribution",
        "Chromatin Immunoprecipitation",
        "Computational Biology",
        "Drosophila",
        "Gene Expression",
        "Gene Expression Profiling",
        "Gene expression",
        "High-Throughput Nucleotide Sequencing",
        "Linear Models",
        "Models, Genetic",
        "RNA-Seq",
        "Saccharomyces cerevisiae",
        "Sequence Analysis, RNA",
        "Stem Cells",
        "Tissue Culture Techniques" ;
    schema1:license "GPL-3.0" ;
    schema1:name "bioconductor-deseq" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/DESeq.html" .

