@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:spyder a schema1:SoftwareApplication ;
    schema1:description "Spyder is a free and open source scientific environment written in Python, for Python, and designed by and for scientists, engineers and data analysts." ;
    schema1:license "MIT" ;
    schema1:name "spyder" ;
    schema1:url "https://github.com/spyder-ide/spyder" .

