@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:imsindel a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/s41598-018-23978-z" ;
    schema1:description "An accurate intermediate-size indel detection tool incorporating de novo assembly and gapped global-local alignment with split read analysis" ;
    schema1:identifier biotools:imsindel ;
    schema1:keywords "Cell Line, Tumor",
        "Computational Biology",
        "DNA",
        "Genome, Human",
        "Humans",
        "INDEL Mutation",
        "Mapping",
        "Sequence analysis",
        "Sequence assembly",
        "Whole Exome Sequencing" ;
    schema1:license "MIT" ;
    schema1:name "imsindel" ;
    schema1:url "https://github.com/NCGG-MGC/IMSindel" .

