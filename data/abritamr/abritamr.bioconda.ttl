@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:abritamr a schema1:SoftwareApplication ;
    schema1:author "kristyhoran" ;
    schema1:description "Idenify bacterial AMR genes and SNPs in genome assemblies" ;
    schema1:downloadUrl "https://pypi.org/packages/source/a/abritamr/abritamr-1.2.0.tar.gz" ;
    schema1:identifier biotools:abritamr ;
    schema1:license "GPL-3.0-only" ;
    schema1:maintainer "kristyhoran" ;
    schema1:name "abritamr" ;
    schema1:softwareVersion "1.2.0" ;
    schema1:url "https://github.com/MDU-PHL/abritamr" ;
    spdx:builtFrom biotools:abritamr .

