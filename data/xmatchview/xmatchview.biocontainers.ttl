@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:xmatchview a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1101/238220" ;
    schema1:description "Genome sequence alignment visualization" ;
    schema1:identifier biotools:xmatchview ;
    schema1:keywords "Data visualisation",
        "Sequence analysis" ;
    schema1:license "Not available" ;
    schema1:name "xmatchview" ;
    schema1:url "https://github.com/bcgsc/xmatchview/releases" .

