@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:crispritz a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/BIOINFORMATICS/BTZ867" ;
    schema1:description "CRISPRitz, tool package for CRISPR experiments assessment and analysis." ;
    schema1:keywords "CRISPR-Cas Systems",
        "Clustered Regularly Interspaced Short Palindromic Repeats",
        "Gene Editing",
        "RNA, Guide" ;
    schema1:license "GPL-3.0" ;
    schema1:name "crispritz" ;
    schema1:url "https://github.com/pinellolab/CRISPRitz" .

