@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-mirnapath a schema1:SoftwareApplication ;
    schema1:description "miRNApath: Pathway Enrichment for miRNA Expression Data" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/miRNApath_1.70.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/miRNApath/miRNApath_1.70.0.tar.gz', 'https://bioarchive.galaxyproject.org/miRNApath_1.70.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-mirnapath/bioconductor-mirnapath_1.70.0_src_all.tar.gz']" ;
    schema1:identifier biotools:mirnapath ;
    schema1:license "LGPL-2.1" ;
    schema1:name "bioconductor-mirnapath" ;
    schema1:softwareVersion "1.70.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/miRNApath.html" ;
    spdx:builtFrom biotools:mirnapath .

