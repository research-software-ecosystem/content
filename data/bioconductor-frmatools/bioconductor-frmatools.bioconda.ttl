@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-frmatools a schema1:SoftwareApplication ;
    schema1:description "Frozen RMA Tools" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/frmaTools_1.58.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/frmaTools/frmaTools_1.58.0.tar.gz', 'https://bioarchive.galaxyproject.org/frmaTools_1.58.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-frmatools/bioconductor-frmatools_1.58.0_src_all.tar.gz']" ;
    schema1:identifier biotools:frmatools ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-frmatools" ;
    schema1:softwareVersion "1.58.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/frmaTools.html" ;
    spdx:builtFrom biotools:frmatools .

