@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-frmatools a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/1471-2105-12-369" ;
    schema1:description "Frozen RMA Tools" ;
    schema1:identifier biotools:frmatools ;
    schema1:keywords "Animals",
        "Databases, Factual",
        "Freezing",
        "Gene expression",
        "Humans",
        "Molecular biology",
        "Oligonucleotide Array Sequence Analysis",
        "Preservation, Biological" ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-frmatools" ;
    schema1:url "https://www.bioconductor.org/packages/release/bioc/html/frmaTools.html" .

