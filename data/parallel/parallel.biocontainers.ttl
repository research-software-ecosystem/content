@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:parallel a schema1:SoftwareApplication ;
    schema1:description "Gnu parallel is a shell tool for executing jobs in parallel using one or more computers." ;
    schema1:license "GPL-3.0" ;
    schema1:name "parallel" ;
    schema1:url "http://ftpmirror.gnu.org/parallel/" .

