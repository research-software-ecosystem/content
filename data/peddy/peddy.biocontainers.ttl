@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:peddy a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1016/j.ajhg.2017.01.017" ;
    schema1:description "Genotype ped correspondence check, ancestry check, sex check, quickly on vcf" ;
    schema1:keywords "Chromosomes, Human, X",
        "Exome",
        "Female",
        "Genetic Association Studies",
        "Genetic Loci",
        "Genetics",
        "Genome, Human",
        "Genomics",
        "Genotype",
        "Humans",
        "Machine Learning",
        "Male",
        "Pedigree",
        "Polymorphism, Single Nucleotide",
        "Sequence Analysis, DNA" ;
    schema1:license "MIT" ;
    schema1:name "peddy" ;
    schema1:url "https://github.com/brentp/peddy" .

