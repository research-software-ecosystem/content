@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:verifyidintensity a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1016/j.ajhg.2012.09.004" ;
    schema1:description "verifyIDintensity detects and estimates sample contamination using intensity data from Illumina genotyping arrays." ;
    schema1:keywords "DNA Contamination",
        "Diabetes Mellitus, Type 2",
        "Genetics",
        "Genotype",
        "Humans",
        "Sequence Analysis, DNA" ;
    schema1:license "GPL-3" ;
    schema1:name "verifyidintensity" ;
    schema1:url "https://genome.sph.umich.edu/wiki/VerifyIDintensity" .

