@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:ncrf a schema1:SoftwareApplication ;
    schema1:description "Noise-Cancelling Repeat Finder, Uncovering tandem repeats in error-prone long-read sequencing data." ;
    schema1:license "MIT" ;
    schema1:name "ncrf" ;
    schema1:url "https://github.com/makovalab-psu/NoiseCancellingRepeatFinder" .

