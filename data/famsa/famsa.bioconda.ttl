@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:famsa a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/srep33964" ;
    schema1:description "Algorithm for large-scale multiple sequence alignments." ;
    schema1:downloadUrl "https://github.com/refresh-bio/famsa/releases/download/v2.4.1/famsa-v2.4.1-arm64_mac.tar.gz" ;
    schema1:identifier biotools:famsa ;
    schema1:license "GPL-3.0-or-later" ;
    schema1:name "famsa" ;
    schema1:softwareVersion "2.4.1" ;
    schema1:url "https://github.com/refresh-bio/FAMSA" ;
    spdx:builtFrom biotools:famsa .

