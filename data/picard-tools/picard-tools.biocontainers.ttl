@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:picard-tools a schema1:SoftwareApplication ;
    schema1:description "Command line tools to manipulate sam and bam files" ;
    schema1:license "MIT" ;
    schema1:name "picard-tools" ;
    schema1:url "http://broadinstitute.github.io/picard/" .

