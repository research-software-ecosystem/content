@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:pureclip a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s13059-017-1364-2" ;
    schema1:description "Pureclip is a tool to detect protein-rna interaction footprints from single-nucleotide clip-seq data, such as iclip and eclip." ;
    schema1:keywords "Binding Sites",
        "Computational Biology",
        "High-Throughput Nucleotide Sequencing",
        "Markov Chains",
        "Nucleotide Motifs",
        "RNA",
        "RNA-Binding Proteins",
        "Reproducibility of Results",
        "Sequence Analysis, RNA" ;
    schema1:license "GPL-3.0" ;
    schema1:name "pureclip" ;
    schema1:url "https://github.com/skrakau/PureCLIP" .

