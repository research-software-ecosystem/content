  "@graph": [
    {
      "@id": "https://bio.tools/bioconductor-sitadela",
      "@type": "sc:SoftwareApplication",
      "dcterms:conformsTo": "https://bioschemas.org/profiles/ComputationalTool/0.6-DRAFT",
      "sc:additionalType": [
        "Command-line tool",
        "Library"
      ],
      "sc:author": "Panagiotis Moulos",
      "sc:citation": {
        "@id": "https://doi.org/10.18129/B9.bioc.sitadela"
      },
      "sc:description": "Provides an interface to build a unified database of genomic annotations and their coordinates (gene, transcript and exon levels). It is aimed to be used when simple tab-delimited annotations (or simple GRanges objects) are required instead of the more complex annotation Bioconductor packages. Also useful when combinatorial annotation elements are reuired, such as RefSeq coordinates with Ensembl biotypes. Finally, it can download, construct and handle annotations with versioned genes and transcripts (where available, e.g. RefSeq and latest Ensembl). This is particularly useful in precision medicine applications where the latter must be reported.",
      "sc:license": "Artistic-2.0",
      "sc:name": "sitadela",
      "sc:operatingSystem": [
        "Windows",
        "Linux",
        "Mac"
      ],
      "sc:softwareHelp": {
        "@id": "https://bioconductor.org/packages/sitadela"
      },
      "sc:softwareVersion": "1.18.0",
      "sc:url": "https://bioconductor.org/packages/sitadela"
    },
    {
