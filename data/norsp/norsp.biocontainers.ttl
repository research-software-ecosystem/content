@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:norsp a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1016/s0022-2836(02)00736-2",
        "doi:10.1093/nar/gkg515" ;
    schema1:description "Norsp (predictor of non-regular secondary structure) is a tool for predicting disordered regions in proteins." ;
    schema1:identifier biotools:norsp ;
    schema1:keywords "Internet",
        "Protein Structure",
        "Protein Structure, Secondary",
        "Protein disordered structure",
        "Protein folds and structural domains",
        "Protein secondary structure",
        "Proteins",
        "Sequence Analysis, Protein",
        "Software Design",
        "Structure prediction",
        "User-Computer Interface" ;
    schema1:license "GPL-3.0+" ;
    schema1:name "norsp" ;
    schema1:url "https://rostlab.org/owiki/index.php/NORSp_-_predictor_of_NOn-Regular_Secondary_Structure" .

