  "@graph": [
    {
      "@id": "https://bio.tools/bioconductor-lemur",
      "@type": "sc:SoftwareApplication",
      "dcterms:conformsTo": "https://bioschemas.org/profiles/ComputationalTool/0.6-DRAFT",
      "sc:additionalType": [
        "Library",
        "Command-line tool"
      ],
      "sc:author": "Constantin Ahlmann-Eltze",
      "sc:citation": {
        "@id": "https://doi.org/10.1101/2023.03.06.531268"
      },
      "sc:description": "Fit a latent embedding multivariate regression (LEMUR) model to multi-condition single-cell data. The model provides a parametric description of single-cell data measured with treatment vs. control or more complex experimental designs. The parametric model is used to (1) align conditions, (2) predict log fold changes between conditions for all cells, and (3) identify cell neighborhoods with consistent log fold changes. For those neighborhoods, a pseudobulked differential expression test is conducted to assess which genes are significantly changed.",
      "sc:license": "MIT",
      "sc:name": "lemur",
      "sc:operatingSystem": [
        "Windows",
        "Mac",
        "Linux"
      ],
      "sc:softwareHelp": {
        "@id": "https://bioconductor.org/packages/lemur"
      },
      "sc:softwareVersion": "1.8.0",
      "sc:url": "https://bioconductor.org/packages/lemur"
    },
    {
      "@id": "https://doi.org/10.1101/2023.03.06.531268",
      "@type": "sc:CreativeWork"
    }
