@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:dfam a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/gks1265" ;
    schema1:description "The dfam database is a collection of repetitive dna element sequence alignments, hidden markov models (hmms) and matches lists for complete eukaryote genomes" ;
    schema1:keywords "DNA Transposable Elements",
        "Databases, Nucleic Acid",
        "Genome, Human",
        "Humans",
        "Internet",
        "Markov Chains",
        "Models, Statistical",
        "Molecular Sequence Annotation" ;
    schema1:license "GPL" ;
    schema1:name "dfam" ;
    schema1:url "https://www.dfam.org" .

