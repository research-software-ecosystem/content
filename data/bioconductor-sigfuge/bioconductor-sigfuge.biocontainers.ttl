        "Cluster Analysis",
        "Data visualisation",
        "Exons",
        "Gene Expression Profiling",
        "Gene expression",
        "Genes, p16",
        "Genetic Loci",
        "Head and Neck Neoplasms",
        "High-Throughput Nucleotide Sequencing",
        "Intracellular Signaling Peptides and Proteins",
        "Kallikreins",
        "Lung Neoplasms",
        "Neoplasms",
        "Nuclear Proteins",
        "RNA",
        "RNA Isoforms",
        "RNA-Seq",
        "Sequence Analysis, RNA",
        "Squamous Cell Carcinoma of Head and Neck" ;
    schema1:license "GPL-3.0" ;
    schema1:name "bioconductor-sigfuge" ;
    schema1:url "https://www.bioconductor.org/packages/release/bioc/html/sigfuge.html" .

