@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-bacon a schema1:SoftwareApplication ;
    schema1:description "Controlling bias and inflation in association studies using the empirical null distribution" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/bacon_1.38.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/bacon/bacon_1.38.0.tar.gz', 'https://bioarchive.galaxyproject.org/bacon_1.38.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-bacon/bioconductor-bacon_1.38.0_src_all.tar.gz']" ;
    schema1:identifier biotools:bacon ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-bacon" ;
    schema1:softwareVersion "1.38.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/bacon.html" ;
    spdx:builtFrom biotools:bacon .

