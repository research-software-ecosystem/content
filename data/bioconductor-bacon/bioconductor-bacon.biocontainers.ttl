@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-bacon a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s13059-016-1131-9" ;
    schema1:description "Controlling bias and inflation in association studies using the empirical null distribution" ;
    schema1:identifier biotools:bacon ;
    schema1:keywords "Age Factors",
        "Bayes Theorem",
        "Bias",
        "Epigenesis, Genetic",
        "Epigenomics",
        "GWAS study",
        "Genome-Wide Association Study",
        "Humans",
        "Meta-Analysis as Topic",
        "Smoking",
        "Transcriptome",
        "Transcriptomics" ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-bacon" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/bacon.html" .

