@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:logol a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1007/978-3-319-09192-1_4" ;
    schema1:description "Logol is a pattern matching grammar language and a set of tools to search a pattern in a sequence (nucleic or proteic)" ;
    schema1:identifier biotools:logol ;
    schema1:keywords "Protein Sequences",
        "Sequence sites, features and motifs" ;
    schema1:license "GPL-3.0" ;
    schema1:name "logol" ;
    schema1:url "https://github.com/genouest/logol" .

