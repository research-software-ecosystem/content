@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-randpack a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Randomization routines for Clinical Trials" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/randPack_1.56.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/randPack/randPack_1.56.0.tar.gz', 'https://bioarchive.galaxyproject.org/randPack_1.56.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-randpack/bioconductor-randpack_1.56.0_src_all.tar.gz']" ;
    schema1:identifier biotools:randpack ;
    schema1:license "Artistic 2.0" ;
    schema1:name "bioconductor-randpack" ;
    schema1:softwareVersion "1.56.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/randPack.html" ;
    spdx:builtFrom biotools:randpack .

