@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:pythomics a schema1:SoftwareApplication ;
    schema1:description "A multi-omic python package" ;
    schema1:keywords "Genomics",
        "Proteomics",
        "Transcriptomics" ;
    schema1:license "GPL-3.0" ;
    schema1:name "pythomics" ;
    schema1:url "https://github.com/pandeylab/pythomics" .

