@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:dbgraph a schema1:SoftwareApplication ;
    schema1:description "A graph-centric approach for metagenome-guided peptide identification in metaproteomics. " ;
    schema1:keywords "Mass spectra",
        "Metagenome",
        "Peptides",
        "Proteomics",
        "Transcriptome" ;
    schema1:license "GPL-3.0" ;
    schema1:name "dbgraph" ;
    schema1:url "https://github.com/COL-IU/graph2pro-var/" .

