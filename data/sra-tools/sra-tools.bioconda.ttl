@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:sra-tools a schema1:SoftwareApplication ;
    schema1:author "rajwanir2" ;
    schema1:description "The SRA Toolkit and SDK from NCBI." ;
    schema1:downloadUrl "https://ftp-trace.ncbi.nlm.nih.gov/sra/sdk/3.4.1/sratoolkit.3.4.1-alma_linux64.tar.gz",
        "https://ftp-trace.ncbi.nlm.nih.gov/sra/sdk/3.4.1/sratoolkit.3.4.1-mac-arm64.tar.gz",
        "https://ftp-trace.ncbi.nlm.nih.gov/sra/sdk/3.4.1/sratoolkit.3.4.1-mac-x86_64.tar.gz" ;
    schema1:identifier biotools:sra-tools ;
    schema1:license "Public Domain" ;
    schema1:maintainer "rajwanir2" ;
    schema1:name "sra-tools" ;
    schema1:softwareHelp "https://github.com/ncbi/sra-tools/wiki" ;
    schema1:softwareVersion "3.4.1" ;
    schema1:url "https://github.com/ncbi/sra-tools" ;
    spdx:builtFrom biotools:sra-tools .

