@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-cma a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/1471-2105-9-439" ;
    schema1:description "Synthesis of microarray-based classification" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/CMA_1.68.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/CMA/CMA_1.68.0.tar.gz', 'https://bioarchive.galaxyproject.org/CMA_1.68.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-cma/bioconductor-cma_1.68.0_src_all.tar.gz']" ;
    schema1:identifier biotools:cma ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-cma" ;
    schema1:softwareVersion "1.68.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/CMA.html" ;
    spdx:builtFrom biotools:cma .

