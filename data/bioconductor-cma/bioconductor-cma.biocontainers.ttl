@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-cma a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/1471-2105-9-439" ;
    schema1:description "Synthesis of microarray-based classification" ;
    schema1:identifier biotools:cma ;
    schema1:keywords "Area Under Curve",
        "Computational Biology",
        "Computer Simulation",
        "Discriminant Analysis",
        "Genomics",
        "Internet",
        "Least-Squares Analysis",
        "Logistic Models",
        "Microarray Analysis",
        "Microarray experiment",
        "Models, Statistical",
        "Monte Carlo Method",
        "Neural Networks, Computer",
        "Reproducibility of Results",
        "Sensitivity and Specificity",
        "Statistics, Nonparametric",
        "User-Computer Interface" ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-cma" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/CMA.html" .

