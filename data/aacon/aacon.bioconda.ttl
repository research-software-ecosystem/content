@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:aacon a schema1:SoftwareApplication ;
    schema1:description "AACon: A Fast Amino Acid Conservation Calculation Service" ;
    schema1:downloadUrl "https://github.com/bartongroup/aacon/releases/download/v1.1/compbio-conservation-1.1.jar" ;
    schema1:identifier biotools:aacon ;
    schema1:license "Apache-2.0" ;
    schema1:name "aacon" ;
    schema1:softwareVersion "1.1" ;
    schema1:url "https://www.compbio.dundee.ac.uk/aacon/" ;
    spdx:builtFrom biotools:aacon .

