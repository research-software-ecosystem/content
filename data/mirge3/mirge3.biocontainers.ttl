@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:mirge3 a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s12859-018-2287-y" ;
    schema1:description "Comprehensive analysis of small rna sequencing data" ;
    schema1:keywords "Animals",
        "Computational Biology",
        "High-Throughput Nucleotide Sequencing",
        "Humans",
        "Mice",
        "MicroRNAs",
        "Phylogeny",
        "Rats",
        "Sequence Analysis, RNA" ;
    schema1:license "Not available" ;
    schema1:name "mirge3" ;
    schema1:url "https://github.com/mhalushka/miRge3.0/" .

