@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:poretools a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btu555" ;
    schema1:description "Flexible toolkit for exploring datasets generated by nanopore sequencing devices from minion for the purposes of quality control and downstream analysis." ;
    schema1:identifier biotools:poretools ;
    schema1:keywords "DNA",
        "Nanopores",
        "Sequence Analysis, DNA",
        "Sequencing" ;
    schema1:license "MIT" ;
    schema1:name "poretools" ;
    schema1:url "https://github.com/arq5x/poretools" .

