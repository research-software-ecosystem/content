@prefix debianmed: <https://salsa.debian.org/med-team/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

debianmed:poretools a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btu555" ;
    schema1:description "toolkit for nanopore nucleotide sequencing data" ;
    schema1:identifier "bio.tools:poretools",
        "conda:bioconda:poretools",
        "omictools:OMICS_07584" ;
    schema1:license "unknown" ;
    schema1:name "poretools" ;
    schema1:softwareVersion "0.6.0" ;
    schema1:url "https://poretools.readthedocs.org" ;
    spdx:builtFrom "poretools" .

