@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:repdenovo a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1371/journal.pone.0150719" ;
    schema1:description "REPdenovo is designed for constructing repeats directly from sequence reads." ;
    schema1:downloadUrl "https://github.com/simoncchu/REPdenovo/archive/refs/tags/v0.1.0.tar.gz" ;
    schema1:identifier biotools:repdenovo ;
    schema1:license "MIT" ;
    schema1:name "repdenovo" ;
    schema1:softwareHelp "https://github.com/simoncchu/REPdenovo/blob/v0.1.0/README.md" ;
    schema1:softwareVersion "0.1.0" ;
    schema1:url "https://github.com/Reedwarbler/REPdenovo" ;
    spdx:builtFrom biotools:repdenovo .

