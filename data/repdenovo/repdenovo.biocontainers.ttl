@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:repdenovo a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1371/journal.pone.0150719" ;
    schema1:description "REPdenovo is designed for constructing repeats directly from sequence reads." ;
    schema1:identifier biotools:repdenovo ;
    schema1:keywords "Genome, Human",
        "Humans",
        "Repetitive Sequences, Nucleic Acid",
        "Sequence assembly",
        "Sequence composition, complexity and repeats",
        "Sequencing" ;
    schema1:license "MIT" ;
    schema1:name "repdenovo" ;
    schema1:url "https://github.com/Reedwarbler/REPdenovo" .

