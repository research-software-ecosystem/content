@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:pretextsnapshot a schema1:SoftwareApplication ;
    schema1:description "Commandline image generator for Pretext Hi-C genome contact maps." ;
    schema1:license "MIT" ;
    schema1:name "pretextsnapshot" ;
    schema1:url "https://github.com/wtsi-hpag/PretextSnapshot" .

