    schema1:description "A Robust and Scalable Software Package for Reproducible Analysis of High-Throughput genotype-phenotype association" ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-openstats" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/OpenStats.html" .

