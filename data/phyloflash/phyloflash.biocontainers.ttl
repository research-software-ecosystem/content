@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:phyloflash a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1128/msystems.00920-20" ;
    schema1:description "Phyloflash is a pipeline to rapidly reconstruct the ssu rrnas and explore phylogenetic composition of an illumina (meta) genomic dataset." ;
    schema1:keywords "Metagenome" ;
    schema1:license "GNU General Public License v3.0" ;
    schema1:name "phyloflash" ;
    schema1:url "https://github.com/HRGV/phyloFlash" .

