@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-csar a schema1:SoftwareApplication ;
    schema1:description "Statistical tools for the analysis of ChIP-seq data" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/CSAR_1.58.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/CSAR/CSAR_1.58.0.tar.gz', 'https://bioarchive.galaxyproject.org/CSAR_1.58.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-csar/bioconductor-csar_1.58.0_src_all.tar.gz']" ;
    schema1:identifier biotools:csar ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-csar" ;
    schema1:softwareVersion "1.58.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/CSAR.html" ;
    spdx:builtFrom biotools:csar .

