@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:ucsc-cell-browser a schema1:SoftwareApplication ;
    schema1:description "A browser for single-cell data, main site at http://cells.ucsc.edu" ;
    schema1:keywords "Genomics" ;
    schema1:license "GPL-3.0" ;
    schema1:name "ucsc-cell-browser" ;
    schema1:url "https://github.com/maximilianh/cellBrowser" .

