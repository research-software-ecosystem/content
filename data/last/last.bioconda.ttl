@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:last a schema1:SoftwareApplication ;
    schema1:description "LAST finds & aligns related regions of sequences." ;
    schema1:downloadUrl "https://gitlab.com/mcfrith/last/-/archive/1651/last-1651.tar.gz" ;
    schema1:identifier biotools:last ;
    schema1:license "GPL-3.0-or-later" ;
    schema1:name "last" ;
    schema1:softwareHelp "https://gitlab.com/mcfrith/last/-/blob/1651/doc/last-cookbook.rst" ;
    schema1:softwareVersion "1651" ;
    schema1:url "https://gitlab.com/mcfrith/last" ;
    spdx:builtFrom biotools:last .

