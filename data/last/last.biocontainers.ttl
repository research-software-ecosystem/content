@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:last a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/gkq010" ;
    schema1:description "LAST finds similar regions between sequences, and aligns them." ;
    schema1:identifier biotools:last ;
    schema1:keywords "Animals",
        "Chromosome Mapping",
        "Comparative genomics",
        "Computer Simulation",
        "Drosophila",
        "Drosophila melanogaster",
        "Genomics",
        "Probability",
        "Sequence Alignment",
        "Sequence Analysis, DNA" ;
    schema1:license "GPL-3.0" ;
    schema1:name "last" ;
    schema1:url "http://last.cbrc.jp/" .

