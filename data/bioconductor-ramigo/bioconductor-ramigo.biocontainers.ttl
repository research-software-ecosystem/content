@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-ramigo a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18129/b9.bioc.ramigo" ;
    schema1:description "R interface sending requests to AmiGO visualize, retrieving DAG GO trees, parsing GraphViz DOT format files and exporting GML files for Cytoscape. Deprecated:Also uses RCytoscape to interactively display AmiGO trees in Cytoscape." ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-ramigo" ;
    schema1:url "http://bioconductor.org/packages/3.5/bioc/html/RamiGO.html" .

