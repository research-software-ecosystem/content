@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:qcumber a schema1:SoftwareApplication ;
    schema1:description "Quality control, quality trimming, adapter removal and sequence content check of ngs data." ;
    schema1:license "GNU" ;
    schema1:name "qcumber" ;
    schema1:url "https://gitlab.com/RKIBioinformaticsPipelines/QCumber" .

