@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:biosql a schema1:SoftwareApplication ;
    schema1:description "Biopython support for the biosql database schema (python 2)" ;
    schema1:license "other" ;
    schema1:name "biosql" ;
    schema1:url "https://github.com/biopython/biopython.github.io" .

