@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-cytolib a schema1:SoftwareApplication ;
    schema1:description "C++ infrastructure for representing and interacting with the gated cytometry data" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/cytolib_2.18.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/cytolib/cytolib_2.18.0.tar.gz', 'https://bioarchive.galaxyproject.org/cytolib_2.18.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-cytolib/bioconductor-cytolib_2.18.0_src_all.tar.gz']" ;
    schema1:identifier biotools:cytolib ;
    schema1:license "AGPL-3.0-only" ;
    schema1:name "bioconductor-cytolib" ;
    schema1:softwareVersion "2.18.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/cytolib.html" ;
    spdx:builtFrom biotools:cytolib .

