      "sc:citation": {
        "@id": "https://doi.org/10.1101/2025.08.08.669426"
      },
      "sc:description": "GFFx is a Rust-based toolkit for ultra-fast and scalable genome annotation access. GFFx introduces a compact, model-aware indexing system inspired by binning strategies and leverages Rust’s strengths in execution speed, memory safety, and multithreading. It supports feature- and region-based feature extraction and coverage profiling with significant improvements in runtime and scalability over existing tools.",
      "sc:featureList": [
