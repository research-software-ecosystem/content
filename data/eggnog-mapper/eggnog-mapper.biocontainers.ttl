@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:eggnog-mapper a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/gkw989",
        "doi:10.1093/nar/gky1085" ;
    schema1:description "Fast genome-wide functional annotation through orthology assignment." ;
    schema1:identifier biotools:eggnog-mapper ;
    schema1:keywords "Computational Biology",
        "DNA Barcoding, Taxonomic",
        "Databases, Genetic",
        "Genome",
        "Genomics",
        "Metagenomics",
        "Molecular Sequence Annotation",
        "Ortholog",
        "Prokaryotic Cells",
        "Transcriptome",
        "Web Browser" ;
    schema1:license "AGPL-3.0" ;
    schema1:name "eggnog-mapper" ;
    schema1:url "https://github.com/jhcepas/eggnog-mapper" .

