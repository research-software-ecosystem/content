@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-maskbad a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btp492" ;
    schema1:description "Masking probes with binding affinity differences" ;
    schema1:identifier biotools:maskbad ;
    schema1:keywords "Animals",
        "Computational Biology",
        "Databases, Genetic",
        "Gene Expression",
        "Gene Expression Profiling",
        "Gene expression",
        "Genomics",
        "Humans",
        "Microarray experiment",
        "Oligonucleotide Array Sequence Analysis",
        "Oligonucleotide Probes" ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-maskbad" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/maskBAD.html" .

