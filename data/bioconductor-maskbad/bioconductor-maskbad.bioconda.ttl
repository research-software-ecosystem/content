@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-maskbad a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btp492" ;
    schema1:description "Masking probes with binding affinity differences" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/maskBAD_1.54.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/maskBAD/maskBAD_1.54.0.tar.gz', 'https://bioarchive.galaxyproject.org/maskBAD_1.54.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-maskbad/bioconductor-maskbad_1.54.0_src_all.tar.gz']" ;
    schema1:identifier biotools:maskbad ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-maskbad" ;
    schema1:softwareVersion "1.54.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/maskBAD.html" ;
    spdx:builtFrom biotools:maskbad .

