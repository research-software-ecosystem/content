@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-crisprseek a schema1:SoftwareApplication ;
    schema1:description "Design of target-specific guide RNAs in CRISPR-Cas9, genome-editing systems" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/CRISPRseek_1.46.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/CRISPRseek/CRISPRseek_1.46.0.tar.gz', 'https://bioarchive.galaxyproject.org/CRISPRseek_1.46.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-crisprseek/bioconductor-crisprseek_1.46.0_src_all.tar.gz']" ;
    schema1:identifier biotools:crisprseek ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-crisprseek" ;
    schema1:softwareVersion "1.46.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/CRISPRseek.html" ;
    spdx:builtFrom biotools:crisprseek .

