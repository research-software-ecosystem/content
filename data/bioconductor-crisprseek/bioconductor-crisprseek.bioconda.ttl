@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-crisprseek a schema1:SoftwareApplication ;
    schema1:description "Design of guide RNAs in CRISPR genome-editing systems" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/CRISPRseek_1.50.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/CRISPRseek/CRISPRseek_1.50.0.tar.gz', 'https://bioarchive.galaxyproject.org/CRISPRseek_1.50.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-crisprseek/bioconductor-crisprseek_1.50.0_src_all.tar.gz']" ;
    schema1:identifier biotools:crisprseek ;
    schema1:license "file LICENSE" ;
    schema1:name "bioconductor-crisprseek" ;
    schema1:softwareVersion "1.50.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/CRISPRseek.html" ;
    spdx:builtFrom biotools:crisprseek .

