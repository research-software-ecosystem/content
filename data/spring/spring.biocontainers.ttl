    schema1:description "Spring is a compression tool for Fastq files" ;
    schema1:identifier biotools:spring ;
    schema1:keywords "Chromosome Inversion",
        "Chromosomes",
        "Chromosomes, Bacterial",
        "DNA",
        "Gammaproteobacteria",
        "Gene Order",
        "Gene Rearrangement",
        "Genomics",
        "Internet",
        "Phylogenetics",
        "Phylogeny",
        "Recombination, Genetic",
        "Sequencing",
        "User-Computer Interface",
        "Vibrio" ;
    schema1:license "Free for non-commercial use" ;
    schema1:name "spring" ;
    schema1:url "https://github.com/shubhamchandak94/Spring" .

