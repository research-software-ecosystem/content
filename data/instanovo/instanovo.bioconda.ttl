@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:instanovo a schema1:SoftwareApplication ;
    schema1:author "BioGeek" ;
    schema1:citation "doi:10.1038/s42256-025-01019-5" ;
    schema1:description "InstaNovo enables diffusion-powered de novo peptide sequencing in large scale proteomics experiments." ;
    schema1:downloadUrl "https://pypi.org/packages/source/i/instanovo/instanovo-1.2.2.tar.gz" ;
    schema1:identifier biotools:instanovo ;
    schema1:license "Apache-2.0" ;
    schema1:maintainer "BioGeek" ;
    schema1:name "instanovo" ;
    schema1:softwareHelp "https://instadeepai.github.io/InstaNovo/" ;
    schema1:softwareVersion "1.2.2" ;
    schema1:url "https://github.com/instadeepai/instanovo" ;
    spdx:builtFrom biotools:instanovo .

