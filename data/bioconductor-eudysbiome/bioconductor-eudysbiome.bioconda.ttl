bioconda:bioconductor-eudysbiome a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s12918-016-0344-6" ;
    schema1:description "Cartesian plot and contingency test on 16S Microbial data" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/eudysbiome_1.40.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/eudysbiome/eudysbiome_1.40.0.tar.gz', 'https://bioarchive.galaxyproject.org/eudysbiome_1.40.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-eudysbiome/bioconductor-eudysbiome_1.40.0_src_all.tar.gz']" ;
    schema1:identifier biotools:eudysbiome ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-eudysbiome" ;
    schema1:softwareVersion "1.40.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/eudysbiome.html" ;
    spdx:builtFrom biotools:eudysbiome .

