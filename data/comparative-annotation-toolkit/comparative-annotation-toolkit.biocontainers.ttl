@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:comparative-annotation-toolkit a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1101/231118" ;
    schema1:description "A straightforward end-to-end pipeline that takes as input a hal-format multiple whole genome alignment as well as a gff3 file representing annotations on one high quality assembly in the hal alignment, and produces a output gff3 annotation on all target genomes chosen" ;
    schema1:keywords "Genomics",
        "Ortholog",
        "RNA-Seq" ;
    schema1:license "Apache-2.0" ;
    schema1:name "comparative-annotation-toolkit" ;
    schema1:url "https://github.com/ComparativeGenomicsToolkit/Comparative-Annotation-Toolkit" .

