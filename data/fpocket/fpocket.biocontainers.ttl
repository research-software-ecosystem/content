@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:fpocket a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/gkq383",
        "doi:10.1186/1471-2105-10-168" ;
    schema1:description "Fpocket: An open source platform for ligand pocket detection" ;
    schema1:identifier biotools:fpocket ;
    schema1:keywords "Binding Sites",
        "Ligands",
        "Protein Binding",
        "Protein Conformation",
        "Protein Structure",
        "Protein Structure, Tertiary",
        "Protein structural motifs and surfaces",
        "Proteins" ;
    schema1:license "MIT" ;
    schema1:name "fpocket" ;
    schema1:url "https://github.com/Discngine/fpocket" .

