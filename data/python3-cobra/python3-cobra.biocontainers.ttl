@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:python3-cobra a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/1752-0509-7-74" ;
    schema1:description "Cobrapy is a package for constraint-based modeling of biological networks." ;
    schema1:keywords "Genomics",
        "Metabolic Networks and Pathways",
        "Models, Biological",
        "Programming Languages" ;
    schema1:license "GPL-2.0" ;
    schema1:name "python3-cobra" ;
    schema1:url "https://github.com/opencobra/cobrapy" .

