@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:genomebaser a schema1:SoftwareApplication ;
    schema1:description "Genomebaser manages complete (bacterial) genomes from ncbi" ;
    schema1:license "Apache 2.0 license" ;
    schema1:name "genomebaser" ;
    schema1:url "http://github.com/mscook/GenomeBaser" .

