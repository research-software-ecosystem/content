@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:quast a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btt086" ;
    schema1:description "QUAST performs fast and convenient quality evaluation and comparison of genome assemblies." ;
    schema1:identifier biotools:quast ;
    schema1:keywords "Animals",
        "Chromosome Mapping",
        "Contig Mapping",
        "Escherichia coli",
        "Genome",
        "Genomic Structural Variation",
        "Genomics",
        "Humans",
        "Metagenome",
        "Quality Control",
        "Sequence Alignment",
        "Sequence Analysis, DNA",
        "Sequence assembly" ;
    schema1:license "GPL-2.0" ;
    schema1:name "quast" ;
    schema1:url "https://sourceforge.net/projects/quast/" .

