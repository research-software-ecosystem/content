@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:quast a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btt086" ;
    schema1:description "Quality Assessment Tool for Genome Assemblies." ;
    schema1:downloadUrl "['https://github.com/ablab/quast/releases/download/quast_5.3.0/quast-5.3.0.tar.gz', 'http://downloads.sourceforge.net/project/quast/quast-5.3.0.tar.gz']" ;
    schema1:identifier biotools:quast ;
    schema1:license "Custom" ;
    schema1:name "quast" ;
    schema1:softwareHelp "https://quast.sourceforge.net/docs/manual.html" ;
    schema1:softwareVersion "5.3.0" ;
    schema1:url "https://quast.sourceforge.net" ;
    spdx:builtFrom biotools:quast .

