@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:ac a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1007/s12539-019-00322-1" ;
    schema1:description "A lossless compression tool for Amino Acid sequences" ;
    schema1:keywords "Amino Acid Sequence",
        "Data Compression",
        "High-Throughput Nucleotide Sequencing",
        "Markov Chains" ;
    schema1:license "GPL-3.0" ;
    schema1:name "ac" ;
    schema1:url "https://github.com/cobilab/ac" .

