        "Computational Biology",
        "DNA",
        "Humans",
        "Programming Languages",
        "Proteins" ;
    schema1:license "MIT" ;
    schema1:name "python3-csb" ;
    schema1:url "https://github.com/csb-toolbox/CSB" .

