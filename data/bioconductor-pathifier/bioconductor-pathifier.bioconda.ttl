@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-pathifier a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1073/pnas.1219651110" ;
    schema1:description "Quantify deregulation of pathways in cancer" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/pathifier_1.44.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/pathifier/pathifier_1.44.0.tar.gz', 'https://bioarchive.galaxyproject.org/pathifier_1.44.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-pathifier/bioconductor-pathifier_1.44.0_src_all.tar.gz']" ;
    schema1:identifier biotools:pathifier ;
    schema1:license "Artistic-1.0" ;
    schema1:name "bioconductor-pathifier" ;
    schema1:softwareVersion "1.44.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/pathifier.html" ;
    spdx:builtFrom biotools:pathifier .

