@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:snpeff a schema1:SoftwareApplication ;
    schema1:description "Genetic variant annotation and effect prediction toolbox" ;
    schema1:downloadUrl "https://snpeff-public.s3.amazonaws.com/versions/snpEff_v5_4c_core.zip" ;
    schema1:identifier biotools:snpeff ;
    schema1:license "LGPLv3" ;
    schema1:name "snpeff" ;
    schema1:softwareVersion "5.4.0c" ;
    schema1:url "http://snpeff.sourceforge.net/" ;
    spdx:builtFrom biotools:snpeff .

