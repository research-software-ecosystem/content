@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:snpeff a schema1:SoftwareApplication ;
    schema1:citation "doi:10.4161/fly.19695" ;
    schema1:description "Variant annotation and effect prediction tool. it annotates and predicts the effects of variants on genes and proteins (such as amino acid changes)." ;
    schema1:identifier biotools:snpeff ;
    schema1:keywords "Animals",
        "DNA polymorphism",
        "Drosophila melanogaster",
        "Genetic variation",
        "Genome, Insect",
        "Male",
        "Molecular Sequence Annotation",
        "Nucleic acid sites, features and motifs",
        "Polymorphism, Single Nucleotide" ;
    schema1:license "LGPL-3.0" ;
    schema1:name "snpeff" ;
    schema1:url "http://snpeff.sourceforge.net/" .

