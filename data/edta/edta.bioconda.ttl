@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:edta a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1101/2022.10.09.511471",
        "doi:10.1186/s13059-019-1905-y" ;
    schema1:description "Extensive de-novo TE Annotator." ;
    schema1:downloadUrl "https://github.com/oushujun/EDTA/archive/v2.3.0.tar.gz" ;
    schema1:identifier biotools:EDTA ;
    schema1:license "GPL-3.0-only" ;
    schema1:name "edta" ;
    schema1:softwareHelp "https://github.com/oushujun/EDTA/wiki" ;
    schema1:softwareVersion "2.3.0" ;
    schema1:url "https://github.com/oushujun/EDTA" ;
    spdx:builtFrom biotools:EDTA .

