@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:biopet-fastqsplitter a schema1:SoftwareApplication ;
    schema1:description "This tool divides a fastq file into smaller fastq files, based on the number of output files specified." ;
    schema1:license "MIT" ;
    schema1:name "biopet-fastqsplitter" ;
    schema1:url "https://github.com/biopet/fastq-splitter" .

