@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioepic a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btz232" ;
    schema1:description "Chip-Seq broad peak/domain finder." ;
    schema1:keywords "Chromatin Immunoprecipitation",
        "Chromatin Immunoprecipitation Sequencing",
        "High-Throughput Nucleotide Sequencing",
        "Sequence Analysis, DNA" ;
    schema1:license "GPL-3.0" ;
    schema1:name "bioepic" ;
    schema1:url "https://github.com/biocore-ntnu/epic2" .

