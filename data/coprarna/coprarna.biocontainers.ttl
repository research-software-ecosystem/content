@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:coprarna a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1073/pnas.1303248110",
        "doi:10.1093/nar/gku359" ;
    schema1:description "Target prediction for prokaryotic trans-acting small rnas" ;
    schema1:identifier biotools:coprarna ;
    schema1:keywords "Base Sequence",
        "Computational Biology",
        "Enterobacteriaceae",
        "Escherichia coli",
        "Evolution, Molecular",
        "Gene Expression Regulation, Bacterial",
        "Gene Regulatory Networks",
        "Genomics",
        "Phylogeny",
        "RNA, Bacterial",
        "Salmonella enterica",
        "Sequence analysis" ;
    schema1:license "MIT" ;
    schema1:name "coprarna" ;
    schema1:url "https://github.com/PatrickRWright/CopraRNA" .

