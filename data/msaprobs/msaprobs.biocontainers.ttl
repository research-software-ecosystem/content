@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:msaprobs a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btq338",
        "doi:10.1093/bioinformatics/btw558" ;
    schema1:description "MSAProbs is a well-established state-of-the-art multiple sequence alignment algorithm for protein sequences." ;
    schema1:identifier biotools:msaprobs ;
    schema1:keywords "Amino Acid Sequence",
        "Computational Biology",
        "Genomics",
        "Markov Chains",
        "Metagenomics",
        "Probability",
        "Protein Sequences",
        "Sequence Alignment",
        "Sequence Analysis, Protein",
        "Sequence analysis" ;
    schema1:license "GPL-3.0" ;
    schema1:name "msaprobs" ;
    schema1:url "http://msaprobs.sourceforge.net/homepage.htm" .

