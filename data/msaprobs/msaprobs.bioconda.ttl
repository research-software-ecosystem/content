@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:msaprobs a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btq338" ;
    schema1:description "MSAProbs is a well-established state-of-the-art multiple sequence alignment algorithm for protein sequences." ;
    schema1:downloadUrl "https://sourceforge.net/projects/msaprobs/files/MSAProbs-0.9.7.tar.gz" ;
    schema1:identifier biotools:msaprobs ;
    schema1:license "GPL-3.0-or-later" ;
    schema1:name "msaprobs" ;
    schema1:softwareHelp "https://msaprobs.sourceforge.net/homepage.htm#latest" ;
    schema1:softwareVersion "0.9.7" ;
    schema1:url "https://msaprobs.sourceforge.net/homepage.htm#latest" ;
    spdx:builtFrom biotools:msaprobs .

