@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-qiimer a schema1:SoftwareApplication ;
    schema1:description "Open QIIME output files in R, compute statistics, and create plots from the data." ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "r-qiimer" ;
    schema1:url "https://CRAN.R-project.org/package=qiimer" .

