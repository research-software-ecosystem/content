@prefix debianmed: <https://salsa.debian.org/med-team/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

debianmed:maqview a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1101/gr.078212.108" ;
    schema1:description "graphical read alignment viewer for short gene sequences" ;
    schema1:identifier "bio.tools:Maqview",
        "omictools:OMICS_00889",
        "scicrunch:SCR_005632" ;
    schema1:license "unknown" ;
    schema1:name "maqview" ;
    schema1:softwareVersion "0.2.5" ;
    schema1:url "https://maq.sourceforge.net/maqview.shtml" ;
    spdx:builtFrom "Maqview" .

