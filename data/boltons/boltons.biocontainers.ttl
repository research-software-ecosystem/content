@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:boltons a schema1:SoftwareApplication ;
    schema1:description "Boltons is a set of over 230 BSD-licensed, pure-Python utilities in the same spirit as — and yet conspicuously missing from — the standard library" ;
    schema1:license "BSD-3" ;
    schema1:name "boltons" ;
    schema1:url "https://github.com/mahmoud/boltons" .

