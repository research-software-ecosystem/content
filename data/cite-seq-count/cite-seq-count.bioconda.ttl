@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:cite-seq-count a schema1:SoftwareApplication ;
    schema1:author "acaprez" ;
    schema1:citation "doi:10.5281/zenodo.2590196" ;
    schema1:description "A python package to map reads from CITE-seq or hashing data for single cell experiments." ;
    schema1:downloadUrl "https://pypi.io/packages/source/C/CITE-seq-Count/CITE-seq-Count-1.4.4.tar.gz" ;
    schema1:identifier biotools:CITE-seq-Count ;
    schema1:license "MIT" ;
    schema1:maintainer "acaprez" ;
    schema1:name "cite-seq-count" ;
    schema1:softwareHelp "https://hoohm.github.io/CITE-seq-Count" ;
    schema1:softwareVersion "1.4.5" ;
    schema1:url "https://hoohm.github.io/CITE-seq-Count" ;
    spdx:builtFrom biotools:CITE-seq-Count .

