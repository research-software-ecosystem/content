@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:sdm a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/gkr363" ;
    schema1:description "sdm - simple demultiplex tool for FASTQ demultiplexing and dereplication" ;
    schema1:identifier biotools:sdm ;
    schema1:keywords "Amino Acid Substitution",
        "Disease",
        "Gene and protein families",
        "Genetic variation",
        "Humans",
        "Internet",
        "Mutation",
        "Protein Conformation",
        "Protein Stability",
        "Protein folding, stability and design",
        "Proteins",
        "Small molecules",
        "Structure prediction",
        "Thermodynamics" ;
    schema1:license "GPL-3.0" ;
    schema1:name "sdm" ;
    schema1:url "https://github.com/hildebra/sdm/" .

