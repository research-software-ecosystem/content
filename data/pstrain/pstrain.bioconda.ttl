@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:pstrain a schema1:SoftwareApplication ;
    schema1:author "wshuai294" ;
    schema1:description "An Iterative Microbial Strains Profiling Algorithm for Shotgun Metagenomic Sequencing Data" ;
    schema1:downloadUrl "https://github.com/wshuai294/PStrain/archive/refs/tags/v1.0.3.tar.gz" ;
    schema1:identifier biotools:pstrain ;
    schema1:license "MIT" ;
    schema1:maintainer "wshuai294" ;
    schema1:name "pstrain" ;
    schema1:softwareVersion "1.0.3" ;
    schema1:url "https://github.com/wshuai294/PStrain" ;
    spdx:builtFrom biotools:pstrain .

