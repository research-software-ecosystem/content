@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:quantiprot a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s12859-017-1751-4" ;
    schema1:description "Quantiprot is a python package for quantitative analysis of protein sequences" ;
    schema1:identifier biotools:quantiprot ;
    schema1:keywords "Amino Acids",
        "Cluster Analysis",
        "Humans",
        "Protein sites, features and motifs",
        "Proteins",
        "Sequence Analysis, Protein",
        "Sequence analysis" ;
    schema1:license "MIT" ;
    schema1:name "quantiprot" ;
    schema1:url "https://git.e-science.pl/wdyrka/quantiprot" .

