@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:w4mclstrpeakpics a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1021/ac051437y",
        "doi:10.1093/bioinformatics/btu813" ;
    schema1:description "Visualize w4m sample-cluster peaks - produce a figure to assess the similarities and differences among peaks in a cluster of samples using xcms-preprocessed data files as input. mit licence allows redistribution." ;
    schema1:keywords "Computational Biology",
        "Mass spectrometry",
        "Metabolomics",
        "Workflow" ;
    schema1:license "MIT" ;
    schema1:name "w4mclstrpeakpics" ;
    schema1:url "https://github.com/HegemanLab/w4mclstrpeakpics" .

