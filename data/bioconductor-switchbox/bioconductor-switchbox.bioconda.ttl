@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-switchbox a schema1:SoftwareApplication ;
    schema1:description "Utilities to train and validate classifiers based on pair switching using the K-Top-Scoring-Pair (KTSP) algorithm" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/switchBox_1.42.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/switchBox/switchBox_1.42.0.tar.gz', 'https://bioarchive.galaxyproject.org/switchBox_1.42.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-switchbox/bioconductor-switchbox_1.42.0_src_all.tar.gz']" ;
    schema1:identifier biotools:switchbox ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-switchbox" ;
    schema1:softwareVersion "1.42.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/switchBox.html" ;
    spdx:builtFrom biotools:switchbox .

