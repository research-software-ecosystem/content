    schema1:keywords "Breast Neoplasms",
        "Cohort Studies",
        "Computational Biology",
        "Data architecture, analysis and design",
        "Gene Expression Profiling",
        "Gene expression",
        "Humans",
        "Prognosis",
        "Reproducibility of Results" ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-switchbox" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/switchBox.html" .

