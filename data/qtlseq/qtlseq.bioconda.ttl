@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:qtlseq a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1111/tpj.12105" ;
    schema1:description "QTL-seq: pipeline to identify causative mutations responsible for a phenotype." ;
    schema1:downloadUrl "https://github.com/YuSugihara/QTL-seq/releases/download/v2.3.0/QTL-seq-2.3.0.tar.gz" ;
    schema1:identifier biotools:qtlseq ;
    schema1:license "GPL-3.0-or-later" ;
    schema1:name "qtlseq" ;
    schema1:softwareVersion "2.3.0" ;
    schema1:url "https://github.com/YuSugihara/QTL-seq" ;
    spdx:builtFrom biotools:qtlseq .

