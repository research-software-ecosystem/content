@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:qtlseq a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1111/tpj.12105" ;
    schema1:description "Qtl-seq: pipeline to identify causative mutations responsible for a phenotype" ;
    schema1:identifier biotools:qtlseq ;
    schema1:keywords "Chromosome Mapping",
        "DNA, Plant",
        "Genome, Plant",
        "Oryza",
        "Phenotype",
        "Polymorphism, Single Nucleotide",
        "Quantitative Trait Loci",
        "Sequence Alignment" ;
    schema1:license "GPL-3.0" ;
    schema1:name "qtlseq" ;
    schema1:url "https://github.com/YuSugihara/QTL-seq" .

