@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:plink2 a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s13742-015-0047-8" ;
    schema1:description "Whole genome association analysis toolset, designed to perform a range of basic, large-scale analyses in a computationally efficient manner." ;
    schema1:keywords "Clustering",
        "Genomics" ;
    schema1:license "GPL-3.0" ;
    schema1:name "plink2" ;
    schema1:url "https://www.cog-genomics.org/plink2" .

