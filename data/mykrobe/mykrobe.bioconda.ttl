@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:mykrobe a schema1:SoftwareApplication ;
    schema1:author "martinghunt",
        "mbhall88" ;
    schema1:citation "doi:10.12688/wellcomeopenres.15603.1" ;
    schema1:description "Antibiotic resistance prediction in minutes." ;
    schema1:downloadUrl "https://github.com/Mykrobe-tools/mykrobe/archive/v0.13.0.tar.gz" ;
    schema1:identifier biotools:Mykrobe ;
    schema1:license "MIT" ;
    schema1:maintainer "martinghunt",
        "mbhall88" ;
    schema1:name "mykrobe" ;
    schema1:softwareHelp "https://github.com/Mykrobe-tools/mykrobe/wiki" ;
    schema1:softwareVersion "0.13.0" ;
    schema1:url "https://github.com/Mykrobe-tools/mykrobe" ;
    spdx:builtFrom biotools:Mykrobe .

