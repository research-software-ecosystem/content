@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-pwomics a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btv323" ;
    schema1:description "Pathway-based data integration of omics data" ;
    schema1:identifier biotools:pwomics ;
    schema1:keywords "Bayes Theorem",
        "Computational Biology",
        "Computer Graphics",
        "Data Interpretation, Statistical",
        "Databases, Factual",
        "Genomics",
        "Humans",
        "Proteomics",
        "Signal Transduction",
        "Time Factors",
        "Transcription Factors" ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-pwomics" ;
    schema1:url "http://bioconductor.org/packages/3.6/bioc/html/pwOmics.html" .

