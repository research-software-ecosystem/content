@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-pwomics a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btv323" ;
    schema1:description "Pathway-based data integration of omics data" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.18/bioc/src/contrib/pwOmics_1.34.0.tar.gz', 'https://bioconductor.org/packages/3.18/bioc/src/contrib/Archive/pwOmics/pwOmics_1.34.0.tar.gz', 'https://bioarchive.galaxyproject.org/pwOmics_1.34.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-pwomics/bioconductor-pwomics_1.34.0_src_all.tar.gz']" ;
    schema1:identifier biotools:pwomics ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-pwomics" ;
    schema1:softwareVersion "1.34.0" ;
    schema1:url "https://bioconductor.org/packages/3.18/bioc/html/pwOmics.html" ;
    spdx:builtFrom biotools:pwomics .

