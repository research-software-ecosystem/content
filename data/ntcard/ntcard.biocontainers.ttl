@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:ntcard a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btw832" ;
    schema1:description "Estimating k-mer coverage histogram of genomics data" ;
    schema1:identifier biotools:ntcard ;
    schema1:keywords "Genome Size",
        "Genome, Human",
        "Genome, Plant",
        "Genomics",
        "Humans",
        "Models, Statistical",
        "Picea",
        "Sequence Analysis, DNA",
        "Sequence analysis",
        "Sequencing" ;
    schema1:license "GPL-3.0" ;
    schema1:name "ntcard" ;
    schema1:url "https://github.com/bcgsc/ntCard" .

