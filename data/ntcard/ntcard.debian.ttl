@prefix debianmed: <https://salsa.debian.org/med-team/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

debianmed:ntcard a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btw832" ;
    schema1:identifier "bio.tools:ntcard",
        "conda:bioconda:ntcard" ;
    schema1:license "unknown" ;
    schema1:name "ntcard" ;
    schema1:softwareVersion "1.2.2" ;
    schema1:url "https://github.com/bcgsc/ntCard" ;
    spdx:builtFrom "ntcard" .

