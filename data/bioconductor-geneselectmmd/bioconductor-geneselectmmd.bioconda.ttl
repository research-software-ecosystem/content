@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-geneselectmmd a schema1:SoftwareApplication ;
    schema1:description "Gene selection based on the marginal distributions of gene profiles that characterized by a mixture of three-component multivariate distributions" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/GeneSelectMMD_2.54.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/GeneSelectMMD/GeneSelectMMD_2.54.0.tar.gz', 'https://bioarchive.galaxyproject.org/GeneSelectMMD_2.54.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-geneselectmmd/bioconductor-geneselectmmd_2.54.0_src_all.tar.gz']" ;
    schema1:identifier biotools:geneselectmmd ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-geneselectmmd" ;
    schema1:softwareVersion "2.54.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/GeneSelectMMD.html" ;
    spdx:builtFrom biotools:geneselectmmd .

