@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:nglview a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btx789" ;
    schema1:description "An ipython widget to interactively view molecular structures and trajectories. utilizes the embeddable ngl viewer for rendering." ;
    schema1:identifier biotools:nglview ;
    schema1:keywords "Computational Biology",
        "Data visualisation",
        "Molecular Dynamics",
        "Molecular Dynamics Simulation",
        "Protein structural motifs and surfaces",
        "Protein structure analysis",
        "Proteins" ;
    schema1:license "Not available" ;
    schema1:name "nglview" ;
    schema1:url "https://github.com/arose/nglview" .

