@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:transdecoder a schema1:SoftwareApplication ;
    schema1:description "TransDecoder identifies candidate coding regions within transcript sequences, such as those generated by de novo RNA-Seq transcript assembly using Trinity, or constructed based on RNA-Seq alignments to the genome using Tophat and Cufflinks." ;
    schema1:downloadUrl "https://github.com/TransDecoder/TransDecoder/archive/TransDecoder-v6.0.0.tar.gz" ;
    schema1:identifier biotools:TransDecoder ;
    schema1:license "Broad Institute" ;
    schema1:name "transdecoder" ;
    schema1:softwareHelp "https://github.com/TransDecoder/TransDecoder/wiki" ;
    schema1:softwareVersion "6.0.0" ;
    schema1:url "https://transdecoder.github.io" ;
    spdx:builtFrom biotools:TransDecoder .

