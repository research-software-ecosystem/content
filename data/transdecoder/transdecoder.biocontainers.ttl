@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:transdecoder a schema1:SoftwareApplication ;
    schema1:description "Transdecoder identifies candidate coding regions within transcript sequences, such as those generated by de novo rna-seq transcript assembly using trinity, or constructed based on rna-seq alignments to the genome using tophat and cufflinks." ;
    schema1:license "Apache-2.0" ;
    schema1:name "transdecoder" ;
    schema1:url "https://github.com/TransDecoder/TransDecoder" .

