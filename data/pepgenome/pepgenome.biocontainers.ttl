@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:pepgenome a schema1:SoftwareApplication ;
    schema1:description "A java tool to map peptide and peptidoform evideces to ENSEMBL Genome Coordinates" ;
    schema1:keywords "Genomics",
        "Proteomics" ;
    schema1:license "Apache-2.0" ;
    schema1:name "pepgenome" ;
    schema1:url "https://github.com/bigbio/pgatk/" .

