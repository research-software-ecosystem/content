@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:logol-bin a schema1:SoftwareApplication ;
    schema1:description "Pattern matching grammar language and a set of tools to search a pattern in a sequence (nucleic or proteic)." ;
    schema1:license "CECILL-2.0" ;
    schema1:name "logol-bin" ;
    schema1:url "http://logol.genouest.org" .

