@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:phantompeakqualtools a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nbt.1508",
        "doi:10.1101/gr.136184.111",
        "doi:10.1534/g3.113.008680" ;
    schema1:description "This package computes informative enrichment and quality measures for chip-seq/dnase-seq/faire-seq/mnase-seq data. it can also be used to obtain robust estimates of the predominant fragment length or characteristic tag shift values in these assays." ;
    schema1:identifier biotools:phantompeakqualtools ;
    schema1:keywords "Binding Sites",
        "ChIP-on-chip",
        "ChIP-seq",
        "Chromatin Immunoprecipitation",
        "Computational Biology",
        "DNA-Binding Proteins",
        "Genetics",
        "Protein Binding",
        "Research Design",
        "Sequence Analysis, DNA",
        "Transcription Factors",
        "Transcription factors and regulatory sites" ;
    schema1:license "BSD 3-Clause \"New\" or \"Revised\" License" ;
    schema1:name "phantompeakqualtools" ;
    schema1:url "https://github.com/kundajelab/phantompeakqualtools" .

