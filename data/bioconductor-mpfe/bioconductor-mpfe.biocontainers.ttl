@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-mpfe a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s12859-015-0600-6" ;
    schema1:description "Estimation of the amplicon methylation pattern distribution from bisulphite sequencing data" ;
    schema1:identifier biotools:mpfe ;
    schema1:keywords "Animals",
        "Bees",
        "Brain",
        "Cytosine",
        "DNA Methylation",
        "Documentation",
        "Epigenetics",
        "High-Throughput Nucleotide Sequencing",
        "Methylated DNA immunoprecipitation",
        "Models, Statistical",
        "Programming Languages",
        "Sequence sites, features and motifs",
        "Sulfites" ;
    schema1:license "GPL-3.0" ;
    schema1:name "bioconductor-mpfe" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/MPFE.html" .

