@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-mpfe a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s12859-015-0600-6" ;
    schema1:description "Estimation of the amplicon methylation pattern distribution from bisulphite sequencing data" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/MPFE_1.46.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/MPFE/MPFE_1.46.0.tar.gz', 'https://bioarchive.galaxyproject.org/MPFE_1.46.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-mpfe/bioconductor-mpfe_1.46.0_src_all.tar.gz']" ;
    schema1:identifier biotools:mpfe ;
    schema1:license "GPL (>= 3)" ;
    schema1:name "bioconductor-mpfe" ;
    schema1:softwareVersion "1.46.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/MPFE.html" ;
    spdx:builtFrom biotools:mpfe .

