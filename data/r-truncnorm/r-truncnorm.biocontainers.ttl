@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-truncnorm a schema1:SoftwareApplication ;
    schema1:description "Density, probability, quantile and random number generation functions for the truncated normal distribution." ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "r-truncnorm" ;
    schema1:url "https://github.com/olafmersmann/truncnorm" .

