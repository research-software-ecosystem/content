@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:cyushuffle a schema1:SoftwareApplication ;
    schema1:description "A Cython wrapper over uShuffle - a useful tool for shuffling biological sequences while preserving the k-let counts" ;
    schema1:license "BSD" ;
    schema1:name "cyushuffle" ;
    schema1:url "https://github.com/guma44/ushuffle" .

