    {
      "@id": "https://bio.tools/bioconductor-spacexr",
      "@type": "sc:SoftwareApplication",
      "dcterms:conformsTo": "https://bioschemas.org/profiles/ComputationalTool/0.6-DRAFT",
      "sc:additionalType": [
        "Library",
        "Command-line tool"
      ],
      "sc:author": [
        "Rafael Irizarry",
        "Dylan Cable"
      ],
      "sc:citation": {
        "@id": "https://doi.org/10.1038/s41587-021-00830-w"
      },
      "sc:contributor": "Fannie and John Hertz Foundation",
      "sc:description": "Spatial-eXpression-R (spacexr) is a package for analyzing cell types in spatial transcriptomics data. This implementation is a fork of the spacexr GitHub repo (https://github.com/dmcable/spacexr), adapted to work with Bioconductor objects. The original package implements two statistical methods: RCTD for learning cell types and CSIDE for inferring cell type-specific differential expression. Currently, this fork only implements RCTD, which learns cell type profiles from annotated RNA sequencing (RNA-seq) reference data and uses these profiles to identify cell types in spatial transcriptomic pixels while accounting for platform-specific effects. Future releases will include an implementation of CSIDE.",
      "sc:funder": "Fannie and John Hertz Foundation",
      "sc:license": "GPL-3.0-or-later",
      "sc:name": "spacexr",
      "sc:operatingSystem": [
        "Mac",
        "Linux",
        "Windows"
      ],
