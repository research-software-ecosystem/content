@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:deeplc a schema1:SoftwareApplication ;
    schema1:author "compomics" ;
    schema1:citation "doi:10.1038/s41592-021-01301-5" ;
    schema1:description "DeepLC: Retention time prediction for (modified) peptides using Deep Learning." ;
    schema1:downloadUrl "https://pypi.io/packages/source/D/DeepLC/deeplc-3.1.13.tar.gz" ;
    schema1:identifier biotools:deeplc ;
    schema1:license "Apache-2.0" ;
    schema1:maintainer "compomics" ;
    schema1:name "deeplc" ;
    schema1:softwareHelp "https://github.com/compomics/DeepLC/blob/v3.1.13/README.md" ;
    schema1:softwareVersion "3.1.13" ;
    schema1:url "https://compomics.github.io/projects/DeepLC" ;
    spdx:builtFrom biotools:deeplc .

