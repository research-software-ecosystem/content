@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-htsfilter a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btt350" ;
    schema1:description "This package implements a filtering procedure for replicated transcriptome sequencing data based on a global jaccard similarity index in order to identify genes with low, constant levels of expression across one or more experimental conditions." ;
    schema1:identifier biotools:htsfilter ;
    schema1:keywords "Animals",
        "Gene Expression Profiling",
        "Gene expression",
        "High-Throughput Nucleotide Sequencing",
        "Humans",
        "Mice",
        "Sequence Analysis, RNA",
        "Sequencing",
        "Transcriptome",
        "Transcriptomics" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-htsfilter" ;
    schema1:url "http://bioconductor.org/packages/release/bioc/html/HTSFilter.html" .

