@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-digest a schema1:SoftwareApplication ;
    schema1:description "Implementation of a function digest() for the creation of hash digests of arbitrary R objects" ;
    schema1:license "GPL-2.0" ;
    schema1:name "r-digest" ;
    schema1:url "http://dirk.eddelbuettel.com/code/digest.html" .

