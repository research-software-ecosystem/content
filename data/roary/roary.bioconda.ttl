@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:roary a schema1:SoftwareApplication ;
    schema1:description "Rapid large-scale prokaryote pan genome analysis" ;
    schema1:downloadUrl "http://search.cpan.org/CPAN/authors/id/A/AJ/AJPAGE/Bio-Roary-3.13.0.tar.gz" ;
    schema1:identifier biotools:roary ;
    schema1:license "GPL-3.0" ;
    schema1:name "roary" ;
    schema1:softwareVersion "3.13.0" ;
    schema1:url "https://github.com/sanger-pathogens/Roary" ;
    spdx:builtFrom biotools:roary .

