@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:roary a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btv421" ;
    schema1:description "A high speed stand alone pan genome pipeline, which takes annotated assemblies in gff3 format (produced by prokka (seemann, 2014)) and calculates the pan genome." ;
    schema1:identifier biotools:roary ;
    schema1:keywords "Computer Simulation",
        "DNA",
        "Databases, Genetic",
        "Genome, Bacterial",
        "Genomics",
        "Mapping",
        "Prokaryotic Cells",
        "Salmonella typhi" ;
    schema1:license "GPL-3" ;
    schema1:name "roary" ;
    schema1:url "https://github.com/sanger-pathogens/Roary" .

