@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:fastq-join a schema1:SoftwareApplication ;
    schema1:description "Similar to audy stitch program, but in C, more efficient and supports some automatic benchmarking and tuning. It uses the same \"squared distance for anchored alignment as other tools." ;
    schema1:license "MIT" ;
    schema1:name "fastq-join" ;
    schema1:url "https://github.com/brwnj/fastq-join" .

