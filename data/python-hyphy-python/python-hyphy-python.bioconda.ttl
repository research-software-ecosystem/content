@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:python-hyphy-python a schema1:SoftwareApplication ;
    schema1:description "HyPhy package interface library" ;
    schema1:downloadUrl "https://github.com/veg/hyphy-python/archive/0.1.12.tar.gz" ;
    schema1:identifier biotools:HyPhy ;
    schema1:license "MIT" ;
    schema1:name "python-hyphy-python" ;
    schema1:softwareVersion "0.1.12" ;
    schema1:url "https://github.com/veg/hyphy-python" ;
    spdx:builtFrom biotools:HyPhy .

