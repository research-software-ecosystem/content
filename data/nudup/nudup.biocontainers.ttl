@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:nudup a schema1:SoftwareApplication ;
    schema1:description "Marks/removes duplicate molecules based on the molecular tagging technology used in nugen products." ;
    schema1:keywords "Genomics" ;
    schema1:license "LGPL-3.0" ;
    schema1:name "nudup" ;
    schema1:url "https://github.com/tecangenomics/nudup" .

