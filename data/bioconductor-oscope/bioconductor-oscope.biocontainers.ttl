@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-oscope a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3549" ;
    schema1:description "Statistical pipeline developed to identify and recover the base cycle profiles of oscillating genes in an unsynchronized single cell rna-seq experiment. it includes three modules: a sine model module to search for candidate oscillator pairs; a k-medoids clustering module to cluster candidate oscillators into groups; and an extended nearest insertion module to recover the base cycle order for each oscillator group." ;
    schema1:identifier biotools:oscope ;
    schema1:keywords "Analysis of Variance",
        "Clustering",
        "Data Interpretation, Statistical",
        "Embryonic Stem Cells",
        "Gene Expression Profiling",
        "Gene expression",
        "Gene regulation",
        "Humans",
        "Models, Genetic",
        "RNA-Seq",
        "Real-Time Polymerase Chain Reaction",
        "Sequence Analysis, RNA",
        "Single-Cell Analysis" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-oscope" ;
    schema1:url "http://bioconductor.org/packages/release/bioc/html/Oscope.html" .

