@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-oscope a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3549" ;
    schema1:description "Oscope - A statistical pipeline for identifying oscillatory genes in unsynchronized single cell RNA-seq" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/Oscope_1.40.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/Oscope/Oscope_1.40.0.tar.gz', 'https://bioarchive.galaxyproject.org/Oscope_1.40.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-oscope/bioconductor-oscope_1.40.0_src_all.tar.gz']" ;
    schema1:identifier biotools:oscope ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-oscope" ;
    schema1:softwareVersion "1.40.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/Oscope.html" ;
    spdx:builtFrom biotools:oscope .

