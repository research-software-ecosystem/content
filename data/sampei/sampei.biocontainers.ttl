@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:sampei a schema1:SoftwareApplication ;
    schema1:description "SAMPEI, a searching method leveraging high quality query spectra within the same or different dataset to assign target spectra with peptide sequence and undefined modification (mass shift)" ;
    schema1:keywords "Mass spectrometry",
        "Proteomics" ;
    schema1:license "MIT" ;
    schema1:name "sampei" ;
    schema1:url "https://github.com/FenyoLab/SAMPEI" .

