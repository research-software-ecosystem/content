@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-grohmm a schema1:SoftwareApplication ;
    schema1:description "GRO-seq Analysis Pipeline" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.18/bioc/src/contrib/groHMM_1.36.0.tar.gz', 'https://bioconductor.org/packages/3.18/bioc/src/contrib/Archive/groHMM/groHMM_1.36.0.tar.gz', 'https://bioarchive.galaxyproject.org/groHMM_1.36.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-grohmm/bioconductor-grohmm_1.36.0_src_all.tar.gz']" ;
    schema1:identifier biotools:grohmm ;
    schema1:license "GPL-3.0-only" ;
    schema1:name "bioconductor-grohmm" ;
    schema1:softwareVersion "1.36.0" ;
    schema1:url "https://bioconductor.org/packages/3.18/bioc/html/groHMM.html" ;
    spdx:builtFrom biotools:grohmm .

