@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:snippy a schema1:SoftwareApplication ;
    schema1:description "Rapid haploid variant calling and core snp phylogeny generation." ;
    schema1:identifier biotools:snippy ;
    schema1:keywords "DNA polymorphism",
        "Genomics",
        "Model organisms",
        "Phylogenetics",
        "Sequence Alignment" ;
    schema1:license "GPL-3.0" ;
    schema1:name "snippy" ;
    schema1:url "https://github.com/tseemann/snippy" .

