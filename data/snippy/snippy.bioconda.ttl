@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:snippy a schema1:SoftwareApplication ;
    schema1:description "Rapid bacterial SNP calling and core genome alignments" ;
    schema1:downloadUrl "https://github.com/tseemann/snippy/archive/v4.6.0.tar.gz" ;
    schema1:identifier biotools:snippy ;
    schema1:license "GPL-2.0" ;
    schema1:name "snippy" ;
    schema1:softwareVersion "4.6.0" ;
    schema1:url "https://github.com/tseemann/snippy" ;
    spdx:builtFrom biotools:snippy .

