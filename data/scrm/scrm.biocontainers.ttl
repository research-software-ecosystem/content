@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:scrm a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btu861" ;
    schema1:description "Simulator of evolution of genetic sequences" ;
    schema1:keywords "Computer Simulation",
        "Genetic Linkage",
        "Genomics",
        "High-Throughput Nucleotide Sequencing",
        "Models, Genetic",
        "Recombination, Genetic" ;
    schema1:license "GPL-3.0+" ;
    schema1:name "scrm" ;
    schema1:url "https://github.com/scrm/scrm" .

