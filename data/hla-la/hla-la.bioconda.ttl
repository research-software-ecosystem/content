@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:hla-la a schema1:SoftwareApplication ;
    schema1:description "HLA typing from short and long reads" ;
    schema1:downloadUrl "https://github.com/DiltheyLab/HLA-LA/archive/v1.0.4.tar.gz" ;
    schema1:identifier biotools:hla-la ;
    schema1:license "GPL" ;
    schema1:name "hla-la" ;
    schema1:softwareVersion "1.0.4" ;
    schema1:url "https://github.com/DiltheyLab/HLA-LA" ;
    spdx:builtFrom biotools:hla-la .

