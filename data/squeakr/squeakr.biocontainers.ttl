@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:squeakr a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btx636" ;
    schema1:description "An Exact and Approximate k-mer Counting System" ;
    schema1:keywords "Animals",
        "Eukaryota",
        "Gene Expression Profiling",
        "Genome",
        "Genomics",
        "High-Throughput Nucleotide Sequencing",
        "Humans",
        "Sequence Analysis, DNA",
        "Sequence Analysis, RNA" ;
    schema1:license "BSD-3-Clause" ;
    schema1:name "squeakr" ;
    schema1:url "https://github.com/splatlab/squeakr" .

