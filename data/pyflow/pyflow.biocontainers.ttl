@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:pyflow a schema1:SoftwareApplication ;
    schema1:description "Lightweight parallel task engine for python" ;
    schema1:license "BSD-2-clause" ;
    schema1:name "pyflow" ;
    schema1:url "https://github.com/Illumina/pyflow" .

