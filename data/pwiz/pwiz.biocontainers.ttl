@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:pwiz a schema1:SoftwareApplication ;
    schema1:description "The ProteoWizard Library and Tools are a set of modular and extensible open-source, cross-platform tools and software libraries that facilitate proteomics data analysis" ;
    schema1:keywords "Mass spectrometry",
        "Proteomics" ;
    schema1:license "Apache-2.0" ;
    schema1:name "pwiz" ;
    schema1:url "https://github.com/ProteoWizard/pwiz" .

