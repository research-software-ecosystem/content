@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-mmdiff a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/1471-2164-14-826" ;
    schema1:description "This package detects statistically significant difference between read enrichment profiles in different ChIP-Seq samples. To take advantage of shape differences it uses Kernel methods (Maximum Mean Discrepancy, MMD)." ;
    schema1:keywords "Animals",
        "Cell Line",
        "Chromatin Immunoprecipitation",
        "Computational Biology",
        "Computer Simulation",
        "Epigenomics",
        "Histones",
        "Humans",
        "Mice",
        "Sequence Analysis, DNA",
        "Statistics, Nonparametric" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-mmdiff" ;
    schema1:url "None" .

