@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-ballgown a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nbt.3172" ;
    schema1:description "Tools for statistical analysis of assembled transcriptomes, including flexible differential expression analysis, visualization of transcript structures, and matching of assembled transcripts to annotation." ;
    schema1:identifier biotools:ballgown ;
    schema1:keywords "Female",
        "Gene Expression Profiling",
        "Gene Expression Regulation",
        "Gene expression",
        "Gene transcripts",
        "Humans",
        "Male",
        "Quantitative Trait Loci",
        "RNA, Messenger",
        "Transcriptome",
        "Transcriptomics" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-ballgown" ;
    schema1:url "http://bioconductor.org/packages/release/bioc/html/ballgown.html" .

