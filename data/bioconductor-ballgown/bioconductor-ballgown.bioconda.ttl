@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-ballgown a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nbt.3172" ;
    schema1:description "Flexible, isoform-level differential expression analysis" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/ballgown_2.38.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/ballgown/ballgown_2.38.0.tar.gz', 'https://bioarchive.galaxyproject.org/ballgown_2.38.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-ballgown/bioconductor-ballgown_2.38.0_src_all.tar.gz']" ;
    schema1:identifier biotools:ballgown ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-ballgown" ;
    schema1:softwareVersion "2.38.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/ballgown.html" ;
    spdx:builtFrom biotools:ballgown .

