@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:tvc a schema1:SoftwareApplication ;
    schema1:description "Genetic variant caller for ion torrent sequencing platforms" ;
    schema1:keywords "Gene Expression",
        "Genetic variation",
        "Genetics",
        "Genomics",
        "Mass spectrometry",
        "Metagenomics",
        "Peptides",
        "RNA-Seq",
        "Transcriptome",
        "Whole genome sequencing" ;
    schema1:license "GPL-2+" ;
    schema1:name "tvc" ;
    schema1:url "http://ioncommunity.thermofisher.com" .

