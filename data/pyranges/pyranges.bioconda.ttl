@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:pyranges a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btz615" ;
    schema1:description "Performant Pythonic GenomicRanges." ;
    schema1:downloadUrl "https://pypi.io/packages/source/p/pyranges/pyranges-0.1.4.tar.gz" ;
    schema1:identifier biotools:PyRanges ;
    schema1:license "MIT" ;
    schema1:name "pyranges" ;
    schema1:softwareHelp "https://pyranges.readthedocs.io" ;
    schema1:softwareVersion "0.1.4" ;
    schema1:url "https://github.com/endrebak/pyranges" ;
    spdx:builtFrom biotools:PyRanges .

