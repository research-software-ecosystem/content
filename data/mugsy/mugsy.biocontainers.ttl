@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:mugsy a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btq665" ;
    schema1:description "Mugsy is a multiple whole genome aligner." ;
    schema1:keywords "Genome, Bacterial",
        "Genomics",
        "Humans",
        "Ortholog",
        "Sequence Alignment",
        "Streptococcus pneumoniae" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "mugsy" ;
    schema1:url "http://mugsy.sourceforge.net" .

