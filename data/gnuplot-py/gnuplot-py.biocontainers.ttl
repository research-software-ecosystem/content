@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:gnuplot-py a schema1:SoftwareApplication ;
    schema1:description "A Python interface to the gnuplot plotting program." ;
    schema1:license "LGPL" ;
    schema1:name "gnuplot-py" ;
    schema1:url "http://gnuplot-py.sourceforge.net" .

