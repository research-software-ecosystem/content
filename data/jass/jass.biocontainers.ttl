@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:jass a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nargab/lqaa003",
        "doi:10.1101/714832v1" ;
    schema1:description "Computation of joint statistics over sets of GWAS results" ;
    schema1:identifier biotools:jass ;
    schema1:keywords "GWAS study",
        "Genetics",
        "Statistics and probability" ;
    schema1:license "MIT" ;
    schema1:name "jass" ;
    schema1:url "http://statistical-genetics.pages.pasteur.fr/jass/" .

