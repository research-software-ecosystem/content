@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-yaqcaffy a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "The package enables users to do quality control of affymetrix genechip expression data and reproducibility analysis of human whole genome chips with the maqc reference datasets." ;
    schema1:identifier biotools:yaqcaffy ;
    schema1:keywords "Computational Biology",
        "Data quality management",
        "Gene Expression Profiling",
        "Gene expression",
        "Genomics",
        "High-Throughput Screening Assays",
        "Microarray experiment",
        "Programming Languages",
        "User-Computer Interface" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-yaqcaffy" ;
    schema1:url "http://bioconductor.org/packages/release/bioc/html/yaqcaffy.html" .

