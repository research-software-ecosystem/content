@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-mdgsa a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s12859-016-0989-6" ;
    schema1:description "Multi Dimensional Gene Set Analysis." ;
    schema1:identifier biotools:mdgsa ;
    schema1:keywords "DNA Copy Number Variations",
        "DNA Methylation",
        "Functional, regulatory and non-coding RNA",
        "Gene expression",
        "Genomics",
        "Humans",
        "MicroRNAs",
        "Microarray experiment",
        "Neoplasms",
        "Oncology",
        "RNA, Messenger" ;
    schema1:license "GPL" ;
    schema1:name "bioconductor-mdgsa" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/mdgsa.html" .

