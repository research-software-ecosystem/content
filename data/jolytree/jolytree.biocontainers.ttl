@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:jolytree a schema1:SoftwareApplication ;
    schema1:description "Fast alignment-free phylogenetic reconstruction from genome sequences" ;
    schema1:keywords "Genetics",
        "Phylogenetics" ;
    schema1:license "GPL-3.0" ;
    schema1:name "jolytree" ;
    schema1:url "https://research.pasteur.fr/fr/software/jolytree/" .

