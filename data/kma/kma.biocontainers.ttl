@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:kma a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s12859-018-2336-6" ;
    schema1:description "KMA is mapping a method designed to map raw reads directly against redundant databases, in an ultra-fast manner using seed and extend." ;
    schema1:keywords "Computational Biology",
        "Computer Simulation",
        "Databases, Factual",
        "Genome, Human",
        "High-Throughput Nucleotide Sequencing",
        "Humans",
        "Sequence Alignment",
        "Sequence Analysis, DNA" ;
    schema1:license "Apache-2.0" ;
    schema1:name "kma" ;
    schema1:url "https://bitbucket.org/genomicepidemiology/kma" .

