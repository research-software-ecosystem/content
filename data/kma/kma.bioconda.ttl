@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:kma a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nargab/lqaf116" ;
    schema1:description "KMA is a mapping method designed to map raw reads directly against redundant databases, in an ultra-fast manner using seed and extend." ;
    schema1:downloadUrl "https://bitbucket.org/genomicepidemiology/kma/get/1.6.11.tar.gz" ;
    schema1:identifier biotools:kma ;
    schema1:license "Apache-2.0" ;
    schema1:name "kma" ;
    schema1:softwareHelp "https://bitbucket.org/genomicepidemiology/kma/src/1.6.11/README.md" ;
    schema1:softwareVersion "1.6.11" ;
    schema1:url "https://bitbucket.org/genomicepidemiology/kma" ;
    spdx:builtFrom biotools:kma .

