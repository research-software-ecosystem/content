@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:jgoslin a schema1:SoftwareApplication ;
    schema1:citation "doi:10.5281/zenodo.7018207" ;
    schema1:description "This project is a parser, validator and normalizer for shorthand lipid names, based on the Goslin project." ;
    schema1:downloadUrl "https://repo1.maven.org/maven2/org/lifs-tools/jgoslin-cli/2.2.0/jgoslin-cli-2.2.0-bin.zip" ;
    schema1:identifier biotools:jgoslin ;
    schema1:license "Apache License 2.0" ;
    schema1:name "jgoslin" ;
    schema1:softwareVersion "2.2.0" ;
    schema1:url "https://github.com/lifs-tools/jgoslin" ;
    spdx:builtFrom biotools:jgoslin .

