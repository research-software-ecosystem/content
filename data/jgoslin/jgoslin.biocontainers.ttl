@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:jgoslin a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1021/acs.analchem.0c01690" ;
    schema1:description "This project is a parser, validator and normalizer for shorthand lipid names, based on the goslin project." ;
    schema1:identifier biotools:jgoslin ;
    schema1:license "Apache License 2.0" ;
    schema1:name "jgoslin" ;
    schema1:url "https://github.com/lifs-tools/jgoslin" .

