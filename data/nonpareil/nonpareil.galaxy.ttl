@prefix edam: <http://edamontology.org/> .
@prefix galaxytool: <https://github.com/galaxyproject/tools-iuc/tree/master/tools/> .
@prefix schema1: <http://schema.org/> .

galaxytool:nonpareil a schema1:SoftwareApplication ;
    schema1:description "Estimate average coverage in metagenomic datasets" ;
    schema1:featureList edam:operation_0004 ;
    schema1:identifier "bioconda:nonpareil",
        "biotools:nonpareil" ;
    schema1:keywords "Metagenomics" ;
    schema1:name "nonpareil" ;
    schema1:softwareVersion "3.5.5" ;
    schema1:url "http://nonpareil.readthedocs.io" .

