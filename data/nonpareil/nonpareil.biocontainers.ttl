@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:nonpareil a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btt584" ;
    schema1:description "Estimate average coverage and create nonpareil curves for metagenomic datasets." ;
    schema1:keywords "Metagenome",
        "Metagenomics",
        "Microbiota",
        "Soil Microbiology" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "nonpareil" ;
    schema1:url "http://enve-omics.ce.gatech.edu/nonpareil/" .

