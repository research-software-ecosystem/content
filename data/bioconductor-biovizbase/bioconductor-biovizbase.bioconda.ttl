@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-biovizbase a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Basic graphic utilities for visualization of genomic data." ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/biovizBase_1.54.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/biovizBase/biovizBase_1.54.0.tar.gz', 'https://bioarchive.galaxyproject.org/biovizBase_1.54.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-biovizbase/bioconductor-biovizbase_1.54.0_src_all.tar.gz']" ;
    schema1:identifier biotools:biovizbase ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-biovizbase" ;
    schema1:softwareVersion "1.54.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/biovizBase.html" ;
    spdx:builtFrom biotools:biovizbase .

