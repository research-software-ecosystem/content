@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:motifscan a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/gkl585" ;
    schema1:description "A package for motif discovery and motif enrichment analysis" ;
    schema1:identifier biotools:motifscan ;
    schema1:keywords "Binding Sites",
        "DNA",
        "Gene Expression",
        "Humans",
        "Models, Genetic",
        "Models, Statistical",
        "Nucleotides",
        "Regulatory Elements, Transcriptional",
        "Saccharomyces cerevisiae",
        "Sequence Analysis, DNA",
        "Transcription Factors" ;
    schema1:license "BSD License" ;
    schema1:name "motifscan" ;
    schema1:url "https://github.com/shao-lab/MotifScan" .

