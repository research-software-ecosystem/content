@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:sherpas a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1101/2020.06.22.161422" ;
    schema1:description "A new, alignment-free genome recombination detection tool exploiting the idea of phylo-kmers (Linard et al. 2019) to accelerate the process by several orders of magnitude while keeping comparable accuracy." ;
    schema1:license "MIT" ;
    schema1:name "sherpas" ;
    schema1:url "https://github.com/phylo42/sherpas" .

