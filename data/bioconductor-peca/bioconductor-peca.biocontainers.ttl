@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-peca a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1007/978-1-4939-6518-2_11" ;
    schema1:description "Probe-level Expression Change Averaging" ;
    schema1:identifier biotools:peca ;
    schema1:keywords "Alternative Splicing",
        "Data Interpretation, Statistical",
        "Gene Expression",
        "Gene Expression Profiling",
        "Gene expression",
        "Humans",
        "Microarray experiment",
        "Proteomics",
        "Proteomics experiment",
        "Transcriptome" ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-peca" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/PECA.html" .

