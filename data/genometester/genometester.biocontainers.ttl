@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:genometester a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/1471-2105-7-172" ;
    schema1:description "Analyse whether pcr primers have excessive number of binding sites in large genomes, how many pcr products would be amplified in the reaction and where are they located." ;
    schema1:identifier biotools:genometester ;
    schema1:keywords "Base Sequence",
        "Binding Sites",
        "DNA Primers",
        "Genome, Human",
        "Humans",
        "Molecular Sequence Data",
        "Polymerase Chain Reaction",
        "Sequence analysis" ;
    schema1:license "GPL-3.0+" ;
    schema1:name "genometester" ;
    schema1:url "http://bioinfo.ut.ee/genometester" .

