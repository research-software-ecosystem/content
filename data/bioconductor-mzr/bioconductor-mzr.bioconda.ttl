@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-mzr a schema1:SoftwareApplication ;
    schema1:description "parser for netCDF, mzXML and mzML and mzIdentML files (mass spectrometry data)" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/mzR_2.40.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/mzR/mzR_2.40.0.tar.gz', 'https://bioarchive.galaxyproject.org/mzR_2.40.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-mzr/bioconductor-mzr_2.40.0_src_all.tar.gz']" ;
    schema1:identifier biotools:mzr ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-mzr" ;
    schema1:softwareVersion "2.40.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/mzR.html" ;
    spdx:builtFrom biotools:mzr .

