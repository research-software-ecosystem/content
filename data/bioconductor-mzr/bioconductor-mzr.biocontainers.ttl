    schema1:keywords "Data management",
        "Databases, Protein",
        "Mass spectrometry",
        "Proteins",
        "Proteome",
        "Proteomics",
        "Proteomics experiment",
        "User-Computer Interface" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-mzr" ;
    schema1:url "None" .

