@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:trycycler a schema1:SoftwareApplication ;
    schema1:author "galladoalba",
        "thanhleviet" ;
    schema1:citation "doi:10.1186/s13059-021-02483-z" ;
    schema1:description "Trycycler is a tool for generating consensus long-read assemblies for bacterial genomes." ;
    schema1:downloadUrl "https://github.com/rrwick/Trycycler/archive/v0.5.6.tar.gz" ;
    schema1:identifier biotools:trycycler ;
    schema1:license "GPL-3.0-or-later" ;
    schema1:maintainer "galladoalba",
        "thanhleviet" ;
    schema1:name "trycycler" ;
    schema1:softwareHelp "https://github.com/rrwick/Trycycler/wiki" ;
    schema1:softwareVersion "0.5.6" ;
    schema1:url "https://github.com/rrwick/Trycycler" ;
    spdx:builtFrom biotools:trycycler .

