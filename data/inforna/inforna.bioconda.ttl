@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:inforna a schema1:SoftwareApplication ;
    schema1:description "A server for the design of RNA sequences that fold into a given pseudo-knot free RNA secondary structure." ;
    schema1:downloadUrl "https://github.com/BackofenLab/INFO-RNA/archive/1e9bb8236c13f5861f07dc19625c394aaeae4c79.tar.gz" ;
    schema1:identifier biotools:inforna ;
    schema1:license "MIT-like" ;
    schema1:name "inforna" ;
    schema1:softwareVersion "2.1.2" ;
    schema1:url "https://github.com/BackofenLab/INFO-RNA" ;
    spdx:builtFrom biotools:inforna .

