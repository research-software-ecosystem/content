@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-rcircos a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/1471-2105-14-244" ;
    schema1:description "A simple and flexible way to generate Circos 2D track plot images for genomic data visualization is implemented in this package. The types of plots include: heatmap, histogram, lines, scatterplot, tiles and plot items for further decorations include connector, link (lines and ribbons), and text (gene) label. All functions require only R graphics package that comes with R base installation.  " ;
    schema1:keywords "Animals",
        "Computer Graphics",
        "Gene Expression Profiling",
        "Genome",
        "Genomics",
        "Image Processing, Computer-Assisted",
        "Mice",
        "Rats" ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "r-rcircos" ;
    schema1:url "None" .

