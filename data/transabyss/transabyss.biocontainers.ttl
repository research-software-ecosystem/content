@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:transabyss a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.1517" ;
    schema1:description "De novo assembly of rna-seq data using abyss" ;
    schema1:identifier biotools:trans-abyss ;
    schema1:keywords "Animals",
        "Computational Biology",
        "Gene Expression Profiling",
        "Gene structure",
        "Mice",
        "RNA-Seq",
        "Sequence Analysis, DNA",
        "Sequence assembly",
        "Transcriptome",
        "Transcriptomics" ;
    schema1:license "GPL" ;
    schema1:name "transabyss" ;
    schema1:url "https://github.com/bcgsc/transabyss" .

