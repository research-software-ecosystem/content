@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:genform a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1101/295071" ;
    schema1:description "Generation of molecular formulas by high-resolution MS and MS/MS data" ;
    schema1:keywords "Mass spectrometry",
        "RNA-Seq" ;
    schema1:license "GPL-2.0" ;
    schema1:name "genform" ;
    schema1:url "https://sourceforge.net/projects/genform/" .

