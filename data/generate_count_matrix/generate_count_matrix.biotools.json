        {
            "cmd": "generate_count_matrix [-h] [--gene-col N] [--count-col N]\n                             [--skip-comments] [--skip-lines N]\n                             [--delimiter DELIM] [--round] [--keep-all-genes]\n                             [--version] [--log LOG_FILE]\n                             COUNT_FILE [COUNT_FILE ...]",
