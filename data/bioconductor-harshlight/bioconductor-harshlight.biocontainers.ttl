@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-harshlight a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/1471-2105-6-294" ;
    schema1:description "A \"corrective make-up\" program for microarray chips" ;
    schema1:identifier biotools:harshlight ;
    schema1:keywords "Artifacts",
        "Automation",
        "Cluster Analysis",
        "Computational Biology",
        "Gene Expression Profiling",
        "Gene expression",
        "Humans",
        "Image Processing, Computer-Assisted",
        "Microarray experiment",
        "Models, Statistical",
        "Molecular genetics",
        "Oligonucleotide Array Sequence Analysis",
        "Oligonucleotide Probes",
        "Oligonucleotides" ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-harshlight" ;
    schema1:url "http://bioconductor.org/packages/3.6/bioc/html/Harshlight.html" .

