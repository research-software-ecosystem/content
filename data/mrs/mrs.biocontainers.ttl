@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:mrs a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/gki422" ;
    schema1:description "Information retrieval system for biomedical databanks" ;
    schema1:identifier biotools:mrs ;
    schema1:keywords "Databases, Genetic",
        "Databases, Nucleic Acid",
        "Databases, Protein",
        "Internet",
        "Proteins",
        "Time Factors",
        "User-Computer Interface" ;
    schema1:license "custom, see /usr/share/doc/mrs/copyright" ;
    schema1:name "mrs" ;
    schema1:url "http://mrs.cmbi.ru.nl/" .

