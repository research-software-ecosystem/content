@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:fastme a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/molbev/msv150" ;
    schema1:description "a comprehensive, accurate and fast distance-based phylogeny inference program." ;
    schema1:downloadUrl "https://gite.lirmm.fr/atgc/FastME/-/archive/v2.1.6.3/FastME-v2.1.6.3.tar.gz" ;
    schema1:identifier biotools:fastme ;
    schema1:license "GPL-3.0-only" ;
    schema1:name "fastme" ;
    schema1:softwareHelp "http://www.atgc-montpellier.fr/fastme/usersguide.php" ;
    schema1:softwareVersion "2.1.6.3" ;
    schema1:url "http://www.atgc-montpellier.fr/fastme/binaries.php" ;
    spdx:builtFrom biotools:fastme .

