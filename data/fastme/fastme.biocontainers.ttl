@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:fastme a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1089/106652702761034136",
        "doi:10.1093/molbev/msv150" ;
    schema1:description "a comprehensive, accurate and fast distance-based phylogeny inference program." ;
    schema1:identifier biotools:fastme ;
    schema1:keywords "Bioinformatics",
        "Computer Simulation",
        "Evolution, Molecular",
        "Models, Genetic",
        "Phylogenetics",
        "Phylogeny" ;
    schema1:license "GPL-3.0" ;
    schema1:name "fastme" ;
    schema1:url "https://gite.lirmm.fr/atgc/FastME/" .

