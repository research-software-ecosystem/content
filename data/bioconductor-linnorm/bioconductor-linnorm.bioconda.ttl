@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-linnorm a schema1:SoftwareApplication ;
    schema1:description "Linear model and normality based normalization and transformation method (Linnorm)" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/Linnorm_2.34.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/Linnorm/Linnorm_2.34.0.tar.gz', 'https://bioarchive.galaxyproject.org/Linnorm_2.34.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-linnorm/bioconductor-linnorm_2.34.0_src_all.tar.gz']" ;
    schema1:identifier biotools:linnorm ;
    schema1:license "MIT + file LICENSE" ;
    schema1:name "bioconductor-linnorm" ;
    schema1:softwareVersion "2.34.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/Linnorm.html" ;
    spdx:builtFrom biotools:linnorm .

