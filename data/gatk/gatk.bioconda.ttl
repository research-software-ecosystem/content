@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:gatk a schema1:SoftwareApplication ;
    schema1:description "The full Genome Analysis Toolkit (GATK) framework, v3" ;
    schema1:downloadUrl "https://storage.googleapis.com/gatk-software/package-archive/gatk/GenomeAnalysisTK-3.8-1-0-gf15c1c3ef.tar.bz2" ;
    schema1:identifier biotools:gatk ;
    schema1:license "BSD" ;
    schema1:name "gatk" ;
    schema1:softwareVersion "3.8" ;
    schema1:url "https://www.broadinstitute.org/gatk/" ;
    spdx:builtFrom biotools:gatk .

