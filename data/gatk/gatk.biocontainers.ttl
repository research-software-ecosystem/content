@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:gatk a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1101/gr.107524.110" ;
    schema1:description "The genome analysis toolkit (gatk) is a set of bioinformatic tools for analyzing high-throughput sequencing (hts) and variant call format (vcf) data. the toolkit is well established for germline short variant discovery from whole genome and exome sequencing data. gatk4 expands functionality into copy number and somatic analyses and offers pipeline scripts for workflows." ;
    schema1:identifier biotools:gatk ;
    schema1:keywords "Base Sequence",
        "Genetic variation",
        "Genome",
        "Genomics",
        "Sequence Analysis, DNA",
        "Sequence analysis",
        "Sequencing",
        "Workflows" ;
    schema1:license "Custom License" ;
    schema1:name "gatk" ;
    schema1:url "https://software.broadinstitute.org/gatk/" .

