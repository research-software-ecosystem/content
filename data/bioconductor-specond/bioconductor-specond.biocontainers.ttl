@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-specond a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/gb-2011-12-12-413" ;
    schema1:description "Condition specific detection from expression data" ;
    schema1:identifier biotools:specond ;
    schema1:keywords "Clustering",
        "Gene Expression",
        "Gene expression",
        "Microarray experiment" ;
    schema1:license "LGPL (>=2)" ;
    schema1:name "bioconductor-specond" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/SpeCond.html" .

