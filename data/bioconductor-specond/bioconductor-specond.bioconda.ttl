@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-specond a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/gb-2011-12-12-413" ;
    schema1:description "Condition specific detection from expression data" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/SpeCond_1.60.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/SpeCond/SpeCond_1.60.0.tar.gz', 'https://bioarchive.galaxyproject.org/SpeCond_1.60.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-specond/bioconductor-specond_1.60.0_src_all.tar.gz']" ;
    schema1:identifier biotools:specond ;
    schema1:license "LGPL (>=2)" ;
    schema1:name "bioconductor-specond" ;
    schema1:softwareVersion "1.60.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/SpeCond.html" ;
    spdx:builtFrom biotools:specond .

