@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-ff a schema1:SoftwareApplication ;
    schema1:description "The ff package provides data structures that are stored on disk but behave (almost) as if they were in RAM by transparently mapping only a section (pagesize) in main memory - the effective virtual memory consumption per ff object." ;
    schema1:license "GPL-2.0" ;
    schema1:name "r-ff" ;
    schema1:url "https://cran.r-project.org/package=ff" .

