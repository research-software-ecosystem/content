@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-oligoclasses a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Classes for high-throughput arrays supported by oligo and crlmm" ;
    schema1:identifier biotools:oligoclasses ;
    schema1:keywords "Computational Biology",
        "Gene Expression Profiling",
        "Genetics",
        "Genomics",
        "High-Throughput Screening Assays",
        "Probes and primers",
        "Programming Languages",
        "Sequence analysis",
        "User-Computer Interface" ;
    schema1:license "GPL-2.0" ;
    schema1:name "bioconductor-oligoclasses" ;
    schema1:url "https://www.bioconductor.org/packages/release/bioc/html/oligoClasses.html" .

