@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-anota a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btr146" ;
    schema1:description "ANalysis Of Translational Activity (ANOTA)." ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/anota_1.58.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/anota/anota_1.58.0.tar.gz', 'https://bioarchive.galaxyproject.org/anota_1.58.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-anota/bioconductor-anota_1.58.0_src_all.tar.gz']" ;
    schema1:identifier biotools:anota ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-anota" ;
    schema1:softwareVersion "1.58.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/anota.html" ;
    spdx:builtFrom biotools:anota .

