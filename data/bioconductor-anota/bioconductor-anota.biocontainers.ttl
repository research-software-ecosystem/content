@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-anota a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btr146" ;
    schema1:description "ANalysis Of Translational Activity (ANOTA)." ;
    schema1:identifier biotools:anota ;
    schema1:keywords "Gene Expression Regulation",
        "Gene transcripts",
        "Genome, Human",
        "Genome-Wide Association Study",
        "Genomics",
        "Humans",
        "Protein Biosynthesis",
        "RNA, Messenger",
        "Ribosomes",
        "Transcriptomics" ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-anota" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/anota.html" .

