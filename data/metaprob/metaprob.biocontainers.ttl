@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:metaprob a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btw466" ;
    schema1:description "assembly-assisted tool for un-supervised metagenomic binning" ;
    schema1:keywords "Cluster Analysis",
        "High-Throughput Nucleotide Sequencing",
        "Humans",
        "Metagenomics",
        "Models, Statistical",
        "Sequence Analysis, DNA" ;
    schema1:license "MIT" ;
    schema1:name "metaprob" ;
    schema1:url "https://bitbucket.org/samu661/metaprob/" .

