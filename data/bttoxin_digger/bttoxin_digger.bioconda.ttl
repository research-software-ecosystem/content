@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bttoxin_digger a schema1:SoftwareApplication ;
    schema1:author "liaochenlanruo" ;
    schema1:description "A toxin minging tool for Bacillus thuringiensis" ;
    schema1:downloadUrl "https://github.com/liaochenlanruo/BtToxin_Digger/archive/v1.0.10.tar.gz" ;
    schema1:identifier biotools:bttoxin_digger ;
    schema1:license "GPLv3" ;
    schema1:maintainer "liaochenlanruo" ;
    schema1:name "bttoxin_digger" ;
    schema1:softwareVersion "1.0.10" ;
    schema1:url "https://github.com/liaochenlanruo/BtToxin_Digger/blob/master/README.md" ;
    spdx:builtFrom biotools:bttoxin_digger .

