@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-synlet a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1101/043570" ;
    schema1:description "Hits Selection for Synthetic Lethal RNAi Screen Data" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/synlet_2.6.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/synlet/synlet_2.6.0.tar.gz', 'https://bioarchive.galaxyproject.org/synlet_2.6.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-synlet/bioconductor-synlet_2.6.0_src_all.tar.gz']" ;
    schema1:identifier biotools:synlet ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-synlet" ;
    schema1:softwareVersion "2.6.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/synlet.html" ;
    spdx:builtFrom biotools:synlet .

