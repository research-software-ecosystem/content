@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-synlet a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1101/043570" ;
    schema1:description "Hits Selection for Synthetic Lethal RNAi Screen Data" ;
    schema1:identifier biotools:synlet ;
    schema1:keywords "Data visualisation",
        "Functional, regulatory and non-coding RNA" ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-synlet" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/synlet.html" .

