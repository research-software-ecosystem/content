@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-genemeta a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "A collection of meta-analysis tools for analysing high throughput experimental data." ;
    schema1:identifier biotools:genemeta ;
    schema1:keywords "Computational Biology",
        "Gene Expression Profiling",
        "Genomics",
        "High-Throughput Screening Assays",
        "Programming Languages",
        "Sequencing",
        "User-Computer Interface" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-genemeta" ;
    schema1:url "http://bioconductor.org/packages/release/bioc/html/GeneMeta.html" .

