@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-pipette a schema1:SoftwareApplication ;
    schema1:description "Pipette biological data in and out of R." ;
    schema1:keywords "Genomics" ;
    schema1:license "GPL-3.0" ;
    schema1:name "r-pipette" ;
    schema1:url "https://github.com/acidgenomics/pipette/" .

