@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:biosyntax-common a schema1:SoftwareApplication ;
    schema1:description "Syntax highlighting for computational biology to bring you intuitively close to your data. biosyntax supports .sam, .flagstat, .vcf, .fasta, .fastq, .faidx, .clustal, .pdb, .gtf, .bed files & more." ;
    schema1:license "GPL-3.0" ;
    schema1:name "biosyntax-common" ;
    schema1:url "https://github.com/bioSyntax/bioSyntax" .

