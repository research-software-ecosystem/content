@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:seqfu a schema1:SoftwareApplication ;
    schema1:description "A collection of utilities to manipulate fasta and fastq files, supporting gzipped input." ;
    schema1:identifier biotools:seqfu ;
    schema1:license "MIT" ;
    schema1:name "seqfu" ;
    schema1:url "https://github.com/quadram-institute-bioscience/seqfu" .

