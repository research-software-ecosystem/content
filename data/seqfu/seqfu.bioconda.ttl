@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:seqfu a schema1:SoftwareApplication ;
    schema1:author "telatin" ;
    schema1:citation "doi:10.3390/bioengineering8050059" ;
    schema1:description "DNA sequence utilities." ;
    schema1:downloadUrl "https://github.com/telatin/seqfu2/archive/refs/tags/v1.26.0.tar.gz" ;
    schema1:identifier biotools:seqfu ;
    schema1:license "GPL-3.0-only" ;
    schema1:maintainer "telatin" ;
    schema1:name "seqfu" ;
    schema1:softwareVersion "1.26.0" ;
    schema1:url "https://github.com/telatin/seqfu2" ;
    spdx:builtFrom biotools:seqfu .

