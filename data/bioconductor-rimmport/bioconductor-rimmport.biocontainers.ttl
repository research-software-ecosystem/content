@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-rimmport a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btw719" ;
    schema1:description "RImmPort: Enabling Ready-for-analysis Immunology Research Data" ;
    schema1:identifier biotools:rimmport ;
    schema1:keywords "Allergy and Immunology",
        "Computational Biology",
        "Humans",
        "Immunology",
        "Research" ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-rimmport" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/RImmPort.html" .

