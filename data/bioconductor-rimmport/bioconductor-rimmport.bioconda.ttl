@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-rimmport a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btw719" ;
    schema1:description "RImmPort: Enabling Ready-for-analysis Immunology Research Data" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/RImmPort_1.34.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/RImmPort/RImmPort_1.34.0.tar.gz', 'https://bioarchive.galaxyproject.org/RImmPort_1.34.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-rimmport/bioconductor-rimmport_1.34.0_src_all.tar.gz']" ;
    schema1:identifier biotools:rimmport ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-rimmport" ;
    schema1:softwareVersion "1.34.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/RImmPort.html" ;
    spdx:builtFrom biotools:rimmport .

