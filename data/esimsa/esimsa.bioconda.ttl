@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:esimsa a schema1:SoftwareApplication ;
    schema1:description "Simple deconvolution of electrospray ionization peak lists" ;
    schema1:downloadUrl "http://www.ms-utils.org/esimsa.c" ;
    schema1:identifier biotools:esimsa ;
    schema1:license "GPL-2.0-or-later" ;
    schema1:name "esimsa" ;
    schema1:softwareVersion "1.0" ;
    schema1:url "http://www.ms-utils.org/esimsa.html" ;
    spdx:builtFrom biotools:esimsa .

