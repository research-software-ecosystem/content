@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:msisensor-pro a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1016/j.gpb.2020.02.001" ;
    schema1:description "Microsatellite Instability (MSI) detection using high-throughput sequencing data." ;
    schema1:downloadUrl "https://github.com/xjtu-omics/msisensor-pro/archive/v1.3.0.tar.gz" ;
    schema1:identifier biotools:msisensor-pro ;
    schema1:license "Custom Licence" ;
    schema1:name "msisensor-pro" ;
    schema1:softwareHelp "https://github.com/xjtu-omics/msisensor-pro/wiki" ;
    schema1:softwareVersion "1.3.0" ;
    schema1:url "https://github.com/xjtu-omics/msisensor-pro" ;
    spdx:builtFrom biotools:msisensor-pro .

