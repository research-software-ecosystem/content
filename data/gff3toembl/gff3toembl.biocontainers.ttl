@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:gff3toembl a schema1:SoftwareApplication ;
    schema1:citation "doi:10.21105/joss.00080" ;
    schema1:description "Submitting annotated genomes to embl is a very difficult and time consuming process. this software converts gff3 files from the most commonly use prokaryote annotation tool prokka into a format that is suitable for submission to embl. it has been used to prepare more than 30% of all annotated genomes in embl/genbank." ;
    schema1:keywords "Genomics" ;
    schema1:license "GPL" ;
    schema1:name "gff3toembl" ;
    schema1:url "https://github.com/sanger-pathogens/gff3toembl/" .

