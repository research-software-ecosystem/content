@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:rsem a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/1471-2105-12-323" ;
    schema1:description "RSEM is a software package for estimating gene and isoform expression levels from RNA-Seq data." ;
    schema1:downloadUrl "https://github.com/deweylab/RSEM/archive/v1.3.3.tar.gz" ;
    schema1:identifier biotools:rsem ;
    schema1:license "GPL-3.0-or-later" ;
    schema1:name "rsem" ;
    schema1:softwareHelp "https://deweylab.github.io/RSEM" ;
    schema1:softwareVersion "1.3.3" ;
    schema1:url "https://deweylab.github.io/RSEM" ;
    spdx:builtFrom biotools:rsem .

