@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:rsem a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btp692",
        "doi:10.1186/1471-2105-12-323" ;
    schema1:description "We present a generative statistical model and associated inference methods that handle read mapping uncertainty in a principled manner. through simulations parameterized by real rnaseq data, we show that our method is more accurate than previous methods. our improved accuracy is the result ofhandling read mapping uncertainty with a statistical model and the estimationof gene expression levels as the sum of isoform expression levels." ;
    schema1:identifier biotools:rsem ;
    schema1:keywords "Animals",
        "Base Sequence",
        "Computational Biology",
        "Databases, Genetic",
        "Gene Expression",
        "Gene Expression Profiling",
        "Genome",
        "Mice",
        "RNA-Seq",
        "Sequence Analysis, RNA",
        "Zea mays" ;
    schema1:license "GPL-3" ;
    schema1:name "rsem" ;
    schema1:url "http://deweylab.github.io/RSEM/" .

