@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:smcounter2 a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/bty790" ;
    schema1:description "Smcounter2: an accurate low-frequency variant caller for targeted sequencing data with unique molecular identifiers" ;
    schema1:keywords "Gene Frequency",
        "High-Throughput Nucleotide Sequencing",
        "Mutation",
        "Polymerase Chain Reaction",
        "Sequence Analysis, DNA" ;
    schema1:license "Not available" ;
    schema1:name "smcounter2" ;
    schema1:url "https://github.com/qiaseq/qiaseq-smcounter-v2" .

