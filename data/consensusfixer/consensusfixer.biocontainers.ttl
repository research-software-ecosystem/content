@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:consensusfixer a schema1:SoftwareApplication ;
    schema1:description "Computes a consensus sequence with wobbles, ambiguous bases, and in-frame insertions, from a ngs read alignment." ;
    schema1:license "GNU GPLv3" ;
    schema1:name "consensusfixer" ;
    schema1:url "https://github.com/cbg-ethz/ConsensusFixer" .

