@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:fusion-inspector a schema1:SoftwareApplication ;
    schema1:description "Fusioninspector is a component of the trinity cancer transcriptome analysis toolkit (ctat). fusioninspector assists in fusion transcript discovery by performing a supervised analysis of fusion predictions, attempting to recover and re-score evidence for such predictions. - https://github.com/fusioninspector/fusioninspector/wiki" ;
    schema1:license "BSD-3" ;
    schema1:name "fusion-inspector" ;
    schema1:url "https://github.com/FusionInspector/FusionInspector" .

