    schema1:license "Apache-2.0" ;
    schema1:name "promod3" ;
    schema1:softwareHelp "https://openstructure.org/promod3/" ;
    schema1:softwareVersion "3.6.0" ;
    schema1:url "https://openstructure.org/promod3/" ;
    spdx:builtFrom biotools:promod3 .

