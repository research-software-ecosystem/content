@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:circexplorer2 a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1007/978-1-4939-8808-2_10" ;
    schema1:description "Circular rna analysis toolkits" ;
    schema1:keywords "Computational Biology",
        "Databases, Nucleic Acid",
        "Genome-Wide Association Study",
        "Molecular Sequence Annotation",
        "RNA",
        "RNA Splicing",
        "RNA, Circular" ;
    schema1:license "Custom License" ;
    schema1:name "circexplorer2" ;
    schema1:url "https://github.com/YangLab/CIRCexplorer2" .

