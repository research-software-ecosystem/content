@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:crux a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1021/pr500741y",
        "doi:10.1021/pr800127y" ;
    schema1:description "Cross-platform suite of analysis tools for interpreting protein mass spectrometry data." ;
    schema1:identifier biotools:crux ;
    schema1:keywords "Computational Biology",
        "Databases, Factual",
        "Humans",
        "Mass Spectrometry",
        "Peptide Fragments",
        "Peptides",
        "Proteomics",
        "Saccharomyces cerevisiae Proteins" ;
    schema1:license "Apache-2.0" ;
    schema1:name "crux" ;
    schema1:url "https://github.com/crux-toolkit/crux-toolkit" .

