@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:tracy a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s12864-020-6635-8" ;
    schema1:description "Basecalling, alignment, assembly and deconvolution of Sanger chromatogram trace files" ;
    schema1:downloadUrl "https://github.com/gear-genomics/tracy/archive/v0.8.1.tar.gz" ;
    schema1:identifier biotools:Gear-Genomics ;
    schema1:license "BSD-3-Clause" ;
    schema1:name "tracy" ;
    schema1:softwareHelp "https://github.com/gear-genomics/tracy/blob/v0.8.1/README.md" ;
    schema1:softwareVersion "0.8.1" ;
    schema1:url "https://github.com/gear-genomics/tracy" ;
    spdx:builtFrom biotools:Gear-Genomics .

