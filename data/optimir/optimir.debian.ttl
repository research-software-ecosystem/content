@prefix debianmed: <https://salsa.debian.org/med-team/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

debianmed:optimir a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1261/rna.069708.118" ;
    schema1:description "Integrating genetic variations in miRNA alignment" ;
    schema1:identifier "bio.tools:optimir",
        "conda:bioconda:optimir",
        "omictools:OMICS_33123" ;
    schema1:license "unknown" ;
    schema1:name "optimir" ;
    schema1:softwareVersion "1.2" ;
    schema1:url "https://github.com/FlorianThibord/OptimiR" ;
    spdx:builtFrom "optimir" .

