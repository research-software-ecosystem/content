@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-epigenomix a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btu003" ;
    schema1:description "Epigenetic and gene transcription data normalization and integration with mixture models" ;
    schema1:identifier biotools:epigenomix ;
    schema1:keywords "Bayes Theorem",
        "ChIP-seq",
        "Chromatin Immunoprecipitation",
        "Computational Biology",
        "Epigenesis, Genetic",
        "Epigenetics",
        "Histones",
        "Microarray experiment",
        "Oligonucleotide Array Sequence Analysis",
        "RNA-Seq",
        "RNA-seq",
        "Sequence Analysis, RNA",
        "Transcription, Genetic" ;
    schema1:license "LGPL-3" ;
    schema1:name "bioconductor-epigenomix" ;
    schema1:url "http://bioconductor.org/packages/3.6/bioc/html/epigenomix.html" .

