@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-epigenomix a schema1:SoftwareApplication ;
    schema1:description "Epigenetic and gene transcription data normalization and integration with mixture models" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/epigenomix_1.46.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/epigenomix/epigenomix_1.46.0.tar.gz', 'https://bioarchive.galaxyproject.org/epigenomix_1.46.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-epigenomix/bioconductor-epigenomix_1.46.0_src_all.tar.gz']" ;
    schema1:identifier biotools:epigenomix ;
    schema1:license "LGPL-3" ;
    schema1:name "bioconductor-epigenomix" ;
    schema1:softwareVersion "1.46.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/epigenomix.html" ;
    spdx:builtFrom biotools:epigenomix .

