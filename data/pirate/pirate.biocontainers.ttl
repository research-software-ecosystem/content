@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:pirate a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/GIGASCIENCE/GIZ119",
        "doi:10.1101/598391" ;
    schema1:description "Pangenome analysis and threshold evaluation toolbox" ;
    schema1:identifier biotools:pirate ;
    schema1:keywords "Cluster Analysis",
        "Clustering",
        "Gene and protein families",
        "Gene structure",
        "Genetic variation",
        "Genome, Bacterial",
        "Genomics",
        "Genotype and phenotype",
        "Ortholog",
        "Sequencing" ;
    schema1:license "GPL-3.0" ;
    schema1:name "pirate" ;
    schema1:url "https://github.com/SionBayliss/PIRATE" .

