@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:pirate a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1101/598391" ;
    schema1:description "Pangenome analysis and threshold evaluation toolbox" ;
    schema1:downloadUrl "https://github.com/SionBayliss/PIRATE/archive/v1.0.5.tar.gz" ;
    schema1:identifier biotools:pirate ;
    schema1:license "GPL3" ;
    schema1:name "pirate" ;
    schema1:softwareVersion "1.0.5" ;
    schema1:url "https://github.com/SionBayliss/PIRATE" ;
    spdx:builtFrom biotools:pirate .

