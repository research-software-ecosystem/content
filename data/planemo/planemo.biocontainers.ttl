@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:planemo a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/gky379" ;
    schema1:description "Command-line utilities to assist in building tools for the galaxy project (http://galaxyproject.org/)." ;
    schema1:keywords "Datasets as Topic",
        "Genomics",
        "Humans",
        "Information Dissemination",
        "International Cooperation",
        "Internet",
        "Metabolomics",
        "Molecular Imaging",
        "Proteomics",
        "Reproducibility of Results",
        "User-Computer Interface" ;
    schema1:license "Academic Free License version 3.0" ;
    schema1:name "planemo" ;
    schema1:url "https://github.com/galaxyproject/planemo" .

