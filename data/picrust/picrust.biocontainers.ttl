@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:picrust a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nbt.2676" ;
    schema1:description "Phylogenetic investigation of communities by reconstruction of unobserved states" ;
    schema1:keywords "Bacteria",
        "Genes, Bacterial",
        "Genetic Markers",
        "High-Throughput Nucleotide Sequencing",
        "Humans",
        "Metagenome",
        "Metagenomics",
        "Microbiota",
        "Phylogeny",
        "RNA, Ribosomal, 16S",
        "Sequence Analysis, DNA" ;
    schema1:license "GPL-3.0" ;
    schema1:name "picrust" ;
    schema1:url "https://github.com/picrust/picrust" .

