@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:swga a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btx118" ;
    schema1:description "Select primer sets for selective whole genome amplification(swga)" ;
    schema1:keywords "Animals",
        "DNA Primers",
        "Drosophila melanogaster",
        "Genetics, Population",
        "Genome, Bacterial",
        "Genomics",
        "Humans",
        "Mycobacterium tuberculosis",
        "Sequence Analysis, DNA",
        "Wolbachia" ;
    schema1:license "GPL-3.0" ;
    schema1:name "swga" ;
    schema1:url "https://github.com/eclarke/swga" .

