@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:gseapy a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btac757" ;
    schema1:description "Gene Set Enrichment Analysis in Python." ;
    schema1:downloadUrl "https://pypi.org/packages/source/g/gseapy/gseapy-1.2.1.tar.gz" ;
    schema1:identifier biotools:gseapy ;
    schema1:license "BSD-3-Clause" ;
    schema1:name "gseapy" ;
    schema1:softwareHelp "https://gseapy.readthedocs.io/en/latest" ;
    schema1:softwareVersion "1.2.1" ;
    schema1:url "https://github.com/zqfang/gseapy" ;
    spdx:builtFrom biotools:gseapy .

