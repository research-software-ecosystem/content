@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-ichip a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btq032" ;
    schema1:description "Bayesian Modeling of ChIP-chip Data Through Hidden Ising Models" ;
    schema1:identifier biotools:ichip ;
    schema1:keywords "ChIP-seq",
        "Chromatin Immunoprecipitation",
        "Databases, Genetic",
        "Gene Expression Profiling",
        "Genomics",
        "Oligonucleotide Array Sequence Analysis" ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-ichip" ;
    schema1:url "http://bioconductor.org/packages/3.6/bioc/html/iChip.html" .

