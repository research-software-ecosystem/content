@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-ichip a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btq032" ;
    schema1:description "Bayesian Modeling of ChIP-chip Data Through Hidden Ising Models" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/iChip_1.64.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/iChip/iChip_1.64.0.tar.gz', 'https://bioarchive.galaxyproject.org/iChip_1.64.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-ichip/bioconductor-ichip_1.64.0_src_all.tar.gz']" ;
    schema1:identifier biotools:ichip ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-ichip" ;
    schema1:softwareVersion "1.64.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/iChip.html" ;
    spdx:builtFrom biotools:ichip .

