@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:mea a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s12864-018-4835-2" ;
    schema1:description "Mea was developed as part of the lab class \"Bioinformatik von RNA- und Proteinstrukturen (Praktikum, Modul 10-202-2208)\". The package predicts maximum expected accuracy (MEA) RNA secondary structures from dot plots of RNAs while correcting the score in dependence of base pair span. Furthermore, it provides tools to evaluate predictions and optimize parameters." ;
    schema1:identifier biotools:mea ;
    schema1:keywords "Alleles",
        "Animals",
        "ChIP-seq",
        "Chromatin Immunoprecipitation",
        "CpG Islands",
        "DNA Methylation",
        "Epigenesis, Genetic",
        "Epigenomics",
        "Gene Expression Profiling",
        "Germ Cells",
        "Humans",
        "INDEL Mutation",
        "Methylated DNA immunoprecipitation",
        "Mice",
        "Mice, Inbred C57BL",
        "Mice, Inbred DBA",
        "Sequence Analysis, DNA",
        "Sequence Analysis, RNA",
        "Transcription Initiation Site" ;
    schema1:license "GPL-3.0" ;
    schema1:name "mea" ;
    schema1:url "http://www.bioinf.uni-leipzig.de/Software/mea/" .

