@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-mirage a schema1:SoftwareApplication ;
    schema1:citation "doi:10.3390/ijms12129265" ;
    schema1:description "MiRNA Ranking by Gene Expression" ;
    schema1:identifier biotools:mirage ;
    schema1:keywords "Cell Differentiation",
        "Embryonic Stem Cells",
        "Gene Expression",
        "Gene Expression Profiling",
        "Gene Expression Regulation, Developmental",
        "Gene expression",
        "Gene regulation",
        "Humans",
        "MicroRNAs",
        "Models, Genetic",
        "Neural Stem Cells" ;
    schema1:license "GPL" ;
    schema1:name "bioconductor-mirage" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/MiRaGE.html" .

