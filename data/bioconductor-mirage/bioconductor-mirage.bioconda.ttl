@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-mirage a schema1:SoftwareApplication ;
    schema1:description "MiRNA Ranking by Gene Expression" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/MiRaGE_1.48.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/MiRaGE/MiRaGE_1.48.0.tar.gz', 'https://bioarchive.galaxyproject.org/MiRaGE_1.48.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-mirage/bioconductor-mirage_1.48.0_src_all.tar.gz']" ;
    schema1:identifier biotools:mirage ;
    schema1:license "GPL" ;
    schema1:name "bioconductor-mirage" ;
    schema1:softwareVersion "1.48.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/MiRaGE.html" ;
    spdx:builtFrom biotools:mirage .

