@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:gdsctools a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btx744" ;
    schema1:description "Set of tools and pipelines to analyse gdsc data (cancerrxgene.org)" ;
    schema1:identifier biotools:gdsctools ;
    schema1:keywords "Antineoplastic Agents",
        "Cell Line, Tumor",
        "Computational Biology",
        "Drug Discovery",
        "Drug development",
        "Genomics",
        "Humans",
        "Neoplasms",
        "Oncology",
        "Pharmacogenetics",
        "Pharmacogenomics" ;
    schema1:license "3-clause (\"Simplified\" or \"New\") BSD license" ;
    schema1:name "gdsctools" ;
    schema1:url "https://github.com/CancerRxGene/gdsctools" .

