@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:genomestrip a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/ng.3200" ;
    schema1:description "Genome strip (genome structure in populations) is a suite of tools for discovery and genotyping of structural variation using whole-genome sequencing data" ;
    schema1:identifier biotools:genome_strip ;
    schema1:keywords "Alleles",
        "DNA Copy Number Variations",
        "DNA structural variation",
        "Gene Dosage",
        "Genetic variation",
        "Genetics",
        "Genome, Human",
        "Genome-Wide Association Study",
        "Haplotypes",
        "Humans" ;
    schema1:license "Not available" ;
    schema1:name "genomestrip" ;
    schema1:url "http://software.broadinstitute.org/software/genomestrip/" .

