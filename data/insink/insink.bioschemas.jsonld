        "pubmed:39583215"
      ],
      "sc:description": "nsink is an R package that uses widely available GIS data to identify landscape sinks within catchments, estimate their nitrogen removal potential, and map the effect of those sinks on nitrogen movement. It facilitates data acquisition, processing, and visualization for decision-makers and resource economists.",
      "sc:featureList": {
        "@id": "edam:operation_0337"
      },
      "sc:name": "nsink",
