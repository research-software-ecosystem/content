@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bali-phy a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1080/10635150590947041",
        "doi:10.1093/bioinformatics/btl175",
        "doi:10.1093/molbev/msu174",
        "doi:10.1186/1471-2148-7-40" ;
    schema1:description "Markov chain monte carlo software for simultaneous bayesian estimation of alignment and phylogeny (and other parameters). it handles generic bayesian modeling via probabilistic programming." ;
    schema1:identifier biotools:bali-phy ;
    schema1:keywords "Bayes Theorem",
        "Markov Chains",
        "Models, Genetic",
        "Models, Statistical",
        "Mutation",
        "Phylogenetics",
        "Phylogeny",
        "Selection, Genetic",
        "Sequence Alignment",
        "Sequence analysis" ;
    schema1:license "GPL-2.0+" ;
    schema1:name "bali-phy" ;
    schema1:url "http://www.bali-phy.org/" .

