@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bali-phy a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btab129" ;
    schema1:description "Phylogenetics - Bayesian estimation of phylogenies and multiple sequence alignments." ;
    schema1:downloadUrl "https://github.com/bredelings/bali-phy/archive/4.1.tar.gz" ;
    schema1:identifier biotools:bali-phy ;
    schema1:license "GPL2" ;
    schema1:name "bali-phy" ;
    schema1:softwareVersion "4.1" ;
    schema1:url "http://www.bali-phy.org" ;
    spdx:builtFrom biotools:bali-phy .

