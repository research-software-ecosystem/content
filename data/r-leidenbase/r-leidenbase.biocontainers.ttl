@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-leidenbase a schema1:SoftwareApplication ;
    schema1:description "An R to C interface that runs the Leiden community detection algorithm to find a basic partition" ;
    schema1:license "GPL2, GPL-3.0, BSD" ;
    schema1:name "r-leidenbase" ;
    schema1:url "https://cole-trapnell-lab.github.io/leidenbase/" .

