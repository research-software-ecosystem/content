        "Genetics",
        "Genomics",
        "Transcriptome",
        "Transcriptomics" ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-river" ;
    schema1:url "https://bioconductor.org/packages/3.8/bioc/html/RIVER.html" .

