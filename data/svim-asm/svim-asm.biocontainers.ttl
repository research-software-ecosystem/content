@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:svim-asm a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/s41587-020-0503-6",
        "doi:10.1101/2020.10.27.356907" ;
    schema1:description "Svim-asm is a fork of the sv caller svim for genome-genome alignments." ;
    schema1:keywords "Benchmarking",
        "Chromosomes, Human",
        "Deep Learning",
        "Genome, Human",
        "Genomics",
        "HLA Antigens",
        "Haploidy",
        "High-Throughput Nucleotide Sequencing",
        "Humans",
        "Nanopore Sequencing",
        "Sequence Analysis, DNA" ;
    schema1:license "GNU General Public License v3.0" ;
    schema1:name "svim-asm" ;
    schema1:url "https://github.com/eldariont/svim-asm" .

