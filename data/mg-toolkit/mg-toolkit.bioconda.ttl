@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:mg-toolkit a schema1:SoftwareApplication ;
    schema1:description "Metagenomics toolkit." ;
    schema1:downloadUrl "https://pypi.io/packages/source/m/mg-toolkit/mg-toolkit-0.10.4.tar.gz" ;
    schema1:identifier biotools:MGnify ;
    schema1:license "Apache-2.0" ;
    schema1:name "mg-toolkit" ;
    schema1:softwareVersion "0.10.4" ;
    schema1:url "https://www.ebi.ac.uk/metagenomics" ;
    spdx:builtFrom biotools:MGnify .

