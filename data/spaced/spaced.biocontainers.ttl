@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:spaced a schema1:SoftwareApplication ;
    schema1:description "Alignment-free sequence comparison using spaced words" ;
    schema1:keywords "Genetics",
        "Protein Sequences" ;
    schema1:license "GPL-3.0+" ;
    schema1:name "spaced" ;
    schema1:url "http://spaced.gobics.de/" .

