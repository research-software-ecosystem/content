@prefix debianmed: <https://salsa.debian.org/med-team/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

debianmed:pftools a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bib/3.3.265" ;
    schema1:description "build and search protein and DNA generalized profiles" ;
    schema1:identifier "bio.tools:pftools",
        "omictools:OMICS_29588" ;
    schema1:license "unknown" ;
    schema1:name "pftools" ;
    schema1:softwareVersion "3.2.12" ;
    schema1:url "https://github.com/sib-swiss/pftools3" ;
    spdx:builtFrom "pftools" .

