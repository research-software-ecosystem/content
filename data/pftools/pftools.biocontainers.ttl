@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:pftools a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1002/pro.5560030118" ;
    schema1:description "The pftools are a collection of programs to build, calibrate, and search biological sequences with generalized profiles. generalized profiles are an extension of position specific scoring matrices by including position specific scores for insertions and deletions. they correspond to a matrix representation of a multiple sequence alignment that can be used to search distant homologous sequences and precisely align sequences to the model." ;
    schema1:identifier biotools:pftools ;
    schema1:keywords "Amino Acid Sequence",
        "Clustering",
        "Globins",
        "Heat-Shock Proteins",
        "Molecular Sequence Data",
        "Protein folds and structural domains",
        "Protein structural motifs and surfaces",
        "Proteomics",
        "Proto-Oncogene Proteins pp60(c-src)",
        "Sensitivity and Specificity",
        "Sequence Alignment",
        "Sequence Analysis",
        "Sequence Homology",
        "Sequence analysis",
        "Sequence sites, features and motifs" ;
    schema1:license "custom, see /usr/share/doc/pftools/copyright" ;
    schema1:name "pftools" ;
    schema1:url "https://github.com/sib-swiss/pftools3" .

