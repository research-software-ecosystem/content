@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:homopolish a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s13059-021-02282-6" ;
    schema1:description "High-quality Nanopore-only genome polisher." ;
    schema1:downloadUrl "https://github.com/SeaneryChang/homopolish/releases/download/v0.4.2/homopolish_0.4.2.tar.gz" ;
    schema1:identifier biotools:homopolish ;
    schema1:license "GPL-3.0-or-later" ;
    schema1:name "homopolish" ;
    schema1:softwareVersion "0.4.2" ;
    schema1:url "https://github.com/ythuang0522/homopolish" ;
    spdx:builtFrom biotools:homopolish .

