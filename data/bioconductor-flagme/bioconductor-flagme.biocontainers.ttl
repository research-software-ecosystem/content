@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-flagme a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Analysis of Metabolomics GC/MS Data" ;
    schema1:identifier biotools:flagme ;
    schema1:keywords "Computational Biology",
        "Gene Expression Profiling",
        "Genomics",
        "High-Throughput Screening Assays",
        "Mass spectrometry",
        "Metabolomics",
        "Programming Languages",
        "User-Computer Interface" ;
    schema1:license "LGPL (>= 2)" ;
    schema1:name "bioconductor-flagme" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/flagme.html" .

