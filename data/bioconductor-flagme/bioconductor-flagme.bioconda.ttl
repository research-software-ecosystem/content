@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-flagme a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Analysis of Metabolomics GC/MS Data" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/flagme_1.62.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/flagme/flagme_1.62.0.tar.gz', 'https://bioarchive.galaxyproject.org/flagme_1.62.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-flagme/bioconductor-flagme_1.62.0_src_all.tar.gz']" ;
    schema1:identifier biotools:flagme ;
    schema1:license "LGPL (>= 2)" ;
    schema1:name "bioconductor-flagme" ;
    schema1:softwareVersion "1.62.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/flagme.html" ;
    spdx:builtFrom biotools:flagme .

