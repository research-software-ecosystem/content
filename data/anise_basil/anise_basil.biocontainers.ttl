@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:anise_basil a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btv051" ;
    schema1:description "BASIL is a method to detect breakpoints for structural variants (including insertion breakpoints) from aligned paired HTS reads in BAM format" ;
    schema1:keywords "Computational Biology",
        "High-Throughput Nucleotide Sequencing",
        "Humans",
        "Sequence Alignment",
        "Sequence Analysis, DNA" ;
    schema1:license "MIT" ;
    schema1:name "anise_basil" ;
    schema1:url "https://github.com/seqan/anise_basil/" .

