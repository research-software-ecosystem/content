@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:quickmerge a schema1:SoftwareApplication ;
    schema1:description "Quickmerge uses a simple concept to improve contiguity of genome assemblies based on long molecule sequences." ;
    schema1:license "GPL-3.0" ;
    schema1:name "quickmerge" ;
    schema1:url "https://github.com/mahulchak/quickmerge" .

