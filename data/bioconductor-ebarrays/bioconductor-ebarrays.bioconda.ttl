@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-ebarrays a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1111/j.1541-0420.2006.00611.x" ;
    schema1:description "Unified Approach for Simultaneous Gene Clustering and Differential Expression Identification" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/EBarrays_2.74.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/EBarrays/EBarrays_2.74.0.tar.gz', 'https://bioarchive.galaxyproject.org/EBarrays_2.74.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-ebarrays/bioconductor-ebarrays_2.74.0_src_all.tar.gz']" ;
    schema1:identifier biotools:ebarrays ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-ebarrays" ;
    schema1:softwareVersion "2.74.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/EBarrays.html" ;
    spdx:builtFrom biotools:ebarrays .

