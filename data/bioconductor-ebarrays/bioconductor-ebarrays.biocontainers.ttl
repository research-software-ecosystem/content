@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-ebarrays a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1111/j.1541-0420.2006.00611.x" ;
    schema1:description "Unified Approach for Simultaneous Gene Clustering and Differential Expression Identification" ;
    schema1:identifier biotools:ebarrays ;
    schema1:keywords "Animals",
        "Bayes Theorem",
        "Biometry",
        "Clustering",
        "Data Interpretation, Statistical",
        "Gene Expression Profiling",
        "Gene expression",
        "Leptin",
        "Mice",
        "Models, Statistical",
        "Multigene Family",
        "Oligonucleotide Array Sequence Analysis" ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-ebarrays" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/EBarrays.html" .

