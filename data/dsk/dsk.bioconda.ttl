@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:dsk a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btt020" ;
    schema1:description "DSK is a k-mer counter for reads or genomes." ;
    schema1:downloadUrl "https://github.com/GATB/dsk/archive/v2.3.3.tar.gz" ;
    schema1:identifier biotools:dsk ;
    schema1:license "AGPL-3.0-or-later" ;
    schema1:name "dsk" ;
    schema1:softwareVersion "2.3.3" ;
    schema1:url "https://github.com/GATB/dsk" ;
    spdx:builtFrom biotools:dsk .

