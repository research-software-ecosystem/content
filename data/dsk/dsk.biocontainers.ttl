@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:dsk a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btt020" ;
    schema1:description "DSK is a k-mer counter for reads or genomes." ;
    schema1:identifier biotools:dsk ;
    schema1:keywords "Genome, Human",
        "Humans",
        "Sequence Analysis, DNA",
        "Sequence Analysis, RNA",
        "Sequence analysis" ;
    schema1:license "AGPL-3.0" ;
    schema1:name "dsk" ;
    schema1:url "https://github.com/GATB/dsk/" .

