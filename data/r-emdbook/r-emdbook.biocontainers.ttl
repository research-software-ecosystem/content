@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-emdbook a schema1:SoftwareApplication ;
    schema1:description "Auxiliary functions and data sets for \"Ecological Models and Data\", a book presenting maximum likelihood estimation and related topics for ecologists (ISBN 978-0-691-12522-0)." ;
    schema1:license "GPL-3" ;
    schema1:name "r-emdbook" ;
    schema1:url "http://www.math.mcmaster.ca/bolker/emdbook" .

