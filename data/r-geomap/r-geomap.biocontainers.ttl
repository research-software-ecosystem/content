@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-geomap a schema1:SoftwareApplication ;
    schema1:description "Set of routines for making Map Projections (forward and inverse), Topographic Maps, Perspective plots, Geological Maps, geological map symbols, geological databases, interactive plotting and selection of focus regions." ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "r-geomap" ;
    schema1:url "None" .

