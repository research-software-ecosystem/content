@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-suprahex a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1016/j.bbrc.2013.11.103" ;
    schema1:description "supraHex: a supra-hexagonal map for analysing tabular omics data" ;
    schema1:identifier biotools:suprahex ;
    schema1:keywords "Animals",
        "Clustering",
        "Computational Biology",
        "DNA Replication",
        "Data Interpretation, Statistical",
        "Data visualisation",
        "Embryonic Development",
        "Gene expression",
        "Genomics",
        "Machine learning",
        "Mice",
        "Multigene Family" ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-suprahex" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/supraHex.html" .

