@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-suprahex a schema1:SoftwareApplication ;
    schema1:description "supraHex: a supra-hexagonal map for analysing tabular omics data" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.18/bioc/src/contrib/supraHex_1.40.0.tar.gz', 'https://bioconductor.org/packages/3.18/bioc/src/contrib/Archive/supraHex/supraHex_1.40.0.tar.gz', 'https://bioarchive.galaxyproject.org/supraHex_1.40.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-suprahex/bioconductor-suprahex_1.40.0_src_all.tar.gz']" ;
    schema1:identifier biotools:suprahex ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-suprahex" ;
    schema1:softwareVersion "1.40.0" ;
    schema1:url "https://bioconductor.org/packages/3.18/bioc/html/supraHex.html" ;
    spdx:builtFrom biotools:suprahex .

