@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:hmftools-sage a schema1:SoftwareApplication ;
    schema1:description "Sage is a somatic snv, mnv and small indel caller optimised to call narrow regions of the genome with high prior chance of a variant with very high sensitivity." ;
    schema1:keywords "Genomics" ;
    schema1:license "MIT" ;
    schema1:name "hmftools-sage" ;
    schema1:url "https://github.com/hartwigmedical/hmftools/tree/master/sage" .

