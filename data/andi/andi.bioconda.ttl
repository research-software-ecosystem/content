@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:andi a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btu815" ;
    schema1:description "Efficient Estimation of Evolutionary Distances" ;
    schema1:downloadUrl "https://github.com/EvolBioInf/andi/releases/download/v1.15/andi-1.15.tar.gz" ;
    schema1:identifier biotools:andi ;
    schema1:license "GPL-3.0-or-later" ;
    schema1:name "andi" ;
    schema1:softwareVersion "1.15" ;
    schema1:url "https://github.com/evolbioinf/andi/" ;
    spdx:builtFrom biotools:andi .

