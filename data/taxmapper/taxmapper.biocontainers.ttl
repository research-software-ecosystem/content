@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:taxmapper a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s12864-017-4168-6" ;
    schema1:description "Analysis pipeline for metagenomic, microeukaryotic sequencing data." ;
    schema1:identifier biotools:taxmapper ;
    schema1:keywords "Databases, Genetic",
        "Eukaryota",
        "High-Throughput Nucleotide Sequencing",
        "Mapping",
        "Metagenomics",
        "Microbiology",
        "NGS",
        "Reference Standards",
        "Taxonomy" ;
    schema1:license "MIT" ;
    schema1:name "taxmapper" ;
    schema1:url "https://bitbucket.org/dbeisser/taxmapper" .

