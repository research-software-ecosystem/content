@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:orthanc a schema1:SoftwareApplication ;
    schema1:description "Lightweight, restful dicom server for medical imaging" ;
    schema1:license "GPL-3.0+ with OpenSSL exception" ;
    schema1:name "orthanc" ;
    schema1:url "http://www.orthanc-server.com/" .

