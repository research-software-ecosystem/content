@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-scde a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.2967" ;
    schema1:description "Single Cell Differential Expression" ;
    schema1:identifier biotools:scde ;
    schema1:keywords "Bayes Theorem",
        "Cell biology",
        "Gene Expression Profiling",
        "Gene expression",
        "Oligonucleotide Array Sequence Analysis",
        "RNA-Seq",
        "Sequence Analysis, RNA",
        "Single-Cell Analysis" ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-scde" ;
    schema1:url "http://bioconductor.org/packages/3.6/bioc/html/scde.html" .

