@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-scde a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.2967" ;
    schema1:description "Single Cell Differential Expression" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/scde_2.34.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/scde/scde_2.34.0.tar.gz', 'https://bioarchive.galaxyproject.org/scde_2.34.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-scde/bioconductor-scde_2.34.0_src_all.tar.gz']" ;
    schema1:identifier biotools:scde ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-scde" ;
    schema1:softwareVersion "2.34.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/scde.html" ;
    spdx:builtFrom biotools:scde .

