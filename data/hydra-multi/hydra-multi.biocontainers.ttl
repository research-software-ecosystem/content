@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:hydra-multi a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btu771" ;
    schema1:description "Hydra detects structural variation breakpoints in both unique and duplicated genomic regions." ;
    schema1:keywords "Animals",
        "Databases, Factual",
        "Gene Deletion",
        "Genetics, Population",
        "Genomic Structural Variation",
        "Genomics",
        "Humans",
        "Hydra",
        "Sequence Alignment" ;
    schema1:license "MIT" ;
    schema1:name "hydra-multi" ;
    schema1:url "https://github.com/arq5x/Hydra" .

