@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:botocore a schema1:SoftwareApplication ;
    schema1:description "A low-level interface to a growing number of Amazon Web Services" ;
    schema1:license "Apache-2.0" ;
    schema1:name "botocore" ;
    schema1:url "https://github.com/boto/botocore" .

