@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-pathview a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btt285" ;
    schema1:description "a tool set for pathway based data integration and visualization" ;
    schema1:identifier biotools:pathview ;
    schema1:keywords "Computer Graphics",
        "Data visualisation",
        "Gene Expression",
        "Metabolic Networks and Pathways",
        "Molecular interactions, pathways and networks",
        "Signal Transduction",
        "Systems Integration",
        "Systems biology" ;
    schema1:license "GPL (>=3.0)" ;
    schema1:name "bioconductor-pathview" ;
    schema1:url "None" .

