@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-pathview a schema1:SoftwareApplication ;
    schema1:description "a tool set for pathway based data integration and visualization" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/pathview_1.46.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/pathview/pathview_1.46.0.tar.gz', 'https://bioarchive.galaxyproject.org/pathview_1.46.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-pathview/bioconductor-pathview_1.46.0_src_all.tar.gz']" ;
    schema1:identifier biotools:pathview ;
    schema1:license "GPL (>=3.0)" ;
    schema1:name "bioconductor-pathview" ;
    schema1:softwareVersion "1.46.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/pathview.html" ;
    spdx:builtFrom biotools:pathview .

