@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:lofreq a schema1:SoftwareApplication ;
    schema1:description "A fast and sensitive variant-caller for inferring SNVs and indels from next-generation sequencing data." ;
    schema1:downloadUrl "https://github.com/CSB5/lofreq/archive/refs/tags/v2.1.5.tar.gz" ;
    schema1:identifier biotools:lofreq ;
    schema1:license "MIT" ;
    schema1:name "lofreq" ;
    schema1:softwareHelp "https://csb5.github.io/lofreq" ;
    schema1:softwareVersion "2.1.5" ;
    schema1:url "https://csb5.github.io/lofreq" ;
    spdx:builtFrom biotools:lofreq .

