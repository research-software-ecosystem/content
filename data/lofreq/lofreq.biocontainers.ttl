@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:lofreq a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/gks918" ;
    schema1:description "A fast and sensitive variant-caller for inferring snvs and indels from next-generation sequencing data" ;
    schema1:keywords "Computer Simulation",
        "Dengue Virus",
        "Escherichia coli",
        "Genetic Variation",
        "Genomics",
        "High-Throughput Nucleotide Sequencing",
        "Humans",
        "Mutation",
        "Sensitivity and Specificity",
        "Sequence Alignment",
        "Stomach Neoplasms",
        "Viral Proteins" ;
    schema1:license "MIT" ;
    schema1:name "lofreq" ;
    schema1:url "https://sourceforge.net/projects/lofreq/" .

