@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-ridigbio a schema1:SoftwareApplication ;
    schema1:description "An interface to iDigBio's search API that allows downloading specimen records. Searches are returned as a data.frame. Other functions such as the metadata end points return lists of information. iDigBio is a US project focused on digitizing and serving museum specimen collections on the web. See <https://www.idigbio.org> for information on iDigBio." ;
    schema1:license "MIT" ;
    schema1:name "r-ridigbio" ;
    schema1:url "https://github.com/iDigBio/ridigbio" .

