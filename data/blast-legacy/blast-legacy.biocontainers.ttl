@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:blast-legacy a schema1:SoftwareApplication ;
    schema1:description "The basic local alignment search tool (blast) finds regions of local similarity between sequences." ;
    schema1:keywords "Protein Sequences",
        "Sequence Alignment" ;
    schema1:license "Public Domain" ;
    schema1:name "blast-legacy" ;
    schema1:url "http://blast.ncbi.nlm.nih.gov" .

