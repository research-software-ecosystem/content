@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:binette a schema1:SoftwareApplication ;
    schema1:author "JeanMainguy" ;
    schema1:citation "doi:10.21105/joss.06782" ;
    schema1:description "A fast and accurate binning refinement tool to constructs high quality MAGs from the output of multiple binning tools." ;
    schema1:downloadUrl "https://github.com/genotoul-bioinfo/binette/archive/refs/tags/v1.2.1.tar.gz" ;
    schema1:identifier biotools:binette ;
    schema1:license "GPL-3.0-only" ;
    schema1:maintainer "JeanMainguy" ;
    schema1:name "binette" ;
    schema1:softwareHelp "https://binette.readthedocs.io" ;
    schema1:softwareVersion "1.2.1" ;
    schema1:url "https://github.com/genotoul-bioinfo/binette" ;
    spdx:builtFrom biotools:binette .

