@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-ippd a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/1471-2105-13-291" ;
    schema1:description "Isotopic peak pattern deconvolution for Protein Mass Spectrometry by template matching" ;
    schema1:identifier biotools:ippd ;
    schema1:keywords "Artifacts",
        "Humans",
        "Isotopes",
        "Least-Squares Analysis",
        "Mass Spectrometry",
        "Mass spectra",
        "Mass spectrometry",
        "Peptides",
        "Protein Processing, Post-Translational",
        "Proteomics",
        "Proteomics experiment",
        "Small molecules" ;
    schema1:license "GPL (version 2 or later)" ;
    schema1:name "bioconductor-ippd" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/IPPD.html" .

