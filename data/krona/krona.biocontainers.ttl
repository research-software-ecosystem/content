@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:krona a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/1471-2105-12-385" ;
    schema1:description "Krona creates interactive html5 charts of hierarchical data (such as taxonomic abundance in a metagenome)." ;
    schema1:identifier biotools:krona ;
    schema1:keywords "Computational Biology",
        "Gastrointestinal Tract",
        "Genomics",
        "Humans",
        "Internet",
        "Metagenome",
        "Metagenomics",
        "Metaproteomics",
        "Proteomics" ;
    schema1:license "Proprietary" ;
    schema1:name "krona" ;
    schema1:url "https://github.com/marbl/Krona/wiki" .

