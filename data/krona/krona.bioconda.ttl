@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:krona a schema1:SoftwareApplication ;
    schema1:description "Krona Tools is a set of scripts to create Krona charts from several Bioinformatics tools as well as from text and XML files." ;
    schema1:downloadUrl "https://github.com/marbl/Krona/releases/download/v2.8.1/KronaTools-2.8.1.tar" ;
    schema1:identifier biotools:krona ;
    schema1:license "BSD" ;
    schema1:name "krona" ;
    schema1:softwareVersion "2.8.1" ;
    schema1:url "https://github.com/marbl/Krona" ;
    spdx:builtFrom biotools:krona .

