@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:daligner a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/1471-2105-13-238" ;
    schema1:description "Local alignment discovery between long nucleotide sequencing reads" ;
    schema1:keywords "Base Sequence",
        "DNA",
        "Genome",
        "Sequence Alignment",
        "Sequence Analysis, DNA" ;
    schema1:license "BSD-3-Clause" ;
    schema1:name "daligner" ;
    schema1:url "https://dazzlerblog.wordpress.com" .

