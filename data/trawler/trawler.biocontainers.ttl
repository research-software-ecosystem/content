@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:trawler a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth1061" ;
    schema1:description "Trawler is a motif discovery tool used to identify enriched motifs in a set of sequenced regions of dna." ;
    schema1:keywords "Clustering",
        "Ortholog" ;
    schema1:license "GPL-2" ;
    schema1:name "trawler" ;
    schema1:url "https://github.com/Ramialison-Lab-ARMI/Trawler-2.0" .

