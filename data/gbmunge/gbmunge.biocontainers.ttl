@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:gbmunge a schema1:SoftwareApplication ;
    schema1:description "Munge GenBank files into FASTA and tab-separated metadata." ;
    schema1:license "MIT" ;
    schema1:name "gbmunge" ;
    schema1:url "https://github.com/sdwfrost/gbmunge" .

