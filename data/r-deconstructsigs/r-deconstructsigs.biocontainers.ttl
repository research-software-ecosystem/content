@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-deconstructsigs a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s13059-016-0893-4" ;
    schema1:description "Takes sample information in the form of the fraction of mutations in each of 96 trinucleotide contexts and identifies the weighted combination of published signatures that, when summed, most closely reconstructs the mutational profile." ;
    schema1:keywords "Adenocarcinoma",
        "Carcinoma, Squamous Cell",
        "Cytidine Deaminase",
        "DNA Mutational Analysis",
        "DNA Repair",
        "DNA Repair-Deficiency Disorders",
        "Esophageal Neoplasms",
        "Genome, Human",
        "Humans",
        "Mutation" ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "r-deconstructsigs" ;
    schema1:url "https://github.com/raerose01/deconstructSigs" .

