@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-fmrs a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18129/b9.bioc.fmrs" ;
    schema1:description "Provides parameter estimation as well as variable selection in Finite Mixture of Accelerated Failure Time Regression and Finite Mixture of Regression Models. Furthermore, this package provides Ridge Regression and Elastic Net." ;
    schema1:license "GPL (>= 3)" ;
    schema1:name "bioconductor-fmrs" ;
    schema1:url "https://bioconductor.org/packages/3.12/bioc/html/fmrs.html" .

