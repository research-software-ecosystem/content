@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:ananse a schema1:SoftwareApplication ;
    schema1:author "siebrenf",
        "simonvh" ;
    schema1:description "ANANSE: ANalysis Algorithm for Networks Specified by Enhancers - Prediction of key transcription factors in cell fate determination using enhancer networks" ;
    schema1:downloadUrl "https://github.com/vanheeringen-lab/ANANSE/releases/download/v0.5.1/ANANSE-0.5.1.tar.gz" ;
    schema1:identifier biotools:ananse ;
    schema1:license "MIT License" ;
    schema1:maintainer "siebrenf",
        "simonvh" ;
    schema1:name "ananse" ;
    schema1:softwareVersion "0.5.1" ;
    schema1:url "https://github.com/vanheeringen-lab/ANANSE" ;
    spdx:builtFrom biotools:ananse .

