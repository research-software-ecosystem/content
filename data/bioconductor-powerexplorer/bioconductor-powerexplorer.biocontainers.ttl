@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-powerexplorer a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18129/b9.bioc.powerexplorer" ;
    schema1:description "Power estimation tool for rna-seq and proteomics data" ;
    schema1:keywords "Proteomics",
        "RNA-Seq" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-powerexplorer" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/PowerExplorer.html" .

