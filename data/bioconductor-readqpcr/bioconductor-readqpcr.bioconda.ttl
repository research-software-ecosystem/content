@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-readqpcr a schema1:SoftwareApplication ;
    schema1:description "Read qPCR data" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/ReadqPCR_1.52.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/ReadqPCR/ReadqPCR_1.52.0.tar.gz', 'https://bioarchive.galaxyproject.org/ReadqPCR_1.52.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-readqpcr/bioconductor-readqpcr_1.52.0_src_all.tar.gz']" ;
    schema1:identifier biotools:readqpcr ;
    schema1:license "LGPL-3" ;
    schema1:name "bioconductor-readqpcr" ;
    schema1:softwareVersion "1.52.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/ReadqPCR.html" ;
    spdx:builtFrom biotools:readqpcr .

