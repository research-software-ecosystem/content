@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-readqpcr a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/1471-2164-13-296" ;
    schema1:description "Read qPCR data" ;
    schema1:identifier biotools:readqpcr ;
    schema1:keywords "PCR experiment",
        "Real-Time Polymerase Chain Reaction" ;
    schema1:license "LGPL-3" ;
    schema1:name "bioconductor-readqpcr" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/ReadqPCR.html" .

