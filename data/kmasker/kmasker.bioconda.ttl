@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:kmasker a schema1:SoftwareApplication ;
    schema1:description "A tool for masking and exploring of sequences from plant species." ;
    schema1:downloadUrl "https://github.com/tschmutzer/kmasker/releases/download/1.1.1/kmasker_release_source.tar" ;
    schema1:identifier biotools:kmasker ;
    schema1:license "GPL-3.0-or-later" ;
    schema1:name "kmasker" ;
    schema1:softwareVersion "1.1.1" ;
    schema1:url "https://kmasker.ipk-gatersleben.de/" ;
    spdx:builtFrom biotools:kmasker .

