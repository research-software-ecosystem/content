@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:kmasker a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1111/TPJ.14645" ;
    schema1:description "A tool for masking and exploring of sequences from plant species." ;
    schema1:identifier biotools:kmasker ;
    schema1:keywords "Comparative genomics",
        "Nucleic acid sites, features and motifs",
        "Plant biology",
        "Sequence composition, complexity and repeats" ;
    schema1:license "GPL-3.0" ;
    schema1:name "kmasker" ;
    schema1:url "https://kmasker.ipk-gatersleben.de/" .

