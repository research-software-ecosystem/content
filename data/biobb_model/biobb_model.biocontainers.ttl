@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:biobb_model a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/s41597-019-0177-4" ;
    schema1:description "Biobb_model is the Biobb module collection to check and model 3d structures, create mutations or reconstruct missing atoms." ;
