@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:stringmeup a schema1:SoftwareApplication ;
    schema1:description "A post-processing tool to reclassify kraken 2 output based on the confidence score and/or minimum minimizer hit groups." ;
    schema1:license "MIT" ;
    schema1:name "stringmeup" ;
    schema1:url "https://github.com/danisven/StringMeUp" .

