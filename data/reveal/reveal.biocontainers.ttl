@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:reveal a schema1:SoftwareApplication ;
    schema1:description "Graph based multi genome aligner" ;
    schema1:identifier biotools:reveal ;
    schema1:keywords "Molecular modelling",
        "Protein binding sites",
        "Protein structure analysis",
        "Sequence Alignment",
        "Structure prediction" ;
    schema1:license "MIT" ;
    schema1:name "reveal" ;
    schema1:url "https://github.com/jasperlinthorst/reveal" .

