@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:coatran a schema1:SoftwareApplication ;
    schema1:author "acaprez",
        "niemasd" ;
    schema1:citation "doi:10.1101/2020.11.10.377499" ;
    schema1:description "Coalescent tree simulation along a transmission network" ;
    schema1:downloadUrl "https://github.com/niemasd/CoaTran/archive/refs/tags/0.0.4.tar.gz" ;
    schema1:identifier biotools:coatran ;
    schema1:license "GPL-3.0-or-later" ;
    schema1:maintainer "acaprez",
        "niemasd" ;
    schema1:name "coatran" ;
    schema1:softwareVersion "0.0.4" ;
    schema1:url "https://github.com/niemasd/CoaTran" ;
    spdx:builtFrom biotools:coatran .

