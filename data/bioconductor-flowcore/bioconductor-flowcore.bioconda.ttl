@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-flowcore a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/1471-2105-10-106" ;
    schema1:description "flowCore: Basic structures for flow cytometry data" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/flowCore_2.18.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/flowCore/flowCore_2.18.0.tar.gz', 'https://bioarchive.galaxyproject.org/flowCore_2.18.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-flowcore/bioconductor-flowcore_2.18.0_src_all.tar.gz']" ;
    schema1:identifier biotools:flowcore ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-flowcore" ;
    schema1:softwareVersion "2.18.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/flowCore.html" ;
    spdx:builtFrom biotools:flowcore .

