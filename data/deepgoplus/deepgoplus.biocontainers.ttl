@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:deepgoplus a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btz595" ;
    schema1:description "Deepgoplus is a novel method for predicting protein functions from protein sequences using deep neural networks combined with sequence similarity based predictions." ;
    schema1:keywords "Protein Sequences",
        "protein function prediction" ;
    schema1:license "SPDX:BSD-3-Clause" ;
    schema1:name "deepgoplus" ;
    schema1:url "http://deepgoplus.bio2vec.net/" .

