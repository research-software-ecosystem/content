@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:gffutils a schema1:SoftwareApplication ;
    schema1:description "Work with gff and gtf files in a flexible database framework" ;
    schema1:identifier biotools:GFFutils ;
    schema1:keywords "Genomics",
        "Nucleic acids",
        "Sequence analysis" ;
    schema1:license "MIT" ;
    schema1:name "gffutils" ;
    schema1:url "https://github.com/daler/gffutils" .

