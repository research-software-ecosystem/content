@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:gffutils a schema1:SoftwareApplication ;
    schema1:description "Work with GFF and GTF files in a flexible database framework" ;
    schema1:downloadUrl "https://pypi.io/packages/source/g/gffutils/gffutils-0.14.tar.gz" ;
    schema1:identifier biotools:GFFutils ;
    schema1:license "MIT" ;
    schema1:name "gffutils" ;
    schema1:softwareHelp "http://daler.github.io/gffutils/" ;
    schema1:softwareVersion "0.14" ;
    schema1:url "https://github.com/daler/gffutils" ;
    spdx:builtFrom biotools:GFFutils .

