@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-hypergraph a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "A package providing hypergraph data structures" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/hypergraph_1.82.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/hypergraph/hypergraph_1.82.0.tar.gz', 'https://bioarchive.galaxyproject.org/hypergraph_1.82.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-hypergraph/bioconductor-hypergraph_1.82.0_src_all.tar.gz']" ;
    schema1:identifier biotools:hypergraph ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-hypergraph" ;
    schema1:softwareVersion "1.82.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/hypergraph.html" ;
    spdx:builtFrom biotools:hypergraph .

