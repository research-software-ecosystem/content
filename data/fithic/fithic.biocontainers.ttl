@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:fithic a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1101/gr.160374.113" ;
    schema1:description "Fit-hi-c is a tool for assigning statistical confidence estimates to chromosomal contact maps produced by genome architecture assays." ;
    schema1:identifier biotools:fithic ;
    schema1:keywords "Animals",
        "Chromatin",
        "Chromatin Assembly and Disassembly",
        "Confidence Intervals",
        "Embryonic Stem Cells",
        "Genomics",
        "Histone Code",
        "Homeodomain Proteins",
        "Humans",
        "Mice",
        "Models, Genetic",
        "Nanog Homeobox Protein",
        "Neurons",
        "Octamer Transcription Factor-3",
        "Protein Binding",
        "Regulatory Sequences, Nucleic Acid",
        "Species Specificity",
        "Yeasts" ;
    schema1:license "MIT" ;
    schema1:name "fithic" ;
    schema1:url "https://github.com/ay-lab/fithic/tree/master" .

