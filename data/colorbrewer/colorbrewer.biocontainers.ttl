@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:colorbrewer a schema1:SoftwareApplication ;
    schema1:description "An easy way to get access to colorbrewer schemes from within a python program" ;
    schema1:license "Apache-2.0" ;
    schema1:name "colorbrewer" ;
    schema1:url "http://noble.gs.washington.edu/~mmh1/software/colorbrewer/" .

