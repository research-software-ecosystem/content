@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-dcgsa a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Distance-correlation based Gene Set Analysis for longitudinal gene expression profiles" ;
    schema1:identifier biotools:dcgsa ;
    schema1:keywords "Computational Biology",
        "Gene Expression",
        "Gene Expression Profiling",
        "Gene expression",
        "Genomics",
        "High-Throughput Screening Assays",
        "Programming Languages",
        "User-Computer Interface" ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-dcgsa" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/dcGSA.html" .

