@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-dcgsa a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Distance-correlation based Gene Set Analysis for longitudinal gene expression profiles" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/dcGSA_1.34.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/dcGSA/dcGSA_1.34.0.tar.gz', 'https://bioarchive.galaxyproject.org/dcGSA_1.34.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-dcgsa/bioconductor-dcgsa_1.34.0_src_all.tar.gz']" ;
    schema1:identifier biotools:dcgsa ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-dcgsa" ;
    schema1:softwareVersion "1.34.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/dcGSA.html" ;
    spdx:builtFrom biotools:dcgsa .

