@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:scoary a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s13059-016-1108-8" ;
    schema1:description "Microbial pan-GWAS using the output from Roary" ;
    schema1:downloadUrl "https://github.com/AdmiralenOla/Scoary/archive/v1.6.16.tar.gz" ;
    schema1:identifier biotools:Scoary ;
    schema1:license "GPL-3.0" ;
    schema1:name "scoary" ;
    schema1:softwareVersion "1.6.16" ;
    schema1:url "https://github.com/AdmiralenOla/Scoary" ;
    spdx:builtFrom biotools:Scoary .

