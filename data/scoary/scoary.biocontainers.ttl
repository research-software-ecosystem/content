@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:scoary a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s13059-016-1108-8" ;
    schema1:description "Pan-genome wide association studies and  is designed to take the gene_presence_absence.csv file from roary as well as a traits file created by the user and calculate the assocations between all genes in the accessory genome (all genes that are present in i genomes where 1 < i < n) and the traits. it reports a list of genes sorted by strength of association per trait." ;
    schema1:identifier biotools:Scoary ;
    schema1:keywords "Functional genomics",
        "GWAS study",
        "Genomics",
        "Genotype and phenotype",
        "Model organisms" ;
    schema1:license "GPL-3.0" ;
    schema1:name "scoary" ;
    schema1:url "https://github.com/AdmiralenOla/Scoary" .

