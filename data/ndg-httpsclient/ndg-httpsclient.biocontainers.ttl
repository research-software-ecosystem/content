@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:ndg-httpsclient a schema1:SoftwareApplication ;
    schema1:description "Provides enhanced HTTPS support for httplib and urllib2 using PyOpenSSL." ;
    schema1:license "BSD3-Clause" ;
    schema1:name "ndg-httpsclient" ;
    schema1:url "https://github.com/cedadev/ndg_httpsclient" .

