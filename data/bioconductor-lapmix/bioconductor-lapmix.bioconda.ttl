@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-lapmix a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/biostatistics/kxj032" ;
    schema1:description "Laplace Mixture Model in Microarray Experiments" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/lapmix_1.72.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/lapmix/lapmix_1.72.0.tar.gz', 'https://bioarchive.galaxyproject.org/lapmix_1.72.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-lapmix/bioconductor-lapmix_1.72.0_src_all.tar.gz']" ;
    schema1:identifier biotools:lapmix ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-lapmix" ;
    schema1:softwareVersion "1.72.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/lapmix.html" ;
    spdx:builtFrom biotools:lapmix .

