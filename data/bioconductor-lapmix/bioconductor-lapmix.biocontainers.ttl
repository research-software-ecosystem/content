@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-lapmix a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/biostatistics/kxj032" ;
    schema1:description "Laplace Mixture Model in Microarray Experiments" ;
    schema1:identifier biotools:lapmix ;
    schema1:keywords "Arabidopsis",
        "Bayes Theorem",
        "Biometry",
        "Data Interpretation, Statistical",
        "Databases, Genetic",
        "Gene Expression Profiling",
        "Likelihood Functions",
        "Microarray experiment",
        "Models, Statistical",
        "Oligonucleotide Array Sequence Analysis" ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-lapmix" ;
    schema1:url "http://bioconductor.org/packages/3.6/bioc/html/lapmix.html" .

