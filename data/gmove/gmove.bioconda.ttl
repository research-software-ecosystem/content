@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:gmove a schema1:SoftwareApplication ;
    schema1:citation "doi:10.7490/f1000research.1111735.1" ;
    schema1:description "Gmove is a gene prediction tool." ;
    schema1:downloadUrl "https://github.com/institut-de-genomique/Gmove/archive/refs/tags/v1.3.tar.gz" ;
    schema1:identifier biotools:Gmove ;
    schema1:license "MIT" ;
    schema1:name "gmove" ;
    schema1:softwareHelp "https://github.com/institut-de-genomique/Gmove/blob/v1.3/README.md" ;
    schema1:softwareVersion "1.3" ;
    schema1:url "https://github.com/institut-de-genomique/Gmove" ;
    spdx:builtFrom biotools:Gmove .

