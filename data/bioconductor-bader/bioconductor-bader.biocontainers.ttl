@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-bader a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Bayesian Analysis of Differential Expression in RNA Sequencing Data" ;
    schema1:identifier biotools:bader ;
    schema1:keywords "Computational Biology",
        "Gene Expression Profiling",
        "Genomics",
        "High-Throughput Screening Assays",
        "Programming Languages",
        "RNA-Seq",
        "Statistics and probability",
        "User-Computer Interface" ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-bader" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/BADER.html" .

