@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-bader a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Bayesian Analysis of Differential Expression in RNA Sequencing Data" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/BADER_1.48.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/BADER/BADER_1.48.0.tar.gz', 'https://bioarchive.galaxyproject.org/BADER_1.48.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-bader/bioconductor-bader_1.48.0_src_all.tar.gz']" ;
    schema1:identifier biotools:bader ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-bader" ;
    schema1:softwareVersion "1.48.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/BADER.html" ;
    spdx:builtFrom biotools:bader .

