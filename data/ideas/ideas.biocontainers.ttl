@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:ideas a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1371/JOURNAL.PCBI.1007399" ;
    schema1:description "A method for jointly and quantitatively characterizing multivariate epigenetic landscapes in many cell types, tissues or conditions." ;
    schema1:keywords "Epigenomics",
        "Forecasting",
        "Gene Regulatory Networks",
        "Genome, Human",
        "Genomics",
        "Humans",
        "Polymorphism, Single Nucleotide",
        "Regulatory Elements, Transcriptional",
        "Regulatory Sequences, Nucleic Acid",
        "Sequence Analysis, DNA",
        "Whole Genome Sequencing" ;
    schema1:license "MIT" ;
    schema1:name "ideas" ;
    schema1:url "https://github.com/yuzhang123/IDEAS" .

