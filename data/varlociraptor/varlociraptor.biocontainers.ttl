@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:varlociraptor a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1101/741256" ;
    schema1:description "Flexible, uncertainty-aware variant calling with parameter free filtration via FDR control." ;
    schema1:identifier biotools:varlociraptor ;
    schema1:keywords "Genetic variation",
        "Genetics",
        "Oncology",
        "Transcription factors and regulatory sites" ;
    schema1:license "GPL-" ;
    schema1:name "varlociraptor" ;
    schema1:url "https://github.com/varlociraptor/varlociraptor" .

