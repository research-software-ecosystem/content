@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:varlociraptor a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s13059-020-01993-6" ;
    schema1:description "Flexible, uncertainty-aware variant calling with parameter free filtration via FDR control." ;
    schema1:downloadUrl "https://github.com/varlociraptor/varlociraptor/archive/v8.9.5.tar.gz" ;
    schema1:identifier biotools:varlociraptor ;
    schema1:license "GPL-3.0-or-later" ;
    schema1:name "varlociraptor" ;
    schema1:softwareHelp "https://varlociraptor.github.io" ;
    schema1:softwareVersion "8.9.5" ;
    schema1:url "https://github.com/varlociraptor/varlociraptor" ;
    spdx:builtFrom biotools:varlociraptor .

