@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-lfa a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btv641" ;
    schema1:description "Logistic Factor Analysis for Categorical Data" ;
    schema1:identifier biotools:lfa ;
    schema1:keywords "DNA polymorphism",
        "Genetic Variation",
        "Genotype",
        "Humans",
        "Models, Statistical",
        "Probability",
        "Statistics and probability",
        "Structure analysis" ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-lfa" ;
    schema1:url "http://bioconductor.org/packages/3.6/bioc/html/lfa.html" .

