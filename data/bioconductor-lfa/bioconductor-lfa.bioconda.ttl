@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-lfa a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btv641" ;
    schema1:description "Logistic Factor Analysis for Categorical Data" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/lfa_2.6.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/lfa/lfa_2.6.0.tar.gz', 'https://bioarchive.galaxyproject.org/lfa_2.6.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-lfa/bioconductor-lfa_2.6.0_src_all.tar.gz']" ;
    schema1:identifier biotools:lfa ;
    schema1:license "GPL (>= 3)" ;
    schema1:name "bioconductor-lfa" ;
    schema1:softwareVersion "2.6.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/lfa.html" ;
    spdx:builtFrom biotools:lfa .

