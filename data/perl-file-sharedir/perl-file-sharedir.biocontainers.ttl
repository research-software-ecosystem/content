@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:perl-file-sharedir a schema1:SoftwareApplication ;
    schema1:description "Locate per-dist and per-module shared files" ;
    schema1:license "perl_5" ;
    schema1:name "perl-file-sharedir" ;
    schema1:url "https://metacpan.org/release/File-ShareDir" .

