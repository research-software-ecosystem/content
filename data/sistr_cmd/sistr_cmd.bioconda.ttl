@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:sistr_cmd a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1371/journal.pone.0147101" ;
    schema1:description "Salmonella In Silico Typing Resource (SISTR) commandline tool for serovar prediction" ;
    schema1:downloadUrl "https://github.com/phac-nml/sistr_cmd/archive/refs/tags/v1.1.3.tar.gz" ;
    schema1:identifier biotools:SISTR ;
    schema1:license "Apache-2.0" ;
    schema1:name "sistr_cmd" ;
    schema1:softwareVersion "1.1.3" ;
    schema1:url "https://github.com/phac-nml/sistr_cmd/" ;
    spdx:builtFrom biotools:SISTR .

