@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:meryl a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s13059-020-02134-9" ;
    schema1:description "meryl is a multi-threaded, multi-process, out-of-core k-mer counter" ;
    schema1:identifier biotools:meryl ;
    schema1:license "Public Domain" ;
    schema1:name "meryl" ;
    schema1:softwareHelp "https://github.com/marbl/meryl" ;
    schema1:softwareVersion "1.4.1" ;
    schema1:url "https://github.com/marbl/meryl" ;
    spdx:builtFrom biotools:meryl .

