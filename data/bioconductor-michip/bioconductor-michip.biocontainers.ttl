@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-michip a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "MiChip Parsing and Summarizing Functions" ;
    schema1:identifier biotools:michip ;
    schema1:keywords "Computational Biology",
        "Data management",
        "Functional, regulatory and non-coding RNA",
        "Gene Expression Profiling",
        "Genomics",
        "High-Throughput Screening Assays",
        "Microarray experiment",
        "Programming Languages",
        "User-Computer Interface" ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-michip" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/MiChip.html" .

