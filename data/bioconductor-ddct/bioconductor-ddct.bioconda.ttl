@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-ddct a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "The ddCt Algorithm for the Analysis of Quantitative Real-Time PCR (qRT-PCR)" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/ddCt_1.62.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/ddCt/ddCt_1.62.0.tar.gz', 'https://bioarchive.galaxyproject.org/ddCt_1.62.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-ddct/bioconductor-ddct_1.62.0_src_all.tar.gz']" ;
    schema1:identifier biotools:ddct ;
    schema1:license "LGPL-3" ;
    schema1:name "bioconductor-ddct" ;
    schema1:softwareVersion "1.62.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/ddCt.html" ;
    spdx:builtFrom biotools:ddct .

