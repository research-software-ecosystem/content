biocontainers:bioconductor-ddct a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "The ddCt Algorithm for the Analysis of Quantitative Real-Time PCR (qRT-PCR)" ;
    schema1:identifier biotools:ddct ;
    schema1:keywords "Computational Biology",
        "Gene Expression",
        "Gene Expression Profiling",
        "Genomics",
        "High-Throughput Screening Assays",
        "PCR experiment",
        "Programming Languages",
        "User-Computer Interface" ;
    schema1:license "LGPL-3" ;
    schema1:name "bioconductor-ddct" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/ddCt.html" .

