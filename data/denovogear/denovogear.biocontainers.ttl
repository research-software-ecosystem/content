@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:denovogear a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.2611" ;
    schema1:description "A program to detect denovo-variants using next-generation sequencing data." ;
    schema1:keywords "Exome",
        "Gene Deletion",
        "Genome, Human",
        "Human Genome Project",
        "Humans",
        "INDEL Mutation",
        "Likelihood Functions",
        "Models, Genetic",
        "Mutagenesis, Insertional",
        "Point Mutation" ;
    schema1:license "GPL-3.0" ;
    schema1:name "denovogear" ;
    schema1:url "https://github.com/denovogear/denovogear" .

