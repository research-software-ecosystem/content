@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:psiclass a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/s41467-019-12990-0" ;
    schema1:description "Simultaneous multi-sample transcript assembler for RNA-seq data." ;
    schema1:downloadUrl "https://github.com/splicebox/PsiCLASS/archive/v1.0.3.tar.gz" ;
    schema1:identifier biotools:psiclass ;
    schema1:license "GPL-3.0-only" ;
    schema1:name "psiclass" ;
    schema1:softwareHelp "https://github.com/splicebox/PsiCLASS/blob/v1.0.3/README.md" ;
    schema1:softwareVersion "1.0.3" ;
    schema1:url "https://github.com/splicebox/PsiCLASS" ;
    spdx:builtFrom biotools:psiclass .

