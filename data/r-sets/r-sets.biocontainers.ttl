@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-sets a schema1:SoftwareApplication ;
    schema1:description "Data structures and basic operations for ordinary sets, generalizations such as fuzzy sets, multisets, and fuzzy multisets, customizable sets, and intervals." ;
    schema1:license "GPL-2.0" ;
    schema1:name "r-sets" ;
    schema1:url "https://CRAN.R-project.org/package=sets" .

