@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:sixgill a schema1:SoftwareApplication ;
    schema1:description "six-frame genome-inferred libraries for LC-MS/MS" ;
    schema1:keywords "Genomics",
        "Metagenomics",
        "Metaproteomics",
        "Peptides",
        "Proteomics" ;
    schema1:license "Apache-2.0" ;
    schema1:name "sixgill" ;
    schema1:url "https://github.com/dhmay/sixgill" .

