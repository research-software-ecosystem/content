@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:isaac4 a schema1:SoftwareApplication ;
    schema1:author "cbrueffer" ;
    schema1:citation "doi:10.1093/bioinformatics/btt314" ;
    schema1:description "Ultra-fast whole-genome alignment for Illumina sequencing platforms." ;
    schema1:downloadUrl "https://github.com/Illumina/Isaac4/archive/Isaac-04.18.11.09.tar.gz" ;
    schema1:identifier biotools:isaac ;
    schema1:license "GPL-3.0-only" ;
    schema1:maintainer "cbrueffer" ;
    schema1:name "isaac4" ;
    schema1:softwareVersion "04.18.11.09" ;
    schema1:url "https://github.com/Illumina/Isaac4" ;
    spdx:builtFrom biotools:isaac .

