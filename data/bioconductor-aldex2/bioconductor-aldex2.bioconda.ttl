@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-aldex2 a schema1:SoftwareApplication ;
    schema1:description "Analysis Of Differential Abundance Taking Sample and Scale Variation Into Account" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/ALDEx2_1.38.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/ALDEx2/ALDEx2_1.38.0.tar.gz', 'https://bioarchive.galaxyproject.org/ALDEx2_1.38.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-aldex2/bioconductor-aldex2_1.38.0_src_all.tar.gz']" ;
    schema1:identifier biotools:aldex2 ;
    schema1:license "GPL (>=3)" ;
    schema1:name "bioconductor-aldex2" ;
    schema1:softwareVersion "1.38.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/ALDEx2.html" ;
    spdx:builtFrom biotools:aldex2 .

