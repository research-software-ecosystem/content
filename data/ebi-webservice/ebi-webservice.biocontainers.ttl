@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:ebi-webservice a schema1:SoftwareApplication ;
    schema1:description "A collection of web service clients to consume ebi bioinfomatics tools" ;
    schema1:keywords "Gene Expression",
        "Genomics" ;
    schema1:license "Apache-2.0" ;
    schema1:name "ebi-webservice" ;
    schema1:url "https://www.ebi.ac.uk/services" .

