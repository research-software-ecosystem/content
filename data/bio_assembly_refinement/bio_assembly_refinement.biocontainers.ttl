@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bio_assembly_refinement a schema1:SoftwareApplication ;
    schema1:description "Assembly refinement tools, mostly useful for (but not limited to) pacbio bacterial assemblies" ;
    schema1:license "GPL-3" ;
    schema1:name "bio_assembly_refinement" ;
    schema1:url "https://github.com/nds/bio_assembly_refinement" .

