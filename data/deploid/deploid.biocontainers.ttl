@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:deploid a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btx530" ;
    schema1:description "A software that deconvolutes mixed genomes with unknown proportions." ;
    schema1:identifier biotools:DEploid ;
    schema1:keywords "Coinfection",
        "Genomics",
        "Genotype and phenotype",
        "Haplotypes",
        "High-Throughput Nucleotide Sequencing",
        "Humans",
        "Malaria, Falciparum",
        "Plasmodium falciparum",
        "Sequence Analysis, DNA",
        "Sequencing",
        "Statistics and probability" ;
    schema1:license "GPL-3.0" ;
    schema1:name "deploid" ;
    schema1:url "https://github.com/DEploid-dev/DEploid" .

