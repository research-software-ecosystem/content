@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:deploid a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btx530" ;
    schema1:description "A software that deconvolutes mixed genomes with unknown proportions." ;
    schema1:downloadUrl "https://github.com/mcveanlab/DEploid/archive/v0.5-release.tar.gz" ;
    schema1:identifier biotools:DEploid ;
    schema1:license "GPLv3" ;
    schema1:name "deploid" ;
    schema1:softwareVersion "0.5" ;
    schema1:url "http://deploid.readthedocs.io/en/latest/index.html" ;
    spdx:builtFrom biotools:DEploid .

