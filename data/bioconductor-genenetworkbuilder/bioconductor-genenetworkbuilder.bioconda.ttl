@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-genenetworkbuilder a schema1:SoftwareApplication ;
    schema1:description "GeneNetworkBuilder: a bioconductor package for building regulatory network using ChIP-chip/ChIP-seq data and Gene Expression Data" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/GeneNetworkBuilder_1.48.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/GeneNetworkBuilder/GeneNetworkBuilder_1.48.0.tar.gz', 'https://bioarchive.galaxyproject.org/GeneNetworkBuilder_1.48.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-genenetworkbuilder/bioconductor-genenetworkbuilder_1.48.0_src_all.tar.gz']" ;
    schema1:identifier biotools:genenetworkbuilder ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-genenetworkbuilder" ;
    schema1:softwareVersion "1.48.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/GeneNetworkBuilder.html" ;
    spdx:builtFrom biotools:genenetworkbuilder .

