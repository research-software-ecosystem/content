@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-genenetworkbuilder a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18129/b9.bioc.genenetworkbuilder" ;
    schema1:description "GeneNetworkBuilder: a bioconductor package for building regulatory network using ChIP-chip/ChIP-seq data and Gene Expression Data" ;
    schema1:keywords "Gene Expression",
        "RNA-Seq",
        "Transcription Factors" ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-genenetworkbuilder" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/GeneNetworkBuilder.html" .

