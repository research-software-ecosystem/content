    schema1:keywords "Animals",
        "Gene Expression Profiling",
        "Gene expression",
        "Humans",
        "Microarray experiment",
        "Oligonucleotide Array Sequence Analysis",
        "Sequence analysis" ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-affyplm" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/affyPLM.html" .

