@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-affyplm a schema1:SoftwareApplication ;
    schema1:description "Methods for fitting probe-level models" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/affyPLM_1.82.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/affyPLM/affyPLM_1.82.0.tar.gz', 'https://bioarchive.galaxyproject.org/affyPLM_1.82.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-affyplm/bioconductor-affyplm_1.82.0_src_all.tar.gz']" ;
    schema1:identifier biotools:affyplm ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-affyplm" ;
    schema1:softwareVersion "1.82.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/affyPLM.html" ;
    spdx:builtFrom biotools:affyplm .

