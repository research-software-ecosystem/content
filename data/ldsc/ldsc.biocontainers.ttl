@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:ldsc a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/ng.3211",
        "doi:10.1101/014241",
        "doi:10.1101/014498",
        "doi:10.1101/018283" ;
    schema1:description "ldsc is a tool for estimating heritability and genetic correlation from GWAS summary statistics. It also computes LD Scores." ;
    schema1:identifier biotools:ldsc ;
    schema1:keywords "Computer Simulation",
        "Genetics",
        "Genome, Human",
        "Genome-Wide Association Study",
        "Humans",
        "Linkage Disequilibrium",
        "Mapping",
        "Polymorphism, Single Nucleotide",
        "Regression Analysis",
        "Sample Size" ;
    schema1:license "GPL-3.0" ;
    schema1:name "ldsc" ;
    schema1:url "https://github.com/bulik/ldsc/" .

