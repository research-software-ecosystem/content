@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:oncotator a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1002/humu.22771" ;
    schema1:description "Oncotator is a tool for annotating human genomic point mutations and indels with data relevant to cancer researchers." ;
    schema1:identifier biotools:oncotator ;
    schema1:keywords "Computational Biology",
        "DNA mutation",
        "Databases, Genetic",
        "Genetic Variation",
        "Genomics",
        "Human biology",
        "Humans",
        "Internet",
        "Neoplasms",
        "Oncology",
        "Web Browser" ;
    schema1:license "Custom OSS" ;
    schema1:name "oncotator" ;
    schema1:url "https://github.com/broadinstitute/oncotator" .

