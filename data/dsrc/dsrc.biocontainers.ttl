@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:dsrc a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btr014" ;
    schema1:description "high-performance compression of sequencing reads stored in FASTQ format" ;
    schema1:identifier biotools:dsrc ;
    schema1:keywords "Base Sequence",
        "Computational Biology",
        "Data Compression",
        "Data management",
        "Genomics",
        "Internet",
        "Sequence Analysis, DNA" ;
    schema1:license "GPL-2.0" ;
    schema1:name "dsrc" ;
    schema1:url "https://github.com/refresh-bio/DSRC" .

