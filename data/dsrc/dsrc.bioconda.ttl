@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:dsrc a schema1:SoftwareApplication ;
    schema1:description "High-performance compression of sequencing reads stored in FASTQ format." ;
    schema1:downloadUrl "https://github.com/refresh-bio/DSRC/archive/5eda82cb1546b71cd3480bc0aba1d321b52bd0b4.zip" ;
    schema1:identifier biotools:dsrc ;
    schema1:license "GPL-2.0-or-later" ;
    schema1:name "dsrc" ;
    schema1:softwareVersion "2015.06.04" ;
    schema1:url "https://github.com/refresh-bio/DSRC" ;
    spdx:builtFrom biotools:dsrc .

