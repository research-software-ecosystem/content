@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:covtobed a schema1:SoftwareApplication ;
    schema1:citation "doi:10.21105/joss.02119" ;
    schema1:description "covtobed - generate a BED file of covered regions from a BAM file" ;
    schema1:identifier biotools:covtobed ;
    schema1:keywords "Genetics",
        "Sequence analysis" ;
    schema1:license "MIT" ;
    schema1:name "covtobed" ;
    schema1:url "https://github.com/telatin/covtobed/" .

