@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-motifrg a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btt615" ;
    schema1:description "Tools for discriminative motif discovery using regression methods." ;
    schema1:identifier biotools:motifrg ;
    schema1:keywords "Base Sequence",
        "Chromatin Immunoprecipitation",
        "DNA",
        "High-Throughput Nucleotide Sequencing",
        "Humans",
        "Sequence Analysis, DNA",
        "Sequence analysis",
        "Sequence sites, features and motifs",
        "Transcription Factors" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-motifrg" ;
    schema1:url "http://bioconductor.org/packages/release/bioc/html/motifRG.html" .

