@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-hiccompare a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1101/147850",
        "doi:10.1186/s12859-018-2288-x" ;
    schema1:description "HiCcompare: Joint normalization and comparative analysis of multiple Hi-C datasets" ;
    schema1:identifier biotools:HiCcompare ;
    schema1:keywords "Animals",
        "CCCTC-Binding Factor",
        "Cell Differentiation",
        "Chromatin",
        "Computational Biology",
        "Databases, Genetic",
        "Genome",
        "Humans",
        "Mice",
        "Neurons",
        "Sequencing" ;
    schema1:license "MIT" ;
    schema1:name "bioconductor-hiccompare" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/HiCcompare.html" .

