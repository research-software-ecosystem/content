@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-chipcomp a schema1:SoftwareApplication ;
    schema1:description "Quantitative comparison of multiple ChIP-seq datasets" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/ChIPComp_1.36.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/ChIPComp/ChIPComp_1.36.0.tar.gz', 'https://bioarchive.galaxyproject.org/ChIPComp_1.36.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-chipcomp/bioconductor-chipcomp_1.36.0_src_all.tar.gz']" ;
    schema1:identifier biotools:chipcomp ;
    schema1:license "GPL" ;
    schema1:name "bioconductor-chipcomp" ;
    schema1:softwareVersion "1.36.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/ChIPComp.html" ;
    spdx:builtFrom biotools:chipcomp .

