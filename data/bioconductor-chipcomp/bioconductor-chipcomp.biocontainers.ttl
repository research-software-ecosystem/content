@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-chipcomp a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btv094" ;
    schema1:description "Quantitative comparison of multiple ChIP-seq datasets" ;
    schema1:identifier biotools:chipcomp ;
    schema1:keywords "Artifacts",
        "ChIP-seq",
        "Chromatin Immunoprecipitation",
        "Computational Biology",
        "Computer Simulation",
        "Datasets as Topic",
        "Genetics",
        "Genome, Human",
        "High-Throughput Nucleotide Sequencing",
        "Histones",
        "Humans",
        "Models, Statistical",
        "Poisson Distribution",
        "Protein Binding",
        "Sequence Analysis, DNA",
        "Transcription Factors" ;
    schema1:license "GPL" ;
    schema1:name "bioconductor-chipcomp" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/ChIPComp.html" .

