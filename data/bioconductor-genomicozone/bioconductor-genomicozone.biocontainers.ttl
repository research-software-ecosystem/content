@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-genomicozone a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18129/b9.bioc.genomicozone" ;
    schema1:description "Delineate outstanding genomic zones of differential gene activity" ;
    schema1:keywords "Clustering",
        "Genetics",
        "Genomics",
        "Transcriptomics" ;
    schema1:license "LGPL (>=3)" ;
    schema1:name "bioconductor-genomicozone" ;
    schema1:url "https://bioconductor.org/packages/3.10/bioc/html/GenomicOZone.html" .

