  "@graph": [
    {
      "@id": "https://doi.org/10.18129/B9.bioc.MEB",
      "@type": "sc:CreativeWork"
    },
    {
      "@id": "https://bio.tools/bioconductor-meb",
      "@type": "sc:SoftwareApplication",
      "dcterms:conformsTo": "https://bioschemas.org/profiles/ComputationalTool/0.6-DRAFT",
      "sc:additionalType": [
        "Command-line tool",
        "Library"
      ],
      "sc:citation": {
        "@id": "https://doi.org/10.18129/B9.bioc.MEB"
      },
      "sc:description": "This package provides a method to identify differential expression genes in the same or different species. Given that non-DE genes have some similarities in features, a scaling-free minimum enclosing ball (SFMEB) model is built to cover those non-DE genes in feature space, then those DE genes, which are enormously different from non-DE genes, being regarded as outliers and rejected outside the ball. The method on this package is described in the article 'A minimum enclosing ball method to detect differential expression genes for RNA-seq data'. The SFMEB method is extended to the scMEB method that considering two or more potential types of cells or unknown labels scRNA-seq dataset DEGs identification.",
      "sc:license": "GPL-2.0-only",
      "sc:name": "MEB",
      "sc:operatingSystem": [
        "Mac",
        "Windows",
        "Linux"
      ],
      "sc:softwareHelp": {
        "@id": "https://bioconductor.org/packages/MEB"
      },
      "sc:softwareVersion": "1.24.0",
      "sc:url": "https://bioconductor.org/packages/MEB"
    }
  ]
