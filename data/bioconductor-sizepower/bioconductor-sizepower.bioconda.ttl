@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-sizepower a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Sample Size and Power Calculation in Micorarray Studies" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/sizepower_1.76.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/sizepower/sizepower_1.76.0.tar.gz', 'https://bioarchive.galaxyproject.org/sizepower_1.76.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-sizepower/bioconductor-sizepower_1.76.0_src_all.tar.gz']" ;
    schema1:identifier biotools:sizepower ;
    schema1:license "LGPL" ;
    schema1:name "bioconductor-sizepower" ;
    schema1:softwareVersion "1.76.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/sizepower.html" ;
    spdx:builtFrom biotools:sizepower .

