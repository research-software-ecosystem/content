@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:quasirecomb a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1089/cmb.2012.0232" ;
    schema1:description "Software of Inference of Quasispecies subjected to Recombination" ;
    schema1:downloadUrl "https://github.com/cbg-ethz/QuasiRecomb/releases/download/v1.2/QuasiRecomb.jar" ;
    schema1:identifier biotools:QuasiRecomb ;
    schema1:license "GNU GPLv3" ;
    schema1:name "quasirecomb" ;
    schema1:softwareVersion "1.2" ;
    schema1:url "https://github.com/cbg-ethz/QuasiRecomb" ;
    spdx:builtFrom biotools:QuasiRecomb .

