@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:uritemplate a schema1:SoftwareApplication ;
    schema1:description "Python implementation of rfc6570, uri template, and can expand templates up to and including level 4 in that specification." ;
    schema1:license "Apache-2.0" ;
    schema1:name "uritemplate" ;
    schema1:url "https://pypi.org/project/uritemplate/" .

