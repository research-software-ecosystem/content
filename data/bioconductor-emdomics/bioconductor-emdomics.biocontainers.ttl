@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-emdomics a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18129/b9.bioc.emdomics" ;
    schema1:description "Earth mover's distance for differential analysis of genomics data" ;
    schema1:keywords "Gene Expression",
        "Genomics" ;
    schema1:license "MIT" ;
    schema1:name "bioconductor-emdomics" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/EMDomics.html" .

