@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:tb-profiler a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s13073-019-0650-x" ;
    schema1:description "Profiling tool for mycobacterium tuberculosis to detect drug resistance and lineage from wgs data" ;
    schema1:keywords "Antitubercular Agents",
        "Drug Resistance, Microbial",
        "Genome, Bacterial",
        "Humans",
        "Molecular Diagnostic Techniques",
        "Mycobacterium tuberculosis",
        "Point-of-Care Testing",
        "Tuberculosis, Multidrug-Resistant",
        "Whole Genome Sequencing" ;
    schema1:license "GPL-3.0" ;
    schema1:name "tb-profiler" ;
    schema1:url "https://github.com/jodyphelan/TBProfiler" .

