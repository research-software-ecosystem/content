bioconda:bioconductor-snagee a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1371/journal.pone.0051013" ;
    schema1:description "Signal-to-Noise applied to Gene Expression Experiments" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/SNAGEE_1.46.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/SNAGEE/SNAGEE_1.46.0.tar.gz', 'https://bioarchive.galaxyproject.org/SNAGEE_1.46.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-snagee/bioconductor-snagee_1.46.0_src_all.tar.gz']" ;
    schema1:identifier biotools:snagee ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-snagee" ;
    schema1:softwareVersion "1.46.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/SNAGEE.html" ;
    spdx:builtFrom biotools:snagee .

