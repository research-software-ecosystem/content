@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-snagee a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1371/journal.pone.0051013" ;
    schema1:description "Signal-to-noise applied to gene expression experiments. signal-to-noise ratios can be used as a proxy for quality of gene expression studies and samples. the snrs can be calculated on any gene expression data set as long as gene ids are available, no access to the raw data files is necessary. this allows to flag problematic studies and samples in any public data set." ;
    schema1:identifier biotools:snagee ;
    schema1:keywords "Data quality management",
        "Gene Expression",
        "Gene Expression Profiling",
        "Gene expression",
        "Humans",
        "Microarray experiment",
        "Oligonucleotide Array Sequence Analysis",
        "Signal-To-Noise Ratio" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-snagee" ;
    schema1:url "http://bioconductor.org/packages/release/bioc/html/SNAGEE.html" .

