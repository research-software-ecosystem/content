@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:vcfanno a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s13059-016-0973-5" ;
    schema1:description "Annotate a VCF with other VCFs/BEDs/tabixed files." ;
    schema1:downloadUrl "https://github.com/brentp/vcfanno/archive/refs/tags/v0.3.8.tar.gz" ;
    schema1:identifier biotools:vcfanno ;
    schema1:license "MIT" ;
    schema1:name "vcfanno" ;
    schema1:softwareHelp "https://github.com/brentp/vcfanno/blob/v0.3.8/README.md" ;
    schema1:softwareVersion "0.3.8" ;
    schema1:url "https://github.com/brentp/vcfanno" ;
    spdx:builtFrom biotools:vcfanno .

