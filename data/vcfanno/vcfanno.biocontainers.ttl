@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:vcfanno a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s13059-016-0973-5" ;
    schema1:description "annotate a VCF with other VCFs/BEDs/tabixed files" ;
    schema1:identifier biotools:vcfanno ;
    schema1:keywords "Chromosomes",
        "Data submission, annotation and curation",
        "Genetic variation",
        "Genome, Human",
        "Genomics",
        "Humans",
        "Molecular Sequence Annotation",
        "Phenotype" ;
    schema1:license "MIT" ;
    schema1:name "vcfanno" ;
    schema1:url "https://github.com/brentp/vcfanno" .

