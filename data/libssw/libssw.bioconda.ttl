@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:libssw a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1371/journal.pone.0082138" ;
    schema1:description "An SIMD Smith-Waterman C/C++/Python/Java Library for Use in Genomic Applications." ;
    schema1:downloadUrl "https://github.com/mengyao/Complete-Striped-Smith-Waterman-Library/archive/v1.2.5.tar.gz" ;
    schema1:identifier biotools:ssw ;
    schema1:license "MIT" ;
    schema1:name "libssw" ;
    schema1:softwareHelp "https://github.com/mengyao/Complete-Striped-Smith-Waterman-Library/blob/v1.2.5/README.md" ;
    schema1:softwareVersion "1.2.5" ;
    schema1:url "https://github.com/mengyao/Complete-Striped-Smith-Waterman-Library" ;
    spdx:builtFrom biotools:ssw .

