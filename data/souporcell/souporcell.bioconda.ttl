@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:souporcell a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1101/699637v1" ;
    schema1:description "Clustering scRNAseq by genotypes." ;
    schema1:downloadUrl "https://github.com/wheaton5/souporcell/archive/refs/tags/v2.5.tar.gz" ;
    schema1:identifier biotools:souporcell ;
    schema1:license "MIT" ;
    schema1:name "souporcell" ;
    schema1:softwareVersion "2.5" ;
    schema1:url "https://github.com/wheaton5/souporcell" ;
    spdx:builtFrom biotools:souporcell .

