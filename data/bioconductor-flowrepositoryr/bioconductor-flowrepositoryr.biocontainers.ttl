@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-flowrepositoryr a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1002/cyto.a.22106" ;
    schema1:description "This package provides an interface to search and download data and annotations from flowrepository (flowrepository.org). it uses the flowrepository programming interface to communicate with a flowrepository server." ;
    schema1:identifier biotools:flowrepositoryr ;
    schema1:keywords "Access to Information",
        "Cell biology",
        "Databases as Topic",
        "Flow Cytometry",
        "Humans",
        "Information Dissemination",
        "Online Systems",
        "Peer Review, Research" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-flowrepositoryr" ;
    schema1:url "http://bioconductor.org/packages/release/bioc/html/FlowRepositoryR.html" .

