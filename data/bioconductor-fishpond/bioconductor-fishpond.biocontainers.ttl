@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-fishpond a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18129/b9.bioc.fishpond" ;
    schema1:description "Fishpond: differential transcript and gene expression with inferential replicates" ;
    schema1:keywords "Gene Expression",
        "RNA-Seq" ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-fishpond" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/fishpond.html" .

