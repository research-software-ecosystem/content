@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-rsubread a schema1:SoftwareApplication ;
    schema1:description "Mapping, quantification and variant analysis of sequencing data" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/Rsubread_2.24.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/Rsubread/Rsubread_2.24.0.tar.gz', 'https://bioarchive.galaxyproject.org/Rsubread_2.24.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-rsubread/bioconductor-rsubread_2.24.0_src_all.tar.gz']" ;
    schema1:identifier biotools:rsubread ;
    schema1:license "GPL (>=3)" ;
    schema1:name "bioconductor-rsubread" ;
    schema1:softwareVersion "2.24.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/Rsubread.html" ;
    spdx:builtFrom biotools:rsubread .

