@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-rsubread a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/gkt214" ;
    schema1:description "Subread Sequence Alignment and Counting for R" ;
    schema1:identifier biotools:rsubread ;
    schema1:keywords "Exons",
        "Gene regulation",
        "Genetics",
        "Genomics",
        "High-Throughput Nucleotide Sequencing",
        "INDEL Mutation",
        "Sequence Alignment",
        "Sequencing" ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-rsubread" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/Rsubread.html" .

