@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:itsxpress a schema1:SoftwareApplication ;
    schema1:citation "doi:10.12688/f1000research.15704.1",
        "doi:10.5281/zenodo.1304349" ;
    schema1:description "Itsxpress: software to rapidly trim the internally transcribed spacer (its) region from fastq files" ;
    schema1:identifier biotools:ITSxpress ;
    schema1:keywords "Adenosine Deaminase",
        "Clustering",
        "Fungi",
        "Intercellular Signaling Peptides and Proteins",
        "Metagenomics",
        "Microbial ecology",
        "Phylogeny" ;
    schema1:license "CC0 1.0" ;
    schema1:name "itsxpress" ;
    schema1:url "http://github.com/usda-ars-gbru/itsxpress" .

