@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:itsxpress a schema1:SoftwareApplication ;
    schema1:author "arivers",
        "seina001" ;
    schema1:citation "doi:10.12688/f1000research.15704.1",
        "doi:10.5281/zenodo.1304349" ;
    schema1:description "ITSxpress: Software to rapidly trim the Internally Transcribed Spacer (ITS) region from FASTQ files." ;
    schema1:downloadUrl "https://github.com/USDA-ARS-GBRU/itsxpress/archive/v2.1.4.tar.gz" ;
    schema1:identifier biotools:ITSxpress ;
    schema1:license "CC0-1.0" ;
    schema1:maintainer "arivers",
        "seina001" ;
    schema1:name "itsxpress" ;
    schema1:softwareVersion "2.1.4" ;
    schema1:url "http://github.com/usda-ars-gbru/itsxpress" ;
    spdx:builtFrom biotools:ITSxpress .

