@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:immuneml a schema1:SoftwareApplication ;
    schema1:author "knutwa-ext",
        "pavelvazquez",
        "pavlovicmilena" ;
    schema1:citation "doi:10.1038/s42256-021-00413-z" ;
    schema1:description "immuneML is a software platform for machine learning analysis of immune receptor repertoires." ;
    schema1:downloadUrl "https://pypi.org/packages/source/i/immuneml/immuneml-3.0.24.tar.gz" ;
    schema1:identifier biotools:immuneml ;
    schema1:license "APGL-3.0-only" ;
    schema1:maintainer "knutwa-ext",
        "pavelvazquez",
        "pavlovicmilena" ;
    schema1:name "immuneml" ;
    schema1:softwareHelp "https://docs.immuneml.uio.no" ;
    schema1:softwareVersion "3.0.24" ;
    schema1:url "https://github.com/uio-bmi/immuneML" ;
    spdx:builtFrom biotools:immuneml .

