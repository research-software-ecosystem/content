@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:blockbuster a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btp419" ;
    schema1:description "Blockbuster detects blocks of overlapping reads using a gaussian-distribution approach." ;
    schema1:identifier biotools:blockbuster ;
    schema1:keywords "Genomics",
        "Humans",
        "MicroRNAs",
        "RNA",
        "RNA, Small Interfering",
        "Sequence Analysis, RNA" ;
    schema1:license "The 3-Clause BSD License" ;
    schema1:name "blockbuster" ;
    schema1:url "http://hoffmann.bioinf.uni-leipzig.de/LIFE/blockbuster.html" .

