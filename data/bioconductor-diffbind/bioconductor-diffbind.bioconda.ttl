@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-diffbind a schema1:SoftwareApplication ;
    schema1:description "Differential Binding Analysis of ChIP-Seq Peak Data" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/DiffBind_3.20.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/DiffBind/DiffBind_3.20.0.tar.gz', 'https://bioarchive.galaxyproject.org/DiffBind_3.20.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-diffbind/bioconductor-diffbind_3.20.0_src_all.tar.gz']" ;
    schema1:identifier biotools:diffbind ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-diffbind" ;
    schema1:softwareVersion "3.20.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/DiffBind.html" ;
    spdx:builtFrom biotools:diffbind .

