      "sc:citation": {
        "@id": "https://doi.org/10.18129/B9.bioc.ASSIGN"
      },
      "sc:description": "ASSIGN is a computational tool to evaluate the pathway deregulation/activation status in individual patient samples. ASSIGN employs a flexible Bayesian factor analysis approach that adapts predetermined pathway signatures derived either from knowledge-based literature or from perturbation experiments to the cell-/tissue-specific pathway signatures. The deregulation/activation level of each context-specific pathway is quantified to a score, which represents the extent to which a patient sample encompasses the pathway deregulation/activation signature.",
      "sc:featureList": {
        "@id": "edam:operation_0533"
      },
