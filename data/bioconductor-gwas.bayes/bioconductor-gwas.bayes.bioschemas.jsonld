        "Jacob Williams",
        "Tieming Ji"
      ],
      "sc:citation": {
        "@id": "https://doi.org/10.18129/B9.bioc.GWAS.BAYES"
      },
      "sc:description": "This package is built to perform GWAS analysis using Bayesian techniques. Currently, GWAS.BAYES has functionality for the implementation of BICOSS (Williams, J., Ferreira, M. A., and Ji, T. (2022). BICOSS: Bayesian iterative conditional stochastic search for GWAS. BMC Bioinformatics), BGWAS (Williams, J., Xu, S., Ferreira, M. A.. (2023) \"BGWAS: Bayesian variable selection in linear mixed models with nonlocal priors for genome-wide association studies.\" BMC Bioinformatics), and GINA. All methods currently are for the analysis of Gaussian phenotypes The research related to this package was supported in part by National Science Foundation awards DMS 1853549, DMS 1853556, and DMS 2054173.",
      "sc:license": "GPL-3.0-only",
      "sc:name": "GWAS.BAYES",
      "sc:operatingSystem": [
        "Mac",
        "Windows",
        "Linux"
      ],
      "sc:softwareHelp": {
        "@id": "https://bioconductor.org/packages/GWAS.BAYES"
      },
      "sc:softwareVersion": "1.20.0",
      "sc:url": "https://bioconductor.org/packages/GWAS.BAYES"
    }
