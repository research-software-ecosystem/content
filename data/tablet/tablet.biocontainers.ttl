@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:tablet a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btp666" ;
    schema1:description "Tablet is a lightweight, high-performance graphical viewer for next generation sequence assemblies and alignments." ;
    schema1:identifier biotools:tablet ;
    schema1:keywords "Base Sequence",
        "Comparative genomics",
        "Computational Biology",
        "Databases, Genetic",
        "Genomics",
        "Genotype and phenotype",
        "RNA-Seq",
        "Sequence Alignment",
        "Sequence Analysis, DNA",
        "User-Computer Interface" ;
    schema1:license "BSD-2" ;
    schema1:name "tablet" ;
    schema1:url "https://ics.hutton.ac.uk/tablet" .

