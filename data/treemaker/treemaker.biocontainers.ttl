@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:treemaker a schema1:SoftwareApplication ;
    schema1:citation "doi:10.15144/pl-c38" ;
    schema1:description "A python tool for generating a newick formatted tree from alist of classifications" ;
    schema1:keywords "Genetics",
        "Phylogenetics" ;
    schema1:license "BSD 3-Clause \"New\" or \"Revised\" License" ;
    schema1:name "treemaker" ;
    schema1:url "https://github.com/SimonGreenhill/treemaker" .

