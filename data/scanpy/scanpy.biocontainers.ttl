@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:scanpy a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s13059-017-1382-0" ;
    schema1:description "Single-Cell Analysis in Python. Scales to >1M cells." ;
    schema1:identifier biotools:scanpy ;
    schema1:keywords "Cell biology",
        "Clustering",
        "Gene Expression",
        "Gene Expression Profiling",
        "Gene Regulatory Networks",
        "Gene expression",
        "Genetics",
        "Single-Cell Analysis",
        "Transcriptomics" ;
    schema1:license "BSD-3" ;
    schema1:name "scanpy" ;
    schema1:url "https://github.com/theislab/scanpy" .

