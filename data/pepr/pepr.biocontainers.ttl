@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:pepr a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btu372" ;
    schema1:description "Peak-calling and prioritization pipeline for replicated chip-seq data" ;
    schema1:identifier biotools:pepr ;
    schema1:keywords "Animals",
        "Cell Line, Tumor",
        "ChIP-seq",
        "Chromatin Immunoprecipitation",
        "DNA binding sites",
        "Epigenomics",
        "Genomics",
        "High-Throughput Nucleotide Sequencing",
        "Mice",
        "Nucleic acid sites, features and motifs",
        "Nucleotide Motifs",
        "Oligonucleotide Array Sequence Analysis",
        "Sequence Analysis, DNA",
        "Transcription Factors" ;
    schema1:license "GPL-3.0" ;
    schema1:name "pepr" ;
    schema1:url "https://github.com/shawnzhangyx/PePr/" .

