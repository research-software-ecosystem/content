@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:hmmcopy a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "C++ based programs for analyzing BAM files and preparing read counts -- used with bioconductor-hmmcopy" ;
    schema1:identifier biotools:hmmcopy ;
    schema1:keywords "Computational Biology",
        "Data quality management",
        "Gene Expression Profiling",
        "Genetics",
        "Genomics",
        "High-Throughput Screening Assays",
        "Programming Languages",
        "Sequence analysis",
        "User-Computer Interface" ;
    schema1:license "GPL-3" ;
    schema1:name "hmmcopy" ;
    schema1:url "http://compbio.bccrc.ca/software/hmmcopy/" .

