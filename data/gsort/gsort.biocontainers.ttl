@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:gsort a schema1:SoftwareApplication ;
    schema1:description "Sort genomic files according to a genomefile" ;
    schema1:license "MIT" ;
    schema1:name "gsort" ;
    schema1:url "https://github.com/brentp/gsort" .

