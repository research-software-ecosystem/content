@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-htscluster a schema1:SoftwareApplication ;
    schema1:description "A Poisson mixture model is implemented to cluster genes from high- throughput transcriptome" ;
    schema1:keywords "Clustering",
        "RNA-Seq",
        "Transcriptome" ;
    schema1:license "GPL-3.0" ;
    schema1:name "r-htscluster" ;
    schema1:url "https://CRAN.R-project.org/package=HTSCluster" .

