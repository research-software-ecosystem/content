@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:genometools a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1109/TCBB.2013.68" ;
    schema1:description "GenomeTools Scripts and Classes For Working With Genomic Data." ;
    schema1:identifier biotools:genometools ;
    schema1:keywords "Genome, Human",
        "Genomics",
        "Humans",
        "Molecular Sequence Annotation",
        "Nucleic acid sites, features and motifs",
        "Sequence analysis" ;
    schema1:license "GPL-3.0" ;
    schema1:name "genometools" ;
    schema1:url "https://github.com/flo-compbio/genometools" .

