@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-phangorn a schema1:SoftwareApplication ;
    schema1:description "Package contains methods for estimation of phylogenetic trees and networks using Maximum Likelihood, Maximum Parsimony, distance methods and Hadamard conjugation. Allows to compare trees, models selection and offers visualizations for trees and split networks. " ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "r-phangorn" ;
    schema1:url "https://github.com/KlausVigo/phangorn" .

