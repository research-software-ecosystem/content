@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-biocgenerics a schema1:SoftwareApplication ;
    schema1:description "S4 generic functions used in Bioconductor" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/BiocGenerics_0.56.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/BiocGenerics/BiocGenerics_0.56.0.tar.gz', 'https://bioarchive.galaxyproject.org/BiocGenerics_0.56.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-biocgenerics/bioconductor-biocgenerics_0.56.0_src_all.tar.gz']" ;
    schema1:identifier biotools:biocgenerics ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-biocgenerics" ;
    schema1:softwareVersion "0.56.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/BiocGenerics.html" ;
    spdx:builtFrom biotools:biocgenerics .

