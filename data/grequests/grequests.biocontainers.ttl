@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:grequests a schema1:SoftwareApplication ;
    schema1:description "Requests + gevent" ;
    schema1:license "BSD" ;
    schema1:name "grequests" ;
    schema1:url "https://pypi.python.org/packages/source/g/grequests/grequests-0.3.0.tar.gz" .

