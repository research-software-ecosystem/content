@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-mutoss a schema1:SoftwareApplication ;
    schema1:description "Designed to ease the application and comparison of multiple hypothesis testing procedures for fwer, gfwer, fdr and fdx. methods are  standardized and usable by the accompanying 'mutossgui'." ;
    schema1:license "GPL" ;
    schema1:name "r-mutoss" ;
    schema1:url "https://github.com/kornl/mutoss/" .

