@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:baitfisher a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/molbev/msw056" ;
    schema1:description "Software package for designing hybrid enrichment probes" ;
    schema1:keywords "DNA",
        "DNA Probes",
        "Gene Library",
        "Genome",
        "High-Throughput Nucleotide Sequencing",
        "Nucleic Acid Amplification Techniques",
        "Phylogeny",
        "Polymerase Chain Reaction",
        "Sequence Alignment",
        "Sequence Analysis, DNA" ;
    schema1:license "GPL-3.0+" ;
    schema1:name "baitfisher" ;
    schema1:url "https://github.com/cmayer/BaitFisher-package" .

