@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-qusage a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/gkt660" ;
    schema1:description "qusage: Quantitative Set Analysis for Gene Expression" ;
    schema1:identifier biotools:qusage ;
    schema1:keywords "Confidence Intervals",
        "Data Interpretation, Statistical",
        "Gene Expression",
        "Gene Expression Profiling",
        "Gene expression",
        "Genes",
        "Humans",
        "Influenza, Human",
        "Microarray experiment",
        "RNA-seq" ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-qusage" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/qusage.html" .

