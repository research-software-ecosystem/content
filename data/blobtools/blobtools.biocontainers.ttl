@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:blobtools a schema1:SoftwareApplication ;
    schema1:citation "doi:10.12688/f1000research.12232.1" ;
    schema1:description "Modular command-line solution for visualisation, quality control and taxonomic partitioning of genome datasets" ;
    schema1:identifier biotools:blobtools ;
    schema1:keywords "Data management",
        "Genomics",
        "Sequence assembly" ;
    schema1:license "GPL-3.0" ;
    schema1:name "blobtools" ;
    schema1:url "https://github.com/DRL/blobtools" .

