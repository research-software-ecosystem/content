@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:tool-generic_filter a schema1:SoftwareApplication ;
    schema1:description "This tool allows to remove all samples and/or variables corresponding to specific values regarding designated factors or numerical variables, in datasets corresponding to dataMatrix, sampleMetadata and variableMetadata." ;
    schema1:keywords "Metabolomics" ;
    schema1:license "Not available" ;
    schema1:name "tool-generic_filter" ;
    schema1:url "https://github.com/workflow4metabolomics/tool-generic_filter" .

