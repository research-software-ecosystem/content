@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:faqcs a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s12859-014-0366-2" ;
    schema1:description "Quality Control of Next Generation Sequencing Data." ;
    schema1:downloadUrl "https://github.com/LANL-Bioinformatics/FaQCs/archive/2.12.tar.gz" ;
    schema1:identifier biotools:faqcs ;
    schema1:license "BSD-3-Clause" ;
    schema1:name "faqcs" ;
    schema1:softwareVersion "2.12" ;
    schema1:url "https://github.com/LANL-Bioinformatics/FaQCs" ;
    spdx:builtFrom biotools:faqcs .

