@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:nasp a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1099/mgen.0.000074" ;
    schema1:description "NASP: an accurate, rapid method for the identification of SNPs in WGS datasets that supports flexible input and output formats" ;
    schema1:keywords "Computer Simulation",
        "Genome, Bacterial",
        "Genomics",
        "Molecular Epidemiology",
        "Phylogeny",
        "Polymorphism, Single Nucleotide",
        "Sequence Analysis, DNA",
        "Whole Genome Sequencing" ;
    schema1:license "Academic and Research License" ;
    schema1:name "nasp" ;
    schema1:url "https://github.com/TGenNorth/nasp" .

