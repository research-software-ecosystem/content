@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:suchtree a schema1:SoftwareApplication ;
    schema1:author "ryneches" ;
    schema1:citation "doi:10.21105/joss.00678" ;
    schema1:description "A python library for doing fast, thread-safe computations on phylogenetic trees" ;
    schema1:downloadUrl "https://pypi.io/packages/source/s/SuchTree/suchtree-1.3.tar.gz" ;
    schema1:identifier biotools:suchtree ;
    schema1:license "BSD" ;
    schema1:maintainer "ryneches" ;
    schema1:name "suchtree" ;
    schema1:softwareHelp "https://github.com/ryneches/SuchTree/blob/master/README.md" ;
    schema1:softwareVersion "1.3" ;
    schema1:url "https://github.com/ryneches/SuchTree/" ;
    spdx:builtFrom biotools:suchtree .

