@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-proper a schema1:SoftwareApplication ;
    schema1:description "PROspective Power Evaluation for RNAseq" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/PROPER_1.42.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/PROPER/PROPER_1.42.0.tar.gz', 'https://bioarchive.galaxyproject.org/PROPER_1.42.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-proper/bioconductor-proper_1.42.0_src_all.tar.gz']" ;
    schema1:identifier biotools:proper ;
    schema1:license "GPL" ;
    schema1:name "bioconductor-proper" ;
    schema1:softwareVersion "1.42.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/PROPER.html" ;
    spdx:builtFrom biotools:proper .

