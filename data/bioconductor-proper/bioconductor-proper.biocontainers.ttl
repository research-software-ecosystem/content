@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-proper a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btu640" ;
    schema1:description "PROspective Power Evaluation for RNAseq" ;
    schema1:identifier biotools:proper ;
    schema1:keywords "Animals",
        "Computational Biology",
        "Datasets as Topic",
        "Gene Expression",
        "Gene Expression Regulation",
        "High-Throughput Nucleotide Sequencing",
        "Humans",
        "Lymphocytes",
        "Mice",
        "Mice, Inbred C57BL",
        "Mice, Inbred DBA",
        "RNA",
        "RNA-Seq",
        "RNA-seq",
        "Sample Size",
        "Sequence Analysis, RNA" ;
    schema1:license "GPL" ;
    schema1:name "bioconductor-proper" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/PROPER.html" .

