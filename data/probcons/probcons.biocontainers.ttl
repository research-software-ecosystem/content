@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:probcons a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1101/gr.2821705" ;
    schema1:description "Probabilistic consistency-based multiple sequence alignment" ;
    schema1:identifier biotools:probcons ;
    schema1:keywords "Amino Acid Sequence",
        "Benchmarking",
        "Computational Biology",
        "Databases, Protein",
        "Genetic Variation",
        "Molecular Sequence Data",
        "Sequence Alignment",
        "Sequence analysis",
        "Software Validation" ;
    schema1:license "PD" ;
    schema1:name "probcons" ;
    schema1:url "http://probcons.stanford.edu/" .

