@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:riboseq-rust a schema1:SoftwareApplication ;
    schema1:description "Ribo-seq unit step transformation. tools to characterise the determinants of ribosome profiling read density across mrna. may be used to examine relative decoding rates and and for quality assessment" ;
    schema1:license "GPL-3" ;
    schema1:name "riboseq-rust" ;
    schema1:url "https://lapti.ucc.ie/rust/" .

