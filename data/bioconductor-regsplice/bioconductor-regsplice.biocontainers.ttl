@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-regsplice a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Statistical methods for detection of differential exon usage in rna-seq and exon microarray data sets, using l1 regularization (lasso) to improve power." ;
    schema1:identifier biotools:regsplice ;
    schema1:keywords "Computational Biology",
        "Gene Expression Profiling",
        "Gene transcripts",
        "Genomics",
        "High-Throughput Screening Assays",
        "Programming Languages",
        "RNA splicing",
        "RNA-Seq",
        "User-Computer Interface" ;
    schema1:license "MIT" ;
    schema1:name "bioconductor-regsplice" ;
    schema1:url "http://bioconductor.org/packages/release/bioc/html/regsplice.html" .

