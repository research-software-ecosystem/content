@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-regsplice a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "L1-regularization based methods for detection of differential splicing" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/regsplice_1.32.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/regsplice/regsplice_1.32.0.tar.gz', 'https://bioarchive.galaxyproject.org/regsplice_1.32.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-regsplice/bioconductor-regsplice_1.32.0_src_all.tar.gz']" ;
    schema1:identifier biotools:regsplice ;
    schema1:license "MIT + file LICENSE" ;
    schema1:name "bioconductor-regsplice" ;
    schema1:softwareVersion "1.32.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/regsplice.html" ;
    spdx:builtFrom biotools:regsplice .

