@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:kfoots a schema1:SoftwareApplication ;
    schema1:description "The package provides methods for fitting multivariate count data with a mixture model or a hidden markov model. Each mixture component is a negative multivariate random variable and an EM algorithm is used to maximize the likelihood." ;
    schema1:license "GPL-2.0" ;
    schema1:name "kfoots" ;
    schema1:url "https://github.com/lamortenera/kfoots" .

