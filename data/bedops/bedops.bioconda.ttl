@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bedops a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/bts277" ;
    schema1:description "High-performance genomic feature operations." ;
    schema1:downloadUrl "https://github.com/bedops/bedops/archive/v2.4.42.tar.gz" ;
    schema1:identifier biotools:Bedops ;
    schema1:license "GPL-2.0-or-later" ;
    schema1:name "bedops" ;
    schema1:softwareHelp "https://bedops.readthedocs.io" ;
    schema1:softwareVersion "2.4.42" ;
    schema1:url "https://github.com/bedops/bedops" ;
    spdx:builtFrom biotools:Bedops .

