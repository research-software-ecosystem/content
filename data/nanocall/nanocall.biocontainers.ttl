@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:nanocall a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btw569" ;
    schema1:description "An Oxford Nanopore Basecaller" ;
    schema1:keywords "DNA",
        "Escherichia coli",
        "Humans",
        "Polymerase Chain Reaction",
        "Sequence Analysis, DNA" ;
    schema1:license "MIT" ;
    schema1:name "nanocall" ;
    schema1:url "https://github.com/mateidavid/nanocall" .

