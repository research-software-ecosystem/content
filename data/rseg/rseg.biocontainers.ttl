@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:rseg a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btq668" ;
    schema1:description "The rseg software package is used to analyze chip-seq data, especially for identifying genomic regions and their boundaries marked by diffusive histone modification markers, such as h3k36me3 and h3k27me3." ;
    schema1:identifier biotools:rseg ;
    schema1:keywords "DNA polymorphism",
        "Genetics",
        "Genomics",
        "Humans",
        "Neoplasms",
        "Oligonucleotide Array Sequence Analysis",
        "Oncology",
        "Polymorphism, Single Nucleotide" ;
    schema1:license "GPL-3.0" ;
    schema1:name "rseg" ;
    schema1:url "http://smithlabresearch.org/software/rseg" .

