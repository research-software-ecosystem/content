biocontainers:bioconductor-mspurity a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1021/acs.analchem.6b04358" ;
    schema1:description "Automated Evaluation of Precursor Ion Purity for Mass Spectrometry Based Fragmentation in Metabolomics'\"" ;
    schema1:identifier biotools:mspurity ;
    schema1:keywords "Automation",
        "Chromatography, High Pressure Liquid",
        "Ions",
        "Mass Spectrometry",
        "Mass spectrometry",
        "Metabolomics",
        "Proteomics",
        "Proteomics experiment",
        "Small molecules",
        "User-Computer Interface" ;
    schema1:license "GPL-2.0" ;
    schema1:name "bioconductor-mspurity" ;
    schema1:url "https://www.bioconductor.org/packages/release/bioc/html/msPurity.html" .

