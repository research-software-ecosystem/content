  "sc:description": "This tool can be used to remove facial features (\"defacing\") from DICOM images. It may be used 1) only for facial removing, or 2) for a complete import and anonymization using DICOM transfer. Defaced images needs to be manually quality checked, and this is done through a web interface  to a local server supplied with the Docker containers.",
  "sc:isAccessibleForFree": true,
  "sc:license": "Proprietary",
  "sc:name": "DICOM defacing anonymisation",
  "sc:operatingSystem": [
    "Mac",
    "Windows",
    "Linux"
  ],
  "sc:url": "https://www.dicom2usb.com"
