@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:dunovo a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nprot.2014.170" ;
    schema1:description "Du Novo: A pipeline for processing duplex sequencing data." ;
    schema1:keywords "DNA Mutational Analysis",
        "DNA, Mitochondrial",
        "Gene Library",
        "Genomics",
        "High-Throughput Nucleotide Sequencing",
        "Humans",
        "Mutation Rate",
        "Polymerase Chain Reaction",
        "Sequence Alignment",
        "Workflow" ;
    schema1:license "GPL-2.0" ;
    schema1:name "dunovo" ;
    schema1:url "https://github.com/galaxyproject/dunovo" .

