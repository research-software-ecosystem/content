@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-semdist a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Information Accretion-based Function Predictor Evaluation" ;
    schema1:identifier biotools:semdist ;
    schema1:keywords "Computational Biology",
        "Data quality management",
        "Gene Expression Profiling",
        "Genomics",
        "High-Throughput Screening Assays",
        "Ontology and terminology",
        "Programming Languages",
        "User-Computer Interface" ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-semdist" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/SemDist.html" .

