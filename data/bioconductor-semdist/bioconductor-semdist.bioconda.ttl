@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-semdist a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Information Accretion-based Function Predictor Evaluation" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/SemDist_1.40.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/SemDist/SemDist_1.40.0.tar.gz', 'https://bioarchive.galaxyproject.org/SemDist_1.40.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-semdist/bioconductor-semdist_1.40.0_src_all.tar.gz']" ;
    schema1:identifier biotools:semdist ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-semdist" ;
    schema1:softwareVersion "1.40.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/SemDist.html" ;
    spdx:builtFrom biotools:semdist .

