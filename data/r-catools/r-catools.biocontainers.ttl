@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-catools a schema1:SoftwareApplication ;
    schema1:description "Contains several basic utility functions including: moving (rolling, running) window statistic functions, read/write for GIF and ENVI binary files, fast calculation of AUC, LogitBoost classifier, base64 encoder/decoder, round-off-error-free sum and cumsum, etc." ;
    schema1:license "GPL-3" ;
    schema1:name "r-catools" ;
    schema1:url "None" .

