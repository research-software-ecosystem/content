@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-streamer a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Enabling stream processing of large files" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/Streamer_1.52.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/Streamer/Streamer_1.52.0.tar.gz', 'https://bioarchive.galaxyproject.org/Streamer_1.52.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-streamer/bioconductor-streamer_1.52.0_src_all.tar.gz']" ;
    schema1:identifier biotools:streamer ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-streamer" ;
    schema1:softwareVersion "1.52.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/Streamer.html" ;
    spdx:builtFrom biotools:streamer .

