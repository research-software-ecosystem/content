@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:extract_genome_region a schema1:SoftwareApplication ;
    schema1:description "Given a csv file of variable information defining the regions of interest, return a file that contains a fasta-formatted representation of these regions." ;
    schema1:license "BSD 2-Clause \"Simplified\" License" ;
    schema1:name "extract_genome_region" ;
    schema1:url "https://github.com/xguse/extract-genome-region" .

