@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:samstats a schema1:SoftwareApplication ;
    schema1:description "SAM file alignment statistics at the read level" ;
    schema1:license "MIT" ;
    schema1:name "samstats" ;
    schema1:url "https://github.com/kundajelab/SAMstats" .

