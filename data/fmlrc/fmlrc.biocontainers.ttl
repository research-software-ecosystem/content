@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:fmlrc a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s12859-018-2051-3" ;
    schema1:description "A long-read error correction tool using the multi-string Burrows Wheeler Transform" ;
    schema1:keywords "Databases, Genetic",
        "Genome, Fungal",
        "Saccharomyces cerevisiae",
        "Sequence Analysis, DNA" ;
    schema1:license "MIT" ;
    schema1:name "fmlrc" ;
    schema1:url "https://github.com/holtjma/fmlrc" .

