@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:novobreak a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.4084" ;
    schema1:description "local assembly for breakpoint detection in cancer genomes" ;
    schema1:keywords "Chromosome Breakpoints",
        "Computational Biology",
        "Genome, Human",
        "Genomics",
        "High-Throughput Nucleotide Sequencing",
        "Humans",
        "Mutation",
        "Neoplasms",
        "Sequence Analysis, DNA",
        "Tumor Cells, Cultured" ;
    schema1:license "MIT" ;
    schema1:name "novobreak" ;
    schema1:url "https://github.com/czc/nb_distribution" .

