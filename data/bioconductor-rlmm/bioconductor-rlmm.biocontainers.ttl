@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-rlmm a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/bti741" ;
    schema1:description "A Genotype Calling Algorithm for Affymetrix SNP Arrays" ;
    schema1:identifier biotools:rlmm ;
    schema1:keywords "Alleles",
        "Alternative Splicing",
        "Computational Biology",
        "DNA Mutational Analysis",
        "DNA polymorphism",
        "Gene Expression Profiling",
        "Gene Frequency",
        "Genotype",
        "Genotyping experiment",
        "Haplotypes",
        "Humans",
        "Models, Genetic",
        "Models, Statistical",
        "Normal Distribution",
        "Oligonucleotide Array Sequence Analysis",
        "Polymorphism, Single Nucleotide",
        "Regression Analysis",
        "Sequence Analysis, DNA" ;
    schema1:license "LGPL (>= 2)" ;
    schema1:name "bioconductor-rlmm" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/RLMM.html" .

