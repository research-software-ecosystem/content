@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-rlmm a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/bti741" ;
    schema1:description "A Genotype Calling Algorithm for Affymetrix SNP Arrays" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/RLMM_1.72.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/RLMM/RLMM_1.72.0.tar.gz', 'https://bioarchive.galaxyproject.org/RLMM_1.72.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-rlmm/bioconductor-rlmm_1.72.0_src_all.tar.gz']" ;
    schema1:identifier biotools:rlmm ;
    schema1:license "LGPL (>= 2)" ;
    schema1:name "bioconductor-rlmm" ;
    schema1:softwareVersion "1.72.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/RLMM.html" ;
    spdx:builtFrom biotools:rlmm .

