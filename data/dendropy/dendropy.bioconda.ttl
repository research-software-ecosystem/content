@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:dendropy a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btq228" ;
    schema1:description "A Python library for phylogenetics and phylogenetic computing: reading, writing, simulation, processing and manipulation of phylogenetic trees (phylogenies) and characters." ;
    schema1:downloadUrl "https://github.com/jeetsukumaran/DendroPy/archive/refs/tags/v5.0.8.tar.gz" ;
    schema1:identifier biotools:dendropy ;
    schema1:license "BSD-3-Clause" ;
    schema1:name "dendropy" ;
    schema1:softwareHelp "https://dendropy.org" ;
    schema1:softwareVersion "5.0.8" ;
    schema1:url "https://github.com/jeetsukumaran/DendroPy" ;
    spdx:builtFrom biotools:dendropy .

