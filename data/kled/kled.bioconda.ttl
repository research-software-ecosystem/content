@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:kled a schema1:SoftwareApplication ;
    schema1:author "CoREse" ;
    schema1:citation "doi:10.1093/bib/bbae049",
        "doi:10.3389/fgene.2024.1435087" ;
    schema1:description "An ultra-fast and sensitive structural variant detection tool for long-read sequencing data." ;
    schema1:downloadUrl "https://github.com/CoREse/kled/releases/download/v1.2.11/kledv1.2.11.allmodules.tar.gz" ;
    schema1:identifier biotools:kled ;
    schema1:license "MIT" ;
    schema1:maintainer "CoREse" ;
    schema1:name "kled" ;
    schema1:softwareHelp "https://github.com/CoREse/kled/blob/v1.2.11/README.md" ;
    schema1:softwareVersion "1.2.11" ;
    schema1:url "https://github.com/CoREse/kled" ;
    spdx:builtFrom biotools:kled .

