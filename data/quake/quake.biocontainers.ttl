@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:quake a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/gb-2010-11-11-r116" ;
    schema1:description "Quake is a package to correct substitution sequencing errors in experiments with deep coverage (e.g. >15X), specifically intended for Illumina sequencing reads" ;
    schema1:identifier biotools:quake ;
    schema1:keywords "Computational Biology",
        "DNA, Bacterial",
        "Escherichia coli",
        "Genome, Human",
        "Genomics",
        "Humans",
        "Likelihood Functions",
        "Models, Biological",
        "Polymorphism, Single Nucleotide",
        "Sequence Alignment",
        "Sequence Analysis, DNA",
        "Sequence analysis",
        "Sequencing",
        "Statistics and probability" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "quake" ;
    schema1:url "http://www.cbcb.umd.edu/software/quake/" .

