@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-occugene a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1007/978-1-59745-321-9_22" ;
    schema1:description "Functions for Multinomial Occupancy Distribution" ;
    schema1:identifier biotools:occugene ;
    schema1:keywords "Gene Library",
        "Genes, Bacterial",
        "Microbiology",
        "Model organisms",
        "Models, Statistical",
        "Mutagenesis",
        "Open Reading Frames",
        "Random Allocation" ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-occugene" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/occugene.html" .

