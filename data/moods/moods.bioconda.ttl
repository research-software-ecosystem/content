@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:moods a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1109/TCBB.2009.35" ;
    schema1:description "MOODS: Motif Occurrence Detection Suite" ;
    schema1:downloadUrl "https://pypi.io/packages/source/m/mira-moods/mira-moods-1.9.4.2.tar.gz" ;
    schema1:identifier biotools:MOODS ;
    schema1:license "GPL-3.0-or-later" ;
    schema1:name "moods" ;
    schema1:softwareHelp "https://github.com/jhkorhonen/MOODS/wiki" ;
    schema1:softwareVersion "1.9.4.2" ;
    schema1:url "https://www.cs.helsinki.fi/group/pssmfind" ;
    spdx:builtFrom biotools:MOODS .

