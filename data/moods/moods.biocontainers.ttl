@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:moods a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btp554",
        "doi:10.1093/bioinformatics/btw683",
        "doi:10.1109/TCBB.2009.35" ;
    schema1:description "MOODS, Motif Occurrence Detection Suite" ;
    schema1:identifier biotools:MOODS ;
    schema1:keywords "Base Sequence",
        "Computational Biology",
        "Mapping",
        "Position-Specific Scoring Matrices",
        "Sequence Analysis, DNA",
        "Sequence composition, complexity and repeats" ;
    schema1:license "GPL-3.0" ;
    schema1:name "moods" ;
    schema1:url "https://github.com/jhkorhonen/MOODS" .

