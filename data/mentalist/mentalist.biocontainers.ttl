@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:mentalist a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1099/mgen.0.000146" ;
    schema1:description "The MLST pipeline developed by the PathOGiST research group." ;
    schema1:identifier biotools:mentalist ;
    schema1:keywords "Bacteria",
        "Bacterial Typing Techniques",
        "Disease Outbreaks",
        "Enterococcus faecium",
        "Epidemiological Monitoring",
        "Foodborne Diseases",
        "Genes, Essential",
        "Genetic variation",
        "Genome, Bacterial",
        "Humans",
        "Molecular Epidemiology",
        "Multilocus Sequence Typing",
        "Mycobacterium tuberculosis",
        "Salmonella",
        "Time Factors",
        "Whole Genome Sequencing" ;
    schema1:license "MIT" ;
    schema1:name "mentalist" ;
    schema1:url "https://github.com/WGS-TB/MentaLiST" .

