@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:boxshade a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/gkg547" ;
    schema1:description "Program for creating printouts from multiple-aligned protein or dna sequences." ;
    schema1:identifier biotools:boxshade ;
    schema1:keywords "Databases, Protein",
        "Europe",
        "Gene transcripts",
        "Genomics",
        "Internet",
        "Proteins",
        "Proteomics",
        "Sequence Alignment",
        "Sequence Analysis, Protein",
        "Sequence analysis",
        "Sequence sites, features and motifs" ;
    schema1:license "public-domain-claim" ;
    schema1:name "boxshade" ;
    schema1:url "https://github.com/mdbaron42/pyBoxshade" .

