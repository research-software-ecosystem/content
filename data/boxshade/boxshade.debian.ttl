@prefix debianmed: <https://salsa.debian.org/med-team/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

debianmed:boxshade a schema1:SoftwareApplication ;
    schema1:description "Pretty-printing of multiple sequence alignments" ;
    schema1:identifier "bio.tools:BoxShade",
        "omictools:OMICS_19792",
        "scicrunch:SCR_007165" ;
    schema1:keywords "biology::format:aln",
        "biology::nuceleic-acids",
        "biology::peptidic",
        "field::biology",
        "field::biology:bioinformatics",
        "implemented-in::c",
        "interface::commandline",
        "role::program",
        "scope::utility",
        "use::typesetting",
        "works-with-format::html",
        "works-with-format::plaintext",
        "works-with-format::postscript",
        "works-with-format::tex",
        "works-with::TODO" ;
    schema1:license "unknown" ;
    schema1:name "boxshade" ;
    schema1:softwareVersion "3.3.1" ;
    schema1:url "http://www.ch.embnet.org/software/BOX_form.html" ;
    spdx:builtFrom "BoxShade" .

