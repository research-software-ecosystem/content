@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:e-pcr a schema1:SoftwareApplication ;
    schema1:description "e-PCR identifies sequence tagged sites(STSs) within DNA sequences.." ;
    schema1:license "GPL-2.0" ;
    schema1:name "e-pcr" ;
    schema1:url "http://www.ncbi.nlm.nih.gov/tools/epcr/" .

