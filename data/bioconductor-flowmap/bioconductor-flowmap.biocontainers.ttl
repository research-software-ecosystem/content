@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-flowmap a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1002/cyto.a.22735" ;
    schema1:description "Mapping cell populations in flow cytometry data for cross-sample comparisons using the Friedman-Rafsky Test" ;
    schema1:identifier biotools:flowmap ;
    schema1:keywords "Adaptor Proteins, Signal Transducing",
        "Biomarkers",
        "CD4 Antigens",
        "Cell biology",
        "Computational Biology",
        "Data Interpretation, Statistical",
        "Flow Cytometry",
        "Humans",
        "Leukocyte Common Antigens",
        "Phosphoproteins",
        "ZAP-70 Protein-Tyrosine Kinase" ;
    schema1:license "GPL (>=2)" ;
    schema1:name "bioconductor-flowmap" ;
    schema1:url "https://bioconductor.org/packages/release/bioc/html/flowMap.html" .

