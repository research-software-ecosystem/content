@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-flowmap a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1002/cyto.a.22735" ;
    schema1:description "Mapping cell populations in flow cytometry data for cross-sample comparisons using the Friedman-Rafsky Test" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.17/bioc/src/contrib/flowMap_1.38.0.tar.gz', 'https://bioconductor.org/packages/3.17/bioc/src/contrib/Archive/flowMap/flowMap_1.38.0.tar.gz', 'https://bioarchive.galaxyproject.org/flowMap_1.38.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-flowmap/bioconductor-flowmap_1.38.0_src_all.tar.gz']" ;
    schema1:identifier biotools:flowmap ;
    schema1:license "GPL (>=2)" ;
    schema1:name "bioconductor-flowmap" ;
    schema1:softwareVersion "1.38.0" ;
    schema1:url "https://bioconductor.org/packages/3.17/bioc/html/flowMap.html" ;
    spdx:builtFrom biotools:flowmap .

