@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-qsea a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/gkw1193" ;
    schema1:description "IP-seq data analysis and vizualization" ;
    schema1:identifier biotools:qsea ;
    schema1:keywords "Animals",
        "Bayes Theorem",
        "ChIP-seq",
        "DNA Methylation",
        "Data visualisation",
        "Gene Expression Regulation",
        "Genomics",
        "Humans",
        "Lung Neoplasms",
        "Mice",
        "Promoter Regions, Genetic",
        "Sequence Analysis, DNA",
        "Sequencing",
        "Sulfites",
        "Workflow" ;
    schema1:license "GPL (>=2)" ;
    schema1:name "bioconductor-qsea" ;
    schema1:url "http://bioconductor.org/packages/3.6/bioc/html/qsea.html" .

