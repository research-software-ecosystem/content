@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-qsea a schema1:SoftwareApplication ;
    schema1:description "IP-seq data analysis and vizualization" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/qsea_1.36.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/qsea/qsea_1.36.0.tar.gz', 'https://bioarchive.galaxyproject.org/qsea_1.36.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-qsea/bioconductor-qsea_1.36.0_src_all.tar.gz']" ;
    schema1:identifier biotools:qsea ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-qsea" ;
    schema1:softwareVersion "1.36.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/qsea.html" ;
    spdx:builtFrom biotools:qsea .

