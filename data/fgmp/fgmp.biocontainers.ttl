@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:fgmp a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1101/049619" ;
    schema1:description "Genome completeness assessment tool focused on fungi" ;
    schema1:identifier biotools:fgmp ;
    schema1:keywords "Comparative genomics",
        "Genomics",
        "Nucleic acid structure analysis",
        "Peptides",
        "Sequence assembly" ;
    schema1:license "MIT" ;
    schema1:name "fgmp" ;
    schema1:url "http://github.com/stajichlab/FGMP" .

