@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:fgmp a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1101/049619" ;
    schema1:description "FGMP: assessing fungal genome completeness and gene content." ;
    schema1:downloadUrl "https://github.com/stajichlab/FGMP/archive/ed86439.tar.gz" ;
    schema1:identifier biotools:fgmp ;
    schema1:license "MIT" ;
    schema1:name "fgmp" ;
    schema1:softwareVersion "1.0.3" ;
    schema1:url "https://github.com/stajichlab/FGMP" ;
    spdx:builtFrom biotools:fgmp .

