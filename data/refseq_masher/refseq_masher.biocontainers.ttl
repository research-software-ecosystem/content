@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:refseq_masher a schema1:SoftwareApplication ;
    schema1:description "Refseq_masher finds what ncbi refseq genomes match or are contained within your sequence data using mash" ;
    schema1:license "Apache-2.0" ;
    schema1:name "refseq_masher" ;
    schema1:url "https://github.com/phac-nml/refseq_masher" .

