@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:pretextgraph a schema1:SoftwareApplication ;
    schema1:description "Embeds bedgraph data into Pretext contact maps." ;
    schema1:license "MIT" ;
    schema1:name "pretextgraph" ;
