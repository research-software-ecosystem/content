@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:malder a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1073/pnas.1313787111" ;
    schema1:description "MALDER is a version of ALDER (http://groups.csail.mit.edu/cb/alder/) that has been modified to allow multiple admixture events." ;
    schema1:keywords "Africa, Eastern",
        "Africa, Southern",
        "Computer Simulation",
        "Demography",
        "Emigration and Immigration",
        "Ethnic Groups",
        "Europe",
        "European Continental Ancestry Group",
        "Gene Flow",
        "Gene Frequency",
        "Genetics, Population",
        "Genotype",
        "Humans",
        "Linkage Disequilibrium",
        "Models, Genetic" ;
    schema1:license "Custom OSS" ;
    schema1:name "malder" ;
    schema1:url "https://github.com/joepickrell/malder" .

