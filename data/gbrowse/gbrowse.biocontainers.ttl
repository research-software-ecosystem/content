@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:gbrowse a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1002/0471250953.bi0909s17" ;
    schema1:description "Combination of database and interactive web pages for manipulating and displaying annotations on genomes." ;
    schema1:identifier biotools:gbrowse ;
    schema1:keywords "Chromosome Mapping",
        "Computer Graphics",
        "Genomics",
        "Internet",
        "Sequence Analysis, DNA",
        "User-Computer Interface" ;
    schema1:license "GPL-1+ or Artistic-2.0" ;
    schema1:name "gbrowse" ;
    schema1:url "https://github.com/GMOD/GBrowse" .

