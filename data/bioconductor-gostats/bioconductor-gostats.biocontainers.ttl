@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-gostats a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btl567" ;
    schema1:description "A set of tools for interacting with go and microarray data. a variety of basic manipulation tools for graphs, hypothesis testing and other simple calculations." ;
    schema1:identifier biotools:gostats ;
    schema1:keywords "Data Interpretation, Statistical",
        "Data quality management",
        "Database Management Systems",
        "Databases, Protein",
        "Gene Expression Profiling",
        "Information Storage and Retrieval",
        "Natural Language Processing",
        "Ontology and terminology",
        "Proteins",
        "Terminology as Topic" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-gostats" ;
    schema1:url "http://bioconductor.org/packages/release/bioc/html/GOstats.html" .

