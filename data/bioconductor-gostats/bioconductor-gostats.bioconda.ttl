@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-gostats a schema1:SoftwareApplication ;
    schema1:description "Tools for manipulating GO and microarrays" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/GOstats_2.72.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/GOstats/GOstats_2.72.0.tar.gz', 'https://bioarchive.galaxyproject.org/GOstats_2.72.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-gostats/bioconductor-gostats_2.72.0_src_all.tar.gz']" ;
    schema1:identifier biotools:gostats ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-gostats" ;
    schema1:softwareVersion "2.72.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/GOstats.html" ;
    spdx:builtFrom biotools:gostats .

