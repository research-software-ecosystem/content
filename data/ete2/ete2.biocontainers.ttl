@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:ete2 a schema1:SoftwareApplication ;
    schema1:description "Phylogenetic tree analyses and exploration" ;
    schema1:keywords "Genetics",
        "Genomics",
        "Ortholog",
        "Phylogenetics",
        "Sequence Alignment" ;
    schema1:license "GPL-3" ;
    schema1:name "ete2" ;
    schema1:url "http://etetoolkit.org/" .

