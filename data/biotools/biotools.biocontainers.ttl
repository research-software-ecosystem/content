@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:biotools a schema1:SoftwareApplication ;
    schema1:description "Python3 bioinformatics utilities for high-throughput genomic sequencing" ;
    schema1:license "custom, see /usr/share/doc/biotools/copyright" ;
    schema1:name "biotools" ;
    schema1:url "https://github.com/sonwell/biotools" .

