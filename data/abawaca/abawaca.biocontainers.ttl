@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:abawaca a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nature14486" ;
    schema1:description "abawaca (A Binning Algorithm Without A Cool Acronym) is a binning program that can take advantage of different types of information such as differential coverage and DNA signature" ;
    schema1:keywords "Bacteria",
        "Environmental Microbiology",
        "Genome, Bacterial",
        "Genomics",
        "Introns",
        "Metagenomics",
        "Phylogeny",
        "RNA, Ribosomal, 16S",
        "Ribosomal Proteins" ;
    schema1:license "MIT" ;
    schema1:name "abawaca" ;
    schema1:url "https://github.com/CK7/abawaca" .

