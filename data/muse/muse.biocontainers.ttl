@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:muse a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s13059-016-1029-6" ;
    schema1:description "Somatic point mutation caller" ;
    schema1:keywords "Alleles",
        "Computational Biology",
        "Exome",
        "Genetic Heterogeneity",
        "Genetics",
        "High-Throughput Nucleotide Sequencing",
        "Humans",
        "Mutation",
        "Neoplasms",
        "Sensitivity and Specificity",
        "Sequence Alignment" ;
    schema1:license "https://github.com/danielfan/MuSE/blob/master/LICENSE" ;
    schema1:name "muse" ;
    schema1:url "http://bioinformatics.mdanderson.org/main/MuSE" .

