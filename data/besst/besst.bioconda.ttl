@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:besst a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/1471-2105-15-281" ;
    schema1:description "Scaffolder for genomic assemblies." ;
    schema1:downloadUrl "https://pypi.io/packages/source/B/BESST/BESST-2.2.8.tar.gz" ;
    schema1:identifier biotools:besst ;
    schema1:license "GPL-3.0" ;
    schema1:name "besst" ;
    schema1:softwareVersion "2.2.8" ;
    schema1:url "https://github.com/ksahlin/BESST" ;
    spdx:builtFrom biotools:besst .

