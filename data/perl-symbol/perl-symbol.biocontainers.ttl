@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:perl-symbol a schema1:SoftwareApplication ;
    schema1:description "Manipulate perl symbols and their names" ;
    schema1:license "perl_5" ;
    schema1:name "perl-symbol" ;
    schema1:url "http://metacpan.org/pod/Symbol" .

