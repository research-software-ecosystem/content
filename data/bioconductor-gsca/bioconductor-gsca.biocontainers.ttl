@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-gsca a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/gkv873" ;
    schema1:description "GSCA: Gene Set Context Analysis" ;
    schema1:identifier biotools:gsca ;
    schema1:keywords "Animals",
        "Computational Biology",
        "Databases, Nucleic Acid",
        "Datasets as Topic",
        "Gene Expression",
        "Gene Expression Profiling",
        "Gene expression",
        "Humans",
        "Molecular genetics" ;
    schema1:license "GPL(>=2)" ;
    schema1:name "bioconductor-gsca" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/GSCA.html" .

