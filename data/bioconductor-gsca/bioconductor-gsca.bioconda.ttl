@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-gsca a schema1:SoftwareApplication ;
    schema1:description "GSCA: Gene Set Context Analysis" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/GSCA_2.36.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/GSCA/GSCA_2.36.0.tar.gz', 'https://bioarchive.galaxyproject.org/GSCA_2.36.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-gsca/bioconductor-gsca_2.36.0_src_all.tar.gz']" ;
    schema1:identifier biotools:gsca ;
    schema1:license "GPL(>=2)" ;
    schema1:name "bioconductor-gsca" ;
    schema1:softwareVersion "2.36.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/GSCA.html" ;
    spdx:builtFrom biotools:gsca .

