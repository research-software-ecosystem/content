@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:nanofilt a schema1:SoftwareApplication ;
    schema1:description "Filtering and trimming of oxford nanopore sequencing data" ;
    schema1:license "GPL-3.0" ;
    schema1:name "nanofilt" ;
    schema1:url "https://github.com/wdecoster/nanofilt" .

