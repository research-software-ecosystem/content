@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:eosc-pilot a schema1:SoftwareApplication ;
    schema1:description "Science demonstrator project in the context of the eosc initiative aimed to explore the feasibility of data reproducibility and data re-mastering in genomics" ;
    schema1:license "MPL-2.0" ;
    schema1:name "eosc-pilot" ;
    schema1:url "https://github.com/CRG-CNAG/EOSC-Pilot" .

