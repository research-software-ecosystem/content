@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-genomicranges a schema1:SoftwareApplication ;
    schema1:description "Representation and manipulation of genomic intervals" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/GenomicRanges_1.62.1.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/GenomicRanges/GenomicRanges_1.62.1.tar.gz', 'https://bioarchive.galaxyproject.org/GenomicRanges_1.62.1.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-genomicranges/bioconductor-genomicranges_1.62.1_src_all.tar.gz']" ;
    schema1:identifier biotools:genomicranges ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-genomicranges" ;
    schema1:softwareVersion "1.62.1" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/GenomicRanges.html" ;
    spdx:builtFrom biotools:genomicranges .

