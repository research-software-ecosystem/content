@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:vispr a schema1:SoftwareApplication ;
    schema1:description "Vispr is a visualization framework and analysis workflow for crispr/cas9 knockout screens. vispr is designed to display results calculated by mageck." ;
    schema1:license "MIT" ;
    schema1:name "vispr" ;
    schema1:url "https://bitbucket.org/liulab/vispr" .

