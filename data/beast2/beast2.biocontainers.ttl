@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:beast2 a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1371/JOURNAL.PCBI.1003537" ;
    schema1:description "Beast 2 is a cross-platform program for bayesian phylogenetic analysis of molecular sequences." ;
    schema1:identifier biotools:beast2 ;
    schema1:keywords "Bayes Theorem",
        "Biological Evolution",
        "Genetics",
        "Phylogenetics",
        "Phylogenomics",
        "Programming Languages" ;
    schema1:license "LGPL (>= 2.1)" ;
    schema1:name "beast2" ;
    schema1:url "https://github.com/CompEvol/beast2" .

