@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:nlstradamus a schema1:SoftwareApplication ;
    schema1:description "NLStradamus: a simple Hidden Markov Model for nuclear localization signal prediction." ;
    schema1:downloadUrl "http://www.moseslab.csb.utoronto.ca/NLStradamus/NLStradamus/NLStradamus.1.8.tar.gz" ;
    schema1:identifier biotools:NLStradamus ;
    schema1:license "GNU General Public License v3 or later (GPLv3+)" ;
    schema1:name "nlstradamus" ;
    schema1:softwareVersion "1.8" ;
    schema1:url "http://www.moseslab.csb.utoronto.ca/NLStradamus/" ;
    spdx:builtFrom biotools:NLStradamus .

