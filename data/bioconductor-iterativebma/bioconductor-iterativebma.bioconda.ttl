@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-iterativebma a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/gb-2008-9-7-r118" ;
    schema1:description "The Iterative Bayesian Model Averaging (BMA) algorithm" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/iterativeBMA_1.64.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/iterativeBMA/iterativeBMA_1.64.0.tar.gz', 'https://bioarchive.galaxyproject.org/iterativeBMA_1.64.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-iterativebma/bioconductor-iterativebma_1.64.0_src_all.tar.gz']" ;
    schema1:identifier biotools:iterativebma ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-iterativebma" ;
    schema1:softwareVersion "1.64.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/iterativeBMA.html" ;
    spdx:builtFrom biotools:iterativebma .

