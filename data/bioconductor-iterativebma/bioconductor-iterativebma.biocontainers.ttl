@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-iterativebma a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/gb-2008-9-7-r118" ;
    schema1:description "The Iterative Bayesian Model Averaging (BMA) algorithm" ;
    schema1:identifier biotools:iterativebma ;
    schema1:keywords "Bayes Theorem",
        "Computer Graphics",
        "Gene Expression Profiling",
        "Gene expression",
        "Microarray experiment",
        "Oligonucleotide Array Sequence Analysis",
        "Systems Integration",
        "User-Computer Interface" ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-iterativebma" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/iterativeBMA.html" .

