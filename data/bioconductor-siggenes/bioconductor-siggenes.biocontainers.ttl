@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-siggenes a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/1471-2105-9-144" ;
    schema1:description "Multiple Testing using SAM and Efron's Empirical Bayes Approaches" ;
    schema1:identifier biotools:siggenes ;
    schema1:keywords "Artificial Intelligence",
        "Base Sequence",
        "Chromosome Mapping",
        "DNA",
        "DNA Mutational Analysis",
        "Gene expression",
        "Molecular Sequence Data",
        "Oligonucleotide Array Sequence Analysis",
        "Pattern Recognition, Automated",
        "Polymorphism, Single Nucleotide",
        "Sequence Alignment",
        "Sequence Analysis, DNA",
        "Statistics and probability" ;
    schema1:license "LGPL (>= 2)" ;
    schema1:name "bioconductor-siggenes" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/siggenes.html" .

