@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-siggenes a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/1471-2105-9-144" ;
    schema1:description "Multiple Testing using SAM and Efron's Empirical Bayes Approaches" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/siggenes_1.84.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/siggenes/siggenes_1.84.0.tar.gz', 'https://bioarchive.galaxyproject.org/siggenes_1.84.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-siggenes/bioconductor-siggenes_1.84.0_src_all.tar.gz']" ;
    schema1:identifier biotools:siggenes ;
    schema1:license "LGPL (>= 2)" ;
    schema1:name "bioconductor-siggenes" ;
    schema1:softwareVersion "1.84.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/siggenes.html" ;
    spdx:builtFrom biotools:siggenes .

