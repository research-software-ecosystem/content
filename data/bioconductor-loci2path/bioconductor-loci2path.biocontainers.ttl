biocontainers:bioconductor-loci2path a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18129/b9.bioc.loci2path" ;
    schema1:description "Loci2path: regulatory annotation of genomic intervals based on tissue-specific expression QTLs" ;
    schema1:keywords "Genetics",
        "Genomics" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-loci2path" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/loci2path.html" .

