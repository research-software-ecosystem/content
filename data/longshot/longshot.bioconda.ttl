@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:longshot a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/s41467-019-12493-y" ;
    schema1:description "Diploid SNV caller for error-prone reads." ;
    schema1:downloadUrl "https://github.com/pjedge/longshot/archive/v1.0.0.tar.gz" ;
    schema1:identifier biotools:longshot ;
    schema1:license "MIT" ;
    schema1:name "longshot" ;
    schema1:softwareHelp "https://github.com/pjedge/longshot/blob/v(( version }}/README.md" ;
    schema1:softwareVersion "1.0.0" ;
    schema1:url "https://github.com/pjedge/longshot" ;
    spdx:builtFrom biotools:longshot .

