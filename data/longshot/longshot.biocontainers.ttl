@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:longshot a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1101/564443" ;
    schema1:description "Longshot is a variant calling tool for diploid genomes using long error prone reads such as Pacific Biosciences (PacBio) SMRT and Oxford Nanopore Technologies (ONT)" ;
    schema1:license "MIT" ;
    schema1:name "longshot" ;
    schema1:url "https://github.com/pjedge/longshot" .

