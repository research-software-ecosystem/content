@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-purecn a schema1:SoftwareApplication ;
    schema1:description "Copy number calling and SNV classification using targeted short read sequencing" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/PureCN_2.16.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/PureCN/PureCN_2.16.0.tar.gz', 'https://bioarchive.galaxyproject.org/PureCN_2.16.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-purecn/bioconductor-purecn_2.16.0_src_all.tar.gz']" ;
    schema1:identifier biotools:purecn ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-purecn" ;
    schema1:softwareVersion "2.16.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/PureCN.html" ;
    spdx:builtFrom biotools:purecn .

