@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:hicup a schema1:SoftwareApplication ;
    schema1:citation "doi:10.12688/f1000research.7334.1" ;
    schema1:description "A mapping pipeline for hic interaction data. performs independent mapping on each end of the interaction pair and removes commonly found artefacts." ;
    schema1:identifier biotools:hicup ;
    schema1:keywords "Epigenomics" ;
    schema1:license "GPL-3.0" ;
    schema1:name "hicup" ;
    schema1:url "http://www.bioinformatics.babraham.ac.uk/projects/hicup/" .

