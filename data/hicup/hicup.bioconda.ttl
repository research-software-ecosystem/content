@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:hicup a schema1:SoftwareApplication ;
    schema1:citation "doi:10.12688/f1000research.7334.1" ;
    schema1:description "A tool for mapping and performing quality control on Hi-C data" ;
    schema1:downloadUrl "https://github.com/StevenWingett/HiCUP/archive/refs/tags/v0.9.2.tar.gz" ;
    schema1:identifier biotools:hicup ;
    schema1:license "GPLv3" ;
    schema1:name "hicup" ;
    schema1:softwareVersion "0.9.2" ;
    schema1:url "http://www.bioinformatics.babraham.ac.uk/projects/hicup/" ;
    spdx:builtFrom biotools:hicup .

