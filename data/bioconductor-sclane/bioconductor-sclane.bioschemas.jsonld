  "@graph": [
    {
      "@id": "https://bio.tools/bioconductor-sclane",
      "@type": "sc:SoftwareApplication",
      "dcterms:conformsTo": "https://bioschemas.org/profiles/ComputationalTool/0.6-DRAFT",
      "sc:additionalType": [
        "Command-line tool",
        "Library"
      ],
      "sc:author": "Jack R. Leary",
      "sc:citation": {
        "@id": "https://doi.org/10.1101/2023.12.19.572477"
      },
      "sc:contributor": "Rhonda Bacher",
      "sc:description": "Our scLANE model uses truncated power basis spline models to build flexible, interpretable models of single cell gene expression over pseudotime or latent time. The modeling architectures currently supported are Negative-binomial GLMs, GEEs, & GLMMs. Downstream analysis functionalities include model comparison, dynamic gene clustering, smoothed counts generation, gene set enrichment testing, & visualization.",
      "sc:license": "MIT",
      "sc:name": "scLANE",
      "sc:operatingSystem": [
        "Linux",
        "Windows",
        "Mac"
      ],
      "sc:softwareHelp": {
        "@id": "https://bioconductor.org/packages/scLANE"
      },
      "sc:softwareVersion": "1.0.4",
      "sc:url": "https://bioconductor.org/packages/scLANE"
    },
