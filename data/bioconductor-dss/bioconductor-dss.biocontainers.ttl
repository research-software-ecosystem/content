@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-dss a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btw026" ;
    schema1:description "Dispersion shrinkage for sequencing data" ;
    schema1:identifier biotools:dss ;
    schema1:keywords "DNA Methylation",
        "Epigenesis, Genetic",
        "Genome",
        "RNA-Seq",
        "RNA-seq",
        "Research Design",
        "Sequencing" ;
    schema1:license "GPL" ;
    schema1:name "bioconductor-dss" ;
    schema1:url "http://bioconductor.org/packages/3.6/bioc/html/DSS.html" .

