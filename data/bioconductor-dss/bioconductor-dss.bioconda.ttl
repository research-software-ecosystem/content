@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-dss a schema1:SoftwareApplication ;
    schema1:description "Dispersion shrinkage for sequencing data" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/DSS_2.58.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/DSS/DSS_2.58.0.tar.gz', 'https://bioarchive.galaxyproject.org/DSS_2.58.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-dss/bioconductor-dss_2.58.0_src_all.tar.gz']" ;
    schema1:identifier biotools:dss ;
    schema1:license "GPL" ;
    schema1:name "bioconductor-dss" ;
    schema1:softwareVersion "2.58.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/DSS.html" ;
    spdx:builtFrom biotools:dss .

