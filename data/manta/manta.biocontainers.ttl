@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:manta a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btv710" ;
    schema1:description "Structural variant and indel caller for mapped sequencing data" ;
    schema1:identifier biotools:Manta9235 ;
    schema1:keywords "DNA, Neoplasm",
        "Genome",
        "Genomics",
        "High-Throughput Nucleotide Sequencing",
        "Humans",
        "INDEL Mutation",
        "Neoplasms" ;
    schema1:license "GPL-3.0" ;
    schema1:name "manta" ;
    schema1:url "https://github.com/Illumina/manta" .

