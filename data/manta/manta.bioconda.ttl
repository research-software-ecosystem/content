@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:manta a schema1:SoftwareApplication ;
    schema1:description "Structural variant and indel caller for mapped sequencing data" ;
    schema1:downloadUrl "https://github.com/Illumina/manta/releases/download/v1.6.0/manta-1.6.0.release_src.tar.bz2" ;
    schema1:identifier biotools:Manta9235 ;
    schema1:license "GPL-3.0-only" ;
    schema1:name "manta" ;
    schema1:softwareVersion "1.6.0" ;
    schema1:url "https://github.com/Illumina/manta" ;
    spdx:builtFrom biotools:Manta9235 .

