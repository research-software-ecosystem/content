@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:perl-dbd-mysql a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/gkm964" ;
    schema1:description "A MySQL driver for the Perl5 Database Interface (DBI)." ;
    schema1:downloadUrl "https://cpan.metacpan.org/authors/id/D/DV/DVEEDEN/DBD-mysql-5.013.tar.gz" ;
    schema1:identifier biotools:dbd ;
    schema1:license "Perl_5" ;
    schema1:name "perl-dbd-mysql" ;
    schema1:softwareHelp "https://dbi.perl.org" ;
    schema1:softwareVersion "5.013" ;
    schema1:url "https://dbi.perl.org" ;
    spdx:builtFrom biotools:dbd .

