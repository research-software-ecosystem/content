biocontainers:r-hierfstat a schema1:SoftwareApplication ;
    schema1:citation "doi:10.2307/2411227" ;
    schema1:description "Allows the estimation of hierarchical F-statistics from haploid or diploid genetic data with any numbers of levels in the hierarchy" ;
