@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-metab a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btr379" ;
    schema1:description "Metab: An R Package for a High-Throughput Analysis of Metabolomics Data Generated by GC-MS." ;
    schema1:identifier biotools:metab ;
    schema1:keywords "Gas Chromatography-Mass Spectrometry",
        "Humans",
        "Mass spectra",
        "Metabolomics",
        "Molecular interactions, pathways and networks",
        "Systems biology" ;
    schema1:license "GPL (>=2)" ;
    schema1:name "bioconductor-metab" ;
    schema1:url "http://bioconductor.org/packages/3.6/bioc/html/Metab.html" .

