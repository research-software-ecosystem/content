@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-metab a schema1:SoftwareApplication ;
    schema1:description "Metab: An R Package for a High-Throughput Analysis of Metabolomics Data Generated by GC-MS." ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.17/bioc/src/contrib/Metab_1.33.0.tar.gz', 'https://bioconductor.org/packages/3.17/bioc/src/contrib/Archive/Metab/Metab_1.33.0.tar.gz', 'https://bioarchive.galaxyproject.org/Metab_1.33.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-metab/bioconductor-metab_1.33.0_src_all.tar.gz']" ;
    schema1:identifier biotools:metab ;
    schema1:license "GPL (>=2)" ;
    schema1:name "bioconductor-metab" ;
    schema1:softwareVersion "1.33.0" ;
    schema1:url "https://bioconductor.org/packages/3.17/bioc/html/Metab.html" ;
    spdx:builtFrom biotools:metab .

