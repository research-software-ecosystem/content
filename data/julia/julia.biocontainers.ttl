@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:julia a schema1:SoftwareApplication ;
    schema1:description "A high-performance dynamic programming language for data science" ;
    schema1:license "MIT" ;
    schema1:name "julia" ;
    schema1:url "https://github.com/JuliaLang/julia" .

