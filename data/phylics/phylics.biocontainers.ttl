@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:phylics a schema1:SoftwareApplication ;
    schema1:description "A tool to perform multi-sample Phylogenetic analysis of Single Cell CNV profiles" ;
    schema1:license "AGPLv3 / BSD 2-Clause" ;
    schema1:name "phylics" ;
    schema1:url "https://github.com/bioinformatics-polito/PhyliCS" .

