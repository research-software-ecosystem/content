@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:multiplierz a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1002/pmic.201700091",
        "doi:10.1038/nmeth0409-240",
        "doi:10.1074/mcp.M110.003970",
        "doi:10.1186/1471-2105-10-364" ;
    schema1:description "multiplierz is a Python software library and associated GUI desktop environment for managing proteomic mass spectrometry workflows and data analysis." ;
    schema1:identifier biotools:multiplierz ;
    schema1:keywords "Computational Biology",
        "Data Interpretation, Statistical",
        "Data visualisation",
        "Guidelines as Topic",
        "Humans",
        "Mass Spectrometry",
        "Mass spectrometry",
        "Peer Review, Research",
        "Periodicals as Topic",
        "Phosphoproteins",
        "Proteome",
        "Proteomics",
        "Proteomics experiment",
        "User-Computer Interface" ;
    schema1:license "GPL" ;
    schema1:name "multiplierz" ;
    schema1:url "https://github.com/BlaisProteomics/multiplierz" .

