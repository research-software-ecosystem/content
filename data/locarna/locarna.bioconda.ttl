@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:locarna a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1371/journal.pcbi.0030065" ;
    schema1:description "Multiple alignment of RNAs." ;
    schema1:downloadUrl "https://github.com/s-will/LocARNA/releases/download/v2.0.1/locarna-2.0.1.tar.gz" ;
    schema1:identifier biotools:locarna ;
    schema1:license "GPL-3.0-or-later" ;
    schema1:name "locarna" ;
    schema1:softwareHelp "https://s-will.github.io/LocARNA" ;
    schema1:softwareVersion "2.0.1" ;
    schema1:url "https://github.com/s-will/LocARNA" ;
    spdx:builtFrom biotools:locarna .

