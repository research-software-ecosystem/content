@prefix debianmed: <https://salsa.debian.org/med-team/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

debianmed:smrtanalysis a schema1:SoftwareApplication ;
    schema1:description "software suite for single molecule, real-time sequencing" ;
    schema1:identifier "bio.tools:SMRT_Analysis",
        "omictools:OMICS_05142",
        "scicrunch:SCR_002942" ;
    schema1:license "unknown" ;
    schema1:name "smrtanalysis" ;
    schema1:softwareVersion "0~20210112" ;
    schema1:url "https://www.pacb.com/products-and-services/analytical-software/smrt-analysis/" ;
    spdx:builtFrom "SMRT_Analysis" .

