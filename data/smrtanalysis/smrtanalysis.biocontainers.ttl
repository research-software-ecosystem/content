@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:smrtanalysis a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/2041-9414-2-10" ;
    schema1:description "Software suite for single molecule, real-time sequencing" ;
    schema1:identifier biotools:smrt_analysis ;
    schema1:keywords "DNA",
        "Data visualisation",
        "Genetics",
        "Genomics",
        "RNA-Seq",
        "Sequence Alignment",
        "Sequencing",
        "Transcriptome",
        "Whole genome sequencing" ;
    schema1:license "Custom License" ;
    schema1:name "smrtanalysis" ;
    schema1:url "http://www.pacb.com/products-and-services/analytical-software/smrt-analysis/" .

