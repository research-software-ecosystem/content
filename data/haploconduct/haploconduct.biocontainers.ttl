@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:haploconduct a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1101/378356",
        "doi:10.1101/gr.215038.116" ;
    schema1:description "HaploConduct is a package designed for reconstruction of individual haplotypes from next generation sequencing data, in particular Illumina. It provides two methods, SAVAGE and POLYTE, which can be run through the haploconduct wrapper." ;
    schema1:keywords "Contig Mapping",
        "Genome, Viral",
        "Genomics",
        "Haplotypes",
        "Hepacivirus",
        "Polymorphism, Genetic",
        "Reference Standards",
        "Sequence Analysis, DNA",
        "Zika Virus" ;
    schema1:license "GPL-3.0" ;
    schema1:name "haploconduct" ;
    schema1:url "https://github.com/HaploConduct/HaploConduct" .

