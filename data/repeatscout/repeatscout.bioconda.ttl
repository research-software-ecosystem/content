@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:repeatscout a schema1:SoftwareApplication ;
    schema1:description "De novo identification of repeat families in large genomes." ;
    schema1:downloadUrl "https://github.com/Dfam-consortium/RepeatScout/archive/refs/tags/v1.0.7.tar.gz" ;
    schema1:identifier biotools:RepeatScout ;
    schema1:license "CC0" ;
    schema1:name "repeatscout" ;
    schema1:softwareHelp "https://github.com/Dfam-consortium/RepeatScout/blob/v1.0.7/README.md" ;
    schema1:softwareVersion "1.0.7" ;
    schema1:url "https://github.com/Dfam-consortium/RepeatScout" ;
    spdx:builtFrom biotools:RepeatScout .

