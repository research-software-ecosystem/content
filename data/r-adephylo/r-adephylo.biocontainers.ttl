@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-adephylo a schema1:SoftwareApplication ;
    schema1:description "Multivariate tools to analyze comparative data, i.e. a phylogeny and some traits measured for each taxa." ;
    schema1:keywords "Genetics",
        "Phylogenetics" ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "r-adephylo" ;
    schema1:url "https://CRAN.R-project.org/package=adephylo" .

