@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:praat a schema1:SoftwareApplication ;
    schema1:description "Program for speech analysis and synthesis" ;
    schema1:license "GPL-2+" ;
    schema1:name "praat" ;
    schema1:url "http://www.praat.org" .

