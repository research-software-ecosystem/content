    schema1:identifier biotools:mgsa ;
    schema1:keywords "Animals",
        "Bayes Theorem",
        "Computer Simulation",
        "Drosophila melanogaster",
        "Gene expression",
        "Genes",
        "Genes, Fungal",
        "Genes, Insect",
        "Genetics",
        "Genomics",
        "Models, Genetic",
        "Saccharomyces" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-mgsa" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/mgsa.html" .

