@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-mgsa a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/gkq045" ;
    schema1:description "Model-based gene set analysis" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/mgsa_1.58.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/mgsa/mgsa_1.58.0.tar.gz', 'https://bioarchive.galaxyproject.org/mgsa_1.58.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-mgsa/bioconductor-mgsa_1.58.0_src_all.tar.gz']" ;
    schema1:identifier biotools:mgsa ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-mgsa" ;
    schema1:softwareVersion "1.58.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/mgsa.html" ;
    spdx:builtFrom biotools:mgsa .

