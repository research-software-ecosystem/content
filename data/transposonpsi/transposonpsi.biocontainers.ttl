@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:transposonpsi a schema1:SoftwareApplication ;
    schema1:description "Transposonpsi is an analysis tool to identify protein or nucleic acid sequence homology to proteins encoded by diverse families of transposable elements." ;
    schema1:keywords "Protein Sequences" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "transposonpsi" ;
    schema1:url "http://transposonpsi.sourceforge.net/" .

