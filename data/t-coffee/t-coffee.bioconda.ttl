@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:t-coffee a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1006/jmbi.2000.4042" ;
    schema1:description "A collection of tools for Multiple Alignments of DNA, RNA, Protein Sequence." ;
    schema1:downloadUrl "https://s3.eu-central-1.amazonaws.com/tcoffee-packages/Archives/T-COFFEE_distribution_Version_13.46.2.7c9e712d.tar.gz" ;
    schema1:identifier biotools:tcoffee ;
    schema1:license "GPL-2.0-only" ;
    schema1:name "t-coffee" ;
    schema1:softwareHelp "https://tcoffee.org/Projects/tcoffee/documentation/index.html" ;
    schema1:softwareVersion "13.46.2.7c9e712d" ;
    schema1:url "https://github.com/cbcrg/tcoffee" ;
    spdx:builtFrom biotools:tcoffee .

