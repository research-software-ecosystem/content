@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-qdnaseq a schema1:SoftwareApplication ;
    schema1:description "Quantitative DNA Sequencing for Chromosomal Aberrations" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/QDNAseq_1.42.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/QDNAseq/QDNAseq_1.42.0.tar.gz', 'https://bioarchive.galaxyproject.org/QDNAseq_1.42.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-qdnaseq/bioconductor-qdnaseq_1.42.0_src_all.tar.gz']" ;
    schema1:identifier biotools:qdnaseq ;
    schema1:license "GPL" ;
    schema1:name "bioconductor-qdnaseq" ;
    schema1:softwareVersion "1.42.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/QDNAseq.html" ;
    spdx:builtFrom biotools:qdnaseq .

