@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:deepvariant a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nbt.4235",
        "doi:10.1101/2020.02.10.942086" ;
    schema1:description "Deepvariant is an analysis pipeline that uses a deep neural network to call genetic variants from next-generation dna sequencing data" ;
    schema1:keywords "Genomics" ;
    schema1:license "MIT" ;
    schema1:name "deepvariant" ;
    schema1:url "https://github.com/google/deepvariant" .

