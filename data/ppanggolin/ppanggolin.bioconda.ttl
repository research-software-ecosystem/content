@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:ppanggolin a schema1:SoftwareApplication ;
    schema1:author "JeanMainguy",
        "axbazin",
        "jpjarnoux" ;
    schema1:citation "doi:10.1101/836239" ;
    schema1:description "PPanGGOLiN: Depicting microbial species diversity via a Partitioned PanGenome Graph." ;
    schema1:downloadUrl "https://github.com/labgem/PPanGGOLiN/archive/2.3.0.tar.gz" ;
    schema1:identifier biotools:PPanGGOLiN ;
    schema1:license "CeCiLL-2.1" ;
    schema1:maintainer "JeanMainguy",
        "axbazin",
        "jpjarnoux" ;
    schema1:name "ppanggolin" ;
    schema1:softwareHelp "https://ppanggolin.readthedocs.io" ;
    schema1:softwareVersion "2.3.0" ;
    schema1:url "https://github.com/labgem/PPanGGOLiN" ;
    spdx:builtFrom biotools:PPanGGOLiN .

