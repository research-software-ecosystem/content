@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-maxlik a schema1:SoftwareApplication ;
    schema1:description "Functions for Maximum Likelihood (ML) estimation and non-linear optimization, and related tools.  It includes a unified way to call different optimizers, and classes and methods to handle the results from the ML viewpoint.  It also includes a number of convenience tools for testing and developing your own models." ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "r-maxlik" ;
    schema1:url "http://www.maxLik.org" .

