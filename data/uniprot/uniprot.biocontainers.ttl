@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:uniprot a schema1:SoftwareApplication ;
    schema1:description "Retrieve protein sequence identifiers and metadata from http://uniprot.org" ;
    schema1:license "Not available" ;
    schema1:name "uniprot" ;
    schema1:url "http://github.com/boscoh/uniprot" .

