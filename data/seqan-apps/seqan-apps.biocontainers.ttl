@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:seqan-apps a schema1:SoftwareApplication ;
    schema1:description "C++ library for the analysis of biological sequences" ;
    schema1:keywords "Genomics" ;
    schema1:license "BSD-3-clause" ;
    schema1:name "seqan-apps" ;
    schema1:url "http://www.seqan.de/" .

