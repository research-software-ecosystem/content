@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-esetvis a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Visualizations of expressionSet Bioconductor object" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/esetVis_1.36.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/esetVis/esetVis_1.36.0.tar.gz', 'https://bioarchive.galaxyproject.org/esetVis_1.36.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-esetvis/bioconductor-esetvis_1.36.0_src_all.tar.gz']" ;
    schema1:identifier biotools:esetvis ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-esetvis" ;
    schema1:softwareVersion "1.36.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/esetVis.html" ;
    spdx:builtFrom biotools:esetvis .

