@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:proteinprophet a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1021/ac0341261" ;
    schema1:description "Validation of protein identifications by ms/ms and database searches." ;
    schema1:identifier biotools:proteinprophet ;
    schema1:keywords "Amino Acid Sequence",
        "Humans",
        "Mass Spectrometry",
        "Models, Statistical",
        "Molecular Sequence Data",
        "Peptides",
        "Proteins",
        "Proteomics",
        "Proteomics experiment",
        "Statistics and probability" ;
    schema1:license "GPL-2.0-only" ;
    schema1:name "proteinprophet" ;
    schema1:url "http://tools.proteomecenter.org/ProteinProphet.php" .

