@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:kraken2 a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/gb-2014-15-3-r46",
        "doi:10.1186/s13059-019-1891-0" ;
    schema1:description "Kraken2 is a system for assigning taxonomic labels to short DNA sequences, usually obtained through metagenomic studies." ;
    schema1:downloadUrl "https://github.com/DerrickWood/kraken2/archive/refs/tags/v2.17.1.tar.gz" ;
    schema1:identifier biotools:kraken2 ;
    schema1:license "GPL-3.0-or-later" ;
    schema1:name "kraken2" ;
    schema1:softwareHelp "https://github.com/DerrickWood/kraken2/blob/v2.17.1/docs/MANUAL.markdown" ;
    schema1:softwareVersion "2.17.1" ;
    schema1:url "https://ccb.jhu.edu/software/kraken2" ;
    spdx:builtFrom biotools:kraken2 .

