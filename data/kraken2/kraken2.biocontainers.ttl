@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:kraken2 a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1101/762302",
        "doi:10.1186/gb-2014-15-3-r46" ;
    schema1:description "Kraken2 is a system for assigning taxonomic labels to short DNA sequences, usually obtained through metagenomic studies." ;
    schema1:identifier biotools:kraken2 ;
    schema1:keywords "Archaea",
        "Bacteria",
        "Classification",
        "Humans",
        "Metagenome",
        "Metagenomics",
        "Sensitivity and Specificity",
        "Sequence Alignment",
        "Sequence Analysis, DNA",
        "Taxonomy" ;
    schema1:license "GPL-3.0" ;
    schema1:name "kraken2" ;
    schema1:url "https://github.com/DerrickWood/kraken2/wiki" .

