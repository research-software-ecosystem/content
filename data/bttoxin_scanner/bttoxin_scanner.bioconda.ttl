@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bttoxin_scanner a schema1:SoftwareApplication ;
    schema1:author "liaochenlanruo" ;
    schema1:description "A toxin exploration tool for Bacillus thuringiensis" ;
    schema1:downloadUrl "https://github.com/liaochenlanruo/BtToxin_scanner/archive/v2.0.1.tar.gz" ;
    schema1:identifier biotools:BtToxin_scanner ;
    schema1:license "GPLv3" ;
    schema1:maintainer "liaochenlanruo" ;
    schema1:name "bttoxin_scanner" ;
    schema1:softwareVersion "2.0.1" ;
    schema1:url "https://github.com/liaochenlanruo/BtToxin_scanner/blob/master/README.md" ;
    spdx:builtFrom biotools:BtToxin_scanner .

