@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-rankprod a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btl476" ;
    schema1:description "Rank Product method for identifying differentially expressed genes with application in meta-analysis" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/RankProd_3.36.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/RankProd/RankProd_3.36.0.tar.gz', 'https://bioarchive.galaxyproject.org/RankProd_3.36.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-rankprod/bioconductor-rankprod_3.36.0_src_all.tar.gz']" ;
    schema1:identifier biotools:rankprod ;
    schema1:license "file LICENSE" ;
    schema1:name "bioconductor-rankprod" ;
    schema1:softwareVersion "3.36.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/RankProd.html" ;
    spdx:builtFrom biotools:rankprod .

