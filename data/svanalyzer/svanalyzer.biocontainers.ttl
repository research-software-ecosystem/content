@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:svanalyzer a schema1:SoftwareApplication ;
    schema1:description "Svanalyzer: tools for the analysis of structural variation in genomes" ;
    schema1:license "CC0" ;
    schema1:name "svanalyzer" ;
    schema1:url "https://github.com/nhansen/SVanalyzer" .

