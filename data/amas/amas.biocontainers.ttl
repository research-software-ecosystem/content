@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:amas a schema1:SoftwareApplication ;
    schema1:citation "doi:10.7717/peerj.1660" ;
    schema1:description "Calculate various summary statistics on a multiple sequence alignment" ;
    schema1:identifier biotools:amas ;
    schema1:keywords "Phylogenetics",
        "Phylogenomics",
        "Protein Sequences",
        "Sequence Alignment",
        "Sequence analysis",
        "Statistics and probability" ;
    schema1:license "GPL-3.0" ;
    schema1:name "amas" ;
    schema1:url "https://github.com/marekborowiec/AMAS" .

