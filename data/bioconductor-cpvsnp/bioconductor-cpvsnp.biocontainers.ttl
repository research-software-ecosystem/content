@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-cpvsnp a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Gene set analysis methods for SNP association p-values that lie in genes in given gene sets" ;
    schema1:identifier biotools:cpvsnp ;
    schema1:keywords "Computational Biology",
        "DNA polymorphism",
        "Gene Expression Profiling",
        "Genetic variation",
        "Genetics",
        "Genomics",
        "High-Throughput Screening Assays",
        "Programming Languages",
        "User-Computer Interface" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-cpvsnp" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/cpvSNP.html" .

