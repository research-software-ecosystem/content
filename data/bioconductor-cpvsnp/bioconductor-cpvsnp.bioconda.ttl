@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-cpvsnp a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Gene set analysis methods for SNP association p-values that lie in genes in given gene sets" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/cpvSNP_1.42.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/cpvSNP/cpvSNP_1.42.0.tar.gz', 'https://bioarchive.galaxyproject.org/cpvSNP_1.42.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-cpvsnp/bioconductor-cpvsnp_1.42.0_src_all.tar.gz']" ;
    schema1:identifier biotools:cpvsnp ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-cpvsnp" ;
    schema1:softwareVersion "1.42.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/cpvSNP.html" ;
    spdx:builtFrom biotools:cpvsnp .

