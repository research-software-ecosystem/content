@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:phame a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/s41598-020-58356-1" ;
    schema1:description "A tool to derive SNP matrices and phylogenetic tree from raw reads, contigs, and full genomes." ;
    schema1:identifier biotools:phame ;
    schema1:keywords "Sequence Alignment" ;
    schema1:license "GPL-2.0" ;
    schema1:name "phame" ;
    schema1:url "https://github.com/LANL-Bioinformatics/PhaME" .

