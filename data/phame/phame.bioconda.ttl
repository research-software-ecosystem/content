@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:phame a schema1:SoftwareApplication ;
    schema1:description "A tool to derive SNP matrices and phylogenetic tree from raw reads, contigs, and full genomes." ;
    schema1:downloadUrl "https://github.com/mshakya/phame/archive/1.0.3.tar.gz" ;
    schema1:identifier biotools:phame ;
    schema1:license "GPLV2" ;
    schema1:name "phame" ;
    schema1:softwareVersion "1.0.3" ;
    schema1:url "https://github.com/LANL-Bioinformatics/PhaME" ;
    spdx:builtFrom biotools:phame .

