@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-hopach a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Hierarchical Ordered Partitioning and Collapsing Hybrid (HOPACH)" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/hopach_2.70.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/hopach/hopach_2.70.0.tar.gz', 'https://bioarchive.galaxyproject.org/hopach_2.70.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-hopach/bioconductor-hopach_2.70.0_src_all.tar.gz']" ;
    schema1:identifier biotools:hopach ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-hopach" ;
    schema1:softwareVersion "2.70.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/hopach.html" ;
    spdx:builtFrom biotools:hopach .

