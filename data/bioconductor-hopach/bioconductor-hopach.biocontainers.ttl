@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-hopach a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Hierarchical Ordered Partitioning and Collapsing Hybrid (HOPACH)" ;
    schema1:identifier biotools:hopach ;
    schema1:keywords "Clustering",
        "Computational Biology",
        "Data architecture, analysis and design",
        "Data management",
        "Gene Expression Profiling",
        "Genomics",
        "High-Throughput Screening Assays",
        "Programming Languages",
        "User-Computer Interface" ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-hopach" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/hopach.html" .

