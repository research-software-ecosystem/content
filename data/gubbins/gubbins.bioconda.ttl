@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:gubbins a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/gku1196" ;
    schema1:description "Rapid phylogenetic analysis of large samples of recombinant bacterial whole genome sequences using Gubbins." ;
    schema1:downloadUrl "https://github.com/nickjcroucher/gubbins/archive/refs/tags/v3.4.3.tar.gz" ;
    schema1:identifier biotools:gubbins ;
    schema1:license "GPL-2.0-or-later" ;
    schema1:name "gubbins" ;
    schema1:softwareHelp "https://nickjcroucher.github.io/gubbins" ;
    schema1:softwareVersion "3.4.3" ;
    schema1:url "https://github.com/nickjcroucher/gubbins" ;
    spdx:builtFrom biotools:gubbins .

