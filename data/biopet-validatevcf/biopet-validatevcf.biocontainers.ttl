@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:biopet-validatevcf a schema1:SoftwareApplication ;
    schema1:description "Validatevcf validates a vcf file against a reference genomes." ;
