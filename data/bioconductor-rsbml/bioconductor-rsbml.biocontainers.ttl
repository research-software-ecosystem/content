@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-rsbml a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18129/b9.bioc.rsbml" ;
    schema1:description "Links R to libsbml for SBML parsing, validating output, provides an S4 SBML DOM, converts SBML to R graph objects. Optionally links to the SBML ODE Solver Library (SOSLib) for simulating models." ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-rsbml" ;
    schema1:url "https://bioconductor.org/packages/3.12/bioc/html/rsbml.html" .

