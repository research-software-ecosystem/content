@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:micall-lite a schema1:SoftwareApplication ;
    schema1:description "A bioinformatic pipeline for mapping of FASTQ data to a set of reference sequences to generate consensus sequences, variant calls and coverage maps." ;
    schema1:license "GNU Affero General Public License v3.0" ;
    schema1:name "micall-lite" ;
    schema1:url "https://github.com/PoonLab/MiCall-Lite" .

