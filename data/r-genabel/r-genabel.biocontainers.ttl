@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-genabel a schema1:SoftwareApplication ;
    schema1:description "A package for genome-wide association analysis between quantitative or binary traits and single-nucleotide polymorphisms (SNPs). " ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "r-genabel" ;
    schema1:url "http://www.genabel.org" .

