@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:biophi a schema1:SoftwareApplication ;
    schema1:description "BioPhi open-source antibody design platform." ;
    schema1:downloadUrl "https://github.com/Merck/BioPhi/archive/v1.0.11.tar.gz" ;
    schema1:identifier biotools:biophi ;
    schema1:license "MIT" ;
    schema1:name "biophi" ;
    schema1:softwareHelp "https://biophi.dichlab.org" ;
    schema1:softwareVersion "1.0.11" ;
    schema1:url "https://github.com/Merck/BioPhi" ;
    spdx:builtFrom biotools:biophi .

