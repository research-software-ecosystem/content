@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bcbio-nextgen a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btv061" ;
    schema1:description "Python scripts and modules for automated next gen sequencing analysis. these provide a fully automated pipeline for taking sequencing results from an illumina sequencer, converting them to standard fastq format, aligning to a reference genome, doing snp calling, and producing a summary pdf of results." ;
    schema1:identifier biotools:bcbio-nextgen ;
    schema1:keywords "Breast Neoplasms",
        "Cluster Analysis",
        "Databases, Factual",
        "Exome",
        "Female",
        "Genetics",
        "Genomics",
        "High-Throughput Nucleotide Sequencing",
        "Humans",
        "RNA-Seq",
        "Reproducibility of Results",
        "Sequence Analysis, RNA",
        "Transcriptome",
        "Workflows" ;
    schema1:license "MIT" ;
    schema1:name "bcbio-nextgen" ;
    schema1:url "https://github.com/chapmanb/bcbio-nextgen" .

