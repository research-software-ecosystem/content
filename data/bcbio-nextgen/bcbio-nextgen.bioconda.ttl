@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bcbio-nextgen a schema1:SoftwareApplication ;
    schema1:description "Validated, scalable, community developed variant calling, RNA-seq and small RNA analysis" ;
    schema1:downloadUrl "https://github.com/bcbio/bcbio-nextgen/archive/refs/tags/v1.2.9.tar.gz" ;
    schema1:identifier biotools:bcbio-nextgen ;
    schema1:license "MIT" ;
    schema1:name "bcbio-nextgen" ;
    schema1:softwareVersion "1.2.9" ;
    schema1:url "https://github.com/bcbio/bcbio-nextgen" ;
    spdx:builtFrom biotools:bcbio-nextgen .

