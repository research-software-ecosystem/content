@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:shovill-se a schema1:SoftwareApplication ;
    schema1:description "An fork of shovill (microbial assembly pipeline for illumina paired-end reads) that supports single-end reads." ;
    schema1:keywords "Metagenome",
        "Whole genome sequencing" ;
    schema1:license "Not available" ;
    schema1:name "shovill-se" ;
    schema1:url "https://github.com/rpetit3/shovill" .

