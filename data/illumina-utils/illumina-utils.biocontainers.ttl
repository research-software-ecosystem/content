@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:illumina-utils a schema1:SoftwareApplication ;
    schema1:description "A library and collection of scripts to work with Illumina paired-end data (for CASAVA 1.8+)." ;
    schema1:license "GPL-3.0" ;
    schema1:name "illumina-utils" ;
    schema1:url "https://github.com/meren/illumina-utils" .

