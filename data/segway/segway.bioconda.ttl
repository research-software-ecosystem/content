@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:segway a schema1:SoftwareApplication ;
    schema1:author "ericr86" ;
    schema1:citation "doi:10.1093/bioinformatics/btx603" ;
    schema1:description "A tool for easy pattern discovery and identification in functional genomics data." ;
    schema1:downloadUrl "https://pypi.org/packages/source/s/segway/segway-3.0.5.tar.gz" ;
    schema1:identifier biotools:segway ;
    schema1:license "GPL-2.0-or-later" ;
    schema1:maintainer "ericr86" ;
    schema1:name "segway" ;
    schema1:softwareHelp "https://segway.readthedocs.io/en/latest" ;
    schema1:softwareVersion "3.0.5" ;
    schema1:url "https://segway.hoffmanlab.org" ;
    spdx:builtFrom biotools:segway .

