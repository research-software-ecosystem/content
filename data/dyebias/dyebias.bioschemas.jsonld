    {
      "@id": "https://bio.tools/dyebias",
      "@type": "sc:SoftwareApplication",
      "dcterms:conformsTo": "https://bioschemas.org/profiles/ComputationalTool/0.6-DRAFT",
      "sc:additionalType": [
        "Command-line tool",
        "Library"
      ],
      "sc:applicationSubCategory": {
        "@id": "edam:topic_3518"
      },
      "sc:citation": {
        "@id": "https://doi.org/10.1038/msb.2009.21"
      },
      "sc:description": "Many two-colour hybridizations suffer from a dye bias that is both gene-specific and slide-specific. The former depends on the content of the nucleotide used for labeling; the latter depends on the labeling percentage. The slide-dependency was hitherto not recognized, and made addressing the artefact impossible.  Given a reasonable number of dye-swapped pairs of hybridizations, or of same vs. same hybridizations, both the gene- and slide-biases can be estimated and corrected using the GASSCO method (Margaritis et al., Mol. Sys. Biol. 5:266 (2009), doi:10.1038/msb.2009.21)",
      "sc:featureList": {
        "@id": "edam:operation_0314"
      },
      "sc:license": "GPL-3.0-only",
      "sc:name": "dyebias",
      "sc:operatingSystem": [
        "Mac",
        "Windows",
        "Linux"
      ],
      "sc:softwareHelp": {
        "@id": "https://bioconductor.org/packages/dyebias"
      },
      "sc:softwareVersion": "1.70.0",
      "sc:url": "https://bioconductor.org/packages/dyebias"
    }
