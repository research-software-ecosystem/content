@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:pacbio_falcon a schema1:SoftwareApplication ;
    schema1:description "a set of tools for fast aligning long reads for consensus and assembly." ;
    schema1:license "Standard PacBio Open Source License" ;
    schema1:name "pacbio_falcon" ;
    schema1:url "https://github.com/PacificBiosciences/FALCON" .

