@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:damidseq_pipeline a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btv386" ;
    schema1:description "An automated pipeline for processing damid sequencing datasets" ;
    schema1:identifier biotools:damidseq_pipeline ;
    schema1:keywords "Binding Sites",
        "ChIP-seq",
        "DNA-Binding Proteins",
        "High-Throughput Nucleotide Sequencing",
        "Microarray experiment",
        "Sequence Alignment",
        "Sequence Analysis, DNA",
        "Workflows" ;
    schema1:license "GNU General Public License v2.0" ;
    schema1:name "damidseq_pipeline" ;
    schema1:url "https://github.com/owenjm/damidseq_pipeline" .

