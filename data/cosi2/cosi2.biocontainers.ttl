@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:cosi2 a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btu562" ;
    schema1:description "Cosi2 is an efficient coalescent simulator with support for selection, population structure, variable recombination rates, and gene conversion. It supports exact and approximate simulation modes." ;
    schema1:keywords "Genetics" ;
    schema1:license "GPL-3.0" ;
    schema1:name "cosi2" ;
    schema1:url "https://www.broadinstitute.org/mpg/cosi2/" .

