@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:extract-codon-alignment a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btp163" ;
    schema1:description "To extract some codon positions (1st, 2nd, 3rd) from a cds alignment." ;
    schema1:license "GPL-3.0" ;
    schema1:name "extract-codon-alignment" ;
    schema1:url "https://github.com/linzhi2013/extract_codon_alignment" .

