@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:minimap a schema1:SoftwareApplication ;
    schema1:description "Tool for approximate mapping of long biosequences such as dna reads" ;
    schema1:keywords "Clustering" ;
    schema1:license "MIT" ;
    schema1:name "minimap" ;
    schema1:url "https://github.com/lh3/minimap" .

