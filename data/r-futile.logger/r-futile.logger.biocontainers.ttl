@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-futile.logger a schema1:SoftwareApplication ;
    schema1:description "Provides a simple yet powerful logging utility. Based loosely on log4j, futile.logger takes advantage of R idioms to make logging a convenient and easy to use replacement for cat and print statements." ;
    schema1:license "LGPL-3" ;
    schema1:name "r-futile.logger" ;
    schema1:url "None" .

