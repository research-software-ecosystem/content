@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-ngscopy a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18129/b9.bioc.ngscopy" ;
    schema1:description "NGScopy provides a quantitative caller for detecting copy number variations in next generation sequencing (NGS), including whole genome sequencing (WGS), whole exome sequencing (WES) and targeted panel sequencing (TPS). The caller can be parallelized by chromosomes to use multiple processors/cores on one computer." ;
    schema1:keywords "Whole genome sequencing" ;
    schema1:license "GPL (>=2)" ;
    schema1:name "bioconductor-ngscopy" ;
    schema1:url "https://bioconductor.org/packages/3.8/bioc/html/NGScopy.html" .

