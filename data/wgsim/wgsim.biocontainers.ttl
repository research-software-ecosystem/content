@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:wgsim a schema1:SoftwareApplication ;
    schema1:description "Wgsim is a small tool for simulating sequence reads from a reference genome." ;
    schema1:keywords "Genomics" ;
    schema1:license "MIT" ;
    schema1:name "wgsim" ;
    schema1:url "https://github.com/lh3/wgsim" .

