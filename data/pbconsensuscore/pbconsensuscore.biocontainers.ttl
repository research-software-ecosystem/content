@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:pbconsensuscore a schema1:SoftwareApplication ;
    schema1:description "Algorithms for pacbio multiple sequence consensus -- python 3" ;
    schema1:license "PacBio-BSD-3-Clause" ;
    schema1:name "pbconsensuscore" ;
    schema1:url "https://github.com/PacificBiosciences/ConsensusCore" .

