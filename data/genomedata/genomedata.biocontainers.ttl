@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:genomedata a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btq164" ;
    schema1:description "Tools for accessing large amounts of genomic data" ;
    schema1:identifier biotools:genomedata ;
    schema1:keywords "Data management",
        "Databases, Genetic",
        "Genome",
        "Genomics",
        "Sequence analysis" ;
    schema1:license "GPL-2.0" ;
    schema1:name "genomedata" ;
    schema1:url "https://bitbucket.org/hoffmanlab/genomedata/" .

