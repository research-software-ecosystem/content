@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:genomedata a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btq164" ;
    schema1:description "Tools for accessing large amounts of genomic data." ;
    schema1:downloadUrl "https://pypi.org/packages/source/g/genomedata/genomedata-1.7.4.tar.gz" ;
    schema1:identifier biotools:genomedata ;
    schema1:license "GPL-2.0-or-later" ;
    schema1:name "genomedata" ;
    schema1:softwareHelp "https://genomedata.readthedocs.io/en/latest" ;
    schema1:softwareVersion "1.7.4" ;
    schema1:url "http://genomedata.hoffmanlab.org" ;
    spdx:builtFrom biotools:genomedata .

