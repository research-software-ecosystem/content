@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:lcmsmatching a schema1:SoftwareApplication ;
    schema1:description "Annotation of MS peaks using matching on a spectra database." ;
    schema1:keywords "Mass Spectrometry",
        "Metabolomics",
        "Proteomics" ;
    schema1:license "MIT" ;
    schema1:name "lcmsmatching" ;
    schema1:url "https://github.com/phnmnl/container-lcmsmatching" .

