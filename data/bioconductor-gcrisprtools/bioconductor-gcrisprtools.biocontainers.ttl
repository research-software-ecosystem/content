@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-gcrisprtools a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Set of tools for evaluating pooled high-throughput screening experiments, typically employing crispr/cas9 or shrna expression cassettes. contains methods for interrogating library and cassette behavior within an experiment, identifying differentially abundant cassettes, aggregating signals to identify candidate targets for empirical validation, hypothesis testing, and comprehensive reporting." ;
    schema1:identifier biotools:gcrisprtools ;
    schema1:keywords "Compound libraries and screening",
        "Computational Biology",
        "Gene Expression Profiling",
        "Genetics",
        "Genomics",
        "High-Throughput Screening Assays",
        "Programming Languages",
        "User-Computer Interface" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-gcrisprtools" ;
    schema1:url "http://bioconductor.org/packages/release/bioc/html/gCrisprTools.html" .

