@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-gcrisprtools a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Suite of Functions for Pooled Crispr Screen QC and Analysis" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/gCrisprTools_2.16.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/gCrisprTools/gCrisprTools_2.16.0.tar.gz', 'https://bioarchive.galaxyproject.org/gCrisprTools_2.16.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-gcrisprtools/bioconductor-gcrisprtools_2.16.0_src_all.tar.gz']" ;
    schema1:identifier biotools:gcrisprtools ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-gcrisprtools" ;
    schema1:softwareVersion "2.16.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/gCrisprTools.html" ;
    spdx:builtFrom biotools:gcrisprtools .

