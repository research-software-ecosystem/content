@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-gam a schema1:SoftwareApplication ;
    schema1:description "Functions for fitting and working with generalized additive models, as described in chapter 7 of \"Statistical Models in S\" (Chambers and Hastie (eds), 1991), and \"Generalized Additive Models\" (Hastie and Tibshirani, 1990)." ;
    schema1:license "GPL-2" ;
    schema1:name "r-gam" ;
    schema1:url "https://cran.r-project.org/package=gam" .

