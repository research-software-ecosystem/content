@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-prebs a schema1:SoftwareApplication ;
    schema1:description "Probe region expression estimation for RNA-seq data for improved microarray comparability" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/prebs_1.46.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/prebs/prebs_1.46.0.tar.gz', 'https://bioarchive.galaxyproject.org/prebs_1.46.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-prebs/bioconductor-prebs_1.46.0_src_all.tar.gz']" ;
    schema1:identifier biotools:prebs ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-prebs" ;
    schema1:softwareVersion "1.46.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/prebs.html" ;
    spdx:builtFrom biotools:prebs .

