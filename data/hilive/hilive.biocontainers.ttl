@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:hilive a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btw659" ;
    schema1:description "Realtime alignment of illumina reads" ;
    schema1:keywords "Genome, Human",
        "High-Throughput Nucleotide Sequencing",
        "Humans",
        "Sequence Analysis, RNA",
        "Transcriptome" ;
    schema1:license "BSD-3-clause" ;
    schema1:name "hilive" ;
    schema1:url "https://gitlab.com/SimonHTausch/HiLive" .

