@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:stream a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btn467" ;
    schema1:description "STREAM Single-cell Trajectories Reconstruction, Exploration And Mapping of single-cell data http://stream.pinellolab.org" ;
    schema1:identifier biotools:stream ;
    schema1:keywords "Binding Sites",
        "Computational Biology",
        "Databases, Genetic",
        "Gene Expression Profiling",
        "Gene Expression Regulation",
        "Gene expression",
        "Gene regulation",
        "Gene transcripts",
        "Molecular interactions, pathways and networks",
        "RNA-Seq",
        "Thermodynamics",
        "Transcription Factors",
        "Transcription factors and regulatory sites",
        "Transcription, Genetic" ;
    schema1:license "AGPL-3" ;
    schema1:name "stream" ;
    schema1:url "https://github.com/pinellolab/STREAM" .

