@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:snp-pileup a schema1:SoftwareApplication ;
    schema1:description "Compute SNP pileup at reference positions in one or more input bam files. Output is ready for the R package facets" ;
    schema1:license "MIT" ;
    schema1:name "snp-pileup" ;
    schema1:url "https://github.com/mskcc/facets" .

