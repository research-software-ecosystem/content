@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:paraclu a schema1:SoftwareApplication ;
    schema1:description "Paraclu finds clusters in data attached to sequences." ;
    schema1:downloadUrl "https://gitlab.com/mcfrith/paraclu/-/archive/10/paraclu-10.tar.gz" ;
    schema1:identifier biotools:paraclu ;
    schema1:license "GPL-3.0-or-later" ;
    schema1:name "paraclu" ;
    schema1:softwareVersion "10" ;
    schema1:url "https://gitlab.com/mcfrith/paraclu" ;
    spdx:builtFrom biotools:paraclu .

