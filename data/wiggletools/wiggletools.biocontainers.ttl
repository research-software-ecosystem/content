@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:wiggletools a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btt737" ;
    schema1:description "The WiggleTools package allows genomewide data files to be manipulated as numerical functions," ;
    schema1:keywords "Genome",
        "Genomic Library",
        "Genomics",
        "High-Throughput Nucleotide Sequencing",
        "Internet" ;
    schema1:license "Apache" ;
    schema1:name "wiggletools" ;
    schema1:url "https://github.com/Ensembl/WiggleTools" .

