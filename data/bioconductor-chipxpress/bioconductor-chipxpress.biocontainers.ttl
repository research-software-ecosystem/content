@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-chipxpress a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18129/b9.bioc.chipxpress" ;
    schema1:description "ChIPXpress: enhanced transcription factor target gene identification from ChIP-seq and ChIP-chip data using publicly available gene expression profiles" ;
    schema1:keywords "Gene Expression" ;
    schema1:license "GPL(>=2)" ;
    schema1:name "bioconductor-chipxpress" ;
    schema1:url "http://bioconductor.org/packages/3.6/bioc/html/ChIPXpress.html" .

