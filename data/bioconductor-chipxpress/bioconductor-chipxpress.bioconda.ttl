@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-chipxpress a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/1471-2105-14-188" ;
    schema1:description "ChIPXpress: enhanced transcription factor target gene identification from ChIP-seq and ChIP-chip data using publicly available gene expression profiles" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/ChIPXpress_1.54.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/ChIPXpress/ChIPXpress_1.54.0.tar.gz', 'https://bioarchive.galaxyproject.org/ChIPXpress_1.54.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-chipxpress/bioconductor-chipxpress_1.54.0_src_all.tar.gz']" ;
    schema1:identifier biotools:chipxpress ;
    schema1:license "GPL(>=2)" ;
    schema1:name "bioconductor-chipxpress" ;
    schema1:softwareVersion "1.54.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/ChIPXpress.html" ;
    spdx:builtFrom biotools:chipxpress .

