@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:clark a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s12864-015-1419-2" ;
    schema1:description "Fast, accurate and versatile k-mer based classification system." ;
    schema1:downloadUrl "https://github.com/rouni001/CLARK/archive/refs/tags/v1.3.0.0.tar.gz" ;
    schema1:identifier biotools:clark ;
    schema1:license "GPL-3.0-or-later" ;
    schema1:name "clark" ;
    schema1:softwareHelp "http://clark.cs.ucr.edu" ;
    schema1:softwareVersion "1.3.0.0" ;
    schema1:url "https://github.com/rouni001/CLARK" ;
    spdx:builtFrom biotools:clark .

