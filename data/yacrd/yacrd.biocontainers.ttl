@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:yacrd a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btaa262" ;
    schema1:description "Yet Another Chimeric Read Detector, with long-read mapper result as input." ;
    schema1:keywords "High-Throughput Nucleotide Sequencing",
        "Sequence Analysis, DNA" ;
    schema1:license "MIT" ;
    schema1:name "yacrd" ;
    schema1:url "https://github.com/natir/yacrd" .

