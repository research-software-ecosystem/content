@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:necat a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/s41467-020-20236-7" ;
    schema1:description "NECAT is an error correction and de-novo assembly tool for Nanopore long noisy reads." ;
    schema1:downloadUrl "https://github.com/xiaochuanle/NECAT/archive/v0.0.1_update20200803.tar.gz" ;
    schema1:identifier biotools:necat ;
    schema1:license "Unknown" ;
    schema1:name "necat" ;
    schema1:softwareHelp "https://github.com/xiaochuanle/NECAT/blob/master/README.md" ;
    schema1:softwareVersion "0.0.1_update20200803" ;
    schema1:url "https://github.com/xiaochuanle/NECAT" ;
    spdx:builtFrom biotools:necat .

