@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:gotree a schema1:SoftwareApplication ;
    schema1:description "gotree is a set of command line tools to manipulate phylogenetic trees" ;
    schema1:license "GPL-2.0" ;
    schema1:name "gotree" ;
    schema1:url "https://github.com/evolbioinfo/gotree" .

