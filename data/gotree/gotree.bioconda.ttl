@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:gotree a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nargab/lqab075" ;
    schema1:description "gotree is a set of command line tools to manipulate phylogenetic trees." ;
    schema1:downloadUrl "https://github.com/evolbioinfo/gotree/archive/v0.5.1.tar.gz" ;
    schema1:identifier biotools:gotree ;
    schema1:license "GPL-2.0-or-later" ;
    schema1:name "gotree" ;
    schema1:softwareHelp "https://github.com/evolbioinfo/gotree/blob/v0.5.1/README.md" ;
    schema1:softwareVersion "0.5.1" ;
    schema1:url "https://github.com/evolbioinfo/gotree" ;
    spdx:builtFrom biotools:gotree .

