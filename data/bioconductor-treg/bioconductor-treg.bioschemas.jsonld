        {
          "@id": "https://doi.org/10.18129/B9.bioc.TREG"
        }
      ],
      "sc:contributor": "Leonardo Collado-Torres",
      "sc:description": "RNA abundance and cell size parameters could improve RNA-seq deconvolution algorithms to more accurately estimate cell type proportions given the different cell type transcription activity levels. A Total RNA Expression Gene (TREG) can facilitate estimating total RNA content using single molecule fluorescent in situ hybridization (smFISH). We developed a data-driven approach using a measure of expression invariance to find candidate TREGs in postmortem human brain single nucleus RNA-seq. This R package implements the method for identifying candidate TREGs from snRNA-seq data.",
      "sc:license": "Artistic-2.0",
      "sc:name": "TREG",
      "sc:operatingSystem": [
        "Mac",
        "Windows",
        "Linux"
      ],
      "sc:softwareHelp": {
        "@id": "https://bioconductor.org/packages/TREG"
      },
      "sc:softwareVersion": "1.14.0",
      "sc:url": "https://bioconductor.org/packages/TREG"
    }
