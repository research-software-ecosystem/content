@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-seqsqc a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18129/b9.bioc.seqsqc" ;
    schema1:description "A bioconductor package for sample quality check with next generation sequencing data" ;
    schema1:license "GPL-3.0" ;
    schema1:name "bioconductor-seqsqc" ;
    schema1:url "https://www.bioconductor.org/packages/release/bioc/html/SeqSQC.html" .

