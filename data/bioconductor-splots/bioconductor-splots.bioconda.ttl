@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-splots a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Visualization of high-throughput assays in microtitre plate or slide format" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/splots_1.76.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/splots/splots_1.76.0.tar.gz', 'https://bioarchive.galaxyproject.org/splots_1.76.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-splots/bioconductor-splots_1.76.0_src_all.tar.gz']" ;
    schema1:identifier biotools:splots ;
    schema1:license "LGPL" ;
    schema1:name "bioconductor-splots" ;
    schema1:softwareVersion "1.76.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/splots.html" ;
    spdx:builtFrom biotools:splots .

