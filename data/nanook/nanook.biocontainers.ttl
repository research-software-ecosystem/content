@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:nanook a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btv540" ;
    schema1:description "A tool for comprehensive analysis of oxford nanopore minion sequence data." ;
    schema1:identifier biotools:nanook ;
    schema1:keywords "Base Sequence",
        "Data Accuracy",
        "Escherichia coli K12",
        "Genomics",
        "Nanopores",
        "Nucleic acids",
        "Sequence Alignment",
        "Sequence Analysis, DNA",
        "Sequence analysis" ;
    schema1:license "GPL-3.0" ;
    schema1:name "nanook" ;
    schema1:url "https://github.com/TGAC/NanoOK" .

