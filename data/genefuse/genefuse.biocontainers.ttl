    schema1:description "Gene fusion detection and visualization" ;
    schema1:keywords "Gene Fusion",
        "High-Throughput Nucleotide Sequencing",
        "Humans",
        "Sequence Analysis, DNA",
        "Sequence Analysis, RNA" ;
    schema1:license "MIT" ;
    schema1:name "genefuse" ;
    schema1:url "https://github.com/OpenGene/genefuse" .

