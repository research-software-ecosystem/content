@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:mustang a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1002/prot.20921" ;
    schema1:description "Mustang is a program that implements an algorithm for structural alignment of multiple protein structures." ;
    schema1:downloadUrl "https://lcb.infotech.monash.edu.au/mustang/mustang_v3.2.4.tgz" ;
    schema1:identifier biotools:mustang ;
    schema1:license "file" ;
    schema1:name "mustang" ;
    schema1:softwareHelp "https://lcb.infotech.monash.edu.au/mustang" ;
    schema1:softwareVersion "3.2.4" ;
    schema1:url "https://lcb.infotech.monash.edu.au/mustang" ;
    spdx:builtFrom biotools:mustang .

