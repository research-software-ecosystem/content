@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:atac a schema1:SoftwareApplication ;
    schema1:description "ATAC is a computational process for comparative mapping between two genome assemblies, or between two different genomes." ;
    schema1:downloadUrl "http://sourceforge.net/projects/kmer/files/ATAC-r2008.tar.bz2" ;
    schema1:identifier biotools:atac ;
    schema1:license "GPL-3.0-or-later" ;
    schema1:name "atac" ;
    schema1:softwareVersion "2008" ;
    schema1:url "https://sourceforge.net/projects/kmer" ;
    spdx:builtFrom biotools:atac .

