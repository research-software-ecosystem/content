@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:atac a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1073/pnas.0307971100" ;
    schema1:description "Genome assembly-to-assembly comparison" ;
    schema1:identifier biotools:atac ;
    schema1:keywords "Computational Biology",
        "Contig Mapping",
        "DNA",
        "Genome, Human",
        "Human Genome Project",
        "Humans",
        "Mapping",
        "RNA, Messenger",
        "Sequence analysis" ;
    schema1:license "GPL-2+" ;
    schema1:name "atac" ;
    schema1:url "http://kmer.sourceforge.net" .

