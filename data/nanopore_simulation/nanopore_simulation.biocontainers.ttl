@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:nanopore_simulation a schema1:SoftwareApplication ;
    schema1:description "Nanopore SimulatION is a tool for simulating an Oxfornd Nanopore Technologies MinION device for bioinformatic development." ;
    schema1:license "MPL-2.0" ;
    schema1:name "nanopore_simulation" ;
    schema1:url "https://github.com/crohrandt/nanopore_simulation" .

