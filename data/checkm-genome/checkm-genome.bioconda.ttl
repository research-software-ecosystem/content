@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:checkm-genome a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1101/gr.186072.114" ;
    schema1:description "Assess the quality of microbial genomes recovered from isolates, single cells, and metagenomes." ;
    schema1:downloadUrl "https://github.com/Ecogenomics/CheckM/archive/v1.2.5.tar.gz" ;
    schema1:identifier biotools:checkm ;
    schema1:license "GPL-3.0-or-later" ;
    schema1:name "checkm-genome" ;
    schema1:softwareHelp "https://ecogenomics.github.io/CheckM" ;
    schema1:softwareVersion "1.2.5" ;
    schema1:url "https://github.com/Ecogenomics/CheckM" ;
    spdx:builtFrom biotools:checkm .

