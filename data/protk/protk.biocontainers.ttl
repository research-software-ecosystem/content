@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:protk a schema1:SoftwareApplication ;
    schema1:description "Protk is a suite of tools for proteomics. It aims to present a simple and consistent command-line interface across otherwise disparate third party tools." ;
    schema1:identifier biotools:protk ;
    schema1:keywords "Genomics",
        "Peptides",
        "Proteomics" ;
    schema1:license "MIT" ;
    schema1:name "protk" ;
    schema1:url "https://github.com/iracooke/protk" .

