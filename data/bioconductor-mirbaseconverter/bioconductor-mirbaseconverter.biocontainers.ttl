@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-mirbaseconverter a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18129/b9.bioc.mirbaseconverter" ;
    schema1:description "A comprehensive and high-efficiency tool for converting and retrieving the information of miRNAs in different miRBase versions" ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-mirbaseconverter" ;
    schema1:url "https://bioconductor.org/packages/3.8/bioc/html/miRBaseConverter.html" .

