@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:unicycler a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1371/JOURNAL.PCBI.1005595" ;
    schema1:description "A tool for assembling bacterial genomes from a combination of short (2nd generation) and long (3rd generation) sequencing reads." ;
    schema1:identifier biotools:unicycler ;
    schema1:keywords "Chromosome Mapping",
        "Genome, Bacterial",
        "Genomics",
        "High-Throughput Nucleotide Sequencing",
        "Metagenome",
        "Microbiology",
        "Sequence Alignment",
        "Sequence Analysis, DNA",
        "Sequence assembly",
        "Sequencing",
        "User-Computer Interface" ;
    schema1:license "GPL-3.0" ;
    schema1:name "unicycler" ;
    schema1:url "https://github.com/rrwick/Unicycler" .

