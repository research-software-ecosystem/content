@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:unicycler a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1371/journal.pcbi.1005595" ;
    schema1:description "Hybrid assembly pipeline for bacterial genomes." ;
    schema1:downloadUrl "https://github.com/rrwick/Unicycler/archive/v0.5.1.tar.gz" ;
    schema1:identifier biotools:unicycler ;
    schema1:license "GPL-3.0-or-later" ;
    schema1:name "unicycler" ;
    schema1:softwareHelp "https://github.com/rrwick/Unicycler/wiki" ;
    schema1:softwareVersion "0.5.1" ;
    schema1:url "https://github.com/rrwick/Unicycler" ;
    spdx:builtFrom biotools:unicycler .

