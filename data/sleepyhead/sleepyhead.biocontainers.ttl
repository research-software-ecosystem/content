@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:sleepyhead a schema1:SoftwareApplication ;
    schema1:description "Sleep tracking software with a focus on monitoring cpap treatment" ;
    schema1:license "GPL-3" ;
    schema1:name "sleepyhead" ;
    schema1:url "https://gitlab.com/sleepyhead/sleepyhead-code" .

