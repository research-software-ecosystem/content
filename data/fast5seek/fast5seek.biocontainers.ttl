@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:fast5seek a schema1:SoftwareApplication ;
    schema1:description "Get paths for fast5 files contained in bam, sam, or fastq." ;
    schema1:license "MIT" ;
    schema1:name "fast5seek" ;
    schema1:url "https://github.com/mbhall88/fast5seek" .

