@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:fqtools a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btw088" ;
    schema1:description "An efficient fastq manipulation suite." ;
    schema1:identifier biotools:fqtools ;
    schema1:keywords "Sequence analysis" ;
    schema1:license "GPL-3.0" ;
    schema1:name "fqtools" ;
    schema1:url "https://github.com/alastair-droop/fqtools" .

