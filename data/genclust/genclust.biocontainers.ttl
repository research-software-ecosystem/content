@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:genclust a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/1471-2105-6-289" ;
    schema1:description "A genetic algorithm for clustering gene expression data." ;
    schema1:identifier biotools:genclust ;
    schema1:keywords "Cluster Analysis",
        "Computational Biology",
        "DNA",
        "DNA, Complementary",
        "Gene Expression Profiling",
        "Gene Expression Regulation",
        "Gene expression",
        "Genetics",
        "Models, Statistical",
        "Mutation",
        "Oligonucleotide Array Sequence Analysis",
        "Oligonucleotides",
        "Open Reading Frames",
        "Pattern Recognition, Automated",
        "Sequence Alignment" ;
    schema1:license "GPL" ;
    schema1:name "genclust" ;
    schema1:url "http://www.math.unipa.it/~lobosco/genclust/" .

