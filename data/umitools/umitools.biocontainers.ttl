@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:umitools a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s12864-018-4933-1" ;
    schema1:description "A toolset for handling sequencing data with unique molecular identifiers (umis)" ;
    schema1:keywords "Animals",
        "Gene Library",
        "Genomics",
        "Male",
        "Mice",
        "Polymerase Chain Reaction",
        "RNA",
        "RNA-Seq",
        "Reproducibility of Results",
        "Sequence Analysis, RNA",
        "Testis" ;
    schema1:license "MIT" ;
    schema1:name "umitools" ;
    schema1:url "https://github.com/weng-lab/umitools" .

