    schema1:description "Soft clustering of time series gene expression data" ;
    schema1:keywords "Clustering",
        "Gene Expression" ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-mfuzz" ;
    schema1:url "https://bioconductor.org/packages/3.8/bioc/html/Mfuzz.html" .

