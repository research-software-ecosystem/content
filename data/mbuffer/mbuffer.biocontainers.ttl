@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:mbuffer a schema1:SoftwareApplication ;
    schema1:description "Mbuffer is a tool for buffering data streams with a large set of unique features" ;
    schema1:license "GPL-3.0" ;
    schema1:name "mbuffer" ;
    schema1:url "http://www.maier-komor.de/mbuffer.html" .

