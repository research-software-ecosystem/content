@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:tandem a schema1:SoftwareApplication ;
    schema1:citation "doi:xtandem" ;
    schema1:description "Matches tandem mass spectra with peptide sequences." ;
    schema1:keywords "Mass spectra",
        "Mass spectrometry",
        "Peptides",
        "Protein Sequences",
        "Proteomics" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "tandem" ;
    schema1:url "http://www.thegpm.org/TANDEM/" .

