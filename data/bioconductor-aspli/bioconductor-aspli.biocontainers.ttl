@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-aspli a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Analysis of alternative splicing using RNA-Seq" ;
    schema1:identifier biotools:aspli ;
    schema1:keywords "Computational Biology",
        "Gene Expression Profiling",
        "Genomics",
        "High-Throughput Screening Assays",
        "Programming Languages",
        "RNA splicing",
        "RNA-Seq",
        "User-Computer Interface" ;
    schema1:license "GPL" ;
    schema1:name "bioconductor-aspli" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/ASpli.html" .

