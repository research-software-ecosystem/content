@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-aspli a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Analysis of Alternative Splicing Using RNA-Seq" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/ASpli_2.16.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/ASpli/ASpli_2.16.0.tar.gz', 'https://bioarchive.galaxyproject.org/ASpli_2.16.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-aspli/bioconductor-aspli_2.16.0_src_all.tar.gz']" ;
    schema1:identifier biotools:aspli ;
    schema1:license "GPL" ;
    schema1:name "bioconductor-aspli" ;
    schema1:softwareVersion "2.16.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/ASpli.html" ;
    spdx:builtFrom biotools:aspli .

