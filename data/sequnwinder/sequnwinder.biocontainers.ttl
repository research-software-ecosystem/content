@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:sequnwinder a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btx271" ;
    schema1:description "Sequnwinder is a framework for characterizing class-discriminative motifs in a collection of genomic loci that have several (overlapping) annotation labels." ;
    schema1:keywords "Chromosomes, Human",
        "Genome, Human",
        "Genomics",
        "Humans",
        "Models, Molecular",
        "Molecular Conformation",
        "Sequence Analysis, DNA" ;
    schema1:license "Not available" ;
    schema1:name "sequnwinder" ;
    schema1:url "http://mahonylab.org/software/sequnwinder/" .

