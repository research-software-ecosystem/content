@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:fitgcp a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btt147" ;
    schema1:description "Fitting genome coverage distributions with mixture models" ;
    schema1:keywords "Bacteria",
        "Gastrointestinal Tract",
        "Genome",
        "Genome, Bacterial",
        "Genomics",
        "Humans",
        "Metagenomics",
        "Probability",
        "Sequence Alignment",
        "Sequence Analysis, DNA" ;
    schema1:license "BSDlike" ;
    schema1:name "fitgcp" ;
    schema1:url "http://sourceforge.net/projects/fitgcp/" .

