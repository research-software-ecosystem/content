  "@graph": [
    {
      "@id": "https://bio.tools/bioconductor-rnaagecalc",
      "@type": "sc:SoftwareApplication",
      "dcterms:conformsTo": "https://bioschemas.org/profiles/ComputationalTool/0.6-DRAFT",
      "sc:additionalType": [
        "Command-line tool",
        "Library"
      ],
      "sc:author": [
        "Xu Ren",
        "Pei Fen Kuan"
      ],
      "sc:citation": {
        "@id": "https://doi.org/10.1371/journal.pone.0237006"
      },
      "sc:description": "It has been shown that both DNA methylation and RNA transcription are linked to chronological age and age related diseases. Several estimators have been developed to predict human aging from DNA level and RNA level. Most of the human transcriptional age predictor are based on microarray data and limited to only a few tissues. To date, transcriptional studies on aging using RNASeq data from different human tissues is limited. The aim of this package is to provide a tool for across-tissue and tissue-specific transcriptional age calculation based on GTEx RNASeq data.",
      "sc:license": "GPL-2.0-only",
      "sc:name": "RNAAgeCalc",
      "sc:operatingSystem": [
        "Windows",
        "Linux",
        "Mac"
      ],
      "sc:softwareHelp": {
        "@id": "https://bioconductor.org/packages/RNAAgeCalc"
      },
      "sc:softwareVersion": "1.22.0",
      "sc:url": "https://bioconductor.org/packages/RNAAgeCalc"
    },
    {
      "@id": "https://doi.org/10.1371/journal.pone.0237006",
      "@type": "sc:CreativeWork"
    }
  ]
