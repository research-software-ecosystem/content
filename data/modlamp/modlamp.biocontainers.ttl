@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:modlamp a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btx285" ;
    schema1:description "Python package for in silico peptide design and qsar studies" ;
    schema1:identifier biotools:modlamp ;
    schema1:keywords "Anti-Infective Agents",
        "Computational Biology",
        "Data visualisation",
        "Immunoproteins, genes and antigens",
        "Machine Learning",
        "Microbiology",
        "Peptides",
        "Protein properties" ;
    schema1:license "BSD 3-Clause License" ;
    schema1:name "modlamp" ;
    schema1:url "https://github.com/alexarnimueller/modlamp" .

