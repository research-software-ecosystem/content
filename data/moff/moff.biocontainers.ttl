@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:moff a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1021/acs.jproteome.8b00708",
        "doi:10.1038/nmeth.4075" ;
    schema1:description "moFF is an OS independent tool designed to extract apex MS1 intensity using a set of identified MS2 peptides." ;
    schema1:identifier biotools:moff ;
    schema1:keywords "Data Analysis",
        "Data Interpretation, Statistical",
        "Peptides",
        "Proteomics" ;
    schema1:license "Apache-2.0" ;
    schema1:name "moff" ;
    schema1:url "https://github.com/compomics/moFF" .

