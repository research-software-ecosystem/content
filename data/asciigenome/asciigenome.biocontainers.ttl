@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:asciigenome a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btx007" ;
    schema1:description "Command-line genome browser running from terminal window and solely based on ascii characters" ;
    schema1:keywords "Genome",
        "Genomics",
        "Sequence Analysis, DNA" ;
    schema1:license "MIT" ;
    schema1:name "asciigenome" ;
    schema1:url "https://github.com/dariober/ASCIIGenome" .

