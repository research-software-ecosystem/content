@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-synapter a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1021/pr300775k" ;
    schema1:description "Label-free data analysis pipeline for optimal identification and quantitation" ;
    schema1:identifier biotools:synapter ;
    schema1:keywords "Amino Acid Sequence",
        "Animals",
        "Cattle",
        "Chickens",
        "Horses",
        "Humans",
        "Ions",
        "Molecular Sequence Data",
        "Peptide Fragments",
        "Proteins",
        "Proteomics",
        "Proteomics experiment",
        "Sensitivity and Specificity",
        "Spectrometry, Mass, Electrospray Ionization" ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-synapter" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/synapter.html" .

