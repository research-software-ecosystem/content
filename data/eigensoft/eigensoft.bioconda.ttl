@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:eigensoft a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1371/journal.pgen.0020190" ;
    schema1:description "The EIGENSOFT package implements methods for analzing population structure and performing stratification correction" ;
    schema1:downloadUrl "https://github.com/DReichLab/EIG/archive/v8.0.0.tar.gz" ;
    schema1:identifier biotools:Eigensoft ;
    schema1:license "Custom OSS" ;
    schema1:name "eigensoft" ;
    schema1:softwareVersion "8.0.0" ;
    schema1:url "https://github.com/DReichLab/EIG" ;
    spdx:builtFrom biotools:Eigensoft .

