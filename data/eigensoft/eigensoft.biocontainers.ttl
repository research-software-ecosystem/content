@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:eigensoft a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1371/journal.pgen.0020190" ;
    schema1:description "Combindes functionality from population genetics methods (patterson et al. 2006) and the eigenstrat correection method (price et al. 2006). the eigenstrat methods uses principal component analysis to model ancestry differences between cases and controls along continuous axes of variation. the resulting correction is specific to a candidate markers variation in frequency across ancestral populations, minimizing spurious associations while maximising power to detect true associations." ;
    schema1:identifier biotools:Eigensoft ;
    schema1:keywords "Computer Simulation",
        "Gene Expression",
        "Genetic Markers",
        "Genetic Variation",
        "Genetics",
        "Genetics, Medical",
        "Genetics, Population",
        "Humans",
        "Models, Genetic",
        "Models, Statistical",
        "Population genetics",
        "Principal Component Analysis" ;
    schema1:license "BSD-3-Clause" ;
    schema1:name "eigensoft" ;
    schema1:url "https://www.hsph.harvard.edu/alkes-price/software/" .

