@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:msisensor a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btt755" ;
    schema1:description "MSIsensor is a C++ program to detect replication slippage variants at microsatellite regions, and differentiate them as somatic or germline." ;
    schema1:identifier biotools:msisensor ;
    schema1:keywords "Automation, Laboratory",
        "DNA",
        "Genetic variation",
        "Genome, Human",
        "Genomics",
        "Humans",
        "Microsatellite Instability",
        "Neoplasms",
        "Oncology",
        "Polymerase Chain Reaction",
        "Proteomics",
        "Sequence Analysis, DNA",
        "Whole genome sequencing" ;
    schema1:license "MIT" ;
    schema1:name "msisensor" ;
    schema1:url "https://github.com/ding-lab/msisensor" .

