@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:ribominer a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s12859-020-03670-8" ;
    schema1:description "A python toolset for mining multi-dimensional features of the translatome with ribosome profiling data" ;
    schema1:keywords "Ribosome",
        "Transcriptome" ;
    schema1:license "GPL-3.0" ;
    schema1:name "ribominer" ;
    schema1:url "https://github.com/xryanglab/RiboMiner" .

