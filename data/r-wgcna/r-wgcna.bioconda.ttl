@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:r-wgcna a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/1471-2105-9-559" ;
    schema1:description "Functions necessary to perform Weighted Correlation Network Analysis on high-dimensional data as originally described in Horvath and Zhang (2005) <doi:10.2202/1544-6115.1128> and Langfelder and Horvath (2008) <doi:10.1186/1471-2105-9-559>. Includes functions for rudimentary data cleaning, construction of correlation networks, module identification, summarization, and relating of variables and modules to sample traits. Also includes a number of utility functions for data manipulation and visualization." ;
    schema1:downloadUrl "['/src/contrib/WGCNA_1.74.tar.gz', '/src/contrib/Archive/WGCNA/WGCNA_1.74.tar.gz']" ;
    schema1:identifier biotools:wgcna ;
    schema1:license "GPL-3.0-or-later" ;
    schema1:name "r-wgcna" ;
    schema1:softwareVersion "1.74" ;
    schema1:url "http://horvath.genetics.ucla.edu/html/CoexpressionNetwork/Rpackages/WGCNA/" ;
    spdx:builtFrom biotools:wgcna .

