@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-wgcna a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/1471-2105-9-559",
        "doi:10.18637/jss.v046.i11",
        "doi:10.2202/1544-6115.1128" ;
    schema1:description "Functions necessary to perform Weighted Correlation Network Analysis on high-dimensional data as originally described in Horvath and Zhang (2005) <> and Langfelder and Horvath (2008) <doi:10.1186/1471-2105-9-559>. Includes functions for rudimentary data cleaning, construction of correlation networks, module identification, summarization, and relating of variables and modules to sample traits. Also includes a number of utility functions for data manipulation and visualization." ;
    schema1:identifier biotools:wgcna ;
    schema1:keywords "Gene Expression",
        "Gene expression",
        "Genetics" ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "r-wgcna" ;
    schema1:url "http://horvath.genetics.ucla.edu/html/CoexpressionNetwork/Rpackages/WGCNA/" .

