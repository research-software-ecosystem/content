@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-sim a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/1471-2105-10-203" ;
    schema1:description "Integrated Analysis on two human genomic datasets" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/SIM_1.76.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/SIM/SIM_1.76.0.tar.gz', 'https://bioarchive.galaxyproject.org/SIM_1.76.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-sim/bioconductor-sim_1.76.0_src_all.tar.gz']" ;
    schema1:identifier biotools:sim ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-sim" ;
    schema1:softwareVersion "1.76.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/SIM.html" ;
    spdx:builtFrom biotools:sim .

