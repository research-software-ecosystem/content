@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-sim a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/1471-2105-10-203" ;
    schema1:description "Integrated Analysis on two human genomic datasets" ;
    schema1:identifier biotools:sim ;
    schema1:keywords "Breast Neoplasms",
        "Computational Biology",
        "DNA",
        "Data visualisation",
        "Databases, Genetic",
        "Female",
        "Gene Dosage",
        "Gene Expression",
        "Gene Expression Profiling",
        "Genomics",
        "Humans",
        "Oligonucleotide Array Sequence Analysis" ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-sim" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/SIM.html" .

