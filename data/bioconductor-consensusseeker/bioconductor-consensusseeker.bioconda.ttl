@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-consensusseeker a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1515/sagmb-2014-0098" ;
    schema1:description "Detection of consensus regions inside a group of experiences using genomic positions and genomic ranges" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/consensusSeekeR_1.34.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/consensusSeekeR/consensusSeekeR_1.34.0.tar.gz', 'https://bioarchive.galaxyproject.org/consensusSeekeR_1.34.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-consensusseeker/bioconductor-consensusseeker_1.34.0_src_all.tar.gz']" ;
    schema1:identifier biotools:consensusseeker ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-consensusseeker" ;
    schema1:softwareVersion "1.34.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/consensusSeekeR.html" ;
    spdx:builtFrom biotools:consensusseeker .

