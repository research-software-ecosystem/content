@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-consensusseeker a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1515/sagmb-2014-0098" ;
    schema1:description "Detection of consensus regions inside a group of experiences using genomic positions and genomic ranges" ;
    schema1:identifier biotools:consensusseeker ;
    schema1:keywords "Bayes Theorem",
        "Chromosome Mapping",
        "Genetics",
        "Genome, Fungal",
        "Genomics",
        "Likelihood Functions",
        "Markov Chains",
        "Models, Genetic",
        "Monte Carlo Method",
        "Nucleosomes",
        "Saccharomyces cerevisiae",
        "Sequence Analysis, DNA" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-consensusseeker" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/consensusSeekeR.html" .

