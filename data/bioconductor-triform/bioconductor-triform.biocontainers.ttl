@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-triform a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/1471-2105-13-176" ;
    schema1:description "Triform finds enriched regions (peaks) in transcription factor ChIP-sequencing data" ;
    schema1:identifier biotools:triform ;
    schema1:keywords "Binding Sites",
        "ChIP-seq",
        "Chromatin Immunoprecipitation",
        "High-Throughput Nucleotide Sequencing",
        "Sensitivity and Specificity",
        "Sequence Analysis, DNA",
        "Transcription Factors",
        "Transcription factors and regulatory sites" ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-triform" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/triform.html" .

