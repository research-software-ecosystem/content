@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-reder a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/gb-2012-13-4-r29" ;
    schema1:description "Interactive visualization and manipulation of nested networks" ;
    schema1:identifier biotools:reder ;
    schema1:keywords "Binding Sites",
        "Computational Biology",
        "Computer Simulation",
        "Data visualisation",
        "Databases, Genetic",
        "Gene Expression Profiling",
        "Gene Library",
        "Gene Regulatory Networks",
        "Genomics",
        "Humans",
        "Oligonucleotide Array Sequence Analysis",
        "Reproducibility of Results",
        "Transcription Initiation Site" ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-reder" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/RedeR.html" .

