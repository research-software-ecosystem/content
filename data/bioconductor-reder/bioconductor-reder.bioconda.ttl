@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-reder a schema1:SoftwareApplication ;
    schema1:description "Interactive visualization and manipulation of nested networks" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/RedeR_3.6.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/RedeR/RedeR_3.6.0.tar.gz', 'https://bioarchive.galaxyproject.org/RedeR_3.6.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-reder/bioconductor-reder_3.6.0_src_all.tar.gz']" ;
    schema1:identifier biotools:reder ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-reder" ;
    schema1:softwareVersion "3.6.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/RedeR.html" ;
    spdx:builtFrom biotools:reder .

