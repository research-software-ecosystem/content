@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-sbgnview a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18129/b9.bioc.sbgnview" ;
    schema1:description "Overlay omics data onto SBGN pathway diagram" ;
    schema1:keywords "Genetics",
        "Metabolomics",
        "Proteomics" ;
    schema1:license "AGPL-3" ;
    schema1:name "bioconductor-sbgnview" ;
    schema1:url "https://bioconductor.org/packages/3.10/bioc/html/SBGNview.html" .

