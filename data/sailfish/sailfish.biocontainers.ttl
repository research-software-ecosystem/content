@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:sailfish a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nbt.2862" ;
    schema1:description "Rapid mapping-based isoform quantification from rna-seq reads." ;
    schema1:identifier biotools:sailfish ;
    schema1:keywords "Brain Chemistry",
        "Computational Biology",
        "Humans",
        "Models, Biological",
        "RNA",
        "RNA Isoforms",
        "RNA-Seq",
        "Sequence Analysis, RNA",
        "Sequencing",
        "Transcriptomics" ;
    schema1:license "GPL-3.0" ;
    schema1:name "sailfish" ;
    schema1:url "https://github.com/kingsfordgroup/sailfish" .

