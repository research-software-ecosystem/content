@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-srap a schema1:SoftwareApplication ;
    schema1:citation "doi:10.7717/peerj.159" ;
    schema1:description "Simplified RNA-Seq Analysis Pipeline" ;
    schema1:identifier biotools:srap ;
    schema1:keywords "Function analysis",
        "Gene Expression",
        "Gene expression",
        "RNA-Seq",
        "RNA-seq" ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-srap" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/sRAP.html" .

