@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-rbiopaxparser a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/bts710" ;
    schema1:description "Parses BioPax files and represents them in R" ;
    schema1:identifier biotools:rbiopaxparser ;
    schema1:keywords "Computational Biology",
        "Computer Graphics",
        "Data management",
        "Databases, Factual",
        "Genomics",
        "Models, Biological",
        "Signal Transduction",
        "Vocabulary, Controlled" ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-rbiopaxparser" ;
    schema1:url "https://bioconductor.org/packages/release/bioc/html/rBiopaxParser.html" .

