@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-rbiopaxparser a schema1:SoftwareApplication ;
    schema1:description "Parses BioPax files and represents them in R" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/rBiopaxParser_2.46.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/rBiopaxParser/rBiopaxParser_2.46.0.tar.gz', 'https://bioarchive.galaxyproject.org/rBiopaxParser_2.46.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-rbiopaxparser/bioconductor-rbiopaxparser_2.46.0_src_all.tar.gz']" ;
    schema1:identifier biotools:rbiopaxparser ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-rbiopaxparser" ;
    schema1:softwareVersion "2.46.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/rBiopaxParser.html" ;
    spdx:builtFrom biotools:rbiopaxparser .

