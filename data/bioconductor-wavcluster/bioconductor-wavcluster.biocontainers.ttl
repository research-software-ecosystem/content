@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-wavcluster a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s12859-015-0470-y" ;
    schema1:description "Sensitive and highly resolved identification of RNA-protein interaction sites in PAR-CLIP data" ;
    schema1:identifier biotools:wavcluster ;
    schema1:keywords "Bayes Theorem",
        "Binding Sites",
        "Functional, regulatory and non-coding RNA",
        "HEK293 Cells",
        "High-Throughput Nucleotide Sequencing",
        "Humans",
        "Immunoprecipitation",
        "MicroRNAs",
        "Models, Statistical",
        "RNA",
        "RNA-Binding Proteins",
        "RNA-Seq",
        "RNA-seq",
        "Sequence Analysis, RNA",
        "Transcriptome" ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-wavcluster" ;
    schema1:url "http://bioconductor.org/packages/3.6/bioc/html/wavClusteR.html" .

