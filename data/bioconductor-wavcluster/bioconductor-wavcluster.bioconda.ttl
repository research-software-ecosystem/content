@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-wavcluster a schema1:SoftwareApplication ;
    schema1:description "Sensitive and highly resolved identification of RNA-protein interaction sites in PAR-CLIP data" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/wavClusteR_2.44.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/wavClusteR/wavClusteR_2.44.0.tar.gz', 'https://bioarchive.galaxyproject.org/wavClusteR_2.44.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-wavcluster/bioconductor-wavcluster_2.44.0_src_all.tar.gz']" ;
    schema1:identifier biotools:wavcluster ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-wavcluster" ;
    schema1:softwareVersion "2.44.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/wavClusteR.html" ;
    spdx:builtFrom biotools:wavcluster .

