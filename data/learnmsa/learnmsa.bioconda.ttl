@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:learnmsa a schema1:SoftwareApplication ;
    schema1:author "felbecker" ;
    schema1:citation "doi:10.1093/gigascience/giac104" ;
    schema1:description "learnMSA: Learning and Aligning large Protein Families" ;
    schema1:downloadUrl "https://pypi.io/packages/source/l/learnMSA/learnmsa-2.0.16.tar.gz" ;
    schema1:identifier biotools:learnMSA ;
    schema1:license "MIT" ;
    schema1:maintainer "felbecker" ;
    schema1:name "learnmsa" ;
    schema1:softwareVersion "2.0.16" ;
    schema1:url "https://github.com/Gaius-Augustus/learnMSA" ;
    spdx:builtFrom biotools:learnMSA .

