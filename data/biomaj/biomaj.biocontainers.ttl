@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:biomaj a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btn325",
        "doi:10.1186/s13742-015-0063-8" ;
    schema1:description "Biomaj is a workflow engine dedicated to data synchronization and processing. the software automates the update cycle and the supervision of the locally mirrored databank repository." ;
    schema1:identifier biotools:biomaj ;
    schema1:keywords "Automation",
        "Computational Biology",
        "Data management",
        "Internet",
        "User-Computer Interface" ;
    schema1:license "AGPL-3.0" ;
    schema1:name "biomaj" ;
    schema1:url "http://biomaj.genouest.org/" .

