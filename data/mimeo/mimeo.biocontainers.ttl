@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:mimeo a schema1:SoftwareApplication ;
    schema1:description "Scan genomes for internally repeated sequences, elements which are repetitive in another species, or high-identity hgt candidate regions between species." ;
    schema1:license "MIT" ;
    schema1:name "mimeo" ;
    schema1:url "https://github.com/Adamtaranto/mimeo" .

