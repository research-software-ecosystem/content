@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:mgf-formatter a schema1:SoftwareApplication ;
    schema1:description "Tools for convert peak lists into MGF files formatted for particular downstream applications" ;
    schema1:license "Eclipse Public License" ;
    schema1:name "mgf-formatter" ;
    schema1:url "https://bitbucket.org/galaxyp-applications/mgf-formatter" .

