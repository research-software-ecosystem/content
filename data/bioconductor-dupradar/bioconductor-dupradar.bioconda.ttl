@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-dupradar a schema1:SoftwareApplication ;
    schema1:description "Assessment of duplication rates in RNA-Seq datasets" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.21/bioc/src/contrib/dupRadar_1.38.0.tar.gz', 'https://bioconductor.org/packages/3.21/bioc/src/contrib/Archive/dupRadar/dupRadar_1.38.0.tar.gz', 'https://bioarchive.galaxyproject.org/dupRadar_1.38.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-dupradar/bioconductor-dupradar_1.38.0_src_all.tar.gz']" ;
    schema1:identifier biotools:dupradar ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-dupradar" ;
    schema1:softwareVersion "1.38.0" ;
    schema1:url "https://bioconductor.org/packages/3.21/bioc/html/dupRadar.html" ;
    spdx:builtFrom biotools:dupradar .

