@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-dupradar a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s12859-016-1276-2" ;
    schema1:description "Duplication rate quality control for rna-seq datasets." ;
    schema1:identifier biotools:dupradar ;
    schema1:keywords "Artifacts",
        "Gene Expression Profiling",
        "Genome, Human",
        "High-Throughput Nucleotide Sequencing",
        "Humans",
        "Polymerase Chain Reaction",
        "RNA",
        "RNA-Seq",
        "RNA-seq",
        "Sequence Analysis, RNA" ;
    schema1:license "GPL-3.0" ;
    schema1:name "bioconductor-dupradar" ;
    schema1:url "http://bioconductor.org/packages/release/bioc/html/dupRadar.html" .

