@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-oligodata a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18129/b9.bioc.oligodata" ;
    schema1:description "Dataset samples (Affymetrix: Expression, Gene, Exon, SNP; NimbleGen: Expression, Tiling) to be used with the oligo package." ;
    schema1:license "LGPL (>= 2)" ;
    schema1:name "bioconductor-oligodata" ;
    schema1:url "https://bioconductor.org/packages/3.8/data/annotation/html/oligoData.html" .

