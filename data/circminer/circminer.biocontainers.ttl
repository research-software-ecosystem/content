@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:circminer a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btaa232" ;
    schema1:description "Sensitive and fast computational tool for detecting circular RNAs (circRNAs) from RNA-Seq data." ;
    schema1:keywords "Base Sequence",
        "RNA",
        "RNA Splicing",
        "RNA, Circular",
        "RNA-Seq",
        "Sequence Analysis, RNA",
        "Transcriptome",
        "Transcriptomics" ;
    schema1:license "GPL-3.0" ;
    schema1:name "circminer" ;
    schema1:url "https://github.com/vpc-ccg/circminer" .

