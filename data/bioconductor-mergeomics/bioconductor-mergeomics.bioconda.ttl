@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-mergeomics a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1101/036012" ;
    schema1:description "Integrative network analysis of omics data" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/Mergeomics_1.34.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/Mergeomics/Mergeomics_1.34.0.tar.gz', 'https://bioarchive.galaxyproject.org/Mergeomics_1.34.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-mergeomics/bioconductor-mergeomics_1.34.0_src_all.tar.gz']" ;
    schema1:identifier biotools:mergeomics ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-mergeomics" ;
    schema1:softwareVersion "1.34.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/Mergeomics.html" ;
    spdx:builtFrom biotools:mergeomics .

