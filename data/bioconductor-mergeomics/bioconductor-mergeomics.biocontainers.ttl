@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-mergeomics a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1101/036012",
        "doi:10.1186/s12864-016-3057-8" ;
    schema1:description "Integrative network analysis of omics data" ;
    schema1:identifier biotools:mergeomics ;
    schema1:keywords "Disease Susceptibility",
        "Experimental design and studies",
        "Functional genomics",
        "GWAS study",
        "Gene Regulatory Networks",
        "Genetic Association Studies",
        "Genomics",
        "Humans",
        "Molecular interactions, pathways and networks",
        "Omics",
        "Signal Transduction",
        "User-Computer Interface",
        "Web Browser" ;
    schema1:license "GPL-2+" ;
    schema1:name "bioconductor-mergeomics" ;
    schema1:url "https://bioconductor.org/packages/Mergeomics/" .

