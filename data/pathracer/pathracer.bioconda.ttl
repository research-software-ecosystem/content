@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:pathracer a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1007/978-3-030-18174-1_6" ;
    schema1:description "PathRacer is a tool for alignment of profile HMM against assembly graph." ;
    schema1:downloadUrl "http://cab.spbu.ru/files/pathracer/SPAdes-3.16.0-pathracer-dev.tar.gz" ;
    schema1:identifier biotools:pathracer ;
    schema1:license "GPLv2" ;
    schema1:name "pathracer" ;
    schema1:softwareVersion "3.16.0.dev" ;
    schema1:url "http://cab.spbu.ru/software/pathracer/" ;
    spdx:builtFrom biotools:pathracer .

