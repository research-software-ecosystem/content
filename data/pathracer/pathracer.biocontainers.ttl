@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:pathracer a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1101/562579" ;
    schema1:description "PathRacer is a tool for alignment of profile HMM against assembly graph." ;
    schema1:keywords "Genomics",
        "Metagenome",
        "Metagenomics",
        "RNA-Seq",
        "Transcriptomics" ;
    schema1:license "GPL--2.0" ;
    schema1:name "pathracer" ;
    schema1:url "http://cab.spbu.ru/software/pathracer/" .

