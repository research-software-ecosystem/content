@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:kronik a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1002/0471250953.bi1318s37" ;
    schema1:description "Utility for processing Hardklor features to find candidate peptides by chromatographic profiling" ;
    schema1:keywords "Chromatography, Liquid",
        "Mass Spectrometry",
        "Peptides",
        "Proteomics" ;
    schema1:license "Apache-2.0" ;
    schema1:name "kronik" ;
    schema1:url "https://github.com/mhoopmann/kronik" .

