@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:mdanalysis a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1002/jcc.21787" ;
    schema1:description "MDAnalysis is a Python library for the analysis of computer simulations of many-body systems at the molecular scale, spanning use cases from interactions of drugs with proteins to novel materials. It is widely used in the scientific community and is written by scientists for scientists." ;
    schema1:identifier biotools:mdanalysis ;
    schema1:keywords "Computational Biology",
        "Molecular Dynamics",
        "Molecular Dynamics Simulation",
        "Molecular dynamics" ;
    schema1:license "GPL-2.0" ;
    schema1:name "mdanalysis" ;
    schema1:url "https://github.com/MDAnalysis/mdanalysis" .

