@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-gwasexacthw a schema1:SoftwareApplication ;
    schema1:description "This package contains a function to do exact Hardy-Weinburg testing (using Fisher's test) for SNP genotypes as typically obtained in a Genome Wide Association Study (GWAS)." ;
    schema1:license "GPL-3" ;
    schema1:name "r-gwasexacthw" ;
    schema1:url "https://CRAN.R-project.org/package=GWASExactHW" .

