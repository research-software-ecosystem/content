@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bsmap a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/1471-2105-10-232" ;
    schema1:description "BSMAP is a short reads mapping software for bisulfite sequencing reads." ;
    schema1:identifier biotools:bsmap ;
    schema1:keywords "Base Sequence",
        "DNA",
        "DNA Methylation",
        "Epigenetics",
        "Genomics",
        "Sequence Alignment",
        "Sequence Analysis, DNA",
        "Sulfites" ;
    schema1:license "GNU GPL v3" ;
    schema1:name "bsmap" ;
    schema1:url "https://code.google.com/archive/p/bsmap/" .

