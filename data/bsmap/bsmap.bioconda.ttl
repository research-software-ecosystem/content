@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bsmap a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/1471-2105-10-232" ;
    schema1:description "BSMAP is a short reads mapping software for bisulfite sequencing reads." ;
    schema1:downloadUrl "https://github.com/xi11west/bsmap/raw/main/bsmap-2.90.tgz" ;
    schema1:identifier biotools:bsmap ;
    schema1:license "GNU GPL v3" ;
    schema1:name "bsmap" ;
    schema1:softwareVersion "2.9" ;
    schema1:url "https://code.google.com/archive/p/bsmap/" ;
    spdx:builtFrom biotools:bsmap .

