@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:ngless a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s40168-019-0684-8" ;
    schema1:description "A tool for short-read processing with a focus on metagenomics" ;
    schema1:keywords "Computational Biology",
        "Genomics",
        "High-Throughput Nucleotide Sequencing",
        "Metagenome",
        "Metagenomics",
        "Programming Languages",
        "Reproducibility of Results",
        "Sequence Analysis, DNA" ;
    schema1:license "MIT" ;
    schema1:name "ngless" ;
    schema1:url "https://ngless.embl.de" .

