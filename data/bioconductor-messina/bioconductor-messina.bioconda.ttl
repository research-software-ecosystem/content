@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-messina a schema1:SoftwareApplication ;
    schema1:description "Single-gene classifiers and outlier-resistant detection of differential expression for two-group and survival problems" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/messina_1.46.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/messina/messina_1.46.0.tar.gz', 'https://bioarchive.galaxyproject.org/messina_1.46.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-messina/bioconductor-messina_1.46.0_src_all.tar.gz']" ;
    schema1:identifier biotools:messina ;
    schema1:license "EPL (>= 1.0)" ;
    schema1:name "bioconductor-messina" ;
    schema1:softwareVersion "1.46.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/messina.html" ;
    spdx:builtFrom biotools:messina .

