@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:ipyrad a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btz966" ;
    schema1:description "Interactive assembly and analysis of RAD-seq data sets." ;
    schema1:downloadUrl "https://github.com/dereneaton/ipyrad/archive/0.9.108.tar.gz" ;
    schema1:identifier biotools:ipyrad ;
    schema1:license "GPL-3.0-only" ;
    schema1:name "ipyrad" ;
    schema1:softwareHelp "https://ipyrad.readthedocs.io/en/master" ;
    schema1:softwareVersion "0.9.108" ;
    schema1:url "https://github.com/dereneaton/ipyrad" ;
    spdx:builtFrom biotools:ipyrad .

