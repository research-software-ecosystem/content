@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:trinotate a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1016/j.celrep.2016.12.063" ;
    schema1:description "Trinotate is a comprehensive annotation suite designed for automatic functional annotation of transcriptomes, particularly de novo assembled transcriptomes, from model or non-model organisms" ;
    schema1:identifier biotools:trinotate ;
    schema1:keywords "Ambystoma mexicanum",
        "Animals",
        "Extremities",
        "Gene expression",
        "In Situ Hybridization",
        "Insulin-Like Growth Factor Binding Proteins",
        "RNA",
        "RNA Interference",
        "RNA Splicing",
        "RNA, Small Interfering",
        "RNA-Binding Proteins",
        "Regeneration",
        "Sequence Analysis, RNA",
        "Transcriptome",
        "Transcriptomics" ;
    schema1:license "BSD" ;
    schema1:name "trinotate" ;
    schema1:url "https://trinotate.github.io/" .

