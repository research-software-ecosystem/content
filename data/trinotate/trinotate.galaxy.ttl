@prefix edam: <http://edamontology.org/> .
@prefix galaxytool: <https://github.com/galaxyproject/tools-iuc/tree/master/tools/> .
@prefix schema1: <http://schema.org/> .

galaxytool:trinotate a schema1:SoftwareApplication ;
    schema1:applicationSubCategory "edam:topic_0203",
        "edam:topic_3308" ;
    schema1:description "Trinotate is a comprehensive annotation suite designed for automatic functional annotation of de novo transcriptomes." ;
    schema1:featureList edam:operation_3672 ;
    schema1:identifier "bioconda:trinotate",
        "biotools:trinotate",
        "workflowhub:1716?version=1" ;
    schema1:keywords "RNA",
        "Transcriptomics" ;
    schema1:name "trinotate" ;
    schema1:softwareVersion "3.2.2" ;
    schema1:url "https://trinotate.github.io/" .

