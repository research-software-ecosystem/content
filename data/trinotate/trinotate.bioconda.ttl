@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:trinotate a schema1:SoftwareApplication ;
    schema1:description "Trinotate is a comprehensive annotation suite designed for automatic functional annotation of transcriptomes, particularly de novo assembled transcriptomes, from model or non-model organisms" ;
    schema1:downloadUrl "https://github.com/Trinotate/Trinotate/archive/refs/tags/Trinotate-v4.0.2.tar.gz" ;
    schema1:identifier biotools:trinotate ;
    schema1:license "BSD-3-Clause" ;
    schema1:name "trinotate" ;
    schema1:softwareVersion "4.0.2" ;
    schema1:url "https://trinotate.github.io/" ;
    spdx:builtFrom biotools:trinotate .

