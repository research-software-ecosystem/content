@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-cellassign a schema1:SoftwareApplication ;
    schema1:description "Automated, probabilistic assignment of cell types in scrna-seq data" ;
    schema1:keywords "Clustering",
        "RNA-Seq" ;
    schema1:license "Apache-2.0" ;
    schema1:name "r-cellassign" ;
    schema1:url "https://github.com/Irrationone/cellassign" .

