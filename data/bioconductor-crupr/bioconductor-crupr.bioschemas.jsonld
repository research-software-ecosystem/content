      "@id": "https://bio.tools/bioconductor-crupr",
      "@type": "sc:SoftwareApplication",
      "dcterms:conformsTo": "https://bioschemas.org/profiles/ComputationalTool/0.6-DRAFT",
      "sc:additionalType": [
        "Command-line tool",
        "Library"
      ],
      "sc:author": [
        "Verena Laupert",
        "Martin Vingron"
      ],
      "sc:citation": {
        "@id": "https://doi.org/10.1186/s13059-019-1860-7"
      },
      "sc:description": "An R package that offers a workflow to predict condition-specific enhancers from ChIP-seq data. The prediction of regulatory units is done in four main steps: Step 1 - the normalization of the ChIP-seq counts. Step 2 - the prediction of active enhancers binwise on the whole genome. Step 3 - the condition-specific clustering of the putative active enhancers. Step 4 - the detection of possible target genes of the condition-specific clusters using RNA-seq counts.",
      "sc:license": "GPL-3.0-only",
      "sc:name": "crupR",
      "sc:operatingSystem": [
        "Mac",
        "Linux",
        "Windows"
      ],
      "sc:softwareHelp": {
        "@id": "https://bioconductor.org/packages/crupR"
      },
      "sc:softwareVersion": "1.2.0",
      "sc:url": "https://bioconductor.org/packages/crupR"
    }
  ]
