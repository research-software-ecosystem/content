@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:cansnper a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btu113" ;
    schema1:description "A hierarchical genotype classifier of clonal pathogens." ;
    schema1:identifier biotools:cansnper ;
    schema1:keywords "DNA polymorphism",
        "Genetics",
        "Genomics",
        "Genotype",
        "Genotyping Techniques",
        "Model organisms",
        "Molecular Typing",
        "Polymorphism, Single Nucleotide" ;
    schema1:license "GNU General Public License v3.0" ;
    schema1:name "cansnper" ;
    schema1:url "https://github.com/adrlar/CanSNPer/" .

