@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:merlin a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/ng786" ;
    schema1:description "MERLIN uses sparse trees to represent gene flow in pedigrees and is a fast pedigree analysis package" ;
    schema1:identifier biotools:Merlin ;
    schema1:keywords "Female",
        "GWAS study",
        "Genetic Linkage",
        "Genetics",
        "Genotype",
        "Haplotypes",
        "Humans",
        "Likelihood Functions",
        "Male",
        "Mapping",
        "Meiosis",
        "Pedigree",
        "Polymorphism, Genetic" ;
    schema1:license "OpenSource" ;
    schema1:name "merlin" ;
    schema1:url "http://csg.sph.umich.edu/abecasis/merlin" .

