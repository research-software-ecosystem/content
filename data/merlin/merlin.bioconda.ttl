@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:merlin a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/ng786" ;
    schema1:description "MERLIN uses sparse trees to represent gene flow in pedigrees and is a fast pedigree analysis package" ;
    schema1:downloadUrl "http://csg.sph.umich.edu/abecasis/merlin/download/merlin-1.1.2.tar.gz" ;
    schema1:identifier biotools:Merlin ;
    schema1:license "OpenSource" ;
    schema1:name "merlin" ;
    schema1:softwareVersion "1.1.2" ;
    schema1:url "http://csg.sph.umich.edu/abecasis/merlin" ;
    spdx:builtFrom biotools:Merlin .

