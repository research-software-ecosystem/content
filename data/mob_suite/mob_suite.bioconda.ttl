@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:mob_suite a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1099/mgen.0.000206",
        "doi:10.1099/mgen.0.000435" ;
    schema1:description "MOB-suite is a set of tools for finding, typing and reconstruction of plasmids from draft and complete genome assemblies." ;
    schema1:downloadUrl "https://pypi.io/packages/source/m/mob_suite/mob_suite-3.1.9.tar.gz" ;
    schema1:identifier biotools:mob-suite ;
    schema1:license "Apache-2.0" ;
    schema1:name "mob_suite" ;
    schema1:softwareHelp "https://github.com/phac-nml/mob-suite/blob/master/README.md" ;
    schema1:softwareVersion "3.1.9" ;
    schema1:url "https://pypi.org/project/mob-suite/" ;
    spdx:builtFrom biotools:mob-suite .

