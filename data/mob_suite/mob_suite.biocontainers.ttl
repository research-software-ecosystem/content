@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:mob_suite a schema1:SoftwareApplication ;
    schema1:description "This package mob-suite: software tools for clustering, reconstruction and typing of plasmids from draft assemblies. the mob-suite is designed to be a modular set of tools for the typing and reconstruction of plasmid sequences from WGS assemblies." ;
    schema1:keywords "Clustering",
        "Genomics" ;
    schema1:license "Apache-2.0" ;
    schema1:name "mob_suite" ;
    schema1:url "https://github.com/phac-nml/mob-suite" .

