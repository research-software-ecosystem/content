@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:cluster-picker a schema1:SoftwareApplication ;
    schema1:description "Picking and Describing HIV Clusters in Phylogenetic Trees. A tool combination for the analysis of phylogenetic clusters of nucleotide sequences" ;
    schema1:license "GPL-3.0" ;
    schema1:name "cluster-picker" ;
    schema1:url "https://github.com/emmahodcroft/cluster-picker-and-cluster-matcher" .

