@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:stringdecomposer a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btaa454",
        "doi:10.6084/m9.figshare.12783371" ;
    schema1:description "A tool for decomposing of strings into a set of given monomers" ;
    schema1:license "GPL-2.0" ;
    schema1:name "stringdecomposer" ;
    schema1:url "https://github.com/ablab/stringdecomposer" .

