@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:rfmix a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1016/j.ajhg.2013.06.020" ;
    schema1:description "RFMix implements a fast discriminative approach to modeling ancestry along an admixed chromosome given observed haplotype sequences of known or inferred ancestry." ;
    schema1:downloadUrl "https://github.com/slowkoni/rfmix/archive/9505bfae51ea57314d98060e6d09f6759cda8e8d.zip" ;
    schema1:identifier biotools:RFMix ;
    schema1:license "Free for Academic Use" ;
    schema1:name "rfmix" ;
    schema1:softwareVersion "2.03.r0.9505bfa" ;
    schema1:url "https://github.com/slowkoni/rfmix" ;
    spdx:builtFrom biotools:RFMix .

