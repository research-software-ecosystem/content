@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:rfmix a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1016/j.ajhg.2013.06.020" ;
    schema1:description "RFMix implements a fast discriminative approach to modeling ancestry along an admixed chromosome given observed haplotype sequences of known or inferred ancestry." ;
    schema1:identifier biotools:RFMix ;
    schema1:keywords "African Continental Ancestry Group",
        "Asian Continental Ancestry Group",
        "Computer Simulation",
        "European Continental Ancestry Group",
        "Genetic Testing",
        "Genetics",
        "Genome, Human",
        "Haplotypes",
        "Human genetics",
        "Humans",
        "Indians, North American",
        "Models, Genetic",
        "Polymorphism, Single Nucleotide",
        "Population genetics",
        "Whole genome sequencing" ;
    schema1:license "Free for Academic Use" ;
    schema1:name "rfmix" ;
    schema1:url "https://github.com/slowkoni/rfmix" .

