@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:sshmm a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/gkx756" ;
    schema1:description "ssHMM is an RNA motif finder that recovers sequence-structure motifs from RNA-binding protein data, such as CLIP-Seq data." ;
    schema1:keywords "Base Sequence",
        "Computational Biology",
        "Models, Molecular",
        "Nucleic Acid Conformation",
        "Nucleotide Motifs",
        "Protein Binding",
        "Protein Domains",
        "RNA",
        "RNA-Binding Proteins",
        "Reproducibility of Results",
        "Sequence Analysis, RNA" ;
    schema1:license "GPL-3.0" ;
    schema1:name "sshmm" ;
    schema1:url "https://github.molgen.mpg.de/heller/ssHMM" .

