@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-chipqc a schema1:SoftwareApplication ;
    schema1:description "Quality metrics for ChIPseq data" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/ChIPQC_1.42.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/ChIPQC/ChIPQC_1.42.0.tar.gz', 'https://bioarchive.galaxyproject.org/ChIPQC_1.42.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-chipqc/bioconductor-chipqc_1.42.0_src_all.tar.gz']" ;
    schema1:identifier biotools:chipqc ;
    schema1:license "GPL (>= 3)" ;
    schema1:name "bioconductor-chipqc" ;
    schema1:softwareVersion "1.42.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/ChIPQC.html" ;
    spdx:builtFrom biotools:chipqc .

