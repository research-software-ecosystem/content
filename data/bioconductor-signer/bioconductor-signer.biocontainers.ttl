@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-signer a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btw572" ;
    schema1:description "Empirical Bayesian approach to mutational signature discovery" ;
    schema1:identifier biotools:signer ;
    schema1:keywords "Animals",
        "Bayes Theorem",
        "DNA Mutational Analysis",
        "Data visualisation",
        "Genetic variation",
        "High-Throughput Nucleotide Sequencing",
        "Humans",
        "Mutation",
        "Neoplasms",
        "Statistics and probability" ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-signer" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/signeR.html" .

