@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-signer a schema1:SoftwareApplication ;
    schema1:description "Empirical Bayesian approach to mutational signature discovery" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/signeR_2.8.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/signeR/signeR_2.8.0.tar.gz', 'https://bioarchive.galaxyproject.org/signeR_2.8.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-signer/bioconductor-signer_2.8.0_src_all.tar.gz']" ;
    schema1:identifier biotools:signer ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-signer" ;
    schema1:softwareVersion "2.8.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/signeR.html" ;
    spdx:builtFrom biotools:signer .

