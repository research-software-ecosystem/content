@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:artemis a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btr703" ;
    schema1:description "Free genome browser and annotation tool that allows visualisation of sequence features, next generation data and the results of analyses within the context of the sequence, and also its six-frame translation." ;
    schema1:identifier biotools:artemis ;
    schema1:keywords "Data visualisation",
        "Genetics",
        "Genome",
        "Genomics",
        "High-Throughput Nucleotide Sequencing",
        "Molecular Sequence Annotation",
        "Transcriptome" ;
    schema1:license "GPL-3.0" ;
    schema1:name "artemis" ;
    schema1:url "http://www.sanger.ac.uk/science/tools/artemis" .

