@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:dimspy a schema1:SoftwareApplication ;
    schema1:description "Python package for data processing of direct-infusion mass spectrometry-based metabolomics and lipidomics data" ;
    schema1:keywords "Mass spectrometry",
        "Metabolomics" ;
    schema1:license "GPL-3.0" ;
    schema1:name "dimspy" ;
    schema1:url "https://github.com/computational-metabolomics/dimspy" .

