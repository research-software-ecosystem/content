@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:discasm a schema1:SoftwareApplication ;
    schema1:description "Discasm aims to extract reads that map to reference genomes in a discordant fashion and optionally include reads that do not map to the genome at all, and perform a de novo transcriptome assembly of these reads. discasm relies on the output from star (as run via star-fusion), and supports de novo transcriptome assembly using trinity or oases. - https://github.com/discasm/discasm/wiki" ;
    schema1:license "BSD 3-Clause \"New\" or \"Revised\" License" ;
    schema1:name "discasm" ;
    schema1:url "https://github.com/DISCASM/DISCASM" .

