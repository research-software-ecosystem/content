@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:rapmap-example-data a schema1:SoftwareApplication ;
    schema1:description "Rapmap is a tool implementing quasi-mapping and is capable of mapping sequencing reads to a target transcriptome substantially faster than existing alignment tools." ;
    schema1:keywords "Transcriptome" ;
    schema1:license "GPL-3.0" ;
    schema1:name "rapmap-example-data" ;
    schema1:url "https://github.com/COMBINE-lab/RapMap" .

