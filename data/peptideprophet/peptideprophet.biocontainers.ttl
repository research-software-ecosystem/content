@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:peptideprophet a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1021/ac025747h" ;
    schema1:description "Validation of peptide identifications by ms/ms and database searches." ;
    schema1:identifier biotools:peptideprophet ;
    schema1:keywords "Databases, Factual",
        "Mass Spectrometry",
        "Models, Statistical",
        "Peptides",
        "Proteomics",
        "Proteomics experiment",
        "Statistics and probability" ;
    schema1:license "GPL-2.0-only" ;
    schema1:name "peptideprophet" ;
    schema1:url "http://peptideprophet.sourceforge.net/index.html" .

