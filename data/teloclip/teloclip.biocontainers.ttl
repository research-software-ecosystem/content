@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:teloclip a schema1:SoftwareApplication ;
    schema1:description "A tool for the recovery of unassembled telomeres from soft-clipped read alignments." ;
    schema1:license "MIT" ;
    schema1:name "teloclip" ;
    schema1:url "https://github.com/Adamtaranto/teloclip" .

