@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-topgo a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btl140" ;
    schema1:description "Enrichment Analysis for Gene Ontology" ;
    schema1:identifier biotools:topgo ;
    schema1:keywords "Cluster Analysis",
        "Computational Biology",
        "Data mining",
        "Databases, Genetic",
        "Gene Expression Profiling",
        "Gene Expression Regulation",
        "Gene Expression Regulation, Neoplastic",
        "Genomics",
        "Humans",
        "Leukemia",
        "Models, Statistical",
        "Oligonucleotide Array Sequence Analysis",
        "Ontology and terminology",
        "Protein Folding",
        "Statistics and probability" ;
    schema1:license "LGPL" ;
    schema1:name "bioconductor-topgo" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/topGO.html" .

