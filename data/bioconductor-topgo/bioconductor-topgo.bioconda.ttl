@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-topgo a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btl140" ;
    schema1:description "Enrichment Analysis for Gene Ontology" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/topGO_2.62.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/topGO/topGO_2.62.0.tar.gz', 'https://bioarchive.galaxyproject.org/topGO_2.62.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-topgo/bioconductor-topgo_2.62.0_src_all.tar.gz']" ;
    schema1:identifier biotools:topgo ;
    schema1:license "LGPL" ;
    schema1:name "bioconductor-topgo" ;
    schema1:softwareVersion "2.62.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/topGO.html" ;
    spdx:builtFrom biotools:topgo .

