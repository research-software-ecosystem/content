@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:usher a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/s41588-021-00862-7" ;
    schema1:description "Ultrafast Sample Placement on Existing Trees (UShER)." ;
    schema1:downloadUrl "https://github.com/yatisht/usher/archive/v0.6.6.tar.gz" ;
    schema1:identifier biotools:usher ;
    schema1:license "MIT" ;
    schema1:name "usher" ;
    schema1:softwareHelp "https://usher-wiki.readthedocs.io/en/latest" ;
    schema1:softwareVersion "0.6.6" ;
    schema1:url "https://github.com/yatisht/usher" ;
    spdx:builtFrom biotools:usher .

