@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-bgeecall a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18129/b9.bioc.bgeecall" ;
    schema1:description "Automatic RNA-Seq present/absent gene expression calls generation" ;
    schema1:keywords "Gene Expression",
        "RNA-Seq" ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-bgeecall" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/BgeeCall.html" .

