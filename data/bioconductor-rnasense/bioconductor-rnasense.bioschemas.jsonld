  "@graph": [
    {
      "@id": "https://bio.tools/bioconductor-rnasense",
      "@type": "sc:SoftwareApplication",
      "dcterms:conformsTo": "https://bioschemas.org/profiles/ComputationalTool/0.6-DRAFT",
      "sc:additionalType": [
        "Library",
        "Command-line tool"
      ],
      "sc:author": [
        "Daria Onichtchouk",
        "Gao Meijang",
        "Helge Hass"
      ],
      "sc:citation": {
        "@id": "https://doi.org/10.18129/B9.bioc.RNAsense"
      },
      "sc:description": "RNA-sense tool compares RNA-seq time curves in two experimental conditions, i.e. wild-type and mutant, and works in three steps. At Step 1, it builds expression profile for each transcript in one condition (i.e. wild-type) and tests if the transcript abundance grows or decays significantly. Dynamic transcripts are then sorted to non-overlapping groups (time profiles) by the time point of switch up or down. At Step 2, RNA-sense outputs the groups of differentially expressed transcripts, which are up- or downregulated in the mutant compared to the wild-type at each time point. At Step 3, Correlations (Fisher's exact test) between the outputs of Step 1 (switch up- and switch down- time profile groups) and the outputs of Step2 (differentially expressed transcript groups) are calculated. The results of the correlation analysis are printed as two-dimensional color plot, with time profiles and differential expression groups at y- and x-axis, respectively, and facilitates the biological interpretation of the data.",
      "sc:license": "GPL-3.0-only",
      "sc:name": "RNAsense",
      "sc:operatingSystem": [
        "Mac",
        "Linux",
        "Windows"
      ],
      "sc:softwareHelp": {
        "@id": "https://bioconductor.org/packages/RNAsense"
      },
      "sc:softwareVersion": "1.24.0",
      "sc:url": "https://bioconductor.org/packages/RNAsense"
    },
    {
      "@id": "https://doi.org/10.18129/B9.bioc.RNAsense",
      "@type": "sc:CreativeWork"
    }
  ]
