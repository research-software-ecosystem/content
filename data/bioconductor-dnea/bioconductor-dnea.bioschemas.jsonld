  "@graph": [
    {
      "@id": "https://bio.tools/bioconductor-dnea",
      "@type": "sc:SoftwareApplication",
      "dcterms:conformsTo": "https://bioschemas.org/profiles/ComputationalTool/0.6-DRAFT",
      "sc:additionalType": [
        "Command-line tool",
        "Library"
      ],
      "sc:author": [
        "Christopher Patsalis",
        "Gayatri Iyer"
      ],
      "sc:citation": {
        "@id": "https://doi.org/10.1186/s12859-024-05994-1"
      },
      "sc:contributor": [
        "Alla Karnovsky",
        "George Michailidis"
      ],
      "sc:description": "The DNEA R package is the latest implementation of the Differential Network Enrichment Analysis algorithm and is the successor to the Filigree Java-application described in Iyer et al. (2020). The package is designed to take as input an m x n expression matrix for some -omics modality (ie. metabolomics, lipidomics, proteomics, etc.) and jointly estimate the biological network associations of each condition using the DNEA algorithm described in Ma et al. (2019). This approach provides a framework for data-driven enrichment analysis across two experimental conditions that utilizes the underlying correlation structure of the data to determine feature-feature interactions.",
      "sc:funder": [
        "Alla Karnovsky",
        "George Michailidis"
      ],
      "sc:license": "MIT",
      "sc:name": "DNEA",
      "sc:operatingSystem": [
        "Linux",
        "Windows",
        "Mac"
      ],
      "sc:softwareHelp": {
        "@id": "https://bioconductor.org/packages/DNEA"
      },
      "sc:softwareVersion": "1.0.0",
      "sc:url": "https://bioconductor.org/packages/DNEA"
    },
