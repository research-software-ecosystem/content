@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:biobambam a schema1:SoftwareApplication ;
    schema1:description "Tools for early stage alignment file processing." ;
    schema1:downloadUrl "https://gitlab.com/german.tischler/biobambam2/-/archive/2.0.185-release-20221211202123/biobambam2-2.0.185-release-20221211202123.tar.gz" ;
    schema1:identifier biotools:biobambam ;
    schema1:license "GPL-3.0-or-later" ;
    schema1:name "biobambam" ;
    schema1:softwareVersion "2.0.185" ;
    schema1:url "https://gitlab.com/german.tischler/biobambam2" ;
    spdx:builtFrom biotools:biobambam .

