@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-tspair a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btp126" ;
    schema1:description "Top Scoring Pairs for Microarray Classification" ;
    schema1:identifier biotools:tspair ;
    schema1:keywords "Computational Biology",
        "Gene Expression Profiling",
        "Genetic variation",
        "Genotype and phenotype",
        "Microarray experiment" ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-tspair" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/tspair.html" .

