@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:pymot a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1007/978-3-540-68585-2_1",
        "doi:10.1155/2008/246309" ;
    schema1:description "This is a python implementation which determines the motp and mota metrics from a set of ground truth tracks and a set of hypothesis tracks given by the tracker to be evaluated." ;
    schema1:license "Custom License" ;
    schema1:name "pymot" ;
    schema1:url "https://github.com/Videmo/pymot" .

