@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:ete3 a schema1:SoftwareApplication ;
    schema1:description "A Python framework for the analysis and visualization of trees" ;
    schema1:keywords "Clustering",
        "Genetics",
        "Genomics",
        "Phylogenetics" ;
    schema1:license "GPL-3.0" ;
    schema1:name "ete3" ;
    schema1:url "https://github.com/etetoolkit/ete" .

