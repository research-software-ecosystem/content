@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-isocorrector a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18129/b9.bioc.isocorrector" ;
    schema1:description "Correction for natural isotope abundance and tracer purity in MS and MS/MS data from stable isotope labeling experiments" ;
    schema1:keywords "Genomics",
        "Mass spectrometry",
        "Metabolomics" ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-isocorrector" ;
    schema1:url "https://bioconductor.org/packages/3.8/bioc/html/IsoCorrectoR.html" .

