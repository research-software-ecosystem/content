@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:recon a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/gkh482" ;
    schema1:description "The recon package performs de novo identification and classification of repeat sequence families from genomic sequences." ;
    schema1:identifier biotools:recon ;
    schema1:keywords "Animals",
        "Clustering",
        "Computer Graphics",
        "DNA",
        "DNA binding sites",
        "DNA packaging",
        "Humans",
        "Internet",
        "Mice",
        "Molecular Sequence Data",
        "Nucleosomes",
        "Promoter Regions, Genetic",
        "Sequence Analysis, DNA",
        "Statistics and probability",
        "Transcription factors and regulatory sites" ;
    schema1:license "GPL2" ;
    schema1:name "recon" ;
    schema1:url "http://eddylab.org/software/recon/" .

