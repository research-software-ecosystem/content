@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-tin a schema1:SoftwareApplication ;
    schema1:citation "doi:10.4137/CIN.S31363" ;
    schema1:description "Transcriptome instability analysis" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/TIN_1.38.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/TIN/TIN_1.38.0.tar.gz', 'https://bioarchive.galaxyproject.org/TIN_1.38.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-tin/bioconductor-tin_1.38.0_src_all.tar.gz']" ;
    schema1:identifier biotools:tin ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-tin" ;
    schema1:softwareVersion "1.38.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/TIN.html" ;
    spdx:builtFrom biotools:tin .

