  "@graph": [
    {
      "@id": "https://bio.tools/bioconductor-stadyum",
      "@type": "sc:SoftwareApplication",
      "dcterms:conformsTo": "https://bioschemas.org/profiles/ComputationalTool/0.6-DRAFT",
      "sc:additionalType": [
        "Command-line tool",
        "Library"
      ],
      "sc:author": [
        "Rebecca Hassett",
        "Yixin Zhao",
        "Lingjie Liu"
      ],
      "sc:citation": {
        "@id": "https://doi.org/10.1093/nar/gkad843"
      },
      "sc:description": "STADyUM is a package with functionality for analyzing nascent RNA read counts to infer transcription rates. This includes utilities for processing experimental nascent RNA read counts as well as for simulating PRO-seq data. Rates such as initiation, pause release and landing pad occupancy are estimated from either synthetic or experimental data. There are also options for varying pause sites and including steric hindrance of initiation in the model.",
      "sc:license": "MIT",
      "sc:name": "STADyUM",
      "sc:operatingSystem": [
        "Linux",
        "Windows",
        "Mac"
      ],
      "sc:softwareHelp": {
        "@id": "https://bioconductor.org/packages/STADyUM"
      },
      "sc:softwareVersion": "1.0.2",
      "sc:url": "https://bioconductor.org/packages/STADyUM"
    },
    {
      "@id": "https://doi.org/10.1093/nar/gkad843",
      "@type": "sc:CreativeWork"
    }
