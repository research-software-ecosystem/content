@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-tximport a schema1:SoftwareApplication ;
    schema1:author "roryk" ;
    schema1:description "Import and summarize transcript-level estimates for transcript- and gene-level analysis" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/tximport_1.34.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/tximport/tximport_1.34.0.tar.gz', 'https://bioarchive.galaxyproject.org/tximport_1.34.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-tximport/bioconductor-tximport_1.34.0_src_all.tar.gz']" ;
    schema1:identifier biotools:tximport ;
    schema1:license "LGPL (>=2)" ;
    schema1:maintainer "roryk" ;
    schema1:name "bioconductor-tximport" ;
    schema1:softwareVersion "1.34.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/tximport.html" ;
    spdx:builtFrom biotools:tximport .

