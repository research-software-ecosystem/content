@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:xtandem a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/bth092" ;
    schema1:description "software that can match tandem mass spectra with peptide sequences" ;
    schema1:identifier biotools:xtandem ;
    schema1:keywords "Databases, Protein",
        "Information Storage and Retrieval",
        "Mass Spectrometry",
        "Mass spectra",
        "Mass spectrometry",
        "Peptides",
        "Protein Sequences",
        "Proteins",
        "Proteomics",
        "Proteomics experiment",
        "Sequence Alignment",
        "Sequence Analysis, Protein",
        "Sequence Homology, Amino Acid" ;
    schema1:license "Artistic License" ;
    schema1:name "xtandem" ;
    schema1:url "https://www.thegpm.org/TANDEM/index.html" .

