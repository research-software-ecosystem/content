@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:xtandem a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/bth092" ;
    schema1:description "X! Tandem open source is software that can match tandem mass spectra with peptide sequences, in a process that has come to be known as protein identification." ;
    schema1:downloadUrl "https://depot.galaxyproject.org/software/xtandem/xtandem_15.12.15.2_src_all.zip" ;
    schema1:identifier biotools:xtandem ;
    schema1:license "The-Artistic-License" ;
    schema1:name "xtandem" ;
    schema1:softwareHelp "https://www.thegpm.org/TANDEM/index.html" ;
    schema1:softwareVersion "15.12.15.2" ;
    schema1:url "https://www.thegpm.org/TANDEM/index.html" ;
    spdx:builtFrom biotools:xtandem .

