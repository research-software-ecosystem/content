@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:hgtools a schema1:SoftwareApplication ;
    schema1:description "Classes and setuptools plugin for mercurial and git repositories" ;
    schema1:license "MIT" ;
    schema1:name "hgtools" ;
    schema1:url "https://github.com/jaraco/hgtools" .

