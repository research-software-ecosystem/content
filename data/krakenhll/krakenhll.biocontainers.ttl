@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:krakenhll a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s13059-018-1568-0" ;
    schema1:description "KrakenHLL metagenomics classification method with unique k-mer counting for more specific results" ;
    schema1:keywords "Genomics",
        "Metagenomics" ;
    schema1:license "GPL-3.0" ;
    schema1:name "krakenhll" ;
    schema1:url "https://github.com/fbreitwieser/krakenhll" .

