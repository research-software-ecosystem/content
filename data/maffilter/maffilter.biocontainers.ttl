@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:maffilter a schema1:SoftwareApplication ;
    schema1:description "Process genome alignment in the multiple alignment format" ;
    schema1:keywords "Genetics",
        "Genomics" ;
    schema1:license "custom, see /usr/share/doc/maffilter/copyright" ;
    schema1:name "maffilter" ;
    schema1:url "https://jydu.github.io/maffilter/" .

