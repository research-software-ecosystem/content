@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-generegionscan a schema1:SoftwareApplication ;
    schema1:description "GeneRegionScan" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/GeneRegionScan_1.66.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/GeneRegionScan/GeneRegionScan_1.66.0.tar.gz', 'https://bioarchive.galaxyproject.org/GeneRegionScan_1.66.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-generegionscan/bioconductor-generegionscan_1.66.0_src_all.tar.gz']" ;
    schema1:identifier biotools:generegionscan ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-generegionscan" ;
    schema1:softwareVersion "1.66.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/GeneRegionScan.html" ;
    spdx:builtFrom biotools:generegionscan .

