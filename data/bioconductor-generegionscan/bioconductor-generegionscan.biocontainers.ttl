    schema1:keywords "Computer Simulation",
        "Databases, Genetic",
        "Genome",
        "Genomics",
        "Genotype",
        "Models, Genetic",
        "Oligonucleotide Array Sequence Analysis",
        "Sequence Alignment",
        "User-Computer Interface" ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-generegionscan" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/GeneRegionScan.html" .

