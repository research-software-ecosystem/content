@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-generegionscan a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btp279" ;
