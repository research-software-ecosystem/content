@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:seroba a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1099/mgen.0.000186" ;
    schema1:description "SeroBA is a k-mer based Pipeline to identify the Serotype from Illumina NGS reads for given references." ;
    schema1:keywords "Alleles",
        "Child, Preschool",
        "Databases, Genetic",
        "Genes, Bacterial",
        "Genomics",
        "High-Throughput Nucleotide Sequencing",
        "Humans",
        "Pneumococcal Infections",
        "Polymorphism, Single Nucleotide",
        "Sensitivity and Specificity",
        "Serogroup",
        "Serotyping",
        "Streptococcus mitis",
        "Streptococcus pneumoniae",
        "Whole Genome Sequencing",
        "Whole genome sequencing" ;
    schema1:license "GPL-3.0" ;
    schema1:name "seroba" ;
    schema1:url "https://github.com/sanger-pathogens/seroba" .

