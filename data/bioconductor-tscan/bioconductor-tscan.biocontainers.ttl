@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-tscan a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/gkw430" ;
    schema1:description "TSCAN: Tools for Single-Cell ANalysis" ;
    schema1:identifier biotools:tscan ;
    schema1:keywords "Computational Biology",
        "Data mining",
        "Gene Expression Regulation",
        "Gene expression",
        "Genetic Heterogeneity",
        "High-Throughput Nucleotide Sequencing",
        "RNA",
        "Single-Cell Analysis",
        "Transcriptome",
        "Transcriptomics",
        "User-Computer Interface" ;
    schema1:license "GPL(>=2)" ;
    schema1:name "bioconductor-tscan" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/TSCAN.html" .

