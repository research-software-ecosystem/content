@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-tscan a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/gkw430" ;
    schema1:description "Tools for Single-Cell Analysis" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/TSCAN_1.44.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/TSCAN/TSCAN_1.44.0.tar.gz', 'https://bioarchive.galaxyproject.org/TSCAN_1.44.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-tscan/bioconductor-tscan_1.44.0_src_all.tar.gz']" ;
    schema1:identifier biotools:tscan ;
    schema1:license "GPL(>=2)" ;
    schema1:name "bioconductor-tscan" ;
    schema1:softwareVersion "1.44.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/TSCAN.html" ;
    spdx:builtFrom biotools:tscan .

