@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:perl-forks a schema1:SoftwareApplication ;
    schema1:description "drop-in replacement for Perl threads using fork()" ;
    schema1:license "perl_5" ;
    schema1:name "perl-forks" ;
    schema1:url "http://search.cpan.org/~rybskej/forks/lib/forks.pm" .

