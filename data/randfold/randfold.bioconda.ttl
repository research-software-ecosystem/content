@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:randfold a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/bth374" ;
    schema1:description "Minimum free energy of folding randomization test software." ;
    schema1:downloadUrl "https://gitlab.psb.ugent.be/biocomp/randfold/-/archive/2.0.1/randfold-2.0.1.tar.gz" ;
    schema1:identifier biotools:randfold ;
    schema1:license "GPL-2.0-or-later" ;
    schema1:name "randfold" ;
    schema1:softwareHelp "http://bioinformatics.psb.ugent.be/software/details/Randfold" ;
    schema1:softwareVersion "2.0.1" ;
    schema1:url "http://bioinformatics.psb.ugent.be/software/details/Randfold" ;
    spdx:builtFrom biotools:randfold .

