@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:randfold a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/bth374" ;
    schema1:description "Minimum free energy of folding randomization test software" ;
    schema1:identifier biotools:randfold ;
    schema1:keywords "Animals",
        "Caenorhabditis elegans",
        "Computer Simulation",
        "Drosophila melanogaster",
        "Energy Transfer",
        "Functional, regulatory and non-coding RNA",
        "Genomics",
        "Humans",
        "MicroRNAs",
        "Models, Chemical",
        "Models, Statistical",
        "Nucleic Acid Conformation",
        "Nucleic Acid Denaturation",
        "Sequence Alignment",
        "Sequence Analysis, RNA",
        "Structure-Activity Relationship",
        "Thermodynamics" ;
    schema1:license "GPL-2.0" ;
    schema1:name "randfold" ;
    schema1:url "http://bioinformatics.psb.ugent.be/software/details/Randfold" .

