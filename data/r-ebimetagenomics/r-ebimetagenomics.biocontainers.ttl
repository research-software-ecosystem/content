@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-ebimetagenomics a schema1:SoftwareApplication ;
    schema1:description "Functions for querying the EBI Metagenomics Portal <https://www.ebi.ac.uk/metagenomics/>. The current main focus is on taxa abundance data, but the intention is that this package should evolve into a general purpose package for working with EBI Metagenomics data using R. " ;
    schema1:keywords "Genomics",
        "Metagenomics" ;
    schema1:license "LGPL-3" ;
    schema1:name "r-ebimetagenomics" ;
    schema1:url "https://CRAN.R-project.org/package=ebimetagenomics" .

