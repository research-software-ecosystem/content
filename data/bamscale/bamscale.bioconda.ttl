@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bamscale a schema1:SoftwareApplication ;
    schema1:description "BAMscale is a one-step tool for either 1) quantifying and normalizing the coverage of peaks." ;
    schema1:downloadUrl "https://github.com/ncbi/BAMscale/archive/v0.0.9.tar.gz" ;
    schema1:identifier biotools:bamscale ;
    schema1:license "Public Domain" ;
    schema1:name "bamscale" ;
    schema1:softwareHelp "https://github.com/ncbi/BAMscale/wiki" ;
    schema1:softwareVersion "0.0.9" ;
    schema1:url "https://github.com/ncbi/BAMscale" ;
    spdx:builtFrom biotools:bamscale .

