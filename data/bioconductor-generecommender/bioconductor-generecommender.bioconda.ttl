@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-generecommender a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1101/gr.1125403" ;
    schema1:description "A gene recommender algorithm to identify genes coexpressed with a query set of genes" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/geneRecommender_1.82.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/geneRecommender/geneRecommender_1.82.0.tar.gz', 'https://bioarchive.galaxyproject.org/geneRecommender_1.82.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-generecommender/bioconductor-generecommender_1.82.0_src_all.tar.gz']" ;
    schema1:identifier biotools:generecommender ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-generecommender" ;
    schema1:softwareVersion "1.82.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/geneRecommender.html" ;
    spdx:builtFrom biotools:generecommender .

