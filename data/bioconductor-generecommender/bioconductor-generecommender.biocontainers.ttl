@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-generecommender a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1101/gr.1125403" ;
    schema1:description "A gene recommender algorithm to identify genes coexpressed with a query set of genes" ;
    schema1:identifier biotools:generecommender ;
    schema1:keywords "Animals",
        "Caenorhabditis elegans",
        "Clustering",
        "Computational Biology",
        "DNA, Helminth",
        "Databases, Genetic",
        "Gene Expression Profiling",
        "Gene Expression Regulation",
        "Genes, Helminth",
        "Genes, Retinoblastoma",
        "Genetics",
        "Oligonucleotide Array Sequence Analysis",
        "RNA Interference" ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-generecommender" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/geneRecommender.html" .

