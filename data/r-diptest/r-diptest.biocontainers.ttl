@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-diptest a schema1:SoftwareApplication ;
    schema1:description "Compute Hartigan's dip test statistic for unimodality / multimodality and provide a test with simulation based p-values, where the original public code has been corrected." ;
    schema1:license "GPL (>=2)" ;
    schema1:name "r-diptest" ;
    schema1:url "https://CRAN.R-project.org/package=diptest" .

