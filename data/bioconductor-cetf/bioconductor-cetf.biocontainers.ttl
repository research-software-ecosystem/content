@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-cetf a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18129/b9.bioc.cetf" ;
    schema1:description "Coexpression for Transcription Factors using Regulatory Impact Factors and Partial Correlation and Information Theory analysis" ;
    schema1:keywords "Gene Expression",
        "RNA-Seq",
        "Transcription Factors" ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-cetf" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/CeTF.html" .

