@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-tcga2stat a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btv677" ;
    schema1:description "Automatically downloads and processes tcga genomics and clinical data into a format convenient for statistical analyses in the r environment." ;
    schema1:keywords "Gene Expression",
        "RNA-Seq" ;
    schema1:license "GPL-2" ;
    schema1:name "r-tcga2stat" ;
    schema1:url "http://www.liuzlab.org/TCGA2STAT/" .

