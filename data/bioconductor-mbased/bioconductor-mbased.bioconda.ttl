@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-mbased a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s13059-014-0405-3" ;
    schema1:description "Package containing functions for ASE analysis using Meta-analysis Based Allele-Specific Expression Detection" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/MBASED_1.40.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/MBASED/MBASED_1.40.0.tar.gz', 'https://bioarchive.galaxyproject.org/MBASED_1.40.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-mbased/bioconductor-mbased_1.40.0_src_all.tar.gz']" ;
    schema1:identifier biotools:mbased ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-mbased" ;
    schema1:softwareVersion "1.40.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/MBASED.html" ;
    spdx:builtFrom biotools:mbased .

