@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-mbased a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s13059-014-0405-3" ;
    schema1:description "The package implements the corresponding algorithm for detecting allele-specific gene expression from rna count data, where allele counts at individual loci (snvs) are integrated into a gene-specific measure of ase, and utilizes simulations to appropriately assess the statistical significance of observed ase." ;
    schema1:identifier biotools:mbased ;
    schema1:keywords "Alleles",
        "Binomial Distribution",
        "Computational Biology",
        "Gene Expression",
        "Gene Expression Regulation, Neoplastic",
        "Gene expression",
        "Humans",
        "Neoplasms",
        "Polymorphism, Single Nucleotide",
        "RNA-Seq",
        "Sequence Analysis, RNA",
        "Tumor Cells, Cultured" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-mbased" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/MBASED.html" .

