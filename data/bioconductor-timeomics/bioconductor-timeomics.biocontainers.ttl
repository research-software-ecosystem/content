@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-timeomics a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18129/b9.bioc.timeomics" ;
    schema1:description "Time-Course Multi-Omics data integration" ;
    schema1:keywords "Clustering",
        "Genomics",
        "Metabolomics",
        "Metagenomics",
        "Proteomics" ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-timeomics" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/timeOmics.html" .

