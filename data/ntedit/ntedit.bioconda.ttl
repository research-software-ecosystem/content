@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:ntedit a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btz400" ;
    schema1:description "Ultrafast, lightweight, scalable genome assembly polishing, and SNV detection & annotation" ;
    schema1:downloadUrl "https://github.com/BirolLab/ntEdit/releases/download/v2.1.1/ntEdit-2.1.1.tar.gz" ;
    schema1:identifier biotools:ntEdit ;
    schema1:license "GPL-3.0-or-later" ;
    schema1:name "ntedit" ;
    schema1:softwareHelp "https://github.com/BirolLab/ntEdit/blob/master/README.md" ;
    schema1:softwareVersion "2.1.1" ;
    schema1:url "https://github.com/BirolLab/ntEdit" ;
    spdx:builtFrom biotools:ntEdit .

