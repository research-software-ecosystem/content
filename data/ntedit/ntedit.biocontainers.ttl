@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:ntedit a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btz400" ;
    schema1:description "ultra fast, scalable genome assembly polishing and snv detection" ;
    schema1:keywords "Animals",
        "Genome, Human",
        "Genomics",
        "Haploidy",
        "High-Throughput Nucleotide Sequencing",
        "Humans",
        "Sequence Analysis, DNA" ;
    schema1:license "GPL-3.0" ;
    schema1:name "ntedit" ;
    schema1:url "https://github.com/bcgsc/ntEdit" .

