@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:metacherchant a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btx681" ;
    schema1:description "Genomic environmSent analysis tool" ;
    schema1:keywords "Bacteria",
        "Drug Resistance, Bacterial",
        "Gastrointestinal Microbiome",
        "Genomics",
        "Humans",
        "Metagenome",
        "Metagenomics" ;
    schema1:license "MIT" ;
    schema1:name "metacherchant" ;
    schema1:url "https://github.com/ctlab/metacherchant" .

