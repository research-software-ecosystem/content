@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:peptide-shaker a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nbt.3109" ;
    schema1:description "Independent platform for interpretation of proteomics identification results." ;
    schema1:downloadUrl "https://genesis.ugent.be/maven2/eu/isas/peptideshaker/PeptideShaker/3.0.11/PeptideShaker-3.0.11.zip" ;
    schema1:identifier biotools:peptide-shaker ;
    schema1:license "Apache-2.0" ;
    schema1:name "peptide-shaker" ;
    schema1:softwareHelp "https://github.com/compomics/peptide-shaker/blob/master/README.md" ;
    schema1:softwareVersion "3.0.11" ;
    schema1:url "https://compomics.github.io/projects/peptide-shaker.html" ;
    spdx:builtFrom biotools:peptide-shaker .

