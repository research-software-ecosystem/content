@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-rtrm a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/gkt913" ;
    schema1:description "Identification of transcriptional regulatory modules from PPI networks" ;
    schema1:identifier biotools:rtrm ;
    schema1:keywords "Animals",
        "Binding Sites",
        "Embryonic Stem Cells",
        "Gene Regulatory Networks",
        "Hematopoietic Stem Cells",
        "Humans",
        "Mice",
        "Protein Interaction Mapping",
        "Protein interactions",
        "Rats",
        "Transcription Factors",
        "Transcription, Genetic" ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-rtrm" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/rTRM.html" .

