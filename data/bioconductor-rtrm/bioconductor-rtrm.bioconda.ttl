@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-rtrm a schema1:SoftwareApplication ;
    schema1:description "Identification of Transcriptional Regulatory Modules from Protein-Protein Interaction Networks" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/rTRM_1.48.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/rTRM/rTRM_1.48.0.tar.gz', 'https://bioarchive.galaxyproject.org/rTRM_1.48.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-rtrm/bioconductor-rtrm_1.48.0_src_all.tar.gz']" ;
    schema1:identifier biotools:rtrm ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-rtrm" ;
    schema1:softwareVersion "1.48.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/rTRM.html" ;
    spdx:builtFrom biotools:rtrm .

