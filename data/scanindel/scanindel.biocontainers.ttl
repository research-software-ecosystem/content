@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:scanindel a schema1:SoftwareApplication ;
    schema1:description "Scanindel is a python program to detect indels (insertions and deletions) from ngs data by re-align and de novo assemble soft clipped reads." ;
    schema1:license "GNU General Public License v3.0" ;
    schema1:name "scanindel" ;
    schema1:url "https://github.com/cauyrd/ScanIndel" .

