@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:c-ares a schema1:SoftwareApplication ;
    schema1:description "c-ares is a C library for asynchronous DNS requests (including name resolves)" ;
    schema1:license "MIT" ;
    schema1:name "c-ares" ;
    schema1:url "https://github.com/c-ares/c-ares" .

