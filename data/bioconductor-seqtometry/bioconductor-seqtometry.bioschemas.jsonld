  "@graph": [
    {
      "@id": "https://doi.org/10.1016/j.cels.2023.12.005",
      "@type": "sc:CreativeWork"
    },
    {
      "@id": "https://bio.tools/bioconductor-seqtometry",
      "@type": "sc:SoftwareApplication",
      "dcterms:conformsTo": "https://bioschemas.org/profiles/ComputationalTool/0.6-DRAFT",
      "sc:additionalType": [
        "Command-line tool",
        "Library"
      ],
      "sc:author": "Robert Kousnetsov",
      "sc:citation": {
        "@id": "https://doi.org/10.1016/j.cels.2023.12.005"
      },
      "sc:contributor": "Daniel Hawiger",
      "sc:description": "This package provides functions used in Seqtometry (Kousnetsov et al. 2024), a method for analyzing single cell (scRNA-seq or scATAC-seq) data via signature (gene set) enrichment scores. The Seqtometry scores may be useful for annotating or characterizing cells, either in a flow cytometry like workflow (where scores are standalone features used for progressive partitoning as described in the Seqtometry publication) or in a cluster-based workflow (as features of clusters). The exported impute function (a port of Python's MAGIC-impute, van Dijk et al. 2018), may also be useful for single cell analysis on its own.",
      "sc:funder": "Daniel Hawiger",
      "sc:license": "MIT",
      "sc:name": "Seqtometry",
      "sc:operatingSystem": [
        "Linux",
        "Mac",
        "Windows"
      ],
      "sc:softwareHelp": {
        "@id": "https://bioconductor.org/packages/Seqtometry"
      },
      "sc:softwareVersion": "1.0.0",
      "sc:url": "https://bioconductor.org/packages/Seqtometry"
    }
  ]
