@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-riboseqr a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1080/15476286.2016.1141862" ;
    schema1:description "Analysis of sequencing data from ribosome profiling experiments" ;
    schema1:identifier biotools:riboseqr ;
    schema1:keywords "Genetics",
        "High-Throughput Nucleotide Sequencing",
        "Protein Biosynthesis",
        "Proteomics",
        "RNA, Messenger",
        "Ribosomes",
        "Sequence Alignment",
        "Sequence Analysis, RNA",
        "Sequencing",
        "Web Browser" ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-riboseqr" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/riboSeqR.html" .

