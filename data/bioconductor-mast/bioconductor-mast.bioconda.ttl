@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-mast a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s13059-015-0844-5" ;
    schema1:description "Model-based Analysis of Single Cell Transcriptomics" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/MAST_1.36.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/MAST/MAST_1.36.0.tar.gz', 'https://bioarchive.galaxyproject.org/MAST_1.36.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-mast/bioconductor-mast_1.36.0_src_all.tar.gz']" ;
    schema1:identifier biotools:mast ;
    schema1:license "GPL(>= 2)" ;
    schema1:name "bioconductor-mast" ;
    schema1:softwareVersion "1.36.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/MAST.html" ;
    spdx:builtFrom biotools:mast .

