@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-mast a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s13059-015-0844-5" ;
    schema1:description "Model-based Analysis of Single Cell Transcriptomics" ;
    schema1:identifier biotools:mast ;
    schema1:keywords "Animals",
        "Data Interpretation, Statistical",
        "Dendritic Cells",
        "Gene Expression Profiling",
        "Genetic Variation",
        "Humans",
        "Linear Models",
        "Mice",
        "Sequence Analysis, RNA",
        "Single-Cell Analysis",
        "Transcriptome",
        "Transcriptomics" ;
    schema1:license "GPL(>= 2)" ;
    schema1:name "bioconductor-mast" ;
    schema1:url "http://bioconductor.org/packages/3.6/bioc/html/MAST.html" .

