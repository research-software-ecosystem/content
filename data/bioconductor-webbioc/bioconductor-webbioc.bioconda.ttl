@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-webbioc a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1007/0-387-29362-0_18" ;
    schema1:description "Bioconductor Web Interface" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/webbioc_1.82.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/webbioc/webbioc_1.82.0.tar.gz', 'https://bioarchive.galaxyproject.org/webbioc_1.82.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-webbioc/bioconductor-webbioc_1.82.0_src_all.tar.gz']" ;
    schema1:identifier biotools:webbioc ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-webbioc" ;
    schema1:softwareVersion "1.82.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/webbioc.html" ;
    spdx:builtFrom biotools:webbioc .

