@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-webbioc a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1007/0-387-29362-0_18" ;
    schema1:description "Bioconductor Web Interface" ;
    schema1:identifier biotools:webbioc ;
    schema1:keywords "Gene expression",
        "Microarray experiment" ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-webbioc" ;
    schema1:url "http://bioconductor.org/packages/3.6/bioc/html/webbioc.html" .

