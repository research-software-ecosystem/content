@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:hmftools-isofox a schema1:SoftwareApplication ;
    schema1:description "Isofox is a tool for counting fragment support for identifying and counting gene and transcript features using genome aligned rnaseq data in tumor samples." ;
    schema1:keywords "Genomics" ;
    schema1:license "Not available" ;
    schema1:name "hmftools-isofox" ;
    schema1:url "https://github.com/hartwigmedical/hmftools/tree/master/isofox" .

