      "sc:citation": {
        "@id": "https://doi.org/10.18129/B9.bioc.MoleculeExperiment"
      },
      "sc:description": "MoleculeExperiment contains functions to create and work with objects from the new MoleculeExperiment class. We introduce this class for analysing molecule-based spatial transcriptomics data (e.g., Xenium by 10X, Cosmx SMI by Nanostring, and Merscope by Vizgen). This allows researchers to analyse spatial transcriptomics data at the molecule level, and to have standardised data formats accross vendors.",
      "sc:license": "MIT",
      "sc:name": "MoleculeExperiment",
      "sc:operatingSystem": [
        "Linux",
        "Windows",
        "Mac"
      ],
      "sc:softwareHelp": {
        "@id": "https://bioconductor.org/packages/MoleculeExperiment"
      },
      "sc:softwareVersion": "1.10.0",
      "sc:url": "https://bioconductor.org/packages/MoleculeExperiment"
    }
  ]
