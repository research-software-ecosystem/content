@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:mquad a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/s41467-022-28845-0" ;
    schema1:description "MQuad: Mixture Model for Mitochondrial Mutation detection in single-cell omics data." ;
    schema1:identifier biotools:mquad ;
    schema1:license "Apache-2.0" ;
    schema1:name "mquad" ;
    schema1:softwareHelp "https://github.com/single-cell-genetics/MQuad/blob/main/README.rst" ;
    schema1:softwareVersion "0.1.8b" ;
    schema1:url "https://github.com/aaronkwc/MQuad" ;
    spdx:builtFrom biotools:mquad .

