@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:lagan a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1101/gr.926603" ;
    schema1:description "Tools for genomic alignment. these include the mlagan multiple alignment tool, and shuffle-lagan for alignment with rearrangements.. all three are based on the chaos local alignment tool and combine speed (regions up to several megabases can be aligned in minutes) with high accuracy." ;
    schema1:identifier biotools:lagan ;
    schema1:keywords "Animals",
        "Base Sequence",
        "Cattle",
        "Chickens",
        "Comparative genomics",
        "Dogs",
        "Genome",
        "Genome, Human",
        "Genomics",
        "Humans",
        "Mice",
        "Molecular Sequence Data",
        "Nucleic acid structure analysis",
        "Pan troglodytes",
        "Papio",
        "Rats",
        "Sequence Alignment",
        "Sequence Analysis, DNA",
        "Sequence Homology, Nucleic Acid",
        "Swine",
        "Takifugu",
        "Zebrafish" ;
    schema1:license "custom, see /usr/share/doc/lagan/copyright" ;
    schema1:name "lagan" ;
    schema1:url "http://lagan.stanford.edu/lagan_web/index.shtml" .

