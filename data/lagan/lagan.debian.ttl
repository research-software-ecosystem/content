@prefix debianmed: <https://salsa.debian.org/med-team/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

debianmed:lagan a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1101/gr.926603" ;
    schema1:description "highly parametrizable pairwise global genome sequence aligner" ;
    schema1:identifier "bio.tools:LAGAN",
        "omictools:OMICS_08469",
        "scicrunch:SCR_008558" ;
    schema1:license "unknown" ;
    schema1:name "lagan" ;
    schema1:softwareVersion "2.0" ;
    schema1:url "http://lagan.stanford.edu/lagan_web/index.shtml" ;
    spdx:builtFrom "LAGAN" .

