@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:varscan a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btp373" ;
    schema1:description "Varscan, an open source tool for variant detection that is compatible with several short read align-ers." ;
    schema1:identifier biotools:varscan ;
    schema1:keywords "Computational Biology",
        "DNA polymorphism",
        "Humans",
        "Polymorphism, Single Nucleotide",
        "Sequence Analysis, DNA",
        "Sequencing" ;
    schema1:license "The Non-Profit Open Software License version 3.0 (NPOSL-3.0)" ;
    schema1:name "varscan" ;
    schema1:url "https://github.com/dkoboldt/varscan" .

