@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:varscan a schema1:SoftwareApplication ;
    schema1:description "variant detection in massively parallel sequencing data" ;
    schema1:downloadUrl "https://github.com/dkoboldt/varscan/raw/master/VarScan.v2.4.6.jar" ;
    schema1:identifier biotools:varscan ;
    schema1:license "The Non-Profit Open Software License version 3.0 (NPOSL-3.0)" ;
    schema1:name "varscan" ;
    schema1:softwareVersion "2.4.6" ;
    schema1:url "http://dkoboldt.github.io/varscan/" ;
    spdx:builtFrom biotools:varscan .

