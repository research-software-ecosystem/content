@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:primedrpa a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/bty701" ;
    schema1:description "Rpa primer & probe design tool." ;
    schema1:keywords "Computational Biology",
        "DNA Primers",
        "Nucleic Acid Amplification Techniques",
        "Recombinases",
        "Sequence Alignment" ;
    schema1:license "GPL-3.0" ;
    schema1:name "primedrpa" ;
    schema1:url "https://github.com/MatthewHiggins2017/bioconda-PrimedRPA/" .

