@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-drimseq a schema1:SoftwareApplication ;
    schema1:description "Differential transcript usage and tuQTL analyses with Dirichlet-multinomial model in RNA-seq" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/DRIMSeq_1.34.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/DRIMSeq/DRIMSeq_1.34.0.tar.gz', 'https://bioarchive.galaxyproject.org/DRIMSeq_1.34.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-drimseq/bioconductor-drimseq_1.34.0_src_all.tar.gz']" ;
    schema1:identifier biotools:drimseq ;
    schema1:license "GPL (>= 3)" ;
    schema1:name "bioconductor-drimseq" ;
    schema1:softwareVersion "1.34.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/DRIMSeq.html" ;
    spdx:builtFrom biotools:drimseq .

