@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-drimseq a schema1:SoftwareApplication ;
    schema1:citation "doi:10.12688/f1000research.8900.2" ;
    schema1:description "Differential transcript usage and tuQTL analyses with Dirichlet-multinomial model in RNA-seq" ;
    schema1:identifier biotools:drimseq ;
    schema1:keywords "Genetics",
        "RNA-Seq",
        "RNA-seq",
        "Sequence analysis",
        "Transcription factors and regulatory sites" ;
    schema1:license "GPL-3.0" ;
    schema1:name "bioconductor-drimseq" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/DRIMSeq.html" .

