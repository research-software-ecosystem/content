@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:pytaxonkit a schema1:SoftwareApplication ;
    schema1:description "Python bindings for the taxonkit library." ;
    schema1:license "Not available" ;
    schema1:name "pytaxonkit" ;
    schema1:url "https://github.com/bioforensics/pytaxonkit/" .

