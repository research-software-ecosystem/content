@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:goslimmer a schema1:SoftwareApplication ;
    schema1:description "Goslimmer transforms go annotations to a slimmed version of go" ;
    schema1:license "Apache-2.0" ;
    schema1:name "goslimmer" ;
    schema1:url "https://github.com/DanFaria/GOSlimmer" .

