@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-variancepartition a schema1:SoftwareApplication ;
    schema1:description "Quantify and interpret drivers of variation in multilevel gene expression experiments" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/variancePartition_1.36.2.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/variancePartition/variancePartition_1.36.2.tar.gz', 'https://bioarchive.galaxyproject.org/variancePartition_1.36.2.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-variancepartition/bioconductor-variancepartition_1.36.2_src_all.tar.gz']" ;
    schema1:identifier biotools:variancepartition ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-variancepartition" ;
    schema1:softwareVersion "1.36.2" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/variancePartition.html" ;
    spdx:builtFrom biotools:variancepartition .

