@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-variancepartition a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s12859-016-1323-z" ;
    schema1:description "Quantify and interpret divers of variation in multilevel gene expression experiments" ;
    schema1:identifier biotools:variancepartition ;
    schema1:keywords "Computational Biology",
        "Gene Expression",
        "Gene Expression Profiling",
        "Gene Expression Regulation",
        "Gene expression",
        "Genetic Variation",
        "Genomics",
        "High-Throughput Nucleotide Sequencing",
        "Humans",
        "Linear Models",
        "RNA-seq",
        "Sequence Analysis, RNA" ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-variancepartition" ;
    schema1:url "http://bioconductor.org/packages/3.6/bioc/html/variancePartition.html" .

