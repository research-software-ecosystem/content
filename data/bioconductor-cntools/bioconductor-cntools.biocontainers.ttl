@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-cntools a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Convert segment data into a region by sample matrix to allow for other high level computational analyses." ;
    schema1:identifier biotools:cntools ;
    schema1:keywords "Computational Biology",
        "Gene Expression Profiling",
        "Genomics",
        "High-Throughput Screening Assays",
        "Programming Languages",
        "Sequence analysis",
        "User-Computer Interface" ;
    schema1:license "LGPL" ;
    schema1:name "bioconductor-cntools" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/CNTools.html" .

