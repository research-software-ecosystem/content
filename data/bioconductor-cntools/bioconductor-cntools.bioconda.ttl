@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-cntools a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Convert segment data into a region by sample matrix to allow for other high level computational analyses." ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/CNTools_1.66.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/CNTools/CNTools_1.66.0.tar.gz', 'https://bioarchive.galaxyproject.org/CNTools_1.66.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-cntools/bioconductor-cntools_1.66.0_src_all.tar.gz']" ;
    schema1:identifier biotools:cntools ;
    schema1:license "LGPL" ;
    schema1:name "bioconductor-cntools" ;
    schema1:softwareVersion "1.66.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/CNTools.html" ;
    spdx:builtFrom biotools:cntools .

