@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:mapdamage a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btr347" ;
    schema1:description "Identify and quantify dna damage patterns in ancient dna." ;
    schema1:identifier biotools:mapdamage ;
    schema1:keywords "Base Sequence",
        "Computational Biology",
        "DNA",
        "DNA Contamination",
        "DNA Damage",
        "DNA Restriction Enzymes",
        "Genetics",
        "Genome, Human",
        "Humans",
        "Paleontology",
        "Reference Standards",
        "Sequence Analysis, DNA",
        "Sequencing" ;
    schema1:license "expat" ;
    schema1:name "mapdamage" ;
    schema1:url "http://ginolhac.github.io/mapDamage/" .

