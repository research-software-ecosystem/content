@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:taxopy a schema1:SoftwareApplication ;
    schema1:description "A python package for obtaining complete lineages and the lowest common ancestor (lca) from a set of taxonomic identifiers." ;
    schema1:keywords "Metagenome" ;
    schema1:license "GPL-3.0" ;
    schema1:name "taxopy" ;
    schema1:url "https://github.com/apcamargo/taxopy" .

