@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:fastq-multx a schema1:SoftwareApplication ;
    schema1:description "Demultiplexes a fastq. Capable of auto-determining barcode id's based on a master set fields. Keeps multiple reads in-sync during demultiplexing. Can verify that the reads are in-sync as well, and fail if they're not." ;
    schema1:license "MIT" ;
    schema1:name "fastq-multx" ;
    schema1:url "https://github.com/brwnj/fastq-multx" .

