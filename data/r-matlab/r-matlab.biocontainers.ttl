@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-matlab a schema1:SoftwareApplication ;
    schema1:description "Emulate MATLAB code using R." ;
    schema1:license "Artistic-2.0" ;
    schema1:name "r-matlab" ;
    schema1:url "https://cran.rstudio.com/web/packages/matlab/index.html" .

