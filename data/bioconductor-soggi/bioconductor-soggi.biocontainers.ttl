@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-soggi a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Visualise ChIP-seq, MNase-seq and motif occurrence as aggregate plots Summarised Over Grouped Genomic Intervals" ;
    schema1:identifier biotools:soggi ;
    schema1:keywords "ChIP-seq",
        "Computational Biology",
        "Data visualisation",
        "Gene Expression Profiling",
        "Genomics",
        "High-Throughput Screening Assays",
        "Programming Languages",
        "Sequence sites, features and motifs",
        "User-Computer Interface" ;
    schema1:license "GPL-3.0" ;
    schema1:name "bioconductor-soggi" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/soGGi.html" .

