@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-soggi a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Visualise ChIP-seq, MNase-seq and motif occurrence as aggregate plots Summarised Over Grouped Genomic Intervals" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/soGGi_1.38.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/soGGi/soGGi_1.38.0.tar.gz', 'https://bioarchive.galaxyproject.org/soGGi_1.38.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-soggi/bioconductor-soggi_1.38.0_src_all.tar.gz']" ;
    schema1:identifier biotools:soggi ;
    schema1:license "GPL (>= 3)" ;
    schema1:name "bioconductor-soggi" ;
    schema1:softwareVersion "1.38.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/soGGi.html" ;
    spdx:builtFrom biotools:soggi .

