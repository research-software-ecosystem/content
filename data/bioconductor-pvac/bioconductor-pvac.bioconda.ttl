@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-pvac a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/gkr241" ;
    schema1:description "PCA-based gene filtering for Affymetrix arrays" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/pvac_1.58.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/pvac/pvac_1.58.0.tar.gz', 'https://bioarchive.galaxyproject.org/pvac_1.58.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-pvac/bioconductor-pvac_1.58.0_src_all.tar.gz']" ;
    schema1:identifier biotools:pvac ;
    schema1:license "LGPL (>= 2.0)" ;
    schema1:name "bioconductor-pvac" ;
    schema1:softwareVersion "1.58.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/pvac.html" ;
    spdx:builtFrom biotools:pvac .

