@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-pvac a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/gkr241" ;
    schema1:description "PCA-based gene filtering for Affymetrix arrays" ;
    schema1:identifier biotools:pvac ;
    schema1:keywords "Animals",
        "Diabetic Cardiomyopathies",
        "Gene Expression Profiling",
        "Genetic variation",
        "Oligonucleotide Array Sequence Analysis",
        "Principal Component Analysis",
        "Rats" ;
    schema1:license "LGPL (>= 2.0)" ;
    schema1:name "bioconductor-pvac" ;
    schema1:url "http://bioconductor.org/packages/3.5/bioc/html/pvac.html" .

