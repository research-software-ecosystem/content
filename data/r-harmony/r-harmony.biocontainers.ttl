@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-harmony a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/s41592-019-0619-0" ;
    schema1:description "Fast, sensitive and accurate integration of single-cell data with Harmony" ;
    schema1:keywords "Genomics",
        "RNA-Seq" ;
    schema1:license "GPL-3.0-only" ;
    schema1:name "r-harmony" ;
    schema1:url "https://github.com/immunogenomics/harmony" .

