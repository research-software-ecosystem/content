@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:metaquant a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btl526" ;
    schema1:description "Quantitative microbiome analysis" ;
    schema1:keywords "Artificial Intelligence",
        "Gas Chromatography-Mass Spectrometry",
        "Gene Expression Profiling",
        "Peptide Mapping",
        "Proteome",
        "User-Computer Interface" ;
    schema1:license "Apache" ;
    schema1:name "metaquant" ;
    schema1:url "https://github.com/caleb-easterly/metaquant" .

