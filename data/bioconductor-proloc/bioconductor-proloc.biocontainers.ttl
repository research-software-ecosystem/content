@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-proloc a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1371/journal.pcbi.1004920" ;
    schema1:description "A unifying bioinformatics framework for spatial proteomics" ;
    schema1:identifier biotools:proloc ;
    schema1:keywords "Animals",
        "Arabidopsis",
        "Clustering",
        "Computational Biology",
        "Data Interpretation, Statistical",
        "Drosophila",
        "Embryonic Stem Cells",
        "Humans",
        "Information Storage and Retrieval",
        "Machine learning",
        "Mass Spectrometry",
        "Mass spectrometry",
        "Mice",
        "Proteome",
        "Proteomics",
        "Proteomics experiment",
        "Subcellular Fractions",
        "Support Vector Machine" ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-proloc" ;
    schema1:url "http://bioconductor.org/packages/3.6/bioc/html/pRoloc.html" .

