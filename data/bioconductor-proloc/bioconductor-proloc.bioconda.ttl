@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-proloc a schema1:SoftwareApplication ;
    schema1:description "A unifying bioinformatics framework for spatial proteomics" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/pRoloc_1.50.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/pRoloc/pRoloc_1.50.0.tar.gz', 'https://bioarchive.galaxyproject.org/pRoloc_1.50.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-proloc/bioconductor-proloc_1.50.0_src_all.tar.gz']" ;
    schema1:identifier biotools:proloc ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-proloc" ;
    schema1:softwareVersion "1.50.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/pRoloc.html" ;
    spdx:builtFrom biotools:proloc .

