@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:kofamscan a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btz859" ;
    schema1:description "KofamKOALA assigns K numbers to the user's sequence data by HMMER/HMMSEARCH against KOfam" ;
    schema1:keywords "Amino Acid Sequence",
        "Computers",
        "Databases, Factual",
        "Ortholog" ;
    schema1:license "MIT" ;
    schema1:name "kofamscan" ;
    schema1:url "https://www.genome.jp/tools/kofamkoala/" .

