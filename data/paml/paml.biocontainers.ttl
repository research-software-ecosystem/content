@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:paml a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/13.5.555",
        "doi:10.1093/molbev/msm088",
        "doi:10.1093/molbev/mst179" ;
    schema1:description "Package of programs for phylogenetic analyses of dna or protein sequences using maximum likelihood." ;
    schema1:identifier biotools:paml ;
    schema1:keywords "Computational Biology",
        "Databases, Genetic",
        "Evolution, Molecular",
        "Internet",
        "Likelihood Functions",
        "Phylogenetics",
        "Phylogeny",
        "Protein Sequences",
        "Sequence analysis",
        "User-Computer Interface" ;
    schema1:license "GPL-3.0" ;
    schema1:name "paml" ;
    schema1:url "http://abacus.gene.ucl.ac.uk/software/paml.html" .

