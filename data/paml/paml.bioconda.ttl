@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:paml a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/13.5.555" ;
    schema1:description "A package of programs for phylogenetic analyses of DNA or protein sequences using maximum likelihood." ;
    schema1:downloadUrl "https://github.com/abacus-gene/paml/archive/refs/tags/v4.10.10.tar.gz" ;
    schema1:identifier biotools:paml ;
    schema1:license "GPL-3.0-or-later" ;
    schema1:name "paml" ;
    schema1:softwareHelp "https://github.com/abacus-gene/paml/wiki" ;
    schema1:softwareVersion "4.10.10" ;
    schema1:url "https://evomics.org/resources/software/molecular-evolution-software/paml" ;
    spdx:builtFrom biotools:paml .

