@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-goeveg a schema1:SoftwareApplication ;
    schema1:description "A collection of functions useful in (vegetation) community analyses and ordinations, mainly to facilitate plotting and interpretation. Includes automatic species selection for ordination diagrams, species response curves and rank-abundance curves." ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "r-goeveg" ;
    schema1:url "http://github.com/fgoral/goeveg" .

