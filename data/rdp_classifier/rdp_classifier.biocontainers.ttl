@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:rdp_classifier a schema1:SoftwareApplication ;
    schema1:description "Naive Bayesian classifier that can rapidly and accurately provide taxonomic assignments from domain to genus" ;
    schema1:license "GPL" ;
    schema1:name "rdp_classifier" ;
    schema1:url "http://rdp.cme.msu.edu/" .

