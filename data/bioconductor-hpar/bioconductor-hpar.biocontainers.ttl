@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-hpar a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "A simple interface to and data from the human protein atlas project." ;
    schema1:identifier biotools:hpar ;
    schema1:keywords "Computational Biology",
        "Gene Expression Profiling",
        "Gene and protein families",
        "Genomics",
        "High-Throughput Screening Assays",
        "Programming Languages",
        "Proteins",
        "Proteomics",
        "User-Computer Interface" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-hpar" ;
    schema1:url "http://bioconductor.org/packages/release/bioc/html/hpar.html" .

