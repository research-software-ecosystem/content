@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-hpar a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Human Protein Atlas in R" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/hpar_1.52.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/hpar/hpar_1.52.0.tar.gz', 'https://bioarchive.galaxyproject.org/hpar_1.52.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-hpar/bioconductor-hpar_1.52.0_src_all.tar.gz']" ;
    schema1:identifier biotools:hpar ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-hpar" ;
    schema1:softwareVersion "1.52.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/hpar.html" ;
    spdx:builtFrom biotools:hpar .

