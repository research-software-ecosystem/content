@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:selscan a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/molbev/msu211" ;
    schema1:description "a program to calculate EHH-based scans for positive selection in genomes" ;
    schema1:identifier biotools:selscan ;
    schema1:keywords "Chromosomes, Human, Pair 22",
        "Genetics",
        "Genome",
        "Haplotypes",
        "Humans",
        "Population genetics",
        "Selection, Genetic" ;
    schema1:license "GPL-3.0" ;
    schema1:name "selscan" ;
    schema1:url "https://github.com/szpiech/selscan" .

