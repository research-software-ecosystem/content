@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:selscan a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/molbev/msu211" ;
    schema1:description "a program to calculate EHH-based scans for positive selection in genomes" ;
    schema1:downloadUrl "https://github.com/szpiech/selscan/archive/1.2.0a.tar.gz" ;
    schema1:identifier biotools:selscan ;
    schema1:license "GPL-3.0" ;
    schema1:name "selscan" ;
    schema1:softwareVersion "1.2.0a" ;
    schema1:url "https://github.com/szpiech/selscan" ;
    spdx:builtFrom biotools:selscan .

