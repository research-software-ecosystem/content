@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-omicsprint a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18129/b9.bioc.omicsprint" ;
    schema1:description "Cross omic genetic fingerprinting" ;
    schema1:keywords "Genetics",
        "Transcriptomics" ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-omicsprint" ;
    schema1:url "https://bioconductor.org/packages/3.8/bioc/html/omicsPrint.html" .

