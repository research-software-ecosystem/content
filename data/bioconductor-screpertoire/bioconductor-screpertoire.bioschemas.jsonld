  "@graph": [
    {
      "@id": "https://bio.tools/bioconductor-screpertoire",
      "@type": "sc:SoftwareApplication",
      "dcterms:conformsTo": "https://bioschemas.org/profiles/ComputationalTool/0.6-DRAFT",
      "sc:additionalType": [
        "Library",
        "Command-line tool"
      ],
      "sc:author": [
        "Ksenia Safina",
        "Qile Yang",
        "Nick Borcherding"
      ],
      "sc:citation": [
        {
          "@id": "https://doi.org/10.1371/journal.pcbi.1012760"
        },
        {
          "@id": "https://doi.org/10.12688/f1000research.22139.2"
        }
      ],
      "sc:contributor": "Justin Reimertz",
      "sc:description": "scRepertoire is a toolkit for processing and analyzing single-cell T-cell receptor (TCR) and immunoglobulin (Ig). The scRepertoire framework supports use of 10x, AIRR, BD, MiXCR, TRUST4, and WAT3R single-cell formats. The functionality includes basic clonal analyses, repertoire summaries, distance-based clustering and interaction with the popular Seurat and SingleCellExperiment/Bioconductor R single-cell workflows.",
      "sc:license": "MIT",
      "sc:name": "scRepertoire",
      "sc:operatingSystem": [
        "Linux",
        "Mac",
        "Windows"
      ],
      "sc:softwareHelp": {
