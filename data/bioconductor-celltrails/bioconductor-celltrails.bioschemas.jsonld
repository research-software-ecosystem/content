  "@graph": [
    {
      "@id": "https://bio.tools/bioconductor-celltrails",
      "@type": "sc:SoftwareApplication",
      "dcterms:conformsTo": "https://bioschemas.org/profiles/ComputationalTool/0.6-DRAFT",
      "sc:additionalType": [
        "Command-line tool",
        "Library"
      ],
      "sc:author": "Daniel Ellwanger",
      "sc:citation": {
        "@id": "https://doi.org/10.1016/j.celrep.2018.05.002"
      },
      "sc:description": "CellTrails is an unsupervised algorithm for the de novo chronological ordering, visualization and analysis of single-cell expression data. CellTrails makes use of a geometrically motivated concept of lower-dimensional manifold learning, which exhibits a multitude of virtues that counteract intrinsic noise of single cell data caused by drop-outs, technical variance, and redundancy of predictive variables. CellTrails enables the reconstruction of branching trajectories and provides an intuitive graphical representation of expression patterns along all branches simultaneously. It allows the user to define and infer the expression dynamics of individual and multiple pathways towards distinct phenotypes.",
      "sc:license": "Artistic-2.0",
      "sc:name": "CellTrails",
      "sc:operatingSystem": [
        "Linux",
        "Windows",
        "Mac"
      ],
      "sc:softwareHelp": {
        "@id": "https://bioconductor.org/packages/CellTrails"
      },
      "sc:softwareVersion": "1.28.0",
      "sc:url": "https://bioconductor.org/packages/CellTrails"
    },
    {
      "@id": "https://doi.org/10.1016/j.celrep.2018.05.002",
      "@type": "sc:CreativeWork"
    }
  ]
