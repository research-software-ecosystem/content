@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-whopgenome a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btu636" ;
    schema1:description "Provides very fast access to whole genome, population scale variation data from VCF" ;
    schema1:keywords "Genetic Variation",
        "Genome, Human",
        "Genomics",
        "Humans",
        "Molecular Sequence Annotation" ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "r-whopgenome" ;
    schema1:url "https://CRAN.R-project.org/package=WhopGenome" .

