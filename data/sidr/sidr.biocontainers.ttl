@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:sidr a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s12859-017-1941-0" ;
    schema1:description "Sequence idenification using decision trees; a tool to classify dna reads using machine learning models." ;
    schema1:identifier biotools:sidr ;
    schema1:keywords "Animals",
        "Base Composition",
        "Caenorhabditis",
        "DNA",
        "DNA, Helminth",
        "Databases, Genetic",
        "Genome",
        "High-Throughput Nucleotide Sequencing",
        "Machine Learning",
        "Sequence Analysis, DNA",
        "Sequencing" ;
    schema1:license "Not available" ;
    schema1:name "sidr" ;
    schema1:url "https://github.com/damurdock/SIDR" .

