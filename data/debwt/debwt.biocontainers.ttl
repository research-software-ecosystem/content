@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:debwt a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btw266" ;
    schema1:description "A efficient method to construct bwt index of a given dna sequence, especially\\nuseful for gigantic and high similar genome. debwt has good scalability to construct bwt in parallel computing. it is well-suited to run on multiple core servers or clusters to\\nconstruct the bwt of large collections of genome sequences." ;
    schema1:keywords "Genome, Human",
        "Genomics",
        "Humans",
        "Programming Languages",
        "Sequence Analysis, DNA" ;
    schema1:license "Not available" ;
    schema1:name "debwt" ;
    schema1:url "https://github.com/DixianZhu/deBWT" .

