@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-qrqc a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Quick Read Quality Control" ;
    schema1:identifier biotools:qrqc ;
    schema1:keywords "Computational Biology",
        "Data visualisation",
        "Gene Expression Profiling",
        "Genomics",
        "High-Throughput Screening Assays",
        "Programming Languages",
        "Sequencing",
        "User-Computer Interface" ;
    schema1:license "GPL-2.0" ;
    schema1:name "bioconductor-qrqc" ;
    schema1:url "https://www.bioconductor.org/packages/release/bioc/html/qrqc.html" .

