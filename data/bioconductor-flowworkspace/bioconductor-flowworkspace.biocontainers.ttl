@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-flowworkspace a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/1471-2105-13-252" ;
    schema1:description "Infrastructure for representing and interacting with gated and ungated cytometry data sets." ;
    schema1:identifier biotools:flowworkspace ;
    schema1:keywords "Cell biology",
        "Data Interpretation, Statistical",
        "Flow Cytometry",
        "Humans" ;
    schema1:license "file LICENSE" ;
    schema1:name "bioconductor-flowworkspace" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/flowWorkspace.html" .

