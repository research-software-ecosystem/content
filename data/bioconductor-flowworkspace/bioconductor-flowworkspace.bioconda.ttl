@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-flowworkspace a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/1471-2105-13-252" ;
    schema1:description "Infrastructure for representing and interacting with gated and ungated cytometry data sets." ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/flowWorkspace_4.18.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/flowWorkspace/flowWorkspace_4.18.0.tar.gz', 'https://bioarchive.galaxyproject.org/flowWorkspace_4.18.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-flowworkspace/bioconductor-flowworkspace_4.18.0_src_all.tar.gz']" ;
    schema1:identifier biotools:flowworkspace ;
    schema1:license "AGPL-3.0-only" ;
    schema1:name "bioconductor-flowworkspace" ;
    schema1:softwareVersion "4.18.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/flowWorkspace.html" ;
    spdx:builtFrom biotools:flowworkspace .

