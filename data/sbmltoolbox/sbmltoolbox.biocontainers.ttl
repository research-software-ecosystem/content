@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:sbmltoolbox a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btl111" ;
    schema1:description "Libsbml toolbox for octave and matlab" ;
    schema1:keywords "Computer Simulation",
        "Database Management Systems",
        "Databases, Factual",
        "Information Storage and Retrieval",
        "Models, Biological",
        "Models, Chemical",
        "Programming Languages",
        "Systems Biology" ;
    schema1:license "LGPL-2.1" ;
    schema1:name "sbmltoolbox" ;
    schema1:url "http://sbml.org/Software/SBMLToolbox" .

