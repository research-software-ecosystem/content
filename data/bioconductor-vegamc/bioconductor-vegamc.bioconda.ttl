bioconda:bioconductor-vegamc a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/bts453" ;
    schema1:description "VegaMC: A Package Implementing a Variational Piecewise Smooth Model for Identification of Driver Chromosomal Imbalances in Cancer" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/VegaMC_3.44.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/VegaMC/VegaMC_3.44.0.tar.gz', 'https://bioarchive.galaxyproject.org/VegaMC_3.44.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-vegamc/bioconductor-vegamc_3.44.0_src_all.tar.gz']" ;
    schema1:identifier biotools:vegamc ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-vegamc" ;
    schema1:softwareVersion "3.44.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/VegaMC.html" ;
    spdx:builtFrom biotools:vegamc .

