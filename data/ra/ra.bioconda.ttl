@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:ra a schema1:SoftwareApplication ;
    schema1:description "Ra is short for RNA Assembler and it is a C++ implementation of an overlap-layout-consensus transcriptome assembler." ;
    schema1:downloadUrl "https://github.com/mariokostelac/ra/archive/v0.9.tar.gz" ;
    schema1:identifier biotools:ra ;
    schema1:license "GPL-3.0-or-later" ;
    schema1:name "ra" ;
    schema1:softwareVersion "0.9" ;
    schema1:url "https://github.com/mariokostelac/ra" ;
    spdx:builtFrom biotools:ra .

