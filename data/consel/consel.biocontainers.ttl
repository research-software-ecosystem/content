@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:consel a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/17.12.1246" ;
    schema1:description "CONSEL calculates the probability value (i.e., p-value) to assess the confidence in the selection problem. Although CONSEL is applicable to any selection problem, it is mainly designed for the phylogenetic tree selection" ;
    schema1:keywords "Genetics" ;
    schema1:license "GNU GENERAL PUBLIC LICENSE Version 2" ;
    schema1:name "consel" ;
    schema1:url "http://stat.sys.i.kyoto-u.ac.jp/prog/consel/" .

