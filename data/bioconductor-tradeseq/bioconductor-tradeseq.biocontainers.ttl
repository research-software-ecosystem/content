@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-tradeseq a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18129/b9.bioc.tradeseq" ;
    schema1:description "Trajectory-based differential expression analysis for sequencing data" ;
    schema1:keywords "Clustering",
        "Transcriptomics" ;
    schema1:license "MIT" ;
    schema1:name "bioconductor-tradeseq" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/tradeSeq.html" .

