@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-sigpathway a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Pathway Analysis" ;
    schema1:identifier biotools:sigpathway ;
    schema1:keywords "Computational Biology",
        "Gene Expression Profiling",
        "Gene expression",
        "Genomics",
        "High-Throughput Screening Assays",
        "Molecular interactions, pathways and networks",
        "Programming Languages",
        "Statistics and probability",
        "User-Computer Interface" ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-sigpathway" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/sigPathway.html" .

