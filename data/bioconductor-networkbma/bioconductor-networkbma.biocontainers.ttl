@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-networkbma a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/1752-0509-8-47" ;
    schema1:description "Regression-based network inference using Bayesian Model Averaging" ;
    schema1:identifier biotools:networkbma ;
    schema1:keywords "Bayes Theorem",
        "Data visualisation",
        "Gene Expression",
        "Gene Regulatory Networks",
        "Gene expression",
        "Genomics",
        "RNA-Seq",
        "Saccharomyces cerevisiae" ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-networkbma" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/networkBMA.html" .

