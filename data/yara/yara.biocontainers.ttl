@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:yara a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/gkt005" ;
    schema1:description "Yara is an exact tool for aligning dna sequencing reads to reference genomes." ;
    schema1:identifier biotools:yara ;
    schema1:keywords "Animals",
        "Caenorhabditis elegans",
        "Chromosome Mapping",
        "Drosophila melanogaster",
        "Escherichia coli",
        "Genetic Variation",
        "Genomics",
        "Humans",
        "Mapping" ;
    schema1:license "https://raw.githubusercontent.com/seqan/seqan/develop/apps/yara/LICENSE" ;
    schema1:name "yara" ;
    schema1:url "http://www.seqan.de/yara/" .

