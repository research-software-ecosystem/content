@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:yara a schema1:SoftwareApplication ;
    schema1:author "eseiler" ;
    schema1:citation "doi:10.1093/nar/gkt005" ;
    schema1:description "Yara is an exact tool for aligning DNA sequencing reads to reference genomes." ;
    schema1:downloadUrl "https://github.com/seqan/seqan/archive/refs/tags/seqan-v2.5.1.tar.gz" ;
    schema1:identifier biotools:yara ;
    schema1:license "BSD 3-Clause" ;
    schema1:maintainer "eseiler" ;
    schema1:name "yara" ;
    schema1:softwareVersion "1.0.5" ;
    schema1:url "https://github.com/seqan/seqan/tree/seqan-v2.5.1/apps/yara/README.rst" ;
    spdx:builtFrom biotools:yara .

