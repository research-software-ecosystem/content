@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:linkage2allegro a schema1:SoftwareApplication ;
    schema1:description "Converts between the output linkage formats of merlin, simwalk, genehunter, and swiftlink into allegro." ;
    schema1:license "Not available" ;
    schema1:name "linkage2allegro" ;
    schema1:url "https://github.com/BioTools-Tek/linkage-converter" .

