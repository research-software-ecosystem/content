@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:verifybamid2 a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1101/gr.246934.118" ;
    schema1:description "A robust tool for DNA contamination estimation from sequence reads using ancestry-agnostic method." ;
    schema1:downloadUrl "https://github.com/Griffan/VerifyBamID/archive/refs/tags/V2.0.2.tar.gz" ;
    schema1:identifier biotools:verifybamid ;
    schema1:license "MIT" ;
    schema1:name "verifybamid2" ;
    schema1:softwareHelp "https://griffan.github.io/VerifyBamID" ;
    schema1:softwareVersion "2.0.2" ;
    schema1:url "https://github.com/Griffan/VerifyBamID" ;
    spdx:builtFrom biotools:verifybamid .

