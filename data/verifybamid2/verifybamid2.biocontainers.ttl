@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:verifybamid2 a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1016/j.ajhg.2012.09.004" ;
    schema1:description "A robust tool for DNA contamination estimation from sequence reads using ancestry-agnostic method." ;
    schema1:identifier biotools:verifybamid ;
    schema1:keywords "DNA Contamination",
        "Data quality management",
        "Diabetes Mellitus, Type 2",
        "Genetic variation",
        "Genetics",
        "Genotype",
        "Humans",
        "Sequence Analysis, DNA" ;
    schema1:license "MIT" ;
    schema1:name "verifybamid2" ;
    schema1:url "https://github.com/Griffan/VerifyBamID" .

