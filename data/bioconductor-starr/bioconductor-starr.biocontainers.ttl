@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-starr a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/1471-2105-11-194" ;
    schema1:description "Simple tiling array analysis of Affymetrix ChIP-chip data" ;
    schema1:identifier biotools:starr ;
    schema1:keywords "ChIP-on-chip",
        "Chromatin Immunoprecipitation",
        "DNA",
        "DNA-Binding Proteins",
        "Data management",
        "Databases, Genetic",
        "Gene Expression",
        "Gene Expression Profiling",
        "Oligonucleotide Array Sequence Analysis",
        "Sequence Analysis, DNA" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-starr" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/Starr.html" .

