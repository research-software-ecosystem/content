@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:rmblast a schema1:SoftwareApplication ;
    schema1:description "RMBlast is a RepeatMasker compatible version of the standard NCBI BLAST+ suite." ;
    schema1:license "OSL-2.1" ;
    schema1:name "rmblast" ;
    schema1:url "http://www.repeatmasker.org/RMBlast.html" .

