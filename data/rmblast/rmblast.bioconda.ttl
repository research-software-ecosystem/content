@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:rmblast a schema1:SoftwareApplication ;
    schema1:author "mencian" ;
    schema1:description "RMBlast is a RepeatMasker compatible version of the standard NCBI BLAST+ suite." ;
    schema1:downloadUrl "https://ftp.ncbi.nlm.nih.gov/blast/executables/blast+/2.14.1/ncbi-blast-2.14.1+-src.tar.gz" ;
    schema1:identifier biotools:rmblast ;
    schema1:license "OSL-2.1" ;
    schema1:maintainer "mencian" ;
    schema1:name "rmblast" ;
    schema1:softwareHelp "https://www.repeatmasker.org/rmblast" ;
    schema1:softwareVersion "2.14.1" ;
    schema1:url "https://www.repeatmasker.org/rmblast" ;
    spdx:builtFrom biotools:rmblast .

