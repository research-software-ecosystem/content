@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-demand a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "This software predicts drug moa by interrogating a cell context specific regulatory network with a small number (n >= 6) of compound-induced gene expression signatures, to elucidate specific proteins whose interactions in the network is dysregulated by the compound." ;
    schema1:identifier biotools:demand ;
    schema1:keywords "Computational Biology",
        "Drug discovery",
        "Gene Expression",
        "Gene Expression Profiling",
        "Genomics",
        "High-Throughput Screening Assays",
        "Molecular interactions, pathways and networks",
        "Pharmacology",
        "Programming Languages",
        "User-Computer Interface" ;
    schema1:license "file LICENSE" ;
    schema1:name "bioconductor-demand" ;
    schema1:url "http://bioconductor.org/packages/release/bioc/html/DeMAND.html" .

