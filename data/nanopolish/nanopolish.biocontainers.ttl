@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:nanopolish a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.4184" ;
    schema1:description "A package for detecting cytosine methylations and genetic variations from nanopore minion sequencing data." ;
    schema1:identifier biotools:nanopolish ;
    schema1:keywords "5-Methylcytosine",
        "Cell Line, Tumor",
        "CpG Islands",
        "Cytosine",
        "DNA Methylation",
        "Escherichia coli",
        "Genetic variation",
        "Genetics",
        "Genome, Human",
        "Humans",
        "Markov Chains",
        "Nanopores",
        "Sequence analysis",
        "Sequencing",
        "Statistics and probability" ;
    schema1:license "MIT" ;
    schema1:name "nanopolish" ;
    schema1:url "https://github.com/jts/nanopolish" .

