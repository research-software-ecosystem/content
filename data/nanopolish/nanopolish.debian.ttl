@prefix debianmed: <https://salsa.debian.org/med-team/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

debianmed:nanopolish a schema1:SoftwareApplication ;
    schema1:description "consensus caller for nanopore sequencing data" ;
    schema1:identifier "bio.tools:nanopolish",
        "conda:bioconda:nanopolish",
        "omictools:OMICS_16545",
        "scicrunch:SCR_016157" ;
    schema1:license "unknown" ;
    schema1:name "nanopolish" ;
    schema1:softwareVersion "0.14.0" ;
    schema1:url "https://github.com/jts/nanopolish" ;
    spdx:builtFrom "nanopolish" .

