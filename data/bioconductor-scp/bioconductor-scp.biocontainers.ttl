@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-scp a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18129/b9.bioc.scp" ;
    schema1:description "Mass spectrometry-based single-cell proteomics data analysis" ;
    schema1:keywords "Mass spectrometry",
        "Proteomics" ;
    schema1:license "Not available" ;
    schema1:name "bioconductor-scp" ;
    schema1:url "https://bioconductor.org/packages/3.12/bioc/html/scp.html" .

