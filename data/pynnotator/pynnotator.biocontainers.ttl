@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:pynnotator a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1016/j.ajhg.2012.03.002" ;
    schema1:description "A Python Annotation Framework for VCFs using multiple tools." ;
    schema1:keywords "Animals",
        "Base Sequence",
        "Biological Evolution",
        "DNA, Mitochondrial",
        "Databases, Genetic",
        "Genetic Variation",
        "Genetics",
        "Genomics",
        "Haplotypes",
        "Humans",
        "Molecular Sequence Data",
        "Mutation",
        "Neanderthals",
        "Phylogeny" ;
    schema1:license "BSD" ;
    schema1:name "pynnotator" ;
    schema1:url "http://github.com/raonyguimaraes/pynnotator" .

