@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-tidyr a schema1:SoftwareApplication ;
    schema1:description "Tools to help to create tidy data, where each column is a variable, each row is an observation, and each cell contains a single value. tidyr contains tools for changing the shape (pivoting) and hierarchy (nesting and unnesting) of a dataset, turning deeply nested lists into rectangular data frames (rectangling), and extracting values out of string columns. It also includes tools for working with missing values (both implicit and explicit)." ;
    schema1:keywords "Clustering",
        "Genomics" ;
    schema1:license "MIT" ;
    schema1:name "r-tidyr" ;
    schema1:url "https://cran.r-project.org/package=tidyr" .

