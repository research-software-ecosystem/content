@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:deepnog a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btaa1051" ;
    schema1:description "Deep learning tool for protein orthologous group assignment" ;
    schema1:keywords "Ortholog",
        "Protein Sequences" ;
    schema1:license "BSD-3-Clause" ;
    schema1:name "deepnog" ;
    schema1:url "https://github.com/univieCUBE/deepnog" .

