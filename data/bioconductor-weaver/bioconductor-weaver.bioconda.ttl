@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-weaver a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Tools and extensions for processing Sweave documents" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/weaver_1.72.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/weaver/weaver_1.72.0.tar.gz', 'https://bioarchive.galaxyproject.org/weaver_1.72.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-weaver/bioconductor-weaver_1.72.0_src_all.tar.gz']" ;
    schema1:identifier biotools:weaver ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-weaver" ;
    schema1:softwareVersion "1.72.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/weaver.html" ;
    spdx:builtFrom biotools:weaver .

