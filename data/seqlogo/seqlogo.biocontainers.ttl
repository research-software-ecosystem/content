@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:seqlogo a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Python port of the r bioconductor `seqlogo` package" ;
    schema1:identifier biotools:seqlogo ;
    schema1:keywords "Computational Biology",
        "Gene Expression Profiling",
        "Genomics",
        "High-Throughput Screening Assays",
        "Mapping",
        "Programming Languages",
        "Sequence Alignment",
        "User-Computer Interface" ;
    schema1:license "BSD 3-Clause \"New\" or \"Revised\" License" ;
    schema1:name "seqlogo" ;
    schema1:url "https://github.com/betteridiot/seqlogo" .

