@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:genenotebook a schema1:SoftwareApplication ;
    schema1:description "A colleborative notebook for comparative genomics" ;
    schema1:keywords "Gene Expression",
        "Genomics",
