@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:plastid a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/S12864-016-3278-X" ;
    schema1:description "plastid is a Python library for genomic analysis -- in particular, high-throughput sequencing data" ;
    schema1:identifier biotools:plastid ;
    schema1:keywords "Computational Biology",
        "Genomics",
        "High-Throughput Nucleotide Sequencing",
        "RNA-Seq",
        "Sequence analysis",
        "Sequencing",
        "Web Browser",
        "Workflow" ;
    schema1:license "BSD 3-Clause" ;
    schema1:name "plastid" ;
    schema1:url "https://github.com/joshuagryphon/plastid" .

