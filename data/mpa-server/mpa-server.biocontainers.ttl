@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:mpa-server a schema1:SoftwareApplication ;
    schema1:description "Independent platform for interpretation of proteomics identification results" ;
    schema1:keywords "Metaproteomics",
        "Peptides",
        "Proteomics" ;
    schema1:license "Apache-2.0" ;
    schema1:name "mpa-server" ;
    schema1:url "https://github.com/compomics/meta-proteome-analyzer" .

