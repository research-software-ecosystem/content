@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-tfbstools a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btw024" ;
    schema1:description "Software Package for Transcription Factor Binding Site (TFBS) Analysis" ;
    schema1:identifier biotools:tfbstools ;
    schema1:keywords "Animals",
        "Binding Sites",
        "Genome-Wide Association Study",
        "Humans",
        "Transcription Factors",
        "Transcription factors and regulatory sites" ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-tfbstools" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/TFBSTools.html" .

