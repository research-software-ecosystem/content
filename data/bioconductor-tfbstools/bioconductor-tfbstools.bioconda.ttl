@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-tfbstools a schema1:SoftwareApplication ;
    schema1:description "Software Package for Transcription Factor Binding Site (TFBS) Analysis." ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.21/bioc/src/contrib/TFBSTools_1.46.0.tar.gz', 'https://bioconductor.org/packages/3.21/bioc/src/contrib/Archive/TFBSTools/TFBSTools_1.46.0.tar.gz', 'https://bioarchive.galaxyproject.org/TFBSTools_1.46.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-tfbstools/bioconductor-tfbstools_1.46.0_src_all.tar.gz']" ;
    schema1:identifier biotools:tfbstools ;
    schema1:license "GPL-2.0-or-later" ;
    schema1:name "bioconductor-tfbstools" ;
    schema1:softwareHelp "https://bioconductor.org/packages/3.21/bioc/html/TFBSTools.html" ;
    schema1:softwareVersion "1.46.0" ;
    schema1:url "https://bioconductor.org/packages/3.21/bioc/html/TFBSTools.html" ;
    spdx:builtFrom biotools:tfbstools .

