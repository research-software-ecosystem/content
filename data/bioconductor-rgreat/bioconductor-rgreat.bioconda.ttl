@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-rgreat a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "GREAT Analysis - Functional Enrichment on Genomic Regions" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/rGREAT_2.8.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/rGREAT/rGREAT_2.8.0.tar.gz', 'https://bioarchive.galaxyproject.org/rGREAT_2.8.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-rgreat/bioconductor-rgreat_2.8.0_src_all.tar.gz']" ;
    schema1:identifier biotools:rgreat ;
    schema1:license "MIT + file LICENSE" ;
    schema1:name "bioconductor-rgreat" ;
    schema1:softwareVersion "2.8.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/rGREAT.html" ;
    spdx:builtFrom biotools:rgreat .

