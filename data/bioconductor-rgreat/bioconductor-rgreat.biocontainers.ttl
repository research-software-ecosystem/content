@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-rgreat a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "This package makes great (genomic regions enrichment of annotations tool) analysis automatic by constructing a http post request according to user's input and automatically retrieving results from great web server." ;
    schema1:identifier biotools:rgreat ;
    schema1:keywords "Computational Biology",
        "Gene Expression Profiling",
        "Genomics",
        "High-Throughput Screening Assays",
        "Programming Languages",
        "User-Computer Interface",
        "Whole genome sequencing" ;
    schema1:license "GPL-2.0" ;
    schema1:name "bioconductor-rgreat" ;
    schema1:url "http://bioconductor.org/packages/release/bioc/html/rGREAT.html" .

