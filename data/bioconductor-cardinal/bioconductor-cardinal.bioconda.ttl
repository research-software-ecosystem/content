@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-cardinal a schema1:SoftwareApplication ;
    schema1:description "A mass spectrometry imaging toolbox for statistical analysis" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/Cardinal_3.12.1.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/Cardinal/Cardinal_3.12.1.tar.gz', 'https://bioarchive.galaxyproject.org/Cardinal_3.12.1.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-cardinal/bioconductor-cardinal_3.12.1_src_all.tar.gz']" ;
    schema1:identifier biotools:cardinal ;
    schema1:license "Artistic-2.0 | file LICENSE" ;
    schema1:name "bioconductor-cardinal" ;
    schema1:softwareVersion "3.12.1" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/Cardinal.html" ;
    spdx:builtFrom biotools:cardinal .

