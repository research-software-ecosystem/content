@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-tcseq a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18129/b9.bioc.tcseq" ;
    schema1:description "Time course sequencing data analysis" ;
    schema1:keywords "Clustering",
        "Genetics" ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-tcseq" ;
    schema1:url "https://bioconductor.org/packages/3.8/bioc/html/TCseq.html" .

