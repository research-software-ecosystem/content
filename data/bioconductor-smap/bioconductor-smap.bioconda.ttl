@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-smap a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btn003" ;
    schema1:description "A Segmental Maximum A Posteriori Approach to Array-CGH Copy Number Profiling" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.18/bioc/src/contrib/SMAP_1.66.0.tar.gz', 'https://bioconductor.org/packages/3.18/bioc/src/contrib/Archive/SMAP/SMAP_1.66.0.tar.gz', 'https://bioarchive.galaxyproject.org/SMAP_1.66.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-smap/bioconductor-smap_1.66.0_src_all.tar.gz']" ;
    schema1:identifier biotools:smap ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-smap" ;
    schema1:softwareVersion "1.66.0" ;
    schema1:url "https://bioconductor.org/packages/3.18/bioc/html/SMAP.html" ;
    spdx:builtFrom biotools:smap .

