@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-smap a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btn003" ;
    schema1:description "A Segmental Maximum A Posteriori Approach to Array-CGH Copy Number Profiling" ;
    schema1:identifier biotools:smap ;
    schema1:keywords "Artificial Intelligence",
        "Base Sequence",
        "Chromosome Mapping",
        "DNA structural variation",
        "Gene Dosage",
        "Gene Expression Profiling",
        "Markov Chains",
        "Microarray experiment",
        "Molecular Sequence Data",
        "Oligonucleotide Array Sequence Analysis",
        "Pattern Recognition, Automated" ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-smap" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/SMAP.html" .

