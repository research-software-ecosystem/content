@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-clusterprofiler a schema1:SoftwareApplication ;
    schema1:description "A universal enrichment tool for interpreting omics data" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/clusterProfiler_4.18.4.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/clusterProfiler/clusterProfiler_4.18.4.tar.gz', 'https://bioarchive.galaxyproject.org/clusterProfiler_4.18.4.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-clusterprofiler/bioconductor-clusterprofiler_4.18.4_src_all.tar.gz']" ;
    schema1:identifier biotools:clusterprofiler ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-clusterprofiler" ;
    schema1:softwareVersion "4.18.4" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/clusterProfiler.html" ;
    spdx:builtFrom biotools:clusterprofiler .

