@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-clusterprofiler a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1089/omi.2011.0118" ;
    schema1:description "This package implements methods to analyze and visualize functional profiles (go and kegg) of gene and gene clusters." ;
    schema1:identifier biotools:clusterprofiler ;
    schema1:keywords "Animals",
        "Clustering",
        "Data visualisation",
        "Gene Expression Profiling",
        "Genetics",
        "Humans",
        "Mice",
        "Multigene Family",
        "Programming Languages",
        "Proteomics",
        "Transcriptome",
        "Yeasts" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-clusterprofiler" ;
    schema1:url "http://bioconductor.org/packages/release/bioc/html/clusterProfiler.html" .

