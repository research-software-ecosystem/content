@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:egglib a schema1:SoftwareApplication ;
    schema1:author "ranwez" ;
    schema1:citation "doi:10.1111/1755-0998.13672" ;
    schema1:description "Evolutionary Genetics and Genomics Library. EggLib is a C++/Python library and program package for evolutionary genetics and genomics. Main features are sequence data management, sequence polymorphism analysis, and coalescent simulations. EggLib is a flexible Python module with a performant underlying C++ library and allows fast and intuitive development of Python programs and scripts." ;
    schema1:downloadUrl "https://pypi.org/packages/source/e/egglib/egglib-3.6.0.tar.gz" ;
    schema1:identifier biotools:egglib ;
    schema1:license "GPL-3.0-or-later" ;
    schema1:maintainer "ranwez" ;
    schema1:name "egglib" ;
    schema1:softwareHelp "https://www.egglib.org/index.html" ;
    schema1:softwareVersion "3.6.0" ;
    schema1:url "https://egglib.org" ;
    spdx:builtFrom biotools:egglib .

