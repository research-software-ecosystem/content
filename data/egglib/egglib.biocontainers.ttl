@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:egglib a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/1471-2156-13-27" ;
    schema1:description "EggLib is a C++/Python library and program package for evolutionary genetics and genomics. Main features are sequence data management, sequence polymorphism analysis, and coalescent simulations. EggLib is a flexible Python module with a performant underlying C++ library and allows fast and intuitive development of Python programs and scripts." ;
    schema1:keywords "Computer Simulation",
        "Genetics, Population",
        "Genomics" ;
    schema1:license "GPL-3.0" ;
    schema1:name "egglib" ;
    schema1:url "http://mycor.nancy.inra.fr/egglib/" .

