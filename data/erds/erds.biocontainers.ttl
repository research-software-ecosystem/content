@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:erds a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1016/j.ajhg.2012.07.004" ;
    schema1:description "Inferring copy number variants in high-coverage human genomes with next-generation sequencing data." ;
    schema1:identifier biotools:erds ;
    schema1:keywords "DNA Copy Number Variations",
        "Gene Deletion",
        "Genetic variation",
        "Genetics",
        "Genome, Human",
        "Genomics",
        "Genotyping Techniques",
        "Humans",
        "Sequence Analysis, DNA",
        "Sequence analysis",
        "Validation Studies as Topic" ;
    schema1:license "Free to academia and non-profit organizations" ;
    schema1:name "erds" ;
    schema1:url "https://github.com/JieYang031/erds1.1" .

