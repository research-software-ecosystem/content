@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-dexseq a schema1:SoftwareApplication ;
    schema1:description "Inference of differential exon usage in RNA-Seq" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/DEXSeq_1.52.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/DEXSeq/DEXSeq_1.52.0.tar.gz', 'https://bioarchive.galaxyproject.org/DEXSeq_1.52.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-dexseq/bioconductor-dexseq_1.52.0_src_all.tar.gz']" ;
    schema1:identifier biotools:dexseq ;
    schema1:license "GPL (>= 3)" ;
    schema1:name "bioconductor-dexseq" ;
    schema1:softwareVersion "1.52.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/DEXSeq.html" ;
    spdx:builtFrom biotools:dexseq .

