@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:ntjoin a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btaa253" ;
    schema1:description "Genome assembly scaffolder using minimizer graphs" ;
    schema1:keywords "Genome, Human",
        "Genomics",
        "High-Throughput Nucleotide Sequencing",
        "Humans",
        "Proteomics",
        "Sequence Analysis, DNA",
        "Synteny" ;
    schema1:license "GPL-3.0" ;
    schema1:name "ntjoin" ;
    schema1:url "http://www.bcgsc.ca/platform/bioinfo/software/ntjoin" .

