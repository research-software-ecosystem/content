@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:ncbi-blast-plus-legacy a schema1:SoftwareApplication ;
    schema1:description "Ncbi blast legacy call script" ;
    schema1:keywords "Gene Expression",
        "Genetics",
        "Sequence Alignment" ;
    schema1:license "custom, see /usr/share/doc/ncbi-blast-plus-legacy/copyright" ;
    schema1:name "ncbi-blast-plus-legacy" ;
    schema1:url "http://www.ncbi.nlm.nih.gov/IEB/ToolBox/CPP_DOC/" .

