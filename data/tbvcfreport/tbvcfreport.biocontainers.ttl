@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:tbvcfreport a schema1:SoftwareApplication ;
    schema1:description "Parses snpeff annotated m.tb vcf(s) and generates an interactive html-based report." ;
    schema1:license "GPL-3.0" ;
    schema1:name "tbvcfreport" ;
    schema1:url "http://github.com/COMBAT-TB/tbvcfreport" .

