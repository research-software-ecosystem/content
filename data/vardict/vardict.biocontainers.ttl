@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:vardict a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/gkw227" ;
    schema1:description "A sensitive variant caller for both single and paired sample variant calling" ;
    schema1:keywords "Alleles",
        "Computational Biology",
        "Gene Frequency",
        "Genetic Variation",
        "High-Throughput Nucleotide Sequencing",
        "Humans",
        "INDEL Mutation",
        "Loss of Heterozygosity",
        "Lung Neoplasms",
        "Neoplasms",
        "ROC Curve",
        "Research",
        "Sequence Analysis, DNA" ;
    schema1:license "MIT" ;
    schema1:name "vardict" ;
    schema1:url "https://github.com/AstraZeneca-NGS/VarDict" .

