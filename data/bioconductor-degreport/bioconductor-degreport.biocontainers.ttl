@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-degreport a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Creation of a html report of differential expression analyses of count data. it integrates some of the code mentioned in deseq2 and edger vignettes, and report a ranked list of genes according to the fold changes mean and variability for each selected gene." ;
    schema1:identifier biotools:degreport ;
    schema1:keywords "Computational Biology",
        "Gene Expression Profiling",
        "Gene expression",
        "Genomics",
        "High-Throughput Screening Assays",
        "Programming Languages",
        "RNA-Seq",
        "User-Computer Interface" ;
    schema1:license "MIT" ;
    schema1:name "bioconductor-degreport" ;
    schema1:url "http://bioconductor.org/packages/release/bioc/html/DEGreport.html" .

