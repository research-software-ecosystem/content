@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:fastq-tools a schema1:SoftwareApplication ;
    schema1:description "A collection of fastq manipulation scripts written in C for speed." ;
    schema1:license "MIT" ;
    schema1:name "fastq-tools" ;
    schema1:url "http://homes.cs.washington.edu/~dcjones/fastq-tools/" .

