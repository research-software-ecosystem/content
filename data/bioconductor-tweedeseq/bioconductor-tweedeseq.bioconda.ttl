@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-tweedeseq a schema1:SoftwareApplication ;
    schema1:description "RNA-seq data analysis using the Poisson-Tweedie family of distributions" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/tweeDEseq_1.52.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/tweeDEseq/tweeDEseq_1.52.0.tar.gz', 'https://bioarchive.galaxyproject.org/tweeDEseq_1.52.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-tweedeseq/bioconductor-tweedeseq_1.52.0_src_all.tar.gz']" ;
    schema1:identifier biotools:tweedeseq ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-tweedeseq" ;
    schema1:softwareVersion "1.52.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/tweeDEseq.html" ;
    spdx:builtFrom biotools:tweedeseq .

