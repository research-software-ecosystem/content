@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-tweedeseq a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/1471-2105-14-254" ;
    schema1:description "RNA-seq data analysis using the Poisson-Tweedie family of distributions" ;
    schema1:identifier biotools:tweedeseq ;
    schema1:keywords "Computational Biology",
        "Gene Expression Profiling",
        "Gene expression",
        "High-Throughput Nucleotide Sequencing",
        "Humans",
        "Models, Statistical",
        "RNA-Seq",
        "RNA-seq",
        "Reproducibility of Results",
        "Sequence Analysis, RNA",
        "Statistics and probability" ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-tweedeseq" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/tweeDEseq.html" .

