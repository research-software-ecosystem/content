@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-sangerseqr a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1002/dvdy.24183" ;
    schema1:description "Tools for Sanger Sequencing Data in R" ;
    schema1:identifier biotools:sangerseqr ;
    schema1:keywords "DNA Mutational Analysis",
        "Heterozygote",
        "INDEL Mutation",
        "Polymerase Chain Reaction",
        "Sequencing" ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-sangerseqr" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/sangerseqR.html" .

