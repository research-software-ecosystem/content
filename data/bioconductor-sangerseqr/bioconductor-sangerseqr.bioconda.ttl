@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-sangerseqr a schema1:SoftwareApplication ;
    schema1:description "Tools for Sanger Sequencing Data in R" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/sangerseqR_1.42.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/sangerseqR/sangerseqR_1.42.0.tar.gz', 'https://bioarchive.galaxyproject.org/sangerseqR_1.42.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-sangerseqr/bioconductor-sangerseqr_1.42.0_src_all.tar.gz']" ;
    schema1:identifier biotools:sangerseqr ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-sangerseqr" ;
    schema1:softwareVersion "1.42.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/sangerseqR.html" ;
    spdx:builtFrom biotools:sangerseqr .

