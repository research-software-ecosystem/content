@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:ms2deepscore a schema1:SoftwareApplication ;
    schema1:author "hechth",
        "niekdejonge" ;
    schema1:citation "doi:10.1186/s13321-021-00558-4" ;
    schema1:description "Deep learning similarity measure for comparing MS/MS spectra with respect to their chemical similarity" ;
    schema1:downloadUrl "https://github.com/matchms/ms2deepscore/archive/refs/tags/2.7.2.tar.gz" ;
    schema1:identifier biotools:ms2deepscore ;
    schema1:license "Apache-2.0" ;
    schema1:maintainer "hechth",
        "niekdejonge" ;
    schema1:name "ms2deepscore" ;
    schema1:softwareVersion "2.7.2" ;
    schema1:url "https://github.com/matchms/ms2deepscore" ;
    spdx:builtFrom biotools:ms2deepscore .

