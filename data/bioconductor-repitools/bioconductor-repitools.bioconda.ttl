@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-repitools a schema1:SoftwareApplication ;
    schema1:description "Epigenomic tools" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/Repitools_1.52.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/Repitools/Repitools_1.52.0.tar.gz', 'https://bioarchive.galaxyproject.org/Repitools_1.52.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-repitools/bioconductor-repitools_1.52.0_src_all.tar.gz']" ;
    schema1:identifier biotools:repitools ;
    schema1:license "LGPL (>= 2)" ;
    schema1:name "bioconductor-repitools" ;
    schema1:softwareVersion "1.52.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/Repitools.html" ;
    spdx:builtFrom biotools:repitools .

