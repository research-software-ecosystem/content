@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-repitools a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/gb-2014-15-2-r35" ;
    schema1:description "Tools for the analysis of enrichment-based epigenomic data.  features include summarization and visualization of epigenomic data across promoters according to gene expression context, finding regions of differential methylation/binding, baymeth for quantifying methylation" ;
    schema1:identifier biotools:repitools ;
    schema1:keywords "Bayes Theorem",
        "CpG Islands",
        "DNA Copy Number Variations",
        "DNA Methylation",
        "Epigenomics",
        "Evaluation Studies as Topic",
        "Gene Expression",
        "Genome, Human",
        "High-Throughput Nucleotide Sequencing",
        "Humans" ;
    schema1:license "LGPL (>= 2)" ;
    schema1:name "bioconductor-repitools" ;
    schema1:url "https://www.bioconductor.org/packages/release/bioc/html/Repitools.html" .

