@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:prosolo a schema1:SoftwareApplication ;
    schema1:description "A highly sensitive and accurate Bayesian caller for variants in single cell sequencing data." ;
    schema1:keywords "Genetics" ;
    schema1:license "GPL-3.0" ;
    schema1:name "prosolo" ;
    schema1:url "https://github.com/ProSolo/prosolo" .

