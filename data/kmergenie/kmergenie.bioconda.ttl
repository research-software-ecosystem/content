@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:kmergenie a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btt310" ;
    schema1:description "KmerGenie estimates the best k-mer length for genome de novo assembly." ;
    schema1:downloadUrl "http://kmergenie.bx.psu.edu/kmergenie-1.7051.tar.gz" ;
    schema1:identifier biotools:kmergenie ;
    schema1:license "Free Software License" ;
    schema1:name "kmergenie" ;
    schema1:softwareHelp "http://kmergenie.bx.psu.edu/README" ;
    schema1:softwareVersion "1.7051" ;
    schema1:url "http://kmergenie.bx.psu.edu" ;
    spdx:builtFrom biotools:kmergenie .

