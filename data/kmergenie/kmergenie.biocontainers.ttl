@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:kmergenie a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btt310" ;
    schema1:description "KmerGenie estimates the best k-mer length for genome de novo assembly" ;
    schema1:identifier biotools:kmergenie ;
    schema1:keywords "Animals",
        "Automation",
        "Genome",
        "High-Throughput Nucleotide Sequencing",
        "Humans",
        "Insecta",
        "Sequence Analysis, DNA",
        "Sequence assembly",
        "Staphylococcus aureus" ;
    schema1:license "GNU" ;
    schema1:name "kmergenie" ;
    schema1:url "http://kmergenie.bx.psu.edu/" .

