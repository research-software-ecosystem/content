@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-pathprint a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18129/b9.bioc.pathprint" ;
    schema1:description "Pathway fingerprinting for analysis of gene expression arrays" ;
    schema1:keywords "Gene Expression" ;
    schema1:license "GPL" ;
    schema1:name "bioconductor-pathprint" ;
    schema1:url "http://bioconductor.org/packages/3.6/bioc/html/pathprint.html" .

