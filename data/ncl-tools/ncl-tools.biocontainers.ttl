@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:ncl-tools a schema1:SoftwareApplication ;
    schema1:description "Tools to deal with nexus files" ;
    schema1:license "custom, see /usr/share/doc/ncl-tools/copyright" ;
    schema1:name "ncl-tools" ;
    schema1:url "https://github.com/mtholder/ncl" .

