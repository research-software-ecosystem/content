@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:msi a schema1:SoftwareApplication ;
    schema1:author "nuno.fonseca" ;
    schema1:citation "doi:10.5281/zenodo.3855032" ;
    schema1:description "Metabarcoding sequences identification - from nanopore reads to taxa tables." ;
    schema1:downloadUrl "https://github.com/nunofonseca/msi/archive/0.3.8.tar.gz" ;
    schema1:identifier biotools:msi ;
    schema1:license "GPL-3.0-or-later" ;
    schema1:maintainer "nuno.fonseca" ;
    schema1:name "msi" ;
    schema1:softwareHelp "https://github.com/nunofonseca/msi" ;
    schema1:softwareVersion "0.3.8" ;
    schema1:url "https://github.com/nunofonseca/msi" ;
    spdx:builtFrom biotools:msi .

