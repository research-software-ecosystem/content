@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:smafa a schema1:SoftwareApplication ;
    schema1:description "smafa is a tool for querying and clustering pre-aligned small pre-aligned DNA and amino acid sequences." ;
    schema1:keywords "Clustering",
        "Genomics",
        "Metagenome" ;
    schema1:license "GPL-3.0" ;
    schema1:name "smafa" ;
    schema1:url "https://github.com/wwood/smafa" .

