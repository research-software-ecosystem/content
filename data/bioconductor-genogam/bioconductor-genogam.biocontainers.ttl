@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-genogam a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btx150" ;
    schema1:description "A GAM based framework for analysis of ChIP-Seq data" ;
    schema1:identifier biotools:genogam ;
    schema1:keywords "Animals",
        "ChIP-seq",
        "Chromatin Immunoprecipitation",
        "DNA Methylation",
        "Genetics",
        "Genomics",
        "High-Throughput Nucleotide Sequencing",
        "Humans",
        "Mice",
        "Models, Biological",
        "Models, Statistical",
        "Sequence Analysis, DNA",
        "Yeasts" ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-genogam" ;
    schema1:url "http://bioconductor.org/packages/3.6/bioc/html/GenoGAM.html" .

