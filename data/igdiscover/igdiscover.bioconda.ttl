@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:igdiscover a schema1:SoftwareApplication ;
    schema1:author "marcelm" ;
    schema1:citation "doi:10.1038/ncomms13642" ;
    schema1:description "Analyze antibody repertoires and discover new V genes" ;
    schema1:downloadUrl "https://pypi.io/packages/source/i/igdiscover/igdiscover-0.15.1.tar.gz" ;
    schema1:identifier biotools:igdiscover ;
    schema1:license "MIT" ;
    schema1:maintainer "marcelm" ;
    schema1:name "igdiscover" ;
    schema1:softwareVersion "0.15.1" ;
    schema1:url "https://igdiscover.se/" ;
    spdx:builtFrom biotools:igdiscover .

