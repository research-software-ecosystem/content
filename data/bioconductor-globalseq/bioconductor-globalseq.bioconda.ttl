@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-globalseq a schema1:SoftwareApplication ;
    schema1:description "Global Test for Counts" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/globalSeq_1.34.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/globalSeq/globalSeq_1.34.0.tar.gz', 'https://bioarchive.galaxyproject.org/globalSeq_1.34.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-globalseq/bioconductor-globalseq_1.34.0_src_all.tar.gz']" ;
    schema1:identifier biotools:globalseq ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-globalseq" ;
    schema1:softwareVersion "1.34.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/globalSeq.html" ;
    spdx:builtFrom biotools:globalseq .

