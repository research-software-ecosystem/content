@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-globalseq a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s12859-016-0961-5" ;
    schema1:description "Global Test for Counts" ;
    schema1:identifier biotools:globalseq ;
    schema1:keywords "Gene Expression Profiling",
        "High-Throughput Nucleotide Sequencing",
        "Humans",
        "Male",
        "Prostatic Neoplasms",
        "RNA",
        "RNA-Seq",
        "RNA-seq",
        "Regression Analysis",
        "Sequence Analysis, RNA",
        "Sequence analysis",
        "Transcriptomics" ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-globalseq" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/globalSeq.html" .

