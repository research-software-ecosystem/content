@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-clstutils a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Tools for performing taxonomic assignment" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/clstutils_1.58.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/clstutils/clstutils_1.58.0.tar.gz', 'https://bioarchive.galaxyproject.org/clstutils_1.58.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-clstutils/bioconductor-clstutils_1.58.0_src_all.tar.gz']" ;
    schema1:identifier biotools:clstutils ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-clstutils" ;
    schema1:softwareVersion "1.58.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/clstutils.html" ;
    spdx:builtFrom biotools:clstutils .

