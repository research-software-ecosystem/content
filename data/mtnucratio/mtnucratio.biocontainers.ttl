@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:mtnucratio a schema1:SoftwareApplication ;
    schema1:description "A small tool to determine MT to Nuclear ratios for NGS data." ;
    schema1:license "GPL-3.0" ;
    schema1:name "mtnucratio" ;
    schema1:url "https://github.com/apeltzer/MTNucRatioCalculator" .

