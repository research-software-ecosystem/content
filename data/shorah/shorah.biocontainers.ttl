        "High-Throughput Nucleotide Sequencing",
        "Humans",
        "Likelihood Functions",
        "Metagenomics",
        "Models, Genetic",
        "Polymorphism, Single Nucleotide",
        "Sequence Analysis, DNA",
        "Sequencing" ;
    schema1:license "GPL-3.0" ;
    schema1:name "shorah" ;
    schema1:url "https://github.com/cbg-ethz/shorah" .

