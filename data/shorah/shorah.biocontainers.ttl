    schema1:citation "doi:10.1089/cmb.2009.0164",
        "doi:10.1093/nar/gkq655",
        "doi:10.1186/1471-2105-12-119",
        "doi:10.1186/1471-2164-14-501" ;
    schema1:description "ShoRAH (Short Reads Assembly into Haplotypes)" ;
