@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:echidna a schema1:SoftwareApplication ;
    schema1:author "mingkz",
        "wgobrien" ;
    schema1:description "Mapping genotype to phenotype through joint probabilistic modeling of single-cell gene expression and chromosomal copy number variation." ;
    schema1:downloadUrl "https://pypi.io/packages/source/s/sc_echidna/sc_echidna-1.0.3.tar.gz" ;
    schema1:identifier biotools:echidna ;
    schema1:license "MIT" ;
    schema1:maintainer "mingkz",
        "wgobrien" ;
    schema1:name "echidna" ;
    schema1:softwareVersion "1.0.3" ;
    schema1:url "https://github.com/azizilab/echidna" ;
    spdx:builtFrom biotools:echidna .

