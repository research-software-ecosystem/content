    schema1:keywords "3' Untranslated Regions",
        "Genetics",
        "High-Throughput Nucleotide Sequencing",
        "Molecular Biology",
        "Poly A",
        "RNA Isoforms",
        "Sequence analysis" ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-cleanupdtseq" ;
    schema1:url "http://bioconductor.org/packages/3.6/bioc/html/cleanUpdTSeq.html" .

