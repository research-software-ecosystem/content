biocontainers:bioconductor-cleanupdtseq a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1002/0471142727.mb0423s110" ;
    schema1:description "This package classifies putative polyadenylation sites as true or false/internally oligodT primed" ;
