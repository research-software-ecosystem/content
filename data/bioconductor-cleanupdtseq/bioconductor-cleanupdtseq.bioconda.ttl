@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-cleanupdtseq a schema1:SoftwareApplication ;
    schema1:description "cleanUpdTSeq cleans up artifacts from polyadenylation sites from oligo(dT)-mediated 3' end RNA sequending data" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/cleanUpdTSeq_1.44.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/cleanUpdTSeq/cleanUpdTSeq_1.44.0.tar.gz', 'https://bioarchive.galaxyproject.org/cleanUpdTSeq_1.44.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-cleanupdtseq/bioconductor-cleanupdtseq_1.44.0_src_all.tar.gz']" ;
    schema1:identifier biotools:cleanupdtseq ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-cleanupdtseq" ;
    schema1:softwareVersion "1.44.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/cleanUpdTSeq.html" ;
    spdx:builtFrom biotools:cleanupdtseq .

