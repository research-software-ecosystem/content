@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-biocinstaller a schema1:SoftwareApplication ;
    schema1:description "Install/update bioconductor and cran packages" ;
    schema1:keywords "Genetics",
        "Genomics",
        "Ortholog" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-biocinstaller" ;
    schema1:url "https://bioconductor.org/packages/BiocInstaller/" .

