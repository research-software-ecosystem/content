@prefix debianmed: <https://salsa.debian.org/med-team/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

debianmed:vt a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics" ;
    schema1:description "toolset for short variant discovery in genetic sequence data" ;
    schema1:identifier "bio.tools:vt",
        "conda:bioconda:vt" ;
    schema1:license "unknown" ;
    schema1:name "vt" ;
    schema1:softwareVersion "0.57721+ds" ;
    schema1:url "https://genome.sph.umich.edu/wiki/Vt" ;
    spdx:builtFrom "vt" .

