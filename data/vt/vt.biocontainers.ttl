@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:vt a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btv112" ;
    schema1:description "A tool set for short variant discovery in genetic sequence data" ;
    schema1:identifier biotools:vt ;
    schema1:keywords "Genetic Variation",
        "Genetics",
        "Genome, Human",
        "Humans",
        "Programming Languages",
        "Sequence analysis",
        "Sequence sites, features and motifs",
        "Sequencing" ;
    schema1:license "MIT" ;
    schema1:name "vt" ;
    schema1:url "https://github.com/atks/vt" .

