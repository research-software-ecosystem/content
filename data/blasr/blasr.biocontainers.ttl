@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:blasr a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/1471-2105-13-238" ;
    schema1:description "Software for mapping single molecule sequencing (sms) reads that are thousands of bases long, with divergence between the read and genome dominated by insertion and deletion error." ;
    schema1:identifier biotools:blasr ;
    schema1:keywords "Base Sequence",
        "DNA",
        "Genome",
        "Genomics",
        "Mapping",
        "Sequence Alignment",
        "Sequence Analysis, DNA",
        "Sequencing" ;
    schema1:license "PacBio-BSD-3-Clause" ;
    schema1:name "blasr" ;
    schema1:url "https://github.com/PacificBiosciences/blasr" .

