@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:pydna a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s12859-015-0544-x" ;
    schema1:description "Representing double stranded dna and simulating cloning, homologous recombination, gibson assembly, gel electrophoresis etc." ;
    schema1:identifier biotools:pydna ;
    schema1:keywords "DNA",
        "Molecular biology",
        "PCR experiment",
        "Sequence assembly" ;
    schema1:license "Copyright (c) 2013,2014,2015 Björn Johansson" ;
    schema1:name "pydna" ;
    schema1:url "https://github.com/BjornFJohansson/pydna" .

