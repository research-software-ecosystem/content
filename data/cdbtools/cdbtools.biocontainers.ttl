@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:cdbtools a schema1:SoftwareApplication ;
    schema1:description "Cdb (constant database) indexing and retrieval tools for fasta files" ;
    schema1:license "Public Domain" ;
    schema1:name "cdbtools" ;
    schema1:url "http://compbio.dfci.harvard.edu/tgi" .

