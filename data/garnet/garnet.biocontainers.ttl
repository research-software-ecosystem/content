@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:garnet a schema1:SoftwareApplication ;
    schema1:description "Garnet uses gene expression and epigenetic data to impute transcription factors (tfs) that played an important role in a biological system." ;
    schema1:keywords "Gene Expression",
        "Genetics",
        "RNA-Seq",
        "Transcription Factors",
        "Transcriptome" ;
    schema1:license "Not available" ;
    schema1:name "garnet" ;
    schema1:url "https://github.com/fraenkel-lab/GarNet" .

