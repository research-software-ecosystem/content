  "@graph": [
    {
      "@id": "https://bio.tools/bioconductor-scmerge",
      "@type": "sc:SoftwareApplication",
      "dcterms:conformsTo": "https://bioschemas.org/profiles/ComputationalTool/0.6-DRAFT",
      "sc:additionalType": [
        "Command-line tool",
        "Library"
      ],
      "sc:author": [
        "Yingxin Lin",
        "Kevin Wang"
      ],
      "sc:citation": {
        "@id": "https://doi.org/10.1073/pnas.1820006116"
      },
      "sc:contributor": "Sydney Bioinformatics and Biometrics Group",
      "sc:description": "Like all gene expression data, single-cell data suffers from batch effects and other unwanted variations that makes accurate biological interpretations difficult. The scMerge method leverages factor analysis, stably expressed genes (SEGs) and (pseudo-) replicates to remove unwanted variations and merge multiple single-cell data. This package contains all the necessary functions in the scMerge pipeline, including the identification of SEGs, replication-identification methods, and merging of single-cell data.",
      "sc:funder": "Sydney Bioinformatics and Biometrics Group",
      "sc:license": "GPL-3.0-only",
      "sc:name": "scMerge",
      "sc:operatingSystem": [
        "Mac",
        "Windows",
        "Linux"
      ],
      "sc:softwareHelp": {
        "@id": "https://bioconductor.org/packages/scMerge"
      },
      "sc:softwareVersion": "1.26.0",
      "sc:url": "https://bioconductor.org/packages/scMerge"
    },
