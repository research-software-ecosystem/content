@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:simka a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btz685",
        "doi:10.7717/peerj-cs.94" ;
    schema1:description "Simka and simkaMin are de novo comparative metagenomics tools. Simka represents each dataset as a k-mer spectrum and computes several classical ecological distances between them. SimkaMin outputs approximate (but very similar) results by subsampling the kmer space and requires much less computational resources." ;
    schema1:downloadUrl "https://github.com/GATB/simka/releases/download/v1.5.3/simka-v1.5.3-Source.tar.gz" ;
    schema1:identifier biotools:Simka ;
    schema1:license "AGPL-3.0-or-later" ;
    schema1:name "simka" ;
    schema1:softwareVersion "1.5.3" ;
    schema1:url "https://github.com/GATB/simka" ;
    spdx:builtFrom biotools:Simka .

