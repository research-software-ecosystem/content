@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:altree a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btl131" ;
    schema1:description "Program to perform phylogeny-based association and localization analysis" ;
    schema1:keywords "Computational Biology",
        "Genetic Diseases, Inborn",
        "Genetic Predisposition to Disease",
        "Genetics, Population",
        "Haplotypes",
        "Humans",
        "Models, Genetic",
        "Models, Statistical",
        "Phylogeny",
        "Programming Languages" ;
    schema1:license "custom, see /usr/share/doc/altree/copyright" ;
    schema1:name "altree" ;
    schema1:url "https://gitlab.inria.fr/NGS/ALTree" .

