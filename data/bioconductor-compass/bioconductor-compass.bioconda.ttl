@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-compass a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nbt.3187" ;
    schema1:description "Combinatorial Polyfunctionality Analysis of Single Cells" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/COMPASS_1.48.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/COMPASS/COMPASS_1.48.0.tar.gz', 'https://bioarchive.galaxyproject.org/COMPASS_1.48.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-compass/bioconductor-compass_1.48.0_src_all.tar.gz']" ;
    schema1:identifier biotools:compass ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-compass" ;
    schema1:softwareVersion "1.48.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/COMPASS.html" ;
    spdx:builtFrom biotools:compass .

