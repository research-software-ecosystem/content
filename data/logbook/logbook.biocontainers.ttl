@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:logbook a schema1:SoftwareApplication ;
    schema1:description "A logging replacement for python" ;
    schema1:license "BSD" ;
    schema1:name "logbook" ;
    schema1:url "https://github.com/getlogbook/logbook" .

