@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:cyvcf2 a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btx057" ;
    schema1:description "Library and software package for fast parsing and querying of vcf and bcf files and illustrate its speed, simplicity and utility." ;
    schema1:identifier biotools:cyvcf2 ;
    schema1:keywords "Genetic Variation",
        "Genetic variation",
        "Genomics",
        "Genotype and phenotype",
        "Genotyping Techniques",
        "Humans",
        "Metadata",
        "Sequence Analysis, DNA",
        "Sequence analysis" ;
    schema1:license "MIT" ;
    schema1:name "cyvcf2" ;
    schema1:url "https://github.com/brentp/cyvcf2" .

