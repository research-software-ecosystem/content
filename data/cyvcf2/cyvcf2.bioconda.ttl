@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:cyvcf2 a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btx057" ;
    schema1:description "A cython wrapper around htslib built for fast parsing of Variant Call Format (VCF) files." ;
    schema1:downloadUrl "https://pypi.org/packages/source/c/cyvcf2/cyvcf2-0.32.1.tar.gz" ;
    schema1:identifier biotools:cyvcf2 ;
    schema1:license "MIT" ;
    schema1:name "cyvcf2" ;
    schema1:softwareHelp "https://brentp.github.io/cyvcf2" ;
    schema1:softwareVersion "0.32.1" ;
    schema1:url "https://github.com/brentp/cyvcf2" ;
    spdx:builtFrom biotools:cyvcf2 .

