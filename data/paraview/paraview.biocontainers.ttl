@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:paraview a schema1:SoftwareApplication ;
    schema1:description "ParaView is an open-source, multi-platform data analysis and visualization application based on Visualization Toolkit (VTK)." ;
    schema1:license "BSD-3-Clause" ;
    schema1:name "paraview" ;
    schema1:url "https://github.com/Kitware/ParaView" .

