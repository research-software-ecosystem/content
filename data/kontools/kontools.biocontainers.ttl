@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:kontools a schema1:SoftwareApplication ;
    schema1:description "A collection of python functions for computational biology / bioinformatics. A central feature of kontools is the dbtools library which contains functions necessary for contructing and interfacing with a database of proteomes, genomes, and gene coordinate files derived from NCBI and / or JGI (Joint Genome Institute, Department of Energy) genomes." ;
    schema1:keywords "Proteomics" ;
    schema1:license "MIT" ;
    schema1:name "kontools" ;
    schema1:url "https://gitlab.com/xonq" .

