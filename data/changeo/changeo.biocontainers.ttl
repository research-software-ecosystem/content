@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:changeo a schema1:SoftwareApplication ;
    schema1:description "A bioinformatics toolkit for processing high-throughput lymphocyte receptor sequencing data." ;
    schema1:license "AGPL-3" ;
    schema1:name "changeo" ;
    schema1:url "https://bitbucket.org/kleinstein/changeo/" .

