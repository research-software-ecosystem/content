@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:igv-reports a schema1:SoftwareApplication ;
    schema1:description "Creates self-contained html pages for visual variant review with IGV (igv.js)." ;
    schema1:license "MIT" ;
    schema1:name "igv-reports" ;
    schema1:url "https://github.com/igvteam/igv-reports" .

