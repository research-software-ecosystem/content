@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:gcs-oauth2-boto-plugin a schema1:SoftwareApplication ;
    schema1:description "Auth plugin allowing use the use of oauth 2.0 credentials for google cloud storage in the boto library." ;
    schema1:keywords "Genomics" ;
    schema1:license "Not available" ;
    schema1:name "gcs-oauth2-boto-plugin" ;
    schema1:url "https://developers.google.com/storage/docs/gspythonlibrary" .

