@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:rapmap a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btw277" ;
    schema1:description "Rapid sensitive and accurate dna read mapping via quasi-mapping" ;
    schema1:identifier biotools:rapmap ;
    schema1:keywords "RNA",
        "Sequence Analysis, RNA",
        "Sequence analysis",
        "Transcriptome",
        "Transcriptomics" ;
    schema1:license "GPL-3.0+" ;
    schema1:name "rapmap" ;
    schema1:url "https://github.com/COMBINE-lab/RapMap" .

