@prefix debianmed: <https://salsa.debian.org/med-team/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

debianmed:rapmap a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nbt.3519",
        "doi:10.1093/bioinformatics/btw277" ;
    schema1:description "rapid sensitive and accurate DNA read mapping via quasi-mapping" ;
    schema1:identifier "bio.tools:rapmap",
        "conda:bioconda:rapmap",
        "omictools:OMICS_10349" ;
    schema1:license "unknown" ;
    schema1:name "rapmap" ;
    schema1:softwareVersion "0.15.0" ;
    schema1:url "https://github.com/COMBINE-lab/RapMap" ;
    spdx:builtFrom "rapmap" .

