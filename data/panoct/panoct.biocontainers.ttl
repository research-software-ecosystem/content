@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:panoct a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/gks757" ;
    schema1:description "Panoct, pan-genome ortholog clustering tool, is a program for pan-genomic analysis of closely related prokaryotic species or strains" ;
    schema1:keywords "Clustering",
        "Ortholog" ;
    schema1:license "GNU General Public License v3.0" ;
    schema1:name "panoct" ;
    schema1:url "https://panoct.sourceforge.io/" .

