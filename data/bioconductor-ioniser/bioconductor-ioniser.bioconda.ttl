@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-ioniser a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Quality Assessment Tools for Oxford Nanopore MinION data" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/IONiseR_2.34.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/IONiseR/IONiseR_2.34.0.tar.gz', 'https://bioarchive.galaxyproject.org/IONiseR_2.34.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-ioniser/bioconductor-ioniser_2.34.0_src_all.tar.gz']" ;
    schema1:identifier biotools:ioniser ;
    schema1:license "MIT + file LICENSE" ;
    schema1:name "bioconductor-ioniser" ;
    schema1:softwareVersion "2.34.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/IONiseR.html" ;
    spdx:builtFrom biotools:ioniser .

