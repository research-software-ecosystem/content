@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-dnabarcodes a schema1:SoftwareApplication ;
    schema1:description "A tool for creating and analysing DNA barcodes used in Next Generation Sequencing multiplexing experiments" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/DNABarcodes_1.40.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/DNABarcodes/DNABarcodes_1.40.0.tar.gz', 'https://bioarchive.galaxyproject.org/DNABarcodes_1.40.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-dnabarcodes/bioconductor-dnabarcodes_1.40.0_src_all.tar.gz']" ;
    schema1:identifier biotools:dnabarcodes ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-dnabarcodes" ;
    schema1:softwareVersion "1.40.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/DNABarcodes.html" ;
    spdx:builtFrom biotools:dnabarcodes .

