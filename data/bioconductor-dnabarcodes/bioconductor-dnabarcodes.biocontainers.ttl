@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-dnabarcodes a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/1471-2105-14-272" ;
    schema1:description "A tool for creating and analysing DNA barcodes used in Next Generation Sequencing multiplexing experiments" ;
    schema1:identifier biotools:dnabarcodes ;
    schema1:keywords "DNA",
        "DNA Primers",
        "High-Throughput Nucleotide Sequencing",
        "Models, Genetic",
        "Nucleic Acid Amplification Techniques",
        "Reproducibility of Results",
        "Sequence Analysis, DNA",
        "Sequencing" ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-dnabarcodes" ;
    schema1:url "http://bioconductor.org/packages/3.6/bioc/html/DNABarcodes.html" .

