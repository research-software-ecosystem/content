@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:centrifuge-core a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1101/gr.210641.116" ;
    schema1:description "Classifier for metagenomic sequences. Does not include evaluation scripts" ;
    schema1:downloadUrl "https://github.com/DaehwanKimLab/centrifuge/archive/refs/tags/v1.0.4.2.tar.gz" ;
    schema1:identifier biotools:Centrifuge ;
    schema1:license "GPL-3.0-only" ;
    schema1:name "centrifuge-core" ;
    schema1:softwareHelp "https://genome.cshlp.org/content/26/12/1721" ;
    schema1:softwareVersion "1.0.4.2" ;
    schema1:url "http://www.ccb.jhu.edu/software/centrifuge" ;
    spdx:builtFrom biotools:Centrifuge .

