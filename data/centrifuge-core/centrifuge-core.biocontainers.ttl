@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:centrifuge-core a schema1:SoftwareApplication ;
    schema1:description "Classifier for metagenomic sequences. Does not include evaluation scripts" ;
    schema1:keywords "Genomics",
        "Metagenomics" ;
    schema1:license "GPL-3.0" ;
    schema1:name "centrifuge-core" ;
    schema1:url "https://github.com/infphilo/centrifuge" .

