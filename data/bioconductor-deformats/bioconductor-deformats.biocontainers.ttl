@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-deformats a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Differential gene expression data formats converter" ;
    schema1:identifier biotools:deformats ;
    schema1:keywords "Computational Biology",
        "Gene Expression",
        "Gene Expression Profiling",
        "Gene expression",
        "Genomics",
        "High-Throughput Screening Assays",
        "Programming Languages",
        "User-Computer Interface" ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-deformats" ;
    schema1:url "http://bioconductor.org/packages/3.6/bioc/html/DEFormats.html" .

