@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:transformation a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1021/ac201065j" ;
    schema1:description "Transforms the dataMatrix intensity values." ;
    schema1:keywords "Animals",
        "Chromatography, High Pressure Liquid",
        "Female",
        "Male",
        "Mass spectrometry",
        "Metabolome",
        "Metabolomics",
        "Principal Component Analysis",
        "Rats",
        "Rats, Wistar",
        "Spectrometry, Mass, Electrospray Ionization" ;
    schema1:license "Custom License" ;
    schema1:name "transformation" ;
    schema1:url "https://github.com/phnmnl/container-transformation" .

