  "@graph": [
    {
      "@id": "https://bio.tools/bioconductor-bloodgen3module",
      "@type": "sc:SoftwareApplication",
      "dcterms:conformsTo": "https://bioschemas.org/profiles/ComputationalTool/0.6-DRAFT",
      "sc:additionalType": [
        "Command-line tool",
        "Library"
      ],
      "sc:author": "Darawan Rinchai",
      "sc:citation": {
        "@id": "https://doi.org/10.18129/B9.bioc.BloodGen3Module"
      },
      "sc:description": "The BloodGen3Module package provides functions for R user performing module repertoire analyses and generating fingerprint representations. Functions can perform group comparison or individual sample analysis and visualization by fingerprint grid plot or fingerprint heatmap. Module repertoire analyses typically involve determining the percentage of the constitutive genes for each module that are significantly increased or decreased. As we describe in details;https://www.biorxiv.org/content/10.1101/525709v2 and https://pubmed.ncbi.nlm.nih.gov/33624743/, the results of module repertoire analyses can be represented in a fingerprint format, where red and blue spots indicate increases or decreases in module activity. These spots are subsequently represented either on a grid, with each position being assigned to a given module, or in a heatmap where the samples are arranged in columns and the modules in rows.",
      "sc:license": "GPL-2.0-only",
      "sc:name": "BloodGen3Module",
      "sc:operatingSystem": [
        "Windows",
        "Linux",
        "Mac"
      ],
      "sc:softwareHelp": {
        "@id": "https://bioconductor.org/packages/BloodGen3Module"
      },
      "sc:softwareVersion": "1.18.0",
      "sc:url": "https://bioconductor.org/packages/BloodGen3Module"
    },
    {
      "@id": "https://doi.org/10.18129/B9.bioc.BloodGen3Module",
      "@type": "sc:CreativeWork"
    }
