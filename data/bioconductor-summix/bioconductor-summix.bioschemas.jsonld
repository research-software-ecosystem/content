      "sc:citation": {
        "@id": "https://doi.org/10.1101/2024.01.29.577805"
      },
      "sc:description": "This package contains the Summix2 method for estimating and adjusting for substructure in genetic summary allele frequency data. The function summix() estimates reference group proportions using a mixture model. The adjAF() function produces adjusted allele frequencies for an observed group with reference group proportions matching a target individual or sample. The summix_local() function estimates local ancestry mixture proportions and performs selection scans in genetic summary data.",
      "sc:license": "MIT",
      "sc:name": "Summix",
      "sc:operatingSystem": [
        "Windows",
        "Mac",
        "Linux"
      ],
      "sc:softwareHelp": {
        "@id": "https://bioconductor.org/packages/Summix"
      },
      "sc:softwareVersion": "2.16.0",
      "sc:url": "https://bioconductor.org/packages/Summix"
    }
  ]
