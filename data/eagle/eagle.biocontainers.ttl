@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:eagle a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btv189" ;
    schema1:description "Eagle is a webtool for genome variants and snp analysis" ;
    schema1:identifier biotools:eagle ;
    schema1:keywords "DNA, Viral",
        "Disease Outbreaks",
        "Ebolavirus",
        "Genome, Human",
        "Genome, Viral",
        "Genomics",
        "Hemorrhagic Fever, Ebola",
        "Humans",
        "Sequence Analysis, DNA",
        "Sequencing",
        "Viral Proteins",
        "Virology" ;
    schema1:license "MIT" ;
    schema1:name "eagle" ;
    schema1:url "https://bitbucket.org/christopherschroeder/eagle" .

