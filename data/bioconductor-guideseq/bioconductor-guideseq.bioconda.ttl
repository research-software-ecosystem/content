@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-guideseq a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s12864-017-3746-y" ;
    schema1:description "GUIDE-seq and PEtag-seq analysis pipeline" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/GUIDEseq_1.40.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/GUIDEseq/GUIDEseq_1.40.0.tar.gz', 'https://bioarchive.galaxyproject.org/GUIDEseq_1.40.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-guideseq/bioconductor-guideseq_1.40.0_src_all.tar.gz']" ;
    schema1:identifier biotools:guideseq ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-guideseq" ;
    schema1:softwareVersion "1.40.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/GUIDEseq.html" ;
    spdx:builtFrom biotools:guideseq .

