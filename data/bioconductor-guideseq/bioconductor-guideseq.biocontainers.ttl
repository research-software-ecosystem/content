@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-guideseq a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s12864-017-3746-y" ;
    schema1:description "GUIDE-seq analysis pipeline" ;
    schema1:identifier biotools:guideseq ;
    schema1:keywords "CRISPR-Cas Systems",
        "Databases, Genetic",
        "Deoxyribonucleases",
        "Molecular Sequence Annotation",
        "Nucleic acid sites, features and motifs",
        "Nucleic acid structure analysis",
        "Sequence Analysis, DNA",
        "Statistics as Topic" ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-guideseq" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/GUIDEseq.html" .

