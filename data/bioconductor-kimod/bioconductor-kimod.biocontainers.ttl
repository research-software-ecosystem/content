@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-kimod a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "A k-tables approach to integrate multiple Omics-Data" ;
    schema1:identifier biotools:kimod ;
    schema1:keywords "Computational Biology",
        "Data management",
        "Gene Expression",
        "Gene Expression Profiling",
        "Genomics",
        "High-Throughput Screening Assays",
        "Omics",
        "Programming Languages",
        "Proteomics",
        "RNA-Seq",
        "Transcriptomics",
        "User-Computer Interface" ;
    schema1:license "GPL (>=2)" ;
    schema1:name "bioconductor-kimod" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/kimod.html" .

