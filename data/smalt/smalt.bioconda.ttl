@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:smalt a schema1:SoftwareApplication ;
    schema1:description "SMALT aligns DNA sequencing reads with a reference genome." ;
    schema1:downloadUrl "https://sourceforge.net/projects/smalt/files/smalt-0.7.6.tar.gz" ;
    schema1:identifier biotools:smalt ;
    schema1:license "GPL-3.0-or-later" ;
    schema1:name "smalt" ;
    schema1:softwareHelp "https://www.sanger.ac.uk/tool/smalt" ;
    schema1:softwareVersion "0.7.6" ;
    schema1:url "https://www.sanger.ac.uk/tool/smalt" ;
    spdx:builtFrom biotools:smalt .

