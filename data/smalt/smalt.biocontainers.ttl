@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:smalt a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1016/j.ygeno.2017.03.001",
        "doi:10.1186/1471-2164-15-264" ;
    schema1:description "Aligns dna sequencing reads with a reference genome. reads from a wide range of sequencing platforms can be processed except for solid reads." ;
    schema1:identifier biotools:Smalt ;
    schema1:keywords "Chromosome Mapping",
        "Computational Biology",
        "Databases, Nucleic Acid",
        "Genomics",
        "High-Throughput Nucleotide Sequencing",
        "Internet",
        "Mapping",
        "Reproducibility of Results",
        "Sensitivity and Specificity" ;
    schema1:license "GPL-3.0" ;
    schema1:name "smalt" ;
    schema1:url "http://www.sanger.ac.uk/science/tools/smalt-0" .

