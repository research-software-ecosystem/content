@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:pairsnp a schema1:SoftwareApplication ;
    schema1:description "pairsnp calculates pairwise SNP distance matrices from multiple sequence alignment fasta files." ;
    schema1:keywords "Sequence Alignment" ;
    schema1:license "MIT" ;
    schema1:name "pairsnp" ;
    schema1:url "https://github.com/gtonkinhill/pairsnp" .

