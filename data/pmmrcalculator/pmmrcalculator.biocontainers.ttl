@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:pmmrcalculator a schema1:SoftwareApplication ;
    schema1:description "A small python tool to calculate pairwise mismatch rate between all individuals in an eigenstrat dataset." ;
