@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:nmrmlconv a schema1:SoftwareApplication ;
    schema1:description "nmrML is an open mark-up language for NMR data. This project contains files that are needed to use the tools to convert RAW vendor NMR files to nmrML files." ;
    schema1:keywords "Metabolomics" ;
    schema1:license "MIT" ;
    schema1:name "nmrmlconv" ;
    schema1:url "https://github.com/phnmnl/container-nmrmlconv" .

