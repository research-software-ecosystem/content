@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-dnashaper a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btv735" ;
    schema1:description "High-throughput prediction of DNA shape features" ;
    schema1:identifier biotools:dnashaper ;
    schema1:keywords "DNA",
        "Genome",
        "Genomics",
        "Programming Languages",
        "Structure prediction" ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-dnashaper" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/DNAshapeR.html" .

