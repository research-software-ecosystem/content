@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-dnashaper a schema1:SoftwareApplication ;
    schema1:description "High-throughput prediction of DNA shape features" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/DNAshapeR_1.38.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/DNAshapeR/DNAshapeR_1.38.0.tar.gz', 'https://bioarchive.galaxyproject.org/DNAshapeR_1.38.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-dnashaper/bioconductor-dnashaper_1.38.0_src_all.tar.gz']" ;
    schema1:identifier biotools:dnashaper ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-dnashaper" ;
    schema1:softwareVersion "1.38.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/DNAshapeR.html" ;
    spdx:builtFrom biotools:dnashaper .

