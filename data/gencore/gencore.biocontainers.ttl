@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:gencore a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/S12859-019-3280-9" ;
    schema1:description "Generate consensus reads to reduce sequencing noises and remove duplications" ;
    schema1:identifier biotools:gencore ;
    schema1:keywords "Consensus Sequence",
        "Genetic variation",
        "High-Throughput Nucleotide Sequencing",
        "Humans",
        "Mapping",
        "Mutation",
        "Quality Control",
        "Sequence Alignment",
        "Sequencing" ;
    schema1:license "MIT" ;
    schema1:name "gencore" ;
    schema1:url "https://github.com/OpenGene/gencore" .

