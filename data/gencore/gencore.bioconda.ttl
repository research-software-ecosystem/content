@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:gencore a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s12859-019-3280-9" ;
    schema1:description "Generate consensus reads to reduce sequencing noises and remove duplications." ;
    schema1:downloadUrl "https://github.com/OpenGene/gencore/archive/v0.17.2.tar.gz" ;
    schema1:identifier biotools:gencore ;
    schema1:license "MIT" ;
    schema1:name "gencore" ;
    schema1:softwareHelp "https://github.com/OpenGene/gencore/blob/v0.17.2/README.md" ;
    schema1:softwareVersion "0.17.2" ;
    schema1:url "https://github.com/OpenGene/gencore" ;
    spdx:builtFrom biotools:gencore .

