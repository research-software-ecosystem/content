@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:rattle a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s13059-022-02715-w" ;
    schema1:description "Reference-free reconstruction and quantification of transcriptomes from long-read sequencing." ;
    schema1:downloadUrl "https://github.com/comprna/RATTLE/releases/download/v1.0/RATTLE-1.0.tar.gz" ;
    schema1:identifier biotools:rattle ;
    schema1:license "GPL-3.0-or-later" ;
    schema1:name "rattle" ;
    schema1:softwareHelp "https://github.com/comprna/RATTLE/blob/v1.0/README.md" ;
    schema1:softwareVersion "1.0" ;
    schema1:url "https://github.com/comprna/RATTLE" ;
    spdx:builtFrom biotools:rattle .

