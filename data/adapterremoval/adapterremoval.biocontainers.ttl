@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:adapterremoval a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/bts311" ;
    schema1:description "Rapid adapter trimming, identification, and read merging of gene sequences" ;
    schema1:identifier biotools:adapter_removal ;
    schema1:keywords "Computational Biology",
        "Genomics",
        "MicroRNAs",
        "RNA",
        "RNA Interference",
        "Sequence Analysis, RNA",
        "Workflows" ;
    schema1:license "GPL-3.0+" ;
    schema1:name "adapterremoval" ;
    schema1:url "https://github.com/MikkelSchubert/adapterremoval" .

