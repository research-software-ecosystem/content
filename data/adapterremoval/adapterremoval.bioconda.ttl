@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:adapterremoval a schema1:SoftwareApplication ;
    schema1:description "The AdapterRemoval v2 tool for merging and clipping reads." ;
    schema1:downloadUrl "https://github.com/MikkelSchubert/adapterremoval/archive/v2.3.4.tar.gz" ;
    schema1:identifier biotools:adapterremoval ;
    schema1:license "GPL-3.0-or-later" ;
    schema1:name "adapterremoval" ;
    schema1:softwareVersion "2.3.4" ;
    schema1:url "https://github.com/MikkelSchubert/adapterremoval" ;
    spdx:builtFrom biotools:adapterremoval .

