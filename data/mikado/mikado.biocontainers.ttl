@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:mikado a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/gigascience/giy093" ;
    schema1:description "A Python3 annotation program to select the best gene model in each locus" ;
    schema1:identifier biotools:mikado ;
    schema1:keywords "Animals",
        "Gene Expression Profiling",
        "Gene transcripts",
        "High-Throughput Nucleotide Sequencing",
        "Humans",
        "Molecular Sequence Annotation",
        "Plants",
        "RNA-Seq",
        "RNA-seq",
        "Sequence Analysis, RNA",
        "Transcriptome" ;
    schema1:license "GNU Lesser General Public License v3 or later (LGPLv3+)" ;
    schema1:name "mikado" ;
    schema1:url "https://github.com/lucventurini/mikado" .

