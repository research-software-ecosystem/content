@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:mikado a schema1:SoftwareApplication ;
    schema1:author "gemygk",
        "ljyanesm",
        "lucventurini",
        "swarbred" ;
    schema1:citation "doi:10.1093/gigascience/giy093",
        "doi:10.1093/gigascience/giy131" ;
    schema1:description "A Python3 annotation program to select the best gene model in each locus." ;
    schema1:downloadUrl "https://github.com/EI-CoreBioinformatics/mikado/archive/refs/tags/v2.3.5rc3.tar.gz" ;
    schema1:identifier biotools:mikado ;
    schema1:license "LGPL-3.0-or-later" ;
    schema1:maintainer "gemygk",
        "ljyanesm",
        "lucventurini",
        "swarbred" ;
    schema1:name "mikado" ;
    schema1:softwareHelp "https://mikado.readthedocs.io/en/stable" ;
    schema1:softwareVersion "2.3.5rc3" ;
    schema1:url "https://github.com/EI-CoreBioinformatics/mikado" ;
    spdx:builtFrom biotools:mikado .

