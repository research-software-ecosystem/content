@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-raceid a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.4662" ;
    schema1:description "Application of 'RaceID' allows inference of cell types and prediction of lineage trees by the StemID2 algorithm." ;
    schema1:keywords "Clustering",
        "Gene Expression",
        "RNA-Seq" ;
    schema1:license "GPL-3" ;
    schema1:name "r-raceid" ;
    schema1:url "https://github.com/dgrun/RaceID3_StemID2_package" .

