@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-geneselector a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18129/b9.bioc.geneselector" ;
    schema1:description "The term 'GeneSelector' refers to a filter selecting those genes which are consistently identified as differentially expressed using various statistical procedures. 'Selected' genes are those present at the top of the list in various ranking methods (currently 14). In addition, the stability of the findings can be taken into account in the final ranking by examining perturbed versions of the original data set, e.g. by leaving samples, swapping class labels, generating bootstrap replicates or adding noise. Given multiple ranked lists, one can use aggregation methods in order to find a synthesis." ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-geneselector" ;
    schema1:url "http://bioconductor.org/packages/3.6/bioc/html/GeneSelector.html" .

