@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-bionet a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btq089" ;
    schema1:description "Routines for the functional analysis of biological networks" ;
    schema1:identifier biotools:bionet ;
    schema1:keywords "Databases, Factual",
        "Genomics",
        "Molecular interactions, pathways and networks",
        "Protein Interaction Mapping",
        "Protein interactions",
        "Proteome" ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-bionet" ;
    schema1:url "None" .

