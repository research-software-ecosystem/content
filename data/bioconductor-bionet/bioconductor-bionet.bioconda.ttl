@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-bionet a schema1:SoftwareApplication ;
    schema1:description "Routines for the functional analysis of biological networks" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/BioNet_1.66.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/BioNet/BioNet_1.66.0.tar.gz', 'https://bioarchive.galaxyproject.org/BioNet_1.66.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-bionet/bioconductor-bionet_1.66.0_src_all.tar.gz']" ;
    schema1:identifier biotools:bionet ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-bionet" ;
    schema1:softwareVersion "1.66.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/BioNet.html" ;
    spdx:builtFrom biotools:bionet .

