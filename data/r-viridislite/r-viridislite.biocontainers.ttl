@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-viridislite a schema1:SoftwareApplication ;
    schema1:description "Port of the new matplotlib color maps (viridis - the default -, magma, plasma and inferno) to R. matplotlib <http://matplotlib.org/ > is a popular plotting library for python. These color maps are designed in such a way that they will analytically be perfectly perceptually-uniform, both in regular form and also when converted to black-and-white. They are also designed to be perceived by readers with the most common form of color blindness." ;
    schema1:license "MIT" ;
    schema1:name "r-viridislite" ;
    schema1:url "https://github.com/sjmgarnier/viridisLite" .

