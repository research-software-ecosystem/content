@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-bgeedb a schema1:SoftwareApplication ;
    schema1:citation "doi:10.12688/f1000research.9973.1" ;
    schema1:description "Annotation and gene expression data retrieval from Bgee database. TopAnat, an anatomical entities Enrichment Analysis tool for UBERON ontology" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/BgeeDB_2.32.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/BgeeDB/BgeeDB_2.32.0.tar.gz', 'https://bioarchive.galaxyproject.org/BgeeDB_2.32.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-bgeedb/bioconductor-bgeedb_2.32.0_src_all.tar.gz']" ;
    schema1:identifier biotools:bgeedb ;
    schema1:license "GPL-3 + file LICENSE" ;
    schema1:name "bioconductor-bgeedb" ;
    schema1:softwareVersion "2.32.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/BgeeDB.html" ;
    spdx:builtFrom biotools:bgeedb .

