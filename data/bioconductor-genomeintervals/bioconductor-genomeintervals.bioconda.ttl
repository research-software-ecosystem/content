@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-genomeintervals a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Operations on genomic intervals" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/genomeIntervals_1.62.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/genomeIntervals/genomeIntervals_1.62.0.tar.gz', 'https://bioarchive.galaxyproject.org/genomeIntervals_1.62.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-genomeintervals/bioconductor-genomeintervals_1.62.0_src_all.tar.gz']" ;
    schema1:identifier biotools:genomeintervals ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-genomeintervals" ;
    schema1:softwareVersion "1.62.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/genomeIntervals.html" ;
    spdx:builtFrom biotools:genomeintervals .

