@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-edge a schema1:SoftwareApplication ;
    schema1:description "Extraction of Differential Gene Expression" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/edge_2.42.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/edge/edge_2.42.0.tar.gz', 'https://bioarchive.galaxyproject.org/edge_2.42.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-edge/bioconductor-edge_2.42.0_src_all.tar.gz']" ;
    schema1:identifier biotools:edge ;
    schema1:license "MIT + file LICENSE" ;
    schema1:name "bioconductor-edge" ;
    schema1:softwareVersion "2.42.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/edge.html" ;
    spdx:builtFrom biotools:edge .

