@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:perl-appconfig a schema1:SoftwareApplication ;
    schema1:description "Appconfig is a bundle of perl5 modules for reading configuration files and parsing command line arguments." ;
    schema1:license "perl_5" ;
    schema1:name "perl-appconfig" ;
    schema1:url "http://metacpan.org/pod/AppConfig" .

