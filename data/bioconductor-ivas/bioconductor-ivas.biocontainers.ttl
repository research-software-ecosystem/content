@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-ivas a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1007/s13258-016-0466-7" ;
    schema1:description "Identification of genetic Variants affecting Alternative Splicing" ;
    schema1:identifier biotools:ivas ;
    schema1:keywords "RNA splicing",
        "RNA-Seq" ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-ivas" ;
    schema1:url "http://bioconductor.org/packages/3.6/bioc/html/IVAS.html" .

