@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-ivas a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1007/s13258-016-0466-7" ;
    schema1:description "Identification of genetic Variants affecting Alternative Splicing" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/IVAS_2.26.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/IVAS/IVAS_2.26.0.tar.gz', 'https://bioarchive.galaxyproject.org/IVAS_2.26.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-ivas/bioconductor-ivas_2.26.0_src_all.tar.gz']" ;
    schema1:identifier biotools:ivas ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-ivas" ;
    schema1:softwareVersion "2.26.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/IVAS.html" ;
    spdx:builtFrom biotools:ivas .

