@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:translig a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s13059-019-1690-7" ;
    schema1:description "A de novo transcriptome assembler that uses line graph iteration" ;
    schema1:keywords "Alternative Splicing",
        "Animals",
        "Gene Expression Profiling",
        "Humans",
        "K562 Cells",
        "Mice",
        "RNA-Seq",
        "Sequence Alignment",
        "Transcriptome" ;
    schema1:license "GPL-3.0" ;
    schema1:name "translig" ;
    schema1:url "https://sourceforge.net/projects/transcriptomeassembly/" .

