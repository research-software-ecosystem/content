@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:orthofinder a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1101/466201",
        "doi:10.1186/s13059-015-0721-2" ;
    schema1:description "Accurate inference of orthogroups, orthologues, gene trees and rooted species tree made easy!" ;
    schema1:keywords "Clustering",
        "Genes, Plant",
        "Genomics",
        "Multigene Family",
        "Ortholog",
        "Phylogeny",
        "Proteins",
        "Sequence Alignment",
        "Transcription Factors" ;
    schema1:license "GPL-3.0" ;
    schema1:name "orthofinder" ;
    schema1:url "https://github.com/davidemms/OrthoFinder" .

