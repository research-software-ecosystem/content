@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:plassembler a schema1:SoftwareApplication ;
    schema1:author "gbouras13" ;
    schema1:citation "doi:10.1093/bioinformatics/btad409" ;
    schema1:description "Quickly and accurately assemble plasmids in hybrid sequenced bacterial isolates." ;
    schema1:downloadUrl "https://pypi.io/packages/source/p/plassembler/plassembler-1.8.2.tar.gz" ;
    schema1:identifier biotools:plassembler ;
    schema1:license "MIT" ;
    schema1:maintainer "gbouras13" ;
    schema1:name "plassembler" ;
    schema1:softwareHelp "https://plassembler.readthedocs.io/en/latest" ;
    schema1:softwareVersion "1.8.2" ;
    schema1:url "https://github.com/gbouras13/plassembler" ;
    spdx:builtFrom biotools:plassembler .

