@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:grep a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1371/journal.pcbi.1001025" ;
    schema1:description "Grep searches one or more input files for lines containing a match to a specified pattern" ;
    schema1:identifier biotools:gerp ;
    schema1:keywords "Animals",
        "DNA",
        "Genetics",
        "Genome, Human",
        "Genomics",
        "Humans",
        "Mammals",
        "Models, Genetic",
        "Phylogeny",
        "Sequence Alignment",
        "Sequence Analysis, DNA",
        "Sequence analysis",
        "User-Computer Interface" ;
    schema1:license "GPL" ;
    schema1:name "grep" ;
    schema1:url "https://www.gnu.org/software/grep/" .

