@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:dnapi a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1371/journal.pone.0164228" ;
    schema1:description "De novo adapter prediction (iterative) algorithm for small RNA sequencing data." ;
    schema1:keywords "Databases, Genetic",
        "High-Throughput Nucleotide Sequencing",
        "Humans",
        "Metadata",
        "RNA, Small Untranslated",
        "Sequence Analysis, RNA" ;
    schema1:license "MIT" ;
    schema1:name "dnapi" ;
    schema1:url "https://github.com/jnktsj/DNApi" .

