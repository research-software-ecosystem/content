@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:scssim a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/BIOINFORMATICS/BTZ713" ;
    schema1:description "A bioinformatics tool for simulating single-cell genome sequencing data" ;
    schema1:keywords "Chromosome Mapping",
        "Genomics",
        "High-Throughput Nucleotide Sequencing",
        "Sequence Analysis, DNA",
        "Whole Genome Sequencing" ;
    schema1:license "BSD-3-Clause" ;
    schema1:name "scssim" ;
    schema1:url "https://github.com/qasimyu/scssim" .

