@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:sonicparanoid a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/bty631",
        "doi:10.1101/2023.05.14.540736" ;
    schema1:description "SonicParanoid: fast, accurate, and comprehensive orthology inference with machine learning and language models" ;
    schema1:downloadUrl "https://pypi.org/packages/source/s/sonicparanoid/sonicparanoid-2.0.9.tar.gz" ;
    schema1:identifier biotools:SonicParanoid ;
    schema1:license "GPL-3.0-only" ;
    schema1:name "sonicparanoid" ;
    schema1:softwareHelp "https://gitlab.com/salvo981/sonicparanoid2/-/wikis/home" ;
    schema1:softwareVersion "2.0.9" ;
    schema1:url "https://gitlab.com/salvo981/sonicparanoid2" ;
    spdx:builtFrom biotools:SonicParanoid .

