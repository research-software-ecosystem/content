@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-mapredictdsc a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btt492" ;
    schema1:description "Phenotype prediction using microarray data: approach of the best overall team in the IMPROVER Diagnostic Signature Challenge" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/maPredictDSC_1.44.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/maPredictDSC/maPredictDSC_1.44.0.tar.gz', 'https://bioarchive.galaxyproject.org/maPredictDSC_1.44.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-mapredictdsc/bioconductor-mapredictdsc_1.44.0_src_all.tar.gz']" ;
    schema1:identifier biotools:mapredictdsc ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-mapredictdsc" ;
    schema1:softwareVersion "1.44.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/maPredictDSC.html" ;
    spdx:builtFrom biotools:mapredictdsc .

