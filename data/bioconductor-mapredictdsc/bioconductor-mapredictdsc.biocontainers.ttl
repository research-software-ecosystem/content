        "Gene Expression Profiling",
        "Humans",
        "Lung Neoplasms",
        "Medicine",
        "Molecular Diagnostic Techniques",
        "Multiple Sclerosis",
        "Oligonucleotide Array Sequence Analysis",
        "Phenotype",
        "Psoriasis",
        "Pulmonary Disease, Chronic Obstructive" ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-mapredictdsc" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/maPredictDSC.html" .

