@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:plasmidhawk a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1101/2020.05.22.110270" ;
    schema1:description "Plasmidhawk is a program for detecting lab-of-origin of input plasmids by building an annotated pangenome of training plasmids." ;
    schema1:license "Not available" ;
    schema1:name "plasmidhawk" ;
    schema1:url "https://gitlab.com/treangenlab/plasmidhawk" .

