@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-oligo a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btq431" ;
    schema1:description "Preprocessing tools for oligonucleotide arrays" ;
    schema1:identifier biotools:oligo ;
    schema1:keywords "Databases, Factual",
        "Gene Expression Profiling",
        "Genetics",
        "Oligonucleotide Array Sequence Analysis",
        "Oligonucleotides",
        "Sequence analysis",
        "User-Computer Interface" ;
    schema1:license "LGPL (>= 2)" ;
    schema1:name "bioconductor-oligo" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/oligo.html" .

