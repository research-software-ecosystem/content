@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-oligo a schema1:SoftwareApplication ;
    schema1:description "Preprocessing tools for oligonucleotide arrays" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/oligo_1.70.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/oligo/oligo_1.70.0.tar.gz', 'https://bioarchive.galaxyproject.org/oligo_1.70.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-oligo/bioconductor-oligo_1.70.0_src_all.tar.gz']" ;
    schema1:identifier biotools:oligo ;
    schema1:license "LGPL (>= 2)" ;
    schema1:name "bioconductor-oligo" ;
    schema1:softwareVersion "1.70.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/oligo.html" ;
    spdx:builtFrom biotools:oligo .

