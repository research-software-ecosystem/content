@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-mosaics a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1198/jasa.2011.ap09706" ;
    schema1:description "MOSAiCS (MOdel-based one and two Sample Analysis and Inference for ChIP-Seq)" ;
    schema1:identifier biotools:mosaics ;
    schema1:keywords "ChIP-seq",
        "Gene regulation",
        "Genetics",
        "Transcription factors and regulatory sites" ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-mosaics" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/mosaics.html" .

