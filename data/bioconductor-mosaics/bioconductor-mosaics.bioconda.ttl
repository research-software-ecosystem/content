@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-mosaics a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1198/jasa.2011.ap09706" ;
    schema1:description "MOSAiCS (MOdel-based one and two Sample Analysis and Inference for ChIP-Seq)" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/mosaics_2.48.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/mosaics/mosaics_2.48.0.tar.gz', 'https://bioarchive.galaxyproject.org/mosaics_2.48.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-mosaics/bioconductor-mosaics_2.48.0_src_all.tar.gz']" ;
    schema1:identifier biotools:mosaics ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-mosaics" ;
    schema1:softwareVersion "2.48.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/mosaics.html" ;
    spdx:builtFrom biotools:mosaics .

