@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:vsclust a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/bty224" ;
    schema1:description "Interactive tool for statistical testing, data browsing and interactive visualizationc of quantitative omics data" ;
    schema1:identifier biotools:vsclust ;
    schema1:keywords "Cluster Analysis",
        "Clustering",
        "Data mining",
        "Genomics",
        "Metabolomics",
        "Omics",
        "Proteomics",
        "Statistics and probability" ;
    schema1:license "GPL (>=2)" ;
    schema1:name "vsclust" ;
    schema1:url "https://bitbucket.org/veitveit/vsclust/src/master/" .

