@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:vsclust a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/bty224" ;
    schema1:description "Interactive tool for statistical testing, data browsing and interactive visualization of quantitative omics data" ;
    schema1:downloadUrl "https://bitbucket.org/veitveit/vsclust/get/release-0.91.tar.gz" ;
    schema1:identifier biotools:vsclust ;
    schema1:license "GPL (>=2)" ;
    schema1:name "vsclust" ;
    schema1:softwareVersion "0.91" ;
    schema1:url "https://bitbucket.org/veitveit/vsclust/src/master/" ;
    spdx:builtFrom biotools:vsclust .

