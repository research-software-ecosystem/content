@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:metabinkit a schema1:SoftwareApplication ;
    schema1:author "nuno.fonseca" ;
    schema1:citation "doi:10.5281/zenodo.3855032" ;
    schema1:description "Set of programs to perform taxonomic binning." ;
    schema1:downloadUrl "https://github.com/envmetagen/metabinkit/archive/0.2.3.tar.gz" ;
    schema1:identifier biotools:metabinkit ;
    schema1:license "GPL-3" ;
    schema1:maintainer "nuno.fonseca" ;
    schema1:name "metabinkit" ;
    schema1:softwareHelp "https://github.com/envmetagen/metabinkit" ;
    schema1:softwareVersion "0.2.3" ;
    schema1:url "https://github.com/envmetagen/metabinkit" ;
    spdx:builtFrom biotools:metabinkit .

