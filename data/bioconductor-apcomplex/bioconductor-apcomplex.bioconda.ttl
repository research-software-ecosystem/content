@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-apcomplex a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/bti567" ;
    schema1:description "Estimate protein complex membership using AP-MS protein data" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/apComplex_2.76.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/apComplex/apComplex_2.76.0.tar.gz', 'https://bioarchive.galaxyproject.org/apComplex_2.76.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-apcomplex/bioconductor-apcomplex_2.76.0_src_all.tar.gz']" ;
    schema1:identifier biotools:apcomplex ;
    schema1:license "LGPL" ;
    schema1:name "bioconductor-apcomplex" ;
    schema1:softwareVersion "2.76.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/apComplex.html" ;
    spdx:builtFrom biotools:apcomplex .

