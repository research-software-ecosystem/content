@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-apcomplex a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/bti567" ;
    schema1:description "Estimate protein complex membership using AP-MS protein data" ;
    schema1:identifier biotools:apcomplex ;
    schema1:keywords "Cell Physiological Phenomena",
        "Computer Simulation",
        "Gene Expression Profiling",
        "Gene Expression Regulation",
        "Models, Biological",
        "Protein Interaction Mapping",
        "Protein structure analysis",
        "Proteins",
        "Proteome",
        "Proteomics experiment",
        "Signal Transduction",
        "Structural biology",
        "Transcription Factors" ;
    schema1:license "LGPL" ;
    schema1:name "bioconductor-apcomplex" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/apComplex.html" .

