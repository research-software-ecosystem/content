@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-markdown a schema1:SoftwareApplication ;
    schema1:description "Convert R Markdown documents into a variety of formats." ;
    schema1:license "GPL-3" ;
    schema1:name "r-markdown" ;
    schema1:url "https://rmarkdown.rstudio.com" .

