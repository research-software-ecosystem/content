@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:fingerprintscan a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/28.1.225" ;
    schema1:description "Search against FingerPRINTScan with a protein query sequence to identify the closest matching PRINTS sequence motif fingerprints in a protein sequence." ;
    schema1:identifier biotools:fingerprintscan ;
    schema1:keywords "Database Management Systems",
        "Databases, Factual",
        "Gene and protein families",
        "Information Storage and Retrieval",
        "Protein Sequences",
        "Proteins",
        "Sequence sites, features and motifs" ;
    schema1:license "GPL-2.0" ;
    schema1:name "fingerprintscan" ;
    schema1:url "https://github.com/ebi-pf-team/interproscan" .

