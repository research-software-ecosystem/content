@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-xcms a schema1:SoftwareApplication ;
    schema1:description "LC-MS and GC-MS Data Analysis" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/xcms_4.4.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/xcms/xcms_4.4.0.tar.gz', 'https://bioarchive.galaxyproject.org/xcms_4.4.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-xcms/bioconductor-xcms_4.4.0_src_all.tar.gz']" ;
    schema1:identifier biotools:xcms ;
    schema1:license "GPL (>= 2) + file LICENSE" ;
    schema1:name "bioconductor-xcms" ;
    schema1:softwareVersion "4.4.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/xcms.html" ;
    spdx:builtFrom biotools:xcms .

