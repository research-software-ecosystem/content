@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:pyensembl a schema1:SoftwareApplication ;
    schema1:description "Python interface to ensembl reference genome metadata" ;
    schema1:license "Apache-2.0" ;
    schema1:name "pyensembl" ;
    schema1:url "https://github.com/openvax/pyensembl" .

