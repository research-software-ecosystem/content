@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-logging a schema1:SoftwareApplication ;
    schema1:description "logging is a pure R package that implements the ubiquitous log4j package." ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "r-logging" ;
    schema1:url "https://CRAN.R-project.org/package=logging" .

