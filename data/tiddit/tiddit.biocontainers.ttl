@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:tiddit a schema1:SoftwareApplication ;
    schema1:citation "doi:10.12688/f1000research.11168.2" ;
    schema1:description "TIDDIT - structural variant calling." ;
    schema1:identifier biotools:tiddit ;
    schema1:keywords "Clustering",
        "DNA structural variation",
        "Exome sequencing",
        "Whole genome sequencing" ;
    schema1:license "GPL-3" ;
    schema1:name "tiddit" ;
    schema1:url "https://github.com/SciLifeLab/TIDDIT" .

