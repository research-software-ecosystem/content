@prefix debianmed: <https://salsa.debian.org/med-team/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

debianmed:tiddit a schema1:SoftwareApplication ;
    schema1:identifier "bio.tools:tiddit",
        "conda:bioconda:tiddit" ;
    schema1:license "unknown" ;
    schema1:name "tiddit" ;
    schema1:softwareVersion "3.6.1" ;
