@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-dyndoc a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "A set of functions to create and interact with dynamic documents and vignettes." ;
    schema1:identifier biotools:dyndoc ;
    schema1:keywords "Computational Biology",
        "Data submission, annotation and curation",
        "Gene Expression Profiling",
        "Genomics",
        "High-Throughput Screening Assays",
        "Programming Languages",
        "User-Computer Interface" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-dyndoc" ;
    schema1:url "http://bioconductor.org/packages/release/bioc/html/DynDoc.html" .

