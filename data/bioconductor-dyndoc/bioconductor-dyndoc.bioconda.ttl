@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-dyndoc a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Dynamic document tools" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/DynDoc_1.84.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/DynDoc/DynDoc_1.84.0.tar.gz', 'https://bioarchive.galaxyproject.org/DynDoc_1.84.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-dyndoc/bioconductor-dyndoc_1.84.0_src_all.tar.gz']" ;
    schema1:identifier biotools:dyndoc ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-dyndoc" ;
    schema1:softwareVersion "1.84.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/DynDoc.html" ;
    spdx:builtFrom biotools:dyndoc .

