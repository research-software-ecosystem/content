@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:sicer a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btp340" ;
    schema1:description "A clustering approach for identification of enriched domains from histone modification chip-seq data" ;
    schema1:identifier biotools:sicer ;
    schema1:keywords "ChIP-seq",
        "Chromatin Immunoprecipitation",
        "Cluster Analysis",
        "Clustering",
        "Computational Biology",
        "Epigenomics",
        "Genome",
        "Histones",
        "Protein Structure, Tertiary",
        "Sequence Analysis, DNA" ;
    schema1:license "MIT" ;
    schema1:name "sicer" ;
    schema1:url "http://home.gwu.edu/~wpeng/Software.htm" .

