@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:ssaha2 a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1101/gr.194201",
        "doi:10.1186/1471-2164-15-264",
        "doi:10.7490/f1000research.1114334.1" ;
    schema1:description "Ssaha2 maps dna sequencing reads onto a genomic reference sequence using a combination of word hashing and dynamic programming" ;
    schema1:identifier biotools:ssaha2 ;
    schema1:keywords "Chromosome Mapping",
        "Computational Biology",
        "Databases, Nucleic Acid",
        "Genomics",
        "High-Throughput Nucleotide Sequencing",
        "Internet",
        "Mapping",
        "Reproducibility of Results",
        "Sensitivity and Specificity",
        "Sequence Alignment" ;
    schema1:license "GPL-3.0" ;
    schema1:name "ssaha2" ;
    schema1:url "http://www.sanger.ac.uk/science/tools/ssaha2-0" .

