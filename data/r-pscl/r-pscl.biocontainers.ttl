@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-pscl a schema1:SoftwareApplication ;
    schema1:description "Bayesian analysis of item-response theory (IRT) models, roll call analysis; computing highest density regions; maximum likelihood estimation of zero-inflated and hurdle models for count data; goodness-of-fit measures for GLMs; data sets used in writing and teaching at the Political Science Computational Laboratory; seats-votes curves." ;
    schema1:license "GPL-2.0" ;
    schema1:name "r-pscl" ;
    schema1:url "http://pscl.stanford.edu/" .

