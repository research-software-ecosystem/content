@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:lordfast a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/bty544" ;
    schema1:description "Sensitive and Fast Alignment Search Tool for Long Read sequencing Data" ;
    schema1:keywords "Computational Biology",
        "Genome, Human",
        "Genomics",
        "High-Throughput Nucleotide Sequencing",
        "Humans",
        "Sequence Analysis, DNA" ;
    schema1:license "GPL-3.0" ;
    schema1:name "lordfast" ;
    schema1:url "https://github.com/vpc-ccg/lordfast" .

