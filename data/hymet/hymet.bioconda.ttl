@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:hymet a schema1:SoftwareApplication ;
    schema1:author "inesbmartins02",
        "jorgeMFS" ;
    schema1:description "HYMET provides hybrid Mash+minimap2 metagenomic classification with benchmark and case-study tooling." ;
    schema1:downloadUrl "https://github.com/ieeta-pt/HYMET/archive/refs/tags/v1.3.0.tar.gz" ;
    schema1:identifier biotools:hymet ;
    schema1:license "MIT" ;
    schema1:maintainer "inesbmartins02",
        "jorgeMFS" ;
    schema1:name "hymet" ;
    schema1:softwareHelp "https://github.com/ieeta-pt/HYMET" ;
    schema1:softwareVersion "1.3.0" ;
    schema1:url "https://github.com/ieeta-pt/HYMET" ;
    spdx:builtFrom biotools:hymet .

