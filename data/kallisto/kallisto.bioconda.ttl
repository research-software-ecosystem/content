@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:kallisto a schema1:SoftwareApplication ;
    schema1:author "mjsteinbaugh" ;
    schema1:citation "doi:10.1038/nbt.3519" ;
    schema1:description "Quantifying abundances of transcripts from RNA-Seq data, or more generally of target sequences using high-throughput sequencing reads." ;
    schema1:downloadUrl "https://github.com/pachterlab/kallisto/archive/refs/tags/v0.52.0.tar.gz" ;
    schema1:identifier biotools:kallisto ;
    schema1:license "BSD-2-Clause" ;
    schema1:maintainer "mjsteinbaugh" ;
    schema1:name "kallisto" ;
    schema1:softwareHelp "https://pachterlab.github.io/kallisto/manual.html" ;
    schema1:softwareVersion "0.52.0" ;
    schema1:url "https://pachterlab.github.io/kallisto" ;
    spdx:builtFrom biotools:kallisto .

