galaxytool:kallisto a schema1:SoftwareApplication ;
    schema1:applicationSubCategory "edam:topic_0203",
        "edam:topic_3170",
        "edam:topic_3308" ;
    schema1:description "kallisto is a program for quantifying abundances of transcripts from RNA-Seqdata, or more generally of target sequences using high-throughput sequencingreads. It is based on the novel idea of pseudoalignment for rapidlydetermining the compatibility of reads with targets, without the need foralignment." ;
    schema1:featureList edam:operation_0314 ;
    schema1:identifier "bioconda:kallisto",
        "biotools:kallisto",
        "galaxywf:workflow?id=385cc7df70d7916",
        "galaxywf:workflow?id=fd90652d475ed739" ;
    schema1:keywords "Transcriptomics" ;
    schema1:name "kallisto" ;
    schema1:softwareVersion "0.48.0" ;
    schema1:url "https://pachterlab.github.io/kallisto/" .

