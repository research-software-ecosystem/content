@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:kallisto a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nbt.3519" ;
    schema1:description "Quantifying abundances of transcripts from rna-seq data, or more generally of target sequences using high-throughput sequencing reads" ;
    schema1:identifier biotools:kallisto ;
    schema1:keywords "Computer Simulation",
        "Data Interpretation, Statistical",
        "Gene expression",
        "High-Throughput Nucleotide Sequencing",
        "Models, Statistical",
        "Pattern Recognition, Automated",
        "RNA",
        "RNA-Seq",
        "RNA-seq",
        "Reproducibility of Results",
        "Sensitivity and Specificity",
        "Sequence Alignment",
        "Sequence Analysis, RNA",
        "Transcriptome",
        "Transcriptomics" ;
    schema1:license "BSD-2-Clause" ;
    schema1:name "kallisto" ;
    schema1:url "https://github.com/pachterlab/kallisto/" .

