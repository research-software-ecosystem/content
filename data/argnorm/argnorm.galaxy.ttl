        "biotools:argnorm",
        "workflowhub:2024?version=4",
        "workflowhub:2068?version=2" ;
    schema1:keywords "Genome annotation" ;
    schema1:name "argnorm" ;
    schema1:softwareVersion "1.0.0" ;
    schema1:url "https://github.com/BigDataBiology/argNorm" .

