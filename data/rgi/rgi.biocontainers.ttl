@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:rgi a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/gkw1004" ;
    schema1:description "This tool provides a preliminary annotation of your dna sequence(s) based upon the data available in the comprehensive antibiotic resistance database (card). hits to genes tagged with antibiotic resistance ontology terms will be highlighted. as card expands to include more pathogens, genomes, plasmids, and ontology terms this tool will grow increasingly powerful in providing first-pass detection of antibiotic resistance associated genes. see license at card website" ;
    schema1:keywords "Biological Ontologies",
        "Computational Biology",
        "Data Curation",
        "Databases, Genetic",
        "Drug Resistance, Microbial",
        "Genomics",
        "Microbiology",
        "Web Browser" ;
    schema1:license "Custom License" ;
    schema1:name "rgi" ;
    schema1:url "https://card.mcmaster.ca" .

