@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-gmapr a schema1:SoftwareApplication ;
    schema1:description "An R interface to the GMAP/GSNAP/GSTRUCT suite" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/gmapR_1.51.1.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/gmapR/gmapR_1.51.1.tar.gz', 'https://bioarchive.galaxyproject.org/gmapR_1.51.1.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-gmapr/bioconductor-gmapr_1.51.1_src_all.tar.gz']" ;
    schema1:identifier biotools:gmapr ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-gmapr" ;
    schema1:softwareVersion "1.51.1" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/gmapR.html" ;
    spdx:builtFrom biotools:gmapr .

