@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-pathvar a schema1:SoftwareApplication ;
    schema1:citation "doi:10.7717/peerj.3334" ;
    schema1:description "Methods to Find Pathways with Significantly Different Variability" ;
    schema1:identifier biotools:pathvar ;
    schema1:keywords "Genetics",
        "Molecular interactions, pathways and networks" ;
    schema1:license "LGPL (>= 2.0)" ;
    schema1:name "bioconductor-pathvar" ;
    schema1:url "http://bioconductor.org/packages/3.6/bioc/html/pathVar.html" .

