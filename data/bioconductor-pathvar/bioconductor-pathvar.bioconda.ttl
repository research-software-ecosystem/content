@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-pathvar a schema1:SoftwareApplication ;
    schema1:citation "doi:10.7717/peerj.3334" ;
    schema1:description "Methods to Find Pathways with Significantly Different Variability" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.17/bioc/src/contrib/pathVar_1.30.0.tar.gz', 'https://bioconductor.org/packages/3.17/bioc/src/contrib/Archive/pathVar/pathVar_1.30.0.tar.gz', 'https://bioarchive.galaxyproject.org/pathVar_1.30.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-pathvar/bioconductor-pathvar_1.30.0_src_all.tar.gz']" ;
    schema1:identifier biotools:pathvar ;
    schema1:license "LGPL (>= 2.0)" ;
    schema1:name "bioconductor-pathvar" ;
    schema1:softwareVersion "1.30.0" ;
    schema1:url "https://bioconductor.org/packages/3.17/bioc/html/pathVar.html" ;
    spdx:builtFrom biotools:pathvar .

