@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-csaw a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/gku351" ;
    schema1:description "ChIP-Seq Analysis with Windows" ;
    schema1:identifier biotools:csaw ;
    schema1:keywords "Binding Sites",
        "ChIP-seq",
        "Chromatin Immunoprecipitation",
        "DNA-Binding Proteins",
        "Data visualisation",
        "Genetics",
        "Histones",
        "Nucleic acid sites, features and motifs",
        "Sequence Analysis, DNA",
        "Sequencing",
        "Transcription Factors" ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-csaw" ;
    schema1:url "https://bioconductor.org/packages/release/bioc/html/csaw.html" .

