@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-csaw a schema1:SoftwareApplication ;
    schema1:description "ChIP-Seq Analysis with Windows" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/csaw_1.40.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/csaw/csaw_1.40.0.tar.gz', 'https://bioarchive.galaxyproject.org/csaw_1.40.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-csaw/bioconductor-csaw_1.40.0_src_all.tar.gz']" ;
    schema1:identifier biotools:csaw ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-csaw" ;
    schema1:softwareVersion "1.40.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/csaw.html" ;
    spdx:builtFrom biotools:csaw .

