    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/covRNA_1.36.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/covRNA/covRNA_1.36.0.tar.gz', 'https://bioarchive.galaxyproject.org/covRNA_1.36.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-covrna/bioconductor-covrna_1.36.0_src_all.tar.gz']" ;
