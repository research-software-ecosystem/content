    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-covrna" ;
    schema1:softwareVersion "1.36.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/covRNA.html" ;
    spdx:builtFrom biotools:covrna .

