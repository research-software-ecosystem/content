@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-simd a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18129/b9.bioc.simd" ;
    schema1:description "Statistical Inferences with MeDIP-seq Data (SIMD) to infer the methylation level for each CpG site" ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-simd" ;
    schema1:url "https://bioconductor.org/packages/3.8/bioc/html/SIMD.html" .

