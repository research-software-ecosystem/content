@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:shapeit a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.1785" ;
    schema1:description "SHAPEIT is a fast and accurate method for estimation of haplotypes (aka phasing) from genotype or sequencing data." ;
    schema1:identifier biotools:shapeit ;
    schema1:keywords "Genetics",
        "Genome",
        "Genotype and phenotype",
        "Genotyping experiment",
        "Haplotypes" ;
    schema1:license "Academic License" ;
    schema1:name "shapeit" ;
    schema1:url "https://mathgen.stats.ox.ac.uk/genetics_software/shapeit/shapeit.html" .

