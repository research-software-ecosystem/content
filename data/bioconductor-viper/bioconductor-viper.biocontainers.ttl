@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-viper a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/ng.3593" ;
    schema1:description "The package uses gene expression data to infer protein activity. the package uses viper and msviper algorithms." ;
    schema1:identifier biotools:viper ;
    schema1:keywords "Antineoplastic Agents",
        "Computational Biology",
        "Data mining",
        "Databases, Pharmaceutical",
        "Databases, Protein",
        "Gene Expression",
        "Gene Expression Regulation, Neoplastic",
        "Gene Regulatory Networks",
        "Gene regulation",
        "Humans",
        "Mutation",
        "Neoplasm Proteins",
        "Neoplasms",
        "Protein Interaction Maps",
        "Protein Structure, Tertiary",
        "Protein sites, features and motifs",
        "Transcription factors and regulatory sites",
        "Transcriptomics" ;
    schema1:license "file LICENSE" ;
    schema1:name "bioconductor-viper" ;
    schema1:url "http://bioconductor.org/packages/release/bioc/html/viper.html" .

