@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-viper a schema1:SoftwareApplication ;
    schema1:description "Virtual Inference of Protein-activity by Enriched Regulon analysis" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/viper_1.40.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/viper/viper_1.40.0.tar.gz', 'https://bioarchive.galaxyproject.org/viper_1.40.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-viper/bioconductor-viper_1.40.0_src_all.tar.gz']" ;
    schema1:identifier biotools:viper ;
    schema1:license "file LICENSE" ;
    schema1:name "bioconductor-viper" ;
    schema1:softwareVersion "1.40.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/viper.html" ;
    spdx:builtFrom biotools:viper .

