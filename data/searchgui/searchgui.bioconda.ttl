@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:searchgui a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1002/pmic.201000595" ;
    schema1:description "User-friendly graphical tool for using proteomics identification search engines." ;
    schema1:downloadUrl "http://genesis.ugent.be/maven2/eu/isas/searchgui/SearchGUI/4.3.15/SearchGUI-4.3.15-mac_and_linux.tar.gz" ;
    schema1:identifier biotools:searchgui ;
    schema1:license "Apache-2.0" ;
    schema1:name "searchgui" ;
    schema1:softwareHelp "https://github.com/compomics/searchgui/blob/master/README.md" ;
    schema1:softwareVersion "4.3.15" ;
    schema1:url "https://github.com/compomics/searchgui" ;
    spdx:builtFrom biotools:searchgui .

