@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:searchgui a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1002/pmic.201000595" ;
    schema1:description "Graphical user interface for proteomics identification search engines" ;
    schema1:identifier biotools:searchgui ;
    schema1:keywords "Data visualisation",
        "Databases, Protein",
        "Mass Spectrometry",
        "Peptides",
        "Proteins",
        "Proteomics",
        "Proteomics experiment",
        "User-Computer Interface" ;
    schema1:license "Apache-2.0" ;
    schema1:name "searchgui" ;
    schema1:url "https://github.com/compomics/searchgui" .

