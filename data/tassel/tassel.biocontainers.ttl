@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:tassel a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btm308" ;
    schema1:description "Tassel is a software package to evaluate traits associations, evolutionary patterns, and linkage disequilibrium." ;
    schema1:identifier biotools:tassel ;
    schema1:keywords "Chromosome Mapping",
        "DNA Mutational Analysis",
        "Data Interpretation, Statistical",
        "GWAS study",
        "Genetic Variation",
        "Genetics",
        "Linkage Disequilibrium",
        "Mapping",
        "Quantitative Trait Loci",
        "Whole genome sequencing" ;
    schema1:license "LGPL-2.1" ;
    schema1:name "tassel" ;
    schema1:url "http://www.maizegenetics.net/tassel" .

