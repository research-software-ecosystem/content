@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-maanova a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1007/0-387-21679-0_14" ;
    schema1:description "Tools for analyzing Micro Array experiments" ;
    schema1:identifier biotools:maanova ;
    schema1:keywords "Clustering",
        "Gene expression",
        "Microarray experiment" ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-maanova" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/maanova.html" .

