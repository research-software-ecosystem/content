@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-clusterstab a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Compute cluster stability scores for microarray data" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/clusterStab_1.78.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/clusterStab/clusterStab_1.78.0.tar.gz', 'https://bioarchive.galaxyproject.org/clusterStab_1.78.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-clusterstab/bioconductor-clusterstab_1.78.0_src_all.tar.gz']" ;
    schema1:identifier biotools:clusterstab ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-clusterstab" ;
    schema1:softwareVersion "1.78.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/clusterStab.html" ;
    spdx:builtFrom biotools:clusterstab .

