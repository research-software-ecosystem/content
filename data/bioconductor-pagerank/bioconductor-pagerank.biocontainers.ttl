@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-pagerank a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18129/b9.bioc.pagerank" ;
    schema1:description "Implemented temporal PageRank analysis as defined by Rozenshtein and Gionis. Implemented multiplex PageRank as defined by Halu et al. Applied temporal and multiplex PageRank in gene regulatory network analysis." ;
    schema1:license "GPL-2.0" ;
    schema1:name "bioconductor-pagerank" ;
    schema1:url "https://bioconductor.org/packages/3.12/bioc/html/pageRank.html" .

