@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:sigma-align a schema1:SoftwareApplication ;
    schema1:description "Simple greedy multiple alignment of non-coding dna sequences" ;
    schema1:keywords "Genomics",
        "Sequence Alignment" ;
    schema1:license "GPL-2+" ;
    schema1:name "sigma-align" ;
    schema1:url "http://www.imsc.res.in/~rsidd/sigma/" .

