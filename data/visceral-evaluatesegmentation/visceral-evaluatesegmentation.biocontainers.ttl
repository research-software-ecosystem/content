@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:visceral-evaluatesegmentation a schema1:SoftwareApplication ;
    schema1:description "EvaluateSegmentation is a tool that compares two volumes (a test segmentation and a ground truth segmentation) using 22 different metrics that were selected as a result of a comprehensive research into the metrics used in the medical volume segmentations." ;
    schema1:license "Apache License, Version 2.0" ;
    schema1:name "visceral-evaluatesegmentation" ;
    schema1:url "https://github.com/Visceral-Project/EvaluateSegmentation" .

