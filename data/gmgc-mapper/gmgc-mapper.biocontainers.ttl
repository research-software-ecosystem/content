@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:gmgc-mapper a schema1:SoftwareApplication ;
    schema1:description "Map genes and genome to the global microbial gene catalog (gmgc)" ;
    schema1:keywords "Genomics",
        "Metagenome",
        "Metagenomics" ;
    schema1:license "Not available" ;
    schema1:name "gmgc-mapper" ;
    schema1:url "https://github.com/BigDataBiology/GMGC-mapper" .

