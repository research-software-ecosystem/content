@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:platypus-variant a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/ng.3036" ;
    schema1:description "A Haplotype-Based Variant Caller For Next Generation Sequence Data" ;
    schema1:keywords "Chromosome Mapping",
        "Exome",
        "Genome, Human",
        "Genomic Structural Variation",
        "Genotype",
        "HLA Antigens",
        "Haplotypes",
        "High-Throughput Nucleotide Sequencing",
        "Humans",
        "Mutation",
        "Polymorphism, Single Nucleotide",
        "Sensitivity and Specificity",
        "Sequence Analysis, DNA" ;
    schema1:license "GPL-3.0" ;
    schema1:name "platypus-variant" ;
    schema1:url "https://github.com/andyrimmer/Platypus" .

