@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:hint a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btu519" ;
    schema1:description "HiNT is a computational method for detecting copy number variations and translocations from Hi-C data" ;
    schema1:identifier biotools:hint ;
    schema1:keywords "Binding Sites",
        "Chromatin Immunoprecipitation",
        "Deoxyribonuclease I",
        "Epigenomics",
        "Gene regulation",
        "Genomics",
        "Histones",
        "Humans",
        "K562 Cells",
        "Markov Chains",
        "Protein Footprinting",
        "Regulatory Elements, Transcriptional",
        "Sequence Analysis, DNA",
        "Transcription Factors",
        "Transcription factors and regulatory sites" ;
    schema1:license "MIT" ;
    schema1:name "hint" ;
    schema1:url "https://github.com/parklab/HiNT" .

