@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bazam a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s13059-019-1688-1" ;
    schema1:description "A tool to extract paired reads in fastq format from coordinate sorted bam files" ;
    schema1:keywords "High-Throughput Nucleotide Sequencing",
        "Sequence Alignment" ;
    schema1:license "LGPL-2.1" ;
    schema1:name "bazam" ;
    schema1:url "https://github.com/ssadedin/bazam" .

