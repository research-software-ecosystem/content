@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:brass a schema1:SoftwareApplication ;
    schema1:description "Breakpoints via assembly - Identifies breaks and attempts to assemble rearrangements." ;
    schema1:identifier biotools:brass ;
    schema1:keywords "Biological rhythms",
        "Biology",
        "Data acquisition",
        "Genomics",
        "Plant" ;
    schema1:license "AGPL-3.0" ;
    schema1:name "brass" ;
    schema1:url "https://github.com/cancerit/BRASS" .

