@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:verifybamid a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1016/j.ajhg.2012.09.004" ;
    schema1:description "verifyBamID verifies identity and purity of sequence data" ;
    schema1:identifier biotools:verifybamid ;
    schema1:keywords "DNA Contamination",
        "Data quality management",
        "Diabetes Mellitus, Type 2",
        "Genetic variation",
        "Genotype",
        "Humans",
        "Sequence Analysis, DNA" ;
    schema1:license "GPL-3.0" ;
    schema1:name "verifybamid" ;
    schema1:url "https://github.com/statgen/verifyBamID/releases" .

