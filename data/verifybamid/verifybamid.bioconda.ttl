@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:verifybamid a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1016/j.ajhg.2012.09.004" ;
    schema1:description "verifyBamID verifies identity and purity of sequence data" ;
    schema1:downloadUrl "https://github.com/statgen/verifyBamID/releases/download/v1.1.3/verifyBamIDLibStatGen.1.1.3.tgz" ;
    schema1:identifier biotools:verifybamid ;
    schema1:license "GPL3" ;
    schema1:name "verifybamid" ;
    schema1:softwareVersion "1.1.3" ;
    schema1:url "http://genome.sph.umich.edu/wiki/VerifyBamID" ;
    spdx:builtFrom biotools:verifybamid .

