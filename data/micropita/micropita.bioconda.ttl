@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:micropita a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/ismej.2013.139" ;
    schema1:description "microPITA is a computational tool enabling sample selection in two-stage (tiered) studies." ;
    schema1:downloadUrl "https://bitbucket.org/biobakery/micropita/downloads/micropita-8.tar.gz" ;
    schema1:identifier biotools:micropita ;
    schema1:license "MIT" ;
    schema1:name "micropita" ;
    schema1:softwareVersion "1.1.0" ;
    schema1:url "http://huttenhower.sph.harvard.edu/micropita" ;
    spdx:builtFrom biotools:micropita .

