@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:micropita a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/ismej.2013.139",
        "doi:10.1093/nar/gkw343",
        "doi:10.7490/f1000research.1114334.1" ;
    schema1:description "microPITA is a computational tool enabling sample selection in two-stage (tiered) studies." ;
    schema1:identifier biotools:micropita ;
    schema1:keywords "Biomedical Research",
        "Computational Biology",
        "Databases, Genetic",
        "Datasets as Topic",
        "Humans",
        "Internet",
        "Nucleic acids",
        "Proteins",
        "Reproducibility of Results",
        "Sequence analysis",
        "User-Computer Interface" ;
    schema1:license "MIT" ;
    schema1:name "micropita" ;
    schema1:url "https://github.com/biobakery/micropita" .

