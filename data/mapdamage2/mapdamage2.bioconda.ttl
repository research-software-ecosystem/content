@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:mapdamage2 a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btr347",
        "doi:10.1093/bioinformatics/btt193" ;
    schema1:description "mapDamage: tracking and quantifying damage patterns in ancient DNA sequencing reads generated by Next-Generation Sequencing platforms." ;
    schema1:downloadUrl "https://pypi.org/packages/source/m/mapdamage/mapdamage-2.2.3.tar.gz" ;
    schema1:identifier biotools:mapdamage ;
    schema1:license "MIT" ;
    schema1:name "mapdamage2" ;
    schema1:softwareHelp "https://ginolhac.github.io/mapDamage" ;
    schema1:softwareVersion "2.2.3" ;
    schema1:url "https://github.com/ginolhac/mapDamage" ;
    spdx:builtFrom biotools:mapdamage .

