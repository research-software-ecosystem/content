@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-biocstyle a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Provides standard formatting styles for bioconductor pdf and html documents. package vignettes illustrate use and functionality." ;
    schema1:identifier biotools:biocstyle ;
    schema1:keywords "Clustering",
        "Computational Biology",
        "Gene Expression Profiling",
        "Genomics",
        "High-Throughput Screening Assays",
        "Literature and language",
        "Metabolomics",
        "Metagenome",
        "Programming Languages",
        "Proteomics",
        "Transcriptome",
        "User-Computer Interface" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-biocstyle" ;
    schema1:url "http://bioconductor.org/packages/release/bioc/html/BiocStyle.html" .

