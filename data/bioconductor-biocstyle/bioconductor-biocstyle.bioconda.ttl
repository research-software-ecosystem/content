@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-biocstyle a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Standard styles for vignettes and other Bioconductor documents" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/BiocStyle_2.38.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/BiocStyle/BiocStyle_2.38.0.tar.gz', 'https://bioarchive.galaxyproject.org/BiocStyle_2.38.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-biocstyle/bioconductor-biocstyle_2.38.0_src_all.tar.gz']" ;
    schema1:identifier biotools:biocstyle ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-biocstyle" ;
    schema1:softwareVersion "2.38.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/BiocStyle.html" ;
    spdx:builtFrom biotools:biocstyle .

