@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:pcalendar a schema1:SoftwareApplication ;
    schema1:description "Track menstrual cycles and predict fertility periods" ;
    schema1:license "GPL-3.0+" ;
    schema1:name "pcalendar" ;
    schema1:url "http://linuxorg.sourceforge.net/" .

