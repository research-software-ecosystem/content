@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-olin a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/bti199" ;
    schema1:description "Optimized local intensity-dependent normalisation of two-color microarrays" ;
    schema1:identifier biotools:olin ;
    schema1:keywords "Computer Graphics",
        "Gene Expression Profiling",
        "Gene expression",
        "Internet",
        "Microarray experiment",
        "Models, Genetic",
        "Models, Statistical",
        "Molecular genetics",
        "Oligonucleotide Array Sequence Analysis",
        "Quality Control",
        "Regression Analysis",
        "User-Computer Interface" ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-olin" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/OLIN.html" .

