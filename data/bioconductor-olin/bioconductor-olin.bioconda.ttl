@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-olin a schema1:SoftwareApplication ;
    schema1:description "Optimized local intensity-dependent normalisation of two-color microarrays" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/OLIN_1.84.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/OLIN/OLIN_1.84.0.tar.gz', 'https://bioarchive.galaxyproject.org/OLIN_1.84.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-olin/bioconductor-olin_1.84.0_src_all.tar.gz']" ;
    schema1:identifier biotools:olin ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-olin" ;
    schema1:softwareVersion "1.84.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/OLIN.html" ;
    spdx:builtFrom biotools:olin .

