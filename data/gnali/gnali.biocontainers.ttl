@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:gnali a schema1:SoftwareApplication ;
    schema1:description "Gnali (gene nonessentiality and loss-of-function identifier) is a tool for finding plof gene variants." ;
