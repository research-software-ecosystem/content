@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-rchemcpp a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btv373" ;
    schema1:description "The Rchemcpp package implements the marginalized graph kernel and extensions, Tanimoto kernels, graph kernels, pharmacophore and 3D kernels suggested for measuring the similarity of molecules." ;
    schema1:keywords "Databases, Chemical",
        "Drug Discovery",
        "Gene Expression",
        "Internet",
        "Machine Learning" ;
    schema1:license "GPL (>= 2.1)" ;
    schema1:name "bioconductor-rchemcpp" ;
    schema1:url "https://bioconductor.org/packages/release/bioc/html/Rchemcpp.html" .

