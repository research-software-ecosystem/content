@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:collect_mgf a schema1:SoftwareApplication ;
    schema1:description "Collects MGF files and dd_results from an XMass setup_QDD.tcl experiment to a single MGF file." ;
    schema1:identifier biotools:collect_mgf ;
    schema1:keywords "Proteomics",
        "Proteomics experiment" ;
    schema1:license "GPL-3.0" ;
    schema1:name "collect_mgf" ;
    schema1:url "http://www.ms-utils.org/collect_mgf.c" .

