@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:collect_mgf a schema1:SoftwareApplication ;
    schema1:description "Collects MGF files and dd_results from an XMass setup_QDD.tcl experiment to a single MGF file." ;
    schema1:downloadUrl "http://www.ms-utils.org/collect_mgf.c" ;
    schema1:identifier biotools:collect_mgf ;
    schema1:license "GPL-3.0" ;
    schema1:name "collect_mgf" ;
    schema1:softwareVersion "1.0" ;
    schema1:url "http://www.ms-utils.org/collect_mgf.c" ;
    spdx:builtFrom biotools:collect_mgf .

