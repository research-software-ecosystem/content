@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:python3-xopen a schema1:SoftwareApplication ;
    schema1:description "Open any compressed file in Python" ;
    schema1:license "MIT" ;
    schema1:name "python3-xopen" ;
    schema1:url "https://github.com/marcelm/xopen/" .

