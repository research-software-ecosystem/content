@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:talon a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1101/672931" ;
    schema1:description "Talon is a python package for identifying and quantifying known and novel genes/isoforms in long-read transcriptome data sets." ;
    schema1:keywords "Gene Expression",
        "Transcriptome" ;
    schema1:license "MIT" ;
    schema1:name "talon" ;
    schema1:url "https://github.com/mortazavilab/TALON" .

