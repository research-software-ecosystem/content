@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:illuminate a schema1:SoftwareApplication ;
    schema1:description "Analytics toolkit for illumina sequencer metrics." ;
    schema1:identifier biotools:illuminate ;
    schema1:keywords "Genomics" ;
    schema1:license "MIT" ;
    schema1:name "illuminate" ;
    schema1:url "https://bitbucket.org/invitae/illuminate" .

