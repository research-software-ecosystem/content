@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:illuminate a schema1:SoftwareApplication ;
    schema1:description "Analytics toolkit for Illumina sequencer metrics." ;
    schema1:downloadUrl "https://bitbucket.org/ilmn8/illuminate/get/e19b8afefead.zip" ;
    schema1:identifier biotools:illuminate ;
    schema1:license "MIT" ;
    schema1:name "illuminate" ;
    schema1:softwareVersion "0.6.3" ;
    schema1:url "https://bitbucket.org/invitae/illuminate" ;
    spdx:builtFrom biotools:illuminate .

