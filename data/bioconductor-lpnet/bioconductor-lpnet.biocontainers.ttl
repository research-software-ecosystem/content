@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-lpnet a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btv327",
        "doi:10.18129/b9.bioc.lpnet" ;
    schema1:description "This tool aims at infering biological networks, in particular signaling and gene networks. for that it takes perturbation data, either steady-state or time-series, as input and generates an lp model which allows the inference of signaling networks. for parameter identification either leave-one-out cross-validation or stratified n-fold cross-validation can be used." ;
    schema1:identifier biotools:lpnet ;
    schema1:keywords "Computer Graphics",
        "Gene regulation",
        "Genetics",
        "Genome, Human",
        "Genomics",
        "Humans",
        "Metabolic Networks and Pathways",
        "Molecular interactions, pathways and networks",
        "Programming, Linear",
        "Signal Transduction",
        "Systems Integration" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-lpnet" ;
    schema1:url "http://bioconductor.org/packages/release/bioc/html/lpNet.html" .

