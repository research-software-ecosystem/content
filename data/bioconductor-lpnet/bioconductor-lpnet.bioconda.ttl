@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-lpnet a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btv327" ;
    schema1:description "Linear Programming Model for Network Inference" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/lpNet_2.38.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/lpNet/lpNet_2.38.0.tar.gz', 'https://bioarchive.galaxyproject.org/lpNet_2.38.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-lpnet/bioconductor-lpnet_2.38.0_src_all.tar.gz']" ;
    schema1:identifier biotools:lpnet ;
    schema1:license "Artistic License 2.0" ;
    schema1:name "bioconductor-lpnet" ;
    schema1:softwareVersion "2.38.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/lpNet.html" ;
    spdx:builtFrom biotools:lpnet .

