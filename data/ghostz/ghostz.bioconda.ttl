@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:ghostz a schema1:SoftwareApplication ;
    schema1:author "tomkinsc" ;
    schema1:citation "doi:10.1093/bioinformatics/btu780" ;
    schema1:description "GHOSTZ is a highly efficient remote homologue detection tool." ;
    schema1:downloadUrl "http://www.bi.cs.titech.ac.jp/ghostz/releases/ghostz-1.0.2.tar.gz" ;
    schema1:identifier biotools:ghostz ;
    schema1:license "BSD-2-Clause" ;
    schema1:maintainer "tomkinsc" ;
    schema1:name "ghostz" ;
    schema1:softwareHelp "http://www.bi.cs.titech.ac.jp/ghostz" ;
    schema1:softwareVersion "1.0.2" ;
    schema1:url "http://www.bi.cs.titech.ac.jp/ghostz" ;
    spdx:builtFrom biotools:ghostz .

