@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:ghostz a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btu780" ;
    schema1:description "GHOSTZ is a highly efficient remote homologue detection tool" ;
    schema1:identifier biotools:ghostz ;
    schema1:keywords "Amino Acid Sequence",
        "Animals",
        "Cluster Analysis",
        "Clustering",
        "DNA",
        "Databases, Genetic",
        "Humans",
        "Metagenomics",
        "Military Personnel",
        "Molecular Sequence Data",
        "Molecular genetics",
        "Programming Languages",
        "Protein Sequences",
        "Sequence Analysis, DNA",
        "Sequence Homology",
        "Sequence analysis",
        "Soil" ;
    schema1:license "BSD-2-Clause" ;
    schema1:name "ghostz" ;
    schema1:url "http://www.bi.cs.titech.ac.jp/ghostz/" .

