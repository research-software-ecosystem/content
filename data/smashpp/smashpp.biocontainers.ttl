@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:smashpp a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/gigascience/giaa048" ;
    schema1:description "A fast tool to find and visualize rearrangements in DNA sequences" ;
    schema1:identifier biotools:smashpp ;
    schema1:license "GPL-3.0" ;
    schema1:name "smashpp" ;
    schema1:url "https://github.com/smortezah/smashpp" .

