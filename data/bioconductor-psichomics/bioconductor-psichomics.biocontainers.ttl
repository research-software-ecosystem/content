    schema1:description "Graphical Interface for Alternative Splicing Quantification, Analysis and Visualisation" ;
    schema1:keywords "Gene Expression",
        "RNA-Seq",
        "Transcriptomics" ;
    schema1:license "MIT" ;
    schema1:name "bioconductor-psichomics" ;
    schema1:url "https://bioconductor.org/packages/3.8/bioc/html/psichomics.html" .

