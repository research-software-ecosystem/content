@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:dudes a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btw150" ;
    schema1:description "Dudes: a top-down taxonomic profiler for metagenomics" ;
    schema1:keywords "Genomics",
        "Metagenomics",
        "Sequence Alignment" ;
    schema1:license "MIT" ;
    schema1:name "dudes" ;
    schema1:url "https://github.com/pirovc/dudes/" .

