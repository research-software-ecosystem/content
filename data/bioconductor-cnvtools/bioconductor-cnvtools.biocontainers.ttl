@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-cnvtools a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/ng.206" ;
    schema1:description "A package to test genetic association with CNV data" ;
    schema1:identifier biotools:cnvtools ;
    schema1:keywords "Case-Control Studies",
        "Chromosomes, Human",
        "Cohort Studies",
        "Computer Simulation",
        "DNA",
        "Diabetes Mellitus, Type 1",
        "Gene Dosage",
        "Genetic variation",
        "Genome, Human",
        "Haplotypes",
        "Humans",
        "Models, Genetic",
        "Oligonucleotide Array Sequence Analysis",
        "Polymerase Chain Reaction",
        "Polymorphism, Single Nucleotide",
        "Quantitative Trait Loci",
        "Sequencing" ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-cnvtools" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/CNVtools.html" .

