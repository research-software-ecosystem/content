@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:prince a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/gks535" ;
    schema1:description "PRINCE estimates Variable Number Tandem Repeats (VNTR) copy number from raw next generation sequencing (NGS) data." ;
    schema1:identifier biotools:prince ;
    schema1:keywords "Internet",
        "Nucleic Acid Conformation",
        "Protein Conformation",
        "Protein interactions",
        "Proteins",
        "RNA",
        "RNA-Binding Proteins" ;
    schema1:license "MIT" ;
    schema1:name "prince" ;
    schema1:url "https://github.com/WGS-TB/PythonPrince" .

