@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:pypeflow a schema1:SoftwareApplication ;
    schema1:description "Light weight and reusable make / flow data process library written in Python" ;
    schema1:keywords "Clustering" ;
    schema1:license "BSD-3-Clause-Clear" ;
    schema1:name "pypeflow" ;
    schema1:url "https://github.com/PacificBiosciences/pypeFLOW" .

