@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:rampler a schema1:SoftwareApplication ;
    schema1:description "Module for sampling genomic sequences" ;
    schema1:license "custom, see /usr/share/doc/rampler/copyright" ;
    schema1:name "rampler" ;
    schema1:url "https://github.com/rvaser/rampler" .

