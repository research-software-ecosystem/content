@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:repenrich a schema1:SoftwareApplication ;
    schema1:description "Repenrich is a method to estimate repetitive element enrichment using high-throughput sequencing data." ;
    schema1:license "Custom OSS" ;
    schema1:name "repenrich" ;
    schema1:url "https://github.com/nskvir/RepEnrich" .

