@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-scan.upc a schema1:SoftwareApplication ;
    schema1:description "Single-channel array normalization (SCAN) and Universal exPression Codes (UPC)" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/SCAN.UPC_2.52.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/SCAN.UPC/SCAN.UPC_2.52.0.tar.gz', 'https://bioarchive.galaxyproject.org/SCAN.UPC_2.52.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-scan.upc/bioconductor-scan.upc_2.52.0_src_all.tar.gz']" ;
    schema1:identifier biotools:scan.upc ;
    schema1:license "MIT" ;
    schema1:name "bioconductor-scan.upc" ;
    schema1:softwareVersion "2.52.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/SCAN.UPC.html" ;
    spdx:builtFrom biotools:scan.upc .

