@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:arem a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1089/cmb.2011.0185" ;
    schema1:description "Arem: aligning short reads from chip-sequencing by expectation maximisation" ;
    schema1:identifier biotools:arem ;
    schema1:keywords "Animals",
        "Base Sequence",
        "Cell Cycle Proteins",
        "ChIP-seq",
        "Chromatin Immunoprecipitation",
        "Computer Simulation",
        "DNA-Binding Proteins",
        "High-Throughput Nucleotide Sequencing",
        "Likelihood Functions",
        "Mice",
        "Models, Genetic",
        "Nuclear Proteins",
        "Phosphoproteins",
        "Protein Binding",
        "Sequence Alignment",
        "Sequence Analysis, DNA",
        "Sterol Regulatory Element Binding Protein 1",
        "Transcription Factors" ;
    schema1:license "Artistic License" ;
    schema1:name "arem" ;
    schema1:url "https://github.com/jakebiesinger/AREM" .

