@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:arem a schema1:SoftwareApplication ;
    schema1:description """Aligning Reads by Expectation-Maximization.
Based on MACS (Model Based Analysis for ChIP-Seq data)""" ;
    schema1:downloadUrl "https://pypi.python.org/packages/bc/0d/6db36d917d821d150f37c68839d8911e52b78c867b27372da5be41d4cc4f/AREM-1.0.1.tar.gz" ;
    schema1:identifier biotools:arem ;
    schema1:license "Artistic License" ;
    schema1:name "arem" ;
    schema1:softwareVersion "1.0.1" ;
    schema1:url "http://cbcl.ics.uci.edu/AREM" ;
    spdx:builtFrom biotools:arem .

