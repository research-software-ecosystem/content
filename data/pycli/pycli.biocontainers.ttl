@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:pycli a schema1:SoftwareApplication ;
    schema1:description "Simple, object-oriented approach to python cli apps" ;
    schema1:license "Not available" ;
    schema1:name "pycli" ;
    schema1:url "http://packages.python.org/pyCLI/" .

