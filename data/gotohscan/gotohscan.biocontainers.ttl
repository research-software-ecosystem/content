@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:gotohscan a schema1:SoftwareApplication ;
    schema1:description "a search tool that finds shorter sequences (usually genes) in large database sequences (chromosomes, genomes, ..) by computing all semi-global alignments." ;
    schema1:identifier biotools:gotohscan ;
    schema1:keywords "Chromosomes",
        "DNA",
        "Sequences",
        "Transcriptome" ;
    schema1:license "GPL" ;
    schema1:name "gotohscan" ;
    schema1:url "http://www.bioinf.uni-leipzig.de/" .

