@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-path2ppi a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btv765" ;
    schema1:description "Prediction of pathway-related protein-protein interaction networks" ;
    schema1:identifier biotools:path2ppi ;
    schema1:keywords "Animals",
        "Humans",
        "Molecular interactions, pathways and networks",
        "Protein Interaction Maps",
        "Protein interactions",
        "Proteins",
        "Proteomics",
        "Systems biology" ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-path2ppi" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/Path2PPI.html" .

