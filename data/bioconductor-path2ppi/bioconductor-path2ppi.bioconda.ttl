@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-path2ppi a schema1:SoftwareApplication ;
    schema1:description "Prediction of pathway-related protein-protein interaction networks" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/Path2PPI_1.36.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/Path2PPI/Path2PPI_1.36.0.tar.gz', 'https://bioarchive.galaxyproject.org/Path2PPI_1.36.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-path2ppi/bioconductor-path2ppi_1.36.0_src_all.tar.gz']" ;
    schema1:identifier biotools:path2ppi ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-path2ppi" ;
    schema1:softwareVersion "1.36.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/Path2PPI.html" ;
    spdx:builtFrom biotools:path2ppi .

