@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:pyexcelerator a schema1:SoftwareApplication ;
    schema1:description "Generating excel 97+ files; importing excel 95+ files; excel files dumper; ole2 files dumper; xls2txt, xls2csv, xls2html" ;
    schema1:license "BSD License" ;
    schema1:name "pyexcelerator" ;
    schema1:url "http://sourceforge.net/projects/pyexcelerator/" .

