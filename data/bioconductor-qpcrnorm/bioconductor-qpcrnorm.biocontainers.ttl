@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-qpcrnorm a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/1471-2105-10-110" ;
    schema1:description "Data-driven normalization strategies for high-throughput qPCR data." ;
    schema1:identifier biotools:qpcrnorm ;
    schema1:keywords "Computational Biology",
        "Databases, Genetic",
        "Gene Expression Profiling",
        "PCR experiment",
        "Reverse Transcriptase Polymerase Chain Reaction" ;
    schema1:license "LGPL (>= 2)" ;
    schema1:name "bioconductor-qpcrnorm" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/qpcrNorm.html" .

