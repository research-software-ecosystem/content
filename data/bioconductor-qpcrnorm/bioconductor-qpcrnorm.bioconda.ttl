@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-qpcrnorm a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/1471-2105-10-110" ;
    schema1:description "Data-driven normalization strategies for high-throughput qPCR data." ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/qpcrNorm_1.68.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/qpcrNorm/qpcrNorm_1.68.0.tar.gz', 'https://bioarchive.galaxyproject.org/qpcrNorm_1.68.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-qpcrnorm/bioconductor-qpcrnorm_1.68.0_src_all.tar.gz']" ;
    schema1:identifier biotools:qpcrnorm ;
    schema1:license "LGPL (>= 2)" ;
    schema1:name "bioconductor-qpcrnorm" ;
    schema1:softwareVersion "1.68.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/qpcrNorm.html" ;
    spdx:builtFrom biotools:qpcrnorm .

