@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:pymol-jupiter a schema1:SoftwareApplication ;
    schema1:description "A portable way of interacting with pymol via jupyter notebook" ;
    schema1:license "MIT" ;
    schema1:name "pymol-jupiter" ;
    schema1:url "http://github.com/ocramz/jupyter-docker-pymol" .

