@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:kleborate a schema1:SoftwareApplication ;
    schema1:author "Marysteph" ;
    schema1:citation "doi:10.1038/s41467-021-24448-3",
        "doi:10.1099/mgen.0.000102" ;
    schema1:description "Kleborate: a tool for typing and screening pathogen genome assemblies." ;
    schema1:downloadUrl "https://pypi.io/packages/source/k/kleborate/kleborate-3.2.4.tar.gz" ;
    schema1:identifier biotools:kleborate ;
    schema1:license "GPL-3.0-or-later" ;
    schema1:maintainer "Marysteph" ;
    schema1:name "kleborate" ;
    schema1:softwareHelp "https://kleborate.readthedocs.io" ;
    schema1:softwareVersion "3.2.4" ;
    schema1:url "https://kleborate.readthedocs.io" ;
    spdx:builtFrom biotools:kleborate .

