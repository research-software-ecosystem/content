  "@graph": [
    {
      "@id": "https://bio.tools/bioconductor-annolinker",
      "@type": "sc:SoftwareApplication",
      "dcterms:conformsTo": "https://bioschemas.org/profiles/ComputationalTool/0.6-DRAFT",
      "sc:additionalType": [
        "Library",
        "Command-line tool"
      ],
      "sc:author": [
        "Jianhong Ou",
        "Kenneth Poss"
      ],
      "sc:citation": {
        "@id": "https://doi.org/10.18129/B9.bioc.annoLinker"
      },
      "sc:contributor": "Kenneth Poss",
      "sc:description": "Fast annotation of genomic peaks using DNA interaction data by constructing interaction networks with igraph, where peaks overlapping any node in a connected subgraph are annotated with all genes in that subgraph. The annotation evidence could be visualized as either a network graph or a genomic track integrated with gene annotation information.",
      "sc:license": "GPL-3.0-only",
      "sc:name": "annoLinker",
      "sc:operatingSystem": [
        "Linux",
        "Mac",
        "Windows"
      ],
