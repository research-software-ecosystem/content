@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:orthodb a schema1:SoftwareApplication ;
    schema1:author "ftegenfe" ;
    schema1:citation "doi:10.1093/nar/gkac996" ;
    schema1:description "Interface to OrthoDB REST API." ;
    schema1:downloadUrl "https://gitlab.com/ezlab/orthodb_py/-/archive/0.9.1/orthodb_py-0.9.1.tar.gz" ;
    schema1:identifier biotools:orthodb ;
    schema1:license "GPL3" ;
    schema1:maintainer "ftegenfe" ;
    schema1:name "orthodb" ;
    schema1:softwareHelp "https://www.ezlab.org/orthodb_v12_userguide.html#api" ;
    schema1:softwareVersion "0.9.1" ;
    schema1:url "https://www.ezlab.org/orthodb_v12_userguide.html" ;
    spdx:builtFrom biotools:orthodb .

