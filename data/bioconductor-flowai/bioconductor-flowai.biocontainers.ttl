@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-flowai a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btw191" ;
    schema1:description "Automatic and interactive quality control for flow cytometry data" ;
    schema1:identifier biotools:flowai ;
    schema1:keywords "Cluster Analysis",
        "Data Interpretation, Statistical",
        "Data quality management",
        "Flow Cytometry",
        "Humans" ;
    schema1:license "GPL-2.0" ;
    schema1:name "bioconductor-flowai" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/flowAI.html" .

