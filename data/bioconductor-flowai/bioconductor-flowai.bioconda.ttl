@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-flowai a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btw191" ;
    schema1:description "Automatic and interactive quality control for flow cytometry data" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/flowAI_1.36.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/flowAI/flowAI_1.36.0.tar.gz', 'https://bioarchive.galaxyproject.org/flowAI_1.36.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-flowai/bioconductor-flowai_1.36.0_src_all.tar.gz']" ;
    schema1:identifier biotools:flowai ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-flowai" ;
    schema1:softwareVersion "1.36.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/flowAI.html" ;
    spdx:builtFrom biotools:flowai .

