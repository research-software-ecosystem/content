@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:recentrifuge a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1371/journal.pcbi.1006967" ;
    schema1:description "Robust comparative analysis and contamination removal for metagenomics" ;
    schema1:keywords "Big Data",
        "Computational Biology",
        "DNA Contamination",
        "Genomics",
        "High-Throughput Nucleotide Sequencing",
        "Humans",
        "Internet",
        "Metagenome",
        "Metagenomics",
        "Microbiota",
        "Sequence Analysis, DNA",
        "Whole Genome Sequencing" ;
    schema1:license "GPL-3.0" ;
    schema1:name "recentrifuge" ;
    schema1:url "https://github.com/khyox/recentrifuge" .

