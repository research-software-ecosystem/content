@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:recentrifuge a schema1:SoftwareApplication ;
    schema1:author "khyox",
        "thanhleviet" ;
    schema1:citation "doi:10.1371/journal.pcbi.1006967" ;
    schema1:description "Robust comparative analysis and contamination removal for metagenomics." ;
    schema1:downloadUrl "https://github.com/khyox/recentrifuge/archive/v2.1.1.tar.gz" ;
    schema1:identifier biotools:Recentrifuge ;
    schema1:license "AGPL-3.0-or-later" ;
    schema1:maintainer "khyox",
        "thanhleviet" ;
    schema1:name "recentrifuge" ;
    schema1:softwareHelp "https://github.com/khyox/recentrifuge/wiki" ;
    schema1:softwareVersion "2.1.1" ;
    schema1:url "https://github.com/khyox/recentrifuge" ;
    spdx:builtFrom biotools:Recentrifuge .

