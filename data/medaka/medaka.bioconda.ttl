@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:medaka a schema1:SoftwareApplication ;
    schema1:description "A tool to create consensus sequences and variant calls from nanopore sequencing data using neural networks." ;
    schema1:downloadUrl "https://pypi.org/packages/source/m/medaka/medaka-2.2.1.tar.gz" ;
    schema1:identifier biotools:medaka ;
    schema1:license "Oxford Nanopore Technologies PLC. Public License Version 1.0" ;
    schema1:name "medaka" ;
    schema1:softwareHelp "https://github.com/nanoporetech/medaka/blob/v2.2.1/README.md" ;
    schema1:softwareVersion "2.2.1" ;
    schema1:url "https://github.com/nanoporetech/medaka" ;
    spdx:builtFrom biotools:medaka .

