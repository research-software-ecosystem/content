@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:osra a schema1:SoftwareApplication ;
    schema1:description "OSRA is a utility designed to convert graphical representations of chemical structures, as they appear in journal articles, patent documents, textbooks, trade magazines etc., into SMILES or SDF." ;
    schema1:license "Simplified BSD Licence" ;
    schema1:name "osra" ;
    schema1:url "http://cactus.nci.nih.gov/osra/" .

