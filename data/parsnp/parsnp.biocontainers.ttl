@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:parsnp a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s13059-014-0524-x" ;
    schema1:description "Parsnp is a command-line-tool for efficient microbial core genome alignment and snp detection." ;
    schema1:keywords "Bacteria",
        "Genome, Bacterial",
        "Phylogeny",
        "Polymorphism, Single Nucleotide",
        "Sequence Alignment",
        "Sequence Analysis, DNA" ;
    schema1:license "Custom License" ;
    schema1:name "parsnp" ;
    schema1:url "https://github.com/marbl/parsnp" .

