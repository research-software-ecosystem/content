biocontainers:bioconductor-screcover a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18129/b9.bioc.screcover" ;
    schema1:description "scRecover for imputation of single-cell RNA-seq data" ;
    schema1:keywords "Clustering",
        "RNA-Seq",
        "Transcriptomics" ;
    schema1:license "GPL" ;
    schema1:name "bioconductor-screcover" ;
    schema1:url "https://bioconductor.org/packages/3.9/bioc/html/scRecover.html" .

