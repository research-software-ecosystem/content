  "@graph": [
    {
      "@id": "https://bio.tools/bioconductor-screcover",
      "@type": "sc:SoftwareApplication",
      "dcterms:conformsTo": "https://bioschemas.org/profiles/ComputationalTool/0.6-DRAFT",
      "sc:additionalType": [
        "Library",
        "Command-line tool"
      ],
      "sc:citation": {
        "@id": "https://doi.org/10.18129/B9.bioc.scRecover"
      },
      "sc:description": "scRecover is an R package for imputation of single-cell RNA-seq (scRNA-seq) data. It will detect and impute dropout values in a scRNA-seq raw read counts matrix while keeping the real zeros unchanged, since there are both dropout zeros and real zeros in scRNA-seq data. By combination with scImpute, SAVER and MAGIC, scRecover not only detects dropout and real zeros at higher accuracy, but also improve the downstream clustering and visualization results.",
      "sc:license": "GPL-1.0-or-later",
      "sc:name": "scRecover",
      "sc:operatingSystem": [
        "Linux",
        "Mac",
        "Windows"
      ],
      "sc:softwareHelp": {
        "@id": "https://bioconductor.org/packages/scRecover"
      },
      "sc:softwareVersion": "1.26.0",
      "sc:url": "https://bioconductor.org/packages/scRecover"
    },
    {
      "@id": "https://doi.org/10.18129/B9.bioc.scRecover",
      "@type": "sc:CreativeWork"
    }
