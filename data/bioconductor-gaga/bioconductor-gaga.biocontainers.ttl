@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-gaga a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1214/09-aoas244" ;
    schema1:description "GaGa hierarchical model for high-throughput data analysis" ;
    schema1:identifier biotools:gaga ;
    schema1:keywords "Clustering",
        "Gene expression" ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-gaga" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/gaga.html" .

