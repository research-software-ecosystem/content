@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-gaga a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1214/09-aoas244" ;
    schema1:description "GaGa hierarchical model for high-throughput data analysis" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/gaga_2.52.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/gaga/gaga_2.52.0.tar.gz', 'https://bioarchive.galaxyproject.org/gaga_2.52.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-gaga/bioconductor-gaga_2.52.0_src_all.tar.gz']" ;
    schema1:identifier biotools:gaga ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-gaga" ;
    schema1:softwareVersion "2.52.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/gaga.html" ;
    spdx:builtFrom biotools:gaga .

