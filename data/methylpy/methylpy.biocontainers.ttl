        "Female",
        "Gene Expression Profiling",
        "Gene Expression Regulation",
        "Genetic Variation",
        "Genetics",
        "Genomics",
        "Humans",
        "Male",
        "Organ Specificity" ;
    schema1:license "Apache-2.0" ;
    schema1:name "methylpy" ;
    schema1:url "https://github.com/yupenghe/methylpy" .

