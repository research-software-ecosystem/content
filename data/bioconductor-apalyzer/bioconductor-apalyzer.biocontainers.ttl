@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-apalyzer a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18129/b9.bioc.apalyzer" ;
    schema1:description "A toolkit for APA analysis using RNA-seq data" ;
    schema1:keywords "Gene Expression",
        "RNA-Seq" ;
    schema1:license "LGPL-3" ;
    schema1:name "bioconductor-apalyzer" ;
    schema1:url "https://bioconductor.org/packages/3.10/bioc/html/APAlyzer.html" .

