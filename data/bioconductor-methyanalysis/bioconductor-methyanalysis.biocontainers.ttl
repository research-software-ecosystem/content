@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-methyanalysis a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "This package aims for the dna methylation data analysis and visualization. a methygenoset class is defined to keep the chromosome location information together with the data. the package also includes functions of estimating the methylation levels from methy-seq data." ;
    schema1:identifier biotools:methyanalysis ;
    schema1:keywords "Computational Biology",
        "DNA",
        "Epigenetics",
        "Gene Expression Profiling",
        "Genomics",
        "High-Throughput Screening Assays",
        "Methylated DNA immunoprecipitation",
        "Programming Languages",
        "User-Computer Interface" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-methyanalysis" ;
    schema1:url "http://bioconductor.org/packages/release/bioc/html/methyAnalysis.html" .

