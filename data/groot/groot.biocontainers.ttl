@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:groot a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/bty387" ;
    schema1:description "A tool for resistome profiling of metagenomic samples." ;
    schema1:identifier biotools:groot ;
    schema1:keywords "Bacterial Infections",
        "Genomics",
        "Humans",
        "Metagenome",
        "Metagenomics",
        "Microbiology" ;
    schema1:license "MIT" ;
    schema1:name "groot" ;
    schema1:url "https://github.com/will-rowe/groot" .

