@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-airr a schema1:SoftwareApplication ;
    schema1:description "Schema definitions and read, write and validation tools for data  formatted in accordance with the AIRR Data Representation schemas defined  by the AIRR Community <http://docs.airr-community.org>." ;
    schema1:license "CC BY 4.0" ;
    schema1:name "r-airr" ;
    schema1:url "http://docs.airr-community.org" .

