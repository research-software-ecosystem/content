@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-r4rna a schema1:SoftwareApplication ;
    schema1:description "An R package for RNA visualization and analysis" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/R4RNA_1.34.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/R4RNA/R4RNA_1.34.0.tar.gz', 'https://bioarchive.galaxyproject.org/R4RNA_1.34.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-r4rna/bioconductor-r4rna_1.34.0_src_all.tar.gz']" ;
    schema1:identifier biotools:r4rna ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-r4rna" ;
    schema1:softwareVersion "1.34.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/R4RNA.html" ;
    spdx:builtFrom biotools:r4rna .

