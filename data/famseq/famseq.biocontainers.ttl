    schema1:description "Peng G, Fan Y, Palculict TB, Shen P, Ruteshouser EC, Chi A, Davis RW, Huff V, Scharfe C, Wang W. Rare variant detection using family-based sequencing analysis. Proceedings of the National Academy of Sciences. 2013 Mar 5;110(10):3985-90" ;
    schema1:keywords "Bayes Theorem",
        "Family",
        "Female",
        "Genetic Variation",
        "Genome, Human",
        "Humans",
        "Kidney Neoplasms",
        "Likelihood Functions",
