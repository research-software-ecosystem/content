        "Models, Genetic",
        "Neurodegenerative Diseases",
        "Pedigree",
        "Polymorphism, Single Nucleotide",
        "Sequence Analysis, DNA",
        "Wilms Tumor" ;
    schema1:license "GPL-3.0" ;
    schema1:name "famseq" ;
    schema1:url "http://bioinformatics.mdanderson.org/main/FamSeq" .

