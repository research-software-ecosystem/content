@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:crb-blast a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1371/journal.pgen.1006087" ;
    schema1:description "Conditional reciprocal best blast - high confidence ortholog assignment." ;
    schema1:keywords "Genetics",
        "Ortholog",
        "Transcriptome" ;
    schema1:license "MIT" ;
    schema1:name "crb-blast" ;
    schema1:url "https://github.com/cboursnell/crb-blast" .

