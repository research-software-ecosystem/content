@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:perl-hash-merge a schema1:SoftwareApplication ;
    schema1:description "Merges arbitrarily deep hashes into a single hash" ;
    schema1:license "perl_5" ;
    schema1:name "perl-hash-merge" ;
    schema1:url "http://metacpan.org/pod/Hash::Merge" .

