@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:python-goenrichment a schema1:SoftwareApplication ;
    schema1:description "GO enrichment analysis from a list of gene names using a precomputed database" ;
    schema1:license "Public Domain" ;
    schema1:name "python-goenrichment" ;
    schema1:url "https://pypi.org/project/goenrichment/" .

