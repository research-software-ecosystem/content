@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:ncls a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btz615" ;
    schema1:description "The Nested Containment List for Python. Basically a static interval-tree that is silly fast for both construction and lookups." ;
    schema1:keywords "Computational Biology",
        "Gene Library",
        "Genome",
        "Genomics" ;
    schema1:license "BSD" ;
    schema1:name "ncls" ;
    schema1:url "https://github.com/endrebak/ncls" .

