@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:gefast a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s12859-018-2349-1" ;
    schema1:description "Clustering tool primarily designed for processing nucleotide sequences obtained from high-throughput sequencing. GeFaST (Generalised Fastidious Swarming Tool) picks up the two-phased, iterative clustering strategy of Swarm and generalises resp. extends both the clustering and the refinement phase. GeFaST considers the iterative strategy as an abstract scheme, which can be coupled with different notions of distance. The refinement phase has been generalised by broadening the applicability of the original fastidious approach and introducing further refinement methods." ;
    schema1:keywords "Cluster Analysis",
        "Clustering",
        "Databases as Topic",
        "High-Throughput Nucleotide Sequencing",
        "RNA, Ribosomal, 16S",
        "Time Factors" ;
    schema1:license "AGPL-3.0" ;
    schema1:name "gefast" ;
    schema1:url "https://github.com/romueller/gefast" .

