@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconda2biocontainer a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1101/2020.07.21.187609" ;
    schema1:description "Biocontainers api client: find biocontainer images for bioconda packages" ;
    schema1:keywords "Genomics",
        "Proteomics",
        "RNA-Seq",
        "Sequence Alignment" ;
    schema1:license "Not available" ;
    schema1:name "bioconda2biocontainer" ;
    schema1:url "https://github.com/BioContainers/bioconda2biocontainer" .

