@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-edger a schema1:SoftwareApplication ;
    schema1:description "Empirical Analysis of Digital Gene Expression Data in R" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/edgeR_4.4.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/edgeR/edgeR_4.4.0.tar.gz', 'https://bioarchive.galaxyproject.org/edgeR_4.4.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-edger/bioconductor-edger_4.4.0_src_all.tar.gz']" ;
    schema1:identifier biotools:edger ;
    schema1:license "GPL (>=2)" ;
    schema1:name "bioconductor-edger" ;
    schema1:softwareVersion "4.4.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/edgeR.html" ;
    spdx:builtFrom biotools:edger .

