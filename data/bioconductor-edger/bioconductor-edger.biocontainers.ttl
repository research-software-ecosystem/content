@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-edger a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/gks042" ;
    schema1:description "Empirical analysis of digital gene expression data in r" ;
    schema1:identifier biotools:edger ;
    schema1:keywords "Bayes Theorem",
        "Carcinoma, Squamous Cell",
        "ChIP-seq",
        "Clustering",
        "Gene Expression",
        "Gene Expression Profiling",
        "Genetic Variation",
        "Genetics",
        "Genomics",
        "High-Throughput Nucleotide Sequencing",
        "Linear Models",
        "Mouth Neoplasms",
        "RNA-Seq",
        "RNA-seq",
        "Sequence Analysis, RNA",
        "Transcriptomics" ;
    schema1:license "GPL-2+" ;
    schema1:name "bioconductor-edger" ;
    schema1:url "http://www.bioconductor.org/packages/release/bioc/html/edgeR.html" .

