@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-gotools a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Functions for Gene Ontology database" ;
    schema1:identifier biotools:gotools ;
    schema1:keywords "Computational Biology",
        "Gene Expression Profiling",
        "Gene expression",
        "Genomics",
        "Genotyping experiment",
        "High-Throughput Screening Assays",
        "Microarray experiment",
        "Ontology and terminology",
        "Programming Languages",
        "User-Computer Interface" ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-gotools" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/goTools.html" .

