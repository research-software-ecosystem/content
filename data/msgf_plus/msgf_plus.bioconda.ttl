@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:msgf_plus a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/ncomms6277" ;
    schema1:description "MS-GF+ is a MS/MS database search tool" ;
    schema1:downloadUrl "https://github.com/MSGFPlus/msgfplus/releases/download/v2024.03.26/MSGFPlus_v20240326.zip" ;
    schema1:identifier biotools:MSGFplus ;
    schema1:license "https://github.com/msgfplus/msgfplus/blob/master/LICENSE.txt" ;
    schema1:name "msgf_plus" ;
    schema1:softwareVersion "2024.03.26" ;
    schema1:url "https://msgfplus.github.io/" ;
    spdx:builtFrom biotools:MSGFplus .

