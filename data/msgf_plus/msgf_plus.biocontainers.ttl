@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:msgf_plus a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/ncomms6277" ;
    schema1:description "Ms-gf+ is a new ms/ms database search tool that is sensitive (it identifies more peptides than other database search tools and as many peptides as spectral library search tools) and universal (works well for diverse types of spectra, different configurations of ms instruments and different experimental protocols)." ;
    schema1:keywords "Mass Spectrometry",
        "Mass spectra",
        "Peptides",
        "Proteomics",
        "Search Engine" ;
    schema1:license "GPL-2.0" ;
    schema1:name "msgf_plus" ;
    schema1:url "https://github.com/MSGFPlus/msgfplus" .

