@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:shapeshifter-cli a schema1:SoftwareApplication ;
    schema1:description "A command-line tool for transforming large data sets" ;
    schema1:keywords "Gene Expression",
        "Genomics",
        "RNA-Seq" ;
    schema1:license "MIT" ;
    schema1:name "shapeshifter-cli" ;
    schema1:url "https://github.com/srp33/ShapeShifter-CLI" .

