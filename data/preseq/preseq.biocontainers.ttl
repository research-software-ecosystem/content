@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:preseq a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btu540" ;
    schema1:description "Software for predicting library complexity and genome coverage in high-throughput sequencing" ;
    schema1:identifier biotools:preseq ;
    schema1:keywords "Bayes Theorem",
        "DNA",
        "Gene Library",
        "Genetic Variation",
        "Genome, Human",
        "Genomics",
        "High-Throughput Nucleotide Sequencing",
        "Humans",
        "Models, Genetic",
        "Sequence Analysis, DNA",
        "Sequencing",
        "Single-Cell Analysis" ;
    schema1:license "GNU" ;
    schema1:name "preseq" ;
    schema1:url "https://github.com/smithlabcode/preseq" .

