@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:minia a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/1748-7188-8-22" ;
    schema1:description "Minia is a short-read assembler based on a de Bruijn graph, capable of assembling a human genome on a desktop computer in a day." ;
    schema1:identifier biotools:minia ;
    schema1:license "AGPL-3.0-or-later" ;
    schema1:name "minia" ;
    schema1:softwareHelp "https://gatb.inria.fr/software/minia" ;
    schema1:softwareVersion "3.2.6" ;
    schema1:url "https://github.com/GATB/minia" ;
    spdx:builtFrom biotools:minia .

