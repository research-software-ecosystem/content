@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:minia a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/1748-7188-9-2" ;
    schema1:description "Short-read assembler based on a de bruijn graph, capable of assembling a human genome on a desktop computer in a day." ;
    schema1:identifier biotools:minia ;
    schema1:keywords "Sequence assembly" ;
    schema1:license "CECILL-2.0" ;
    schema1:name "minia" ;
    schema1:url "http://minia.genouest.org/" .

