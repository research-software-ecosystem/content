@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:rnaclust a schema1:SoftwareApplication ;
    schema1:author "pvanheus" ;
    schema1:description "A tool for clustering of RNAs based on their secondary structures using LocARNA" ;
    schema1:downloadUrl "http://www.bioinf.uni-leipzig.de/~kristin/Software/RNAclust/RNAclust-1.3.tar.gz" ;
    schema1:identifier biotools:RNAclust ;
    schema1:license "GPL-2.0" ;
    schema1:maintainer "pvanheus" ;
    schema1:name "rnaclust" ;
    schema1:softwareVersion "1.3" ;
    schema1:url "http://www.bioinf.uni-leipzig.de/~kristin/Software/RNAclust/" ;
    spdx:builtFrom biotools:RNAclust .

