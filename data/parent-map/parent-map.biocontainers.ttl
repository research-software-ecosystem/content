@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:parent-map a schema1:SoftwareApplication ;
    schema1:description "Analyze parental contributions to evolved or engineered protein or dna sequences" ;
    schema1:license "GPL-3.0" ;
    schema1:name "parent-map" ;
    schema1:url "https://github.com/damienmarsic/parent-map" .

