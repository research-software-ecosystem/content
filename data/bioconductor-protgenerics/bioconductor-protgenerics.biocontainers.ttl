@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-protgenerics a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "S4 generic functions for Bioconductor proteomics infrastructure" ;
    schema1:identifier biotools:protgenerics ;
    schema1:keywords "Computational Biology",
        "Gene Expression Profiling",
        "Genomics",
        "High-Throughput Screening Assays",
        "Programming Languages",
        "Proteomics",
        "User-Computer Interface" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-protgenerics" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/ProtGenerics.html" .

