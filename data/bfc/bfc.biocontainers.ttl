@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bfc a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btv290" ;
    schema1:description "Bfc is a standalone high-performance tool for correcting sequencing errors from illumina sequencing data." ;
    schema1:identifier biotools:bfc ;
    schema1:keywords "Computational Biology",
        "DNA",
        "False Positive Reactions",
        "Genome, Human",
        "Genomics",
        "High-Throughput Nucleotide Sequencing",
        "Humans",
        "Reproducibility of Results",
        "Sequence Analysis, DNA",
        "Sequencing",
        "Whole genome sequencing" ;
    schema1:license "MIT" ;
    schema1:name "bfc" ;
    schema1:url "https://github.com/lh3/bfc" .

