@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-rnaprobr a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1016/bs.mie.2015.01.014" ;
    schema1:description "An R package for analysis of massive parallel sequencing based RNA structure probing data" ;
    schema1:identifier biotools:rnaprobr ;
    schema1:keywords "Base Sequence",
        "Computational Biology",
        "Computer Graphics",
        "DNA Barcoding, Taxonomic",
        "DNA Probes",
        "Data Mining",
        "Genome",
        "High-Throughput Nucleotide Sequencing",
        "Hydroxyl Radical",
        "Models, Statistical",
        "Molecular Probes",
        "Molecular Sequence Data",
        "RNA",
        "Sequence Analysis, RNA",
        "Sequencing" ;
    schema1:license "GPL (>=2)" ;
    schema1:name "bioconductor-rnaprobr" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/RNAprobR.html" .

