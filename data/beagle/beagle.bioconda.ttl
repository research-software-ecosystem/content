@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:beagle a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1016/j.ajhg.2018.07.015",
        "doi:10.1086/521987" ;
    schema1:description "Beagle is a software package for phasing genotypes and for imputing ungenotyped markers." ;
    schema1:downloadUrl "https://faculty.washington.edu/browning/beagle/beagle.27Feb25.75f.jar" ;
    schema1:identifier biotools:BEAGLE ;
    schema1:license "GPL-3.0-or-later" ;
    schema1:name "beagle" ;
    schema1:softwareHelp "https://faculty.washington.edu/browning/beagle/beagle_5.4_18Mar22.pdf" ;
    schema1:softwareVersion "5.5_27Feb25.75f" ;
    schema1:url "http://faculty.washington.edu/browning/beagle/beagle.html" ;
    spdx:builtFrom biotools:BEAGLE .

