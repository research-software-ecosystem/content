@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:beagle a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1016/j.ajhg.2018.07.015",
        "doi:10.1086/521987" ;
    schema1:description "Beagle is a software package that performs genotype calling, genotype phasing, imputation of ungenotyped markers, and identity-by-descent segment detection." ;
    schema1:identifier biotools:BEAGLE ;
    schema1:keywords "Clustering",
        "Computational Biology",
        "Genome, Human",
        "Genome-Wide Association Study",
        "Haplotypes",
        "Humans",
        "Population genetics" ;
    schema1:license "GPL-3.0" ;
    schema1:name "beagle" ;
    schema1:url "https://faculty.washington.edu/browning/beagle/beagle.html" .

