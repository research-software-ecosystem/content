@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:autodock-vina a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1002/jcc.21256",
        "doi:10.26434/CHEMRXIV.9702389.V1" ;
    schema1:description "Autodock vina is an open-source program for doing molecular docking" ;
    schema1:identifier biotools:autodock ;
    schema1:keywords "Ligands",
        "Models, Molecular",
        "Protein Binding",
        "Proteins" ;
    schema1:license "Apache-2.0" ;
    schema1:name "autodock-vina" ;
    schema1:url "http://vina.scripps.edu/" .

