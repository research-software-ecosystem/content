@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:revtrans a schema1:SoftwareApplication ;
    schema1:description "revtrans - performs a reverse translation of a peptide alignment." ;
    schema1:downloadUrl "http://www.cbs.dtu.dk/services/RevTrans-2.0/web/releases/contributed/revtrans_jarmo.py",
        "http://www.cbs.dtu.dk/services/RevTrans-2.0/web/releases/revtrans-1.4.tgz" ;
    schema1:identifier biotools:revtrans ;
    schema1:license "GPLv2" ;
    schema1:name "revtrans" ;
    schema1:softwareVersion "1.4" ;
    schema1:url "http://www.cbs.dtu.dk/services/RevTrans-2.0/web/download.php" ;
    spdx:builtFrom biotools:revtrans .

