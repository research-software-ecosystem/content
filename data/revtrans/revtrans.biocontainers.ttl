@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:revtrans a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/gkg609" ;
    schema1:description "Revtrans takes a set of dna sequences, virtually translates them, aligns the peptide sequences, and uses this as a scaffold for constructing the corresponding dna multiple alignment." ;
    schema1:identifier biotools:revtrans ;
    schema1:keywords "Amino Acid Substitution",
        "Base Sequence",
        "Codon",
        "DNA",
        "Genetic variation",
        "Internet",
        "Mutation",
        "Protein expression",
        "Sequence Alignment",
        "Sequence Analysis, DNA",
        "Sequence Analysis, Protein",
        "Sequence analysis",
        "Small molecules" ;
    schema1:license "Other" ;
    schema1:name "revtrans" ;
    schema1:url "http://www.cbs.dtu.dk/services/RevTrans/" .

