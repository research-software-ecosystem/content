@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:ls-gkm a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btw142" ;
    schema1:description "gkm-SVM, a sequence-based method for predicting regulatory DNA elements, is a useful tool for studying gene regulatory mechanisms. In continuous efforts to improve the method, new software, LS-GKM, is introduced. It offers much better scalability and provides further advanced gapped k-mer based kernel functions. As a result, LS-GKM achieves considerably higher accuracy than the original gkm-SVM." ;
    schema1:keywords "Chromatin Immunoprecipitation",
        "DNA",
        "Gene Regulatory Networks",
        "Humans",
        "Support Vector Machine" ;
    schema1:license "GPL-3.0" ;
    schema1:name "ls-gkm" ;
    schema1:url "https://github.com/Dongwon-Lee/lsgkm" .

