@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:snpomatic a schema1:SoftwareApplication ;
    schema1:description "Fast, stringent short-read mapping software" ;
    schema1:license "GPL-3.0+" ;
    schema1:name "snpomatic" ;
    schema1:url "https://github.com/magnusmanske/snpomatic" .

