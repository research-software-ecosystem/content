@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-pcamethods a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btm069" ;
    schema1:description "A collection of PCA methods" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/pcaMethods_2.2.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/pcaMethods/pcaMethods_2.2.0.tar.gz', 'https://bioarchive.galaxyproject.org/pcaMethods_2.2.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-pcamethods/bioconductor-pcamethods_2.2.0_src_all.tar.gz']" ;
    schema1:identifier biotools:pcamethods ;
    schema1:license "GPL (>= 3)" ;
    schema1:name "bioconductor-pcamethods" ;
    schema1:softwareVersion "2.2.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/pcaMethods.html" ;
    spdx:builtFrom biotools:pcamethods .

