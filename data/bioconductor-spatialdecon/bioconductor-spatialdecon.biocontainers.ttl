@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-spatialdecon a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18129/b9.bioc.spatialdecon" ;
    schema1:description "Deconvolution of mixed cells from spatial and/or bulk gene expression data" ;
    schema1:keywords "Gene Expression",
        "Transcriptomics" ;
    schema1:license "Not available" ;
    schema1:name "bioconductor-spatialdecon" ;
    schema1:url "https://bioconductor.org/packages/3.12/bioc/html/SpatialDecon.html" .

