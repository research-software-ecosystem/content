@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:cyvcf a schema1:SoftwareApplication ;
    schema1:description "A cython wrapper around htslib built for fast parsing of Variant Call Format (VCF) files" ;
    schema1:keywords "Genomics" ;
    schema1:license "MIT" ;
    schema1:name "cyvcf" ;
    schema1:url "https://github.com/brentp/cyvcf2" .

