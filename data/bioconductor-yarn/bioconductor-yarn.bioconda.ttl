@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-yarn a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1101/086587" ;
    schema1:description "YARN: Robust Multi-Condition RNA-Seq Preprocessing and Normalization" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/yarn_1.36.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/yarn/yarn_1.36.0.tar.gz', 'https://bioarchive.galaxyproject.org/yarn_1.36.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-yarn/bioconductor-yarn_1.36.0_src_all.tar.gz']" ;
    schema1:identifier biotools:yarn ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-yarn" ;
    schema1:softwareVersion "1.36.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/yarn.html" ;
    spdx:builtFrom biotools:yarn .

