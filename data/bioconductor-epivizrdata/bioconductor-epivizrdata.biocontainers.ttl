@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-epivizrdata a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Serve data from bioconductor objects through a websocket connection." ;
    schema1:identifier biotools:epivizrdata ;
    schema1:keywords "Computational Biology",
        "Data management",
        "Gene Expression Profiling",
        "Genomics",
        "High-Throughput Screening Assays",
        "Programming Languages",
        "User-Computer Interface" ;
    schema1:license "MIT" ;
    schema1:name "bioconductor-epivizrdata" ;
    schema1:url "http://bioconductor.org/packages/release/bioc/html/epivizrData.html" .

