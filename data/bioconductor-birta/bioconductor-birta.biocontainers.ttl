@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-birta a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/bts257" ;
    schema1:description "Bayesian Inference of Regulation of Transcriptional Activity" ;
    schema1:identifier biotools:birta ;
    schema1:keywords "Bayes Theorem",
        "Computational Biology",
        "Escherichia coli",
        "Female",
        "Gene Expression Profiling",
        "Gene Expression Regulation",
        "Gene Regulatory Networks",
        "Humans",
        "MicroRNAs",
        "Ovarian Neoplasms",
        "Pancreatic Neoplasms",
        "RNA",
        "RNA, Messenger",
        "Transcription Factors",
        "Transcriptomics" ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-birta" ;
    schema1:url "https://www.bioconductor.org/packages/release/bioc/html/birta.html" .

