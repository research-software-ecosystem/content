@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-ebsea a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Exon Based Strategy for Expression Analysis of genes" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/EBSEA_1.34.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/EBSEA/EBSEA_1.34.0.tar.gz', 'https://bioarchive.galaxyproject.org/EBSEA_1.34.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-ebsea/bioconductor-ebsea_1.34.0_src_all.tar.gz']" ;
    schema1:identifier biotools:ebsea ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-ebsea" ;
    schema1:softwareVersion "1.34.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/EBSEA.html" ;
    spdx:builtFrom biotools:ebsea .

