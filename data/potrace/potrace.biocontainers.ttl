@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:potrace a schema1:SoftwareApplication ;
    schema1:description "A tool for tracing a bitmap, which means, transforming a bitmap into a smooth, scalable image" ;
    schema1:license "GPL" ;
    schema1:name "potrace" ;
    schema1:url "http://potrace.sourceforge.net" .

