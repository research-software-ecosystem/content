@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-minpack.lm a schema1:SoftwareApplication ;
    schema1:description "The nls.lm function provides an R interface to lmder and lmdif from the MINPACK library, for solving nonlinear least-squares problems by a modification of the Levenberg-Marquardt algorithm, with support for lower and upper parameter bounds.  The implementation can be used via nls-like calls using the nlsLM function.  " ;
    schema1:license "GPL-3" ;
    schema1:name "r-minpack.lm" ;
    schema1:url "https://CRAN.R-project.org/package=minpack.lm" .

