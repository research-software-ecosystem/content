@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:outrigger a schema1:SoftwareApplication ;
    schema1:description "Outrigger detects *de novo* exons and quantifies their percent spliced-in" ;
    schema1:license "BSD" ;
    schema1:name "outrigger" ;
    schema1:url "https://github.com/YeoLab/outrigger" .

