@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-optparse a schema1:SoftwareApplication ;
    schema1:description "A command line parser inspired by Python's 'optparse' library to be used with Rscript to write \"#!\" shebang scripts that accept short and long flag/options." ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "r-optparse" ;
    schema1:url "None" .

