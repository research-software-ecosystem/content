@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-lobstahs a schema1:SoftwareApplication ;
    schema1:description "Lipid and Oxylipin Biomarker Screening through Adduct Hierarchy Sequences" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/LOBSTAHS_1.36.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/LOBSTAHS/LOBSTAHS_1.36.0.tar.gz', 'https://bioarchive.galaxyproject.org/LOBSTAHS_1.36.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-lobstahs/bioconductor-lobstahs_1.36.0_src_all.tar.gz']" ;
    schema1:identifier biotools:lobstahs ;
    schema1:license "GPL (>= 3) + file LICENSE" ;
    schema1:name "bioconductor-lobstahs" ;
    schema1:softwareVersion "1.36.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/LOBSTAHS.html" ;
    spdx:builtFrom biotools:lobstahs .

