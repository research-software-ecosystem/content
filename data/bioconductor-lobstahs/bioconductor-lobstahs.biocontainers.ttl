@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-lobstahs a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1021/acs.analchem.6b01260" ;
    schema1:description "Lipid and Oxylipin Biomarker Screening through Adduct Hierarchy Sequences" ;
    schema1:identifier biotools:lobstahs ;
    schema1:keywords "Biomarkers",
        "Chromatography, Liquid",
        "Databases, Chemical",
        "Diatoms",
        "High-Throughput Screening Assays",
        "Hydrogen Peroxide",
        "Isomerism",
        "Lipid Metabolism",
        "Lipids",
        "Mass Spectrometry",
        "Mass spectra",
        "Metabolomics",
        "Oxidative Stress",
        "Oxylipins",
        "Small molecules" ;
    schema1:license "GPL-3.0" ;
    schema1:name "bioconductor-lobstahs" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/LOBSTAHS.html" .

