@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-ggtools a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btp169" ;
    schema1:description "Software and data for analyses in genetics of gene expression and/or dna methylation." ;
    schema1:identifier biotools:ggtools ;
    schema1:keywords "Databases, Genetic",
        "Gene Expression",
        "Gene Expression Profiling",
        "Gene expression",
        "Genetics",
        "Genotype",
        "Oligonucleotide Array Sequence Analysis",
        "Polymorphism, Single Nucleotide" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-ggtools" ;
    schema1:url "http://bioconductor.org/packages/release/bioc/html/GGtools.html" .

