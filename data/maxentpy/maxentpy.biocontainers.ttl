@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:maxentpy a schema1:SoftwareApplication ;
    schema1:description "maxentpy is a python wrapper for MaxEntScan to calculate splice site strength." ;
    schema1:license "MIT" ;
    schema1:name "maxentpy" ;
    schema1:url "https://github.com/kepbod/maxentpy" .

