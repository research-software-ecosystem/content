@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:nanomod a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s12864-018-5372-8" ;
    schema1:description "A computational method for nanopore signal analysis and modification detection." ;
    schema1:keywords "Computational Biology",
        "Computer Simulation",
        "DNA",
        "Escherichia coli",
        "Genomics",
        "High-Throughput Nucleotide Sequencing",
        "Humans",
        "Nanopores",
        "Reproducibility of Results",
        "Sequence Analysis, DNA",
        "Workflow" ;
    schema1:license "Not available" ;
    schema1:name "nanomod" ;
    schema1:url "https://github.com/WGLab/NanoMod" .

