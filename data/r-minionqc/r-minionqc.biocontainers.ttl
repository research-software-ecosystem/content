@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-minionqc a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/bty654" ;
    schema1:description "Quality control for MinION sequencing data" ;
    schema1:keywords "Computational Biology",
        "Gene Library",
        "High-Throughput Nucleotide Sequencing",
        "Quality Control",
        "Sequence Analysis, DNA" ;
    schema1:license "MIT" ;
    schema1:name "r-minionqc" ;
    schema1:url "https://github.com/roblanf/minion_qc/blob/master/MinIONQC.R" .

