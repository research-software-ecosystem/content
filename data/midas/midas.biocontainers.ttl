@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:midas a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1007/s13361-013-0733-7",
        "doi:10.1101/gr.201863.115" ;
    schema1:description "An integrated pipeline for estimating strain-level genomic variation from metagenomic data" ;
    schema1:identifier biotools:midas ;
    schema1:keywords "Adult",
        "Bacteria",
        "Bacterial Infections",
        "Biochemistry",
        "DNA Fingerprinting",
        "Feces",
        "Female",
        "Genome, Bacterial",
        "Humans",
        "Infant",
        "Infectious Disease Transmission, Vertical",
        "Metagenome",
        "Metagenomics",
        "Molecular biology",
        "Phylogeny",
        "Phylogeography",
        "Polymorphism, Single Nucleotide",
        "Proteins",
        "Reference Standards",
        "Sequence Analysis, DNA",
        "Sequence analysis",
        "Soil Microbiology",
        "Water Microbiology" ;
    schema1:license "GNU General Public License v3.0" ;
    schema1:name "midas" ;
    schema1:url "https://github.com/snayfach/MIDAS" .

