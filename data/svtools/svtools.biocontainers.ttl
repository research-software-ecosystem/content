@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:svtools a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btz492",
        "doi:10.5281/zenodo.3406745" ;
    schema1:description "Tools for processing and analyzing structural variants" ;
    schema1:keywords "Genome, Human",
        "Humans",
        "Sequence Deletion",
        "Whole Genome Sequencing" ;
    schema1:license "MIT" ;
    schema1:name "svtools" ;
    schema1:url "https://github.com/hall-lab/svtools" .

