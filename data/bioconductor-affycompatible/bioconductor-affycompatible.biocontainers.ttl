@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-affycompatible a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "This package provides an interface to affymetrix chip annotation and sample attribute files. the package allows an easy way for users to download and manage local data bases of affynmetrix netaffx annotation files. the package also provides access to genechip operating system (gcos) and genechip command console (agcc)-compatible sample annotation files." ;
    schema1:identifier biotools:affycompatible ;
    schema1:keywords "Computational Biology",
        "Database management",
        "Gene Expression Profiling",
        "Genomics",
        "High-Throughput Screening Assays",
        "Microarray experiment",
        "Programming Languages",
        "User-Computer Interface" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-affycompatible" ;
    schema1:url "http://bioconductor.org/packages/release/bioc/html/AffyCompatible.html" .

