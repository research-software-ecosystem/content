@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:debarcer a schema1:SoftwareApplication ;
    schema1:description "A package for de-barcoding and error correction of sequencing data containing molecular barcodes." ;
    schema1:license "Not available" ;
    schema1:name "debarcer" ;
    schema1:url "https://github.com/oicr-gsi/debarcer" .

