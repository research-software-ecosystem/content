@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-dmrcate a schema1:SoftwareApplication ;
    schema1:description "Methylation array and sequencing spatial analysis methods" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/DMRcate_3.6.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/DMRcate/DMRcate_3.6.0.tar.gz', 'https://bioarchive.galaxyproject.org/DMRcate_3.6.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-dmrcate/bioconductor-dmrcate_3.6.0_src_all.tar.gz']" ;
    schema1:identifier biotools:dmrcate ;
    schema1:license "file LICENSE" ;
    schema1:name "bioconductor-dmrcate" ;
    schema1:softwareVersion "3.6.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/DMRcate.html" ;
    spdx:builtFrom biotools:dmrcate .

