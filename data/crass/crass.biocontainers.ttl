@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:crass a schema1:SoftwareApplication ;
    schema1:description "Crass (The CRISPR Assembler) is a program that searches through raw metagenomic reads for Clustered Regularly Interspersed Short Palindromic Repeats" ;
    schema1:keywords "Clustering",
        "Protein Sequences",
        "Sequence Alignment" ;
    schema1:license "GNU General Public License v3.0" ;
    schema1:name "crass" ;
    schema1:url "https://github.com/mummer4/mummer" .

