@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:fitter a schema1:SoftwareApplication ;
    schema1:description "A tool to fit data to many distributions and best one(s)" ;
    schema1:license "GPL-3.0" ;
    schema1:name "fitter" ;
    schema1:url "http://github.com/cokelaer/fitter" .

