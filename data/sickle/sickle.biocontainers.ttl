@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:sickle a schema1:SoftwareApplication ;
    schema1:description "A tool that uses sliding windows along with quality and length thresholds to determine when quality is sufficiently low to trim the 3'-end of reads and also determines when the quality is sufficiently high enough to trim the 5'-end of reads." ;
    schema1:identifier biotools:sickle ;
    schema1:keywords "Data quality management" ;
    schema1:license "MIT" ;
    schema1:name "sickle" ;
    schema1:url "https://github.com/najoshi/sickle" .

