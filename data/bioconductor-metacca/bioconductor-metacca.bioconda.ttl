@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-metacca a schema1:SoftwareApplication ;
    schema1:description "Summary Statistics-Based Multivariate Meta-Analysis of Genome-Wide Association Studies Using Canonical Correlation Analysis" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/metaCCA_1.38.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/metaCCA/metaCCA_1.38.0.tar.gz', 'https://bioarchive.galaxyproject.org/metaCCA_1.38.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-metacca/bioconductor-metacca_1.38.0_src_all.tar.gz']" ;
    schema1:identifier biotools:metacca ;
    schema1:license "MIT + file LICENSE" ;
    schema1:name "bioconductor-metacca" ;
    schema1:softwareVersion "1.38.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/metaCCA.html" ;
    spdx:builtFrom biotools:metacca .

