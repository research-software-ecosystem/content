@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-metacca a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btw052" ;
    schema1:description "Performs multivariate analysis of a single or multiple gwas based on univariate regression coefficients. it allows multivariate representation of both phenotype and genotype. it extends the statistical technique of canonical correlation analysis to the setting where original individual-level records are not available, and employs a covariance shrinkage algorithm to achieve robustness." ;
    schema1:identifier biotools:metacca ;
    schema1:keywords "Computational Biology",
        "GWAS study",
        "Genetics",
        "Genome-Wide Association Study",
        "Genotype",
        "Genotype and phenotype",
        "Humans",
        "Multivariate Analysis",
        "Phenotype",
        "Polymorphism, Single Nucleotide" ;
    schema1:license "MIT" ;
    schema1:name "bioconductor-metacca" ;
    schema1:url "http://bioconductor.org/packages/release/bioc/html/metaCCA.html" .

