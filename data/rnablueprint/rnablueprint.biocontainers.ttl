@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:rnablueprint a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btx263" ;
    schema1:description "The RNAblueprint library solves the problem of uniformly sampling RNA/DNA sequences compatible to multiple structural constraints and sequence constraints." ;
    schema1:identifier biotools:rnablueprint ;
    schema1:keywords "Data visualisation",
        "Models, Molecular",
        "Nucleic Acid Conformation",
        "Nucleic acids",
        "RNA",
        "Synthetic Biology" ;
    schema1:license "GPL-3.0" ;
    schema1:name "rnablueprint" ;
    schema1:url "https://github.com/ViennaRNA/RNAblueprint" .

