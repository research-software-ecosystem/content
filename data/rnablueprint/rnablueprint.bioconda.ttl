@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:rnablueprint a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btx263" ;
    schema1:description "The RNAblueprint library solves the problem of uniformly sampling RNA/DNA sequences compatible to multiple structural constraints and sequence constraints." ;
    schema1:downloadUrl "https://github.com/ViennaRNA/RNAblueprint/archive/refs/tags/v1.3.3.tar.gz" ;
    schema1:identifier biotools:rnablueprint ;
    schema1:license "GPL-3.0-or-later" ;
    schema1:name "rnablueprint" ;
    schema1:softwareHelp "https://viennarna.github.io/RNAblueprint" ;
    schema1:softwareVersion "1.3.3" ;
    schema1:url "https://github.com/ViennaRNA/RNAblueprint" ;
    spdx:builtFrom biotools:rnablueprint .

