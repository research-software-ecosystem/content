@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-cliquems a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18129/b9.bioc.cliquems" ;
    schema1:description "Annotation of Isotopes, Adducts and Fragmentation Adducts for in-Source LC/MS Metabolomics Data" ;
    schema1:keywords "Mass spectrometry",
        "Metabolomics" ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-cliquems" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/cliqueMS.html" .

