        "Gene Expression Regulation, Fungal",
        "Genome, Fungal",
        "Quantitative Trait, Heritable",
        "Reproductive Isolation",
        "Schizosaccharomyces",
        "Translocation, Genetic" ;
    schema1:license "MIT" ;
    schema1:name "survivor" ;
    schema1:url "https://github.com/fritzsedlazeck/SURVIVOR" .

