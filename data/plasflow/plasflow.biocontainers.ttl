@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:plasflow a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/gkx1321" ;
    schema1:description "Plasflow - predicting plasmid sequences in metagenomic data" ;
    schema1:keywords "Bacteria",
        "Computational Biology",
        "Genomics",
        "Metagenome",
        "Metagenomics",
        "Phylogeny",
        "Plasmids",
        "Reproducibility of Results",
        "Sequence Analysis, DNA" ;
    schema1:license "GPL-3.0" ;
    schema1:name "plasflow" ;
    schema1:url "https://github.com/smaegol/PlasFlow" .

