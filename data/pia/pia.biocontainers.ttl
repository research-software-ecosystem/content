@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:pia a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1021/acs.jproteome.5b00121" ;
    schema1:description "The main focus lays on the integrated inference algorithms, concluding the proteins from a set of identified spectra. but it also allows you to inspect your peptide spectrum matches, calculate fdr values across different search engine results and visualize the correspondence between psms, peptides and proteins." ;
    schema1:identifier biotools:pia ;
    schema1:keywords "Databases, Protein",
        "Internet",
        "Peptides",
        "Protein variants",
        "Proteins",
        "Proteomics",
        "Proteomics experiment",
        "User-Computer Interface" ;
    schema1:license "BSD-3-Clause" ;
    schema1:name "pia" ;
    schema1:url "https://github.com/mpc-bioinformatics/pia" .

