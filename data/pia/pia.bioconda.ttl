@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:pia a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1021/acs.jproteome.5b00121" ;
    schema1:description "PIA is a toolbox for MS based protein inference and identification analysis." ;
    schema1:downloadUrl "https://github.com/medbioinf/pia/releases/download/1.5.8/pia-1.5.8.zip" ;
    schema1:identifier biotools:pia ;
    schema1:license "BSD-3-Clause" ;
    schema1:name "pia" ;
    schema1:softwareVersion "1.5.8" ;
    schema1:url "https://github.com/medbioinf/pia" ;
    spdx:builtFrom biotools:pia .

