@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-myvariant a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1101/035667" ;
    schema1:description "Accesses MyVariant.info variant query and annotation services" ;
    schema1:identifier biotools:myvariant ;
    schema1:keywords "Bioinformatics",
        "Protein variants" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-myvariant" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/myvariant.html" .

