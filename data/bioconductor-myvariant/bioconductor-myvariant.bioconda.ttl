@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-myvariant a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1101/035667" ;
    schema1:description "Accesses MyVariant.info variant query and annotation services" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/myvariant_1.36.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/myvariant/myvariant_1.36.0.tar.gz', 'https://bioarchive.galaxyproject.org/myvariant_1.36.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-myvariant/bioconductor-myvariant_1.36.0_src_all.tar.gz']" ;
    schema1:identifier biotools:myvariant ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-myvariant" ;
    schema1:softwareVersion "1.36.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/myvariant.html" ;
    spdx:builtFrom biotools:myvariant .

