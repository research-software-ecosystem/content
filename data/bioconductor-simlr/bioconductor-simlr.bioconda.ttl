@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-simlr a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1101/118901" ;
    schema1:description "Single-cell Interpretation via Multi-kernel LeaRning (SIMLR)" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/SIMLR_1.32.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/SIMLR/SIMLR_1.32.0.tar.gz', 'https://bioarchive.galaxyproject.org/SIMLR_1.32.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-simlr/bioconductor-simlr_1.32.0_src_all.tar.gz']" ;
    schema1:identifier biotools:simlr ;
    schema1:license "file LICENSE" ;
    schema1:name "bioconductor-simlr" ;
    schema1:softwareVersion "1.32.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/SIMLR.html" ;
    spdx:builtFrom biotools:simlr .

