@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:pyloh a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btu174" ;
    schema1:description "Deconvolving tumor purity and ploidy by integrating copy number alterations and loss of heterozygosity" ;
    schema1:identifier biotools:pyloh ;
    schema1:keywords "Breast Neoplasms",
        "Chromosome Mapping",
        "Computational Biology",
        "DNA",
        "DNA Copy Number Variations",
        "DNA polymorphism",
        "Genome, Human",
        "High-Throughput Nucleotide Sequencing",
        "Humans",
        "Loss of Heterozygosity",
        "Models, Statistical",
        "Neoplasms",
        "Oncology",
        "Ploidies",
        "Whole genome sequencing" ;
    schema1:license "GNU General Public License v2.0" ;
    schema1:name "pyloh" ;
    schema1:url "https://github.com/uci-cbcl/PyLOH" .

