@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-quartpac a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s12859-016-0963-3" ;
    schema1:description "Identification of mutational clusters in protein quaternary structures." ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.18/bioc/src/contrib/QuartPAC_1.34.0.tar.gz', 'https://bioconductor.org/packages/3.18/bioc/src/contrib/Archive/QuartPAC/QuartPAC_1.34.0.tar.gz', 'https://bioarchive.galaxyproject.org/QuartPAC_1.34.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-quartpac/bioconductor-quartpac_1.34.0_src_all.tar.gz']" ;
    schema1:identifier biotools:quartpac ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-quartpac" ;
    schema1:softwareVersion "1.34.0" ;
    schema1:url "https://bioconductor.org/packages/3.18/bioc/html/QuartPAC.html" ;
    spdx:builtFrom biotools:quartpac .

