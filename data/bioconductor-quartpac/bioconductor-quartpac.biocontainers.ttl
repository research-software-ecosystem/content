        "Humans",
        "Internet",
        "Mutation",
        "Neoplasms",
        "Protein Structure, Quaternary",
        "Protein structure analysis",
        "Proteins",
        "Proteomics",
        "User-Computer Interface" ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-quartpac" ;
    schema1:url "http://bioconductor.org/packages/3.6/bioc/html/QuartPAC.html" .

