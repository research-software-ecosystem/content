@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-sispa a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/gkv1503" ;
    schema1:description "SISPA: Method for Sample Integrated Set Profile Analysis" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.17/bioc/src/contrib/SISPA_1.30.0.tar.gz', 'https://bioconductor.org/packages/3.17/bioc/src/contrib/Archive/SISPA/SISPA_1.30.0.tar.gz', 'https://bioarchive.galaxyproject.org/SISPA_1.30.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-sispa/bioconductor-sispa_1.30.0_src_all.tar.gz']" ;
    schema1:identifier biotools:sispa ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-sispa" ;
    schema1:softwareVersion "1.30.0" ;
    schema1:url "https://bioconductor.org/packages/3.17/bioc/html/SISPA.html" ;
    spdx:builtFrom biotools:sispa .

