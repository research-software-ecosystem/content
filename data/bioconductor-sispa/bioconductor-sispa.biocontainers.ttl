@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-sispa a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/gkv1503" ;
    schema1:description "SISPA: Method for Sample Integrated Set Profile Analysis" ;
    schema1:identifier biotools:sispa ;
    schema1:keywords "Cell Line, Tumor",
        "DNA Methylation",
        "GWAS study",
        "Gene Expression Profiling",
        "Genes, Neoplasm",
        "Genomics",
        "Humans",
        "Multiple Myeloma",
        "Mutation",
        "Prognosis" ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-sispa" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/SISPA.html" .

