@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:crux-toolkit a schema1:SoftwareApplication ;
    schema1:description "A cross-platform suite of analysis tools for interpreting protein mass spectrometry data" ;
    schema1:keywords "Proteomics" ;
    schema1:license "Apache-2.0" ;
    schema1:name "crux-toolkit" ;
    schema1:url "https://github.com/crux-toolkit/crux-toolkit" .

