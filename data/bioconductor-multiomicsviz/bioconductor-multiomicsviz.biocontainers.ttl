@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-multiomicsviz a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18129/b9.bioc.multiomicsviz" ;
    schema1:description "Plot the effect of one omics data on other omics data along the chromosome" ;
    schema1:license "LGPL" ;
    schema1:name "bioconductor-multiomicsviz" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/multiOmicsViz.html" .

