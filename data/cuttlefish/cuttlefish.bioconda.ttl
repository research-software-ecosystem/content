@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:cuttlefish a schema1:SoftwareApplication ;
    schema1:author "jamshed",
        "rob-p" ;
    schema1:citation "doi:10.1093/bioinformatics/btab309",
        "doi:10.1186/s13059-022-02743-6" ;
    schema1:description "Construction of the compacted de Bruijn graph efficiently." ;
    schema1:downloadUrl "https://github.com/COMBINE-lab/cuttlefish/archive/refs/tags/v2.2.0.tar.gz" ;
    schema1:identifier biotools:cuttlefish ;
    schema1:license "BSD-3-Clause" ;
    schema1:maintainer "jamshed",
        "rob-p" ;
    schema1:name "cuttlefish" ;
    schema1:softwareHelp "https://github.com/COMBINE-lab/cuttlefish/blob/v2.2.0/README.md" ;
    schema1:softwareVersion "2.2.0" ;
    schema1:url "https://github.com/COMBINE-lab/cuttlefish" ;
    spdx:builtFrom biotools:cuttlefish .

