@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-omicsmarker a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18129/b9.bioc.omicsmarker" ;
    schema1:description "Classification and Feature Selection for 'Omics' Datasets" ;
    schema1:keywords "Metabolomics",
        "Proteomics",
        "Transcriptomics" ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-omicsmarker" ;
    schema1:url "https://bioconductor.org/packages/3.8/bioc/html/OmicsMarkeR.html" .

