@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:rseqc a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/bts356" ;
    schema1:description "QC package for RNA-seq data." ;
    schema1:downloadUrl "https://pypi.org/packages/source/r/rseqc/rseqc-5.0.4.tar.gz" ;
    schema1:identifier biotools:rseqc ;
    schema1:license "GPL-2.0-or-later" ;
    schema1:name "rseqc" ;
    schema1:softwareHelp "https://rseqc.sourceforge.net/#usage-information" ;
    schema1:softwareVersion "5.0.4" ;
    schema1:url "https://rseqc.sourceforge.net" ;
    spdx:builtFrom biotools:rseqc .

