@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:rseqc a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/bts356",
        "doi:10.1186/s12859-016-0922-z" ;
    schema1:description "RSeQC package provides a number of useful modules that can comprehensively evaluate high throughput sequence data especially RNA-seq data" ;
    schema1:identifier biotools:rseqc ;
    schema1:keywords "Gene Expression",
        "Genome, Human",
        "Genomics",
        "High-Throughput Nucleotide Sequencing",
        "Humans",
        "Male",
        "Prostatic Neoplasms",
        "Quality Control",
        "RNA Stability",
        "RNA, Messenger",
        "RNA, Neoplasm",
        "RNA-Seq",
        "Sequence Analysis, RNA",
        "Sequencing",
        "Transcriptome" ;
    schema1:license "GPL-3.0" ;
    schema1:name "rseqc" ;
    schema1:url "http://rseqc.sourceforge.net/" .

