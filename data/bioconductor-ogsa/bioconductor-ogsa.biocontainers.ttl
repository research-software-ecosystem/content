@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-ogsa a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1109/TCBB.2013.153" ;
    schema1:description "Outlier Gene Set Analysis" ;
    schema1:identifier biotools:ogsa ;
    schema1:keywords "Biomarkers, Tumor",
        "Child",
        "Gene Expression Profiling",
        "Gene regulation",
        "Genomics",
        "Humans",
        "Leukemia, Myeloid",
        "Methylation",
        "Models, Statistical",
        "Molecular interactions, pathways and networks",
        "Oncology",
        "Signal Transduction" ;
    schema1:license "GPL (== 2)" ;
    schema1:name "bioconductor-ogsa" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/OGSA.html" .

