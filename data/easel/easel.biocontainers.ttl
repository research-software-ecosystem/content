@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:easel a schema1:SoftwareApplication ;
    schema1:description "Easel is an ANSI C code library developed by the Eddy/Rivas laboratory at Harvard for computational analysis of biological sequences using probabilistic models." ;
    schema1:license "BSD" ;
    schema1:name "easel" ;
    schema1:url "https://github.com/EddyRivasLab/easel" .

