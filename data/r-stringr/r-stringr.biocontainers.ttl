@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-stringr a schema1:SoftwareApplication ;
    schema1:description "A consistent, simple and easy to use set of wrappers around the fantastic stringi package. All function and argument names (and positions) are consistent, all functions deal with NAs and zero length vectors in the same way, and the output from one function is easy to feed into the input of another." ;
    schema1:license "GPL-2.0" ;
    schema1:name "r-stringr" ;
    schema1:url "https://github.com/tidyverse/stringr" .

