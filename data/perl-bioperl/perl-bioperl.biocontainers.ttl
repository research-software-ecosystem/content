@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:perl-bioperl a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1007/978-1-59745-535-0_26" ;
    schema1:description "Bioinformatics toolkit" ;
    schema1:identifier biotools:bioperl ;
    schema1:keywords "Computational Biology",
        "Data management",
        "Databases, Genetic",
        "Genomics",
        "Programming Languages",
        "Sequence Alignment",
        "Software engineering",
        "User-Computer Interface" ;
    schema1:license "perl_5" ;
    schema1:name "perl-bioperl" ;
    schema1:url "https://github.com/bioperl/bioperl-live" .

