@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:perl-bioperl a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1007/978-1-59745-535-0_26" ;
    schema1:description "Bioinformatics Toolkit" ;
    schema1:identifier biotools:bioperl ;
    schema1:license "perl_5" ;
    schema1:name "perl-bioperl" ;
    schema1:softwareVersion "1.7.8" ;
    schema1:url "http://metacpan.org/pod/BioPerl" ;
    spdx:builtFrom biotools:bioperl .

