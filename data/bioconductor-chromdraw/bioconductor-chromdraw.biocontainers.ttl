@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-chromdraw a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1007/s10577-015-9513-5" ;
    schema1:description "chromDraw is a R package for drawing the schemes of karyotypes in the linear and circular fashion." ;
    schema1:identifier biotools:chromdraw ;
    schema1:keywords "Chromosome Aberrations",
        "Chromosomes",
        "Data visualisation",
        "Genomics",
        "Karyotype",
        "Karyotyping" ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-chromdraw" ;
    schema1:url "https://bioconductor.org/packages/release/bioc/html/chromDraw.html" .

