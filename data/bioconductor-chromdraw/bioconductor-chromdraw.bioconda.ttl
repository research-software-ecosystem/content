@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-chromdraw a schema1:SoftwareApplication ;
    schema1:description "chromDraw is a R package for drawing the schemes of karyotypes in the linear and circular fashion." ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/chromDraw_2.40.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/chromDraw/chromDraw_2.40.0.tar.gz', 'https://bioarchive.galaxyproject.org/chromDraw_2.40.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-chromdraw/bioconductor-chromdraw_2.40.0_src_all.tar.gz']" ;
    schema1:identifier biotools:chromdraw ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-chromdraw" ;
    schema1:softwareVersion "2.40.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/chromDraw.html" ;
    spdx:builtFrom biotools:chromdraw .

