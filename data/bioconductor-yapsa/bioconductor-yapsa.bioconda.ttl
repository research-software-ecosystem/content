@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-yapsa a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Yet Another Package for Signature Analysis" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/YAPSA_1.32.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/YAPSA/YAPSA_1.32.0.tar.gz', 'https://bioarchive.galaxyproject.org/YAPSA_1.32.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-yapsa/bioconductor-yapsa_1.32.0_src_all.tar.gz']" ;
    schema1:identifier biotools:yapsa ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-yapsa" ;
    schema1:softwareVersion "1.32.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/YAPSA.html" ;
    spdx:builtFrom biotools:yapsa .

