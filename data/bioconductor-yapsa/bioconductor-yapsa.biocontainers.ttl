@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-yapsa a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Yet Another Package for Signature Analysis" ;
    schema1:identifier biotools:yapsa ;
    schema1:keywords "Applied mathematics",
        "Clustering",
        "Computational Biology",
        "Data mining",
        "Gene Expression Profiling",
        "Genetic variation",
        "Genomics",
        "High-Throughput Screening Assays",
        "Oncology",
        "Programming Languages",
        "User-Computer Interface" ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-yapsa" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/YAPSA.html" .

