@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-chipseq a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "chipseq: A package for analyzing chipseq data" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/chipseq_1.56.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/chipseq/chipseq_1.56.0.tar.gz', 'https://bioarchive.galaxyproject.org/chipseq_1.56.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-chipseq/bioconductor-chipseq_1.56.0_src_all.tar.gz']" ;
    schema1:identifier biotools:chipseq ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-chipseq" ;
    schema1:softwareVersion "1.56.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/chipseq.html" ;
    spdx:builtFrom biotools:chipseq .

