@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-chipseq a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "chipseq: A package for analyzing chipseq data" ;
    schema1:identifier biotools:chipseq ;
    schema1:keywords "ChIP-seq",
        "Computational Biology",
        "Gene Expression Profiling",
        "Genomics",
        "High-Throughput Screening Assays",
        "Programming Languages",
        "User-Computer Interface" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-chipseq" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/chipseq.html" .

