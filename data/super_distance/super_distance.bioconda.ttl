@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:super_distance a schema1:SoftwareApplication ;
    schema1:description "Supertree method with distances" ;
    schema1:identifier biotools:super_distance ;
    schema1:license "GPLv3" ;
    schema1:name "super_distance" ;
    schema1:softwareVersion "1.1.0" ;
    schema1:url "https://github.com/quadram-institute-bioscience/super_distance" ;
    spdx:builtFrom biotools:super_distance .

