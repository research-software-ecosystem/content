@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:super_distance a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/bth211" ;
    schema1:description "Supertree method with distances" ;
    schema1:identifier biotools:super_distance ;
    schema1:keywords "Chromosome Mapping",
        "Clustering",
        "Evolution, Molecular",
        "Genetics",
        "Genome",
        "Genomics",
        "Least-Squares Analysis",
        "Models, Genetic",
        "Models, Statistical",
        "Ortholog",
        "Phylogeny",
        "Sequence Alignment",
        "Sequence Analysis, DNA" ;
    schema1:license "GPL-3.0" ;
    schema1:name "super_distance" ;
    schema1:url "https://github.com/quadram-institute-bioscience/super_distance" .

