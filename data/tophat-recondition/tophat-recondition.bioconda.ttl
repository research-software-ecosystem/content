@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:tophat-recondition a schema1:SoftwareApplication ;
    schema1:author "cbrueffer" ;
    schema1:citation "doi:10.1186/s12859-016-1058-x" ;
    schema1:description "Post-processor for TopHat unmapped reads" ;
    schema1:downloadUrl "https://github.com/cbrueffer/tophat-recondition/archive/v1.4.tar.gz" ;
    schema1:identifier biotools:tophat-recondition ;
    schema1:license "BSD-2-Clause" ;
    schema1:maintainer "cbrueffer" ;
    schema1:name "tophat-recondition" ;
    schema1:softwareVersion "1.4" ;
    schema1:url "https://github.com/cbrueffer/tophat-recondition" ;
    spdx:builtFrom biotools:tophat-recondition .

