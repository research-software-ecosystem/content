@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-tracktables a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Build IGV tracks and HTML reports" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/tracktables_1.44.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/tracktables/tracktables_1.44.0.tar.gz', 'https://bioarchive.galaxyproject.org/tracktables_1.44.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-tracktables/bioconductor-tracktables_1.44.0_src_all.tar.gz']" ;
    schema1:identifier biotools:tracktables ;
    schema1:license "GPL (>= 3)" ;
    schema1:name "bioconductor-tracktables" ;
    schema1:softwareVersion "1.44.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/tracktables.html" ;
    spdx:builtFrom biotools:tracktables .

