@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:reseq a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1101/2020.07.17.209072" ;
    schema1:description "More realistic simulator for genomic DNA sequences from Illumina machines that achieves a similar k-mer spectrum as the original" ;
    schema1:license "MIT" ;
    schema1:name "reseq" ;
    schema1:url "https://github.com/schmeing/ReSeq/tree/devel" .

