@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-plotly a schema1:SoftwareApplication ;
    schema1:description "Create interactive web graphics from ggplot2 graphs and/or a custom interface to the (MIT-licensed) JavaScript library plotly.js inspired by the grammar of graphics." ;
    schema1:license "MIT" ;
    schema1:name "r-plotly" ;
    schema1:url "https://github.com/ropensci/plotly" .

