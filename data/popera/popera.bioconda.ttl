@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:popera a schema1:SoftwareApplication ;
    schema1:description "A software for DNase I hypersensitive sites identification." ;
    schema1:downloadUrl "https://github.com/forrestzhang/Popera/archive/1.0.3.tar.gz" ;
    schema1:identifier biotools:popera ;
    schema1:license "MIT" ;
    schema1:name "popera" ;
    schema1:softwareVersion "1.0.3" ;
    schema1:url "https://github.com/forrestzhang/Popera" ;
    spdx:builtFrom biotools:popera .

