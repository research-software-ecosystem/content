@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-genomegraphs a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/1471-2105-10-2" ;
    schema1:description "Plotting genomic information from Ensembl" ;
    schema1:keywords "Computational Biology",
        "Computer Graphics",
        "Data Interpretation, Statistical",
        "Exons",
        "Genome",
        "Genomics",
        "Humans",
        "Models, Statistical",
        "Programming Languages",
        "Protein Isoforms",
        "Transcription, Genetic",
        "User-Computer Interface" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-genomegraphs" ;
    schema1:url "https://bioconductor.org/packages/release/bioc/html/GenomeGraphs.html" .

