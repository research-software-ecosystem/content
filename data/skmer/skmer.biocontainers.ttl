@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:skmer a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s13059-019-1632-4" ;
    schema1:description "Assembly-free and alignment-free tool for estimating genomic distances between genome-skims" ;
    schema1:keywords "Animals",
        "Birds",
        "DNA Barcoding, Taxonomic",
        "Genome, Insect",
        "Genomics",
        "Models, Genetic",
        "Phylogeny" ;
    schema1:license "the University of California" ;
    schema1:name "skmer" ;
    schema1:url "https://github.com/shahab-sarmashghi/Skmer" .

