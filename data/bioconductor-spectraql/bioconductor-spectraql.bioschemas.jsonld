  "@graph": [
    {
      "@id": "https://bio.tools/bioconductor-spectraql",
      "@type": "sc:SoftwareApplication",
      "dcterms:conformsTo": "https://bioschemas.org/profiles/ComputationalTool/0.6-DRAFT",
      "sc:additionalType": [
        "Command-line tool",
        "Library"
      ],
      "sc:author": [
        "Johannes Rainer",
        "Andrea Vicini"
      ],
      "sc:citation": {
        "@id": "https://doi.org/10.1038/s41592-025-02660-z"
      },
      "sc:contributor": "Sebastian Gibb",
      "sc:description": "The Mass Spec Query Language (MassQL) is a domain-specific language enabling to express a query and retrieve mass spectrometry (MS) data in a more natural and understandable way for MS users. It is inspired by SQL and is by design programming language agnostic. The SpectraQL package adds support for the MassQL query language to R, in particular to MS data represented by Spectra objects. Users can thus apply MassQL expressions to analyze and retrieve specific data from Spectra objects.",
      "sc:license": "Artistic-2.0",
      "sc:name": "SpectraQL",
      "sc:operatingSystem": [
        "Windows",
        "Mac",
        "Linux"
      ],
      "sc:softwareHelp": {
        "@id": "https://bioconductor.org/packages/SpectraQL"
      },
      "sc:softwareVersion": "1.4.0",
      "sc:url": "https://bioconductor.org/packages/SpectraQL"
    },
