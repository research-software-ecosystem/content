  "@graph": [
    {
      "@id": "https://bio.tools/bioconductor-anansi",
      "@type": "sc:SoftwareApplication",
      "dcterms:conformsTo": "https://bioschemas.org/profiles/ComputationalTool/0.6-DRAFT",
      "sc:additionalType": [
        "Command-line tool",
        "Library"
      ],
      "sc:author": [
        "Thomas Quinn",
        "Giulio Benedetti",
        "Tuomas Borman",
        "Thomaz Bastiaanssen",
        "Leo Lahti"
      ],
      "sc:citation": {
        "@id": "https://doi.org/10.48550/arXiv.2305.10832"
      },
      "sc:description": "Studies including both microbiome and metabolomics data are becoming more common. Often, it would be helpful to integrate both datasets in order to see if they corroborate each others patterns. All vs all association is imprecise and likely to yield spurious associations. This package takes a knowledge-based approach to constrain association search space, only considering metabolite-function pairs that have been recorded in a pathway database. This package also provides a framework to assess differential association.",
      "sc:license": "GPL-3.0-only",
      "sc:name": "anansi",
      "sc:operatingSystem": [
        "Linux",
        "Windows",
        "Mac"
      ],
      "sc:softwareHelp": {
        "@id": "https://bioconductor.org/packages/anansi"
      },
      "sc:softwareVersion": "1.0.0",
      "sc:url": "https://bioconductor.org/packages/anansi"
    },
    {
      "@id": "https://doi.org/10.48550/arXiv.2305.10832",
      "@type": "sc:CreativeWork"
    }
  ]
