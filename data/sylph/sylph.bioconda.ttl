@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:sylph a schema1:SoftwareApplication ;
    schema1:author "bluenote-1577" ;
    schema1:citation "doi:10.1038/s41587-024-02412-y" ;
    schema1:description "sylph quickly enables querying of genomes against even low-coverage shotgun metagenomes to find nearest neighbour ANI." ;
    schema1:downloadUrl "https://github.com/bluenote-1577/sylph/archive/v0.9.0.tar.gz" ;
    schema1:identifier biotools:sylph ;
    schema1:license "MIT" ;
    schema1:maintainer "bluenote-1577" ;
    schema1:name "sylph" ;
    schema1:softwareHelp "https://github.com/bluenote-1577/sylph/blob/v0.9.0/README.md" ;
    schema1:softwareVersion "0.9.0" ;
    schema1:url "https://github.com/bluenote-1577/sylph" ;
    spdx:builtFrom biotools:sylph .

