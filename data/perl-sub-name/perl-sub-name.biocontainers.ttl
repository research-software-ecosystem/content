@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:perl-sub-name a schema1:SoftwareApplication ;
    schema1:description "(re)name a sub" ;
    schema1:license "free software" ;
    schema1:name "perl-sub-name" ;
    schema1:url "https://github.com/p5sagit/Sub-Name" .

