@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:nanoqc a schema1:SoftwareApplication ;
    schema1:description "Create fastqc-like plots for oxford nanopore sequencing data" ;
    schema1:license "MIT" ;
    schema1:name "nanoqc" ;
    schema1:url "https://github.com/wdecoster/nanoQC" .

