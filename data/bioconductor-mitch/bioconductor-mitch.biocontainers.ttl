@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-mitch a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18129/b9.bioc.mitch" ;
    schema1:description "Multi-contrast gene set enrichment analysis" ;
    schema1:keywords "Genetics",
        "Proteomics",
        "RNA-Seq",
        "Transcriptomics" ;
    schema1:license "CC BY-SA 4.0" ;
    schema1:name "bioconductor-mitch" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/mitch.html" .

