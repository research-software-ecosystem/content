@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:collect-columns a schema1:SoftwareApplication ;
    schema1:description "Retrieve a column for each in a set of tables, placing them in a single output table." ;
    schema1:keywords "RNA-Seq" ;
    schema1:license "MIT" ;
    schema1:name "collect-columns" ;
    schema1:url "https://github.com/biowdl/collect-columns" .

