@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:flextaxd a schema1:SoftwareApplication ;
    schema1:description "Script that allows the creation of custom kraken databases from various sources (ncbi, qiime, cansnper)" ;
    schema1:license "GPL-3.0" ;
    schema1:name "flextaxd" ;
    schema1:url "https://github.com/FOI-Bioinformatics/flextaxd" .

