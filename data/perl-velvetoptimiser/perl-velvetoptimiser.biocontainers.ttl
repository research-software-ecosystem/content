@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:perl-velvetoptimiser a schema1:SoftwareApplication ;
    schema1:description "Automatically optimise three of velvet's assembly parameters." ;
    schema1:identifier biotools:velvetoptimiser ;
    schema1:keywords "Genomics",
        "Sequence assembly" ;
    schema1:license "GPL-2.0" ;
    schema1:name "perl-velvetoptimiser" ;
    schema1:url "https://github.com/tseemann/VelvetOptimiser" .

