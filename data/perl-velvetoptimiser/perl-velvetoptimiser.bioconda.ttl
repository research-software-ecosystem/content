@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:perl-velvetoptimiser a schema1:SoftwareApplication ;
    schema1:description "Automatically optimise three of Velvet's assembly parameters." ;
    schema1:downloadUrl "https://github.com/tseemann/VelvetOptimiser/archive/2.2.6.tar.gz" ;
    schema1:identifier biotools:velvetoptimiser ;
    schema1:license "GPLv2" ;
    schema1:name "perl-velvetoptimiser" ;
    schema1:softwareVersion "2.2.6" ;
    schema1:url "https://github.com/tseemann/VelvetOptimiser" ;
    spdx:builtFrom biotools:velvetoptimiser .

