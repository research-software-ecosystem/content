@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:tepid a schema1:SoftwareApplication ;
    schema1:citation "doi:10.7554/elife.20777" ;
    schema1:description "Tepid uses paired-end illumina sequencing reads to identify novel te variants." ;
    schema1:keywords "Arabidopsis",
        "DNA Methylation",
        "DNA Transposable Elements",
        "Epigenomics",
        "Gene Expression Regulation",
        "Genetic Variation",
        "Genetics, Population" ;
    schema1:license "GNU General Public License v3.0" ;
    schema1:name "tepid" ;
    schema1:url "https://github.com/ListerLab/TEPID" .

