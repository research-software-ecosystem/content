@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:pplacer a schema1:SoftwareApplication ;
    schema1:description "Pplacer places query sequences on a fixed reference phylogenetic tree to maximize phylogenetic likelihood or posterior probability according to a reference alignment." ;
    schema1:license "GPL-3" ;
    schema1:name "pplacer" ;
    schema1:url "https://github.com/matsen/pplacer" .

