@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:fgap a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/1756-0500-7-371" ;
    schema1:description "Fgap: an automated gap closing tool" ;
    schema1:identifier biotools:fgap ;
    schema1:keywords "Base Sequence",
        "Chromosomes, Human, Pair 14",
        "Contig Mapping",
        "Escherichia coli",
        "Genome, Bacterial",
        "Genome, Human",
        "High-Throughput Nucleotide Sequencing",
        "Humans",
        "Molecular Sequence Data",
        "Sequence analysis" ;
    schema1:license "MIT" ;
    schema1:name "fgap" ;
    schema1:url "https://github.com/pirovc/fgap" .

