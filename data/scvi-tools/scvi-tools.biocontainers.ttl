@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:scvi-tools a schema1:SoftwareApplication ;
    schema1:description "Deep generative models for end-to-end analysis of single-cell omics data." ;
    schema1:keywords "Genomics",
        "RNA-Seq",
        "Transcriptomics" ;
    schema1:license "BSD-3.0" ;
    schema1:name "scvi-tools" ;
    schema1:url "https://github.com/YosefLab/scvi-tools" .

