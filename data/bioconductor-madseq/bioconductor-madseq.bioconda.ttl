@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-madseq a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1101/142299" ;
    schema1:description "Mosaic Aneuploidy Detection and Quantification using Massive Parallel Sequencing Data" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/MADSEQ_1.32.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/MADSEQ/MADSEQ_1.32.0.tar.gz', 'https://bioarchive.galaxyproject.org/MADSEQ_1.32.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-madseq/bioconductor-madseq_1.32.0_src_all.tar.gz']" ;
    schema1:identifier biotools:madseq ;
    schema1:license "GPL(>=2)" ;
    schema1:name "bioconductor-madseq" ;
    schema1:softwareVersion "1.32.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/MADSEQ.html" ;
    spdx:builtFrom biotools:madseq .

