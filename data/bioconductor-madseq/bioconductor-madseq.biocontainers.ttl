@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-madseq a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1101/142299" ;
    schema1:description "Mosaic Aneuploidy Detection and Quantification using Massive Parallel Sequencing Data" ;
    schema1:identifier biotools:madseq ;
    schema1:keywords "Cell biology",
        "DNA",
        "Nucleic acid structure analysis" ;
    schema1:license "GPL(>=2)" ;
    schema1:name "bioconductor-madseq" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/MADSEQ.html" .

