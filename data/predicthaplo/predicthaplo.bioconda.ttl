@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:predicthaplo a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1109/TCBB.2013.145" ;
    schema1:description "This software aims at reconstructing haplotypes from next-generation sequencing data." ;
    schema1:downloadUrl "https://github.com/cbg-ethz/PredictHaplo/archive/2.1.4.tar.gz" ;
    schema1:identifier biotools:PredictHaplo ;
    schema1:license "GPL-3.0-or-later" ;
    schema1:name "predicthaplo" ;
    schema1:softwareVersion "2.1.4" ;
    schema1:url "https://github.com/cbg-ethz/PredictHaplo" ;
    spdx:builtFrom biotools:PredictHaplo .

