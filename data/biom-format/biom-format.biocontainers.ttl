@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:biom-format a schema1:SoftwareApplication ;
    schema1:description "Biological observation matrix (biom) format (python 3)" ;
    schema1:keywords "Genomics",
        "Metagenome",
        "Metagenomics" ;
    schema1:license "GPL" ;
