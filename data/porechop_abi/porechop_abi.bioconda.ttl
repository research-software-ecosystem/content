@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:porechop_abi a schema1:SoftwareApplication ;
    schema1:description "Adapter inferrence and removal of Oxford Nanopore reads." ;
    schema1:downloadUrl "https://github.com/bonsai-team/Porechop_ABI/archive/0bc9f17f31d4ec1dcbab4796871cc09324cc143b.tar.gz" ;
    schema1:identifier biotools:porechop_abi ;
    schema1:license "GPL-3.0-or-later" ;
    schema1:name "porechop_abi" ;
    schema1:softwareHelp "https://github.com/bonsai-team/Porechop_ABI/blob/master/README.md" ;
    schema1:softwareVersion "0.5.1" ;
    schema1:url "https://github.com/bonsai-team/Porechop_ABI" ;
    spdx:builtFrom biotools:porechop_abi .

