@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-nucler a schema1:SoftwareApplication ;
    schema1:description "Nucleosome positioning package for R" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/nucleR_2.42.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/nucleR/nucleR_2.42.0.tar.gz', 'https://bioarchive.galaxyproject.org/nucleR_2.42.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-nucler/bioconductor-nucler_2.42.0_src_all.tar.gz']" ;
    schema1:identifier biotools:nucler ;
    schema1:license "LGPL (>= 3)" ;
    schema1:name "bioconductor-nucler" ;
    schema1:softwareVersion "2.42.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/nucleR.html" ;
    spdx:builtFrom biotools:nucler .

