@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-nucler a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btr345" ;
    schema1:description "Nucleosome positioning package for R" ;
    schema1:identifier biotools:nucler ;
    schema1:keywords "DNA packaging",
        "Fourier Analysis",
        "Genetics",
        "Genomics",
        "Nucleic acid sites, features and motifs",
        "Nucleosomes",
        "Sequencing" ;
    schema1:license "LGPL-3.0" ;
    schema1:name "bioconductor-nucler" ;
    schema1:url "https://www.bioconductor.org/packages/release/bioc/html/nucleR.html" .

