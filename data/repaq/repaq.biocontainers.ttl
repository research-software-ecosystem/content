@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:repaq a schema1:SoftwareApplication ;
    schema1:description "A fast lossless FASTQ compressor with ultra-high compression ratio" ;
    schema1:license "MIT" ;
    schema1:name "repaq" ;
    schema1:url "https://github.com/OpenGene/repaq" .

