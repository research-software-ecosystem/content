@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-bayespeak a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/biostatistics/kxr029" ;
    schema1:description "Bayesian Analysis of ChIP-seq Data" ;
    schema1:identifier biotools:bayespeak ;
    schema1:keywords "Bayes Theorem",
        "Binding Sites",
        "Biotechnology",
        "ChIP-seq",
        "Chromatin Immunoprecipitation",
        "DNA",
        "DNA binding sites",
        "Data Interpretation, Statistical",
        "Databases, Nucleic Acid",
        "Humans",
        "Markov Chains",
        "Models, Statistical",
        "Nucleic acid sites, features and motifs",
        "Sequence Analysis, DNA",
        "Transcription Factors" ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-bayespeak" ;
    schema1:url "None" .

