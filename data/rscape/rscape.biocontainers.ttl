@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:rscape a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1101/2020.02.04.933952",
        "doi:10.1101/789404" ;
    schema1:description "R-scape (rna structural covariation above phylogenetic expectation) looks for evidence of a conserved rna secondary structure by measuring pairwise covariations observed in an input multiple sequence alignment." ;
    schema1:keywords "Sequence Alignment" ;
    schema1:license "GPL-3.0" ;
    schema1:name "rscape" ;
    schema1:url "http://eddylab.org/R-scape/" .

