@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:quasitools a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1101/733238" ;
    schema1:description "Quasitools is a collection of tools for analysing viral quasispecies" ;
    schema1:identifier biotools:quasitools ;
    schema1:keywords "Sequencing",
        "Small molecules",
        "Virology" ;
    schema1:license "Apache-2.0" ;
    schema1:name "quasitools" ;
    schema1:url "https://github.com/phac-nml/quasitools/" .

