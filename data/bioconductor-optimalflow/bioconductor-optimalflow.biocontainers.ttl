        "Flow Cytometry",
        "Humans",
        "Statistics as Topic",
        "Supervised Machine Learning" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-optimalflow" ;
    schema1:url "http://www.bioconductor.org/packages/release/bioc/html/optimalFlow.html" .

