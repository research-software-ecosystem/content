@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioservices a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btt547" ;
    schema1:description "Access to Biological Web Services from Python" ;
    schema1:identifier biotools:bioservices ;
    schema1:keywords "Biology",
        "Computational Biology",
        "Databases, Factual",
        "Information Storage and Retrieval",
        "Internet",
        "Peptides",
        "Programming Languages",
        "Systems Integration" ;
    schema1:license "GPL-3.0" ;
    schema1:name "bioservices" ;
    schema1:url "https://github.com/cokelaer/bioservices" .

