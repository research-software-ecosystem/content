        "Genomics",
        "Humans",
        "Metagenome",
        "Metagenomics",
        "Microbiota",
        "Soil Microbiology",
        "User-Computer Interface",
        "Water Microbiology" ;
    schema1:license "Not available" ;
    schema1:name "das_tool" ;
