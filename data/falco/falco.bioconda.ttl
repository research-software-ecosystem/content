@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:falco a schema1:SoftwareApplication ;
    schema1:author "andrewdavidsmith",
        "guilhermesena1" ;
    schema1:citation "doi:10.12688/f1000research.21142.2" ;
    schema1:description "falco is a drop-in C++ implementation of FastQC to assess the quality of sequence reads." ;
    schema1:downloadUrl "https://github.com/smithlabcode/falco/releases/download/v1.3.0/falco-1.3.0.tar.gz" ;
    schema1:identifier biotools:falco ;
    schema1:license "GPL-3.0-only" ;
    schema1:maintainer "andrewdavidsmith",
        "guilhermesena1" ;
    schema1:name "falco" ;
    schema1:softwareHelp "https://falco.readthedocs.io" ;
    schema1:softwareVersion "1.3.0" ;
    schema1:url "https://github.com/smithlabcode/falco" ;
    spdx:builtFrom biotools:falco .

