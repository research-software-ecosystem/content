@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:falco a schema1:SoftwareApplication ;
    schema1:citation "doi:10.12688/F1000RESEARCH.21142.1" ;
    schema1:description "falco is a C++ implementation of FastQC to run quality control checks on fastq files" ;
    schema1:identifier biotools:falco ;
    schema1:keywords "Imaging",
        "Mapping",
        "Workflows" ;
    schema1:license "GPL 3" ;
    schema1:name "falco" ;
    schema1:url "https://github.com/smithlabcode/falco" .

