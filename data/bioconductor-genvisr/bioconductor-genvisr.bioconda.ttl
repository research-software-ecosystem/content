@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-genvisr a schema1:SoftwareApplication ;
    schema1:description "Genomic Visualizations in R" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/GenVisR_1.42.2.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/GenVisR/GenVisR_1.42.2.tar.gz', 'https://bioarchive.galaxyproject.org/GenVisR_1.42.2.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-genvisr/bioconductor-genvisr_1.42.2_src_all.tar.gz']" ;
    schema1:identifier biotools:genvisr ;
    schema1:license "GPL-3 + file LICENSE" ;
    schema1:name "bioconductor-genvisr" ;
    schema1:softwareVersion "1.42.2" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/GenVisR.html" ;
    spdx:builtFrom biotools:genvisr .

