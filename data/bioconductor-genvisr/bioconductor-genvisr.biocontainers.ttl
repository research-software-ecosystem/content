@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-genvisr a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btw325" ;
    schema1:description "Produce highly customizable publication quality graphics for genomic data primarily at the cohort level." ;
    schema1:identifier biotools:genvisr ;
    schema1:keywords "Genome",
        "Genomics" ;
    schema1:license "GPL-3.0" ;
    schema1:name "bioconductor-genvisr" ;
    schema1:url "http://bioconductor.org/packages/release/bioc/html/GenVisR.html" .

