@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-excluster a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18129/b9.bioc.excluster" ;
    schema1:description "ExCluster robustly detects differentially expressed exons between two conditions of RNA-seq data, requiring at least two independent biological replicates per condition" ;
    schema1:keywords "RNA-Seq" ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-excluster" ;
    schema1:url "https://bioconductor.org/packages/3.8/bioc/html/ExCluster.html" .

