@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-s4vectors a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Bioconductor s4 implementation of vectors and lists" ;
    schema1:identifier biotools:s4vectors ;
    schema1:keywords "Applied mathematics",
        "Computational Biology",
        "Gene Expression Profiling",
        "Genetics",
        "Genomics",
        "High-Throughput Screening Assays",
        "Metagenome",
        "Programming Languages",
        "Transcriptome",
        "User-Computer Interface" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-s4vectors" ;
    schema1:url "https://bioconductor.org/packages/S4Vectors/" .

