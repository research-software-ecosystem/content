@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-rnexml a schema1:SoftwareApplication ;
    schema1:description "Provides access to phyloinformatic data in 'NeXML' format.  The package should add new functionality to R such as the possibility to manipulate 'NeXML' objects in more various and refined way and compatibility with 'ape' objects." ;
    schema1:keywords "Genetics",
        "Phylogenetics" ;
    schema1:license "BSD_3_clause" ;
    schema1:name "r-rnexml" ;
    schema1:url "https://CRAN.R-project.org/package=RNeXML" .

