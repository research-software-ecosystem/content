@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:subread a schema1:SoftwareApplication ;
    schema1:author "mjsteinbaugh" ;
    schema1:citation "doi:10.1093/nar/gkt214" ;
    schema1:description "High-performance read alignment, quantification, and mutation discovery." ;
    schema1:downloadUrl "https://downloads.sourceforge.net/project/subread/subread-2.1.1/subread-2.1.1-source.tar.gz" ;
    schema1:identifier biotools:subread ;
    schema1:license "GPL-3.0-only" ;
    schema1:maintainer "mjsteinbaugh" ;
    schema1:name "subread" ;
    schema1:softwareHelp "https://subread.sourceforge.net/SubreadUsersGuide.pdf" ;
    schema1:softwareVersion "2.1.1" ;
    schema1:url "https://subread.sourceforge.net" ;
    spdx:builtFrom biotools:subread .

