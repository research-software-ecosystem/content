@prefix debianmed: <https://salsa.debian.org/med-team/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

debianmed:subread a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btt656",
        "doi:10.1093/nar/gkt214",
        "doi:10.1093/nar/gkz114",
        "doi:10.1186/s12859-022-04644-8" ;
    schema1:description "toolkit for processing next-gen sequencing data" ;
    schema1:identifier "bio.tools:subread",
        "conda:bioconda:subread",
        "omictools:OMICS_01255",
        "scicrunch:SCR_009803" ;
    schema1:license "unknown" ;
    schema1:name "subread" ;
    schema1:softwareVersion "2.0.8" ;
    schema1:url "http://sourceforge.net/projects/subread/" ;
    spdx:builtFrom "subread" .

