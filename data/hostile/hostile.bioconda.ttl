@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:hostile a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btad728" ;
    schema1:description "Hostile: accurate host decontamination." ;
    schema1:downloadUrl "https://pypi.org/packages/source/h/hostile/hostile-2.0.2.tar.gz" ;
    schema1:identifier biotools:hostile ;
    schema1:license "MIT" ;
    schema1:name "hostile" ;
    schema1:softwareHelp "https://github.com/bede/hostile/blob/2.0.2/README.md" ;
    schema1:softwareVersion "2.0.2" ;
    schema1:url "https://github.com/bede/hostile" ;
    spdx:builtFrom biotools:hostile .

