@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:pipmir a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1101/gr.123547.111" ;
    schema1:description "We developed the PIPmiR algorithm to identify novel plant miRNA." ;
    schema1:downloadUrl "https://ohlerlab.mdc-berlin.de/files/duke/PIPmiR/PIPmiR_v1_1b_executable.tar.gz" ;
    schema1:identifier biotools:pipmir ;
    schema1:license "PIPmiR is provided for academic use only, if you wish to use it in another setting please contact Uwe Ohler." ;
    schema1:name "pipmir" ;
    schema1:softwareVersion "1.1" ;
    schema1:url "https://ohlerlab.mdc-berlin.de/software/Pipeline_for_the_Identification_of_Plant_miRNAs_84" ;
    spdx:builtFrom biotools:pipmir .

