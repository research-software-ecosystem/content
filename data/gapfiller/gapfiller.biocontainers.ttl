@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:gapfiller a schema1:SoftwareApplication ;
    schema1:description "Gapfiller is a seed-and-extend local assembler to fill the gap within paired reads." ;
    schema1:license "GPL-3" ;
    schema1:name "gapfiller" ;
    schema1:url "https://sourceforge.net/projects/gapfiller" .

