  "@graph": [
    {
      "@id": "https://bio.tools/bioconductor-flowspecs",
      "@type": "sc:SoftwareApplication",
      "dcterms:conformsTo": "https://bioschemas.org/profiles/ComputationalTool/0.6-DRAFT",
      "sc:additionalType": [
        "Command-line tool",
        "Library"
      ],
      "sc:author": "Jakob Theorell",
      "sc:citation": {
        "@id": "https://doi.org/10.18129/B9.bioc.flowSpecs"
      },
      "sc:description": "This package is intended to fill the role of conventional cytometry pre-processing software, for spectral decomposition, transformation, visualization and cleanup, and to aid further downstream analyses, such as with DepecheR, by enabling transformation of flowFrames and flowSets to dataframes. Functions for flowCore-compliant automatic 1D-gating/filtering are in the pipe line. The package name has been chosen both as it will deal with spectral cytometry and as it will hopefully give the user a nice pair of spectacles through which to view their data.",
      "sc:license": "MIT",
      "sc:name": "flowSpecs",
      "sc:operatingSystem": [
        "Mac",
        "Windows",
        "Linux"
      ],
      "sc:softwareHelp": {
        "@id": "https://bioconductor.org/packages/flowSpecs"
      },
      "sc:softwareVersion": "1.24.0",
      "sc:url": "https://bioconductor.org/packages/flowSpecs"
    },
