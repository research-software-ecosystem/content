@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-flowclust a schema1:SoftwareApplication ;
    schema1:description "Clustering for Flow Cytometry" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/flowClust_3.44.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/flowClust/flowClust_3.44.0.tar.gz', 'https://bioarchive.galaxyproject.org/flowClust_3.44.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-flowclust/bioconductor-flowclust_3.44.0_src_all.tar.gz']" ;
    schema1:identifier biotools:flowclust ;
    schema1:license "MIT" ;
    schema1:name "bioconductor-flowclust" ;
    schema1:softwareVersion "3.44.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/flowClust.html" ;
    spdx:builtFrom biotools:flowclust .

