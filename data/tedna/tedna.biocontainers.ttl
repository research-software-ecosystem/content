@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:tedna a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btu365" ;
    schema1:description "Tedna is a lightweight de novo transposable element assembler" ;
    schema1:identifier biotools:tedna ;
    schema1:keywords "Arabidopsis",
        "DNA",
        "DNA Transposable Elements",
        "Genomics",
        "Repetitive Sequences, Nucleic Acid",
        "Sequence Analysis, DNA",
        "Sequence analysis",
        "Sequence assembly",
        "Triticum" ;
    schema1:license "GNU Affero General Public License" ;
    schema1:name "tedna" ;
    schema1:url "https://urgi.versailles.inra.fr/Tools/Tedna" .

