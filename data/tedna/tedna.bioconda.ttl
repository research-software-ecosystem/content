@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:tedna a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btu365" ;
    schema1:description "Tedna is a lightweight de novo transposable element assembler." ;
    schema1:downloadUrl "https://github.com/mzytnicki/tedna/archive/refs/tags/1.3.1.tar.gz" ;
    schema1:identifier biotools:tedna ;
    schema1:license "GPL-3.0-or-later" ;
    schema1:name "tedna" ;
    schema1:softwareHelp "https://github.com/mzytnicki/tedna/blob/1.3.1/README.md" ;
    schema1:softwareVersion "1.3.1" ;
    schema1:url "https://github.com/mzytnicki/tedna" ;
    spdx:builtFrom biotools:tedna .

