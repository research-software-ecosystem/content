@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-rtcgatoolbox a schema1:SoftwareApplication ;
    schema1:description "A new tool for exporting TCGA Firehose data" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/RTCGAToolbox_2.36.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/RTCGAToolbox/RTCGAToolbox_2.36.0.tar.gz', 'https://bioarchive.galaxyproject.org/RTCGAToolbox_2.36.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-rtcgatoolbox/bioconductor-rtcgatoolbox_2.36.0_src_all.tar.gz']" ;
    schema1:identifier biotools:rtcgatoolbox ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-rtcgatoolbox" ;
    schema1:softwareVersion "2.36.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/RTCGAToolbox.html" ;
    spdx:builtFrom biotools:rtcgatoolbox .

