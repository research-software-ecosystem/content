@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:fcsparser a schema1:SoftwareApplication ;
    schema1:description "A python package for reading raw fcs files" ;
    schema1:license "MIT" ;
    schema1:name "fcsparser" ;
    schema1:url "https://github.com/eyurtsev/fcsparser" .

