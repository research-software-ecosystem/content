@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:ucsc-estorient a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bib/bbs038" ;
    schema1:description "Read ESTs from a database and determine orientation based on estOrientInfo table or direction in gbCdnaInfo table.  Update PSLs so that the strand reflects the direction of transcription. By default, PSLs where the direction can't be determined are dropped." ;
    schema1:downloadUrl "https://hgdownload.cse.ucsc.edu/admin/exe/userApps.archive/userApps.v482.src.tgz" ;
    schema1:identifier biotools:UCSC_Genome_Browser_Utilities ;
    schema1:license "Varies; see https://genome.ucsc.edu/license" ;
    schema1:name "ucsc-estorient" ;
    schema1:softwareHelp "https://github.com/ucscGenomeBrowser/kent/blob/v482_base/README" ;
    schema1:softwareVersion "482" ;
    schema1:url "https://hgdownload.cse.ucsc.edu/admin/exe" ;
    spdx:builtFrom biotools:UCSC_Genome_Browser_Utilities .

