@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:python3-pymummer a schema1:SoftwareApplication ;
    schema1:description "Python3 wrapper for running MUMmer and parsing the output. MUMmer is a modular and versatile package that relies on a suffix tree data structure for efficient pattern matching." ;
    schema1:license "GPL-3.0" ;
    schema1:name "python3-pymummer" ;
    schema1:url "https://github.com/sanger-pathogens/pymummer" .

