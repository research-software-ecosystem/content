    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/rGADEM_2.54.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/rGADEM/rGADEM_2.54.0.tar.gz', 'https://bioarchive.galaxyproject.org/rGADEM_2.54.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-rgadem/bioconductor-rgadem_2.54.0_src_all.tar.gz']" ;
