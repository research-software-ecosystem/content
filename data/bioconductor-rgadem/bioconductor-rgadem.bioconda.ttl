    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-rgadem" ;
    schema1:softwareVersion "2.54.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/rGADEM.html" ;
    spdx:builtFrom biotools:rgadem .

