        "Chromosome Mapping",
        "HeLa Cells",
        "Hepatocyte Nuclear Factor 3-alpha",
        "Humans",
        "Molecular Sequence Data",
        "Protein Binding",
        "Repressor Proteins",
        "STAT1 Transcription Factor",
        "Sequence Analysis, DNA",
        "Sequence Homology",
        "Sequence sites, features and motifs",
        "Systems Integration",
        "Transcription Factors",
        "Tumor Cells, Cultured" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-rgadem" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/rGADEM.html" .

