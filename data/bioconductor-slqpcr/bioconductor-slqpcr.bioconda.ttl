@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-slqpcr a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Functions for analysis of real-time quantitative PCR data at SIRS-Lab GmbH" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/SLqPCR_1.76.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/SLqPCR/SLqPCR_1.76.0.tar.gz', 'https://bioarchive.galaxyproject.org/SLqPCR_1.76.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-slqpcr/bioconductor-slqpcr_1.76.0_src_all.tar.gz']" ;
    schema1:identifier biotools:slqpcr ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-slqpcr" ;
    schema1:softwareVersion "1.76.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/SLqPCR.html" ;
    spdx:builtFrom biotools:slqpcr .

