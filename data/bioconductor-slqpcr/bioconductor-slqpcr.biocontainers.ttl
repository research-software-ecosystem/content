@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-slqpcr a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Functions for analysis of real-time quantitative PCR data at SIRS-Lab GmbH" ;
    schema1:identifier biotools:slqpcr ;
    schema1:keywords "Computational Biology",
        "Gene Expression Profiling",
        "Genomics",
        "High-Throughput Screening Assays",
        "PCR experiment",
        "Programming Languages",
        "User-Computer Interface" ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-slqpcr" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/SLqPCR.html" .

