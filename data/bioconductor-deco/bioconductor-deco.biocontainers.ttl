@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-deco a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18129/b9.bioc.deco" ;
    schema1:description "Decomposing Heterogeneous Cohorts using Omic Data Profiling" ;
    schema1:keywords "Clustering",
        "Functional genomics",
        "Genomics",
        "Proteomics",
        "Transcriptomics" ;
    schema1:license "GPL (>=3)" ;
    schema1:name "bioconductor-deco" ;
    schema1:url "https://bioconductor.org/packages/3.9/bioc/html/deco.html" .

