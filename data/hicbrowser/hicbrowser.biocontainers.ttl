@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:hicbrowser a schema1:SoftwareApplication ;
    schema1:description "A simple web browser to visualize Hi-C and other genomic tracks (bigwig, bed, interactions)." ;
    schema1:keywords "Genetics",
        "Genomics" ;
    schema1:license "GPL-3.0" ;
    schema1:name "hicbrowser" ;
    schema1:url "https://github.com/maxplanck-ie/HiCBrowser" .

