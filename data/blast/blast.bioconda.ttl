@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:blast a schema1:SoftwareApplication ;
    schema1:author "christiam",
        "ebete" ;
    schema1:citation "doi:10.1016/S0022-2836(05)80360-2" ;
    schema1:description "BLAST+ is a new suite of BLAST tools that utilizes the NCBI C++ Toolkit." ;
    schema1:downloadUrl "https://ftp.ncbi.nlm.nih.gov/blast/executables/blast+/2.17.0/ncbi-blast-2.17.0+-src.tar.gz" ;
    schema1:identifier biotools:blast ;
    schema1:license "NCBI-PD" ;
    schema1:maintainer "christiam",
        "ebete" ;
    schema1:name "blast" ;
    schema1:softwareVersion "2.17.0" ;
    schema1:url "https://blast.ncbi.nlm.nih.gov/doc/blast-help/" ;
    spdx:builtFrom biotools:blast .

