@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:blast a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1016/S0022-2836(05)80360-2",
        "doi:10.1093/bioinformatics/btw305" ;
    schema1:description "Basic local alignment search tool" ;
    schema1:identifier biotools:blast ;
    schema1:keywords "Benchmarking",
        "Databases, Protein",
        "Genomics",
        "High-Throughput Nucleotide Sequencing",
        "Protein Sequences",
        "Proteins",
        "Sequence Alignment",
        "Sequence Homology",
        "Sequence Homology, Amino Acid",
        "Sequence analysis" ;
    schema1:license "MIT" ;
    schema1:name "blast" ;
    schema1:url "http://blast.ncbi.nlm.nih.gov/Blast.cgi?CMD=Web&PAGE_TYPE=BlastHome" .

