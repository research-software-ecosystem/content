@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:akt a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btw576" ;
    schema1:description "Ancestry and Kinship Tools (AKT) provides a handful of useful statistical genetics routines using the htslib API for input/output. This means it can seamlessly read BCF/VCF files and play nicely with bcftools." ;
    schema1:keywords "Cluster Analysis",
        "Family",
        "Female",
        "Genetics",
        "Genome, Human",
        "Humans",
        "Male",
        "Pedigree",
        "Phylogeny",
        "Sequence Analysis, DNA" ;
    schema1:license "GPL-3.0" ;
    schema1:name "akt" ;
    schema1:url "https://github.com/Illumina/akt" .

