@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-metabosignal a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btw697" ;
    schema1:description "MetaboSignal: a network-based approach to overlay and explore metabolic and signaling KEGG pathways" ;
    schema1:identifier biotools:metabosignal ;
    schema1:keywords "Adipose Tissue",
        "Animals",
        "Computational Biology",
        "Genetics",
        "Metabolic Networks and Pathways",
        "Metabolomics",
        "Molecular interactions, pathways and networks",
        "Quantitative Trait Loci",
        "Rats",
        "Signal Transduction" ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-metabosignal" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/MetaboSignal.html" .

