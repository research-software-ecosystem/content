@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-metabosignal a schema1:SoftwareApplication ;
    schema1:description "MetaboSignal: a network-based approach to overlay and explore metabolic and signaling KEGG pathways" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/MetaboSignal_1.36.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/MetaboSignal/MetaboSignal_1.36.0.tar.gz', 'https://bioarchive.galaxyproject.org/MetaboSignal_1.36.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-metabosignal/bioconductor-metabosignal_1.36.0_src_all.tar.gz']" ;
    schema1:identifier biotools:metabosignal ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-metabosignal" ;
    schema1:softwareVersion "1.36.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/MetaboSignal.html" ;
    spdx:builtFrom biotools:metabosignal .

