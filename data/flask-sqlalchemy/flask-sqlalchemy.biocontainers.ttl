@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:flask-sqlalchemy a schema1:SoftwareApplication ;
    schema1:description "Flask-Sqlalchemy: Adds sqlalchemy support to your flask application" ;
    schema1:license "BSD" ;
    schema1:name "flask-sqlalchemy" ;
    schema1:url "https://pypi.python.org/packages/source/F/Flask-SQLAlchemy/Flask-SQLAlchemy-2.1.tar.gz" .

