@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:suitename a schema1:SoftwareApplication ;
    schema1:description "Categorize each suite in an rna backbone" ;
    schema1:keywords "Genomics" ;
    schema1:license "suitename" ;
    schema1:name "suitename" ;
    schema1:url "http://kinemage.biochem.duke.edu/software/suitename.php" .

