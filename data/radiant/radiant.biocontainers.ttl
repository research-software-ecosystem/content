@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:radiant a schema1:SoftwareApplication ;
    schema1:description "Explore hierarchical metagenomic data with zoomable pie charts" ;
    schema1:keywords "Genomics",
        "Metagenome",
        "Metagenomics",
        "Metaproteomics",
        "Proteomics" ;
    schema1:license "custom, see /usr/share/doc/radiant/copyright" ;
    schema1:name "radiant" ;
    schema1:url "https://github.com/marbl/Krona/wiki" .

