@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bmtagger a schema1:SoftwareApplication ;
    schema1:description "Bmtagger aka best match tagger is for removing human reads from metagenomics datasets." ;
    schema1:license "Public Domain" ;
    schema1:name "bmtagger" ;
    schema1:url "ftp://ftp.ncbi.nlm.nih.gov/pub/agarwala/bmtagger/" .

