@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:metagene_annotator a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/dnares/dsn027" ;
    schema1:description "MetaGeneAnnotator is a gene-finding program for prokaryote and phage" ;
    schema1:identifier biotools:metageneannotator ;
    schema1:keywords "Bacteria",
        "Bacteriophages",
        "Binding Sites",
        "Computational Biology",
        "Data submission, annotation and curation",
        "Genes, Bacterial",
        "Genes, Viral",
        "Genome, Bacterial",
        "Genome, Viral",
        "Genomics",
        "Model organisms",
        "Plasmids",
        "Predictive Value of Tests",
        "Protein Biosynthesis",
        "Ribosomes",
        "Species Specificity" ;
    schema1:license "The software is freely available for academic use" ;
    schema1:name "metagene_annotator" ;
    schema1:url "http://metagene.nig.ac.jp/" .

