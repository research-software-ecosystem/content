@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:ngscheckmate a schema1:SoftwareApplication ;
    schema1:description "Software package for identifying next generation sequencing (NGS) data files from the same individual." ;
    schema1:downloadUrl "https://github.com/parklab/NGSCheckMate/archive/ef7a38c51dadbd4ef5b6b6db60775f239926f0a8.zip" ;
    schema1:identifier biotools:ngscheckmate ;
    schema1:license "MIT" ;
    schema1:name "ngscheckmate" ;
    schema1:softwareHelp "https://github.com/parklab/NGSCheckMate/blob/master/Documentation.pdf" ;
    schema1:softwareVersion "1.0.1" ;
    schema1:url "https://github.com/parklab/NGSCheckMate" ;
    spdx:builtFrom biotools:ngscheckmate .

