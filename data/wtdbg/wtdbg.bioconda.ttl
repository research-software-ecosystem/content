@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:wtdbg a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/s41592-019-0669-3" ;
    schema1:description "Wtdbg2: A fuzzy Bruijn graph approach to long noisy reads assembly." ;
    schema1:downloadUrl "https://github.com/ruanjue/wtdbg2/archive/v2.5.tar.gz" ;
    schema1:identifier biotools:wtdbg2 ;
    schema1:license "GPL-3.0-or-later" ;
    schema1:name "wtdbg" ;
    schema1:softwareHelp "https://github.com/ruanjue/wtdbg2/blob/v2.5/README.md" ;
    schema1:softwareVersion "2.5" ;
    schema1:url "https://github.com/ruanjue/wtdbg2" ;
    spdx:builtFrom biotools:wtdbg2 .

