@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-ctsge a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btx116" ;
    schema1:description "Clustering of Time Series Gene Expression data" ;
    schema1:identifier biotools:ctsge ;
    schema1:keywords "Adenocarcinoma",
        "Cluster Analysis",
        "Clustering",
        "Gene Expression",
        "Gene Expression Profiling",
        "Gene Expression Regulation, Neoplastic",
        "Gene expression",
        "Genetics",
        "Humans",
        "Molecular genetics",
        "Sequence Analysis, RNA" ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-ctsge" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/ctsGE.html" .

