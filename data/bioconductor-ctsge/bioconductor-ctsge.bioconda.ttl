@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-ctsge a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btx116" ;
    schema1:description "Clustering of Time Series Gene Expression data" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/ctsGE_1.32.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/ctsGE/ctsGE_1.32.0.tar.gz', 'https://bioarchive.galaxyproject.org/ctsGE_1.32.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-ctsge/bioconductor-ctsge_1.32.0_src_all.tar.gz']" ;
    schema1:identifier biotools:ctsge ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-ctsge" ;
    schema1:softwareVersion "1.32.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/ctsGE.html" ;
    spdx:builtFrom biotools:ctsge .

