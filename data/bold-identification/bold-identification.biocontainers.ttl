@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bold-identification a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s12864-020-07255-w" ;
    schema1:description "A tool for taxonomic assignment for given sequences using the bold database (http://www.boldsystems.org/index.php)" ;
    schema1:identifier biotools:bold-identification ;
    schema1:license "GPL-3.0" ;
    schema1:name "bold-identification" ;
    schema1:url "https://github.com/linzhi2013/bold_identification" .

