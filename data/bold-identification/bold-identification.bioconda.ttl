@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bold-identification a schema1:SoftwareApplication ;
    schema1:author "linzhi2013" ;
    schema1:description "A tool for taxonomic assignment for given sequences using the BOLD database (http://www.boldsystems.org/index.php)" ;
    schema1:downloadUrl "https://github.com/linzhi2013/bold_identification/archive/v0.0.27.tar.gz" ;
    schema1:identifier biotools:bold-identification ;
    schema1:license "GNU General Public v3 or later (GPLv3+)" ;
    schema1:maintainer "linzhi2013" ;
    schema1:name "bold-identification" ;
    schema1:softwareVersion "0.0.27" ;
    schema1:url "https://github.com/linzhi2013/bold_identification" ;
    spdx:builtFrom biotools:bold-identification .

