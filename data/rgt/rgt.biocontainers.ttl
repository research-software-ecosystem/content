@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:rgt a schema1:SoftwareApplication ;
    schema1:description "Toolkit to perform regulatory genomics data analysis" ;
    schema1:keywords "Genomics",
        "Transcription Factors" ;
    schema1:license "GPL" ;
    schema1:name "rgt" ;
    schema1:url "http://www.regulatory-genomics.org" .

