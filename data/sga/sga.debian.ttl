@prefix debianmed: <https://salsa.debian.org/med-team/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

debianmed:sga a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1101/gr.126953.111" ;
    schema1:description "de novo genome assembler that uses string graphs" ;
    schema1:identifier "bio.tools:SGA",
        "conda:bioconda:sga",
        "omictools:OMICS_00028",
        "scicrunch:SCR_001982" ;
    schema1:license "unknown" ;
    schema1:name "sga" ;
    schema1:softwareVersion "0.10.15" ;
    schema1:url "https://github.com/jts/sga" ;
    spdx:builtFrom "SGA" .

