@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:sga a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/bti1114" ;
    schema1:description "Sga is a de novo assembler designed to assemble large genomes from high coverage short read data." ;
    schema1:identifier biotools:sga ;
    schema1:keywords "Base Sequence",
        "Chromosome Mapping",
        "DNA Fragmentation",
        "Genomics",
        "Molecular Sequence Data",
        "Sequence Analysis, DNA",
        "Sequence assembly",
        "Whole genome sequencing" ;
    schema1:license "GPL-3.0" ;
    schema1:name "sga" ;
    schema1:url "https://github.com/jts/sga" .

