@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:sga a schema1:SoftwareApplication ;
    schema1:description "SGA - String Graph Assembler. SGA is a de novo assembler for DNA sequence reads. It is based on Gene Myers string graph formulation of assembly and uses the FM-index/Burrows-Wheeler transform to efficiently find overlaps between sequence reads." ;
    schema1:downloadUrl "https://github.com/jts/sga/archive/v0.10.15.tar.gz" ;
    schema1:identifier biotools:sga ;
    schema1:license "GPL-3.0-or-later" ;
    schema1:name "sga" ;
    schema1:softwareVersion "0.10.15" ;
    schema1:url "https://github.com/jts/sga" ;
    spdx:builtFrom biotools:sga .

