    schema1:identifier biotools:magneto ;
    schema1:license "GPL-3.0-only" ;
    schema1:name "magneto" ;
    schema1:softwareHelp "https://gitlab.univ-nantes.fr/bird_pipeline_registry/magneto/-/wikis/home" ;
    schema1:softwareVersion "1.5.2" ;
    schema1:url "https://gitlab.univ-nantes.fr/bird_pipeline_registry/magneto" ;
    spdx:builtFrom biotools:magneto .

