@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:eastr a schema1:SoftwareApplication ;
    schema1:author "coperni",
        "ishinder" ;
    schema1:citation "doi:10.1038/s41467-023-43017-4" ;
    schema1:description "Tool for emending alignments of spuriously spliced transcript reads." ;
    schema1:downloadUrl "https://pypi.io/packages/source/e/eastr/eastr-1.1.2.tar.gz" ;
    schema1:identifier biotools:eastr ;
    schema1:license "MIT" ;
    schema1:maintainer "coperni",
        "ishinder" ;
    schema1:name "eastr" ;
    schema1:softwareHelp "https://ccb.jhu.edu/eastr/#usage" ;
    schema1:softwareVersion "1.1.2" ;
    schema1:url "https://ccb.jhu.edu/eastr" ;
    spdx:builtFrom biotools:eastr .

