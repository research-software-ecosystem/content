@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:orthanc-mysql a schema1:SoftwareApplication ;
    schema1:description "Plugins to use mysql or mariadb as a database back-end to orthanc" ;
    schema1:license "AGPL-3" ;
    schema1:name "orthanc-mysql" ;
    schema1:url "https://www.orthanc-server.com/static.php?page=mysql" .

