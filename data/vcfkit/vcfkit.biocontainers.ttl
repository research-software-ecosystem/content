@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:vcfkit a schema1:SoftwareApplication ;
    schema1:description "VCF-kit is a command-line based collection of utilities for performing analysis on Variant Call Format (VCF) files." ;
    schema1:license "MIT" ;
    schema1:name "vcfkit" ;
    schema1:url "https://github.com/AndersenLab/VCF-kit" .

