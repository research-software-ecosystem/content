@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:variant_tools a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1101/027227" ;
    schema1:description "Integrated annotation and analysis of next gen sequencing data" ;
    schema1:identifier biotools:varianttools ;
    schema1:keywords "Genetic variation",
        "Genomics" ;
    schema1:license "GNU General Public License (GPL)" ;
    schema1:name "variant_tools" ;
    schema1:url "https://github.com/vatlab/varianttools" .

