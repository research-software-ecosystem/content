@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-qpgraph a schema1:SoftwareApplication ;
    schema1:description "Estimation of Genetic and Molecular Regulatory Networks from High-Throughput Genomics Data" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/qpgraph_2.44.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/qpgraph/qpgraph_2.44.0.tar.gz', 'https://bioarchive.galaxyproject.org/qpgraph_2.44.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-qpgraph/bioconductor-qpgraph_2.44.0_src_all.tar.gz']" ;
    schema1:identifier biotools:qpgraph ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-qpgraph" ;
    schema1:softwareVersion "2.44.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/qpgraph.html" ;
    spdx:builtFrom biotools:qpgraph .

