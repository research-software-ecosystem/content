@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-qpgraph a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1534/genetics.114.169573" ;
    schema1:description "Estimation of genetic and molecular regulatory networks from high-throughput genomics data" ;
    schema1:identifier biotools:qpgraph ;
    schema1:keywords "Chromosome Mapping",
        "Crosses, Genetic",
        "DNA polymorphism",
        "Gene Expression Regulation, Fungal",
        "Gene Regulatory Networks",
        "Gene expression",
        "Genetics",
        "Genomics",
        "Markov Chains",
        "Microarray experiment",
        "Models, Genetic",
        "Quantitative Trait Loci",
        "Reproducibility of Results",
        "Transcriptomics",
        "Yeasts" ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-qpgraph" ;
    schema1:url "http://bioconductor.org/packages/3.6/bioc/html/qpgraph.html" .

