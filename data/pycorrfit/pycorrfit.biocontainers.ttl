@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:pycorrfit a schema1:SoftwareApplication ;
    schema1:description "Tool for fitting correlation curves on a logarithmic plot" ;
    schema1:license "GPL-2+" ;
    schema1:name "pycorrfit" ;
    schema1:url "http://fcs-analysis.github.io/PyCorrFit/" .

