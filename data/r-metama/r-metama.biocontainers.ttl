@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-metama a schema1:SoftwareApplication ;
    schema1:description "Combines either p-values or modified effect sizes from different studies to find differentially expressed genes" ;
    schema1:license "GPL" ;
    schema1:name "r-metama" ;
    schema1:url "https://CRAN.R-project.org/package=metaMA" .

