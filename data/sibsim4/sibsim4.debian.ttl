        "implemented-in::c",
        "interface::commandline",
        "role::program",
        "scope::utility",
        "use::TODO",
        "use::comparing",
        "use::searching",
        "works-with-format::TODO",
        "works-with-format::plaintext",
        "works-with::TODO" ;
    schema1:license "unknown" ;
    schema1:name "sibsim4" ;
    schema1:softwareVersion "0.20" ;
    schema1:url "http://sibsim4.sourceforge.net/" ;
    spdx:builtFrom "SIBsim4" .

