@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:sibsim4 a schema1:SoftwareApplication ;
    schema1:description "Sibsim4 is a modified version of the sim4 program, which is a similarity-based tool for spliced alignments, i.e. for aligning an expressed dna sequence (est, mrna) with a genomic sequence." ;
    schema1:identifier biotools:sibsim4 ;
    schema1:keywords "Genomics",
        "RNA-Seq",
        "Transcriptome",
        "Transcriptomics" ;
    schema1:license "GPL-2+" ;
    schema1:name "sibsim4" ;
    schema1:url "https://sourceforge.net/projects/sibsim4/" .

