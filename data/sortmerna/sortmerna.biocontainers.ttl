@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:sortmerna a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/bts611" ;
    schema1:description "Sequence analysis tool for filtering, mapping and otu-picking ngs reads." ;
    schema1:identifier biotools:sortmerna ;
    schema1:keywords "Clustering",
        "Ecosystem",
        "Gene Expression Profiling",
        "Genomics",
        "Phylogeny",
        "RNA, Messenger",
        "RNA, Ribosomal",
        "RNA, Ribosomal, 16S",
        "Sequence Analysis, RNA",
        "Transcriptomics" ;
    schema1:license "LGPL" ;
    schema1:name "sortmerna" ;
    schema1:url "http://bioinfo.lifl.fr/RNA/sortmerna/" .

