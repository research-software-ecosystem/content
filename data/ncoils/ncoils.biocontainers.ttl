@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:ncoils a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1126/science.252.5009.1162" ;
    schema1:description "Program that compares a sequence to a database of known parallel two-stranded coiled-coils and derives a similarity score. by comparing this score to the distribution of scores in globular and coiled-coil proteins, the program then calculates the probability that the sequence will adopt a coiled-coil conformation." ;
    schema1:identifier biotools:ncoils ;
    schema1:keywords "Amino Acid Sequence",
        "Amino Acids",
        "Animals",
        "Databases, Factual",
        "Humans",
        "Probability",
        "Protein Conformation",
        "Protein Sequences",
        "Protein secondary structure",
        "Proteins" ;
    schema1:license "GPL-2" ;
    schema1:name "ncoils" ;
    schema1:url "https://embnet.vital-it.ch/software/COILS_form.html" .

