@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-acde a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1007/978-0-387-49317-6_9" ;
    schema1:description "Artificial Components Detection of Differentially Expressed Genes" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/acde_1.40.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/acde/acde_1.40.0.tar.gz', 'https://bioarchive.galaxyproject.org/acde_1.40.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-acde/bioconductor-acde_1.40.0_src_all.tar.gz']" ;
    schema1:identifier biotools:acde ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-acde" ;
    schema1:softwareVersion "1.40.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/acde.html" ;
    spdx:builtFrom biotools:acde .

