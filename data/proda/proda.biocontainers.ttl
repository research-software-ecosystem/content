@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:proda a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/gkl511" ;
    schema1:description "Protein multiple aligner that automatically finds domain structures of sequences with shuffled and repeated domain architectures." ;
    schema1:identifier biotools:proda ;
    schema1:keywords "Computational Biology",
        "Internet",
        "Protein Sequences",
        "Protein Structure, Tertiary",
        "Protein folds and structural domains",
        "Protein structure analysis",
        "Repetitive Sequences, Amino Acid",
        "Reproducibility of Results",
        "Sequence Alignment",
        "Sequence Analysis, Protein",
        "Sequence analysis" ;
    schema1:license "PD" ;
    schema1:name "proda" ;
    schema1:url "http://proda.stanford.edu/" .

