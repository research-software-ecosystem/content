@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-massir a schema1:SoftwareApplication ;
    schema1:description "massiR: MicroArray Sample Sex Identifier" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/massiR_1.46.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/massiR/massiR_1.46.0.tar.gz', 'https://bioarchive.galaxyproject.org/massiR_1.46.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-massir/bioconductor-massir_1.46.0_src_all.tar.gz']" ;
    schema1:identifier biotools:massir ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-massir" ;
    schema1:softwareVersion "1.46.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/massiR.html" ;
    spdx:builtFrom biotools:massir .

