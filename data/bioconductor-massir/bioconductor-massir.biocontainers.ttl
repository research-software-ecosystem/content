    schema1:keywords "Cluster Analysis",
        "Clustering",
        "Data visualisation",
        "Female",
        "Gene Expression",
        "Gene Expression Profiling",
        "Gene expression",
        "Humans",
        "Male",
        "Oligonucleotide Array Sequence Analysis" ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-massir" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/massiR.html" .

