  "@id": "https://bio.tools/4d-bioreconx",
  "@type": "sc:SoftwareApplication",
  "dcterms:conformsTo": "https://bioschemas.org/profiles/ComputationalTool/0.6-DRAFT",
  "sc:description": "4D-BioReconX: a bioinformatic framework for reconstructing 4D spatial transcriptomics atlas and spatiotemporal analyses+\n4D-BioReconX is a scalable and versatile framework designed to construct a comprehensive four-dimensional (4D) spatial transcriptomics atlas of whole animals at single-cell resolution. This approach enables us to track the intricate spatiotemporal dependencies of morphogenetic gradients and regenerative patterning. It runs based on spatial transcriptomics data, such as Stereo-seq (spatial enhanced resolution omics sequencing) data. Notably, we are still working on the improvement of performance and calculation efficiency.",
  "sc:name": "4D-BioReconX",
  "sc:softwareVersion": "v0.1",
  "sc:url": "https://github.com/BGI-Qingdao/4D-BioReconX"
}