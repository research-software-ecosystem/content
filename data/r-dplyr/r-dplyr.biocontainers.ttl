@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-dplyr a schema1:SoftwareApplication ;
    schema1:description "A fast, consistent tool for working with data frame like objects, both in memory and out of memory." ;
    schema1:keywords "Clustering",
        "Genomics",
        "Metagenome",
        "Proteomics",
        "Transcriptome" ;
    schema1:license "MIT" ;
    schema1:name "r-dplyr" ;
    schema1:url "https://cran.r-project.org/package=dplyr" .

