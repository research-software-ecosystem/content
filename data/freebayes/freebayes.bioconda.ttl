@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:freebayes a schema1:SoftwareApplication ;
    schema1:author "jpuritz",
        "mencian" ;
    schema1:citation "doi:10.48550/arXiv.1207.3907" ;
    schema1:description "Bayesian haplotype-based polymorphism discovery and genotyping." ;
    schema1:downloadUrl "https://github.com/freebayes/freebayes/releases/download/v1.3.10/freebayes-1.3.10-src.tar.gz",
        "https://github.com/vcflib/multichoose/archive/255192edd49cfe36557f7f4f0d2d6ee1c702ffbb.tar.gz" ;
    schema1:identifier biotools:freebayes ;
    schema1:license "MIT" ;
    schema1:maintainer "jpuritz",
        "mencian" ;
    schema1:name "freebayes" ;
    schema1:softwareHelp "https://github.com/freebayes/freebayes/blob/v1.3.10/README.md" ;
    schema1:softwareVersion "1.3.10" ;
    schema1:url "https://github.com/freebayes/freebayes" ;
    spdx:builtFrom biotools:freebayes .

