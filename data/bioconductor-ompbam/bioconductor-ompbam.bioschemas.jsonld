  "@graph": [
    {
      "@id": "https://bio.tools/bioconductor-ompbam",
      "@type": "sc:SoftwareApplication",
      "dcterms:conformsTo": "https://bioschemas.org/profiles/ComputationalTool/0.6-DRAFT",
      "sc:additionalType": [
        "Command-line tool",
        "Library"
      ],
      "sc:author": "Alex Chit Hei Wong",
      "sc:citation": {
        "@id": "https://doi.org/10.18129/B9.bioc.ompBAM"
      },
      "sc:description": "This packages provides C++ header files for developers wishing to create R packages that processes BAM files. ompBAM automates file access, memory management, and handling of multiple threads 'behind the scenes', so developers can focus on creating domain-specific functionality. The included vignette contains detailed documentation of this API, including quick-start instructions to create a new ompBAM-based package, and step-by-step explanation of the functionality behind the example packaged included within ompBAM.",
      "sc:license": "MIT",
      "sc:name": "ompBAM",
      "sc:operatingSystem": [
        "Linux",
        "Mac",
        "Windows"
      ],
