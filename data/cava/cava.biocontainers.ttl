@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:cava a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s13073-015-0195-6" ;
    schema1:description "Lightweight, fast and flexible ngs variant annotation tool" ;
    schema1:keywords "BRCA1 Protein",
        "BRCA2 Protein",
        "Computational Biology",
        "Exome",
        "High-Throughput Nucleotide Sequencing",
        "Humans",
        "Molecular Sequence Annotation",
        "Mutation",
        "Sequence Analysis, DNA" ;
    schema1:license "GPL-3.0" ;
    schema1:name "cava" ;
    schema1:url "http://www.well.ox.ac.uk/cava" .

