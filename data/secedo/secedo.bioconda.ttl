@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:secedo a schema1:SoftwareApplication ;
    schema1:description "SNV-based clustering for single-cell sequencing data." ;
    schema1:downloadUrl "https://github.com/ratschlab/secedo/archive/refs/tags/v1.0.7.tar.gz" ;
    schema1:identifier biotools:secedo ;
    schema1:license "MIT" ;
    schema1:name "secedo" ;
    schema1:softwareVersion "1.0.7" ;
    schema1:url "https://github.com/ratschlab/secedo" ;
    spdx:builtFrom biotools:secedo .

