@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:ataqv a schema1:SoftwareApplication ;
    schema1:description "ataqv is a toolkit for measuring and comparing ATAC-seq results. It was written to help understand how well ATAC-seq assays have worked, and to make it easier to spot differences that might be caused by library prep or sequencing." ;
    schema1:license "GPL-3.0" ;
    schema1:name "ataqv" ;
    schema1:url "https://parkerlab.github.io/ataqv/" .

