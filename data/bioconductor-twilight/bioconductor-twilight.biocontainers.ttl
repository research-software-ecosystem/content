@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-twilight a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/bti436" ;
    schema1:description "Estimation of local false discovery rate" ;
    schema1:identifier biotools:twilight ;
    schema1:keywords "Computer Graphics",
        "Computer Simulation",
        "False Positive Reactions",
        "Gene Expression",
        "Gene Expression Profiling",
        "Gene expression",
        "Microarray experiment",
        "Models, Genetic",
        "Models, Statistical",
        "Oligonucleotide Array Sequence Analysis",
        "Statistics and probability",
        "User-Computer Interface" ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-twilight" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/twilight.html" .

