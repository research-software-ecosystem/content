@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:stringtie a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nbt.3122",
        "doi:10.1038/nprot.2016.095",
        "doi:10.1186/s13059-019-1910-1" ;
    schema1:description "StringTie employs efficient algorithms for transcript structure recovery and abundance estimation from bulk RNA-Seq reads aligned to a reference genome." ;
    schema1:downloadUrl "https://github.com/gpertea/stringtie/releases/download/v3.0.3/stringtie-3.0.3.tar.gz" ;
    schema1:identifier biotools:stringtie ;
    schema1:license "MIT" ;
    schema1:name "stringtie" ;
    schema1:softwareHelp "https://ccb.jhu.edu/software/stringtie/index.shtml?t=manual" ;
    schema1:softwareVersion "3.0.3" ;
    schema1:url "https://ccb.jhu.edu/software/stringtie" ;
    spdx:builtFrom biotools:stringtie .

