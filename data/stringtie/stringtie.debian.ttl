@prefix debianmed: <https://salsa.debian.org/med-team/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

debianmed:stringtie a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nbt.3122",
        "doi:10.1038/nprot.2016.095" ;
    schema1:description "assemble short RNAseq reads to transcripts" ;
    schema1:identifier "bio.tools:stringtie",
        "conda:bioconda:stringtie",
        "omictools:OMICS_07226",
        "scicrunch:SCR_016323" ;
    schema1:license "unknown" ;
    schema1:name "stringtie" ;
    schema1:softwareVersion "3.0.3+ds" ;
    schema1:url "https://ccb.jhu.edu/software/stringtie/" ;
    spdx:builtFrom "stringtie" .

