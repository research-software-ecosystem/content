@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:stringtie a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nbt.3122",
        "doi:10.1038/nprot.2016.095",
        "doi:10.1186/s13059-019-1910-1" ;
    schema1:description "Transcriptome assembly and quantification for rna-seq" ;
    schema1:identifier biotools:StringTie ;
    schema1:keywords "Animals",
        "Arabidopsis",
        "Genetic Techniques",
        "Genomics",
        "Humans",
        "RNA-Seq",
        "RNA-seq",
        "Sequence Analysis, RNA",
        "Transcriptome",
        "Transcriptomics",
        "Zea mays" ;
    schema1:license "MIT" ;
    schema1:name "stringtie" ;
    schema1:url "https://github.com/gpertea/stringtie" .

