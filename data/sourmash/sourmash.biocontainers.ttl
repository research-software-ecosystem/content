@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:sourmash a schema1:SoftwareApplication ;
    schema1:citation "doi:10.12688/f1000research.19675.1",
        "doi:10.21105/joss.00027" ;
    schema1:description "Compute and compare minhash signatures for dna data sets." ;
    schema1:identifier biotools:sourmash ;
    schema1:keywords "Computational biology",
        "Databases, Factual",
        "Genome" ;
    schema1:license "BSD-3-Clause" ;
    schema1:name "sourmash" ;
    schema1:url "https://github.com/dib-lab/sourmash" .

