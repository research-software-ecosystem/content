@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:sourmash a schema1:SoftwareApplication ;
    schema1:author "bluegenes",
        "ctb",
        "luizirber" ;
    schema1:citation "doi:10.12688/f1000research.19675.1",
        "doi:10.21105/joss.00027",
        "doi:10.5281/zenodo.11557883" ;
    schema1:description "Quickly search, compare, and analyze genomic and metagenomic data sets." ;
    schema1:downloadUrl "https://pypi.io/packages/source/s/sourmash/sourmash-4.9.4.tar.gz" ;
    schema1:identifier biotools:sourmash ;
    schema1:license "BSD-3-Clause" ;
    schema1:maintainer "bluegenes",
        "ctb",
        "luizirber" ;
    schema1:name "sourmash" ;
    schema1:softwareHelp "https://sourmash.readthedocs.io/" ;
    schema1:softwareVersion "4.9.4" ;
    schema1:url "https://github.com/sourmash-bio/sourmash" ;
    spdx:builtFrom biotools:sourmash .

