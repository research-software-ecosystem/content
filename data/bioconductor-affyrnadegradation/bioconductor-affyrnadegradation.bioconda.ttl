@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-affyrnadegradation a schema1:SoftwareApplication ;
    schema1:description "Analyze and correct probe positional bias in microarray data due to RNA degradation" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/AffyRNADegradation_1.56.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/AffyRNADegradation/AffyRNADegradation_1.56.0.tar.gz', 'https://bioarchive.galaxyproject.org/AffyRNADegradation_1.56.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-affyrnadegradation/bioconductor-affyrnadegradation_1.56.0_src_all.tar.gz']" ;
    schema1:identifier biotools:affyrnadegradation ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-affyrnadegradation" ;
    schema1:softwareVersion "1.56.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/AffyRNADegradation.html" ;
    spdx:builtFrom biotools:affyrnadegradation .

