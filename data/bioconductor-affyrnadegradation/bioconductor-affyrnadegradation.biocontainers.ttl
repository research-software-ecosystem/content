@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-affyrnadegradation a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/bts629" ;
    schema1:description "Analyze and correct probe positional bias in microarray data due to RNA degradation" ;
    schema1:identifier biotools:affyrnadegradation ;
    schema1:keywords "Data quality management",
        "Gene Expression Profiling",
        "Humans",
        "Microarray experiment",
        "Oligonucleotide Array Sequence Analysis",
        "RNA",
        "RNA Stability",
        "RNA, Messenger" ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-affyrnadegradation" ;
    schema1:url "https://bioconductor.org/packages/release/bioc/html/AffyRNADegradation.html" .

