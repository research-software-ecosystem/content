@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:ifeature a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/bty140" ;
    schema1:description "A python package for feature extraction and selection from protein and peptide sequences" ;
    schema1:identifier biotools:ifeature ;
    schema1:keywords "Machine Learning",
        "Molecular Sequence Annotation",
        "Peptides",
        "Protein Conformation",
        "Protein properties",
        "Protein structure analysis",
        "Proteins",
        "Sequence Analysis, Protein" ;
    schema1:license "Not available" ;
    schema1:name "ifeature" ;
    schema1:url "https://github.com/Jie-Yuan/iFeature" .

