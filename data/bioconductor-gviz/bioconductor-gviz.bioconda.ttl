@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-gviz a schema1:SoftwareApplication ;
    schema1:description "Plotting data and annotation information along genomic coordinates" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/Gviz_1.50.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/Gviz/Gviz_1.50.0.tar.gz', 'https://bioarchive.galaxyproject.org/Gviz_1.50.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-gviz/bioconductor-gviz_1.50.0_src_all.tar.gz']" ;
    schema1:identifier biotools:gviz ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-gviz" ;
    schema1:softwareVersion "1.50.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/Gviz.html" ;
    spdx:builtFrom biotools:gviz .

