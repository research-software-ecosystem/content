@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-bcrank a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/gkp381" ;
    schema1:description "Predicting binding site consensus from ranked DNA sequences" ;
    schema1:identifier biotools:bcrank ;
    schema1:keywords "Alleles",
        "Binding Sites",
        "Chromatin Immunoprecipitation",
        "Genotype",
        "Humans",
        "Oligonucleotide Array Sequence Analysis",
        "Polymorphism, Single Nucleotide",
        "Regulatory Elements, Transcriptional",
        "Sequence Analysis, DNA",
        "Transcription Factors",
        "Transcription factors and regulatory sites",
        "Transcription, Genetic",
        "Upstream Stimulatory Factors" ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-bcrank" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/BCRANK.html" .

