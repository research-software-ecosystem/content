@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-bcrank a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/gkp381" ;
    schema1:description "Predicting binding site consensus from ranked DNA sequences" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/BCRANK_1.68.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/BCRANK/BCRANK_1.68.0.tar.gz', 'https://bioarchive.galaxyproject.org/BCRANK_1.68.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-bcrank/bioconductor-bcrank_1.68.0_src_all.tar.gz']" ;
    schema1:identifier biotools:bcrank ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-bcrank" ;
    schema1:softwareVersion "1.68.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/BCRANK.html" ;
    spdx:builtFrom biotools:bcrank .

