@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:wgs-assembler a schema1:SoftwareApplication ;
    schema1:description "Celera Assembler (wgs-assembler) is a de novo whole-genome shotgun (WGS) DNA sequence assembler" ;
    schema1:license "MIT" ;
    schema1:name "wgs-assembler" ;
    schema1:url "http://wgs-assembler.sourceforge.net/" .

