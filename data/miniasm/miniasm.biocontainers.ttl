@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:miniasm a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btw152" ;
    schema1:description "Ultrafast de novo assembler for long noisy dna sequencing reads" ;
    schema1:keywords "Animals",
        "Bacteria",
        "Caenorhabditis elegans",
        "Chromosome Mapping",
        "Computational Biology",
        "Genomics",
        "High-Throughput Nucleotide Sequencing",
        "Humans",
        "Sequence Analysis, DNA" ;
    schema1:license "MIT" ;
    schema1:name "miniasm" ;
    schema1:url "https://github.com/lh3/miniasm" .

