@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:miniasm a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btw152" ;
    schema1:description "Ultrafast de novo assembly for long noisy reads (though having no consensus step)." ;
    schema1:downloadUrl "https://github.com/lh3/miniasm/archive/refs/tags/v0.3.tar.gz" ;
    schema1:identifier biotools:miniasm ;
    schema1:license "MIT" ;
    schema1:name "miniasm" ;
    schema1:softwareHelp "https://github.com/lh3/miniasm/blob/v0.3/README.md" ;
    schema1:softwareVersion "0.3" ;
    schema1:url "https://github.com/lh3/miniasm" ;
    spdx:builtFrom biotools:miniasm .

