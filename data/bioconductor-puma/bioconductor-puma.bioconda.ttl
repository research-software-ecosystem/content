@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-puma a schema1:SoftwareApplication ;
    schema1:description "Propagating Uncertainty in Microarray Analysis(including Affymetrix tranditional 3' arrays and exon arrays and Human Transcriptome Array 2.0)" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/puma_3.48.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/puma/puma_3.48.0.tar.gz', 'https://bioarchive.galaxyproject.org/puma_3.48.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-puma/bioconductor-puma_3.48.0_src_all.tar.gz']" ;
    schema1:identifier biotools:puma ;
    schema1:license "LGPL" ;
    schema1:name "bioconductor-puma" ;
    schema1:softwareVersion "3.48.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/puma.html" ;
    spdx:builtFrom biotools:puma .

