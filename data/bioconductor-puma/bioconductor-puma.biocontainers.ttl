@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-puma a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/1471-2105-14-39" ;
    schema1:description "Propagating Uncertainty in Microarray Analysis(including Affymetrix tranditional 3' arrays and exon arrays and Human Transcriptome Array 2.0)" ;
    schema1:identifier biotools:puma ;
    schema1:keywords "Carcinoma, Squamous Cell",
        "Cluster Analysis",
        "Clustering",
        "Exons",
        "Gene Expression",
        "Gene Expression Profiling",
        "Gene expression",
        "Genomics",
        "Head and Neck Neoplasms",
        "Humans",
        "Oligonucleotide Array Sequence Analysis",
        "RNA Isoforms",
        "RNA splicing",
        "Squamous Cell Carcinoma of Head and Neck",
        "Transcriptome",
        "Uncertainty" ;
    schema1:license "LGPL" ;
    schema1:name "bioconductor-puma" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/puma.html" .

