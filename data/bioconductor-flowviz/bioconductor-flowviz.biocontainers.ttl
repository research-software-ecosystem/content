@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-flowviz a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btn021" ;
    schema1:description "Provides visualization tools for flow cytometry data." ;
    schema1:identifier biotools:flowviz ;
    schema1:keywords "Biophysics",
        "Computer Graphics",
        "Data visualisation",
        "Database Management Systems",
        "Databases, Factual",
        "Flow Cytometry",
        "User-Computer Interface" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-flowviz" ;
    schema1:url "http://bioconductor.org/packages/release/bioc/html/flowViz.html" .

