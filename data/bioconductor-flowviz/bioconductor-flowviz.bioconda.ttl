@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-flowviz a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btn021" ;
    schema1:description "Visualization for flow cytometry" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/flowViz_1.70.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/flowViz/flowViz_1.70.0.tar.gz', 'https://bioarchive.galaxyproject.org/flowViz_1.70.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-flowviz/bioconductor-flowviz_1.70.0_src_all.tar.gz']" ;
    schema1:identifier biotools:flowviz ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-flowviz" ;
    schema1:softwareVersion "1.70.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/flowViz.html" ;
    spdx:builtFrom biotools:flowviz .

