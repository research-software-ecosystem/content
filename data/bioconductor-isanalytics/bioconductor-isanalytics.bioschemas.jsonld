    {
      "@id": "https://bio.tools/bioconductor-isanalytics",
      "@type": "sc:SoftwareApplication",
      "dcterms:conformsTo": "https://bioschemas.org/profiles/ComputationalTool/0.6-DRAFT",
      "sc:additionalType": [
        "Command-line tool",
        "Library"
      ],
      "sc:author": [
        "Giulia Pais",
        "Giulio Spinozzi",
        "Andrea Calabria"
      ],
      "sc:citation": [
        {
          "@id": "https://doi.org/10.18129/B9.bioc.ISAnalytics"
        },
        {
          "@id": "https://doi.org/10.1093/bib/bbac551"
        }
      ],
      "sc:description": "In gene therapy, stem cells are modified using viral vectors to deliver the therapeutic transgene and replace functional properties since the genetic modification is stable and inherited in all cell progeny. The retrieval and mapping of the sequences flanking the virus-host DNA junctions allows the identification of insertion sites (IS), essential for monitoring the evolution of genetically modified cells in vivo. A comprehensive toolkit for the analysis of IS is required to foster clonal trackign studies and supporting the assessment of safety and long term efficacy in vivo. This package is aimed at (1) supporting automation of IS workflow, (2) performing base and advance analysis for IS tracking (clonal abundance, clonal expansions and statistics for insertional mutagenesis, etc.), (3) providing basic biology insights of transduced stem cells in vivo.",
      "sc:license": "CC-BY-4.0",
      "sc:name": "ISAnalytics",
      "sc:operatingSystem": [
        "Linux",
        "Windows",
        "Mac"
      ],
      "sc:softwareHelp": {
        "@id": "https://bioconductor.org/packages/ISAnalytics"
      },
      "sc:softwareVersion": "1.20.1",
      "sc:url": "https://bioconductor.org/packages/ISAnalytics"
    },
    {
      "@id": "https://doi.org/10.18129/B9.bioc.ISAnalytics",
      "@type": "sc:CreativeWork"
    }
