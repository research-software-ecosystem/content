@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-isanalytics a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18129/b9.bioc.isanalytics" ;
    schema1:description "Analyze gene therapy vector insertion sites data identified from genomics next generation sequencing reads for clonal tracking studies" ;
    schema1:keywords "Genomics" ;
    schema1:license "Not available" ;
    schema1:name "bioconductor-isanalytics" ;
    schema1:url "https://bioconductor.org/packages/3.12/bioc/html/ISAnalytics.html" .

