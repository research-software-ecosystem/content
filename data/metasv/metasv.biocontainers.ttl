@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:metasv a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btv204" ;
    schema1:description "An accurate and integrative structural-variant caller for next generation sequencing" ;
    schema1:identifier biotools:metasv ;
    schema1:keywords "Genetic Variation",
        "High-Throughput Nucleotide Sequencing",
        "Mutagenesis, Insertional",
        "Sequence Deletion",
        "Sequencing",
        "Structure analysis" ;
    schema1:license "MIT" ;
    schema1:name "metasv" ;
    schema1:url "https://github.com/bioinform/metasv" .

