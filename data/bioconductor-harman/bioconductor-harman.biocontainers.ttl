@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-harman a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s12859-016-1212-5" ;
    schema1:description "The removal of batch effects from datasets using a PCA and constrained optimisation based technique" ;
    schema1:identifier biotools:harman ;
    schema1:keywords "Data quality management",
        "Genomics",
        "Humans",
        "Information Storage and Retrieval",
        "Principal Component Analysis",
        "Sequence Analysis, RNA",
        "Statistics and probability" ;
    schema1:license "GPL-3 + file LICENCE" ;
    schema1:name "bioconductor-harman" ;
    schema1:url "http://bioconductor.org/packages/3.6/bioc/html/Harman.html" .

