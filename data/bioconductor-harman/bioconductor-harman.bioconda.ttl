@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-harman a schema1:SoftwareApplication ;
    schema1:description "The removal of batch effects from datasets using a PCA and constrained optimisation based technique" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/Harman_1.34.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/Harman/Harman_1.34.0.tar.gz', 'https://bioarchive.galaxyproject.org/Harman_1.34.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-harman/bioconductor-harman_1.34.0_src_all.tar.gz']" ;
    schema1:identifier biotools:harman ;
    schema1:license "GPL-3 + file LICENCE" ;
    schema1:name "bioconductor-harman" ;
    schema1:softwareVersion "1.34.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/Harman.html" ;
    spdx:builtFrom biotools:harman .

