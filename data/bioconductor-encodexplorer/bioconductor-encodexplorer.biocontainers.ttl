@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-encodexplorer a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "This package allows user to quickly access encode project files metadata and give access to helper functions to query the encode rest api, download encode datasets and save the database in sqlite format." ;
    schema1:identifier biotools:encodexplorer ;
    schema1:keywords "Computational Biology",
        "Data management",
        "Gene Expression Profiling",
        "Genomics",
        "High-Throughput Screening Assays",
        "Programming Languages",
        "User-Computer Interface" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-encodexplorer" ;
    schema1:url "http://bioconductor.org/packages/release/bioc/html/ENCODExplorer.html" .

