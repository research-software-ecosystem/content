@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-vanillaice a schema1:SoftwareApplication ;
    schema1:description "A Hidden Markov Model for high throughput genotyping arrays" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/VanillaICE_1.68.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/VanillaICE/VanillaICE_1.68.0.tar.gz', 'https://bioarchive.galaxyproject.org/VanillaICE_1.68.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-vanillaice/bioconductor-vanillaice_1.68.0_src_all.tar.gz']" ;
    schema1:identifier biotools:vanillaice ;
    schema1:license "LGPL-2" ;
    schema1:name "bioconductor-vanillaice" ;
    schema1:softwareVersion "1.68.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/VanillaICE.html" ;
    spdx:builtFrom biotools:vanillaice .

