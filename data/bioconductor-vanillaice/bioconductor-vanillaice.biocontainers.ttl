@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-vanillaice a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1214/07-AOAS155" ;
    schema1:description "A Hidden Markov Model for high throughput genotyping arrays" ;
    schema1:identifier biotools:vanillaice ;
    schema1:keywords "Applied mathematics",
        "DNA structural variation",
        "Genomics",
        "Microarray experiment" ;
    schema1:license "LGPL-2" ;
    schema1:name "bioconductor-vanillaice" ;
    schema1:url "http://bioconductor.org/packages/3.6/bioc/html/VanillaICE.html" .

