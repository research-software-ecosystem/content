@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-nucleosim a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1515/sagmb-2014-0098" ;
    schema1:description "Generate synthetic nucleosome maps" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/nucleoSim_1.34.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/nucleoSim/nucleoSim_1.34.0.tar.gz', 'https://bioarchive.galaxyproject.org/nucleoSim_1.34.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-nucleosim/bioconductor-nucleosim_1.34.0_src_all.tar.gz']" ;
    schema1:identifier biotools:nucleosim ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-nucleosim" ;
    schema1:softwareVersion "1.34.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/nucleoSim.html" ;
    spdx:builtFrom biotools:nucleosim .

