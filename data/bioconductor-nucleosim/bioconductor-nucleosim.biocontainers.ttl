@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-nucleosim a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1515/sagmb-2014-0098" ;
    schema1:description "Generate synthetic nucleosome maps" ;
    schema1:identifier biotools:nucleosim ;
    schema1:keywords "Bayes Theorem",
        "Chromosome Mapping",
        "DNA binding sites",
        "Genetics",
        "Genome, Fungal",
        "Likelihood Functions",
        "Markov Chains",
        "Models, Genetic",
        "Monte Carlo Method",
        "Nucleic acid sites, features and motifs",
        "Nucleic acids",
        "Nucleosomes",
        "Saccharomyces cerevisiae",
        "Sequence Analysis, DNA",
        "Sequence analysis" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-nucleosim" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/nucleoSim.html" .

