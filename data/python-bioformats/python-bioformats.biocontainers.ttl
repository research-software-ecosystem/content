@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:python-bioformats a schema1:SoftwareApplication ;
    schema1:citation "doi:10.2144/000112257" ;
    schema1:description "Python-bioformats is a Python wrapper for Bio-Formats, a standalone Java library for reading and writing life sciences image file formats." ;
    schema1:keywords "Cell Count",
        "Colony Count, Microbial",
        "Cytological Techniques",
        "Image Processing, Computer-Assisted",
        "Saccharomyces cerevisiae",
        "Tissue Array Analysis",
        "Wound Healing" ;
    schema1:license "BSD-3-Clause" ;
    schema1:name "python-bioformats" ;
    schema1:url "https://github.com/CellProfiler/python-bioformats" .

