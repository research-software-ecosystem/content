@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:isonclust2 a schema1:SoftwareApplication ;
    schema1:description "De novo clustering of long transcriptomic reads" ;
    schema1:keywords "Clustering",
        "RNA-Seq",
        "Transcriptomics" ;
    schema1:license "MPL-2.0" ;
    schema1:name "isonclust2" ;
    schema1:url "https://github.com/nanoporetech/isonclust2" .

