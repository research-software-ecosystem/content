  "@graph": [
    {
      "@id": "https://bio.tools/bioconductor-cyanofilter",
      "@type": "sc:SoftwareApplication",
      "dcterms:conformsTo": "https://bioschemas.org/profiles/ComputationalTool/0.6-DRAFT",
      "sc:additionalType": [
        "Command-line tool",
        "Library"
      ],
      "sc:author": [
        "Spaak jurg",
        "Oluwafemi Olusoji"
      ],
      "sc:citation": {
        "@id": "https://doi.org/10.18129/B9.bioc.cyanoFilter"
      },
      "sc:contributor": [
        "Delaender Frederik",
        "Neyens Thomas",
        "Aerts Marc"
      ],
      "sc:description": "An approach to filter out and/or identify phytoplankton cells from all particles measured via flow cytometry pigment and cell complexity information. It does this using a sequence of one-dimensional gates on pre-defined channels measuring certain pigmentation and complexity. The package is especially tuned for cyanobacteria, but will work fine for phytoplankton communities where there is at least one cell characteristic that differentiates every phytoplankton in the community.",
      "sc:license": "MIT",
      "sc:name": "cyanoFilter",
      "sc:operatingSystem": [
        "Mac",
        "Linux",
        "Windows"
      ],
      "sc:softwareHelp": {
        "@id": "https://bioconductor.org/packages/cyanoFilter"
      },
      "sc:softwareVersion": "1.18.0",
      "sc:url": "https://bioconductor.org/packages/cyanoFilter"
    },
