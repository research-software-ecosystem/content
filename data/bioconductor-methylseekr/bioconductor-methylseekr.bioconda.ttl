@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-methylseekr a schema1:SoftwareApplication ;
    schema1:description "Segmentation of Bis-seq data" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/MethylSeekR_1.46.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/MethylSeekR/MethylSeekR_1.46.0.tar.gz', 'https://bioarchive.galaxyproject.org/MethylSeekR_1.46.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-methylseekr/bioconductor-methylseekr_1.46.0_src_all.tar.gz']" ;
    schema1:identifier biotools:methylseekr ;
    schema1:license "GPL (>=2)" ;
    schema1:name "bioconductor-methylseekr" ;
    schema1:softwareVersion "1.46.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/MethylSeekR.html" ;
    spdx:builtFrom biotools:methylseekr .

