@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:proteinortho a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/1471-2105-12-124" ;
    schema1:description "Detection of (co-)orthologs in large-scale protein analysis" ;
    schema1:keywords "Base Sequence",
        "Clustering",
        "Databases, Genetic",
        "Genomics",
        "Ortholog",
        "Phylogeny",
        "Sequence Alignment" ;
    schema1:license "GPL-2+" ;
    schema1:name "proteinortho" ;
    schema1:url "http://www.bioinf.uni-leipzig.de/Software/proteinortho/" .

