@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:proteinortho a schema1:SoftwareApplication ;
    schema1:citation "doi:10.3389/fbinf.2023.1322477" ;
    schema1:description "Proteinortho is a tool to detect orthologous genes within different species." ;
    schema1:downloadUrl "https://gitlab.com/paulklemm_PHD/proteinortho/-/archive/v6.3.6/proteinortho-v6.3.6.tar.gz" ;
    schema1:identifier biotools:proteinortho ;
    schema1:license "GPL-3.0-only" ;
    schema1:name "proteinortho" ;
    schema1:softwareHelp "https://gitlab.com/paulklemm_PHD/proteinortho/-/blob/master/README.md" ;
    schema1:softwareVersion "6.3.6" ;
    schema1:url "https://gitlab.com/paulklemm_PHD/proteinortho" ;
    spdx:builtFrom biotools:proteinortho .

