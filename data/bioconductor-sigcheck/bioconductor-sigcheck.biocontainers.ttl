@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-sigcheck a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18129/b9.bioc.sigcheck" ;
    schema1:description "Check a gene signature's prognostic performance against random signatures, known signatures, and permuted data/metadata" ;
    schema1:keywords "Gene Expression" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-sigcheck" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/SigCheck.html" .

