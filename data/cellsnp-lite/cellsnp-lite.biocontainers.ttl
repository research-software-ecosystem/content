@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:cellsnp-lite a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1101/2020.12.31.424913" ;
    schema1:description "Efficient genotyping bi-allelic SNPs on single cells" ;
    schema1:keywords "Genetics",
        "RNA-Seq" ;
    schema1:license "Apache-2.0" ;
    schema1:name "cellsnp-lite" ;
    schema1:url "https://github.com/single-cell-genetics/cellsnp-lite" .

