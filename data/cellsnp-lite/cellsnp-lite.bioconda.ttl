@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:cellsnp-lite a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btab358" ;
    schema1:description "Efficient genotyping bi-allelic SNPs on single cells." ;
    schema1:downloadUrl "https://github.com/single-cell-genetics/cellsnp-lite/archive/aad18644adcde853c313362a856a24245c9b91f7.tar.gz" ;
    schema1:identifier biotools:cellsnp-lite ;
    schema1:license "Apache-2.0" ;
    schema1:name "cellsnp-lite" ;
    schema1:softwareHelp "https://cellsnp-lite.readthedocs.io/en/latest" ;
    schema1:softwareVersion "1.2.3" ;
    schema1:url "https://github.com/single-cell-genetics/cellsnp-lite" ;
    spdx:builtFrom biotools:cellsnp-lite .

