        "Humans",
        "Quality Control",
        "Sequence Alignment",
        "Vertebrates" ;
    schema1:license "https://github.com/ComparativeGenomicsToolkit/cactus/blob/master/LICENSE.txt" ;
    schema1:name "cactus" ;
