@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:cactus a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/s41586-020-2871-y",
        "doi:10.1089/cmb.2010.0252",
        "doi:10.1101/gr.123356.111" ;
    schema1:description "Cactus is a reference-free whole-genome multiple alignment program based upon notion of Cactus graphs." ;
    schema1:downloadUrl "https://github.com/ComparativeGenomicsToolkit/cactus/releases/download/v3.1.4/cactus-v3.1.4.tar.gz" ;
    schema1:identifier biotools:cactus ;
    schema1:license "MIT" ;
    schema1:name "cactus" ;
    schema1:softwareHelp "https://github.com/ComparativeGenomicsToolkit/cactus/blob/v3.1.4/README.md" ;
    schema1:softwareVersion "3.1.4" ;
    schema1:url "https://github.com/ComparativeGenomicsToolkit/cactus" ;
    spdx:builtFrom biotools:cactus .

