@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-bus a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Gene network reconstruction" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/BUS_1.66.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/BUS/BUS_1.66.0.tar.gz', 'https://bioarchive.galaxyproject.org/BUS_1.66.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-bus/bioconductor-bus_1.66.0_src_all.tar.gz']" ;
    schema1:identifier biotools:bus ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-bus" ;
    schema1:softwareVersion "1.66.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/BUS.html" ;
    spdx:builtFrom biotools:bus .

