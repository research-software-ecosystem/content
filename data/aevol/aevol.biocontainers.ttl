@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:aevol a schema1:SoftwareApplication ;
    schema1:description "Digital genetics model to run evolution experiments in silico" ;
    schema1:keywords "Gene Expression",
        "Genetics",
        "Genomics",
        "Transcriptome" ;
    schema1:license "Custom License" ;
    schema1:name "aevol" ;
    schema1:url "http://www.aevol.fr/" .

