@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:graphlan a schema1:SoftwareApplication ;
    schema1:description "Graphlan is a software tool for producing high-quality circular representations of taxonomic and phylogenetic trees." ;
    schema1:license "MIT" ;
    schema1:name "graphlan" ;
    schema1:url "https://github.com/biobakery/graphlan" .

