@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-qtl a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btg112" ;
    schema1:description "Analysis of experimental crosses to identify genes (called quantitative trait loci, QTLs) contributing to variation in quantitative traits." ;
    schema1:identifier biotools:r-qtl ;
    schema1:keywords "Chromosome Mapping",
        "Chromosomes, Human, Pair 1",
        "Clustering",
        "Crosses, Genetic",
        "Gene Expression Profiling",
        "Genetic Markers",
        "Genetics",
        "Genome",
        "Genotype",
        "Humans",
        "Inbreeding",
        "Mapping",
        "Markov Chains",
        "Models, Genetic",
        "Models, Statistical",
        "Quantitative Trait Loci",
        "Quantitative genetics" ;
    schema1:license "GPL-3" ;
    schema1:name "r-qtl" ;
    schema1:url "http://rqtl.org" .

