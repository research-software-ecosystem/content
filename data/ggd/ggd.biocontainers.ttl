@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:ggd a schema1:SoftwareApplication ;
    schema1:description "Gogetdata (ggd) is a genomic data managment system. it provide simple and reproducible access to a repository of genomic data. simply put, it is 'conda' for genomic data" ;
    schema1:keywords "Genomics" ;
    schema1:license "MIT" ;
    schema1:name "ggd" ;
    schema1:url "https://github.com/gogetdata/ggd-cli" .

