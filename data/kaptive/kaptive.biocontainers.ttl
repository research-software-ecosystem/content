@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:kaptive a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1101/869370" ;
    schema1:description "Kaptive reports information about capsular (k) loci found in genome assemblies" ;
    schema1:keywords "Genomics",
        "Ortholog",
        "Protein Sequences" ;
