@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:combined-pvalues a schema1:SoftwareApplication ;
    schema1:description "A library to combine, analyze, group and correct p-values in bed files.unique tools involve correction for spatial autocorrelation. this is useful for chip-seq probes and tiling arrays, or any data with spatial correlation." ;
    schema1:license "MIT" ;
    schema1:name "combined-pvalues" ;
    schema1:url "https://github.com/brentp/combined-pvalues" .

