@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:pathwaymatcher a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/GIGASCIENCE/GIZ088" ;
    schema1:description "Pathwaymatcher is a software tool writen in java to search for pathways related to a list of proteins in reactome." ;
    schema1:keywords "Computational Biology",
        "Gene Regulatory Networks",
        "Humans",
        "Peptides",
        "Polymorphism, Single Nucleotide",
        "Protein Interaction Mapping",
        "Protein Processing, Post-Translational",
        "Signal Transduction" ;
    schema1:license "Apache-2.0" ;
    schema1:name "pathwaymatcher" ;
    schema1:url "https://github.com/PathwayAnalysisPlatform/PathwayMatcher" .

