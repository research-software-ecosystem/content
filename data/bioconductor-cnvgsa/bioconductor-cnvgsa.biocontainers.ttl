@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-cnvgsa a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Gene Set Analysis of (Rare) Copy Number Variants" ;
    schema1:identifier biotools:cnvgsa ;
    schema1:keywords "Computational Biology",
        "Gene Expression Profiling",
        "Genetic variation",
        "Genomics",
        "High-Throughput Screening Assays",
        "Programming Languages",
        "User-Computer Interface" ;
    schema1:license "LGPL" ;
    schema1:name "bioconductor-cnvgsa" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/cnvGSA.html" .

