@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:cansam a schema1:SoftwareApplication ;
    schema1:description "The Sequence Alignment/Map (SAM) file format and its binary companion BAM are formats for storing nucleotide sequence alignments. They are designed for the large volumes of short- to middling-length reads produced by next-generation sequencing technologies." ;
    schema1:keywords "Sequence Alignment" ;
    schema1:license "BSD-3-Clause" ;
    schema1:name "cansam" ;
    schema1:url "https://github.com/jmarshall/cansam/" .

