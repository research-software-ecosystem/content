@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-cghnormaliter a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/1471-2164-10-401" ;
    schema1:description "Normalization of array CGH data with imbalanced aberrations." ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/CGHnormaliter_1.64.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/CGHnormaliter/CGHnormaliter_1.64.0.tar.gz', 'https://bioarchive.galaxyproject.org/CGHnormaliter_1.64.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-cghnormaliter/bioconductor-cghnormaliter_1.64.0_src_all.tar.gz']" ;
    schema1:identifier biotools:cghnormaliter ;
    schema1:license "GPL (>= 3)" ;
    schema1:name "bioconductor-cghnormaliter" ;
    schema1:softwareVersion "1.64.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/CGHnormaliter.html" ;
    spdx:builtFrom biotools:cghnormaliter .

