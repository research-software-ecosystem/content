@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-cghnormaliter a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/1471-2164-10-401" ;
    schema1:description "Normalization of array CGH data with imbalanced aberrations." ;
    schema1:identifier biotools:cghnormaliter ;
    schema1:keywords "Comparative Genomic Hybridization",
        "DNA, Neoplasm",
        "Gene Dosage",
        "Humans",
        "Microarray experiment",
        "Oligonucleotide Array Sequence Analysis",
        "Sensitivity and Specificity",
        "Sequence Analysis, DNA" ;
    schema1:license "GPL (>= 3)" ;
    schema1:name "bioconductor-cghnormaliter" ;
    schema1:url "http://bioconductor.org/packages/3.6/bioc/html/CGHnormaliter.html" .

