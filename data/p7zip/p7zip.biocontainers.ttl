@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:p7zip a schema1:SoftwareApplication ;
    schema1:description "p7zip is a quick port of 7z.exe and 7za.exe (command line version of 7zip, see www.7-zip.org ) for Unix." ;
    schema1:license "LGPLv2" ;
    schema1:name "p7zip" ;
    schema1:url "None" .

