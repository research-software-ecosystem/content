@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-vsn a schema1:SoftwareApplication ;
    schema1:description "Variance stabilization and calibration for microarray data" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/vsn_3.78.1.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/vsn/vsn_3.78.1.tar.gz', 'https://bioarchive.galaxyproject.org/vsn_3.78.1.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-vsn/bioconductor-vsn_3.78.1_src_all.tar.gz']" ;
    schema1:identifier biotools:vsn ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-vsn" ;
    schema1:softwareVersion "3.78.1" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/vsn.html" ;
    spdx:builtFrom biotools:vsn .

