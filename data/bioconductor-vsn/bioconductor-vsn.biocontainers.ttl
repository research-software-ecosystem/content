@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-vsn a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/18.suppl_1.S96" ;
    schema1:description "Variance stabilization and calibration for microarray data" ;
    schema1:identifier biotools:vsn ;
    schema1:keywords "Analysis of Variance",
        "Calibration",
        "Data Interpretation, Statistical",
        "Gene Expression Profiling",
        "Gene expression",
        "Likelihood Functions",
        "Microarray experiment",
        "Models, Genetic",
        "Models, Statistical",
        "Oligonucleotide Array Sequence Analysis",
        "Reference Standards",
        "Reproducibility of Results",
        "Sensitivity and Specificity",
        "Statistics and probability" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-vsn" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/vsn.html" .

