@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:ksw a schema1:SoftwareApplication ;
    schema1:description "Ksw: (interactive) smith-waterman in C" ;
    schema1:identifier biotools:ksw ;
    schema1:license "MIT" ;
    schema1:name "ksw" ;
    schema1:url "https://github.com/nh13/ksw" .

