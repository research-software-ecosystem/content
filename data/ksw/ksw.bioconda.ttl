@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:ksw a schema1:SoftwareApplication ;
    schema1:description "Ksw: (interactive) smith-waterman in C" ;
    schema1:downloadUrl "https://github.com/nh13/ksw/releases/download/0.2.3/0.2.3.tar.gz" ;
    schema1:identifier biotools:ksw ;
    schema1:license "MIT" ;
    schema1:name "ksw" ;
    schema1:softwareVersion "0.2.3" ;
    schema1:url "https://github.com/nh13/ksw" ;
    spdx:builtFrom biotools:ksw .

