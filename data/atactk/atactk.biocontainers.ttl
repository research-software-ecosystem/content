@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:atactk a schema1:SoftwareApplication ;
    schema1:description "A toolkit for working with atac-seq data." ;
    schema1:keywords "Functional genomics",
        "Genetic variation",
        "Genetics",
        "Genomics" ;
    schema1:license "Not available" ;
    schema1:name "atactk" ;
    schema1:url "http://theparkerlab.org/" .

