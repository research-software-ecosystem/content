@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:ucsc-bedjointaboffset a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bib/bbs038" ;
    schema1:description "given a bed file and tab file where each have a column with matching values: first get the value of column0, the offset and line length from inTabFile. Then go over the bed file, use the name field and append its offset and length to the bed file as two separate fields. Write the new bed file to outBed." ;
    schema1:downloadUrl "http://hgdownload.cse.ucsc.edu/admin/exe/userApps.archive/userApps.v469.src.tgz" ;
    schema1:identifier biotools:UCSC_Genome_Browser_Utilities ;
    schema1:license "varies; see http://genome.ucsc.edu/license" ;
    schema1:name "ucsc-bedjointaboffset" ;
    schema1:softwareHelp "https://github.com/ucscGenomeBrowser/kent/blob/master/README" ;
    schema1:softwareVersion "469" ;
    schema1:url "http://hgdownload.cse.ucsc.edu/admin/exe/" ;
    spdx:builtFrom biotools:UCSC_Genome_Browser_Utilities .

