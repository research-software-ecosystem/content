@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-multiscan a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "R package for combining multiple scans" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/multiscan_1.66.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/multiscan/multiscan_1.66.0.tar.gz', 'https://bioarchive.galaxyproject.org/multiscan_1.66.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-multiscan/bioconductor-multiscan_1.66.0_src_all.tar.gz']" ;
    schema1:identifier biotools:multiscan ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-multiscan" ;
    schema1:softwareVersion "1.66.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/multiscan.html" ;
    spdx:builtFrom biotools:multiscan .

