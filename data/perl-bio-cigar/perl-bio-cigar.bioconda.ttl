@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:perl-bio-cigar a schema1:SoftwareApplication ;
    schema1:description "Parse CIGAR strings and translate coordinates to/from reference/query" ;
    schema1:downloadUrl "https://cpan.metacpan.org/authors/id/T/TS/TSIBLEY/Bio-Cigar-1.01.tar.gz" ;
    schema1:identifier biotools:bio-cigar ;
    schema1:license "gpl_2" ;
    schema1:name "perl-bio-cigar" ;
    schema1:softwareVersion "1.01" ;
    schema1:url "https://github.com/MullinsLab/Bio-Cigar" ;
    spdx:builtFrom biotools:bio-cigar .

