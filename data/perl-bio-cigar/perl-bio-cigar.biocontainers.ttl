@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:perl-bio-cigar a schema1:SoftwareApplication ;
    schema1:description "Parse cigar strings and translate coordinates to/from reference/query." ;
    schema1:identifier biotools:bio-cigar ;
    schema1:keywords "Sequence analysis" ;
    schema1:license "gpl_2" ;
    schema1:name "perl-bio-cigar" ;
    schema1:url "https://github.com/MullinsLab/Bio-Cigar" .

