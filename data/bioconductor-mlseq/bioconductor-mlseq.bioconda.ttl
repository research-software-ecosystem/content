@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-mlseq a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Machine Learning Interface for RNA-Seq Data" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/MLSeq_2.28.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/MLSeq/MLSeq_2.28.0.tar.gz', 'https://bioarchive.galaxyproject.org/MLSeq_2.28.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-mlseq/bioconductor-mlseq_2.28.0_src_all.tar.gz']" ;
    schema1:identifier biotools:mlseq ;
    schema1:license "GPL(>=2)" ;
    schema1:name "bioconductor-mlseq" ;
    schema1:softwareVersion "2.28.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/MLSeq.html" ;
    spdx:builtFrom biotools:mlseq .

