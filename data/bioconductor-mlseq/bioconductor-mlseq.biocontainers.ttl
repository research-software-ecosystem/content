@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-mlseq a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Machine Learning Interface for RNA-Seq Data" ;
    schema1:identifier biotools:mlseq ;
    schema1:keywords "Clustering",
        "Computational Biology",
        "Gene Expression Profiling",
        "Genomics",
        "High-Throughput Screening Assays",
        "Machine learning",
        "Programming Languages",
        "RNA-Seq",
        "User-Computer Interface" ;
    schema1:license "GPL(>=2)" ;
    schema1:name "bioconductor-mlseq" ;
    schema1:url "http://bioconductor.org/packages/3.6/bioc/html/MLSeq.html" .

