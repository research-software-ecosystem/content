@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-batchjobs a schema1:SoftwareApplication ;
    schema1:description "Provides Map, Reduce and Filter variants to generate jobs on batch computing systems like PBS/Torque, LSF, SLURM and Sun Grid Engine. Multicore and SSH systems are also supported. For further details see the project web page." ;
    schema1:license "BSD_2_clause" ;
    schema1:name "r-batchjobs" ;
    schema1:url "None" .

