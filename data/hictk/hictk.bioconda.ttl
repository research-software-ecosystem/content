@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:hictk a schema1:SoftwareApplication ;
    schema1:author "jonnings",
        "robomics" ;
    schema1:citation "doi:10.5281/zenodo.8214221" ;
    schema1:description "Blazing fast toolkit to work with .hic and .cool files" ;
    schema1:downloadUrl "https://github.com/paulsengroup/hictk/archive/refs/tags/v2.2.0.tar.gz" ;
    schema1:identifier biotools:hictk ;
    schema1:license "MIT" ;
    schema1:maintainer "jonnings",
        "robomics" ;
    schema1:name "hictk" ;
    schema1:softwareHelp "https://hictk.readthedocs.io/en/stable/" ;
    schema1:softwareVersion "2.2.0" ;
    schema1:url "https://github.com/paulsengroup/hictk" ;
    spdx:builtFrom biotools:hictk .

