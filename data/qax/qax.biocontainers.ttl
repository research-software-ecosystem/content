@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:qax a schema1:SoftwareApplication ;
    schema1:description "Extract data, metadata, bibliography and provenance from Qiime2 artifacts" ;
    schema1:identifier biotools:qax ;
    schema1:license "GPL-3" ;
    schema1:name "qax" ;
    schema1:url "https://github.com/telatin/qax" .

