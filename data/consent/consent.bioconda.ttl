@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:consent a schema1:SoftwareApplication ;
    schema1:author "natir" ;
    schema1:citation "doi:10.1038/s41598-020-80757-5" ;
    schema1:description "Scalable long read self-correction and assembly polishing with multiple sequence alignment." ;
    schema1:identifier biotools:consent-correct ;
    schema1:license "AGPL-3.0-or-later" ;
    schema1:maintainer "natir" ;
    schema1:name "consent" ;
    schema1:softwareHelp "https://github.com/morispi/CONSENT/blob/v2.2.2/README.md" ;
    schema1:softwareVersion "2.2.2" ;
    schema1:url "https://github.com/morispi/CONSENT" ;
    spdx:builtFrom biotools:consent-correct .

