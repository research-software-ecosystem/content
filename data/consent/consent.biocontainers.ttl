@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:consent a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s13321-017-0248-5" ;
    schema1:description "Scalable long read self-correction and assembly polishing with multiple sequence alignment" ;
    schema1:identifier biotools:consent ;
    schema1:keywords "Cheminformatics",
        "Compound libraries and screening",
        "Protein-ligand interactions",
        "Sequence Alignment" ;
    schema1:license "AGPL-3.0" ;
    schema1:name "consent" ;
    schema1:url "https://github.com/morispi/CONSENT" .

