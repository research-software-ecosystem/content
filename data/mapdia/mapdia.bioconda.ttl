@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:mapdia a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1016/j.jprot.2015.09.013" ;
    schema1:description "Performs essential data preprocessing, including novel retention time-based normalization method and a sequence of peptide/fragment selection steps, and more importantly, hierarchical model-based statistical significance analysis for multi-group comparisons under representative experimental designs." ;
    schema1:downloadUrl "https://sourceforge.net/projects/mapdia/files/mapDIA_v3.1.0.tar.gz" ;
    schema1:identifier biotools:MAPDIA ;
    schema1:license "file" ;
    schema1:name "mapdia" ;
    schema1:softwareVersion "3.1.0" ;
    schema1:url "https://sourceforge.net/projects/mapdia" ;
    spdx:builtFrom biotools:MAPDIA .

