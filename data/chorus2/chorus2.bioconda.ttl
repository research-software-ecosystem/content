@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:chorus2 a schema1:SoftwareApplication ;
    schema1:author "forrestzhang",
        "ljq12697",
        "zhangtaolab" ;
    schema1:description "A pipeline to select oligonucleotides for fluorescence in situ hbridization (Oligo-FISH)." ;
    schema1:downloadUrl "https://github.com/zhangtaolab/Chorus2/archive/v2.1.tar.gz" ;
    schema1:identifier biotools:chorus2 ;
    schema1:license "MIT" ;
    schema1:maintainer "forrestzhang",
        "ljq12697",
        "zhangtaolab" ;
    schema1:name "chorus2" ;
    schema1:softwareHelp "https://chorus2.readthedocs.io/en/dev/" ;
    schema1:softwareVersion "2.1" ;
    schema1:url "https://github.com/zhangtaolab/Chorus2" ;
    spdx:builtFrom biotools:chorus2 .

