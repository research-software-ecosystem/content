@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:hicexplorer a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/gkaa220",
        "doi:10.1093/nar/gky504" ;
    schema1:description "Set of programs to process, analyze and visualize hi-c and capture hi-c data" ;
    schema1:keywords "Chromatin",
        "Computer Graphics",
        "Genetic Techniques",
        "Genetics",
        "Genomics",
        "Internet",
        "Molecular Conformation",
        "Reproducibility of Results",
        "Single-Cell Analysis" ;
    schema1:license "GPL-3.0" ;
    schema1:name "hicexplorer" ;
    schema1:url "https://github.com/deeptools/HiCExplorer" .

