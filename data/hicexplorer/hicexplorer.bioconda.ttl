@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:hicexplorer a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/gigascience/giac061",
        "doi:10.1093/nar/gkaa220",
        "doi:10.1093/nar/gky504" ;
    schema1:description "Set of programs to process, analyze and visualize Hi-C and capture Hi-C data" ;
    schema1:downloadUrl "https://github.com/deeptools/HiCExplorer/archive/3.7.6.tar.gz" ;
    schema1:identifier biotools:hicexplorer ;
    schema1:license "GPL-3.0-or-later" ;
    schema1:name "hicexplorer" ;
    schema1:softwareHelp "https://hicexplorer.readthedocs.org/" ;
    schema1:softwareVersion "3.7.6" ;
    schema1:url "https://github.com/deeptools/HiCExplorer" ;
    spdx:builtFrom biotools:hicexplorer .

