@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-multtest a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1007/0-387-29362-0_15" ;
    schema1:description "Resampling-based multiple hypothesis testing" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/multtest_2.62.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/multtest/multtest_2.62.0.tar.gz', 'https://bioarchive.galaxyproject.org/multtest_2.62.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-multtest/bioconductor-multtest_2.62.0_src_all.tar.gz']" ;
    schema1:identifier biotools:multtest ;
    schema1:license "LGPL" ;
    schema1:name "bioconductor-multtest" ;
    schema1:softwareVersion "2.62.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/multtest.html" ;
    spdx:builtFrom biotools:multtest .

