@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:medusa a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btv171" ;
    schema1:description "A draft genome scaffolder that uses multiple reference genomes in a graph-based approach." ;
    schema1:identifier biotools:medusa ;
    schema1:keywords "Comparative genomics",
        "Contig Mapping",
        "Genomics",
        "Structural genomics" ;
    schema1:license "GPL-3.0" ;
    schema1:name "medusa" ;
    schema1:url "https://github.com/combogenomics/medusa" .

