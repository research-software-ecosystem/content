@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:perl-exporter-tiny a schema1:SoftwareApplication ;
    schema1:description "Exporter with the features of Sub::Exporter but only core dependencies" ;
    schema1:license "perl_5" ;
    schema1:name "perl-exporter-tiny" ;
    schema1:url "https://metacpan.org/release/Exporter-Tiny" .

