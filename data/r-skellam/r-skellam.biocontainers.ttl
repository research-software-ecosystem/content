@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-skellam a schema1:SoftwareApplication ;
    schema1:description "Functions for the Skellam distribution, including: density (pmf), cdf, quantiles and regression." ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "r-skellam" ;
    schema1:url "https://cran.r-project.org/package=skellam" .

