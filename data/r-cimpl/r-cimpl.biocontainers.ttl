@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-cimpl a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/bts448" ;
    schema1:description "An analysis package for multi sample insertional mutagenesis data (including viral- and transposon-based systems) using Gaussian kernel convolution to identify common insertion sites." ;
    schema1:keywords "Clustering",
        "Genomics",
        "Mass spectrometry",
        "Transcriptomics" ;
    schema1:license "GPL-3" ;
    schema1:name "r-cimpl" ;
    schema1:url "http://ccb.nki.nl/software/" .

