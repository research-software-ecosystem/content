@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-goseq a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/gb-2010-11-2-r14" ;
    schema1:description "Gene Ontology analyser for RNA-seq and other length biased data" ;
    schema1:identifier biotools:goseq ;
    schema1:keywords "Androgens",
        "Bias",
        "Cell Line, Tumor",
        "Gene Expression Regulation, Neoplastic",
        "Genome-Wide Association Study",
        "Humans",
        "Male",
        "Prostatic Neoplasms",
        "RNA-Seq",
        "RNA-seq",
        "Sequence Analysis, RNA" ;
    schema1:license "LGPL-2.0" ;
    schema1:name "bioconductor-goseq" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/goseq.html" .

