@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-goseq a schema1:SoftwareApplication ;
    schema1:description "Gene Ontology analyser for RNA-seq and other length biased data" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/goseq_1.62.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/goseq/goseq_1.62.0.tar.gz', 'https://bioarchive.galaxyproject.org/goseq_1.62.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-goseq/bioconductor-goseq_1.62.0_src_all.tar.gz']" ;
    schema1:identifier biotools:goseq ;
    schema1:license "LGPL (>= 2)" ;
    schema1:name "bioconductor-goseq" ;
    schema1:softwareVersion "1.62.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/goseq.html" ;
    spdx:builtFrom biotools:goseq .

