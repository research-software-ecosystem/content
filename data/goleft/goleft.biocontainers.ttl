@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:goleft a schema1:SoftwareApplication ;
    schema1:description "goleft is a collection of bioinformatics tools distributed under MIT license in a single static binary" ;
    schema1:keywords "Genomics" ;
    schema1:license "MIT" ;
    schema1:name "goleft" ;
    schema1:url "https://github.com/brentp/goleft" .

