@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-genomation a schema1:SoftwareApplication ;
    schema1:description "Summary, annotation and visualization of genomic data" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/genomation_1.38.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/genomation/genomation_1.38.0.tar.gz', 'https://bioarchive.galaxyproject.org/genomation_1.38.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-genomation/bioconductor-genomation_1.38.0_src_all.tar.gz']" ;
    schema1:identifier biotools:genomation ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-genomation" ;
    schema1:softwareVersion "1.38.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/genomation.html" ;
    spdx:builtFrom biotools:genomation .

