@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-genomation a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btu775" ;
    schema1:description "Summary, annotation and visualization of genomic data" ;
    schema1:identifier biotools:genomation ;
    schema1:keywords "Computational Biology",
        "Computer Graphics",
        "Data visualisation",
        "Databases, Genetic",
        "Exons",
        "Genome, Human",
        "Genomics",
        "High-Throughput Nucleotide Sequencing",
        "Humans",
        "Introns",
        "Molecular Sequence Annotation" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-genomation" ;
    schema1:url "None" .

