@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-proteoqc a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18129/b9.bioc.proteoqc" ;
    schema1:description "An R package for proteomics data quality control" ;
    schema1:keywords "Mass spectra",
        "Mass spectrometry",
        "Proteomics",
        "Transcriptome" ;
    schema1:license "LGPL-2" ;
    schema1:name "bioconductor-proteoqc" ;
    schema1:url "https://github.com/wenbostar/proteoQC" .

