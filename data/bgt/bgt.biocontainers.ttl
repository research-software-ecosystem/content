@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bgt a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btv613" ;
    schema1:description "Flexible genotype query among 30,000+ samples whole-genome." ;
    schema1:identifier biotools:bgt ;
    schema1:keywords "Databases, Factual",
        "Datasets as Topic",
        "Genetic Variation",
        "Genome, Human",
        "Genomics",
        "Genotype",
        "Haplotypes",
        "Humans",
        "Sample collections",
        "Whole genome sequencing" ;
    schema1:license "MIT" ;
    schema1:name "bgt" ;
    schema1:url "https://github.com/lh3/bgt" .

