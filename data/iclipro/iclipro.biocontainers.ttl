@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:iclipro a schema1:SoftwareApplication ;
    schema1:description "Iclipro is a python package that can be used to control for systematic misassignments in iclip data." ;
