@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-nhmmfdr a schema1:SoftwareApplication ;
    schema1:description "The NHMMfdr package implements the non-homogeneous Hidden Markov Model based FDR control as described in Kuan et al., 2011 for multiple comparison adjustment under dependence. It allows for prior information to be incorporated in the model to improve detection of significant tests." ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "r-nhmmfdr" ;
    schema1:url "http://www.ams.sunysb.edu/~pfkuan/NHMMfdr/" .

