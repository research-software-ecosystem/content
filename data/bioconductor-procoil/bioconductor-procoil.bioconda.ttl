@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-procoil a schema1:SoftwareApplication ;
    schema1:description "Prediction of Oligomerization of Coiled Coil Proteins" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/procoil_2.38.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/procoil/procoil_2.38.0.tar.gz', 'https://bioarchive.galaxyproject.org/procoil_2.38.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-procoil/bioconductor-procoil_2.38.0_src_all.tar.gz']" ;
    schema1:identifier biotools:procoil ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-procoil" ;
    schema1:softwareVersion "2.38.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/procoil.html" ;
    spdx:builtFrom biotools:procoil .

