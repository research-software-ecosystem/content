@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:iucn_sim a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1101/2019.12.16.878249" ;
    schema1:description "Simulate future extinctions and extinction rates for a given set of species, based on iucn threat assessments" ;
    schema1:license "MIT" ;
    schema1:name "iucn_sim" ;
    schema1:url "https://github.com/tobiashofmann88/iucn_extinction_simulator" .

