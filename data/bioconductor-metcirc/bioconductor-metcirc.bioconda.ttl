@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-metcirc a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btx159" ;
    schema1:description "Navigating mass spectral similarity in high-resolution MS/MS metabolomics data metabolomics data" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/MetCirc_1.36.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/MetCirc/MetCirc_1.36.0.tar.gz', 'https://bioarchive.galaxyproject.org/MetCirc_1.36.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-metcirc/bioconductor-metcirc_1.36.0_src_all.tar.gz']" ;
    schema1:identifier biotools:metcirc ;
    schema1:license "GPL (>= 3)" ;
    schema1:name "bioconductor-metcirc" ;
    schema1:softwareVersion "1.36.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/MetCirc.html" ;
    spdx:builtFrom biotools:metcirc .

