@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-metcirc a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btx159" ;
    schema1:description "Navigating mass spectral similarity in high-resolution MS/MS metabolomics data" ;
    schema1:identifier biotools:metcirc ;
    schema1:keywords "Mass Spectrometry",
        "Mass spectra",
        "Metabolomics",
        "Molecular interactions, pathways and networks",
        "Systems biology" ;
    schema1:license "GPL (>= 3)" ;
    schema1:name "bioconductor-metcirc" ;
    schema1:url "http://bioconductor.org/packages/3.5/bioc/html/MetCirc.html" .

