@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-rtcga a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "The Cancer Genome Atlas Data Integration" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/RTCGA_1.36.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/RTCGA/RTCGA_1.36.0.tar.gz', 'https://bioarchive.galaxyproject.org/RTCGA_1.36.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-rtcga/bioconductor-rtcga_1.36.0_src_all.tar.gz']" ;
    schema1:identifier biotools:rtcga ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-rtcga" ;
    schema1:softwareVersion "1.36.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/RTCGA.html" ;
    spdx:builtFrom biotools:rtcga .

