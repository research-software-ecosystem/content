@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-purbayes a schema1:SoftwareApplication ;
    schema1:description "PurBayes is an MCMC-based algorithm that uses next-generation sequencing data to estimate tumor purity and clonality for paired tumor-normal data." ;
    schema1:license "GPL-2" ;
    schema1:name "r-purbayes" ;
    schema1:url "https://CRAN.R-project.org/package=PurBayes" .

