@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-affycomp a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btg410" ;
    schema1:description "Graphics Toolbox for Assessment of Affymetrix Expression Measures" ;
    schema1:identifier biotools:affycomp ;
    schema1:keywords "Benchmarking",
        "Computer Graphics",
        "Gene Expression Profiling",
        "Gene expression",
        "Information Storage and Retrieval",
        "Microarray experiment",
        "Oligonucleotide Array Sequence Analysis",
        "Reference Standards",
        "Reproducibility of Results",
        "Sensitivity and Specificity",
        "Sequence Analysis, DNA",
        "United States",
        "User-Computer Interface" ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-affycomp" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/affycomp.html" .

