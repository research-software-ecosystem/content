@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-affycomp a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btg410" ;
    schema1:description "Graphics Toolbox for Assessment of Affymetrix Expression Measures" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/affycomp_1.82.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/affycomp/affycomp_1.82.0.tar.gz', 'https://bioarchive.galaxyproject.org/affycomp_1.82.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-affycomp/bioconductor-affycomp_1.82.0_src_all.tar.gz']" ;
    schema1:identifier biotools:affycomp ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-affycomp" ;
    schema1:softwareVersion "1.82.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/affycomp.html" ;
    spdx:builtFrom biotools:affycomp .

