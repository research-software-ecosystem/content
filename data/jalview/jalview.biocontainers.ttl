@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:jalview a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btp033" ;
    schema1:description "Jalview is a free program for multiple sequence alignment editing, visualisation, analysis and figure generation." ;
    schema1:keywords "Computational Biology",
        "Databases, Protein",
        "Protein Structure",
        "Proteins",
        "Sequence Alignment",
        "Sequence Analysis, Protein" ;
    schema1:license "GPL-3" ;
    schema1:name "jalview" ;
    schema1:url "http://www.jalview.org/" .

