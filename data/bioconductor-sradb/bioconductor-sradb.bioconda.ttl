@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-sradb a schema1:SoftwareApplication ;
    schema1:description "A compilation of metadata from NCBI SRA and tools" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.18/bioc/src/contrib/SRAdb_1.64.0.tar.gz', 'https://bioconductor.org/packages/3.18/bioc/src/contrib/Archive/SRAdb/SRAdb_1.64.0.tar.gz', 'https://bioarchive.galaxyproject.org/SRAdb_1.64.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-sradb/bioconductor-sradb_1.64.0_src_all.tar.gz']" ;
    schema1:identifier biotools:sradb ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-sradb" ;
    schema1:softwareVersion "1.64.0" ;
    schema1:url "https://bioconductor.org/packages/3.18/bioc/html/SRAdb.html" ;
    spdx:builtFrom biotools:sradb .

