@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:orfm a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btw241" ;
    schema1:description "OrfM is a simple and not slow ORF caller." ;
    schema1:downloadUrl "https://github.com/wwood/OrfM/archive/2.1.1.tar.gz" ;
    schema1:identifier biotools:orfm ;
    schema1:license "LGPL-3.0-or-later" ;
    schema1:name "orfm" ;
    schema1:softwareVersion "2.1.1" ;
    schema1:url "https://github.com/wwood/OrfM" ;
    spdx:builtFrom biotools:orfm .

