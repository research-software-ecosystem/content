@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:orfm a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btw241" ;
    schema1:description "OrfM is a simple and not slow ORF caller" ;
    schema1:keywords "Computational Biology",
        "Gene Expression Profiling",
        "Genome",
        "Humans",
        "Metagenomics",
        "Open Reading Frames" ;
    schema1:license "LGPL-3.0" ;
    schema1:name "orfm" ;
    schema1:url "https://github.com/wwood/OrfM" .

