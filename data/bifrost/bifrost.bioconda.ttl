@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bifrost a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1101/695338" ;
    schema1:description "Highly parallel construction and indexing of colored and compacted de Bruijn graphs." ;
    schema1:downloadUrl "https://github.com/pmelsted/bifrost/archive/v1.3.5.tar.gz" ;
    schema1:identifier biotools:bifrost ;
    schema1:license "BSD-2-Clause" ;
    schema1:name "bifrost" ;
    schema1:softwareHelp "https://github.com/pmelsted/bifrost/blob/v1.3.5/README.md" ;
    schema1:softwareVersion "1.3.5" ;
    schema1:url "https://github.com/pmelsted/bifrost" ;
    spdx:builtFrom biotools:bifrost .

