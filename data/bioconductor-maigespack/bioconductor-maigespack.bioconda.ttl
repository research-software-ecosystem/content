    schema1:license "GPL-3.0-or-later" ;
    schema1:name "bioconductor-maigespack" ;
    schema1:softwareVersion "1.64.0" ;
    schema1:url "https://bioconductor.org/packages/3.17/bioc/html/maigesPack.html" ;
    spdx:builtFrom biotools:maigespack .

