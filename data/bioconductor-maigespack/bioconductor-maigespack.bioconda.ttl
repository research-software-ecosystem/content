bioconda:bioconductor-maigespack a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Functions to handle cDNA microarray data, including several methods of data analysis" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.17/bioc/src/contrib/maigesPack_1.64.0.tar.gz', 'https://bioconductor.org/packages/3.17/bioc/src/contrib/Archive/maigesPack/maigesPack_1.64.0.tar.gz', 'https://bioarchive.galaxyproject.org/maigesPack_1.64.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-maigespack/bioconductor-maigespack_1.64.0_src_all.tar.gz']" ;
