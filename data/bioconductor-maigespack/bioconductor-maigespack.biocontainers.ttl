@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-maigespack a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Functions to handle cDNA microarray data, including several methods of data analysis" ;
    schema1:identifier biotools:maigespack ;
    schema1:keywords "Clustering",
        "Computational Biology",
        "DNA",
        "Gene Expression Profiling",
        "Gene transcripts",
        "Genetics",
        "Genomics",
        "High-Throughput Screening Assays",
        "Programming Languages",
        "User-Computer Interface" ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-maigespack" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/maigesPack.html" .

