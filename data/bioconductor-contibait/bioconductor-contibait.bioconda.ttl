@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-contibait a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btx281" ;
    schema1:description "Improves Early Build Genome Assemblies using Strand-Seq Data" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.18/bioc/src/contrib/contiBAIT_1.30.0.tar.gz', 'https://bioconductor.org/packages/3.18/bioc/src/contrib/Archive/contiBAIT/contiBAIT_1.30.0.tar.gz', 'https://bioarchive.galaxyproject.org/contiBAIT_1.30.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-contibait/bioconductor-contibait_1.30.0_src_all.tar.gz']" ;
    schema1:identifier biotools:contibait ;
    schema1:license "BSD_2_clause + file LICENSE" ;
    schema1:name "bioconductor-contibait" ;
    schema1:softwareVersion "1.30.0" ;
    schema1:url "https://bioconductor.org/packages/3.18/bioc/html/contiBAIT.html" ;
    spdx:builtFrom biotools:contibait .

