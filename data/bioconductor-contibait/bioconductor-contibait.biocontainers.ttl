@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-contibait a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btx281" ;
    schema1:description "Improves Early Build Genome Assemblies using Strand-Seq Data" ;
    schema1:identifier biotools:contibait ;
    schema1:keywords "Genetics",
        "Genome, Human",
        "Genomics",
        "High-Throughput Nucleotide Sequencing",
        "Humans",
        "Sequence Analysis, DNA" ;
    schema1:license "BSD_2_clause" ;
    schema1:name "bioconductor-contibait" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/contiBAIT.html" .

