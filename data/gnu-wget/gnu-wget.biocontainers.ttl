@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:gnu-wget a schema1:SoftwareApplication ;
    schema1:description "Retrieve files using HTTP, HTTPS and FTP" ;
    schema1:license "GPL-3.0" ;
    schema1:name "gnu-wget" ;
    schema1:url "http://www.gnu.org/software/wget/" .

