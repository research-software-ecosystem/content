@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-survcomp a schema1:SoftwareApplication ;
    schema1:description "Performance Assessment and Comparison for Survival Analysis" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/survcomp_1.56.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/survcomp/survcomp_1.56.0.tar.gz', 'https://bioarchive.galaxyproject.org/survcomp_1.56.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-survcomp/bioconductor-survcomp_1.56.0_src_all.tar.gz']" ;
    schema1:identifier biotools:survcomp ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-survcomp" ;
    schema1:softwareVersion "1.56.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/survcomp.html" ;
    spdx:builtFrom biotools:survcomp .

