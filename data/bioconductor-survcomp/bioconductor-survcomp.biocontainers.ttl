@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-survcomp a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btn374" ;
    schema1:description "Performance Assessment and Comparison for Survival Analysis" ;
    schema1:identifier biotools:survcomp ;
    schema1:keywords "Breast Neoplasms",
        "Female",
        "Gene Expression Profiling",
        "Genomics",
        "Humans",
        "Medicine",
        "Microarray experiment",
        "Models, Biological",
        "Oligonucleotide Array Sequence Analysis",
        "Pathology",
        "Phenotype",
        "Statistics and probability",
        "Survival Analysis" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-survcomp" ;
    schema1:url "https://www.bioconductor.org/packages/release/bioc/html/survcomp.html" .

