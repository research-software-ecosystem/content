@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-arraytools a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "geneChip Analysis Package" ;
    schema1:identifier biotools:arraytools ;
    schema1:keywords "Computational Biology",
        "Data quality management",
        "Gene Expression Profiling",
        "Gene expression",
        "Genomics",
        "High-Throughput Screening Assays",
        "Programming Languages",
        "User-Computer Interface" ;
    schema1:license "LGPL (>= 2.0)" ;
    schema1:name "bioconductor-arraytools" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/ArrayTools.html" .

