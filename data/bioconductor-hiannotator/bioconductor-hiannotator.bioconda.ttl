@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-hiannotator a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Functions for annotating GRanges objects" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/hiAnnotator_1.40.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/hiAnnotator/hiAnnotator_1.40.0.tar.gz', 'https://bioarchive.galaxyproject.org/hiAnnotator_1.40.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-hiannotator/bioconductor-hiannotator_1.40.0_src_all.tar.gz']" ;
    schema1:identifier biotools:hiannotator ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-hiannotator" ;
    schema1:softwareVersion "1.40.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/hiAnnotator.html" ;
    spdx:builtFrom biotools:hiannotator .

