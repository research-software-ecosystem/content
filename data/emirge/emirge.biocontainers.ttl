@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:emirge a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/gb-2011-12-5-r44",
        "doi:10.1371/journal.pone.0056018" ;
    schema1:description "EMIRGE reconstructs full length sequences from short sequencing reads" ;
    schema1:keywords "Bacteria",
        "Biodiversity",
        "DNA, Bacterial",
        "Genetic Variation",
        "Geologic Sediments",
        "Groundwater",
        "Phylogeny",
        "RNA, Ribosomal, 16S",
        "Sequence Analysis, DNA" ;
    schema1:license "GPL-3.0" ;
    schema1:name "emirge" ;
    schema1:url "https://github.com/csmiller/EMIRGE" .

