@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-metagenomeseq a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.2658" ;
    schema1:description "Statistical analysis for sparse high-throughput sequencing" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/metagenomeSeq_1.52.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/metagenomeSeq/metagenomeSeq_1.52.0.tar.gz', 'https://bioarchive.galaxyproject.org/metagenomeSeq_1.52.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-metagenomeseq/bioconductor-metagenomeseq_1.52.0_src_all.tar.gz']" ;
    schema1:identifier biotools:metagenomeseq ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-metagenomeseq" ;
    schema1:softwareVersion "1.52.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/metagenomeSeq.html" ;
    spdx:builtFrom biotools:metagenomeseq .

