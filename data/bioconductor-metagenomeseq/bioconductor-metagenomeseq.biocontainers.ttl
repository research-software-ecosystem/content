@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-metagenomeseq a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.2658" ;
    schema1:description "Designed to determine features (be it operational taxanomic unit (otu), species, etc.) that are differentially abundant between two or more groups of multiple samples. it is designed to address the effects of both normalization and under-sampling of microbial communities on disease association detection and the testing of feature correlations." ;
    schema1:identifier biotools:metagenomeseq ;
    schema1:keywords "Animals",
        "Area Under Curve",
        "Cluster Analysis",
        "Clustering",
        "Computer Simulation",
        "Databases, Genetic",
        "Gene Expression Profiling",
        "Genetic Markers",
        "Genetic Variation",
        "Genomics",
        "Humans",
        "Intestines",
        "Metagenome",
        "Metagenomics",
        "Mice",
        "Microbiota",
        "Models, Genetic",
        "Models, Statistical",
        "Normal Distribution",
        "Phenotype",
        "RNA, Ribosomal, 16S",
        "Sequence Analysis, DNA",
        "Sequencing" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-metagenomeseq" ;
    schema1:url "http://bioconductor.org/packages/release/bioc/html/metagenomeSeq.html" .

