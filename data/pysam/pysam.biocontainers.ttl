@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:pysam a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btp352" ;
    schema1:description "Pysam is a python module for reading and manipulating Samfiles. It is a lightweight wrapper of the samtools C-API. Pysam also includes an interface for tabix." ;
    schema1:identifier biotools:pysam ;
    schema1:keywords "Base Sequence",
        "Computational Biology",
        "Genome",
        "Genomics",
        "Mapping",
        "Molecular Sequence Data",
        "Sequence Alignment",
        "Sequence Analysis, DNA",
        "Sequencing" ;
    schema1:license "MIT" ;
    schema1:name "pysam" ;
    schema1:url "https://github.com/pysam-developers/pysam" .

