@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:pysam a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btp352" ;
    schema1:description "Pysam is a Python module for reading and manipulating SAM/BAM/VCF/BCF files. It's a lightweight wrapper of the htslib C-API, the same one that powers samtools, bcftools, and tabix." ;
    schema1:downloadUrl "https://github.com/pysam-developers/pysam/archive/v0.23.3.tar.gz" ;
    schema1:identifier biotools:pysam ;
    schema1:license "MIT" ;
    schema1:name "pysam" ;
    schema1:softwareVersion "0.23.3" ;
    schema1:url "https://github.com/pysam-developers/pysam" ;
    spdx:builtFrom biotools:pysam .

