@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:octopus a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btn221" ;
    schema1:description "Octopus is a mapping-based variant caller that implements several calling models within a unified haplotype-aware framework." ;
    schema1:identifier biotools:octopus ;
    schema1:keywords "Amino Acid Sequence",
        "Computer Simulation",
        "Genomics",
        "Membrane Proteins",
        "Models, Chemical",
        "Models, Molecular",
        "Molecular Sequence Data",
        "Neural Networks, Computer",
        "Pattern Recognition, Automated",
        "Protein Conformation",
        "Reproducibility of Results",
        "Semantics",
        "Sensitivity and Specificity",
        "Sequence Analysis, Protein",
        "Sequence analysis" ;
    schema1:license "MIT" ;
    schema1:name "octopus" ;
    schema1:url "https://github.com/luntergroup/octopus" .

