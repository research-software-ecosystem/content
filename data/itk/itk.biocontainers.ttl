@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:itk a schema1:SoftwareApplication ;
    schema1:description "ITK is an open-source toolkit for multidimensional image analysis" ;
    schema1:license "Apache-2.0" ;
    schema1:name "itk" ;
    schema1:url "https://itk.org/" .

