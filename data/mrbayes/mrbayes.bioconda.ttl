@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:mrbayes a schema1:SoftwareApplication ;
    schema1:description "Bayesian Inference of Phylogeny" ;
    schema1:downloadUrl "https://github.com/NBISweden/MrBayes/archive/v3.2.7.tar.gz" ;
    schema1:identifier biotools:mrbayes ;
    schema1:license "GPL-3.0-or-later" ;
    schema1:name "mrbayes" ;
    schema1:softwareHelp "https://nbisweden.github.io/MrBayes/" ;
    schema1:softwareVersion "3.2.7" ;
    schema1:url "https://github.com/NBISweden/MrBayes" ;
    spdx:builtFrom biotools:mrbayes .

