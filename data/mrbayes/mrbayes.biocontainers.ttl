@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:mrbayes a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/17.8.754" ;
    schema1:description "Bayesian inference of phylogeny" ;
    schema1:identifier biotools:mrbayes ;
    schema1:keywords "Bayes Theorem",
        "Computational Biology",
        "Genetics",
        "Markov Chains",
        "Phylogenetics",
        "Phylogeny" ;
    schema1:license "GPL-3.0" ;
    schema1:name "mrbayes" ;
    schema1:url "https://github.com/NBISweden/MrBayes" .

