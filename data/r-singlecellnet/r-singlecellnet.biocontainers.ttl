@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-singlecellnet a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1016/j.cels.2019.06.004" ;
    schema1:description "Singlecellnet enables the classifcation of single cell rna-seq data across species and platforms." ;
    schema1:keywords "Animals",
        "Computational Biology",
        "Gene Expression Profiling",
        "High-Throughput Nucleotide Sequencing",
        "Humans",
        "Ortholog",
        "RNA",
        "RNA-Seq",
        "Sensitivity and Specificity",
        "Sequence Analysis, RNA",
        "Whole Exome Sequencing" ;
    schema1:license "MIT" ;
    schema1:name "r-singlecellnet" ;
    schema1:url "https://github.com/pcahan1/singlecellnet" .

