@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:treesapp a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btaa588" ;
    schema1:description "TreeSAPP is a functional and taxonomic annotation tool for microbial genomes and proteins" ;
    schema1:keywords "Genetics",
        "Genomics",
        "Metagenome",
        "Ortholog",
        "Phylogenetics",
        "Sequence Alignment" ;
    schema1:license "GPL-3.0" ;
    schema1:name "treesapp" ;
    schema1:url "https://github.com/hallamlab/TreeSAPP" .

