@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:soapsnp a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1101/gr.088013.108" ;
    schema1:description "Accurate consensus sequence builder based on soap1 and soapaligner/soap2's alignment output. it calculates a quality score for each consensus base, which can be used for any latter process to call snps." ;
    schema1:identifier biotools:soapsnp ;
    schema1:keywords "Asian Continental Ancestry Group",
        "Chromosomes, Human, X",
        "Computational Biology",
        "DNA polymorphism",
        "Genetics, Population",
        "Genome, Human",
        "Genotype",
        "Human biology",
        "Humans",
        "Likelihood Functions",
        "Models, Genetic",
        "Models, Statistical",
        "Polymorphism, Single Nucleotide",
        "Probability",
        "Reproducibility of Results",
        "Sequence Analysis, DNA",
        "Sequence assembly" ;
    schema1:license "GPL-3.0+" ;
    schema1:name "soapsnp" ;
    schema1:url "http://soap.genomics.org.cn/soapsnp.html" .

