@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:pynast a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btp636" ;
    schema1:description "The python nearest alignment space termination tool" ;
    schema1:keywords "Databases, Genetic",
        "Sequence Alignment",
        "Sequence Analysis, RNA",
        "User-Computer Interface" ;
    schema1:license "GPL-2.0" ;
    schema1:name "pynast" ;
    schema1:url "https://github.com/biocore/qiime" .

