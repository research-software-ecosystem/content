@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-mqtl.nmr a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18129/b9.bioc.mqtl.nmr" ;
    schema1:description "mQTL.NMR provides a complete mQTL analysis pipeline for 1H NMR data. Distinctive features include normalisation using most-used approaches, peak alignment using RSPA approach, dimensionality reduction using SRV and binning approaches, and mQTL analysis for animal and human cohorts." ;
    schema1:keywords "Genetics",
        "Metabolomics" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-mqtl.nmr" ;
    schema1:url "http://bioconductor.org/packages/3.6/bioc/html/mQTL.NMR.html" .

