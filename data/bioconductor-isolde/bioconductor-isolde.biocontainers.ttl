@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-isolde a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Integrative Statistics of alleLe Dependent Expression" ;
    schema1:identifier biotools:isolde ;
    schema1:keywords "Computational Biology",
        "Gene Expression Profiling",
        "Genetics",
        "Genomics",
        "High-Throughput Screening Assays",
        "Programming Languages",
        "RNA-Seq",
        "Sequencing",
        "User-Computer Interface" ;
    schema1:license "GPL (>= 2.0)" ;
    schema1:name "bioconductor-isolde" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/ISoLDE.html" .

