@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:nextpolish a schema1:SoftwareApplication ;
    schema1:author "rpetit3" ;
    schema1:citation "doi:10.1093/bioinformatics/btz891" ;
    schema1:description "Fast and accurately polish the genome generated by noisy long reads." ;
    schema1:identifier biotools:NextPolish ;
    schema1:license "GPL-3.0-or-later" ;
    schema1:maintainer "rpetit3" ;
    schema1:name "nextpolish" ;
    schema1:softwareHelp "https://nextpolish.readthedocs.io/en/latest" ;
    schema1:softwareVersion "1.4.1" ;
    schema1:url "https://github.com/Nextomics/NextPolish" ;
    spdx:builtFrom biotools:NextPolish .

