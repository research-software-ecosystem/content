@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:mercat a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1016/J.MEEGID.2019.104043" ;
    schema1:description "Mercat: a versatile counter and diversity estimator for data base independent property analysis obtained from whole community sequencing data." ;
