@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-biocgraph a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Graph examples and use cases in Bioinformatics" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/biocGraph_1.72.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/biocGraph/biocGraph_1.72.0.tar.gz', 'https://bioarchive.galaxyproject.org/biocGraph_1.72.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-biocgraph/bioconductor-biocgraph_1.72.0_src_all.tar.gz']" ;
    schema1:identifier biotools:biocgraph ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-biocgraph" ;
    schema1:softwareVersion "1.72.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/biocGraph.html" ;
    spdx:builtFrom biotools:biocgraph .

