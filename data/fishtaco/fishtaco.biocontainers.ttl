@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:fishtaco a schema1:SoftwareApplication ;
    schema1:description "Fishtaco: a metagenomic computational framework, aiming to identify the taxa that are driving functional shifts in microbiomes." ;
    schema1:license "FishTaco Software License" ;
    schema1:name "fishtaco" ;
    schema1:url "https://github.com/borenstein-lab/fishtaco/" .

