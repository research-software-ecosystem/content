@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:metavelvet a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/gks678" ;
    schema1:description "Metavelvet : an extension of velvet assembler to de novo metagenome assembly from short sequence reads" ;
    schema1:identifier biotools:metavelvet ;
    schema1:keywords "Assembly",
        "Bacteria",
        "Gastrointestinal Tract",
        "Genome, Bacterial",
        "Genomics",
        "Humans",
        "Metagenome",
        "Metagenomics",
        "Sequence Analysis, DNA" ;
    schema1:license "GPL-2.0" ;
    schema1:name "metavelvet" ;
    schema1:url "http://metavelvet.dna.bio.keio.ac.jp" .

