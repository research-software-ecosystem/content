@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:slimfastq a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1371/journal.pone.0059190" ;
    schema1:description "slimfastq would efficiently compresses/decompresses fastq files" ;
    schema1:keywords "Computational Biology",
        "Data Compression",
        "Sequence Analysis, DNA" ;
    schema1:license "BSD-3" ;
    schema1:name "slimfastq" ;
    schema1:url "https://github.com/Infinidat/slimfastq" .

