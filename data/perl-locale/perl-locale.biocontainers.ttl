@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:perl-locale a schema1:SoftwareApplication ;
    schema1:description "Perl pragma to use or avoid posix locales for built-in operations" ;
    schema1:license "perl_5" ;
    schema1:name "perl-locale" ;
    schema1:url "http://metacpan.org/pod/locale" .

