@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:syri a schema1:SoftwareApplication ;
    schema1:author "mnshgl0110" ;
    schema1:citation "doi:10.1186/s13059-019-1911-0" ;
    schema1:description "Synteny and rearrangement identifier between whole-genome assemblies." ;
    schema1:downloadUrl "https://github.com/schneebergerlab/syri/archive/refs/tags/v1.7.1.tar.gz" ;
    schema1:identifier biotools:SyRI ;
    schema1:license "MIT" ;
    schema1:maintainer "mnshgl0110" ;
    schema1:name "syri" ;
    schema1:softwareHelp "https://schneebergerlab.github.io/syri" ;
    schema1:softwareVersion "1.7.1" ;
    schema1:url "https://github.com/schneebergerlab/syri" ;
    spdx:builtFrom biotools:SyRI .

