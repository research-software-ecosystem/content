@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:mummer4 a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1371/journal.pcbi.1005944" ;
    schema1:description "MUMmer is a system for rapidly aligning entire genomes." ;
    schema1:downloadUrl "https://github.com/mummer4/mummer/releases/download/v4.0.1/mummer-4.0.1.tar.gz" ;
    schema1:identifier biotools:mummer4 ;
    schema1:license "Artistic License 2.0" ;
    schema1:name "mummer4" ;
    schema1:softwareHelp "https://github.com/mummer4/mummer/blob/v4.0.1/README.md" ;
    schema1:softwareVersion "4.0.1" ;
    schema1:url "https://mummer4.github.io" ;
    spdx:builtFrom biotools:mummer4 .

