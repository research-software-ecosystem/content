@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-quaternaryprod a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/gks1094" ;
    schema1:description "Computes the Quaternary Dot Product Scoring Statistic for Signed and Unsigned Causal Graphs" ;
    schema1:identifier biotools:quaternaryprod ;
    schema1:keywords "Data Interpretation, Statistical",
        "Data Mining",
        "Databases, Protein",
        "Internet",
        "Molecular interactions, pathways and networks",
        "Protein Interaction Mapping",
        "Systems Integration",
        "User-Computer Interface" ;
    schema1:license "GPL (>=3)" ;
    schema1:name "bioconductor-quaternaryprod" ;
    schema1:url "http://bioconductor.org/packages/3.6/bioc/html/QuaternaryProd.html" .

