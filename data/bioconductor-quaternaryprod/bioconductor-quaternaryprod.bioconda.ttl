@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-quaternaryprod a schema1:SoftwareApplication ;
    schema1:description "Computes the Quaternary Dot Product Scoring Statistic for Signed and Unsigned Causal Graphs" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/QuaternaryProd_1.40.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/QuaternaryProd/QuaternaryProd_1.40.0.tar.gz', 'https://bioarchive.galaxyproject.org/QuaternaryProd_1.40.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-quaternaryprod/bioconductor-quaternaryprod_1.40.0_src_all.tar.gz']" ;
    schema1:identifier biotools:quaternaryprod ;
    schema1:license "GPL (>=3)" ;
    schema1:name "bioconductor-quaternaryprod" ;
    schema1:softwareVersion "1.40.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/QuaternaryProd.html" ;
    spdx:builtFrom biotools:quaternaryprod .

