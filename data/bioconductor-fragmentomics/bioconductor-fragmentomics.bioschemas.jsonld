    {
      "@id": "https://bio.tools/bioconductor-fragmentomics",
      "@type": "sc:SoftwareApplication",
      "dcterms:conformsTo": "https://bioschemas.org/profiles/ComputationalTool/0.6-DRAFT",
      "sc:additionalType": [
        "Library",
        "Command-line tool"
      ],
      "sc:author": [
        "Killian Maudet",
        "Elsa Bernard",
        "Yoann Pradat",
        "Juliette Samaniego"
      ],
      "sc:citation": {
        "@id": "https://doi.org/10.18129/B9.bioc.fRagmentomics"
      },
      "sc:description": "A user-friendly R package that enables the characterization of each cfDNA fragment overlapping one or multiple mutations of interest, starting from a sequencing file containing aligned reads (BAM file). fRagmentomics supports multiple mutation input formats (e.g., VCF, TSV, or string \"chr:pos:ref:alt\" representation), accommodates one-based and zero-based genomic conventions, handles mutation representation ambiguities, and accepts any reference file and species in FASTA format. For each cfDNA fragment, fRagmentomics outputs its size, its 3' and 5' sequences, and its mutational status. Optionally, when users set apply_bcftools_norm = TRUE, fRagmentomics invokes the external command-line tool bcftools norm to left-align and normalize variants. If bcftools is not found on the system PATH while this option is enabled, the function errors. The package does not install external software; see the INSTALL file for per-OS instructions.",
      "sc:license": "GPL-3.0-or-later",
      "sc:name": "fRagmentomics",
      "sc:operatingSystem": [
        "Windows",
        "Mac",
        "Linux"
      ],
      "sc:softwareHelp": {
        "@id": "https://bioconductor.org/packages/fRagmentomics"
      },
      "sc:softwareVersion": "1.0.0",
      "sc:url": "https://bioconductor.org/packages/fRagmentomics"
    }
  ]
