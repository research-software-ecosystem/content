@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:pipelign a schema1:SoftwareApplication ;
    schema1:description "A pipeline for automated multiple sequence alignment, particularly of viral sequences." ;
    schema1:keywords "Clustering",
        "Sequence Alignment" ;
    schema1:license "MIT" ;
    schema1:name "pipelign" ;
    schema1:url "https://github.com/asmmhossain/pipelign/" .

