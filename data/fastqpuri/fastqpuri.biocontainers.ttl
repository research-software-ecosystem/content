@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:fastqpuri a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s12859-019-2799-0" ;
    schema1:description "fastq quality assessment and filtering tool" ;
    schema1:keywords "High-Throughput Nucleotide Sequencing",
        "Humans",
        "Sequence Analysis, RNA" ;
    schema1:license "GPL-3.0.0" ;
    schema1:name "fastqpuri" ;
    schema1:url "https://github.com/jengelmann/FastqPuri" .

