@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:gffread a schema1:SoftwareApplication ;
    schema1:citation "doi:10.12688/f1000research.23297.2" ;
    schema1:description "GFF/GTF utility providing format conversions, region filtering, FASTA sequence extraction and more." ;
    schema1:downloadUrl "https://github.com/gpertea/gffread/releases/download/v0.12.9/gffread-0.12.9.tar.gz" ;
    schema1:identifier biotools:gffread ;
    schema1:license "MIT" ;
    schema1:name "gffread" ;
    schema1:softwareHelp "https://ccb.jhu.edu/software/stringtie/gff.shtml#gffread" ;
    schema1:softwareVersion "0.12.9" ;
    schema1:url "https://ccb.jhu.edu/software/stringtie/gff.shtml" ;
    spdx:builtFrom biotools:gffread .

