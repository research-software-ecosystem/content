@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:gimmemotifs a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btq636" ;
    schema1:description "Motif prediction pipeline and various motif-related tools" ;
    schema1:identifier biotools:gimmemotifs ;
    schema1:keywords "Animals",
        "Binding Sites",
        "ChIP-seq",
        "Chromatin Immunoprecipitation",
        "Computational Biology",
        "Epigenomics",
        "Gene regulation",
        "Humans",
        "Mice",
        "Sequence Analysis, DNA",
        "Transcription Factors" ;
    schema1:license "MIT" ;
    schema1:name "gimmemotifs" ;
    schema1:url "https://github.com/vanheeringen-lab/gimmemotifs" .

