@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:gimmemotifs a schema1:SoftwareApplication ;
    schema1:author "siebrenf",
        "simonvh" ;
    schema1:citation "doi:10.1093/bioinformatics/btq636",
        "doi:10.1101/474403" ;
    schema1:description "Motif prediction pipeline and various motif-related tools." ;
    schema1:downloadUrl "https://github.com/vanheeringen-lab/gimmemotifs/releases/download/0.18.2/gimmemotifs-0.18.2.tar.gz" ;
    schema1:identifier biotools:gimmemotifs ;
    schema1:license "MIT" ;
    schema1:maintainer "siebrenf",
        "simonvh" ;
    schema1:name "gimmemotifs" ;
    schema1:softwareHelp "https://gimmemotifs.readthedocs.io/en/master" ;
    schema1:softwareVersion "0.18.2" ;
    schema1:url "https://github.com/vanheeringen-lab/gimmemotifs" ;
    spdx:builtFrom biotools:gimmemotifs .

