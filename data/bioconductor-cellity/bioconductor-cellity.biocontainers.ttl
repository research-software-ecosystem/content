@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-cellity a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18129/b9.bioc.cellity" ;
    schema1:description "Quality Control for Single-Cell RNA-seq Data" ;
    schema1:keywords "RNA-Seq",
        "Transcriptomics" ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-cellity" ;
    schema1:url "https://bioconductor.org/packages/3.8/bioc/html/cellity.html" .

