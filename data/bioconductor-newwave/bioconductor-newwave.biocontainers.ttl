@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-newwave a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18129/b9.bioc.newwave" ;
    schema1:description "A model designed for dimensionality reduction and batch effect removal for scRNA-seq data. It is designed to be massively parallelizable using shared objects that prevent memory duplication, and it can be used with different mini-batch approaches in order to reduce time consumption. It assumes a negative binomial distribution for the data with a dispersion parameter that can be both commonwise across gene both genewise." ;
    schema1:keywords "RNA-Seq",
        "Transcriptomics" ;
    schema1:license "GPL-3.0" ;
    schema1:name "bioconductor-newwave" ;
    schema1:url "https://bioconductor.org/packages/3.12/bioc/html/NewWave.html" .

