        "HIV Reverse Transcriptase",
        "HIV-1",
        "Humans",
        "Sequence Alignment" ;
    schema1:license "MIT" ;
    schema1:name "nucamino" ;
    schema1:url "https://github.com/hivdb/nucamino" .

