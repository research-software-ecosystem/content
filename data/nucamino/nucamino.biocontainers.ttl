biocontainers:nucamino a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s12859-017-1555-6" ;
    schema1:description "A nucleotide to amino acid alignment program optimized for virus gene sequences" ;
    schema1:keywords "Amino Acid Sequence",
        "Base Sequence",
        "HIV Integrase",
