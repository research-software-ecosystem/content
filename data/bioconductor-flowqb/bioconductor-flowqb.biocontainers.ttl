@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-flowqb a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18129/b9.bioc.flowqb" ;
    schema1:description "Flowqb is a fully automated r bioconductor package to calculate automatically the detector efficiency (q), optical background (b) and intrinsic cv of the beads." ;
    schema1:license "Not available" ;
    schema1:name "bioconductor-flowqb" ;
    schema1:url "https://bioconductor.org/packages/3.9/bioc/html/flowQB.html" .

