@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:w4mclassfilter a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1021/ac051437y",
        "doi:10.1093/bioinformatics/btu813" ;
    schema1:description "Filter workflow4metabolomics feature list, optionally imputing na values." ;
    schema1:keywords "Computational Biology",
        "Mass spectrometry",
        "Metabolomics",
        "Workflow" ;
    schema1:license "Custom License" ;
    schema1:name "w4mclassfilter" ;
    schema1:url "https://github.com/HegemanLab/w4mclassfilter" .

