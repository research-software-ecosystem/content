@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:faststructure a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1534/genetics.114.164350" ;
    schema1:description "A variational framework for inferring population structure from SNP genotype data." ;
    schema1:identifier biotools:faststructure ;
    schema1:keywords "Bayes Theorem",
        "Genetics",
        "Genetics, Population",
        "Genome, Human",
        "Genotype",
        "Humans",
        "Models, Genetic",
        "Polymorphism, Single Nucleotide",
        "Population genetics" ;
    schema1:license "MIT" ;
    schema1:name "faststructure" ;
    schema1:url "https://github.com/rajanil/fastStructure" .

