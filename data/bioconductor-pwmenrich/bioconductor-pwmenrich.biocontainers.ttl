@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-pwmenrich a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "PWM enrichment analysis" ;
    schema1:identifier biotools:pwmenrich ;
    schema1:keywords "Computational Biology",
        "Gene Expression Profiling",
        "Genomics",
        "High-Throughput Screening Assays",
        "Nucleic acid sites, features and motifs",
        "Nucleic acid structure analysis",
        "Programming Languages",
        "User-Computer Interface" ;
    schema1:license "LGPL (>= 2)" ;
    schema1:name "bioconductor-pwmenrich" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/PWMEnrich.html" .

