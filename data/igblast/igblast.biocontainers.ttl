@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:igblast a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/gkt382" ;
    schema1:description "A tool for analyzing immunoglobulin (IG) and T cell receptor (TR) sequences" ;
    schema1:identifier biotools:igblast ;
    schema1:keywords "Gene transcripts",
        "Humans",
        "Immunoglobulin Variable Region",
        "Immunoproteins, genes and antigens",
        "Internet",
        "Protein Sequences",
        "Sequence Alignment",
        "Sequence Analysis, DNA",
        "Sequence Analysis, Protein",
        "Sequence analysis",
        "Sequence assembly",
        "Sequencing",
        "V(D)J Recombination" ;
    schema1:license "Public Domain and others" ;
    schema1:name "igblast" ;
    schema1:url "http://www.ncbi.nlm.nih.gov/projects/igblast/" .

