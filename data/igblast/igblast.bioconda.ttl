@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:igblast a schema1:SoftwareApplication ;
    schema1:description "A tool for analyzing immunoglobulin (IG) and T cell receptor (TR) sequences" ;
    schema1:downloadUrl "ftp://ftp.ncbi.nih.gov/blast/executables/igblast/release/1.22.0/ncbi-igblast-1.22.0-src.tar.gz" ;
    schema1:identifier biotools:igblast ;
    schema1:license "Public Domain and others" ;
    schema1:name "igblast" ;
    schema1:softwareVersion "1.22.0" ;
    schema1:url "http://www.ncbi.nlm.nih.gov/projects/igblast/" ;
    spdx:builtFrom biotools:igblast .

