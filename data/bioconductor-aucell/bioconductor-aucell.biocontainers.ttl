@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-aucell a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18129/b9.bioc.aucell" ;
    schema1:description "AUCell: Analysis of 'gene set' activity in single-cell RNA-seq data (e.g. identify cells with specific gene signatures)" ;
    schema1:keywords "Gene Expression",
        "RNA-Seq",
        "Transcriptomics" ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-aucell" ;
    schema1:url "https://bioconductor.org/packages/3.8/bioc/html/AUCell.html" .

