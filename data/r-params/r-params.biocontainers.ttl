@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-params a schema1:SoftwareApplication ;
    schema1:description "An interface to simplify organizing parameters used in a package, using external configuration files. This attempts to provide a cleaner alternative to options()." ;
    schema1:license "GPL-2" ;
    schema1:name "r-params" ;
    schema1:url "None" .

