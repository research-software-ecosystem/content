@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:fast5 a schema1:SoftwareApplication ;
    schema1:description "A c++ header-only library for reading oxford nanopore fast5 files." ;
    schema1:license "MIT" ;
    schema1:name "fast5" ;
    schema1:url "https://github.com/mateidavid/fast5" .

