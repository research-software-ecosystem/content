@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-ropls a schema1:SoftwareApplication ;
    schema1:description "PCA, PLS(-DA) and OPLS(-DA) for multivariate analysis and feature selection of omics data" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/ropls_1.42.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/ropls/ropls_1.42.0.tar.gz', 'https://bioarchive.galaxyproject.org/ropls_1.42.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-ropls/bioconductor-ropls_1.42.0_src_all.tar.gz']" ;
    schema1:identifier biotools:ropls ;
    schema1:license "CeCILL" ;
    schema1:name "bioconductor-ropls" ;
    schema1:softwareVersion "1.42.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/ropls.html" ;
    spdx:builtFrom biotools:ropls .

