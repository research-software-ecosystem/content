@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-helloranges a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Introduce *Ranges to bedtools users" ;
    schema1:identifier biotools:helloranges ;
    schema1:keywords "Computational Biology",
        "Gene Expression Profiling",
        "Genomics",
        "High-Throughput Screening Assays",
        "Informatics",
        "Programming Languages",
        "User-Computer Interface" ;
    schema1:license "GPL-2.0" ;
    schema1:name "bioconductor-helloranges" ;
    schema1:url "https://www.bioconductor.org/packages/release/bioc/html/helloranges.html" .

