@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-helloranges a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Introduce *Ranges to bedtools users" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/HelloRanges_1.32.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/HelloRanges/HelloRanges_1.32.0.tar.gz', 'https://bioarchive.galaxyproject.org/HelloRanges_1.32.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-helloranges/bioconductor-helloranges_1.32.0_src_all.tar.gz']" ;
    schema1:identifier biotools:helloranges ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-helloranges" ;
    schema1:softwareVersion "1.32.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/HelloRanges.html" ;
    spdx:builtFrom biotools:helloranges .

