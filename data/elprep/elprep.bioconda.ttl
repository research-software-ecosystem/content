@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:elprep a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1371/journal.pone.0244471" ;
    schema1:description "elPrep is a high-performance tool for preparing .sam/.bam files for variant calling in sequencing pipelines. It can be used as a drop-in replacement for SAMtools/Picard/GATK4." ;
    schema1:downloadUrl "https://github.com/ExaScience/elprep/archive/refs/tags/v5.1.3.tar.gz" ;
    schema1:identifier biotools:Elprep ;
    schema1:license "AGPL-3.0-only" ;
    schema1:name "elprep" ;
    schema1:softwareVersion "5.1.3" ;
    schema1:url "https://github.com/ExaScience/elprep" ;
    spdx:builtFrom biotools:Elprep .

