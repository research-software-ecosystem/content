@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:transvar a schema1:SoftwareApplication ;
    schema1:description "Transcript-based variant annotator." ;
    schema1:downloadUrl "https://pypi.org/packages/source/t/transvar/TransVar-2.5.10.20211024.tar.gz" ;
    schema1:identifier biotools:transvar ;
    schema1:license "MIT" ;
    schema1:name "transvar" ;
    schema1:softwareHelp "https://transvar.readthedocs.io" ;
    schema1:softwareVersion "2.5.10.20211024" ;
    schema1:url "https://github.com/zwdzwd/transvar" ;
    spdx:builtFrom biotools:transvar .

