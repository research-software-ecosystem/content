@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:fastani a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/s41467-018-07641-9" ;
    schema1:description "FastANI is developed for fast alignment-free computation of whole-genome Average Nucleotide Identity (ANI)." ;
    schema1:downloadUrl "https://github.com/ParBLiSS/FastANI/archive/v1.34.tar.gz" ;
    schema1:identifier biotools:fastani ;
    schema1:license "Apache-2.0" ;
    schema1:name "fastani" ;
    schema1:softwareHelp "https://github.com/ParBLiSS/FastANI/blob/v1.34/README.md" ;
    schema1:softwareVersion "1.34" ;
    schema1:url "https://github.com/ParBLiSS/FastANI" ;
    spdx:builtFrom biotools:fastani .

