@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-derfinderhelper a schema1:SoftwareApplication ;
    schema1:description "derfinder helper package" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/derfinderHelper_1.40.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/derfinderHelper/derfinderHelper_1.40.0.tar.gz', 'https://bioarchive.galaxyproject.org/derfinderHelper_1.40.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-derfinderhelper/bioconductor-derfinderhelper_1.40.0_src_all.tar.gz']" ;
    schema1:identifier biotools:derfinderhelper ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-derfinderhelper" ;
    schema1:softwareVersion "1.40.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/derfinderHelper.html" ;
    spdx:builtFrom biotools:derfinderhelper .

