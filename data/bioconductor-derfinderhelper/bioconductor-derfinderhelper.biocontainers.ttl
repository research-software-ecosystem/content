@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-derfinderhelper a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/gkw852" ;
    schema1:description "Helper package for speeding up the derfinder package when using multiple cores." ;
    schema1:identifier biotools:derfinderhelper ;
    schema1:keywords "Gene Expression Profiling",
        "Gene Expression Regulation",
        "Genomics",
        "High-Throughput Nucleotide Sequencing",
        "Molecular Sequence Annotation",
        "Organ Specificity",
        "Software engineering",
        "Transcriptome",
        "Web Browser" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-derfinderhelper" ;
    schema1:url "http://bioconductor.org/packages/release/bioc/html/derfinderHelper.html" .

