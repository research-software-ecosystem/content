@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-bioqc a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s12864-017-3661-2" ;
    schema1:description "Detect tissue heterogeneity in expression profiles with gene sets" ;
    schema1:identifier biotools:bioqc ;
    schema1:keywords "Animals",
        "Data quality management",
        "Dogs",
        "Gene Expression",
        "Gene Expression Profiling",
        "Gene expression",
        "Humans",
        "Mice",
        "Organ Specificity",
        "Reproducibility of Results",
        "Transcriptome" ;
    schema1:license "GPL (>=3)" ;
    schema1:name "bioconductor-bioqc" ;
    schema1:url "http://bioconductor.org/packages/3.6/bioc/html/BioQC.html" .

