@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-bioqc a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s12864-017-3661-2" ;
    schema1:description "Detect tissue heterogeneity in expression profiles with gene sets" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/BioQC_1.34.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/BioQC/BioQC_1.34.0.tar.gz', 'https://bioarchive.galaxyproject.org/BioQC_1.34.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-bioqc/bioconductor-bioqc_1.34.0_src_all.tar.gz']" ;
    schema1:identifier biotools:bioqc ;
    schema1:license "GPL (>=3) + file LICENSE" ;
    schema1:name "bioconductor-bioqc" ;
    schema1:softwareVersion "1.34.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/BioQC.html" ;
    spdx:builtFrom biotools:bioqc .

