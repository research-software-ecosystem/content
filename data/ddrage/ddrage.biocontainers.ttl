@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:ddrage a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1111/1755-0998.12743" ;
    schema1:description "Simulator for ddradseq (double digest restriction site associated dna sequencing) datasets. generates reads (fastq format) that can be analyzed and validated using a ground truth file (yaml)." ;
    schema1:keywords "Computer Simulation",
        "Datasets as Topic",
        "Models, Genetic",
        "Models, Theoretical",
        "Sequence Analysis" ;
    schema1:license "MIT" ;
    schema1:name "ddrage" ;
    schema1:url "https://bitbucket.org/genomeinformatics/rage" .

