@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:dagchainer a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/bth397" ;
    schema1:description "DAGchainer identifies syntenic regions." ;
    schema1:keywords "Arabidopsis",
        "Chromosome Mapping",
        "Conserved Sequence",
        "Gene Duplication",
        "Sequence Alignment",
        "Sequence Analysis, DNA",
        "Sequence Homology, Nucleic Acid" ;
    schema1:license "MIT" ;
    schema1:name "dagchainer" ;
    schema1:url "https://github.com/kullrich/dagchainer" .

