@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:neptune a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/NAR/GKX702" ;
    schema1:description "Neptune: genomic signature discovery" ;
    schema1:identifier biotools:neptune ;
    schema1:keywords "Bacillus anthracis",
        "Bacteria",
        "Computational Biology",
        "DNA Mutational Analysis",
        "Gene Expression Regulation, Bacterial",
        "Genetic Association Studies",
        "Genetic variation",
        "Genome, Bacterial",
        "Genomics",
        "Genotype and phenotype",
        "Machine learning",
        "Microbiological Techniques",
        "Sequence Analysis, DNA",
        "Transcriptome",
        "Vibrio cholerae" ;
    schema1:license "Apache-2.0" ;
    schema1:name "neptune" ;
    schema1:url "https://github.com/phac-nml/neptune" .

