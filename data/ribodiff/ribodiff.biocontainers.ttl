@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:ribodiff a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btw585" ;
    schema1:description "Ribodiff is a statistical tool that detects the protein translational efficiency change from ribo-seq (ribosome footprinting) and rna-seq data." ;
    schema1:keywords "Gene Expression Regulation",
        "High-Throughput Nucleotide Sequencing",
        "Protein Biosynthesis",
        "RNA, Messenger",
        "RNA-Seq",
        "Ribosomes",
        "Sequence Analysis, RNA" ;
    schema1:license "GPL-3.0" ;
    schema1:name "ribodiff" ;
    schema1:url "http://public.bmi.inf.ethz.ch/user/zhongy/RiboDiff/index.html" .

