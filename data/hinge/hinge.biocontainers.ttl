@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:hinge a schema1:SoftwareApplication ;
    schema1:description "Long read genome assembler based on hinging" ;
    schema1:license "BSD-3-Clause/HINGE" ;
    schema1:name "hinge" ;
    schema1:url "https://github.com/HingeAssembler/HINGE" .

