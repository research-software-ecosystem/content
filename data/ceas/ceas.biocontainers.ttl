@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:ceas a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/gkl322" ;
    schema1:description "Cis-regulatory element annotation system (ceas) is a resource for chip-chip analyses that retrieves repeat-masked genomic sequences, calculates gc content, plots evolutionary conservation, maps nearby genes, and identifies enriched transcription factor binding (tfbs) motifs." ;
    schema1:identifier biotools:ceas ;
    schema1:keywords "Binding Sites",
        "ChIP-on-chip",
        "Chromatin Immunoprecipitation",
        "Gene expression",
        "Gene transcripts",
        "Genome, Human",
        "Genomics",
        "Humans",
        "Internet",
        "Mapping",
        "Oligonucleotide Array Sequence Analysis",
        "Regulatory Elements, Transcriptional",
        "Transcription Factors",
        "Transcription factors and regulatory sites",
        "User-Computer Interface" ;
    schema1:license "Artistic" ;
    schema1:name "ceas" ;
    schema1:url "http://ceas.cbi.pku.edu.cn" .

