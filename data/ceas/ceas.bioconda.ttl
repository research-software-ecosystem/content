@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:ceas a schema1:SoftwareApplication ;
    schema1:description "CEAS: Cis-regulatory Element Annotation System" ;
    schema1:downloadUrl "http://liulab.dfci.harvard.edu/CEAS/src/CEAS-Package-1.0.2.tar.gz" ;
    schema1:identifier biotools:ceas ;
    schema1:license "Artistic" ;
    schema1:name "ceas" ;
    schema1:softwareVersion "1.0.2" ;
    schema1:url "http://liulab.dfci.harvard.edu/CEAS" ;
    spdx:builtFrom biotools:ceas .

