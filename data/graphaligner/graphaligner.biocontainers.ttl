@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:graphaligner a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1101/810812",
        "doi:10.1186/s13059-020-02157-2" ;
    schema1:description "Sequence to graph aligner for long reads" ;
    schema1:license "MIT" ;
    schema1:name "graphaligner" ;
    schema1:url "https://github.com/maickrau/GraphAligner" .

