@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:python-tripal a schema1:SoftwareApplication ;
    schema1:description "Tripal API library" ;
    schema1:downloadUrl "https://files.pythonhosted.org/packages/df/0f/74f673fd20ff1dd6b26606dac6c2c8f2935df88c6fb6702ab81cd7bd0c86/tripal-3.2.1.tar.gz" ;
    schema1:identifier biotools:tripal ;
    schema1:license "MIT License" ;
    schema1:name "python-tripal" ;
    schema1:softwareVersion "3.2.1" ;
    schema1:url "https://github.com/galaxy-genome-annotation/python-tripal" ;
    spdx:builtFrom biotools:tripal .

