        "Databases, Protein",
        "Fungal Proteins",
        "Gene Expression Regulation, Fungal",
        "Genomics",
        "Models, Biological",
        "Molecular interactions, pathways and networks",
        "Protein Interaction Mapping",
        "Protein interactions",
        "Proteins",
        "Proteome",
        "Proteomics",
        "Regression Analysis",
        "Reproducibility of Results",
        "Saccharomyces cerevisiae",
        "Stochastic Processes" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-ppistats" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/ppiStats.html" .

