@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:batman a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nbt1414" ;
    schema1:description "Bayesian Automated Metabolite Analyser for NMR spectra (BATMAN)." ;
    schema1:identifier biotools:batman ;
    schema1:keywords "Base Sequence",
        "Bayes Theorem",
        "Chromatin Immunoprecipitation",
        "Chromosome Mapping",
        "DNA",
        "DNA Methylation",
        "Epigenetics",
        "Metabolomics",
        "Molecular Sequence Data",
        "Pattern Recognition, Automated",
        "Sequence Analysis, DNA" ;
    schema1:license "GPL-2.0" ;
    schema1:name "batman" ;
    schema1:url "https://github.com/phnmnl/container-batman" .

