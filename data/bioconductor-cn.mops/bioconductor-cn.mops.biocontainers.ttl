@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-cn.mops a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/gks003" ;
    schema1:description "cn.mops - Mixture of Poissons for CNV detection in NGS data" ;
    schema1:identifier biotools:cn.mops ;
    schema1:keywords "Chromosomes, Human, X",
        "DNA Copy Number Variations",
        "Genetics",
        "HapMap Project",
        "High-Throughput Nucleotide Sequencing",
        "Humans",
        "Male",
        "Molecular genetics",
        "Poisson Distribution",
        "Sequence Analysis, DNA",
        "Sequencing" ;
    schema1:license "LGPL (>= 2.0)" ;
    schema1:name "bioconductor-cn.mops" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/cn.mops.html" .

