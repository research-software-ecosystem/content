@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-cn.mops a schema1:SoftwareApplication ;
    schema1:description "cn.mops - Mixture of Poissons for CNV detection in NGS data" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/cn.mops_1.52.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/cn.mops/cn.mops_1.52.0.tar.gz', 'https://bioarchive.galaxyproject.org/cn.mops_1.52.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-cn.mops/bioconductor-cn.mops_1.52.0_src_all.tar.gz']" ;
    schema1:identifier biotools:cn.mops ;
    schema1:license "LGPL (>= 2.0)" ;
    schema1:name "bioconductor-cn.mops" ;
    schema1:softwareVersion "1.52.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/cn.mops.html" ;
    spdx:builtFrom biotools:cn.mops .

