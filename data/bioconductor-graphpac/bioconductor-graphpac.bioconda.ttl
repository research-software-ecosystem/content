@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-graphpac a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/1471-2105-15-86" ;
    schema1:description "Identification of Mutational Clusters in Proteins via a Graph Theoretical Approach." ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.18/bioc/src/contrib/GraphPAC_1.44.0.tar.gz', 'https://bioconductor.org/packages/3.18/bioc/src/contrib/Archive/GraphPAC/GraphPAC_1.44.0.tar.gz', 'https://bioarchive.galaxyproject.org/GraphPAC_1.44.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-graphpac/bioconductor-graphpac_1.44.0_src_all.tar.gz']" ;
    schema1:identifier biotools:graphpac ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-graphpac" ;
    schema1:softwareVersion "1.44.0" ;
    schema1:url "https://bioconductor.org/packages/3.18/bioc/html/GraphPAC.html" ;
    spdx:builtFrom biotools:graphpac .

