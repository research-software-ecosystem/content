@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-graphpac a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/1471-2105-15-86" ;
    schema1:description "Identification of Mutational Clusters in Proteins via a Graph Theoretical Approach." ;
    schema1:identifier biotools:graphpac ;
    schema1:keywords "Cluster Analysis",
        "Clustering",
        "Genes, Neoplasm",
        "Mutation",
        "Protein Structure, Tertiary",
        "Protein modifications",
        "Protein structure analysis",
        "Proteins",
        "Proteomics" ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-graphpac" ;
    schema1:url "http://bioconductor.org/packages/3.6/bioc/html/GraphPAC.html" .

