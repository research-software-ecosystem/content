@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:centreseq a schema1:SoftwareApplication ;
    schema1:description "Fast generation of core genome from bacterial strains" ;
    schema1:license "MIT" ;
    schema1:name "centreseq" ;
    schema1:url "https://github.com/bfssi-forest-dussault/centreseq" .

