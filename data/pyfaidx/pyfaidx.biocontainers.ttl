@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:pyfaidx a schema1:SoftwareApplication ;
    schema1:citation "doi:10.7287/peerj.preprints.970v1" ;
    schema1:description "This python module implements pure python classes for indexing, retrieval, and in-place modification of fasta files using a samtools compatible index." ;
    schema1:identifier biotools:pyfaidx ;
    schema1:keywords "Genomics",
        "Sequence analysis" ;
    schema1:license "MIT" ;
    schema1:name "pyfaidx" ;
    schema1:url "https://github.com/mdshw5/pyfaidx" .

