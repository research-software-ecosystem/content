@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:pyfaidx a schema1:SoftwareApplication ;
    schema1:citation "doi:10.7287/peerj.preprints.970v1" ;
    schema1:description "pyfaidx: efficient pythonic random access to fasta subsequences" ;
    schema1:downloadUrl "https://files.pythonhosted.org/packages/19/af/da148aaa8e75c9890a41dbe5516f8006def2b74831e66acf79f81bb7bb5b/pyfaidx-0.9.0.4.tar.gz" ;
    schema1:identifier biotools:pyfaidx ;
    schema1:license "BSD" ;
    schema1:name "pyfaidx" ;
    schema1:softwareHelp "https://pypi.org/project/pyfaidx" ;
    schema1:softwareVersion "0.9.0.4" ;
    schema1:url "https://github.com/mdshw5/pyfaidx" ;
    spdx:builtFrom biotools:pyfaidx .

