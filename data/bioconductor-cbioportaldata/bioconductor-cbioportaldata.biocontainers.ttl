@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-cbioportaldata a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18129/b9.bioc.cbioportaldata" ;
    schema1:description "Exposes and makes available data from the cBioPortal web resources" ;
    schema1:license "AGPL-3" ;
    schema1:name "bioconductor-cbioportaldata" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/cBioPortalData.html" .

