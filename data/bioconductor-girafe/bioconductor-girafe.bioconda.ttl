@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-girafe a schema1:SoftwareApplication ;
    schema1:description "Genome Intervals and Read Alignments for Functional Exploration" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/girafe_1.58.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/girafe/girafe_1.58.0.tar.gz', 'https://bioarchive.galaxyproject.org/girafe_1.58.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-girafe/bioconductor-girafe_1.58.0_src_all.tar.gz']" ;
    schema1:identifier biotools:girafe ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-girafe" ;
    schema1:softwareVersion "1.58.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/girafe.html" ;
    spdx:builtFrom biotools:girafe .

