@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-calm a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18129/b9.bioc.calm" ;
    schema1:description "Covariate Assisted Large-scale Multiple testing" ;
    schema1:keywords "Genetics",
        "Metabolomics",
        "Proteomics",
        "Transcriptomics" ;
    schema1:license "GPL (>=2)" ;
    schema1:name "bioconductor-calm" ;
    schema1:url "https://bioconductor.org/packages/3.10/bioc/html/calm.html" .

