@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:pypore a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btz269" ;
    schema1:description "Pythonic/Cythonic Nanopore Translocation Analysis" ;
    schema1:keywords "Genome",
        "High-Throughput Nucleotide Sequencing",
        "Nanopore Sequencing",
        "Nanopores",
        "Sequence Analysis, DNA" ;
    schema1:license "Apache 2.0" ;
    schema1:name "pypore" ;
    schema1:url "http://parkin.github.io/pypore/" .

