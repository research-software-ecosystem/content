@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:piper a schema1:SoftwareApplication ;
    schema1:description "A lightweight python toolkit for gluing together restartable, robust command line pipelines" ;
    schema1:license "BSD-2-Clause" ;
    schema1:name "piper" ;
    schema1:url "https://github.com/databio/pypiper/" .

