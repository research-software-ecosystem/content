@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:terminus a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btu165" ;
    schema1:description "Terminus enables the discovery of data-driven, robust transcript groups from RNA-seq data" ;
    schema1:identifier biotools:terminus ;
    schema1:keywords "Acetylation",
        "Acetyltransferases",
        "Amino Acid Motifs",
        "Artificial Intelligence",
        "Humans",
        "Methionine",
        "Protein Processing, Post-Translational",
        "Protein sites, features and motifs",
        "Proteins",
        "RNA-Seq",
        "Sequence Analysis, Protein",
        "Transcriptome",
        "Transcriptomics" ;
    schema1:license "BSD 3-Clause" ;
    schema1:name "terminus" ;
    schema1:url "https://github.com/COMBINE-lab/terminus" .

