@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-metams a schema1:SoftwareApplication ;
    schema1:description "MS-based metabolomics annotation pipeline" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/metaMS_1.42.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/metaMS/metaMS_1.42.0.tar.gz', 'https://bioarchive.galaxyproject.org/metaMS_1.42.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-metams/bioconductor-metams_1.42.0_src_all.tar.gz']" ;
    schema1:identifier biotools:metams ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-metams" ;
    schema1:softwareVersion "1.42.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/metaMS.html" ;
    spdx:builtFrom biotools:metams .

