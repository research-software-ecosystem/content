@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-metams a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1016/j.jchromb.2014.02.051" ;
    schema1:description "MS-based metabolomics annotation pipeline" ;
    schema1:identifier biotools:metams ;
    schema1:keywords "Databases, Factual",
        "Gas Chromatography-Mass Spectrometry",
        "Metabolomics",
        "Reproducibility of Results" ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-metams" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/metaMS.html" .

