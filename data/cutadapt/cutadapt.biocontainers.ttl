@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:cutadapt a schema1:SoftwareApplication ;
    schema1:citation "doi:10.14806/ej.17.1.200",
        "doi:10.7490/f1000research.1114334.1" ;
    schema1:description "Clean biological sequences from high-throughput sequencing reads" ;
    schema1:identifier biotools:cutadapt ;
    schema1:keywords "Genomics",
        "Probes and primers",
        "Sequencing" ;
    schema1:license "Expat" ;
    schema1:name "cutadapt" ;
    schema1:url "http://pypi.python.org/pypi/cutadapt" .

