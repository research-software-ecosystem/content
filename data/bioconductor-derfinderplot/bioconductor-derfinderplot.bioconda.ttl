@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-derfinderplot a schema1:SoftwareApplication ;
    schema1:description "Plotting functions for derfinder" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/derfinderPlot_1.40.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/derfinderPlot/derfinderPlot_1.40.0.tar.gz', 'https://bioarchive.galaxyproject.org/derfinderPlot_1.40.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-derfinderplot/bioconductor-derfinderplot_1.40.0_src_all.tar.gz']" ;
    schema1:identifier biotools:derfinderplot ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-derfinderplot" ;
    schema1:softwareVersion "1.40.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/derfinderPlot.html" ;
    spdx:builtFrom biotools:derfinderplot .

