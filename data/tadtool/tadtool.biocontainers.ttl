@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:tadtool a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btw368" ;
    schema1:description "Tadtool is an interactive tool for the identification of meaningful parameters in tad-calling algorithms for hi-c data" ;
    schema1:keywords "Animals",
        "Genome",
        "Humans" ;
    schema1:license "MIT" ;
    schema1:name "tadtool" ;
    schema1:url "https://github.com/vaquerizaslab/tadtool" .

