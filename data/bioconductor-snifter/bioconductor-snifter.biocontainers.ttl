@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-snifter a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/s41592-018-0308-4",
        "doi:10.1101/731877" ;
    schema1:description "Provides an R wrapper for the implementation of FI-tSNE from the python package openTNSE. See Poličar et al. (2019) and the algorithm described by Linderman et al. (2018)." ;
    schema1:keywords "Animals",
        "Base Sequence",
        "Computational Biology",
        "Gene Expression Profiling",
        "Genetic Markers",
        "Mice",
        "RNA",
        "Sequence Analysis, RNA",
        "Single-Cell Analysis",
        "Stochastic Processes" ;
    schema1:license "GPL-3.0" ;
    schema1:name "bioconductor-snifter" ;
    schema1:url "https://bioconductor.org/packages/3.12/bioc/html/snifter.html" .

