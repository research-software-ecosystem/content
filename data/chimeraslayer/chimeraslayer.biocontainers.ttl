@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:chimeraslayer a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1101/gr.112730.110" ;
    schema1:description "Detects likely chimeras in pcr amplified dna" ;
    schema1:identifier biotools:chimeraslayer ;
    schema1:keywords "Artifacts",
        "Bacteria",
        "Base Sequence",
        "Chimera",
        "Clustering",
        "DNA",
        "DNA, Bacterial",
        "DNA, Ribosomal",
        "Genomics",
        "Molecular Sequence Data",
        "Nucleic Acid Amplification Techniques",
        "Polymerase Chain Reaction",
        "RNA, Bacterial",
        "RNA, Ribosomal, 16S",
        "Sequence Alignment",
        "Sequence Analysis, DNA",
        "Sequences" ;
    schema1:license "BSD-3-clause" ;
    schema1:name "chimeraslayer" ;
    schema1:url "http://microbiomeutil.sourceforge.net/" .

