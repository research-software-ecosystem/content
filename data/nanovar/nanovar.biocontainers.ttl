@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:nanovar a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s13059-020-01968-7" ;
    schema1:description "Structural variant caller using low-depth long reads" ;
    schema1:keywords "Cells, Cultured",
        "Genetic Testing",
        "Genomic Structural Variation",
        "HCT116 Cells",
        "Humans",
        "Leukemia, Myeloid",
        "Nanopore Sequencing",
        "Reproducibility of Results",
        "Sensitivity and Specificity",
        "Sequence Analysis, DNA" ;
    schema1:license "GPL-3.0" ;
    schema1:name "nanovar" ;
    schema1:url "https://github.com/cytham/nanovar" .

