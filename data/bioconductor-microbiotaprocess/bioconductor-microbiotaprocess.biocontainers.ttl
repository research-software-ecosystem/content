@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-microbiotaprocess a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18129/b9.bioc.microbiotaprocess" ;
    schema1:description "an R package for analysis, visualization and biomarker discovery of microbiome" ;
    schema1:keywords "Cluster Analysis",
        "Metagenome" ;
    schema1:license "GPL (>= 3.0)" ;
    schema1:name "bioconductor-microbiotaprocess" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/MicrobiotaProcess.html" .

