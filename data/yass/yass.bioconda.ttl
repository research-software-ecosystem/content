@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:yass a schema1:SoftwareApplication ;
    schema1:description "YASS is a genomic similarity search tool, for nucleic (DNA/RNA) sequences in fasta or plain text format." ;
    schema1:downloadUrl "https://bioinfo.lifl.fr/yass/files/yass-1.16_alpha1/yass-1.16.tar.gz" ;
    schema1:identifier biotools:yass ;
    schema1:license "CeCILL Free Software License" ;
    schema1:name "yass" ;
    schema1:softwareHelp "https://bioinfo.lifl.fr/yass" ;
    schema1:softwareVersion "1.16" ;
    schema1:url "https://bioinfo.lifl.fr/yass" ;
    spdx:builtFrom biotools:yass .

