@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:yass a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/gki478" ;
    schema1:description "YASS is a genomic similarity search tool, for nucleic (DNA/RNA) sequences in fasta or plain text format" ;
    schema1:identifier biotools:yass ;
    schema1:keywords "Computer Graphics",
        "Genomics",
        "Internet",
        "Mapping",
        "Sequence Alignment",
        "Sequence Analysis, DNA",
        "Sequence Homology, Nucleic Acid",
        "Sequencing",
        "User-Computer Interface" ;
    schema1:license "CeCILL Free Software License" ;
    schema1:name "yass" ;
    schema1:url "http://bioinfo.lifl.fr/yass/" .

