@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:idba_subasm a schema1:SoftwareApplication ;
    schema1:description "Fork of IDBA with modifications to perform subassembly for the read cloud metagenomic assembler Athena" ;
