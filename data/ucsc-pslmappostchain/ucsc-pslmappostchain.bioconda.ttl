@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:ucsc-pslmappostchain a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bib/bbs038" ;
    schema1:description "Post genomic pslMap (TransMap) chaining. This takes transcripts that have been mapped via genomic chains adds back in blocks that didn't get include in genomic chains due to complex rearrangements or other issues." ;
    schema1:downloadUrl "https://hgdownload.cse.ucsc.edu/admin/exe/userApps.archive/userApps.v482.src.tgz" ;
    schema1:identifier biotools:UCSC_Genome_Browser_Utilities ;
    schema1:license "Varies; see https://genome.ucsc.edu/license" ;
    schema1:name "ucsc-pslmappostchain" ;
    schema1:softwareHelp "https://github.com/ucscGenomeBrowser/kent/blob/v482_base/README" ;
    schema1:softwareVersion "482" ;
    schema1:url "https://hgdownload.cse.ucsc.edu/admin/exe" ;
    spdx:builtFrom biotools:UCSC_Genome_Browser_Utilities .

