@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-les a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1089/cmb.2008.0226" ;
    schema1:description "Identifying Differential Effects in Tiling Microarray Data" ;
    schema1:identifier biotools:les ;
    schema1:keywords "ChIP-seq",
        "DNA mutation",
        "Gene Expression Profiling",
        "Gene Expression Regulation",
        "Microarray experiment",
        "Models, Biological",
        "Oligonucleotide Array Sequence Analysis" ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-les" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/les.html" .

