@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-les a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1089/cmb.2008.0226" ;
    schema1:description "Identifying Differential Effects in Tiling Microarray Data" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/les_1.60.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/les/les_1.60.0.tar.gz', 'https://bioarchive.galaxyproject.org/les_1.60.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-les/bioconductor-les_1.60.0_src_all.tar.gz']" ;
    schema1:identifier biotools:les ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-les" ;
    schema1:softwareVersion "1.60.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/les.html" ;
    spdx:builtFrom biotools:les .

