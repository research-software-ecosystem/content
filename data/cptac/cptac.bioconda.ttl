@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:cptac a schema1:SoftwareApplication ;
    schema1:author "old-rob" ;
    schema1:citation "doi:10.1021/acs.jproteome.0c00919" ;
    schema1:description "Python packaging for CPTAC data" ;
    schema1:downloadUrl "https://pypi.io/packages/source/c/cptac/cptac-1.5.13.tar.gz" ;
    schema1:identifier biotools:cptac ;
    schema1:license "Apache-2.0" ;
    schema1:maintainer "old-rob" ;
    schema1:name "cptac" ;
    schema1:softwareHelp "https://paynelab.github.io/cptac/" ;
    schema1:softwareVersion "1.5.13" ;
    schema1:url "https://pypi.org/project/cptac/" ;
    spdx:builtFrom biotools:cptac .

