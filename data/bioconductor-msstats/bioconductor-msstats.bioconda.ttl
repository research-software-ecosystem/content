@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-msstats a schema1:SoftwareApplication ;
    schema1:description "Protein Significance Analysis in DDA, SRM and DIA for Label-free or Label-based Proteomics Experiments" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/MSstats_4.14.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/MSstats/MSstats_4.14.0.tar.gz', 'https://bioarchive.galaxyproject.org/MSstats_4.14.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-msstats/bioconductor-msstats_4.14.0_src_all.tar.gz']" ;
    schema1:identifier biotools:msstats ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-msstats" ;
    schema1:softwareVersion "4.14.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/MSstats.html" ;
    spdx:builtFrom biotools:msstats .

