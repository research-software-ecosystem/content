@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-targetscore a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btt599" ;
    schema1:description "TargetScore: Infer microRNA targets using microRNA-overexpression data and sequence information" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/TargetScore_1.44.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/TargetScore/TargetScore_1.44.0.tar.gz', 'https://bioarchive.galaxyproject.org/TargetScore_1.44.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-targetscore/bioconductor-targetscore_1.44.0_src_all.tar.gz']" ;
    schema1:identifier biotools:targetscore ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-targetscore" ;
    schema1:softwareVersion "1.44.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/TargetScore.html" ;
    spdx:builtFrom biotools:targetscore .

