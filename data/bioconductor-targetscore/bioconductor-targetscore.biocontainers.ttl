@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-targetscore a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btt599" ;
    schema1:description "TargetScore: Infer microRNA targets using microRNA-overexpression data and sequence information" ;
    schema1:identifier biotools:targetscore ;
    schema1:keywords "Bayes Theorem",
        "Down-Regulation",
        "Functional, regulatory and non-coding RNA",
        "Gene Expression Profiling",
        "Gene Ontology",
        "Gene Regulatory Networks",
        "Humans",
        "MicroRNAs",
        "Oncogenes",
        "Probability",
        "Proteins",
        "RNA, Messenger",
        "Sequence Analysis, RNA" ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-targetscore" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/TargetScore.html" .

