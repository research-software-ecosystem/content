@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:netreg a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btx677" ;
    schema1:description "netReg fits linear regression models using network-penalization." ;
    schema1:identifier biotools:netreg ;
    schema1:keywords "Applied mathematics",
        "Biological networks",
        "Computational Biology",
        "Gene Expression Profiling",
        "Genomics",
        "Models, Biological",
        "Protein Interaction Maps",
        "Regression Analysis",
        "Yeasts" ;
    schema1:license "GPL-3.0" ;
    schema1:name "netreg" ;
    schema1:url "https://github.com/dirmeier/netReg" .

