@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-gpumagic a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18129/b9.bioc.gpumagic" ;
    schema1:description "The package aims to help users write openCL code with little or no effort. It is able to compile an user-defined R function and run it on a device such as a CPU or a GPU. The user can also write and run their openCL code directly by calling .kernel function." ;
    schema1:license "GPL-3.0" ;
    schema1:name "bioconductor-gpumagic" ;
    schema1:url "https://bioconductor.org/packages/3.12/bioc/html/gpuMagic.html" .

