@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:ont-tombo a schema1:SoftwareApplication ;
    schema1:description "Detection of modified bases from raw nanopore sequencing data." ;
    schema1:keywords "Sequence Alignment",
        "Transcriptome" ;
    schema1:license "mpl-2.0" ;
    schema1:name "ont-tombo" ;
    schema1:url "https://nanoporetech.github.io/tombo/" .

