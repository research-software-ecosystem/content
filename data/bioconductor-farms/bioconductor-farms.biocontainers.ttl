@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-farms a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btl033" ;
    schema1:description "FARMS - Factor Analysis for Robust Microarray Summarization" ;
    schema1:identifier biotools:farms ;
    schema1:keywords "Computer Simulation",
        "DNA Probes",
        "Gene Expression Profiling",
        "Microarray experiment",
        "Models, Genetic",
        "Oligonucleotide Array Sequence Analysis",
        "Sequence Analysis, DNA" ;
    schema1:license "LGPL (>= 2.1)" ;
    schema1:name "bioconductor-farms" ;
    schema1:url "https://www.bioconductor.org/packages/release/bioc/html/farms.html" .

