@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-farms a schema1:SoftwareApplication ;
    schema1:description "FARMS - Factor Analysis for Robust Microarray Summarization" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.17/bioc/src/contrib/farms_1.52.0.tar.gz', 'https://bioconductor.org/packages/3.17/bioc/src/contrib/Archive/farms/farms_1.52.0.tar.gz', 'https://bioarchive.galaxyproject.org/farms_1.52.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-farms/bioconductor-farms_1.52.0_src_all.tar.gz']" ;
    schema1:identifier biotools:farms ;
    schema1:license "LGPL (>= 2.1)" ;
    schema1:name "bioconductor-farms" ;
    schema1:softwareVersion "1.52.0" ;
    schema1:url "https://bioconductor.org/packages/3.17/bioc/html/farms.html" ;
    spdx:builtFrom biotools:farms .

