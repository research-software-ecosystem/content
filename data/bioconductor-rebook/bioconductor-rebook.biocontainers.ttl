@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-rebook a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18129/b9.bioc.rebook" ;
    schema1:description "Provides utilities to re-use content across chapters of a Bioconductor book. This is mostly based on functionality developed while writing the OSCA book, but generalized for potential use in other large books with heavy compute. Also contains some functions to assist book deployment." ;
    schema1:license "GPL-3.0" ;
    schema1:name "bioconductor-rebook" ;
    schema1:url "https://bioconductor.org/packages/3.12/bioc/html/rebook.html" .

