@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:svict a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/gkz067" ;
    schema1:description "SViCT is a computational tool for detecting structural variations from cell free DNA (cfDNA) containing low dilutions of circulating tumor DNA (ctDNA)." ;
    schema1:keywords "Cell-Free Nucleic Acids",
        "Circulating Tumor DNA",
        "DNA Mutational Analysis",
        "Datasets as Topic",
        "Humans",
        "Male",
        "Mutation",
        "Prostatic Neoplasms",
        "Sensitivity and Specificity" ;
    schema1:license "Apache-2.0" ;
    schema1:name "svict" ;
    schema1:url "https://github.com/vpc-ccg/svict" .

