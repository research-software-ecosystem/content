@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:seqprep a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1134/S1021443716020175" ;
    schema1:description "Strips adapters and optionally merges overlapping paired-end (or paired-end contamination in mate-pair libraries) illumina style reads." ;
    schema1:identifier biotools:seqprep ;
    schema1:keywords "Genomics",
        "Probes and primers",
        "Sequence assembly",
        "Sequencing" ;
    schema1:license "MIT" ;
    schema1:name "seqprep" ;
    schema1:url "https://github.com/jstjohn/SeqPrep" .

