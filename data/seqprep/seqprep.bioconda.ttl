@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:seqprep a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1134/S1021443716020175" ;
    schema1:description "Tool for stripping adaptors and/or merging paired reads with overlap into single reads." ;
    schema1:downloadUrl "https://github.com/jstjohn/SeqPrep/archive/v1.3.2.tar.gz" ;
    schema1:identifier biotools:seqprep ;
    schema1:license "MIT" ;
    schema1:name "seqprep" ;
    schema1:softwareHelp "https://github.com/jstjohn/SeqPrep/blob/v1.3.2/README.md" ;
    schema1:softwareVersion "1.3.2" ;
    schema1:url "https://github.com/jstjohn/SeqPrep" ;
    spdx:builtFrom biotools:seqprep .

