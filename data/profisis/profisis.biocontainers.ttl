@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:profisis a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btl303" ;
    schema1:description "Prediction of protein-protein interaction sites identified from sequence." ;
    schema1:identifier biotools:profisis ;
    schema1:keywords "Amino Acids",
        "Binding Sites",
        "Computer Simulation",
        "Models, Chemical",
        "Models, Molecular",
        "Pattern Recognition, Automated",
        "Protein Binding",
        "Protein Interaction Mapping",
        "Protein interactions",
        "Proteins",
        "Sequence Analysis, Protein" ;
    schema1:license "GPL-2.0" ;
    schema1:name "profisis" ;
    schema1:url "https://rostlab.org/owiki/index.php/PROFisis" .

