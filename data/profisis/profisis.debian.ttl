@prefix debianmed: <https://salsa.debian.org/med-team/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

debianmed:profisis a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btl303" ;
    schema1:description "prediction of protein-protein interaction sites from sequence" ;
    schema1:identifier "bio.tools:profisis",
        "omictools:OMICS_13706" ;
    schema1:license "unknown" ;
    schema1:name "profisis" ;
    schema1:softwareVersion "1.0.11" ;
    schema1:url "https://rostlab.org/owiki/index.php/PROFisis" ;
    spdx:builtFrom "profisis" .

