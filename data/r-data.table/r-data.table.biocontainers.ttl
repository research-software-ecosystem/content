@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-data.table a schema1:SoftwareApplication ;
    schema1:description "Fast aggregation of large data (e.g. 100gb in ram), fast ordered joins, fast add/modify/delete" ;
    schema1:keywords "Clustering",
        "Genomics",
        "Metabolomics" ;
    schema1:license "GPL-3.0" ;
    schema1:name "r-data.table" ;
    schema1:url "https://CRAN.R-project.org/package=data.table" .

