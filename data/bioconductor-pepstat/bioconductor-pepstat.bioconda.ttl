@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-pepstat a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1007/978-1-4939-3037-1_10" ;
    schema1:description "Statistical analysis of peptide microarrays" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/pepStat_1.44.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/pepStat/pepStat_1.44.0.tar.gz', 'https://bioarchive.galaxyproject.org/pepStat_1.44.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-pepstat/bioconductor-pepstat_1.44.0_src_all.tar.gz']" ;
    schema1:identifier biotools:pepstat ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-pepstat" ;
    schema1:softwareVersion "1.44.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/pepStat.html" ;
    spdx:builtFrom biotools:pepstat .

