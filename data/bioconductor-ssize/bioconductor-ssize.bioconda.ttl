@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-ssize a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Estimate Microarray Sample Size" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/ssize_1.80.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/ssize/ssize_1.80.0.tar.gz', 'https://bioarchive.galaxyproject.org/ssize_1.80.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-ssize/bioconductor-ssize_1.80.0_src_all.tar.gz']" ;
    schema1:identifier biotools:ssize ;
    schema1:license "LGPL" ;
    schema1:name "bioconductor-ssize" ;
    schema1:softwareVersion "1.80.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/ssize.html" ;
    spdx:builtFrom biotools:ssize .

