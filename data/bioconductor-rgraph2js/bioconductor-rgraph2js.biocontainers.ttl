@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-rgraph2js a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Convert a Graph into a D3js Script" ;
    schema1:identifier biotools:rgraph2js ;
    schema1:keywords "Computational Biology",
        "Data management",
        "Data visualisation",
        "Gene Expression Profiling",
        "Genomics",
        "High-Throughput Screening Assays",
        "Programming Languages",
        "User-Computer Interface" ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-rgraph2js" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/RGraph2js.html" .

