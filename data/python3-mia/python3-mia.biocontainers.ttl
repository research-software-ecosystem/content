@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:python3-mia a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/1751-0473-8-20" ;
    schema1:description "MIA comprises a set of tools, libraries, and plug-ins for general purpose 2D and 3D gray scale image processing and basic handling of triangular meshes. The libraries provide a basic infrastructure and generic algorithms, that can be specialized by specifying the appropriate plug-ins. This package provides the Python-3 bindings." ;
    schema1:license "GNU" ;
    schema1:name "python3-mia" ;
    schema1:url "http://mia.sourceforge.net/" .

