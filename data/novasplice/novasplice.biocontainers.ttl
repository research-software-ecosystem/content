@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:novasplice a schema1:SoftwareApplication ;
    schema1:description "Novasplice is a python tool to predict novel intronic splice sites from a given vcf file" ;
    schema1:keywords "Genomics" ;
    schema1:license "MIT" ;
    schema1:name "novasplice" ;
    schema1:url "https://github.com/aryakaul/novasplice" .

