@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-peco a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18129/b9.bioc.peco" ;
    schema1:description "A Supervised Approach for **P**r**e**dicting **c**ell Cycle Pr**o**gression using scRNA-seq data" ;
    schema1:keywords "Gene Expression",
        "RNA-Seq",
        "Transcriptomics" ;
    schema1:license "GPL (>= 3)" ;
    schema1:name "bioconductor-peco" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/peco.html" .

