@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-pvca a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1002/9780470685983.ch12" ;
    schema1:description "Principal Variance Component Analysis (PVCA)" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/pvca_1.50.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/pvca/pvca_1.50.0.tar.gz', 'https://bioarchive.galaxyproject.org/pvca_1.50.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-pvca/bioconductor-pvca_1.50.0_src_all.tar.gz']" ;
    schema1:identifier biotools:pvca ;
    schema1:license "LGPL (>= 2.0)" ;
    schema1:name "bioconductor-pvca" ;
    schema1:softwareVersion "1.50.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/pvca.html" ;
    spdx:builtFrom biotools:pvca .

