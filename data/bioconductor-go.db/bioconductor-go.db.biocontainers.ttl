@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-go.db a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18129/b9.bioc.go.db" ;
    schema1:description "A set of annotation maps describing the entire gene ontology" ;
    schema1:keywords "Proteomics" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-go.db" ;
    schema1:url "https://bioconductor.org/packages/3.11/data/annotation/html/GO.db.html" .

