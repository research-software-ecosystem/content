@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:prottest a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/bti263" ;
    schema1:description "Prottest is a program that determines the best-fit model of evolution, among a set of candidate models, for a given protein sequence alignment." ;
    schema1:identifier biotools:prottest ;
    schema1:keywords "Amino Acid Sequence",
        "Amino Acid Substitution",
        "Amino Acids",
        "Computer Graphics",
        "Computer Simulation",
        "DNA Mutational Analysis",
        "Evolution, Molecular",
        "Experimental design and studies",
        "Humans",
        "Internet",
        "Models, Genetic",
        "Models, Molecular",
        "Molecular Sequence Data",
        "Mutagenesis, Site-Directed",
        "Phylogenetics",
        "Phylogeny",
        "Proteins",
        "Sequence Analysis, Protein",
        "Small molecules",
        "Structure-Activity Relationship",
        "User-Computer Interface" ;
    schema1:license "GPL-2+" ;
    schema1:name "prottest" ;
    schema1:url "http://darwin.uvigo.es/software/prottest_server.html?" .

