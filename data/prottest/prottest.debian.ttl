@prefix debianmed: <https://salsa.debian.org/med-team/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

debianmed:prottest a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btr088" ;
    schema1:description "selection of best-fit models of protein evolution" ;
    schema1:identifier "bio.tools:ProtTest",
        "omictools:OMICS_11547",
        "scicrunch:SCR_014628" ;
    schema1:license "unknown" ;
    schema1:name "prottest" ;
    schema1:softwareVersion "3.4.2" ;
    schema1:url "https://github.com/ddarriba/prottest3" ;
    spdx:builtFrom "ProtTest" .

