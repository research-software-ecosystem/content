        "biotools:gi2taxonomy" ;
    schema1:keywords "Metagenomics" ;
    schema1:name "gi2taxonomy" ;
    schema1:softwareVersion "1.1.1" ;
    schema1:url "https://bitbucket.org/natefoo/taxonomy" .

