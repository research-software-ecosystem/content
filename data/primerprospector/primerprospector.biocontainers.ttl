@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:primerprospector a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btr087" ;
    schema1:description "Primer prospector is a pipeline of programs to design and analyze pcr primers." ;
    schema1:keywords "Base Sequence",
        "DNA Primers",
        "Humans",
        "Phylogeny",
        "Polymerase Chain Reaction",
        "Sequence Alignment" ;
    schema1:license "Custom License" ;
    schema1:name "primerprospector" ;
    schema1:url "http://pprospector.sourceforge.net/" .

