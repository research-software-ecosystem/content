@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:molpopgen-analysis a schema1:SoftwareApplication ;
    schema1:description "Deprecated and no longer maintained programs for the (pre-NGS-era) analysis of population-genetic data. Unless you work with Sanger data, results will be wrong. Please check the software homepage for more details." ;
    schema1:keywords "Genetic variation" ;
    schema1:license "GPL-2.0" ;
    schema1:name "molpopgen-analysis" ;
    schema1:url "https://github.com/molpopgen/analysis" .

