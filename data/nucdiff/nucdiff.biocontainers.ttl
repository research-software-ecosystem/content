@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:nucdiff a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s12859-017-1748-z" ;
    schema1:description "NucDiff locates and categorizes differences between two closely related nucleotide sequences." ;
    schema1:keywords "Base Sequence",
        "DNA",
        "Genomics",
        "Internet",
        "Sequence Alignment",
        "User-Computer Interface" ;
    schema1:license "MPL-2.0" ;
    schema1:name "nucdiff" ;
    schema1:url "https://github.com/uio-cels/NucDiff" .

