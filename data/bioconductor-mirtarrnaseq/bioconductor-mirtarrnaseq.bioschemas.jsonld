      "sc:citation": {
        "@id": "https://doi.org/10.18129/B9.bioc.mirTarRnaSeq"
      },
      "sc:description": "mirTarRnaSeq R package can be used for interactive mRNA miRNA sequencing statistical analysis. This package utilizes expression or differential expression mRNA and miRNA sequencing results and performs interactive correlation and various GLMs (Regular GLM, Multivariate GLM, and Interaction GLMs ) analysis between mRNA and miRNA expriments. These experiments can be time point experiments, and or condition expriments.",
      "sc:license": "MIT",
      "sc:name": "mirTarRnaSeq",
      "sc:operatingSystem": [
        "Windows",
        "Linux",
        "Mac"
      ],
