@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-metarnaseq a schema1:SoftwareApplication ;
    schema1:description "Implementation of two p-value combination techniques (inverse normal and Fisher methods). A vignette is provided to explain how to perform a meta-analysis from two independent RNA-seq experiments." ;
    schema1:keywords "RNA-Seq" ;
    schema1:license "GPL" ;
    schema1:name "r-metarnaseq" ;
    schema1:url "https://CRAN.R-project.org/package=metaRNASeq" .

