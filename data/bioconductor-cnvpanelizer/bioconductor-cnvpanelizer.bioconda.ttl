@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-cnvpanelizer a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Reliable CNV detection in targeted sequencing applications" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/CNVPanelizer_1.42.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/CNVPanelizer/CNVPanelizer_1.42.0.tar.gz', 'https://bioarchive.galaxyproject.org/CNVPanelizer_1.42.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-cnvpanelizer/bioconductor-cnvpanelizer_1.42.0_src_all.tar.gz']" ;
    schema1:identifier biotools:cnvpanelizer ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-cnvpanelizer" ;
    schema1:softwareVersion "1.42.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/CNVPanelizer.html" ;
    spdx:builtFrom biotools:cnvpanelizer .

