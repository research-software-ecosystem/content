@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:blockclust a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btu270" ;
    schema1:description "Efficient clustering and classification of non-coding RNAs from short read RNA-seq profiles." ;
    schema1:keywords "Artificial Intelligence",
        "Cluster Analysis",
        "Clustering",
        "Gene Expression Profiling",
        "High-Throughput Nucleotide Sequencing",
        "Humans",
        "Molecular Sequence Annotation",
        "RNA, Small Untranslated",
        "Sequence Alignment",
        "Sequence Analysis, RNA" ;
    schema1:license "GPL" ;
    schema1:name "blockclust" ;
    schema1:url "https://github.com/pavanvidem/blockclust" .

