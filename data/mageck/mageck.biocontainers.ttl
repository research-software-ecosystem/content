@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:mageck a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s13059-015-0843-6" ;
    schema1:description "Model-based analysis of genome-wide crispr-cas9 knockout." ;
    schema1:identifier biotools:mageck ;
    schema1:keywords "CRISPR-Cas Systems",
        "Gene Targeting",
        "Genes, Essential",
        "Genetic variation",
        "Genetics",
        "Genomics",
        "Quality Control" ;
    schema1:license "BSD" ;
    schema1:name "mageck" ;
    schema1:url "https://bitbucket.org/liulab/mageck/" .

