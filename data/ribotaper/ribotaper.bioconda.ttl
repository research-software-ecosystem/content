@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:ribotaper a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3688" ;
    schema1:description "RiboTaper is a new analysis pipeline for Ribosome Profiling (Ribo-seq) experiments, which exploits the triplet periodicity of ribosomal footprints to call translated regions." ;
    schema1:downloadUrl "https://ohlerlab.mdc-berlin.de/files/RiboTaper/RiboTaper-1.3.1a.tar.gz" ;
    schema1:identifier biotools:ribotaper ;
    schema1:license "GPL-3.0-or-later" ;
    schema1:name "ribotaper" ;
    schema1:softwareVersion "1.3.1a" ;
    schema1:url "https://ohlerlab.mdc-berlin.de/software/RiboTaper_126/" ;
    spdx:builtFrom biotools:ribotaper .

