@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-mineica a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1155/2014/213656" ;
    schema1:description "Analysis of an ICA decomposition obtained on genomics data" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/MineICA_1.49.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/MineICA/MineICA_1.49.0.tar.gz', 'https://bioarchive.galaxyproject.org/MineICA_1.49.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-mineica/bioconductor-mineica_1.49.0_src_all.tar.gz']" ;
    schema1:identifier biotools:mineica ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-mineica" ;
    schema1:softwareVersion "1.49.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/MineICA.html" ;
    spdx:builtFrom biotools:mineica .

