@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-mineica a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1155/2014/213656" ;
    schema1:description "Analysis of an ICA decomposition obtained on genomics data" ;
    schema1:identifier biotools:mineica ;
    schema1:keywords "Data Interpretation, Statistical",
        "Gene Expression Profiling",
        "Gene expression",
        "Gene transcripts",
        "Genomics",
        "Oligonucleotide Array Sequence Analysis",
        "Pattern Recognition, Automated",
        "Software Design",
        "Transcriptome",
        "Transcriptomics" ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-mineica" ;
    schema1:url "http://bioconductor.org/packages/3.6/bioc/html/MineICA.html" .

