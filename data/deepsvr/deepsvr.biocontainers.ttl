@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:deepsvr a schema1:SoftwareApplication ;
    schema1:description "Deepsvr stands for deep somatic variant refinement. it uses deep learning to classify real somatic and anomalous variants in paired tumor sequencing data." ;
    schema1:license "MIT" ;
    schema1:name "deepsvr" ;
    schema1:url "https://github.com/griffithlab/deepsvr" .

