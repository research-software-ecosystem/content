@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:transcriptclean a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/bty483" ;
    schema1:description "Transcriptclean is a python program that corrects mismatches, microindels, and noncanonical splice junctions in long reads that have been mapped to the genome." ;
    schema1:keywords "Transcriptome" ;
    schema1:license "MIT" ;
    schema1:name "transcriptclean" ;
    schema1:url "https://github.com/dewyman/TranscriptClean" .

