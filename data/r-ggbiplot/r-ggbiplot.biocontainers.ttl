@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-ggbiplot a schema1:SoftwareApplication ;
    schema1:description "A biplot based on ggplot2" ;
    schema1:license "GPL-2" ;
    schema1:name "r-ggbiplot" ;
    schema1:url "http://github.com/vqv/ggbiplot" .

