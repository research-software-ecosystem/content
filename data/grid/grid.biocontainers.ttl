@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:grid a schema1:SoftwareApplication ;
    schema1:description "Growth rate index (grid) measures bacterial growth rate from reference genomes (including draft quality genomes) and metagenomic bins at ultra-low sequencing coverage (> 0.2x)." ;
    schema1:keywords "Clustering" ;
    schema1:license "Not available" ;
    schema1:name "grid" ;
    schema1:url "https://github.com/ohlab/GRiD" .

