        "Microarray experiment",
        "Programming Languages",
        "User-Computer Interface" ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-bufferedmatrixmethods" ;
    schema1:url "http://bioconductor.org/packages/3.6/bioc/html/BufferedMatrixMethods.html" .

