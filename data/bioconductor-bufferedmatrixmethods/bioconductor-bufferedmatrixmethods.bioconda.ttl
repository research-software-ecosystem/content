@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-bufferedmatrixmethods a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Microarray Data related methods that utlize BufferedMatrix objects" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/BufferedMatrixMethods_1.70.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/BufferedMatrixMethods/BufferedMatrixMethods_1.70.0.tar.gz', 'https://bioarchive.galaxyproject.org/BufferedMatrixMethods_1.70.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-bufferedmatrixmethods/bioconductor-bufferedmatrixmethods_1.70.0_src_all.tar.gz']" ;
    schema1:identifier biotools:bufferedmatrixmethods ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-bufferedmatrixmethods" ;
    schema1:softwareVersion "1.70.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/BufferedMatrixMethods.html" ;
    spdx:builtFrom biotools:bufferedmatrixmethods .

