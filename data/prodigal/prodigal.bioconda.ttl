@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:prodigal a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/1471-2105-11-119" ;
    schema1:description "Prodigal (Prokaryotic Dynamic Programming Genefinding Algorithm) is a microbial (bacterial and archaeal) gene finding program." ;
    schema1:downloadUrl "https://github.com/hyattpd/Prodigal/archive/v2.6.3.zip" ;
    schema1:identifier biotools:prodigal ;
    schema1:license "GPL-3.0-or-later" ;
    schema1:name "prodigal" ;
    schema1:softwareHelp "https://github.com/hyattpd/Prodigal/wiki" ;
    schema1:softwareVersion "2.6.3" ;
    schema1:url "https://github.com/hyattpd/Prodigal" ;
    spdx:builtFrom biotools:prodigal .

