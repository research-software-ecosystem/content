@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:prodigal a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/1471-2105-11-119" ;
    schema1:description "Microbial (bacterial and archaeal) gene finding program" ;
    schema1:keywords "Databases, Genetic",
        "Genome, Bacterial",
        "Peptide Chain Initiation, Translational",
        "Prokaryotic Cells" ;
    schema1:license "GPL-3" ;
    schema1:name "prodigal" ;
    schema1:url "http://prodigal.ornl.gov/" .

