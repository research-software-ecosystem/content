@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:optitype a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btu548" ;
    schema1:description "Precision HLA typing from next-generation sequencing data" ;
    schema1:keywords "Exome",
        "Genotyping Techniques",
        "HLA Antigens",
        "High-Throughput Nucleotide Sequencing",
        "Histocompatibility Testing",
        "Humans",
        "Introns",
        "RNA-Seq",
        "Sequence Analysis, DNA" ;
    schema1:license "BSD" ;
    schema1:name "optitype" ;
    schema1:url "https://github.com/FRED-2/OptiType" .

