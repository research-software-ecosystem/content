@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:r-monocle3 a schema1:SoftwareApplication ;
    schema1:author "ctrapnell",
        "hpliner",
        "mjsteinbaugh" ;
    schema1:citation "doi:10.1038/nbt.2859",
        "doi:10.1038/nmeth.4402",
        "doi:10.1038/s41586-019-0969-x" ;
    schema1:description "An analysis toolkit for single-cell RNA-seq." ;
    schema1:downloadUrl "https://github.com/cole-trapnell-lab/monocle3/archive/v1.4.26.tar.gz" ;
    schema1:identifier biotools:monocle ;
    schema1:license "MIT" ;
    schema1:maintainer "ctrapnell",
        "hpliner",
        "mjsteinbaugh" ;
    schema1:name "r-monocle3" ;
    schema1:softwareHelp "https://cole-trapnell-lab.github.io/monocle3/docs/introduction" ;
    schema1:softwareVersion "1.4.26" ;
    schema1:url "https://cole-trapnell-lab.github.io/monocle3" ;
    spdx:builtFrom biotools:monocle .

