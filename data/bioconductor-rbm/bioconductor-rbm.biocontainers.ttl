@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-rbm a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "RBM: a R package for microarray and RNA-Seq data analysis" ;
    schema1:identifier biotools:rbm ;
    schema1:keywords "Computational Biology",
        "Gene Expression Profiling",
        "Genomics",
        "High-Throughput Screening Assays",
        "Microarray experiment",
        "Programming Languages",
        "RNA-Seq",
        "User-Computer Interface" ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-rbm" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/RBM.html" .

