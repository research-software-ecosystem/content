@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-lola a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btv612" ;
    schema1:description "Locus overlap analysis for enrichment of genomic ranges" ;
    schema1:identifier biotools:lola ;
    schema1:keywords "Computational Biology",
        "Databases, Factual",
        "Epigenomics",
        "Functional genomics",
        "Gene Regulatory Networks",
        "Genome, Human",
        "Genomics",
        "Humans",
        "Regulatory Sequences, Nucleic Acid",
        "Sequence Analysis, DNA",
        "Sequence analysis" ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-lola" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/LOLA.html" .

