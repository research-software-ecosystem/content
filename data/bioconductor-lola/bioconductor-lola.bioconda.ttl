@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-lola a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btv612" ;
    schema1:description "Locus overlap analysis for enrichment of genomic ranges" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/LOLA_1.36.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/LOLA/LOLA_1.36.0.tar.gz', 'https://bioarchive.galaxyproject.org/LOLA_1.36.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-lola/bioconductor-lola_1.36.0_src_all.tar.gz']" ;
    schema1:identifier biotools:lola ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-lola" ;
    schema1:softwareVersion "1.36.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/LOLA.html" ;
    spdx:builtFrom biotools:lola .

