@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:scxa-plots a schema1:SoftwareApplication ;
    schema1:description "A set of wrappers to produce some bespoke plots used by the team behind single-cell expresion atlas (scxa) in single-cell rna-seq analysis. not to be confused with the plots displayed in scxa itself." ;
    schema1:license "Apache-2.0" ;
    schema1:name "scxa-plots" ;
    schema1:url "https://github.com/ebi-gene-expression-group/scxa-plots" .

