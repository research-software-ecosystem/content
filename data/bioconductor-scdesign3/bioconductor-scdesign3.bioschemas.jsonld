    {
      "@id": "https://bio.tools/bioconductor-scdesign3",
      "@type": "sc:SoftwareApplication",
      "dcterms:conformsTo": "https://bioschemas.org/profiles/ComputationalTool/0.6-DRAFT",
      "sc:additionalType": [
        "Command-line tool",
        "Library"
      ],
      "sc:author": [
        "Dongyuan Song",
        "Chenxin Jiang",
        "Qingyang Wang"
      ],
      "sc:citation": {
        "@id": "https://doi.org/10.1038/s41587-023-01772-1"
      },
      "sc:description": "We present a statistical simulator, scDesign3, to generate realistic single-cell and spatial omics data, including various cell states, experimental designs, and feature modalities, by learning interpretable parameters from real data. Using a unified probabilistic model for single-cell and spatial omics data, scDesign3 infers biologically meaningful parameters; assesses the goodness-of-fit of inferred cell clusters, trajectories, and spatial locations; and generates in silico negative and positive controls for benchmarking computational tools.",
      "sc:license": "MIT",
      "sc:name": "scDesign3",
      "sc:operatingSystem": [
        "Windows",
        "Mac",
        "Linux"
      ],
      "sc:softwareHelp": {
        "@id": "https://bioconductor.org/packages/scDesign3"
      },
      "sc:softwareVersion": "1.8.0",
      "sc:url": "https://bioconductor.org/packages/scDesign3"
    }
  ]
