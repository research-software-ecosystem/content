@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-rols a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "An R interface to the Ontology Lookup Service" ;
    schema1:identifier biotools:rols ;
    schema1:keywords "Computational Biology",
        "Gene Expression Profiling",
        "Genomics",
        "High-Throughput Screening Assays",
        "Ontology and terminology",
        "Programming Languages",
        "Proteomics",
        "User-Computer Interface" ;
    schema1:license "GPL-2.0" ;
    schema1:name "bioconductor-rols" ;
    schema1:url "https://www.bioconductor.org/packages/release/bioc/html/rols.html" .

