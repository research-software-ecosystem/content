@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-rols a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "An R interface to the Ontology Lookup Service" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/rols_3.6.1.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/rols/rols_3.6.1.tar.gz', 'https://bioarchive.galaxyproject.org/rols_3.6.1.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-rols/bioconductor-rols_3.6.1_src_all.tar.gz']" ;
    schema1:identifier biotools:rols ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-rols" ;
    schema1:softwareVersion "3.6.1" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/rols.html" ;
    spdx:builtFrom biotools:rols .

