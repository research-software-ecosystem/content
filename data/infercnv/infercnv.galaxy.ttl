@prefix edam: <http://edamontology.org/> .
@prefix galaxytool: <https://github.com/galaxyproject/tools-iuc/tree/master/tools/> .
@prefix schema1: <http://schema.org/> .

galaxytool:infercnv a schema1:SoftwareApplication ;
    schema1:description "Infer Copy Number Variation from Single-Cell RNA-Seq Data" ;
    schema1:featureList edam:operation_0531,
        edam:operation_2495,
        edam:operation_3432,
        edam:operation_3680,
        edam:operation_3961 ;
    schema1:identifier "bioconda:bioconductor-infercnv",
        "biotools:infercnv" ;
    schema1:keywords "Single Cell",
        "Transcriptomics",
        "Variant Analysis" ;
    schema1:name "infercnv" ;
    schema1:softwareVersion "1.26.0" ;
    schema1:url "https://github.com/broadinstitute/infercnv" .

