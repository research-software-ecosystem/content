@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-pcaexplorer a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18547/gcb.2017.vol3.iss1.e39" ;
    schema1:description "Interactive Visualization of RNA-seq Data Using a Principal Components Approach" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/pcaExplorer_3.0.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/pcaExplorer/pcaExplorer_3.0.0.tar.gz', 'https://bioarchive.galaxyproject.org/pcaExplorer_3.0.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-pcaexplorer/bioconductor-pcaexplorer_3.0.0_src_all.tar.gz']" ;
    schema1:identifier biotools:pcaexplorer ;
    schema1:license "MIT + file LICENSE" ;
    schema1:name "bioconductor-pcaexplorer" ;
    schema1:softwareVersion "3.0.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/pcaExplorer.html" ;
    spdx:builtFrom biotools:pcaexplorer .

