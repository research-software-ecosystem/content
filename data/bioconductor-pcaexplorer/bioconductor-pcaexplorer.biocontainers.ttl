@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-pcaexplorer a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18547/gcb.2017.vol3.iss1.e39" ;
    schema1:description "Interactive Visualization of RNA-seq Data Using a Principal Components Approach" ;
    schema1:identifier biotools:pcaexplorer ;
    schema1:keywords "Data visualisation",
        "Gene expression",
        "RNA-Seq",
        "Sequencing" ;
    schema1:license "MIT" ;
    schema1:name "bioconductor-pcaexplorer" ;
    schema1:url "https://www.bioconductor.org/packages/release/bioc/html/pcaExplorer.html" .

