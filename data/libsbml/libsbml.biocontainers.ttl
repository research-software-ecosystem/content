@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:libsbml a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btn051" ;
    schema1:description "LibSBML is an application programming interface library for reading, writing, manipulating and validating content expressed in the Systems Biology Markup Language (SBML) format. It is written in ISO C and C++, provides language bindings for Common Lisp, Java, Python, Perl, MATLAB and Octave, and includes many features that facilitate adoption and use of both SBML and the library. Developers can embed libSBML in their applications, saving themselves the work of implementing their own SBML parsing, manipulation and validation software." ;
    schema1:identifier biotools:libsbml ;
    schema1:keywords "Computer Simulation",
        "Data management",
        "Models, Biological",
        "Programming Languages",
        "Proteome",
        "Signal Transduction",
        "Systems Biology",
        "Systems biology",
        "User-Computer Interface" ;
    schema1:license "LGPL-2.1" ;
    schema1:name "libsbml" ;
    schema1:url "https://sourceforge.net/p/sbml/code/HEAD/tree/trunk/libsbml/" .

