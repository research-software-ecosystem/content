@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:batch_correction a schema1:SoftwareApplication ;
    schema1:description "Corrects intensities for signal drift and batch-effects" ;
    schema1:keywords "Batch correction",
        "Mass spectrometry",
        "Metabolomics" ;
    schema1:license "GPL" ;
    schema1:name "batch_correction" ;
    schema1:url "https://github.com/phnmnl/container-batch_correction" .

