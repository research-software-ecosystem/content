@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-gopro a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18129/b9.bioc.gopro" ;
    schema1:description "Find the most characteristic gene ontology terms for groups of human genes" ;
    schema1:keywords "Clustering",
        "Genetics" ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-gopro" ;
    schema1:url "https://bioconductor.org/packages/3.8/bioc/html/GOpro.html" .

