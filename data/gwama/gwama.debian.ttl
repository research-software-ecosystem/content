        "conda:bioconda:gwama",
        "omictools:OMICS_00235",
        "scicrunch:SCR_006624" ;
    schema1:license "unknown" ;
    schema1:name "gwama" ;
    schema1:softwareVersion "2.2.2" ;
    schema1:url "https://genomics.ut.ee/en/tools" ;
    spdx:builtFrom "GWAMA" .

