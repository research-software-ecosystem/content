@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:gwama a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/1471-2105-11-288" ;
    schema1:description "Genome-Wide Association Meta Analysis" ;
    schema1:downloadUrl "http://www.geenivaramu.ee/tools/GWAMA_v2.2.2.zip" ;
    schema1:identifier biotools:GWAMA ;
    schema1:license "BSD-3-clause" ;
    schema1:name "gwama" ;
    schema1:softwareVersion "2.2.2" ;
    schema1:url "https://www.geenivaramu.ee/en/tools/gwama" ;
    spdx:builtFrom biotools:GWAMA .

