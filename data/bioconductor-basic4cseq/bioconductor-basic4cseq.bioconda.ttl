@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-basic4cseq a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btu497" ;
    schema1:description "Basic4Cseq: an R/Bioconductor package for analyzing 4C-seq data" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/Basic4Cseq_1.46.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/Basic4Cseq/Basic4Cseq_1.46.0.tar.gz', 'https://bioarchive.galaxyproject.org/Basic4Cseq_1.46.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-basic4cseq/bioconductor-basic4cseq_1.46.0_src_all.tar.gz']" ;
    schema1:identifier biotools:basic4cseq ;
    schema1:license "LGPL-3" ;
    schema1:name "bioconductor-basic4cseq" ;
    schema1:softwareVersion "1.46.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/Basic4Cseq.html" ;
    spdx:builtFrom biotools:basic4cseq .

