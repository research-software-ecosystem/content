@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-basic4cseq a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btu497" ;
    schema1:description "Basic4Cseq: an R/Bioconductor package for analyzing 4C-seq data" ;
    schema1:identifier biotools:basic4cseq ;
    schema1:keywords "Chromosomes",
        "Data visualisation",
        "High-Throughput Nucleotide Sequencing",
        "Sequence analysis",
        "Sequencing" ;
    schema1:license "LGPL-3" ;
    schema1:name "bioconductor-basic4cseq" ;
    schema1:url "https://www.bioconductor.org/packages/release/bioc/html/Basic4Cseq.html" .

