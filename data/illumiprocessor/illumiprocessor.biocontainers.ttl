@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:illumiprocessor a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btu170",
        "doi:10.6079/j9ill" ;
    schema1:description "Illumiprocessor is a tool to batch process illumina sequencing reads using the excellent trimmomatic package." ;
    schema1:keywords "Computational Biology",
        "Databases, Genetic",
        "High-Throughput Nucleotide Sequencing" ;
    schema1:license "Not available" ;
    schema1:name "illumiprocessor" ;
    schema1:url "https://github.com/faircloth-lab/illumiprocessor" .

