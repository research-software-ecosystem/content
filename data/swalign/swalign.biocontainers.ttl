@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:swalign a schema1:SoftwareApplication ;
    schema1:description "Smith-Waterman local aligner" ;
    schema1:identifier biotools:swalign ;
    schema1:keywords "Applied mathematics",
        "Mapping" ;
    schema1:license "BSD" ;
    schema1:name "swalign" ;
    schema1:url "http://github.com/mbreese/swalign/" .

