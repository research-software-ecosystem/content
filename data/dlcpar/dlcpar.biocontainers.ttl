@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:dlcpar a schema1:SoftwareApplication ;
    schema1:description "Accurate inference of orthogroups, orthologues, gene trees and rooted species tree made easy!" ;
    schema1:keywords "Clustering",
        "Genomics",
        "Ortholog",
        "Sequence Alignment" ;
    schema1:license "GPL-3.0" ;
    schema1:name "dlcpar" ;
    schema1:url "https://github.com/davidemms/OrthoFinder" .

