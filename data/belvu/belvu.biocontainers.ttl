@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:belvu a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/1471-2105-6-108" ;
    schema1:description "Analyze read length, phred scores and alphabet frequency and dna k-mers on uncompressed and compressed fastq files." ;
    schema1:identifier biotools:belvu ;
    schema1:keywords "Amino Acid Sequence",
        "Biological Evolution",
        "Calibration",
        "Computational Biology",
        "Computer Simulation",
        "Evolution, Molecular",
        "Likelihood Functions",
        "Models, Statistical",
        "Molecular Sequence Data",
        "Monte Carlo Method",
        "Pattern Recognition, Automated",
        "Phylogeny",
        "Proteins",
        "Sequence Analysis, Protein",
        "Sequence Homology, Amino Acid" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "belvu" ;
    schema1:url "http://bioconductor.org/packages/release/bioc/html/seqTools.html" .

