@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:blastalign a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/bth459" ;
    schema1:description "BlastAlign uses NCBI Blast to align nucleotide sequences that have large indels or are otherwise difficult to align globally." ;
    schema1:identifier biotools:blastalign ;
    schema1:keywords "Base Sequence",
        "Information Storage and Retrieval",
        "Internet",
        "Molecular Sequence Data",
        "National Institutes of Health (U.S.)",
        "Sequence Alignment",
        "Sequence Analysis, DNA",
        "Sequence Homology, Nucleic Acid",
        "Sequences",
        "United States" ;
    schema1:license "GNU GENERAL PUBLIC LICENSE" ;
    schema1:name "blastalign" ;
    schema1:url "http://evolve.zoo.ox.ac.uk/Evolve/Blastalign.html" .

