@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-brainstars a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1097/HTR.0b013e3181a7ecb0" ;
    schema1:description "This package can search and get gene expression data and plots from the brainstars quantitative expression database of the adult mouse brain, which has genome-wide expression profile at 51 adult mouse cns regions." ;
    schema1:identifier biotools:brainstars ;
    schema1:keywords "Adolescent",
        "Brain Injuries",
        "Child",
        "Child, Preschool",
        "Faculty",
        "Female",
        "Gene Expression",
        "Gene expression",
        "Humans",
        "Learning Disabilities",
        "Male",
        "Manuals as Topic",
        "Parents",
        "Referral and Consultation",
        "Remedial Teaching",
        "Severity of Illness Index",
        "Students" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-brainstars" ;
    schema1:url "http://bioconductor.org/packages/release/bioc/html/BrainStars.html" .

