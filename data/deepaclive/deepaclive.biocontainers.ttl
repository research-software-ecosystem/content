@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:deepaclive a schema1:SoftwareApplication ;
    schema1:description "Detecting novel pathogens from ngs reads in real-time during a sequencing run." ;
    schema1:license "MIT" ;
    schema1:name "deepaclive" ;
    schema1:url "https://gitlab.com/dacs-hpi/deepac-live" .

