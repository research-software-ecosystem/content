@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:mreps a schema1:SoftwareApplication ;
    schema1:description "mreps is a flexible and efficient software for identifying serial repeats (usually called tandem repeats) in DNA sequences." ;
    schema1:downloadUrl "https://github.com/gregorykucherov/mreps/archive/2.6.01.tar.gz" ;
    schema1:identifier biotools:mreps ;
    schema1:license "GPL-2.0-or-later" ;
    schema1:name "mreps" ;
    schema1:softwareVersion "2.6.01" ;
    schema1:url "http://mreps.univ-mlv.fr" ;
    spdx:builtFrom biotools:mreps .

