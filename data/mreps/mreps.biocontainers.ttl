@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:mreps a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/gkg617" ;
    schema1:description "Mreps is a flexible and efficient software for identifying serial repeats (usually called tandem repeats) in DNA sequences." ;
    schema1:identifier biotools:mreps ;
    schema1:keywords "DNA",
        "DNA polymorphism",
        "DNA, Bacterial",
        "Genes, Bacterial",
        "Genetic variation",
        "Genetics",
        "Genome, Human",
        "Genomics",
        "Humans",
        "Internet",
        "Neisseria meningitidis",
        "Polymorphism, Genetic",
        "Saccharomyces cerevisiae",
        "Sequence Analysis, DNA",
        "Sequence composition, complexity and repeats",
        "Sequencing",
        "Tandem Repeat Sequences" ;
    schema1:license "GPL" ;
    schema1:name "mreps" ;
    schema1:url "http://mreps.univ-mlv.fr" .

