@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-haplo.stats a schema1:SoftwareApplication ;
    schema1:description "lRoutines for the analysis of indirectly measured haplotypes. The statistical methods assume that all subjects are unrelated and that haplotypes are ambiguous (due to unknown linkage phase of the genetic markers). The main functions are: haplo.em(), haplo.glm(), haplo.score(), and haplo.power(); all of which have detailed examples in the vignette." ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "r-haplo.stats" ;
    schema1:url "http://www.mayo.edu/research/labs/statistical-genetics-genetic-epidemiology/software" .

