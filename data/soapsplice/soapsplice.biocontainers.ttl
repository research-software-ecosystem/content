@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:soapsplice a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.4106",
        "doi:10.3389/fgene.2011.00046" ;
    schema1:description "We have developed a tool soapsplice for genome-wide ab initio detection of splice junction sites from rna-seq, a method using new generation sequencing technologies to sequence the messenger rna." ;
    schema1:identifier biotools:SOAPsplice ;
    schema1:keywords "Benchmarking",
        "Computer Simulation",
        "Exons",
        "Genome, Human",
        "Humans",
        "Introns",
        "Molecular Sequence Annotation",
        "Plasmodium falciparum",
        "Polymorphism, Genetic",
        "RNA Splicing",
        "RNA splicing",
        "Sequence Alignment",
        "Sequence Analysis, RNA" ;
    schema1:license "freely available" ;
    schema1:name "soapsplice" ;
    schema1:url "http://soap.genomics.org.cn/soapsplice.html" .

