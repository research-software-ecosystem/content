@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:soapsplice a schema1:SoftwareApplication ;
    schema1:citation "doi:10.3389/fgene.2011.00046" ;
    schema1:description "We have developed a tool SOAPsplice for genome-wide ab initio detection of splice junction sites from RNA-Seq, a method using new generation sequencing technologies to sequence the messenger RNA." ;
    schema1:downloadUrl "https://depot.galaxyproject.org/software/soapsplice/soapsplice_1.10_src_all.tar.gz" ;
    schema1:identifier biotools:SOAPsplice ;
    schema1:license "freely available" ;
    schema1:name "soapsplice" ;
    schema1:softwareVersion "1.1" ;
    schema1:url "http://soap.genomics.org.cn/soapsplice.html" ;
    spdx:builtFrom biotools:SOAPsplice .

