@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-geoaxe a schema1:SoftwareApplication ;
    schema1:description "Split 'geospatial' objects into pieces. Includes support for some spatial object inputs, 'Well-Known Text', and 'GeoJSON'." ;
    schema1:license "MIT" ;
    schema1:name "r-geoaxe" ;
    schema1:url "https://github.com/ropenscilabs/geoaxe" .

