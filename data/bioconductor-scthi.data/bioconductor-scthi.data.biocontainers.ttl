@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-scthi.data a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18129/b9.bioc.scthi.data" ;
    schema1:description "The package contains examples of single cell data used in vignettes and examples of the scTHI package; data contain both tumor cells and immune cells from public dataset of glioma" ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-scthi.data" ;
    schema1:url "https://bioconductor.org/packages/3.11/data/experiment/html/scTHI.data.html" .

