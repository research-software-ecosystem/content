    schema1:license "GPL-3" ;
    schema1:maintainer "martin-steinegger",
        "milot-mirdita" ;
    schema1:name "foldseek" ;
    schema1:softwareVersion "10.941cd33" ;
    schema1:url "https://github.com/steineggerlab/foldseek" ;
