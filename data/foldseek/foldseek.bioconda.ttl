@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:foldseek a schema1:SoftwareApplication ;
    schema1:author "martin-steinegger",
        "milot-mirdita" ;
    schema1:citation "doi:10.1038/s41586-023-06510-w",
        "doi:10.1038/s41587-023-01773-0",
        "doi:10.1101/2024.04.14.589414" ;
    schema1:description "Foldseek: fast and accurate protein structure search" ;
