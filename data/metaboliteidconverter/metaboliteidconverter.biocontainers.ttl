@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:metaboliteidconverter a schema1:SoftwareApplication ;
    schema1:description "Enrich metabolomic data sets with well known databases such as InChIKey, ChEBI identifiers" ;
    schema1:license "Custom License" ;
    schema1:name "metaboliteidconverter" ;
    schema1:url "https://github.com/phnmnl/container-metaboliteidconverter" .

