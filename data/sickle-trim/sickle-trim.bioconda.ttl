@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:sickle-trim a schema1:SoftwareApplication ;
    schema1:description "Windowed Adaptive Trimming for fastq files using quality." ;
    schema1:downloadUrl "https://github.com/najoshi/sickle/archive/v1.33.tar.gz" ;
    schema1:identifier biotools:sickle ;
    schema1:license "MIT" ;
    schema1:name "sickle-trim" ;
    schema1:softwareHelp "https://github.com/najoshi/sickle/blob/v1.33/README.md" ;
    schema1:softwareVersion "1.33" ;
    schema1:url "https://github.com/najoshi/sickle" ;
    spdx:builtFrom biotools:sickle .

