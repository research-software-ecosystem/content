@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:rust-ncbitaxonomy a schema1:SoftwareApplication ;
    schema1:description "Read NCBI Taxonomy Database from files and work with NCBI Taxonomy DB" ;
    schema1:license "MIT" ;
    schema1:name "rust-ncbitaxonomy" ;
    schema1:url "https://docs.rs/crate/ncbitaxonomy/1.0.3/source/" .

