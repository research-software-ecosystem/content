@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-variantannotation a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btu168" ;
    schema1:description "Bioconductor annotation of genetic variants" ;
    schema1:identifier biotools:variantannotation ;
    schema1:keywords "DNA polymorphism",
        "Genetic Variation",
        "Genetics",
        "Genomics",
        "Molecular Sequence Annotation",
        "Whole genome sequencing" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-variantannotation" ;
    schema1:url "https://bioconductor.org/packages/VariantAnnotation/" .

