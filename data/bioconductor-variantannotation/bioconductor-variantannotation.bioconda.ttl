@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-variantannotation a schema1:SoftwareApplication ;
    schema1:description "Annotation of Genetic Variants" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/VariantAnnotation_1.56.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/VariantAnnotation/VariantAnnotation_1.56.0.tar.gz', 'https://bioarchive.galaxyproject.org/VariantAnnotation_1.56.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-variantannotation/bioconductor-variantannotation_1.56.0_src_all.tar.gz']" ;
    schema1:identifier biotools:variantannotation ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-variantannotation" ;
    schema1:softwareVersion "1.56.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/VariantAnnotation.html" ;
    spdx:builtFrom biotools:variantannotation .

