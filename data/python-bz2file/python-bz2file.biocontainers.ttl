@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:python-bz2file a schema1:SoftwareApplication ;
    schema1:description "Python library for reading and writing bzip2-compressed files." ;
    schema1:license "Custom License" ;
    schema1:name "python-bz2file" ;
    schema1:url "https://github.com/nvawda/bz2file" .

