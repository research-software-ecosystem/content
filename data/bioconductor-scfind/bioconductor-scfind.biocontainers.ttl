@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-scfind a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18129/b9.bioc.scfind" ;
    schema1:description "A search tool for single cell RNA-seq data by gene lists" ;
    schema1:keywords "RNA-Seq",
        "Transcriptomics" ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-scfind" ;
    schema1:url "https://bioconductor.org/packages/3.8/bioc/html/scfind.html" .

