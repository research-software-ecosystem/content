@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:kerneltree a schema1:SoftwareApplication ;
    schema1:description "Ultrafast interval tree implementation stolen from the kernel, modified and wrapped for Python." ;
