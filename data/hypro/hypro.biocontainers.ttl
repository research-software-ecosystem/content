@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:hypro a schema1:SoftwareApplication ;
    schema1:description "Extend hypothetical prokka protein annotations using additional homology searches against larger databases" ;
    schema1:keywords "Clustering" ;
    schema1:license "GPL" ;
    schema1:name "hypro" ;
    schema1:url "https://github.com/hoelzer-lab/hypro.git" .

