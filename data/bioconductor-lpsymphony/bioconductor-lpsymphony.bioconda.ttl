@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-lpsymphony a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1007/0-387-23529-9_5" ;
    schema1:description "Symphony integer linear programming solver in R" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/lpsymphony_1.38.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/lpsymphony/lpsymphony_1.38.0.tar.gz', 'https://bioarchive.galaxyproject.org/lpsymphony_1.38.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-lpsymphony/bioconductor-lpsymphony_1.38.0_src_all.tar.gz']" ;
    schema1:identifier biotools:lpsymphony ;
    schema1:license "EPL" ;
    schema1:name "bioconductor-lpsymphony" ;
    schema1:softwareVersion "1.38.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/lpsymphony.html" ;
    spdx:builtFrom biotools:lpsymphony .

