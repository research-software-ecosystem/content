@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:plink a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1086/519795" ;
    schema1:description "Free, open-source whole genome association analysis toolset, designed to perform a range of basic, large-scale analyses in a computationally efficient manner." ;
    schema1:identifier biotools:plink ;
    schema1:keywords "Clustering",
        "GWAS study",
        "Genetic Linkage",
        "Genome, Human",
        "Humans",
        "Polymorphism, Single Nucleotide",
        "Population" ;
    schema1:license "GPL-2.0" ;
    schema1:name "plink" ;
    schema1:url "http://zzz.bwh.harvard.edu/plink/" .

