@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-fourcseq a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btv335" ;
    schema1:description "Package analyse 4C sequencing data" ;
    schema1:identifier biotools:fourcseq ;
    schema1:keywords "Chromosomes",
        "Genome",
        "High-Throughput Nucleotide Sequencing",
        "Nucleic Acid Conformation",
        "Sequencing",
        "Statistics as Topic" ;
    schema1:license "GPL-3.0" ;
    schema1:name "bioconductor-fourcseq" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/FourCSeq.html" .

