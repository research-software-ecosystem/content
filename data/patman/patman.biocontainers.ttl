@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:patman a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btn223" ;
    schema1:description "Patman searches for short patterns in large dna databases, allowing for approximate matches. it is optimized for searching for many small pattern at the same time, for example microarray probes." ;
    schema1:identifier biotools:patman ;
    schema1:keywords "Base Sequence",
        "Database Management Systems",
        "Databases, Genetic",
        "Genomics",
        "Information Storage and Retrieval",
        "Mapping",
        "Molecular Sequence Data",
        "Sequence Alignment",
        "Sequence Analysis, DNA" ;
    schema1:license "GPL-2.0" ;
    schema1:name "patman" ;
    schema1:url "http://bioinf.eva.mpg.de/patman/" .

