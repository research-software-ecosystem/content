@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-nnnorm a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/bti397" ;
    schema1:description "Spatial and intensity based normalization of cDNA microarray data based on robust neural nets" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/nnNorm_2.74.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/nnNorm/nnNorm_2.74.0.tar.gz', 'https://bioarchive.galaxyproject.org/nnNorm_2.74.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-nnnorm/bioconductor-nnnorm_2.74.0_src_all.tar.gz']" ;
    schema1:identifier biotools:nnnorm ;
    schema1:license "LGPL" ;
    schema1:name "bioconductor-nnnorm" ;
    schema1:softwareVersion "2.74.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/nnNorm.html" ;
    spdx:builtFrom biotools:nnnorm .

