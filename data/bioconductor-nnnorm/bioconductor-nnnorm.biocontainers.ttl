@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-nnnorm a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/bti397" ;
    schema1:description "Spatial and intensity based normalization of cDNA microarray data based on robust neural nets" ;
    schema1:identifier biotools:nnnorm ;
    schema1:keywords "Artifacts",
        "Data quality management",
        "Gene Expression Profiling",
        "Image Interpretation, Computer-Assisted",
        "In Situ Hybridization, Fluorescence",
        "Microarray experiment",
        "Microscopy, Fluorescence",
        "Models, Genetic",
        "Models, Statistical",
        "Neural Networks, Computer",
        "Oligonucleotide Array Sequence Analysis",
        "Pattern Recognition, Automated" ;
    schema1:license "LGPL" ;
    schema1:name "bioconductor-nnnorm" ;
    schema1:url "http://bioconductor.org/packages/3.5/bioc/html/nnNorm.html" .

