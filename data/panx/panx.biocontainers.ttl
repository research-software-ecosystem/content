@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:panx a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/gkx977" ;
    schema1:description "Microbial pan-genome analysis and exploration tool" ;
    schema1:keywords "Bacteria",
        "Computational Biology",
        "Evolution, Molecular",
        "Genome, Bacterial",
        "Genomics",
        "Multigene Family",
        "Phylogeny",
        "Reproducibility of Results" ;
    schema1:license "GPL-3.0" ;
    schema1:name "panx" ;
    schema1:url "http://pangenome.de" .

