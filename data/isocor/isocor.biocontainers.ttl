@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:isocor a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btz209" ;
    schema1:description "A Isotope Correction for mass spectrometry labeling experiments" ;
    schema1:keywords "Isotope Labeling",
        "Isotopes",
        "Mass Spectrometry",
        "Mass spectrometry",
        "Metabolomics",
        "Synthetic Biology" ;
    schema1:license "GPL-3.0" ;
    schema1:name "isocor" ;
    schema1:url "https://github.com/MetaSys-LISBP/IsoCor/" .

