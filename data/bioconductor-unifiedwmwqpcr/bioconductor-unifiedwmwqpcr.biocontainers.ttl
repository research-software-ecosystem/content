@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-unifiedwmwqpcr a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btu313" ;
    schema1:description "Unified Wilcoxon-Mann Whitney Test for testing differential expression in qPCR data" ;
    schema1:identifier biotools:unifiedwmwqpcr ;
    schema1:keywords "Humans",
        "MicroRNAs",
        "Neuroblastoma",
        "PCR experiment",
        "Real-Time Polymerase Chain Reaction",
        "Statistics, Nonparametric" ;
    schema1:license "GPL (>=2)" ;
    schema1:name "bioconductor-unifiedwmwqpcr" ;
    schema1:url "http://bioconductor.org/packages/3.6/bioc/html/unifiedWMWqPCR.html" .

