@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-unifiedwmwqpcr a schema1:SoftwareApplication ;
    schema1:description "Unified Wilcoxon-Mann Whitney Test for testing differential expression in qPCR data" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/unifiedWMWqPCR_1.42.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/unifiedWMWqPCR/unifiedWMWqPCR_1.42.0.tar.gz', 'https://bioarchive.galaxyproject.org/unifiedWMWqPCR_1.42.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-unifiedwmwqpcr/bioconductor-unifiedwmwqpcr_1.42.0_src_all.tar.gz']" ;
    schema1:identifier biotools:unifiedwmwqpcr ;
    schema1:license "GPL (>=2)" ;
    schema1:name "bioconductor-unifiedwmwqpcr" ;
    schema1:softwareVersion "1.42.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/unifiedWMWqPCR.html" ;
    spdx:builtFrom biotools:unifiedwmwqpcr .

