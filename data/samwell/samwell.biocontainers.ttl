@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:samwell a schema1:SoftwareApplication ;
    schema1:description "Useful utilities for biological data formats and analyses" ;
    schema1:license "MIT" ;
    schema1:name "samwell" ;
    schema1:url "https://github.com/myriad-opensource/samwell" .

