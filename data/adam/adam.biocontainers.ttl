@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:adam a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1016/j.livsci.2008.06.028" ;
    schema1:description "Genomics analysis platform built on apache avro, apache spark, and apache parquet" ;
    schema1:identifier biotools:adam ;
    schema1:keywords "Genomics",
        "Simulation experiment" ;
    schema1:license "Apache-2.0" ;
    schema1:name "adam" ;
    schema1:url "https://github.com/bigdatagenomics/adam" .

