@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:kneaddata a schema1:SoftwareApplication ;
    schema1:description "Kneaddata is a tool designed to perform quality control on metagenomic and metatranscriptomic sequencing data, especially data from microbiome experiments." ;
    schema1:license "MIT" ;
    schema1:name "kneaddata" ;
    schema1:url "http://huttenhower.sph.harvard.edu/kneaddata" .

