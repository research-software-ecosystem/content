        "Gene Conversion",
        "Genetic Variation",
        "Genetics, Population",
        "Models, Genetic",
        "Monte Carlo Method",
        "Population genetics",
        "Recombination, Genetic",
        "Systems biology" ;
    schema1:license "Not available" ;
    schema1:name "ms" ;
