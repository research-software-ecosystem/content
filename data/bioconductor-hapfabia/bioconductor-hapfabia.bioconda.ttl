@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-hapfabia a schema1:SoftwareApplication ;
    schema1:description "hapFabia: Identification of very short segments of identity by descent (IBD) characterized by rare variants in large sequencing data" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/hapFabia_1.48.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/hapFabia/hapFabia_1.48.0.tar.gz', 'https://bioarchive.galaxyproject.org/hapFabia_1.48.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-hapfabia/bioconductor-hapfabia_1.48.0_src_all.tar.gz']" ;
    schema1:identifier biotools:hapfabia ;
    schema1:license "LGPL (>= 2.1)" ;
    schema1:name "bioconductor-hapfabia" ;
    schema1:softwareVersion "1.48.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/hapFabia.html" ;
    spdx:builtFrom biotools:hapfabia .

