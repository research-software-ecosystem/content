@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-hapfabia a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/gkt1013" ;
    schema1:description "hapFabia: Identification of very short segments of identity by descent (IBD) characterized by rare variants in large sequencing data" ;
    schema1:identifier biotools:hapfabia ;
    schema1:keywords "Clustering",
        "Genetic Variation",
        "Genetics",
        "Genomics",
        "Genotype and phenotype",
        "Genotyping Techniques",
        "High-Throughput Nucleotide Sequencing",
        "Humans",
        "Inheritance Patterns",
        "Mapping",
        "Sequence Analysis, DNA" ;
    schema1:license "LGPL (>= 2.1)" ;
    schema1:name "bioconductor-hapfabia" ;
    schema1:url "http://bioconductor.org/packages/3.6/bioc/html/hapFabia.html" .

