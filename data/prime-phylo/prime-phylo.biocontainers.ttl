@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:prime-phylo a schema1:SoftwareApplication ;
    schema1:description "Bayesian estimation of gene trees taking the species tree into account" ;
    schema1:keywords "Genetics",
        "Ortholog",
        "Phylogenetics" ;
    schema1:license "custom, see /usr/share/doc/prime-phylo/copyright" ;
    schema1:name "prime-phylo" ;
    schema1:url "http://prime.sbc.su.se" .

