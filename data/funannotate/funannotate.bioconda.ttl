@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:funannotate a schema1:SoftwareApplication ;
    schema1:author "nextgenusfs" ;
    schema1:citation "doi:10.5281/zenodo.1134477" ;
    schema1:description "funannotate: eukaryotic genome annotation pipeline." ;
    schema1:downloadUrl "https://pypi.org/packages/source/f/funannotate/funannotate-1.8.17.tar.gz" ;
    schema1:identifier biotools:funannotate ;
    schema1:license "BSD-2-Clause" ;
    schema1:maintainer "nextgenusfs" ;
    schema1:name "funannotate" ;
    schema1:softwareHelp "https://funannotate.readthedocs.io/en/latest" ;
    schema1:softwareVersion "1.8.17" ;
    schema1:url "https://github.com/nextgenusfs/funannotate" ;
    spdx:builtFrom biotools:funannotate .

