@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:sanitizeme a schema1:SoftwareApplication ;
    schema1:description "GUI and CLI tool for removing host DNA from NGS data." ;
    schema1:license "Apache-2.0" ;
    schema1:name "sanitizeme" ;
    schema1:url "https://github.com/jiangweiyao/SanitizeMe" .

