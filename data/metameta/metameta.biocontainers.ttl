@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:metameta a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s40168-017-0318-y" ;
    schema1:description "Metameta - pipeline for integrating metagenome analysis tools to improve taxonomic profiling" ;
    schema1:keywords "Genomics",
        "Metagenome",
        "Metagenomics" ;
    schema1:license "MIT" ;
    schema1:name "metameta" ;
    schema1:url "https://github.com/pirovc/metameta/" .

