biocontainers:coinfinder a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1101/859371" ;
    schema1:description "A tool for the identification of coincident (associating and dissociating) genes in pangenomes." ;
    schema1:keywords "Genomics" ;
