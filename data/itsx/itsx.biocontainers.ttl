@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:itsx a schema1:SoftwareApplication ;
    schema1:description "Itsx is an open source software utility to extract the highly variable its1 and its2 subregions from its sequences, which is commonly used as a molecular barcode for e.g. fungi." ;
    schema1:keywords "Genomics",
        "Metagenomics" ;
    schema1:license "Not available" ;
    schema1:name "itsx" ;
    schema1:url "http://microbiology.se/software/itsx/" .

