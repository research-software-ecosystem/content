@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-metnet a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18129/b9.bioc.metnet" ;
    schema1:description "Inferring metabolic networks from untargeted high-resolution mass spectrometry data" ;
    schema1:keywords "Mass spectrometry",
        "Metabolomics" ;
    schema1:license "GPL (>= 3)" ;
    schema1:name "bioconductor-metnet" ;
    schema1:url "https://bioconductor.org/packages/3.8/bioc/html/MetNet.html" .

