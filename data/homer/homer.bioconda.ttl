@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:homer a schema1:SoftwareApplication ;
    schema1:author "BioNinja",
        "cokelaer",
        "r78v10a07",
        "simonvh" ;
    schema1:citation "doi:10.1016/j.molcel.2010.05.004" ;
    schema1:description "Software for motif discovery and next generation sequencing analysis." ;
