    schema1:identifier biotools:homer ;
    schema1:license "GPL-3.0-or-later" ;
    schema1:maintainer "BioNinja",
        "cokelaer",
        "r78v10a07",
        "simonvh" ;
    schema1:name "homer" ;
    schema1:softwareHelp "http://homer.ucsd.edu/homer/homer2.html" ;
