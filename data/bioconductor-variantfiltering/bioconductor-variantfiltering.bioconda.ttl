@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-variantfiltering a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Filtering of coding and non-coding genetic variants" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/VariantFiltering_1.42.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/VariantFiltering/VariantFiltering_1.42.0.tar.gz', 'https://bioarchive.galaxyproject.org/VariantFiltering_1.42.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-variantfiltering/bioconductor-variantfiltering_1.42.0_src_all.tar.gz']" ;
    schema1:identifier biotools:variantfiltering ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-variantfiltering" ;
    schema1:softwareVersion "1.42.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/VariantFiltering.html" ;
    spdx:builtFrom biotools:variantfiltering .

