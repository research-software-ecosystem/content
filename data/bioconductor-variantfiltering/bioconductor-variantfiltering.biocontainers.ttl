@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-variantfiltering a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Filtering of coding and non-coding genetic variants" ;
    schema1:identifier biotools:variantfiltering ;
    schema1:keywords "Computational Biology",
        "DNA polymorphism",
        "Gene Expression Profiling",
        "Genetics",
        "Genomics",
        "High-Throughput Screening Assays",
        "Programming Languages",
        "User-Computer Interface" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-variantfiltering" ;
    schema1:url "http://bioconductor.org/packages/3.6/bioc/html/VariantFiltering.html" .

