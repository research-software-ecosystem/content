@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-htssip a schema1:SoftwareApplication ;
    schema1:description "Functions for analyzing high throughput sequencing  stable isotope probing (hts-sip) data. analyses include high resolution stable isotope probing (hr-sip), multi-window high resolution stable isotope probing (mw-hr-sip),  and quantitative stable isotope probing (q-sip). " ;
    schema1:license "GPL-2 | file LICENSE" ;
    schema1:name "r-htssip" ;
    schema1:url "https://CRAN.R-project.org/package=HTSSIP" .

