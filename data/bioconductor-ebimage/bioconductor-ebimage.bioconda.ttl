@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-ebimage a schema1:SoftwareApplication ;
    schema1:description "Image processing and analysis toolbox for R" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/EBImage_4.48.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/EBImage/EBImage_4.48.0.tar.gz', 'https://bioarchive.galaxyproject.org/EBImage_4.48.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-ebimage/bioconductor-ebimage_4.48.0_src_all.tar.gz']" ;
    schema1:identifier biotools:ebimage ;
    schema1:license "LGPL" ;
    schema1:name "bioconductor-ebimage" ;
    schema1:softwareVersion "4.48.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/EBImage.html" ;
    spdx:builtFrom biotools:ebimage .

