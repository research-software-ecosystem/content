@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:metaeuk a schema1:SoftwareApplication ;
    schema1:author "elileka",
        "milot-mirdita" ;
    schema1:citation "doi:10.1186/s40168-020-00808-x" ;
    schema1:description "MetaEuk - sensitive, high-throughput gene discovery and annotation for large-scale eukaryotic metagenomics" ;
    schema1:downloadUrl "https://github.com/soedinglab/metaeuk/archive/7-bba0d80.tar.gz" ;
    schema1:identifier biotools:metaeuk ;
    schema1:license "GPL-3" ;
    schema1:maintainer "elileka",
        "milot-mirdita" ;
    schema1:name "metaeuk" ;
    schema1:softwareVersion "7.bba0d80" ;
    schema1:url "https://github.com/soedinglab/metaeuk" ;
    spdx:builtFrom biotools:metaeuk .

