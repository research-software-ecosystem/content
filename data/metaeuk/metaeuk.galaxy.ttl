@prefix edam: <http://edamontology.org/> .
@prefix galaxytool: <https://github.com/galaxyproject/tools-iuc/tree/master/tools/> .
@prefix schema1: <http://schema.org/> .

galaxytool:metaeuk a schema1:SoftwareApplication ;
    schema1:applicationSubCategory "edam:topic_0623",
        "edam:topic_3174" ;
    schema1:description "MetaEuk is a modular toolkit designed for large-scale gene discovery andannotation in eukaryotic metagenomic contigs. Metaeuk combines the fast andsensitive homology search capabilities of MMseqs2 with a dynamic programmingprocedure to recover optimal exons sets. It reduces redundancies in multiplediscoveries of the same gene and resolves conflicting gene predictions onthe same strand. " ;
    schema1:featureList edam:operation_3663 ;
    schema1:identifier "bioconda:metaeuk",
        "biotools:MetaEuk",
        "galaxywf:workflow?id=9b9e1e28f3683f92" ;
    schema1:keywords "Genome annotation",
        "Sequence Analysis" ;
    schema1:name "metaeuk" ;
    schema1:softwareVersion "7.bba0d80" ;
    schema1:url "https://github.com/soedinglab/metaeuk" .

