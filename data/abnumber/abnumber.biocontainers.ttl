@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:abnumber a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btv552" ;
    schema1:description "Abnumber antibody numbering using anarci" ;
    schema1:identifier biotools:anarci ;
    schema1:keywords "Antibodies",
        "Computational Biology",
        "Humans",
        "Immunoglobulin Variable Region",
        "Models, Molecular",
        "Protein structure analysis",
        "Proteomics",
        "Receptors, Antigen, T-Cell" ;
    schema1:license "Not available" ;
    schema1:name "abnumber" ;
    schema1:url "https://github.com/prihoda/AbNumber" .

