@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-classifyr a schema1:SoftwareApplication ;
    schema1:description "A framework for cross-validated classification problems, with applications to differential variability and differential distribution testing" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/ClassifyR_3.14.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/ClassifyR/ClassifyR_3.14.0.tar.gz', 'https://bioarchive.galaxyproject.org/ClassifyR_3.14.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-classifyr/bioconductor-classifyr_3.14.0_src_all.tar.gz']" ;
    schema1:identifier biotools:classifyr ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-classifyr" ;
    schema1:softwareVersion "3.14.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/ClassifyR.html" ;
    spdx:builtFrom biotools:classifyr .

