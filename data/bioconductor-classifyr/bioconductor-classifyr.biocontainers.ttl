@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-classifyr a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btv066" ;
    schema1:description "A framework for cross-validated classification problems, with applications to differential variability and differential distribution testing" ;
    schema1:identifier biotools:classifyr ;
    schema1:keywords "Classification",
        "Gene Expression Profiling",
        "Humans",
        "Sequence analysis" ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-classifyr" ;
    schema1:url "http://bioconductor.org/packages/3.6/bioc/html/ClassifyR.html" .

