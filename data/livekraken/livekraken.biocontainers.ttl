@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:livekraken a schema1:SoftwareApplication ;
    schema1:description "LiveKraken is a real-time metagenomic classifier for Illumina sequencing data." ;
    schema1:license "GPL-3.0" ;
    schema1:name "livekraken" ;
    schema1:url "https://gitlab.com/SimonHTausch/LiveKraken" .

