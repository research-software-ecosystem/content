@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:pipdeptree a schema1:SoftwareApplication ;
    schema1:description "Display dependency tree of the installed python 3 packages" ;
    schema1:license "MIT" ;
    schema1:name "pipdeptree" ;
    schema1:url "https://github.com/naiquevin/pipdeptree" .

