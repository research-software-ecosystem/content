@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:ryuto a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s12859-019-2786-5" ;
    schema1:description "Network-Flow based Transcriptome Reconstruction" ;
    schema1:keywords "Computational Biology",
        "Gene Expression Profiling",
        "High-Throughput Nucleotide Sequencing",
        "Humans",
        "RNA, Messenger",
        "RNA-Seq",
        "Sequence Analysis, RNA",
        "Transcriptome" ;
    schema1:license "BSD" ;
    schema1:name "ryuto" ;
    schema1:url "https://github.com/studla/RYUTO/" .

