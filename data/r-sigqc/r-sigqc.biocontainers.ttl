@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-sigqc a schema1:SoftwareApplication ;
    schema1:description "Provides gene signature quality control metrics in publication ready plots. namely, enables the visualization of properties such as expression, variability, correlation, and comparison of methods of standardisation and scoring metrics." ;
    schema1:license "GNU GENERAL PUBLIC LICENSE Version 3" ;
    schema1:name "r-sigqc" ;
    schema1:url "https://CRAN.R-project.org/package=sigQC" .

