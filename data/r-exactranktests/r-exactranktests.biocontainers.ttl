@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-exactranktests a schema1:SoftwareApplication ;
    schema1:description "Computes exact conditional p-values and quantiles using an implementation of the Shift-Algorithm by Streitberg & Roehmel." ;
    schema1:license "GPL-2|GPL-3" ;
    schema1:name "r-exactranktests" ;
    schema1:url "https://cran.rstudio.com/web/packages/exactRankTests/index.html" .

