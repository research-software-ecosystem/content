@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:sequenza-utils a schema1:SoftwareApplication ;
    schema1:description "Analysis of cancer sequencing samples, utilities for the R package sequenza" ;
    schema1:license "GPL-3.0" ;
    schema1:name "sequenza-utils" ;
    schema1:url "http://sequenza-utils.readthedocs.org" .

