@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:ratt a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/gkq1268" ;
    schema1:description "Rapid Annotation Transfer Tool" ;
    schema1:identifier biotools:ratt ;
    schema1:keywords "Assembly",
        "DNA",
        "Genome, Bacterial",
        "Genome, Protozoan",
        "Genomics",
        "Molecular Sequence Annotation",
        "Mycobacterium tuberculosis",
        "Plasmodium berghei",
        "Plasmodium chabaudi" ;
    schema1:license "GPL-3.0" ;
    schema1:name "ratt" ;
    schema1:url "http://ratt.sourceforge.net" .

