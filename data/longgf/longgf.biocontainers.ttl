@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:longgf a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s12864-020-07207-4" ;
    schema1:description "A fast tool to detect gene fusion from long-read RNA-seq data." ;
    schema1:keywords "Genomics",
        "RNA-Seq",
        "Transcriptome" ;
    schema1:license "GPL-3.0" ;
    schema1:name "longgf" ;
    schema1:url "https://github.com/WGLab/LongGF" .

