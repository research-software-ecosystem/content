@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-slalom a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18129/b9.bioc.slalom" ;
    schema1:description "Factorial Latent Variable Modeling of Single-Cell RNA-Seq Data" ;
    schema1:keywords "RNA-Seq",
        "Transcriptome",
        "Transcriptomics" ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-slalom" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/slalom.html" .

