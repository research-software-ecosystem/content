@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:metagem a schema1:SoftwareApplication ;
    schema1:author "franciscozorrilla" ;
    schema1:citation "doi:10.1093/nar/gkab815" ;
    schema1:description "Generate context specific genome-scale metabolic models and predict metabolic interactions directly from metagenomic data" ;
    schema1:downloadUrl "https://github.com/franciscozorrilla/metaGEM/archive/refs/tags/v1.0.5.tar.gz" ;
    schema1:identifier biotools:metagem ;
    schema1:license "MIT" ;
    schema1:maintainer "franciscozorrilla" ;
    schema1:name "metagem" ;
    schema1:softwareVersion "1.0.5" ;
    schema1:url "https://github.com/franciscozorrilla/metaGEM" ;
    spdx:builtFrom biotools:metagem .

