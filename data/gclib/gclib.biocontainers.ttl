@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:gclib a schema1:SoftwareApplication ;
    schema1:description "GCLib - Genomic C++ library of reusable code for bioinformatics projects" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "gclib" ;
    schema1:url "https://github.com/gpertea/gclib" .

