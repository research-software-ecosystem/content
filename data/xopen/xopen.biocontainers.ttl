@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:xopen a schema1:SoftwareApplication ;
    schema1:description "Python3 module to open compressed files transparently" ;
    schema1:keywords "Genomics",
        "Metagenomics" ;
    schema1:license "MIT" ;
    schema1:name "xopen" ;
    schema1:url "https://github.com/marcelm/xopen" .

