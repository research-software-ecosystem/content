@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bamclipper a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/s41598-017-01703-6" ;
    schema1:description "Remove primer sequence from BAM alignments by soft-clipping." ;
    schema1:keywords "Base Sequence",
        "Computer Simulation",
        "DNA Primers",
        "Gene Frequency",
        "High-Throughput Nucleotide Sequencing",
        "Humans",
        "Mutation" ;
    schema1:license "MIT" ;
    schema1:name "bamclipper" ;
    schema1:url "https://github.com/tommyau/bamclipper" .

