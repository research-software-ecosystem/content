@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:platon a schema1:SoftwareApplication ;
    schema1:author "oschwengers" ;
    schema1:description "Plasmid contig classification and characterization for short read draft assemblies." ;
    schema1:downloadUrl "https://github.com/oschwengers/platon/archive/v1.7.tar.gz" ;
    schema1:identifier biotools:platon ;
    schema1:license "GPLv3" ;
    schema1:maintainer "oschwengers" ;
    schema1:name "platon" ;
    schema1:softwareVersion "1.7" ;
    schema1:url "https://github.com/oschwengers/platon" ;
    spdx:builtFrom biotools:platon .

