@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:platon a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1099/mgen.0.000398" ;
    schema1:description "Plasmid contig classification and characterization for short read draft assemblies." ;
    schema1:identifier biotools:platon ;
    schema1:keywords "Clustering",
        "Genomics",
        "Mobile genetic elements",
        "Protein Sequences" ;
    schema1:license "GPL-3.0" ;
    schema1:name "platon" ;
    schema1:url "https://github.com/oschwengers/platon" .

