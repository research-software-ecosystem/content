@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:conus a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/1471-2105-5-71" ;
    schema1:description "CONUS is an implementation of simple stochastic context-free grammars for RNA secondary structure analysis.CONUS developed for exploring the consequences of different single sequence SCFG designs in predicting RNA secondary structure." ;
    schema1:identifier biotools:CONUS ;
    schema1:keywords "Computational Biology",
        "Models, Statistical",
        "Nucleic Acid Conformation",
        "Predictive Value of Tests",
        "RNA",
        "Stochastic Processes",
        "Structure analysis" ;
    schema1:license "file" ;
    schema1:name "conus" ;
    schema1:url "http://eddylab.org/software/conus/" .

