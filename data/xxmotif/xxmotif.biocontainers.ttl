@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:xxmotif a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/gks602",
        "doi:10.1101/gr.139881.112" ;
    schema1:description "eXhaustive, weight matriX-based motif discovery in nucleotide sequences" ;
    schema1:identifier biotools:xxmotif ;
    schema1:keywords "Animals",
        "DNA",
        "Drosophila melanogaster",
        "Enhancer Elements, Genetic",
        "Genome, Fungal",
        "Genome, Human",
        "Genome, Insect",
        "Humans",
        "MicroRNAs",
        "Nucleotide Motifs",
        "Position-Specific Scoring Matrices",
        "Promoter Regions, Genetic",
        "Saccharomyces cerevisiae",
        "Sequence Analysis, DNA",
        "Sequence analysis",
        "Sequence sites, features and motifs",
        "Transcription Initiation Site" ;
    schema1:license "GPL-3.0" ;
    schema1:name "xxmotif" ;
    schema1:url "https://github.com/soedinglab/xxmotif" .

