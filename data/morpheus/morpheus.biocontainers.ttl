@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:morpheus a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1021/pr301024c" ;
    schema1:description "mass spectrometry–based proteomics database search algorithm" ;
    schema1:identifier biotools:morpheus ;
    schema1:keywords "Chromatography, Liquid",
        "Escherichia coli Proteins",
        "Humans",
        "Mass Spectrometry",
        "Mass spectrometry",
        "Proteomics",
        "Saccharomyces cerevisiae Proteins" ;
    schema1:license "MIT" ;
    schema1:name "morpheus" ;
    schema1:url "https://github.com/cwenger/Morpheus/" .

