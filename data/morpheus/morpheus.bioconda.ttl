@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:morpheus a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1021/pr301024c" ;
    schema1:description "mass spectrometry–based proteomics database search algorithm" ;
    schema1:downloadUrl "https://github.com/cwenger/Morpheus/releases/download/r290/Morpheus_mzML_Mono.tar.gz" ;
    schema1:identifier biotools:morpheus ;
    schema1:license "MIT" ;
    schema1:name "morpheus" ;
    schema1:softwareHelp "https://cwenger.github.io/Morpheus/" ;
    schema1:softwareVersion "290" ;
    schema1:url "https://github.com/cwenger/Morpheus/" ;
    spdx:builtFrom biotools:morpheus .

