@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-beat a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "BEAT - BS-Seq Epimutation Analysis Toolkit" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/BEAT_1.44.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/BEAT/BEAT_1.44.0.tar.gz', 'https://bioarchive.galaxyproject.org/BEAT_1.44.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-beat/bioconductor-beat_1.44.0_src_all.tar.gz']" ;
    schema1:identifier biotools:beat ;
    schema1:license "LGPL (>= 3.0)" ;
    schema1:name "bioconductor-beat" ;
    schema1:softwareVersion "1.44.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/BEAT.html" ;
    spdx:builtFrom biotools:beat .

