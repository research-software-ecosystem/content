@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-beat a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "BEAT - BS-Seq Epimutation Analysis Toolkit" ;
    schema1:identifier biotools:beat ;
    schema1:keywords "Computational Biology",
        "Epigenetics",
        "Gene Expression Profiling",
        "Genetics",
        "Genomics",
        "High-Throughput Screening Assays",
        "Programming Languages",
        "User-Computer Interface" ;
    schema1:license "LGPL (>= 3.0)" ;
    schema1:name "bioconductor-beat" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/BEAT.html" .

