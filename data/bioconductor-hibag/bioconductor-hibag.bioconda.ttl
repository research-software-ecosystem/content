@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-hibag a schema1:SoftwareApplication ;
    schema1:description "HLA Genotype Imputation with Attribute Bagging" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/HIBAG_1.46.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/HIBAG/HIBAG_1.46.0.tar.gz', 'https://bioarchive.galaxyproject.org/HIBAG_1.46.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-hibag/bioconductor-hibag_1.46.0_src_all.tar.gz']" ;
    schema1:identifier biotools:hibag ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-hibag" ;
    schema1:softwareVersion "1.46.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/HIBAG.html" ;
    spdx:builtFrom biotools:hibag .

