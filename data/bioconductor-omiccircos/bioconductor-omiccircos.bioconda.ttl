@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-omiccircos a schema1:SoftwareApplication ;
    schema1:citation "doi:10.4137/cin.s13495" ;
    schema1:description "High-quality circular visualization of omics data" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/OmicCircos_1.44.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/OmicCircos/OmicCircos_1.44.0.tar.gz', 'https://bioarchive.galaxyproject.org/OmicCircos_1.44.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-omiccircos/bioconductor-omiccircos_1.44.0_src_all.tar.gz']" ;
    schema1:identifier biotools:omiccircos ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-omiccircos" ;
    schema1:softwareVersion "1.44.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/OmicCircos.html" ;
    spdx:builtFrom biotools:omiccircos .

