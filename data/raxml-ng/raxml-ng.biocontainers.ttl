@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:raxml-ng a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btu033",
        "doi:10.1093/bioinformatics/btz305",
        "doi:10.1093/sysbio/syu084" ;
    schema1:description "RAxML Next Generation: faster, easier-to-use and more flexible" ;
    schema1:keywords "Genetics",
        "Likelihood Functions",
        "Phylogenetics",
        "Phylogeny" ;
    schema1:license "AGPL-3" ;
    schema1:name "raxml-ng" ;
    schema1:url "https://github.com/amkozlov/raxml-ng" .

