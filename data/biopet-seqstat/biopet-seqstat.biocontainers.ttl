@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:biopet-seqstat a schema1:SoftwareApplication ;
    schema1:description "Seqstats outputs several stats on a fastq file." ;
    schema1:license "MIT" ;
    schema1:name "biopet-seqstat" ;
    schema1:url "https://github.com/biopet/seqstat" .

