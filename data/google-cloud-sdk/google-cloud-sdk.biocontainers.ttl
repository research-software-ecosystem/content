@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:google-cloud-sdk a schema1:SoftwareApplication ;
    schema1:description "Command-line interface for Google Cloud Platform products and services" ;
    schema1:license "Apache v2.0" ;
    schema1:name "google-cloud-sdk" ;
    schema1:url "https://github.com/GoogleCloudPlatform/cloud-sdk-docker" .

