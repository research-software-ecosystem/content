@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-intad a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18129/b9.bioc.intad" ;
    schema1:description "Search for correlation between epigenetic signals and gene expression in TADs" ;
    schema1:keywords "Gene Expression",
        "Genetics" ;
    schema1:license "GPL (>=2)" ;
    schema1:name "bioconductor-intad" ;
    schema1:url "https://bioconductor.org/packages/3.8/bioc/html/InTAD.html" .

