@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:pepquery a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1101/gr.235028.118" ;
    schema1:description "PepQuery is a peptide-centric search engine for novel peptide identification and validation." ;
    schema1:keywords "Genome, Human",
        "Genomics",
        "Humans",
        "Polymorphism, Genetic",
        "Proteome",
        "Proteomics",
        "Sequence Analysis, DNA",
        "Sequence Analysis, Protein" ;
    schema1:license "GPL-3" ;
    schema1:name "pepquery" ;
    schema1:url "https://github.com/bzhanglab/PepQuery" .

