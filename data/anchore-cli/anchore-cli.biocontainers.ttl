@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:anchore-cli a schema1:SoftwareApplication ;
    schema1:description "The Anchore CLI provides a command line interface on top of the Anchore Engine REST API." ;
