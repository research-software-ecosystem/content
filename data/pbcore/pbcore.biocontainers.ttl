@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:pbcore a schema1:SoftwareApplication ;
    schema1:description "A python library for reading and writing pacbio data files" ;
    schema1:license "BSD-3-Clause-Clear" ;
    schema1:name "pbcore" ;
    schema1:url "https://github.com/PacificBiosciences/pbbioconda" .

