@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:htseq a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btac166",
        "doi:10.1093/bioinformatics/btu638" ;
    schema1:description "HTSeq is a Python library to facilitate processing and analysis of data from high-throughput sequencing (HTS) experiments." ;
    schema1:downloadUrl "https://pypi.org/packages/source/h/htseq/htseq-2.1.2.tar.gz" ;
    schema1:identifier biotools:htseq ;
    schema1:license "GPL-3.0-only" ;
    schema1:name "htseq" ;
    schema1:softwareHelp "https://htseq.readthedocs.io/en/latest" ;
    schema1:softwareVersion "2.1.2" ;
    schema1:url "https://github.com/htseq/htseq" ;
    spdx:builtFrom biotools:htseq .

