@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:htseq a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btu638" ;
    schema1:description "Python framework to process and analyse high-throughput sequencing (hts) data" ;
    schema1:identifier biotools:htseq ;
    schema1:keywords "Gene Expression Regulation",
        "Genome, Human",
        "Genomics",
        "High-Throughput Nucleotide Sequencing",
        "Humans",
        "Sequence analysis" ;
    schema1:license "GPL-3.0" ;
    schema1:name "htseq" ;
    schema1:url "https://github.com/simon-anders/htseq" .

