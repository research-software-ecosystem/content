@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:pasta a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/gku399" ;
    schema1:description "An implementation of the Practical Alignment using Sate and TrAnsitivity) algorithm" ;
    schema1:identifier biotools:pasta ;
    schema1:keywords "Amyloid",
        "Clustering",
        "Internet",
        "Intrinsically Disordered Proteins",
        "Peptides",
        "Point Mutation",
        "Protein Structure, Secondary",
        "Protein interactions",
        "Sequence Alignment",
        "Sequence Analysis, Protein",
        "Sequence analysis" ;
    schema1:license "GPL-3.0" ;
    schema1:name "pasta" ;
    schema1:url "https://github.com/smirarab/pasta" .

