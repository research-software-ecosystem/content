  "@id": "https://bio.tools/agrischemas",
  "@type": "sc:SoftwareApplication",
  "dcterms:conformsTo": "https://bioschemas.org/profiles/ComputationalTool/0.6-DRAFT",
  "sc:description": "AgriSchemas extends established standards – primarily schema.org and Bioschemas – adopting their philosophy of simple, practical modeling to enable interoperable data sharing. Unlike formal OWL-based\nontologies, which can be computationally heavy and complex to implement, AgriSchemas utilizes a lightweight, low-formal schematization approach. This makes it highly suitable for the automatic integration of semi-structured and large datasets, enabling exploratory research (e.g., identifying candidate genes) through APIs, graph query languages, and annotated web pages. This approach complements highly formalized ontologies, providing a pragmatic pathway to share \"farm-to-fork\" data.",
  "sc:name": "AgriSchemas",
  "sc:url": "https://github.com/Rothamsted/agri-schemas"
}