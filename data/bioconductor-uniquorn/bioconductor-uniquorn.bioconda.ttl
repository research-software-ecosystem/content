@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-uniquorn a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18632/oncotarget.16110" ;
    schema1:description "Identification of cancer cell lines based on their weighted mutational/ variational fingerprint" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/Uniquorn_2.30.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/Uniquorn/Uniquorn_2.30.0.tar.gz', 'https://bioarchive.galaxyproject.org/Uniquorn_2.30.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-uniquorn/bioconductor-uniquorn_2.30.0_src_all.tar.gz']" ;
    schema1:identifier biotools:uniquorn ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-uniquorn" ;
    schema1:softwareVersion "2.30.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/Uniquorn.html" ;
    spdx:builtFrom biotools:uniquorn .

