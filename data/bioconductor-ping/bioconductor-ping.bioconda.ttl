@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-ping a schema1:SoftwareApplication ;
    schema1:description "Probabilistic inference for Nucleosome Positioning with MNase-based or Sonicated Short-read Data" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/PING_2.50.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/PING/PING_2.50.0.tar.gz', 'https://bioarchive.galaxyproject.org/PING_2.50.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-ping/bioconductor-ping_2.50.0_src_all.tar.gz']" ;
    schema1:identifier biotools:ping ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-ping" ;
    schema1:softwareVersion "2.50.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/PING.html" ;
    spdx:builtFrom biotools:ping .

