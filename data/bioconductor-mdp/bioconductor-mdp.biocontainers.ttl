@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-mdp a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18129/b9.bioc.mdp" ;
    schema1:description "Molecular Degree of Perturbation calculates scores for transcriptome data samples based on their perturbation from controls" ;
    schema1:keywords "Transcriptome",
        "Transcriptomics" ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-mdp" ;
    schema1:url "https://bioconductor.org/packages/3.8/bioc/html/mdp.html" .

