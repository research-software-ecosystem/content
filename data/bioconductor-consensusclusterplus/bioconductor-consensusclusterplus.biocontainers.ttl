@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-consensusclusterplus a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btq170" ;
    schema1:description "ConsensusClusterPlus" ;
    schema1:identifier biotools:consensusclusterplus ;
    schema1:keywords "Cluster Analysis",
        "Clustering",
        "Data Mining",
        "Data mining",
        "Data visualisation",
        "Gene Expression Profiling",
        "Principal Component Analysis" ;
    schema1:license "GPL version 2" ;
    schema1:name "bioconductor-consensusclusterplus" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/ConsensusClusterPlus.html" .

