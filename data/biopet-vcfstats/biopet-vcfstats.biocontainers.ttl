@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:biopet-vcfstats a schema1:SoftwareApplication ;
    schema1:description "Vcfstats is a tool that can generate metrics from a vcf file." ;
    schema1:license "MIT" ;
    schema1:name "biopet-vcfstats" ;
    schema1:url "https://github.com/biopet/vcfstats" .

