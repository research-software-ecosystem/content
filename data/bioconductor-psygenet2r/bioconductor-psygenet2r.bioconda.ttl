@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-psygenet2r a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btv301" ;
    schema1:description "psygenet2r - An R package for querying PsyGeNET and to perform comorbidity studies in psychiatric disorders" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.18/bioc/src/contrib/psygenet2r_1.34.0.tar.gz', 'https://bioconductor.org/packages/3.18/bioc/src/contrib/Archive/psygenet2r/psygenet2r_1.34.0.tar.gz', 'https://bioarchive.galaxyproject.org/psygenet2r_1.34.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-psygenet2r/bioconductor-psygenet2r_1.34.0_src_all.tar.gz']" ;
    schema1:identifier biotools:psygenet2r ;
    schema1:license "MIT + file LICENSE" ;
    schema1:name "bioconductor-psygenet2r" ;
    schema1:softwareVersion "1.34.0" ;
    schema1:url "https://bioconductor.org/packages/3.18/bioc/html/psygenet2r.html" ;
    spdx:builtFrom biotools:psygenet2r .

