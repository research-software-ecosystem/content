@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:idba a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1007/978-3-642-12683-3_28" ;
    schema1:description "IDBA is a practical iterative De Bruijn Graph De Novo Assembler for sequence assembly in bioinformatics." ;
    schema1:downloadUrl "https://github.com/loneknightpy/idba/archive/1.1.3.tar.gz" ;
    schema1:identifier biotools:idba ;
    schema1:license "GPL2" ;
    schema1:name "idba" ;
    schema1:softwareHelp "https://i.cs.hku.hk/~alse/hkubrg/projects/idba_ud" ;
    schema1:softwareVersion "1.1.3" ;
    schema1:url "https://i.cs.hku.hk/~alse/hkubrg/projects/idba_ud" ;
    spdx:builtFrom biotools:idba .

