@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:idba a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1007/978-3-642-12683-3_28" ;
    schema1:description "A short read assembler based on iterative de bruijn graph. it is developed under 64-bit linux, but should be suitable for all unix-like system." ;
    schema1:identifier biotools:idba ;
    schema1:keywords "RNA-Seq",
        "Sequence assembly",
        "Transcriptome" ;
    schema1:license "GNU" ;
    schema1:name "idba" ;
    schema1:url "https://github.com/loneknightpy/idba" .

