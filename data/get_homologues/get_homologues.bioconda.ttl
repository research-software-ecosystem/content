@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:get_homologues a schema1:SoftwareApplication ;
    schema1:citation "doi:https://doi.org/10.1007/978-1-0716-2429-6_9",
        "doi:https://doi.org/10.1007/978-1-4939-1720-4_14",
        "doi:https://doi.org/10.1128/AEM.02411-13",
        "doi:https://doi.org/10.3389/fpls.2017.00184" ;
    schema1:description "A versatile software package for pan-genome analysis, including GET_HOMOLOGUES and GET_HOMOLOGUES-EST" ;
    schema1:downloadUrl "https://github.com/eead-csic-compbio/get_homologues/archive/refs/tags/v3.8.1.tar.gz" ;
    schema1:identifier biotools:get_homologues ;
    schema1:license "GPL-3.0-or-later" ;
    schema1:name "get_homologues" ;
    schema1:softwareVersion "3.8.1" ;
    schema1:url "https://github.com/eead-csic-compbio/get_homologues" ;
    spdx:builtFrom biotools:get_homologues .

