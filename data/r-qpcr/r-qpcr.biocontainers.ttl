@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-qpcr a schema1:SoftwareApplication ;
    schema1:description "Model fitting, optimal model selection and calculation of various features that are essential in the analysis of quantitative real-time polymerase chain reaction (qPCR)." ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "r-qpcr" ;
    schema1:url "https://CRAN.R-project.org/package=qpcR" .

