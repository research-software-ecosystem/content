@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:masurca a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btt476" ;
    schema1:description "Genome assembly and analysis toolkit contains of MaSuRCA genome assembler, QuORUM error corrector for Illumina data, POLCA genome polishing software, Chromosome scaffolder, jellyfish mer counter, and MUMmer aligner" ;
    schema1:identifier biotools:masurca ;
    schema1:keywords "Animals",
        "Genome, Bacterial",
        "Genomics",
        "Mice",
        "Rhodobacter sphaeroides",
        "Sequence Analysis, DNA",
        "Sequence analysis",
        "Sequence assembly",
        "Whole genome sequencing" ;
    schema1:license "GPL-3.0" ;
    schema1:name "masurca" ;
    schema1:url "https://github.com/alekseyzimin/masurca" .

