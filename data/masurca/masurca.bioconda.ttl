@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:masurca a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btt476" ;
    schema1:description "MaSuRCA (Maryland Super-Read Celera Assembler) genome assembly software." ;
    schema1:downloadUrl "https://github.com/alekseyzimin/masurca/releases/download/v4.1.4/MaSuRCA-4.1.4.tar.gz" ;
    schema1:identifier biotools:masurca ;
    schema1:license "GPL-3.0-only" ;
    schema1:name "masurca" ;
    schema1:softwareHelp "https://github.com/alekseyzimin/masurca/blob/v4.1.4/README.md" ;
    schema1:softwareVersion "4.1.4" ;
    schema1:url "https://masurca.blogspot.co.uk" ;
    spdx:builtFrom biotools:masurca .

