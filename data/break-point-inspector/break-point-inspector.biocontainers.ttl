@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:break-point-inspector a schema1:SoftwareApplication ;
    schema1:description "Bpi uses manta’s variant calls to re-analyse bam files and precisely determine the location of the breaks, and applies a set of filters to remove false positives, thereby increasing the accuracy of manta’s calls." ;
    schema1:license "MIT" ;
    schema1:name "break-point-inspector" ;
    schema1:url "https://github.com/hartwigmedical/hmftools/tree/master/break-point-inspector" .

