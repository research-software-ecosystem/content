@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:art a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btr708" ;
    schema1:description "Illumina, 454 and solid read simulator" ;
    schema1:identifier biotools:art ;
    schema1:keywords "Bioinformatics",
        "Chromosomes, Human, Pair 17",
        "Gene Expression",
        "Genetic Variation",
        "Genetics",
        "High-Throughput Nucleotide Sequencing",
        "Humans",
        "Sequence Analysis, DNA" ;
    schema1:license "GPL-2.0" ;
    schema1:name "art" ;
    schema1:url "https://www.niehs.nih.gov/research/resources/software/biostatistics/art/index.cfm" .

