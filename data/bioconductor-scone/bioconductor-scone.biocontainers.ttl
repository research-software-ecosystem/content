@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-scone a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18129/b9.bioc.scone" ;
    schema1:description "Single cell overview of normalized expression data" ;
    schema1:keywords "RNA-Seq",
        "Transcriptomics" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-scone" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/scone.html" .

