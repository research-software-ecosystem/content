@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:mintmap a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/srep41184" ;
    schema1:description "Generate trf profiles from short rna-seq datasets" ;
    schema1:identifier biotools:mintmap ;
    schema1:keywords "Animals",
        "Cell Nucleus",
        "Cell biology",
        "Functional, regulatory and non-coding RNA",
        "High-Throughput Nucleotide Sequencing",
        "Humans",
        "Male",
        "Mice",
        "Mitochondria",
        "Models, Molecular",
        "Nucleic Acid Conformation",
        "RNA, Transfer",
        "RNA-seq",
        "Sequence Analysis, RNA" ;
    schema1:license "Not available" ;
    schema1:name "mintmap" ;
    schema1:url "https://github.com/TJU-CMC-Org/MINTmap" .

