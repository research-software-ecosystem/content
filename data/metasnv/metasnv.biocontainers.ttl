@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:metasnv a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1371/JOURNAL.PONE.0182392" ;
    schema1:description "SNV calling software" ;
    schema1:identifier biotools:metasnv ;
    schema1:keywords "DNA polymorphism",
        "High-Throughput Nucleotide Sequencing",
        "Humans",
        "Metagenomic sequencing",
        "Metagenomics",
        "Sequence Analysis, DNA" ;
    schema1:license "GPL-3.0" ;
    schema1:name "metasnv" ;
    schema1:url "http://metasnv.embl.de" .

