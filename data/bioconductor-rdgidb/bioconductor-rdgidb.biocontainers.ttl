@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-rdgidb a schema1:SoftwareApplication ;
    schema1:citation "doi:10.12688/f1000research.9357.1" ;
    schema1:description "Wrapper for the drug gene interaction database. for simplicity, its query function and output resembles the user interface and results format provided on the dgidb website." ;
    schema1:identifier biotools:rdgidb ;
    schema1:keywords "Compound libraries and screening",
        "Drug discovery",
        "Genetics",
        "Genomics" ;
    schema1:license "MIT" ;
    schema1:name "bioconductor-rdgidb" ;
    schema1:url "http://bioconductor.org/packages/release/bioc/html/rDGIdb.html" .

