@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-biganalytics a schema1:SoftwareApplication ;
    schema1:description "Extend the bigmemory package with various analytics. Functions bigkmeans and binit may also be used with native R objects. For tapply-like functions, the bigtabulate package may also be helpful. For linear algebra support, see bigalgebra. For mutex (locking) support for advanced shared-memory usage, see synchronicity." ;
    schema1:license "Apache 2.0" ;
    schema1:name "r-biganalytics" ;
    schema1:url "https://cran.r-project.org/package=biganalytics" .

