      "sc:citation": {
        "@id": "https://doi.org/10.18129/B9.bioc.epiregulon.extra"
      },
      "sc:description": "Gene regulatory networks model the underlying gene regulation hierarchies that drive gene expression and observed phenotypes. Epiregulon infers TF activity in single cells by constructing a gene regulatory network (regulons). This is achieved through integration of scATAC-seq and scRNA-seq data and incorporation of public bulk TF ChIP-seq data. Links between regulatory elements and their target genes are established by computing correlations between chromatin accessibility and gene expressions.",
      "sc:license": "MIT",
      "sc:name": "epiregulon.extra",
