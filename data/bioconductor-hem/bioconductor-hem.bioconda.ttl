@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-hem a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/bth192" ;
    schema1:description "Heterogeneous error model for identification of differentially expressed genes under multiple conditions" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/HEM_1.82.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/HEM/HEM_1.82.0.tar.gz', 'https://bioarchive.galaxyproject.org/HEM_1.82.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-hem/bioconductor-hem_1.82.0_src_all.tar.gz']" ;
    schema1:identifier biotools:hem ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-hem" ;
    schema1:softwareVersion "1.82.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/HEM.html" ;
    spdx:builtFrom biotools:hem .

