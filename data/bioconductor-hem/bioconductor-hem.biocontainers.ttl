@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-hem a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/bth192" ;
    schema1:description "Heterogeneous error model for identification of differentially expressed genes under multiple conditions" ;
    schema1:identifier biotools:hem ;
    schema1:keywords "Animals",
        "Bayes Theorem",
        "Brain",
        "Computer Simulation",
        "Data Interpretation, Statistical",
        "Gene Expression Profiling",
        "Gene expression",
        "Humans",
        "Mice",
        "Microarray experiment",
        "Models, Genetic",
        "Models, Statistical",
        "Molecular genetics",
        "Oligonucleotide Array Sequence Analysis",
        "Pan troglodytes",
        "Sequence Alignment",
        "Sequence Analysis, DNA",
        "Sequence Analysis, Protein" ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-hem" ;
    schema1:url "http://bioconductor.org/packages/3.6/bioc/html/HEM.html" .

