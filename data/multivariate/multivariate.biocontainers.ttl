@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:multivariate a schema1:SoftwareApplication ;
    schema1:description "PCA, PLS(-DA) and OPLS(-DA) for multivariate analysis of omics data" ;
    schema1:keywords "Mass spectrometry",
        "Metabolomics",
        "Proteomics",
        "Transcriptomics" ;
    schema1:license "Custom License" ;
    schema1:name "multivariate" ;
    schema1:url "https://github.com/phnmnl/container-multivariate" .

