@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-simpleaffy a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/bti605" ;
    schema1:description "Very simple high level analysis of Affymetrix data" ;
    schema1:identifier biotools:simpleaffy ;
    schema1:keywords "Computational Biology",
        "Computer Graphics",
        "Computer Simulation",
        "Data visualisation",
        "Database Management Systems",
        "Gene Expression Profiling",
        "Humans",
        "Information Storage and Retrieval",
        "Internet",
        "Microarray experiment",
        "Nucleic Acid Hybridization",
        "Oligonucleotide Array Sequence Analysis",
        "Quality Control",
        "RNA",
        "Sequence Analysis, DNA",
        "Statistics as Topic",
        "User-Computer Interface" ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-simpleaffy" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/simpleaffy.html" .

