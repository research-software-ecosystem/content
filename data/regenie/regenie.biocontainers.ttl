@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:regenie a schema1:SoftwareApplication ;
    schema1:description "Regenie is a C++ program for whole genome regression modelling of large genome-wide association studies (GWAS)." ;
    schema1:keywords "Genetics",
        "Genomics" ;
    schema1:license "MIT" ;
    schema1:name "regenie" ;
    schema1:url "https://rgcgithub.github.io/regenie/" .

