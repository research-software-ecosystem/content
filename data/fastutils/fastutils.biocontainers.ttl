@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:fastutils a schema1:SoftwareApplication ;
    schema1:description "A light toolkit for parsing, manipulating and analysis of FASTA and FASTQ files" ;
    schema1:license "GPL-3.0" ;
    schema1:name "fastutils" ;
    schema1:url "https://github.com/haghshenas/fastutils" .

