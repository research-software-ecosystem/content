@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-consensusov a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18129/b9.bioc.consensusov" ;
    schema1:description "Gene expression-based subtype classification for high-grade serous ovarian cancer" ;
    schema1:keywords "Clustering",
        "Gene Expression",
        "Genomics",
        "Transcriptomics" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-consensusov" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/consensusOV.html" .

