@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:basic a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/ncomms14836" ;
    schema1:description "Basic is a semi-de novo assembly method for assembling bcr and tcr genes  from single cell rna-seq data." ;
    schema1:identifier biotools:basic ;
    schema1:keywords "Artifacts",
        "Biological imaging",
        "Biomarkers",
        "Image Processing, Computer-Assisted",
        "Imaging",
        "Microscopy",
        "RNA-Seq",
        "Time-Lapse Imaging" ;
    schema1:license "MIT" ;
    schema1:name "basic" ;
    schema1:url "https://github.com/akds/BASIC" .

