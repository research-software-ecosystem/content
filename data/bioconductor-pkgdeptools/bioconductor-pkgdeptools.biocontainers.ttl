@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-pkgdeptools a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Package Dependency Tools" ;
    schema1:identifier biotools:pkgdeptools ;
    schema1:keywords "Computational Biology",
        "Computer science",
        "Gene Expression Profiling",
        "Genomics",
        "High-Throughput Screening Assays",
        "Programming Languages",
        "User-Computer Interface" ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-pkgdeptools" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/pkgDepTools.html" .

