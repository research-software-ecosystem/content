@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:satsuma2 a schema1:SoftwareApplication ;
    schema1:description "FFT cross-correlation based synteny aligner, (re)designed to make full use of parallel computing" ;
    schema1:keywords "Genomics",
        "Sequence Alignment" ;
    schema1:license "GPL-3.0" ;
    schema1:name "satsuma2" ;
    schema1:url "https://github.com/bioinfologics/satsuma2" .

