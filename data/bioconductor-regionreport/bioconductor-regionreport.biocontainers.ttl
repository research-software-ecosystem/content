@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-regionreport a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18129/b9.bioc.regionreport" ;
    schema1:description "Generate html or pdf reports for a set of genomic regions or deseq2/edger results" ;
    schema1:keywords "RNA-Seq" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-regionreport" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/regionReport.html" .

