@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:artic a schema1:SoftwareApplication ;
    schema1:description "Artic pipeline - a bioinformatics pipeline for working with virus sequencing data sequenced with nanopore" ;
    schema1:identifier biotools:artic ;
    schema1:keywords "Genomics" ;
    schema1:license "MIT" ;
    schema1:name "artic" ;
    schema1:url "https://github.com/artic-network/fieldbioinformatics" .

