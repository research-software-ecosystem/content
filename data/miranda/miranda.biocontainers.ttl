@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:miranda a schema1:SoftwareApplication ;
    schema1:description "An algorithm for finding genomic targets for microRNAs" ;
