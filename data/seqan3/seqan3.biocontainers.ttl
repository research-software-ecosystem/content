@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:seqan3 a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/1471-2105-9-11" ;
    schema1:description "SeqAn3 is the new version of the popular SeqAn template library for the analysis of biological sequences." ;
    schema1:keywords "Database Management Systems",
        "Databases, Genetic",
        "Genomics",
        "Programming Languages",
        "Sequence Alignment",
        "Sequence Analysis",
        "User-Computer Interface" ;
    schema1:license "BSD-3-Clause" ;
    schema1:name "seqan3" ;
    schema1:url "https://www.seqan.de" .

