@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-cnanorm a schema1:SoftwareApplication ;
    schema1:description "A normalization method for Copy Number Aberration in cancer samples" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/CNAnorm_1.52.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/CNAnorm/CNAnorm_1.52.0.tar.gz', 'https://bioarchive.galaxyproject.org/CNAnorm_1.52.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-cnanorm/bioconductor-cnanorm_1.52.0_src_all.tar.gz']" ;
    schema1:identifier biotools:cnanorm ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-cnanorm" ;
    schema1:softwareVersion "1.52.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/CNAnorm.html" ;
    spdx:builtFrom biotools:cnanorm .

