@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:prokka a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btu153" ;
    schema1:description "Software tool to annotate bacterial, archaeal and viral genomes quickly and produce standards-compliant output files." ;
    schema1:identifier biotools:prokka ;
    schema1:keywords "Genome, Bacterial",
        "Genomics",
        "Metagenome",
        "Model organisms",
        "Molecular Sequence Annotation",
        "Peptides",
        "Proteomics",
        "Sequence Analysis, DNA",
        "Virology" ;
    schema1:license "GPL-2.0" ;
    schema1:name "prokka" ;
    schema1:url "https://github.com/tseemann/prokka" .

