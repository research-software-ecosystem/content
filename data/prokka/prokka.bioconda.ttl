@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:prokka a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btu153" ;
    schema1:description "Rapid annotation of prokaryotic genomes" ;
    schema1:downloadUrl "https://github.com/tseemann/prokka/archive/v1.15.6.tar.gz" ;
    schema1:identifier biotools:prokka ;
    schema1:license "GPL-3.0-only" ;
    schema1:name "prokka" ;
    schema1:softwareVersion "1.15.6" ;
    schema1:url "https://github.com/tseemann/prokka" ;
    spdx:builtFrom biotools:prokka .

