@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-classdiscovery a schema1:SoftwareApplication ;
    schema1:description "Defines the classes used for \"class discovery\" problems in the OOMPA project (<http://oompa.r-forge.r-project.org/>). Class discovery primarily consists of unsupervised clustering methods with attempts to assess their statistical significance. " ;
    schema1:keywords "Gene Expression",
        "Proteomics" ;
    schema1:license "Apache (== 2.0)" ;
    schema1:name "r-classdiscovery" ;
    schema1:url "http://oompa.r-forge.r-project.org/" .

