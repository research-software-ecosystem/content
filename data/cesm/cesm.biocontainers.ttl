@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:cesm a schema1:SoftwareApplication ;
    schema1:description "The Community Earth System Model (CESM) is a coupled climate model for simulating Earth’s climate system" ;
    schema1:license "BSD-3-Clause" ;
    schema1:name "cesm" ;
    schema1:url "https://github.com/ESCOMP/cesm" .

