@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:metaphlan2-data a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3589" ;
    schema1:description "Data package for metagenomic phylogenetic analysis" ;
    schema1:keywords "DNA Barcoding, Taxonomic",
        "Humans",
        "Metagenome",
        "Metagenomics",
        "Phylogeny",
        "Propionibacterium acnes",
        "Reproducibility of Results",
        "Skin" ;
    schema1:license "expat" ;
    schema1:name "metaphlan2-data" ;
    schema1:url "https://bitbucket.org/biobakery/metaphlan2" .

