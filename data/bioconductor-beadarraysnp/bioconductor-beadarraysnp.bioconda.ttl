@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-beadarraysnp a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btm311" ;
    schema1:description "Normalization and reporting of Illumina SNP bead arrays" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.18/bioc/src/contrib/beadarraySNP_1.68.0.tar.gz', 'https://bioconductor.org/packages/3.18/bioc/src/contrib/Archive/beadarraySNP/beadarraySNP_1.68.0.tar.gz', 'https://bioarchive.galaxyproject.org/beadarraySNP_1.68.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-beadarraysnp/bioconductor-beadarraysnp_1.68.0_src_all.tar.gz']" ;
    schema1:identifier biotools:beadarraysnp ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-beadarraysnp" ;
    schema1:softwareVersion "1.68.0" ;
    schema1:url "https://bioconductor.org/packages/3.18/bioc/html/beadarraySNP.html" ;
    spdx:builtFrom biotools:beadarraysnp .

