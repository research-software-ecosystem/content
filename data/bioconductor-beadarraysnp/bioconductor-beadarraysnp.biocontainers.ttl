@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-beadarraysnp a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btm311" ;
    schema1:description "Normalization and reporting of Illumina SNP bead arrays" ;
    schema1:identifier biotools:beadarraysnp ;
    schema1:keywords "DNA polymorphism",
        "Databases, Genetic",
        "Image Interpretation, Computer-Assisted",
        "In Situ Hybridization, Fluorescence",
        "Microspheres",
        "Oligonucleotide Array Sequence Analysis",
        "Programming Languages",
        "Sequence Analysis, DNA",
        "Sequence analysis",
        "Sequencing" ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-beadarraysnp" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/beadarraySNP.html" .

