@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:shark a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btaa779",
        "doi:10.1101/836130" ;
    schema1:description "Mapping-free filtering of useless RNA-Seq reads" ;
    schema1:identifier biotools:shark ;
    schema1:keywords "RNA-Seq" ;
    schema1:license "GPL-3.0" ;
    schema1:name "shark" ;
    schema1:url "https://github.com/AlgoLab/shark" .

