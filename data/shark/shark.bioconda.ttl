@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:shark a schema1:SoftwareApplication ;
    schema1:description "Mapping-free filtering of useless RNA-Seq reads" ;
    schema1:downloadUrl "https://github.com/AlgoLab/shark/archive/v1.2.0.tar.gz" ;
    schema1:identifier biotools:shark ;
    schema1:license "GPL-3.0-or-later" ;
    schema1:name "shark" ;
    schema1:softwareVersion "1.2.0" ;
    schema1:url "https://algolab.github.io/shark/" ;
    spdx:builtFrom biotools:shark .

