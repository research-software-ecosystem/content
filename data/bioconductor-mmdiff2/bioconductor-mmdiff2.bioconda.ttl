@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-mmdiff2 a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Statistical Testing for ChIP-Seq data sets" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/MMDiff2_1.34.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/MMDiff2/MMDiff2_1.34.0.tar.gz', 'https://bioarchive.galaxyproject.org/MMDiff2_1.34.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-mmdiff2/bioconductor-mmdiff2_1.34.0_src_all.tar.gz']" ;
    schema1:identifier biotools:mmdiff2 ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-mmdiff2" ;
    schema1:softwareVersion "1.34.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/MMDiff2.html" ;
    spdx:builtFrom biotools:mmdiff2 .

