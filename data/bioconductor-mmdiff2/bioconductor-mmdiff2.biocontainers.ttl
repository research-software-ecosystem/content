@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-mmdiff2 a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Statistical Testing for ChIP-Seq data sets" ;
    schema1:identifier biotools:mmdiff2 ;
    schema1:keywords "ChIP-seq",
        "Computational Biology",
        "Gene Expression Profiling",
        "Gene expression",
        "Genomics",
        "High-Throughput Screening Assays",
        "Programming Languages",
        "Statistics and probability",
        "User-Computer Interface" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-mmdiff2" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/MMDiff2.html" .

