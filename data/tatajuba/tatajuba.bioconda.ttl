@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:tatajuba a schema1:SoftwareApplication ;
    schema1:description "Identification and classification of homopolymeric tracts from reads" ;
    schema1:identifier biotools:tatajuba ;
    schema1:license "GPLv3" ;
    schema1:name "tatajuba" ;
    schema1:softwareVersion "1.0.4" ;
    schema1:url "https://github.com/quadram-institute-bioscience/tatajuba" ;
    spdx:builtFrom biotools:tatajuba .

