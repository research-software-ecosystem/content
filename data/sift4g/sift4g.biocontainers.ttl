@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:sift4g a schema1:SoftwareApplication ;
    schema1:description "SIFT 4G is a faster version of SIFT that enables us to scale up and provide SIFT predictions for more organisms." ;
    schema1:keywords "Genetic variation" ;
    schema1:license "GPL-3.0" ;
    schema1:name "sift4g" ;
    schema1:url "http://sift.bii.a-star.edu.sg/sift4g/" .

