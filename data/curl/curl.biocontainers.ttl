@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:curl a schema1:SoftwareApplication ;
    schema1:description "Curl is an open source command line tool and library for transferring data with url syntax." ;
    schema1:license "MIT" ;
    schema1:name "curl" ;
    schema1:url "https://github.com/curl/curl" .

