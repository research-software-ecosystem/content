@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:artfastqgenerator a schema1:SoftwareApplication ;
    schema1:description "Outputs artificial fastq files derived from a reference genome" ;
    schema1:keywords "Sequence Alignment" ;
    schema1:license "GPL-3.0+" ;
    schema1:name "artfastqgenerator" ;
    schema1:url "https://sourceforge.net/projects/artfastqgen/" .

