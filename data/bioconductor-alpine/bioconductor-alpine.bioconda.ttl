@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-alpine a schema1:SoftwareApplication ;
    schema1:description "alpine" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.17/bioc/src/contrib/alpine_1.26.0.tar.gz', 'https://bioconductor.org/packages/3.17/bioc/src/contrib/Archive/alpine/alpine_1.26.0.tar.gz', 'https://bioarchive.galaxyproject.org/alpine_1.26.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-alpine/bioconductor-alpine_1.26.0_src_all.tar.gz']" ;
    schema1:identifier biotools:alpine ;
    schema1:license "GPL (>=2)" ;
    schema1:name "bioconductor-alpine" ;
    schema1:softwareVersion "1.26.0" ;
    schema1:url "https://bioconductor.org/packages/3.17/bioc/html/alpine.html" ;
    spdx:builtFrom biotools:alpine .

