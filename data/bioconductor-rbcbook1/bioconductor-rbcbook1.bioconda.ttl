@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-rbcbook1 a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Support for Springer monograph on Bioconductor" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/RbcBook1_1.74.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/RbcBook1/RbcBook1_1.74.0.tar.gz', 'https://bioarchive.galaxyproject.org/RbcBook1_1.74.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-rbcbook1/bioconductor-rbcbook1_1.74.0_src_all.tar.gz']" ;
    schema1:identifier biotools:rbcbook1 ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-rbcbook1" ;
    schema1:softwareVersion "1.74.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/RbcBook1.html" ;
    spdx:builtFrom biotools:rbcbook1 .

