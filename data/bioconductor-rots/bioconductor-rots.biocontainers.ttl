@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-rots a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1109/tcbb.2007.1078" ;
    schema1:description "Reproducibility-Optimized Test Statistic" ;
    schema1:identifier biotools:rots ;
    schema1:keywords "Data Interpretation, Statistical",
        "Gene Expression Profiling",
        "Gene expression",
        "Genes",
        "Oligonucleotide Array Sequence Analysis",
        "Omics",
        "Proteomics",
        "Reproducibility of Results",
        "Sensitivity and Specificity",
        "Statistics and probability" ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-rots" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/ROTS.html" .

