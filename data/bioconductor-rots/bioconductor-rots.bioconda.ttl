@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-rots a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1109/tcbb.2007.1078" ;
    schema1:description "Reproducibility-Optimized Test Statistic" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/ROTS_2.2.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/ROTS/ROTS_2.2.0.tar.gz', 'https://bioarchive.galaxyproject.org/ROTS_2.2.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-rots/bioconductor-rots_2.2.0_src_all.tar.gz']" ;
    schema1:identifier biotools:rots ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-rots" ;
    schema1:softwareVersion "2.2.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/ROTS.html" ;
    spdx:builtFrom biotools:rots .

