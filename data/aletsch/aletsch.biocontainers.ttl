@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:aletsch a schema1:SoftwareApplication ;
    schema1:description "Aletsch is a scalable, accurate, and versatile assembler for multiple RNA-seq samples." ;
    schema1:keywords "RNA-Seq",
        "Transcriptome" ;
    schema1:license "BSD-3-Clause" ;
    schema1:name "aletsch" ;
    schema1:url "https://github.com/Shao-Group/aletsch" .

