@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:cufflinks a schema1:SoftwareApplication ;
    schema1:description "Transcriptome assembly and differential expression analysis for RNA-Seq." ;
    schema1:downloadUrl "http://cole-trapnell-lab.github.io/cufflinks/assets/downloads/cufflinks-2.2.1.Linux_x86_64.tar.gz",
        "http://cole-trapnell-lab.github.io/cufflinks/assets/downloads/cufflinks-2.2.1.OSX_x86_64.tar.gz" ;
    schema1:identifier biotools:cufflinks ;
    schema1:license "Boost Software License" ;
    schema1:name "cufflinks" ;
    schema1:softwareVersion "2.2.1" ;
    schema1:url "http://cole-trapnell-lab.github.io/cufflinks/" ;
    spdx:builtFrom biotools:cufflinks .

