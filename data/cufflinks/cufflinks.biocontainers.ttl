@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:cufflinks a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nbt.1621",
        "doi:10.1038/nbt.2450",
        "doi:10.1093/bioinformatics/btr355",
        "doi:10.1186/gb-2011-12-3-r22",
        "doi:10.7490/f1000research.1114334.1" ;
    schema1:description "Cufflinks assembles transcripts and estimates their abundances in rna-seq samples. it accepts aligned rna-seq reads and assembles the alignments into a parsimonious set of transcripts. cufflinks then estimates the relative abundances of these transcripts based on how many reads support each one." ;
    schema1:identifier biotools:cufflinks ;
    schema1:keywords "Bias",
        "Gene Expression Profiling",
        "Gene Library",
        "Genomics",
        "Humans",
        "Quality Improvement",
        "RNA splicing",
        "RNA-Seq",
        "RNA-seq",
        "Reproducibility of Results",
        "Sequence Analysis, RNA",
        "Transcriptome",
        "Transcriptomics" ;
    schema1:license "BSL-1.0" ;
    schema1:name "cufflinks" ;
    schema1:url "http://cole-trapnell-lab.github.io/cufflinks" .

