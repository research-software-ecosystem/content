@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:repeatmasker a schema1:SoftwareApplication ;
    schema1:description "RepeatMasker is a program that screens DNA sequences for interspersed repeats and low complexity DNA sequences." ;
    schema1:downloadUrl "https://www.repeatmasker.org/RepeatMasker/RepeatMasker-4.2.3.tar.gz" ;
    schema1:identifier biotools:repeatmasker ;
    schema1:license "Open Software License v2.1" ;
    schema1:name "repeatmasker" ;
    schema1:softwareHelp "https://www.repeatmasker.org/RepeatMasker" ;
    schema1:softwareVersion "4.2.3" ;
    schema1:url "https://www.repeatmasker.org/RepeatMasker" ;
    spdx:builtFrom biotools:repeatmasker .

