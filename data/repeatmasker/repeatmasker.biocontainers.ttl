@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:repeatmasker a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1101/856591" ;
    schema1:description "Repeatmasker is a program that screens dna sequences for interspersed repeats and low complexity dna sequences." ;
    schema1:identifier biotools:RepeatMasker ;
    schema1:keywords "Clustering",
        "Sequence analysis",
        "Sequence composition, complexity and repeats" ;
    schema1:license "OSL-2.1" ;
    schema1:name "repeatmasker" ;
    schema1:url "http://www.repeatmasker.org" .

