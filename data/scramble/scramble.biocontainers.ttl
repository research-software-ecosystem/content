@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:scramble a schema1:SoftwareApplication ;
    schema1:description "SCRAMble identifies clusters of soft clipped reads in a BAM file, builds consensus sequences, aligns to representative L1Ta, AluYa5, and SVA-E sequences, and outputs MEI calls" ;
    schema1:license "CC" ;
    schema1:name "scramble" ;
    schema1:url "https://github.com/GeneDx/scramble" .

