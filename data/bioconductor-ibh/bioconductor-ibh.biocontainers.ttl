@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-ibh a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Interaction Based Homogeneity for Evaluating Gene Lists" ;
    schema1:identifier biotools:ibh ;
    schema1:keywords "Clustering",
        "Computational Biology",
        "Gene Expression Profiling",
        "Genetics",
        "Genomics",
        "High-Throughput Screening Assays",
        "Molecular interactions, pathways and networks",
        "Programming Languages",
        "User-Computer Interface" ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-ibh" ;
    schema1:url "http://bioconductor.org/packages/3.6/bioc/html/ibh.html" .

