@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-ibh a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Interaction Based Homogeneity for Evaluating Gene Lists" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/ibh_1.54.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/ibh/ibh_1.54.0.tar.gz', 'https://bioarchive.galaxyproject.org/ibh_1.54.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-ibh/bioconductor-ibh_1.54.0_src_all.tar.gz']" ;
    schema1:identifier biotools:ibh ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-ibh" ;
    schema1:softwareVersion "1.54.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/ibh.html" ;
    spdx:builtFrom biotools:ibh .

