@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-glimma a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1101/096107" ;
    schema1:description "Interactive visualizations for gene expression analysis" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/Glimma_2.20.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/Glimma/Glimma_2.20.0.tar.gz', 'https://bioarchive.galaxyproject.org/Glimma_2.20.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-glimma/bioconductor-glimma_2.20.0_src_all.tar.gz']" ;
    schema1:identifier biotools:glimma ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-glimma" ;
    schema1:softwareVersion "2.20.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/Glimma.html" ;
    spdx:builtFrom biotools:glimma .

