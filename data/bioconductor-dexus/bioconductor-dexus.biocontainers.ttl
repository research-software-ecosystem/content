@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-dexus a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/gkt834" ;
    schema1:description "DEXUS - Identifying Differential Expression in RNA-Seq Studies with Unknown Conditions or without Replicates" ;
    schema1:identifier biotools:dexus ;
    schema1:keywords "Animals",
        "Gene Expression Profiling",
        "Gene expression",
        "HapMap Project",
        "High-Throughput Nucleotide Sequencing",
        "Humans",
        "Liver",
        "Macaca mulatta",
        "Pan troglodytes",
        "Plant Leaves",
        "RNA-Seq",
        "RNA-seq",
        "Sequence Analysis, RNA",
        "Zea mays" ;
    schema1:license "LGPL (>= 2.0)" ;
    schema1:name "bioconductor-dexus" ;
    schema1:url "http://bioconductor.org/packages/3.6/bioc/html/dexus.html" .

