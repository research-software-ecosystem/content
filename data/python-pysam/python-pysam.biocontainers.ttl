@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:python-pysam a schema1:SoftwareApplication ;
    schema1:description "Pysam is a python module for reading and manipulating files in the SAM/BAM format. The SAM/BAM format is a way to store efficiently large numbers of alignments (Li 2009), such as those routinely created by next-generation sequencing methods." ;
    schema1:license "MIT" ;
    schema1:name "python-pysam" ;
    schema1:url "https://github.com/pysam-developers/pysam" .

