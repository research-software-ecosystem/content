@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:shapemapper a schema1:SoftwareApplication ;
    schema1:description "ShapeMapper converts raw sequencing files into mutational profiles, creates SHAPE reactivity plots, and provides extensive diagnostic information useful for experiment analysis and troubleshooting." ;
    schema1:license "GPL" ;
    schema1:name "shapemapper" ;
    schema1:url "http://www.chem.unc.edu/rna/software.html" .

