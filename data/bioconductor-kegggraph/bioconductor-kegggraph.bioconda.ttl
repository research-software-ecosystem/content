@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-kegggraph a schema1:SoftwareApplication ;
    schema1:description "KEGGgraph: A graph approach to KEGG PATHWAY in R and Bioconductor" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/KEGGgraph_1.66.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/KEGGgraph/KEGGgraph_1.66.0.tar.gz', 'https://bioarchive.galaxyproject.org/KEGGgraph_1.66.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-kegggraph/bioconductor-kegggraph_1.66.0_src_all.tar.gz']" ;
    schema1:identifier biotools:kegggraph ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-kegggraph" ;
    schema1:softwareVersion "1.66.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/KEGGgraph.html" ;
    spdx:builtFrom biotools:kegggraph .

