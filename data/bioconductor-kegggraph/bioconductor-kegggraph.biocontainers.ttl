@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-kegggraph a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btp167" ;
    schema1:description "KEGGgraph: A graph approach to KEGG PATHWAY in R and Bioconductor" ;
    schema1:identifier biotools:kegggraph ;
    schema1:keywords "Computational Biology",
        "Computer Graphics",
        "Data visualisation",
        "Databases, Genetic",
        "Genome",
        "Humans",
        "Models, Biological",
        "Molecular interactions, pathways and networks",
        "Pancreatic Neoplasms" ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-kegggraph" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/KEGGgraph.html" .

