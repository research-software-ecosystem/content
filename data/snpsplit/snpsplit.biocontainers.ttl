@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:snpsplit a schema1:SoftwareApplication ;
    schema1:citation "doi:10.12688/f1000research.9037.2" ;
    schema1:description "Snpsplit is an allele-specific alignment sorter which is designed to read in alignment files in sam/bam format and determine the allelic origin of reads that cover known snp positions." ;
    schema1:license "GNU General Public License v3.0" ;
    schema1:name "snpsplit" ;
    schema1:url "https://github.com/FelixKrueger/SNPsplit" .

