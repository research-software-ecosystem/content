@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-arrayquality a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btn647" ;
    schema1:description "Assessing array quality on spotted arrays" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/arrayQuality_1.84.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/arrayQuality/arrayQuality_1.84.0.tar.gz', 'https://bioarchive.galaxyproject.org/arrayQuality_1.84.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-arrayquality/bioconductor-arrayquality_1.84.0_src_all.tar.gz']" ;
    schema1:identifier biotools:arrayquality ;
    schema1:license "LGPL" ;
    schema1:name "bioconductor-arrayquality" ;
    schema1:softwareVersion "1.84.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/arrayQuality.html" ;
    spdx:builtFrom biotools:arrayquality .

