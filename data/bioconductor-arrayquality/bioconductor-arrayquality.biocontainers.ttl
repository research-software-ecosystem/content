@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-arrayquality a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btn647" ;
    schema1:description "Assessing array quality on spotted arrays" ;
    schema1:identifier biotools:arrayquality ;
    schema1:keywords "Computational Biology",
        "Data Interpretation, Statistical",
        "Data quality management",
        "Internet",
        "Microarray experiment",
        "Oligonucleotide Array Sequence Analysis",
        "Quality Control" ;
    schema1:license "LGPL" ;
    schema1:name "bioconductor-arrayquality" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/arrayQuality.html" .

