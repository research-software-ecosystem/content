@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-cfassay a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s13014-015-0529-y" ;
    schema1:description "Statistical analysis for the Colony Formation Assay" ;
    schema1:identifier biotools:cfassay ;
    schema1:keywords "Cell Line, Tumor",
        "Cell Proliferation",
        "Cell Survival",
        "Cell biology",
        "Cytological Techniques",
        "Humans",
        "Likelihood Functions",
        "Oncology",
        "Radiation, Ionizing" ;
    schema1:license "LGPL" ;
    schema1:name "bioconductor-cfassay" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/CFAssay.html" .

