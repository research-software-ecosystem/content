@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:longstitch a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1101/2021.06.17.448848" ;
    schema1:description "A genome assembly correction and scaffolding pipeline using long reads." ;
    schema1:downloadUrl "https://github.com/BirolLab/LongStitch/releases/download/v1.0.5/longstitch-1.0.5.tar.gz" ;
    schema1:identifier biotools:longstitch ;
    schema1:license "GPL-3.0-or-later" ;
    schema1:name "longstitch" ;
    schema1:softwareHelp "https://github.com/BirolLab/LongStitch/blob/v1.0.5/README.md" ;
    schema1:softwareVersion "1.0.5" ;
    schema1:url "https://github.com/BirolLab/longstitch" ;
    spdx:builtFrom biotools:longstitch .

