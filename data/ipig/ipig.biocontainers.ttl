@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:ipig a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1371/journal.pone.0050246" ;
    schema1:description "Targets the integration of peptide spectrum matches (psms) from mass spectrometry (ms) peptide identifications into genomic visualisations provided by genome browser such as the ucsc genome browser" ;
    schema1:identifier biotools:ipig ;
    schema1:keywords "Computer Graphics",
        "DNA",
        "Databases, Protein",
        "Genomics",
        "Mass spectrometry",
        "Peptides",
        "Proteomics",
        "RNA-Seq",
        "Sequence Alignment",
        "Targets",
        "User-Computer Interface" ;
    schema1:license "BSDlike" ;
    schema1:name "ipig" ;
    schema1:url "http://sourceforge.net/projects/ipig/" .

