@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:disco a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1002/pro.620",
        "doi:10.1089/cmb.2011.0173" ;
    schema1:description "Multi-threaded Distributed Memory Overlap-Layout-Consensus (OLC) Metagenome Assembler" ;
    schema1:identifier biotools:disco ;
    schema1:keywords "Bacterial Proteins",
        "Computer Simulation",
        "Diacylglycerol Kinase",
        "Disulfides",
        "Escherichia coli Proteins",
        "Magnetic Resonance Spectroscopy",
        "Metagenome",
        "Models, Molecular",
        "Multiprotein Complexes",
        "Protein Structure, Quaternary",
        "Structure determination" ;
    schema1:license "GPL-3.0" ;
    schema1:name "disco" ;
    schema1:url "http://disco.omicsbio.org/" .

