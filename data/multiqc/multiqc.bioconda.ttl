@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:multiqc a schema1:SoftwareApplication ;
    schema1:author "ewels" ;
    schema1:citation "doi:10.1093/bioinformatics/btw354" ;
    schema1:description "Aggregate results from bioinformatics analyses across many samples into a single report." ;
    schema1:downloadUrl "https://github.com/MultiQC/MultiQC/archive/v1.35.tar.gz" ;
    schema1:identifier biotools:multiqc ;
    schema1:license "GPL-3.0-or-later" ;
    schema1:maintainer "ewels" ;
    schema1:name "multiqc" ;
    schema1:softwareHelp "https://docs.seqera.io/multiqc/" ;
    schema1:softwareVersion "1.35" ;
    schema1:url "https://seqera.io/multiqc" ;
    spdx:builtFrom biotools:multiqc .

