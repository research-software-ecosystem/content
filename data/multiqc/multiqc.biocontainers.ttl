@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:multiqc a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btw354" ;
    schema1:description "Multiqc aggregates results from multiple bioinformatics analyses across many samples into a single report. it searches a given directory for analysis logs and compiles a html report. i is a general use tool, perfect for summarising the output from numerous bioinformatics tools." ;
    schema1:identifier biotools:multiqc ;
    schema1:keywords "Bioinformatics",
        "Computational Biology",
        "High-Throughput Nucleotide Sequencing",
        "Quality Control",
        "RNA-Seq",
        "Sequencing" ;
    schema1:license "GPL-3.0" ;
    schema1:name "multiqc" ;
    schema1:url "https://github.com/ewels/MultiQC" .

