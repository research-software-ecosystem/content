@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:aodp a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s12859-018-2363-3" ;
    schema1:description "Cluster oligonucleotide signatures for rapid identification by sequencing" ;
    schema1:keywords "High-Throughput Nucleotide Sequencing",
        "Metagenomics",
        "Oligonucleotides",
        "Sequence Analysis, DNA" ;
    schema1:license "GPL-3" ;
    schema1:name "aodp" ;
    schema1:url "https://github.com/peterk87/aodp" .

