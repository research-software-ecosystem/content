@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:cortex_con a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/ng.1028" ;
    schema1:description "cortex_con (primary contact Mario Caccamo) is for consensus genome assembly" ;
    schema1:downloadUrl "https://sourceforge.net/projects/cortexassembler/files/cortex_con/cortex_con_beta_0.04c.zip" ;
    schema1:identifier biotools:cortex ;
    schema1:license "GPL3" ;
    schema1:name "cortex_con" ;
    schema1:softwareVersion "0.04c" ;
    schema1:url "http://cortexassembler.sourceforge.net/index.html" ;
    spdx:builtFrom biotools:cortex .

