@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-somaticsignatures a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btv408" ;
    schema1:description "This package identifies mutational signatures of single nucleotide variants (snvs)." ;
    schema1:identifier biotools:somaticsignatures ;
    schema1:keywords "Clustering",
        "Genetic variation",
        "Genome, Human",
        "Humans",
        "Mutation",
        "Neoplasms",
        "Polymorphism, Single Nucleotide",
        "Sequencing",
        "Statistics and probability" ;
    schema1:license "MIT" ;
    schema1:name "bioconductor-somaticsignatures" ;
    schema1:url "http://bioconductor.org/packages/release/bioc/html/SomaticSignatures.html" .

