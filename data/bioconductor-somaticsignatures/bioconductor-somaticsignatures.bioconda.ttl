@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-somaticsignatures a schema1:SoftwareApplication ;
    schema1:description "Somatic Signatures" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/SomaticSignatures_2.46.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/SomaticSignatures/SomaticSignatures_2.46.0.tar.gz', 'https://bioarchive.galaxyproject.org/SomaticSignatures_2.46.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-somaticsignatures/bioconductor-somaticsignatures_2.46.0_src_all.tar.gz']" ;
    schema1:identifier biotools:somaticsignatures ;
    schema1:license "MIT + file LICENSE" ;
    schema1:name "bioconductor-somaticsignatures" ;
    schema1:softwareVersion "2.46.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/SomaticSignatures.html" ;
    spdx:builtFrom biotools:somaticsignatures .

