@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bz2file a schema1:SoftwareApplication ;
    schema1:description "Python3 library for reading and writing bzip2-compressed files" ;
    schema1:license "Apache" ;
    schema1:name "bz2file" ;
    schema1:url "https://github.com/nvawda/bz2file" .

