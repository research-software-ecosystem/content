@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:saffrontree a schema1:SoftwareApplication ;
    schema1:citation "doi:10.21105/joss.00243" ;
    schema1:description "SaffronTree: Reference free rapid phylogenetic tree construction from raw read data" ;
    schema1:keywords "Clustering",
        "Genomics" ;
    schema1:license "GPL-3.0" ;
    schema1:name "saffrontree" ;
    schema1:url "https://github.com/sanger-pathogens/saffrontree" .

