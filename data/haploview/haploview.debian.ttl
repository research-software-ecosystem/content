        "doi:10.1101/pdb.ip71" ;
    schema1:identifier "bio.tools:HaploView",
        "omictools:OMICS_09142",
        "scicrunch:SCR_003076" ;
    schema1:license "MIT" ;
    schema1:name "haploview" ;
    schema1:softwareVersion "4.1" ;
    schema1:url "https://www.broadinstitute.org/haploview/haploview" ;
    spdx:builtFrom "HaploView" .

