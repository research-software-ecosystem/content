@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:gatb a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btu406" ;
    schema1:description "The Genome Analysis Toolbox with de-Bruijn graph" ;
    schema1:identifier biotools:gatb ;
    schema1:keywords "Biostatistics",
        "Computer Graphics",
        "DNA",
        "Data management",
        "Genome, Human",
        "Genomics",
        "High-Throughput Nucleotide Sequencing",
        "Humans",
        "Metagenome",
        "Sequencing" ;
    schema1:license "AGPL 3.0" ;
    schema1:name "gatb" ;
    schema1:url "https://gatb.inria.fr/" .

