@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:intervene a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s12859-017-1708-7" ;
    schema1:description "A tool for intersection of multiple gene or genomic region sets and visualization as venn diagrams, UpSet plots or pariwaise heatmaps" ;
    schema1:downloadUrl "https://files.pythonhosted.org/packages/45/43/c8cc6574be4806653b43c2a974ed9751a512d75e2bd339261f8a65b98ad5/intervene-0.6.5.tar.gz" ;
    schema1:identifier biotools:Intervene ;
    schema1:license "MIT License" ;
    schema1:name "intervene" ;
    schema1:softwareVersion "0.6.5" ;
    schema1:url "https://github.com/asntech/intervene" ;
    spdx:builtFrom biotools:Intervene .

