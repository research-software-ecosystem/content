@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:intervene a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1101/109728",
        "doi:10.1186/s12859-017-1708-7" ;
    schema1:description "A tool for intersection of multiple gene or genomic region sets and visualization as venn diagrams, upset plots or pariwaise heatmaps" ;
    schema1:identifier biotools:Intervene ;
    schema1:keywords "Animals",
        "Computational biology",
        "Computer Graphics",
        "Gene Dosage",
        "Genome",
        "High-Throughput Nucleotide Sequencing",
        "Humans",
        "Mice",
        "Sequence Analysis, DNA" ;
    schema1:license "MIT" ;
    schema1:name "intervene" ;
    schema1:url "https://github.com/asntech/intervene" .

