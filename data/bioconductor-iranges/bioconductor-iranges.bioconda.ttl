@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-iranges a schema1:SoftwareApplication ;
    schema1:description "Foundation of integer range manipulation in Bioconductor" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/IRanges_2.44.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/IRanges/IRanges_2.44.0.tar.gz', 'https://bioarchive.galaxyproject.org/IRanges_2.44.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-iranges/bioconductor-iranges_2.44.0_src_all.tar.gz']" ;
    schema1:identifier biotools:iranges ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-iranges" ;
    schema1:softwareVersion "2.44.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/IRanges.html" ;
    spdx:builtFrom biotools:iranges .

