    schema1:identifier biotools:iranges ;
    schema1:keywords "Animals",
        "Data management",
        "Databases, Genetic",
        "Genetics",
        "Genomics",
        "Humans",
        "Mathematics",
        "Mice",
        "Sequence Alignment",
        "Sequence Analysis, DNA" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-iranges" ;
    schema1:url "https://bioconductor.org/packages/IRanges/" .

