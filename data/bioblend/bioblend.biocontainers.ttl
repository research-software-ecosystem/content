@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioblend a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btt199",
        "doi:10.1093/nar/gkw343",
        "doi:10.1093/nar/gky379" ;
    schema1:description "Cloudman and galaxy api library" ;
    schema1:keywords "Genomics" ;
    schema1:license "MIT" ;
    schema1:name "bioblend" ;
    schema1:url "http://bioblend.readthedocs.org/" .

