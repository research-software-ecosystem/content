@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-immunoclust a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18129/b9.bioc.immunoclust" ;
    schema1:description "immunoClust is a model based clustering approach for Flow Cytometry samples. The cell-events of single Flow Cytometry samples are modelled by a mixture of multinominal normal- or t-distributions." ;
    schema1:keywords "Clustering" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-immunoclust" ;
    schema1:url "http://bioconductor.org/packages/release/bioc/html/immunoClust.html" .

