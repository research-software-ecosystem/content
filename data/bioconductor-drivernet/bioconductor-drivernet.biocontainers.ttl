@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-drivernet a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/gb-2012-13-12-r124" ;
    schema1:description "Drivernet: uncovering somatic driver mutations modulating transcriptional networks in cancer" ;
    schema1:identifier biotools:drivernet ;
    schema1:keywords "DNA mutation",
        "Gene Expression",
        "Gene Expression Profiling",
        "Gene Expression Regulation, Neoplastic",
        "Gene Regulatory Networks",
        "Genomics",
        "Humans",
        "Metabolic Networks and Pathways",
        "Mutation",
        "Neoplasms",
        "Oncogenes",
        "Oncology",
        "Transcription, Genetic",
        "Transcriptome",
        "Transcriptomics" ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-drivernet" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/DriverNet.html" .

