@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-drivernet a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/gb-2012-13-12-r124" ;
    schema1:description "Drivernet: uncovering somatic driver mutations modulating transcriptional networks in cancer" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/DriverNet_1.46.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/DriverNet/DriverNet_1.46.0.tar.gz', 'https://bioarchive.galaxyproject.org/DriverNet_1.46.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-drivernet/bioconductor-drivernet_1.46.0_src_all.tar.gz']" ;
    schema1:identifier biotools:drivernet ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-drivernet" ;
    schema1:softwareVersion "1.46.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/DriverNet.html" ;
    spdx:builtFrom biotools:drivernet .

