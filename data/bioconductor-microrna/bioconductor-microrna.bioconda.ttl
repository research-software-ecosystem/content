@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-microrna a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Data and functions for dealing with microRNAs" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/microRNA_1.68.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/microRNA/microRNA_1.68.0.tar.gz', 'https://bioarchive.galaxyproject.org/microRNA_1.68.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-microrna/bioconductor-microrna_1.68.0_src_all.tar.gz']" ;
    schema1:identifier biotools:microrna ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-microrna" ;
    schema1:softwareVersion "1.68.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/microRNA.html" ;
    spdx:builtFrom biotools:microrna .

