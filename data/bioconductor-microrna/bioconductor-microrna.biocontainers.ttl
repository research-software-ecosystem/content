@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-microrna a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Data and functions for dealing with microRNAs" ;
    schema1:identifier biotools:microrna ;
    schema1:keywords "Computational Biology",
        "Functional, regulatory and non-coding RNA",
        "Gene Expression Profiling",
        "Genomics",
        "High-Throughput Screening Assays",
        "Programming Languages",
        "RNA",
        "User-Computer Interface" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-microrna" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/microRNA.html" .

