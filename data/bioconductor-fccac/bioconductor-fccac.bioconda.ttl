@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-fccac a schema1:SoftwareApplication ;
    schema1:description "functional Canonical Correlation Analysis to evaluate Covariance between nucleic acid sequencing datasets" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/fCCAC_1.32.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/fCCAC/fCCAC_1.32.0.tar.gz', 'https://bioarchive.galaxyproject.org/fCCAC_1.32.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-fccac/bioconductor-fccac_1.32.0_src_all.tar.gz']" ;
    schema1:identifier biotools:fccac ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-fccac" ;
    schema1:softwareVersion "1.32.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/fCCAC.html" ;
    spdx:builtFrom biotools:fccac .

