@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bwread a schema1:SoftwareApplication ;
    schema1:description "Read bigwig files quickly into PyRanges or DataFrames" ;
    schema1:license "MIT" ;
    schema1:name "bwread" ;
    schema1:url "http://github.com/endrebak/bwread" .

