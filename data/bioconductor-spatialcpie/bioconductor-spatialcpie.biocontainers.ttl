    schema1:description "Cluster analysis of spatial transcriptomics data" ;
    schema1:keywords "Cluster Analysis",
        "Clustering",
        "Transcriptomics" ;
    schema1:license "MIT" ;
    schema1:name "bioconductor-spatialcpie" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/SpatialCPie.html" .

