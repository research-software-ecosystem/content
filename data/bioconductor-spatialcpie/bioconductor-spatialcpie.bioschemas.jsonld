      "@id": "https://bio.tools/bioconductor-spatialcpie",
      "@type": "sc:SoftwareApplication",
      "dcterms:conformsTo": "https://bioschemas.org/profiles/ComputationalTool/0.6-DRAFT",
      "sc:additionalType": [
        "Command-line tool",
        "Library"
      ],
      "sc:author": "Joseph Bergenstraahle",
      "sc:citation": {
        "@id": "https://doi.org/10.18129/B9.bioc.SpatialCPie"
      },
      "sc:description": "SpatialCPie is an R package designed to facilitate cluster evaluation for spatial transcriptomics data by providing intuitive visualizations that display the relationships between clusters in order to guide the user during cluster identification and other downstream applications. The package is built around a shiny \"gadget\" to allow the exploration of the data with multiple plots in parallel and an interactive UI. The user can easily toggle between different cluster resolutions in order to choose the most appropriate visual cues.",
      "sc:license": "MIT",
      "sc:name": "SpatialCPie",
      "sc:operatingSystem": [
        "Mac",
        "Windows",
        "Linux"
      ],
      "sc:softwareHelp": {
        "@id": "https://bioconductor.org/packages/SpatialCPie"
      },
      "sc:softwareVersion": "1.26.0",
      "sc:url": "https://bioconductor.org/packages/SpatialCPie"
    }
  ]
