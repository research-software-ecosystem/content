@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-bluster a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18129/b9.bioc.bluster" ;
    schema1:description "Wraps common clustering algorithms in an easily extended S4 framework. Backends are implemented for hierarchical, k-means and graph-based clustering. Several utilities are also provided to compare and evaluate clustering results." ;
    schema1:keywords "Clustering",
        "Transcriptomics" ;
    schema1:license "GPL-3.0" ;
    schema1:name "bioconductor-bluster" ;
    schema1:url "https://bioconductor.org/packages/3.12/bioc/html/bluster.html" .

