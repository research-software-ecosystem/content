@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-vegan a schema1:SoftwareApplication ;
    schema1:description "Ordination methods, diversity analysis and other functions for community and vegetation" ;
    schema1:keywords "Clustering",
        "Genetics",
        "Genomics",
        "Metagenome",
        "Metagenomics",
        "Phylogenetics" ;
    schema1:license "GPL-2.0" ;
    schema1:name "r-vegan" ;
    schema1:url "https://CRAN.R-project.org/package=vegan" .

