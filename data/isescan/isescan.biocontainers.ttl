@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:isescan a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btx433" ;
    schema1:description "A python pipeline to identify IS (Insertion Sequence elements in genome and metagenome " ;
    schema1:identifier biotools:isescan ;
    schema1:keywords "Archaea",
        "Bacteria",
        "DNA Transposable Elements",
        "DNA structural variation",
        "Genetic variation",
        "Genome, Archaeal",
        "Genome, Bacterial",
        "Genomics",
        "Metagenome",
        "Sequence Analysis, DNA",
        "Sequence analysis" ;
    schema1:license "GPL-3.0" ;
    schema1:name "isescan" ;
    schema1:url "https://github.com/xiezhq/ISEScan" .

