@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-eir a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18129/b9.bioc.eir" ;
    schema1:description "Accelerated similarity searching of small molecules" ;
    schema1:keywords "Clustering",
        "Genetics",
        "Genomics",
        "Metabolomics",
        "Proteomics" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-eir" ;
    schema1:url "https://bioconductor.org/packages/3.8/bioc/html/eiR.html" .

