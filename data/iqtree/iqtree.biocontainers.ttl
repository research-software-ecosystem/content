@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:iqtree a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1080/10635150290069913",
        "doi:10.1093/bioinformatics/btg319",
        "doi:10.1093/molbev/mst024",
        "doi:10.1093/molbev/msu300",
        "doi:10.1093/oxfordjournals.molbev.a025808",
        "doi:10.1093/sysbio/syr041" ;
    schema1:description "Efficient phylogenetic software by maximum likelihood" ;
    schema1:keywords "Databases, Bibliographic",
        "Databases, Genetic",
        "Genetics",
        "Genomics",
        "Information Storage and Retrieval",
        "Phylogenetics",
        "Programming Languages",
        "Sequence Alignment",
        "Sequence Analysis" ;
    schema1:license "GPL-2.0+" ;
    schema1:name "iqtree" ;
    schema1:url "https://github.com/Cibiv/IQ-TREE/" .

