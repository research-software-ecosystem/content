@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-maftools a schema1:SoftwareApplication ;
    schema1:description "Summarize, Analyze and Visualize MAF Files" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/maftools_2.26.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/maftools/maftools_2.26.0.tar.gz', 'https://bioarchive.galaxyproject.org/maftools_2.26.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-maftools/bioconductor-maftools_2.26.0_src_all.tar.gz']" ;
    schema1:identifier biotools:maftools ;
    schema1:license "MIT + file LICENSE" ;
    schema1:name "bioconductor-maftools" ;
    schema1:softwareVersion "2.26.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/maftools.html" ;
    spdx:builtFrom biotools:maftools .

