@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:xmlbuilder a schema1:SoftwareApplication ;
    schema1:description "pythonic way to crate xml/(x)html files" ;
    schema1:license "LGPL-3.0" ;
    schema1:name "xmlbuilder" ;
    schema1:url "https://pypi.python.org/pypi/xmlbuilder/1.0" .

