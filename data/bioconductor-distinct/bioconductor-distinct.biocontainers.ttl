@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-distinct a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18129/b9.bioc.distinct" ;
    schema1:description "distinct: a method for differential analyses via hierarchical permutation tests" ;
    schema1:keywords "Genetics",
        "RNA-Seq" ;
    schema1:license "GPL (>= 3)" ;
    schema1:name "bioconductor-distinct" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/distinct.html" .

