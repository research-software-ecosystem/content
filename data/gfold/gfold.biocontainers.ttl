@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:gfold a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/bts515" ;
    schema1:description "Find differentially expressed genes from rna-seq data with few replicates using generalized fold changes." ;
    schema1:keywords "Base Sequence",
        "Databases, Genetic",
        "Gene Expression",
        "Gene Expression Profiling",
        "Humans",
        "Models, Molecular",
        "Oligonucleotide Array Sequence Analysis",
        "RNA",
        "Sequence Analysis, RNA" ;
    schema1:license "MIT" ;
    schema1:name "gfold" ;
    schema1:url "http://compbio.tongji.edu.cn/~fengjx/GFOLD/gfold.html" .

