@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:beads a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/gkr425" ;
    schema1:description "Chip-seq data normalization for illumina" ;
    schema1:identifier biotools:beads ;
    schema1:keywords "Animals",
        "Base Composition",
        "Caenorhabditis elegans",
        "ChIP-seq",
        "Chromatin Immunoprecipitation",
        "DNA, Helminth",
        "High-Throughput Nucleotide Sequencing",
        "Sequence Analysis, DNA" ;
    schema1:license "CeCILL" ;
    schema1:name "beads" ;
    schema1:url "http://beads.sourceforge.net/" .

