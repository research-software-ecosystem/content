@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-pickgene a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1007/0-387-21679-0_13" ;
    schema1:description "Adaptive Gene Picking for Microarray Expression Data Analysis" ;
    schema1:identifier biotools:pickgene ;
    schema1:keywords "Gene Expression",
        "Gene expression",
        "Microarray experiment" ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-pickgene" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/pickgene.html" .

