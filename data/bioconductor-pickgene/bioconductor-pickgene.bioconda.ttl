@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-pickgene a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1007/0-387-21679-0_13" ;
    schema1:description "Adaptive Gene Picking for Microarray Expression Data Analysis" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/pickgene_1.78.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/pickgene/pickgene_1.78.0.tar.gz', 'https://bioarchive.galaxyproject.org/pickgene_1.78.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-pickgene/bioconductor-pickgene_1.78.0_src_all.tar.gz']" ;
    schema1:identifier biotools:pickgene ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-pickgene" ;
    schema1:softwareVersion "1.78.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/pickgene.html" ;
    spdx:builtFrom biotools:pickgene .

