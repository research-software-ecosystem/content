@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:mapsplice a schema1:SoftwareApplication ;
    schema1:description "MapSplice is a software for mapping RNA-seq data to reference genome for splice junction discovery that depends only on reference genome, and not on any further annotations." ;
    schema1:downloadUrl "http://protocols.netlab.uky.edu/~zeng/MapSplice-v2.2.1.zip" ;
    schema1:identifier biotools:mapsplice ;
    schema1:license "Custom" ;
    schema1:name "mapsplice" ;
    schema1:softwareHelp "http://www.netlab.uky.edu/p/bioinfo/MapSplice2" ;
    schema1:softwareVersion "2.2.1" ;
    schema1:url "http://www.netlab.uky.edu/p/bioinfo/MapSplice2" ;
    spdx:builtFrom biotools:mapsplice .

