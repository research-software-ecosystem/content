@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:segtools a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/1471-2105-12-415" ;
    schema1:description "A python package for analyzing genomic segmentations" ;
    schema1:identifier biotools:segtools ;
    schema1:keywords "ChIP-seq",
        "Epigenetics",
        "Gene Expression",
        "Genome, Human",
        "Genomics",
        "Histone Code",
        "Histones",
        "Humans",
        "Plasmodium falciparum",
        "Sequence sites, features and motifs" ;
    schema1:license "Not available" ;
    schema1:name "segtools" ;
    schema1:url "http://segtools.hoffmanlab.org/" .

