@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-ssviz a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "A small RNA-seq visualizer and analysis toolkit" ;
    schema1:identifier biotools:ssviz ;
    schema1:keywords "Computational Biology",
        "Functional, regulatory and non-coding RNA",
        "Gene Expression Profiling",
        "Genetics",
        "Genomics",
        "High-Throughput Screening Assays",
        "Programming Languages",
        "RNA-Seq",
        "User-Computer Interface" ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-ssviz" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/ssviz.html" .

