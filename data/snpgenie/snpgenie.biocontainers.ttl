@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:snpgenie a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btv449" ;
    schema1:description "Program for estimating πN/πS, dN/dS, and other diversity measures from next-generation sequencing data" ;
    schema1:identifier biotools:snpgenie ;
    schema1:keywords "Biological Evolution",
        "DNA",
        "DNA polymorphism",
        "Evolutionary biology",
        "Genetic variation",
        "Genetics",
        "Genetics, Population",
        "Genomics",
        "Hemagglutinins",
        "High-Throughput Nucleotide Sequencing",
        "Humans",
        "Influenza A Virus, H5N1 Subtype",
        "Neuraminidase",
        "Polymorphism, Single Nucleotide",
        "Selection, Genetic",
        "Sequencing" ;
    schema1:license "GPL-3.0" ;
    schema1:name "snpgenie" ;
    schema1:url "https://github.com/chasewnelson/SNPGenie" .

