@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:graph2pro-var a schema1:SoftwareApplication ;
    schema1:description "meta-proteogenomic identification from mass spec and metagenomic/transcriptomic data" ;
    schema1:keywords "Mass spectra",
        "Metagenome",
        "Peptides",
        "Transcriptome" ;
    schema1:license "GPL-3.0" ;
    schema1:name "graph2pro-var" ;
    schema1:url "https://github.com/COL-IU/graph2pro-var" .

