@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:cmseq a schema1:SoftwareApplication ;
    schema1:description "Set of utilities on sequences and BAM files" ;
    schema1:keywords "Genomics",
        "Metagenome",
        "Metagenomics",
        "Protein Sequences" ;
    schema1:license "MIT" ;
    schema1:name "cmseq" ;
    schema1:url "https://github.com/SegataLab/cmseq" .

