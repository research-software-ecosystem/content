@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:msalign2 a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1007/s00216-009-3166-1" ;
    schema1:description "Aligns 2 CE-MS or LC-MS datasets using accurate mass information." ;
    schema1:downloadUrl "http://www.ms-utils.org/msalign2/msalign2.zip" ;
    schema1:identifier biotools:msalign2 ;
    schema1:license "GPL3" ;
    schema1:name "msalign2" ;
    schema1:softwareVersion "1.0" ;
    schema1:url "http://www.ms-utils.org/msalign2/index.html" ;
    spdx:builtFrom biotools:msalign2 .

