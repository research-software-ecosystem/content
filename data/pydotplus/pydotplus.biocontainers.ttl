@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:pydotplus a schema1:SoftwareApplication ;
    schema1:description "PyDotPlus is an improved version of the old pydot project that provides a Python Interface to the Graphviz Dot language." ;
    schema1:license "MIT" ;
    schema1:name "pydotplus" ;
    schema1:url "https://github.com/carlos-jenkins/pydotplus" .

