@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:pathogen-profiler a schema1:SoftwareApplication ;
    schema1:description "Library giving access to classes and functions to create a profiling tool to look for mutations from NGS data." ;
    schema1:license "GPL-3.0" ;
    schema1:name "pathogen-profiler" ;
    schema1:url "https://github.com/jodyphelan/pathogen-profiler" .

