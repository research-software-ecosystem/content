@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:glimmerhmm a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/bth315" ;
    schema1:description "GlimmerHMM is a gene finder based on a Generalized Hidden Markov Model (GHMM)." ;
    schema1:downloadUrl "https://ccb.jhu.edu/software/glimmerhmm/dl/GlimmerHMM-3.0.4.tar.gz" ;
    schema1:identifier biotools:glimmer-hmm ;
    schema1:license "Artistic License" ;
    schema1:name "glimmerhmm" ;
    schema1:softwareHelp "https://ccb.jhu.edu/software/glimmerhmm" ;
    schema1:softwareVersion "3.0.4" ;
    schema1:url "https://ccb.jhu.edu/software/glimmerhmm" ;
    spdx:builtFrom biotools:glimmer-hmm .

