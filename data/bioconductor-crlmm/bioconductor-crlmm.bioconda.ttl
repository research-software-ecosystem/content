@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-crlmm a schema1:SoftwareApplication ;
    schema1:description "Genotype Calling (CRLMM) and Copy Number Analysis tool for Affymetrix SNP 5.0 and 6.0 and Illumina arrays" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/crlmm_1.68.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/crlmm/crlmm_1.68.0.tar.gz', 'https://bioarchive.galaxyproject.org/crlmm_1.68.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-crlmm/bioconductor-crlmm_1.68.0_src_all.tar.gz']" ;
    schema1:identifier biotools:crlmm ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-crlmm" ;
    schema1:softwareVersion "1.68.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/crlmm.html" ;
    spdx:builtFrom biotools:crlmm .

