@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-crlmm a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18129/b9.bioc.crlmm" ;
    schema1:description "Genotype Calling (CRLMM) and Copy Number Analysis tool for Affymetrix SNP 5.0 and 6.0 and Illumina arrays" ;
    schema1:identifier biotools:crlmm ;
    schema1:keywords "DNA polymorphism",
        "Genotype and phenotype" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-crlmm" ;
    schema1:url "http://bioconductor.org/packages/3.6/bioc/html/crlmm.html" .

