@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:pyprophet a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nbt.3908",
        "doi:10.1038/nmeth.4398" ;
    schema1:description "Python reimplementation of mprophet peak scoring" ;
    schema1:keywords "Computer Simulation",
        "Data Interpretation, Statistical",
        "High-Throughput Screening Assays",
        "Mass Spectrometry",
        "Models, Statistical",
        "Peptide Mapping",
        "Proteins",
        "Proteomics",
        "Reproducibility of Results",
        "Sensitivity and Specificity",
        "Sequence Analysis, Protein" ;
    schema1:license "BSD" ;
    schema1:name "pyprophet" ;
    schema1:url "https://github.com/PyProphet/pyprophet" .

