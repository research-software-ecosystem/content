@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-progeny a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18129/b9.bioc.progeny" ;
    schema1:description "Pathway responsive genes for activity inference from gene expression" ;
    schema1:keywords "Gene Expression",
        "RNA-Seq",
        "Transcriptomics" ;
    schema1:license "Apache License (== 2.0) | file LICENSE" ;
    schema1:name "bioconductor-progeny" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/progeny.html" .

