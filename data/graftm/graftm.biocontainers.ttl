@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:graftm a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/gky174" ;
    schema1:description "Graftm is a pipeline used for identifying and classifying marker gene reads from metagenomic datasets" ;
    schema1:identifier biotools:graftm ;
    schema1:keywords "Computer Simulation",
        "Databases, Genetic",
        "Genes, Archaeal",
        "Genes, Bacterial",
        "Genomics",
        "Markov Chains",
        "Metagenome",
        "Metagenomics",
        "Phylogeny",
        "Protein Sequences",
        "RNA, Ribosomal, 16S",
        "Sensitivity and Specificity",
        "Soil Microbiology",
        "Sweden",
        "Transcriptome",
        "Transcriptomics" ;
    schema1:license "Not available" ;
    schema1:name "graftm" ;
    schema1:url "http://geronimp.github.io/graftM" .

