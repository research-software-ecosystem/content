@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:wise-data a schema1:SoftwareApplication ;
    schema1:description "Compare a protein sequences or protein hmms to a genomic dna sequence, allowing for introns and frameshifting errors." ;
    schema1:keywords "Sequence Alignment" ;
    schema1:license "GRL" ;
    schema1:name "wise-data" ;
    schema1:url "http://www.ebi.ac.uk/Tools/Wise2/" .

