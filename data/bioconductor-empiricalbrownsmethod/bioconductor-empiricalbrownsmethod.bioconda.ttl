@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-empiricalbrownsmethod a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btw438" ;
    schema1:description "Uses Brown's method to combine p-values from dependent tests" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/EmpiricalBrownsMethod_1.34.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/EmpiricalBrownsMethod/EmpiricalBrownsMethod_1.34.0.tar.gz', 'https://bioarchive.galaxyproject.org/EmpiricalBrownsMethod_1.34.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-empiricalbrownsmethod/bioconductor-empiricalbrownsmethod_1.34.0_src_all.tar.gz']" ;
    schema1:identifier biotools:empiricalbrownsmethod ;
    schema1:license "MIT + file LICENSE" ;
    schema1:name "bioconductor-empiricalbrownsmethod" ;
    schema1:softwareVersion "1.34.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/EmpiricalBrownsMethod.html" ;
    spdx:builtFrom biotools:empiricalbrownsmethod .

