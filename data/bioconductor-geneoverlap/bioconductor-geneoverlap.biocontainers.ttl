@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-geneoverlap a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1167/iovs.16-20618" ;
    schema1:description "Test and visualize gene overlaps" ;
    schema1:identifier biotools:geneoverlap ;
    schema1:keywords "Animals",
        "Genetic Predisposition to Disease",
        "Genetics",
        "Genome-Wide Association Study",
        "Humans",
        "Myopia",
        "Proteomics",
        "Transcriptome" ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-geneoverlap" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/GeneOverlap.html" .

