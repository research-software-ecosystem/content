@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-geneoverlap a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1167/iovs.16-20618" ;
    schema1:description "Test and visualize gene overlaps" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/GeneOverlap_1.46.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/GeneOverlap/GeneOverlap_1.46.0.tar.gz', 'https://bioarchive.galaxyproject.org/GeneOverlap_1.46.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-geneoverlap/bioconductor-geneoverlap_1.46.0_src_all.tar.gz']" ;
    schema1:identifier biotools:geneoverlap ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-geneoverlap" ;
    schema1:softwareVersion "1.46.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/GeneOverlap.html" ;
    spdx:builtFrom biotools:geneoverlap .

