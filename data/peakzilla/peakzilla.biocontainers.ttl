@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:peakzilla a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btt470" ;
    schema1:description "Identify transcription factor binding sites from chip-seq data at high resolution." ;
    schema1:identifier biotools:peakzilla ;
    schema1:keywords "Animals",
        "Binding Sites",
        "Chromatin Immunoprecipitation",
        "Drosophila",
        "Drosophila Proteins",
        "Enhancer Elements, Genetic",
        "High-Throughput Nucleotide Sequencing",
        "Humans",
        "Mice",
        "Sequence Analysis, DNA",
        "Transcription Factors",
        "Transcription factors and regulatory sites",
        "Twist-Related Protein 1" ;
    schema1:license "GPL-2.0" ;
    schema1:name "peakzilla" ;
    schema1:url "https://github.com/steinmann/peakzilla" .

