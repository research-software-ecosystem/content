@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:peakzilla a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btt470" ;
    schema1:description "Peakzilla identifies sites of enrichment and transcription factor binding sites from transcription factor ChIP-seq and ChIP-exo experiments at hight accuracy and resolution." ;
    schema1:downloadUrl "https://github.com/steinmann/peakzilla/archive/0fc94780ee1a8c2b6395b5c7489e21a70eeb5217.tar.gz" ;
    schema1:identifier biotools:peakzilla ;
    schema1:license "GPLv2" ;
    schema1:name "peakzilla" ;
    schema1:softwareVersion "1.0" ;
    schema1:url "http://stark.imp.ac.at/data/peakzilla" ;
    spdx:builtFrom biotools:peakzilla .

