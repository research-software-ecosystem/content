@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:aria2 a schema1:SoftwareApplication ;
    schema1:description "Aria2 is a lightweight multi-protocol & multi-source, cross platform download utility operated in command-line." ;
    schema1:license "GPL-2.0" ;
    schema1:name "aria2" ;
    schema1:url "https://github.com/aria2/aria2" .

