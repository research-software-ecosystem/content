@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:multigps a schema1:SoftwareApplication ;
    schema1:description "MultiGPS is a framework for analyzing collections of multi-condition ChIP-seq datasets and characterizing differential binding events between conditions." ;
    schema1:license "MIT" ;
    schema1:name "multigps" ;
    schema1:url "https://github.com/seqcode/multigps" .

