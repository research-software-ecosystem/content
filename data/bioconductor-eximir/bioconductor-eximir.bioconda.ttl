@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-eximir a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/1756-0500-7-302" ;
    schema1:description "R functions for the normalization of Exiqon miRNA array data" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/ExiMiR_2.48.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/ExiMiR/ExiMiR_2.48.0.tar.gz', 'https://bioarchive.galaxyproject.org/ExiMiR_2.48.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-eximir/bioconductor-eximir_2.48.0_src_all.tar.gz']" ;
    schema1:identifier biotools:eximir ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-eximir" ;
    schema1:softwareVersion "2.48.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/ExiMiR.html" ;
    spdx:builtFrom biotools:eximir .

