@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:escher-fluxomics a schema1:SoftwareApplication ;
    schema1:description "Escher-based visualization for fluxes and concentrations generated from fluxomics data sets" ;
    schema1:license "GPL-3.0" ;
    schema1:name "escher-fluxomics" ;
    schema1:url "https://github.com/phnmnl/container-escher-fluxomics" .

