@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-ffpe a schema1:SoftwareApplication ;
    schema1:description "Quality assessment and control for FFPE microarray expression data" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/ffpe_1.54.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/ffpe/ffpe_1.54.0.tar.gz', 'https://bioarchive.galaxyproject.org/ffpe_1.54.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-ffpe/bioconductor-ffpe_1.54.0_src_all.tar.gz']" ;
    schema1:identifier biotools:ffpe ;
    schema1:license "GPL (>2)" ;
    schema1:name "bioconductor-ffpe" ;
    schema1:softwareVersion "1.54.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/ffpe.html" ;
    spdx:builtFrom biotools:ffpe .

