@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-decontam a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18129/b9.bioc.decontam" ;
    schema1:description "Identify contaminants in marker-gene and metagenomics sequencing data" ;
    schema1:keywords "Genomics",
        "Metagenomics" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-decontam" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/decontam.html" .

