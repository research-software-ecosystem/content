@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:lightstringgraph a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1007/978-3-662-44753-6_23" ;
    schema1:description "LightStringGraphs (LSG) is an external memory string graph construction tool." ;
    schema1:downloadUrl "https://github.com/AlgoLab/LightStringGraph/archive/v0.4.0.tar.gz" ;
    schema1:identifier biotools:lightstringgraph ;
    schema1:license "GPL-3" ;
    schema1:name "lightstringgraph" ;
    schema1:softwareVersion "0.4.0" ;
    schema1:url "http://lsg.algolab.eu" ;
    spdx:builtFrom biotools:lightstringgraph .

