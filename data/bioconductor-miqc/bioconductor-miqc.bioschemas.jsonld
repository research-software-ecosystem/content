  "@graph": [
    {
      "@id": "https://bio.tools/bioconductor-miqc",
      "@type": "sc:SoftwareApplication",
      "dcterms:conformsTo": "https://bioschemas.org/profiles/ComputationalTool/0.6-DRAFT",
      "sc:additionalType": [
        "Command-line tool",
        "Library"
      ],
      "sc:author": [
        "Stephanie Hicks",
        "Ariel Hippen"
      ],
      "sc:citation": {
        "@id": "https://doi.org/10.1371/journal.pcbi.1009290"
      },
      "sc:description": "Single-cell RNA-sequencing (scRNA-seq) has made it possible to profile gene expression in tissues at high resolution.  An important preprocessing step prior to performing downstream analyses is to identify and remove cells with poor or degraded sample quality using quality control (QC) metrics.  Two widely used QC metrics to identify a ‘low-quality’ cell are (i) if the cell includes a high proportion of reads that map to mitochondrial DNA encoded genes (mtDNA) and (ii) if a small number of genes are detected. miQC is data-driven QC metric that jointly models both the proportion of reads mapping to mtDNA and the number of detected genes with mixture models in a probabilistic framework to predict the low-quality cells in a given dataset.",
      "sc:license": "BSD-3-Clause",
      "sc:name": "miQC",
      "sc:operatingSystem": [
        "Mac",
        "Windows",
        "Linux"
      ],
      "sc:softwareHelp": {
        "@id": "https://bioconductor.org/packages/miQC"
      },
      "sc:softwareVersion": "1.18.0",
      "sc:url": "https://bioconductor.org/packages/miQC"
    },
    {
      "@id": "https://doi.org/10.1371/journal.pcbi.1009290",
      "@type": "sc:CreativeWork"
    }
  ]
