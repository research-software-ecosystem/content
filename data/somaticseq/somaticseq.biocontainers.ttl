@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:somaticseq a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s13059-015-0758-2" ;
    schema1:description "An ensemble approach to accurately detect somatic mutations" ;
    schema1:keywords "DNA Mutational Analysis",
        "Genomics",
        "Humans",
        "INDEL Mutation",
        "Machine Learning",
        "Neoplasms" ;
    schema1:license "BSD-2-Clause" ;
    schema1:name "somaticseq" ;
    schema1:url "https://github.com/bioinform/somaticseq/" .

