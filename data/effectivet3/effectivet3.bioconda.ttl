@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:effectivet3 a schema1:SoftwareApplication ;
    schema1:description "Command line NoD (clinod), for  predicting nucleolar localization sequences." ;
    schema1:downloadUrl "https://depot.galaxyproject.org/software/TTSS_GUI/TTSS_GUI_1.0.1_src_all.jar" ;
    schema1:identifier biotools:effectivet3 ;
    schema1:license "Apache License, Version 2.0 + others used internally" ;
    schema1:name "effectivet3" ;
    schema1:softwareVersion "1.0.1" ;
    schema1:url "http://www.compbio.dundee.ac.uk/nod" ;
    spdx:builtFrom biotools:effectivet3 .

