@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:longranger a schema1:SoftwareApplication ;
    schema1:description "10x genomics aligner" ;
    schema1:license "AGPLv2" ;
    schema1:name "longranger" ;
    schema1:url "https://support.10xgenomics.com/genome-exome/software/pipelines/latest/what-is-long-ranger" .

