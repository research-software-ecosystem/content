@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:recalladapters a schema1:SoftwareApplication ;
    schema1:description "Recalladapters - a tool to recall adapters for pacbio data" ;
    schema1:license "BSD 3-Clause Clear License" ;
    schema1:name "recalladapters" ;
    schema1:url "https://github.com/PacificBiosciences/pbbioconda" .

