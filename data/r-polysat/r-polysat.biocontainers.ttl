@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-polysat a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1111/1755-0998.12639",
        "doi:10.1111/j.1755-0998.2011.02985.x" ;
    schema1:description "A collection of tools to handle microsatellite data of any ploidy (and samples of mixed ploidy) where allele copy number is not known in partially heterozygous genotypes." ;
    schema1:keywords "Animals",
        "Diploidy",
        "Fishes",
        "Genotype",
        "Genotyping Techniques",
        "Microsatellite Repeats",
        "Models, Genetic",
        "Polyploidy" ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "r-polysat" ;
    schema1:url "https://CRAN.R-project.org/package=polysat" .

