@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bandage a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btv383" ;
    schema1:description "Gui program that allows users to interact with the assembly graphs made by de novo assemblers such as velvet, spades, megahit and others. it visualises assembly graphs, with connections, using graph layout algorithms." ;
    schema1:identifier biotools:bandage ;
    schema1:keywords "Chromosome Mapping",
        "Computational Biology",
        "Computer Graphics",
        "Genome, Bacterial",
        "Genome, Human",
        "Genomics",
        "Humans",
        "Sequence Analysis, DNA",
        "Sequence assembly" ;
    schema1:license "GPL-3.0" ;
    schema1:name "bandage" ;
    schema1:url "https://github.com/rrwick/Bandage" .

