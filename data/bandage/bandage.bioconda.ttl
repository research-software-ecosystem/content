@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bandage a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btv383" ;
    schema1:description "Bandage - a Bioinformatics Application for Navigating De novo Assembly Graphs Easily." ;
    schema1:downloadUrl "https://github.com/rrwick/Bandage/archive/v0.9.0.tar.gz" ;
    schema1:identifier biotools:bandage ;
    schema1:license "GPL-3.0-or-later" ;
    schema1:name "bandage" ;
    schema1:softwareHelp "https://rrwick.github.io/Bandage" ;
    schema1:softwareVersion "0.9.0" ;
    schema1:url "https://github.com/rrwick/Bandage" ;
    spdx:builtFrom biotools:bandage .

