@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:haptools a schema1:SoftwareApplication ;
    schema1:author "aryarm" ;
    schema1:citation "doi:10.1093/bioinformatics/btad104" ;
    schema1:description "Ancestry and haplotype aware simulation of genotypes and phenotypes for complex trait analysis" ;
    schema1:downloadUrl "https://pypi.io/packages/source/h/haptools/haptools-0.6.2.tar.gz" ;
    schema1:identifier biotools:haptools ;
    schema1:license "MIT" ;
    schema1:maintainer "aryarm" ;
    schema1:name "haptools" ;
    schema1:softwareHelp "https://haptools.readthedocs.io" ;
    schema1:softwareVersion "0.6.2" ;
    schema1:url "https://github.com/cast-genomics/haptools" ;
    spdx:builtFrom biotools:haptools .

