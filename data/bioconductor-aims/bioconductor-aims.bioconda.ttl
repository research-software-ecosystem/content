@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-aims a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/jnci/dju357" ;
    schema1:description "AIMS : Absolute Assignment of Breast Cancer Intrinsic Molecular Subtype" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/AIMS_1.38.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/AIMS/AIMS_1.38.0.tar.gz', 'https://bioarchive.galaxyproject.org/AIMS_1.38.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-aims/bioconductor-aims_1.38.0_src_all.tar.gz']" ;
    schema1:identifier biotools:aims ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-aims" ;
    schema1:softwareVersion "1.38.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/AIMS.html" ;
    spdx:builtFrom biotools:aims .

