bioconda:encyclopedia a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/s41467-018-07454-w" ;
    schema1:description "EncyclopeDIA is library search engine comprised of several algorithms for DIA data analysis" ;
    schema1:downloadUrl "https://bitbucket.org/searleb/encyclopedia/downloads/encyclopedia-2.12.30-executable.jar" ;
    schema1:identifier biotools:encyclopedia ;
    schema1:license "Apache License 2.0" ;
    schema1:name "encyclopedia" ;
    schema1:softwareVersion "2.12.30" ;
    schema1:url "https://bitbucket.org/searleb/encyclopedia/wiki/Home" ;
    spdx:builtFrom biotools:encyclopedia .

