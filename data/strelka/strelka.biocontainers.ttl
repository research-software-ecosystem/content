@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:strelka a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/bts271" ;
    schema1:description "Strelka is an analysis package designed to detect somatic snvs and small indels from the aligned sequencing reads of matched tumor-normal samples." ;
    schema1:identifier biotools:strelka ;
    schema1:keywords "Bayes Theorem",
        "Computational Biology",
        "Exome",
        "Gene Frequency",
        "Genetic Variation",
        "Genetic variation",
        "Genome",
        "Humans",
        "INDEL Mutation",
        "Models, Genetic",
        "Neoplasms",
        "Sequence Alignment" ;
    schema1:license "GPL-3.0" ;
    schema1:name "strelka" ;
    schema1:url "https://github.com/Illumina/strelka" .

