@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:strelka a schema1:SoftwareApplication ;
    schema1:description "Strelka calls somatic and germline small variants from mapped sequencing reads" ;
    schema1:downloadUrl "https://github.com/Illumina/strelka/releases/download/v2.9.10/strelka-2.9.10.centos6_x86_64.tar.bz2" ;
    schema1:identifier biotools:strelka ;
    schema1:license "GPL-3.0" ;
    schema1:name "strelka" ;
    schema1:softwareVersion "2.9.10" ;
    schema1:url "https://github.com/Illumina/strelka" ;
    spdx:builtFrom biotools:strelka .

