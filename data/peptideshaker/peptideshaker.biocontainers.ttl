@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:peptideshaker a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nbt.3109" ;
    schema1:description "Peptideshaker is a search engine independent platform for interpretation of proteomics identification results from multiple search engines, currently supporting x!tandem, ms-gf+, ms amanda, omssa, myrimatch, comet, tide, mascot, andromeda and mzidentml. by combining the results from multiple search engines, while re-calculating ptm localization scores and redoing the protein inference, peptideshaker attempts to give you the best possible understanding of your proteomics data!" ;
    schema1:identifier biotools:peptideshaker ;
    schema1:keywords "Amino Acid Sequence",
        "Mass Spectrometry",
        "Molecular Sequence Data",
        "Peptides",
        "Protein Sequences",
        "Protein Structure",
        "Proteome",
        "Proteomics",
        "Proteomics experiment" ;
    schema1:license "Apache-2.0" ;
    schema1:name "peptideshaker" ;
    schema1:url "https://github.com/compomics/peptide-shaker" .

