@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:infernal a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btt509" ;
    schema1:description "Inference of rna secondary structural alignments" ;
    schema1:keywords "Nucleic Acid Conformation",
        "RNA",
        "Sequence Alignment",
        "Sequence Analysis, RNA",
        "Sequence Homology, Nucleic Acid" ;
    schema1:license "GPL-3.0" ;
    schema1:name "infernal" ;
    schema1:url "https://github.com/EddyRivasLab/infernal" .

