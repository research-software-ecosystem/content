@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:intemap a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s12859-015-0686-x" ;
    schema1:description "Integrated metagenomic assembly pipeline for short reads" ;
    schema1:identifier biotools:intemap ;
    schema1:keywords "High-Throughput Nucleotide Sequencing",
        "Humans",
        "Metagenome",
        "Metagenomics",
        "Sequence Analysis, DNA",
        "Sequence assembly",
        "Sequencing" ;
    schema1:license "Not available" ;
    schema1:name "intemap" ;
    schema1:url "http://cqb.pku.edu.cn/ZhuLab/InteMAP/index.html" .

