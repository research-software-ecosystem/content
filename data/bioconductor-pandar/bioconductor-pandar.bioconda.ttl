@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-pandar a schema1:SoftwareApplication ;
    schema1:description "PANDA Algorithm" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/pandaR_1.38.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/pandaR/pandaR_1.38.0.tar.gz', 'https://bioarchive.galaxyproject.org/pandaR_1.38.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-pandar/bioconductor-pandar_1.38.0_src_all.tar.gz']" ;
    schema1:identifier biotools:pandar ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-pandar" ;
    schema1:softwareVersion "1.38.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/pandaR.html" ;
    spdx:builtFrom biotools:pandar .

