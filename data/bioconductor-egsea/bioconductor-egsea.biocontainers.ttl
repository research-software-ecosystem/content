@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-egsea a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btw623" ;
    schema1:description "Ensemble of Gene Set Enrichment Analyses" ;
    schema1:identifier biotools:egsea ;
    schema1:keywords "Animals",
        "Computational Biology",
        "Databases, Genetic",
        "Female",
        "Gene Expression Profiling",
        "Genetics",
        "Humans",
        "Interleukin-13",
        "Leukocytes, Mononuclear",
        "Mammary Glands, Human",
        "Metabolomics",
        "Mice",
        "Proteomics",
        "Sequence Analysis, RNA",
        "Systems biology" ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-egsea" ;
    schema1:url "http://bioconductor.org/packages/3.6/bioc/html/EGSEA.html" .

