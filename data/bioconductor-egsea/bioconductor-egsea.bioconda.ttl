@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-egsea a schema1:SoftwareApplication ;
    schema1:description "Ensemble of Gene Set Enrichment Analyses" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/EGSEA_1.34.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/EGSEA/EGSEA_1.34.0.tar.gz', 'https://bioarchive.galaxyproject.org/EGSEA_1.34.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-egsea/bioconductor-egsea_1.34.0_src_all.tar.gz']" ;
    schema1:identifier biotools:egsea ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-egsea" ;
    schema1:softwareVersion "1.34.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/EGSEA.html" ;
    spdx:builtFrom biotools:egsea .

