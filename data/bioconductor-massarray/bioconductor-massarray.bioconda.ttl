@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-massarray a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btp382" ;
    schema1:description "Analytical Tools for MassArray Data" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/MassArray_1.62.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/MassArray/MassArray_1.62.0.tar.gz', 'https://bioarchive.galaxyproject.org/MassArray_1.62.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-massarray/bioconductor-massarray_1.62.0_src_all.tar.gz']" ;
    schema1:identifier biotools:massarray ;
    schema1:license "GPL (>=2)" ;
    schema1:name "bioconductor-massarray" ;
    schema1:softwareVersion "1.62.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/MassArray.html" ;
    spdx:builtFrom biotools:massarray .

