@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-massarray a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btp382" ;
    schema1:description "Analytical Tools for MassArray Data" ;
    schema1:identifier biotools:massarray ;
    schema1:keywords "Animals",
        "Cell Line",
        "Computational Biology",
        "DNA Methylation",
        "Dinucleoside Phosphates",
        "Epigenetics",
        "Gene expression",
        "Genetics",
        "Male",
        "Mass Spectrometry",
        "Mice",
        "Polymorphism, Single Nucleotide",
        "Rats",
        "Rats, Sprague-Dawley",
        "Reproducibility of Results",
        "Sulfites" ;
    schema1:license "GPL (>=2)" ;
    schema1:name "bioconductor-massarray" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/MassArray.html" .

