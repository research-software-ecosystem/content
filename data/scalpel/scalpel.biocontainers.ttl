@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:scalpel a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3069" ;
    schema1:description "Sensitive detection of indels (insertions and deletions)" ;
    schema1:identifier biotools:scalpel ;
    schema1:keywords "Computational Biology",
        "DNA",
        "DNA Mutational Analysis",
        "DNA mutation",
        "DNA polymorphism",
        "Databases, Genetic",
        "Exome",
        "Humans",
        "INDEL Mutation",
        "Mutation",
        "Programming Languages",
        "Sequence Alignment",
        "Sequencing" ;
    schema1:license "MIT" ;
    schema1:name "scalpel" ;
    schema1:url "http://scalpel.sourceforge.net/" .

