@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:pyvolve a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1371/journal.pone.0139047" ;
    schema1:description "Pyvolve is an open-source Python module for simulating sequences along a phylogenetic tree according to continuous-time Markov models of sequence evolution. Please cite: Spielman, S.J., and Wilke, C.O. (2015). Pyvolve: A Flexible Python Module for Simulating Sequences along Phylogenies. PLOS ONE 10, e0139047." ;
    schema1:identifier biotools:pyvolve ;
    schema1:keywords "Amino Acid Sequence",
        "Animals",
        "Base Sequence",
        "Computer Simulation",
        "Genomics",
        "Humans",
        "Machine learning",
        "Markov Chains",
        "Models, Genetic",
        "Phylogenetics",
        "Phylogeny",
        "Sequence analysis" ;
    schema1:license "FreeBSD" ;
    schema1:name "pyvolve" ;
    schema1:url "https://github.com/sjspielman/pyvolve" .

