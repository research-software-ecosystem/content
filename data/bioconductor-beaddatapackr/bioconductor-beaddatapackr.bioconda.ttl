    schema1:identifier biotools:beaddatapackr ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-beaddatapackr" ;
    schema1:softwareVersion "1.58.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/BeadDataPackR.html" ;
    spdx:builtFrom biotools:beaddatapackr .

