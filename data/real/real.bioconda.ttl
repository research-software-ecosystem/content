@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:real a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1145/1854776.1854801" ;
    schema1:description "REad ALigner for Next-Generation sequencing reads." ;
    schema1:downloadUrl "https://github.com/solonas13/REAL/archive/master.tar.gz" ;
    schema1:identifier biotools:real ;
    schema1:license "file" ;
    schema1:name "real" ;
    schema1:softwareVersion "1.0" ;
    schema1:url "https://nms.kcl.ac.uk/informatics/projects/real/?id=man" ;
    spdx:builtFrom biotools:real .

