@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-preprocesscore a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Bioconductor collection of pre-processing functions" ;
    schema1:identifier biotools:preprocesscore ;
    schema1:keywords "Computational Biology",
        "Data management",
        "Data quality management",
        "Gene Expression Profiling",
        "Genomics",
        "High-Throughput Screening Assays",
        "Programming Languages",
        "User-Computer Interface" ;
    schema1:license "LGPL-2.1+" ;
    schema1:name "bioconductor-preprocesscore" ;
    schema1:url "https://bioconductor.org/packages/preprocessCore/" .

