@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-hilbertvis a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btp152" ;
    schema1:description "Hilbert curve visualization" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/HilbertVis_1.64.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/HilbertVis/HilbertVis_1.64.0.tar.gz', 'https://bioarchive.galaxyproject.org/HilbertVis_1.64.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-hilbertvis/bioconductor-hilbertvis_1.64.0_src_all.tar.gz']" ;
    schema1:identifier biotools:hilbertvis ;
    schema1:license "GPL (>= 3)" ;
    schema1:name "bioconductor-hilbertvis" ;
    schema1:softwareVersion "1.64.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/HilbertVis.html" ;
    spdx:builtFrom biotools:hilbertvis .

