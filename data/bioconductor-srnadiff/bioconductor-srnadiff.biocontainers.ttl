@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-srnadiff a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18129/b9.bioc.srnadiff" ;
    schema1:description "Finding differentially expressed unannotated genomic regions from RNA-seq data" ;
    schema1:keywords "Genetics",
        "RNA-Seq" ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-srnadiff" ;
    schema1:url "https://bioconductor.org/packages/3.8/bioc/html/srnadiff.html" .

