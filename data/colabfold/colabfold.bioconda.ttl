@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:colabfold a schema1:SoftwareApplication ;
    schema1:author "milot-mirdita" ;
    schema1:citation "doi:10.1038/s41592-022-01488-1" ;
    schema1:description "ColabFold: making protein folding accessible to all" ;
    schema1:downloadUrl "https://github.com/sokrypton/ColabFold/archive/refs/tags/v1.5.5.tar.gz",
        "https://github.com/steineggerlab/alphafold/archive/refs/tags/v2.3.6.tar.gz" ;
    schema1:identifier biotools:colabfold ;
    schema1:license "MIT" ;
    schema1:maintainer "milot-mirdita" ;
    schema1:name "colabfold" ;
    schema1:softwareVersion "1.5.5" ;
    schema1:url "https://github.com/sokrypton/ColabFold" ;
    spdx:builtFrom biotools:colabfold .

