@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-bbcanalyzer a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s12859-017-1549-4" ;
    schema1:description "BBCAnalyzer: an R/Bioconductor package for visualizing base counts" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/BBCAnalyzer_1.40.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/BBCAnalyzer/BBCAnalyzer_1.40.0.tar.gz', 'https://bioarchive.galaxyproject.org/BBCAnalyzer_1.40.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-bbcanalyzer/bioconductor-bbcanalyzer_1.40.0_src_all.tar.gz']" ;
    schema1:identifier biotools:bbcanalyzer ;
    schema1:license "LGPL-3" ;
    schema1:name "bioconductor-bbcanalyzer" ;
    schema1:softwareVersion "1.40.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/BBCAnalyzer.html" ;
    spdx:builtFrom biotools:bbcanalyzer .

