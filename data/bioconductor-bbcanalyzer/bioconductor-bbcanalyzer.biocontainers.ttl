@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-bbcanalyzer a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s12859-017-1549-4" ;
    schema1:description "BBCAnalyzer: an R/Bioconductor package for visualizing base counts" ;
    schema1:identifier biotools:bbcanalyzer ;
    schema1:keywords "DNA Mutational Analysis",
        "Data visualisation",
        "High-Throughput Nucleotide Sequencing",
        "Humans",
        "Mutation",
        "Sequence Alignment",
        "Sequence analysis" ;
    schema1:license "LGPL-3" ;
    schema1:name "bioconductor-bbcanalyzer" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/BBCAnalyzer.html" .

