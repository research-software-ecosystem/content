@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bmtool a schema1:SoftwareApplication ;
    schema1:description "Bmtool is part of bmtagger aka best match tagger, for removing human reads from metagenomics datasets" ;
    schema1:license "Not available" ;
    schema1:name "bmtool" ;
    schema1:url "ftp://ftp.ncbi.nlm.nih.gov/pub/agarwala/bmtagger/" .

