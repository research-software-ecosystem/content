@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:plek a schema1:SoftwareApplication ;
    schema1:description "Predictor of long non-coding RNAs and mRNAs based on k-mer scheme." ;
    schema1:downloadUrl "https://sourceforge.net/projects/plek/files/PLEK.1.2.tar.gz" ;
    schema1:identifier biotools:plek ;
    schema1:license "GPL-3.0-or-later" ;
    schema1:name "plek" ;
    schema1:softwareVersion "1.2" ;
    schema1:url "https://sourceforge.net/projects/plek" ;
    spdx:builtFrom biotools:plek .

