@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:plek a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/1471-2105-15-311" ;
    schema1:description "Predictor of long non-coding RNAs and mRNAs based on k-mer scheme." ;
    schema1:identifier biotools:plek ;
    schema1:keywords "Animals",
        "Computational Biology",
        "Databases, Genetic",
        "Functional, regulatory and non-coding RNA",
        "Gene Expression Profiling",
        "Humans",
        "Mice",
        "Molecular Sequence Annotation",
        "Proteins",
        "RNA, Long Noncoding",
        "RNA, Messenger",
        "RNA-seq",
        "Sequence Analysis, RNA",
        "Sequence assembly",
        "Sequencing",
        "Support Vector Machine" ;
    schema1:license "GNU GPL v3" ;
    schema1:name "plek" ;
    schema1:url "https://sourceforge.net/projects/plek" .

