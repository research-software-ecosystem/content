@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:variant-effect-predictor a schema1:SoftwareApplication ;
    schema1:description "The VEP determines the effect of your variants (SNPs, insertions, deletions, CNVs or structural variants) on genes, transcripts, and protein sequence, as well as regulatory regions." ;
    schema1:license "Apache 2.0" ;
    schema1:name "variant-effect-predictor" ;
    schema1:url "None" .

