        "Biomarkers, Tumor",
        "Computational Biology",
        "DNA Methylation",
        "Data Mining",
        "Databases, Genetic",
        "Epigenetics",
        "Gene expression",
        "Gene regulation",
        "Genome, Human",
        "Genomics",
        "Humans",
        "Microarray experiment",
        "Neoplasms",
        "Oncology",
        "Statistics as Topic" ;
    schema1:license "GPL (>= 3)" ;
    schema1:name "bioconductor-tcgabiolinks" ;
    schema1:url "http://bioconductor.org/packages/3.6/bioc/html/TCGAbiolinks.html" .

