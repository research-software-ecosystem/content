@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:variantbam a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btw111" ;
    schema1:description "Filtering and profiling of next-generational sequencing data using region-specific rules" ;
    schema1:identifier biotools:variantbam ;
    schema1:keywords "Computational Biology",
        "Genomics",
        "High-Throughput Nucleotide Sequencing",
        "Humans",
        "Sequence analysis",
        "Sequence sites, features and motifs",
        "Sequencing" ;
    schema1:license "GPL-3.0" ;
    schema1:name "variantbam" ;
    schema1:url "https://github.com/jwalabroad/VariantBam" .

