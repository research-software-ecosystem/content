@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-titancna a schema1:SoftwareApplication ;
    schema1:description "Subclonal copy number and LOH prediction from whole genome sequencing of tumours" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/TitanCNA_1.44.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/TitanCNA/TitanCNA_1.44.0.tar.gz', 'https://bioarchive.galaxyproject.org/TitanCNA_1.44.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-titancna/bioconductor-titancna_1.44.0_src_all.tar.gz']" ;
    schema1:identifier biotools:titancna ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-titancna" ;
    schema1:softwareVersion "1.44.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/TitanCNA.html" ;
    spdx:builtFrom biotools:titancna .

