@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:barrnap a schema1:SoftwareApplication ;
    schema1:description "Rapid microbial RNA identidication" ;
    schema1:downloadUrl "https://github.com/tseemann/barrnap/archive/v1.10.5.tar.gz" ;
    schema1:identifier biotools:barrnap ;
    schema1:license "GPLv3" ;
    schema1:name "barrnap" ;
    schema1:softwareVersion "1.10.5" ;
    schema1:url "https://github.com/tseemann/barrnap" ;
    spdx:builtFrom biotools:barrnap .

