@prefix debianmed: <https://salsa.debian.org/med-team/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

debianmed:barrnap a schema1:SoftwareApplication ;
    schema1:description "rapid ribosomal RNA prediction" ;
    schema1:identifier "bio.tools:barrnap",
        "conda:bioconda:barrnap",
        "omictools:OMICS_13988",
        "scicrunch:SCR_015995" ;
    schema1:license "unknown" ;
    schema1:name "barrnap" ;
    schema1:softwareVersion "1.0.0" ;
    schema1:url "http://www.vicbioinformatics.com/software.barrnap.shtml" ;
    spdx:builtFrom "barrnap" .

