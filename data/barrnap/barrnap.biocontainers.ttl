@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:barrnap a schema1:SoftwareApplication ;
    schema1:description "Predict the location of ribosomal rna genes in genomes. it supports bacteria (5s,23s,16s), archaea (5s,5.8s,23s,16s), mitochondria (12s,16s) and eukaryotes (5s,5.8s,28s,18s)." ;
    schema1:identifier biotools:barrnap ;
    schema1:keywords "Genomics",
        "Model organisms" ;
    schema1:license "GPL-3.0" ;
    schema1:name "barrnap" ;
    schema1:url "https://github.com/tseemann/barrnap" .

