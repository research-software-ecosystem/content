@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:plass a schema1:SoftwareApplication ;
    schema1:author "martin-steinegger",
        "milot-mirdita" ;
    schema1:citation "doi:10.1038/s41592-019-0437-4",
        "doi:10.1101/2024.03.29.587318" ;
    schema1:description "Plass (Protein-Level ASSembler) and PenguiN (Protein-guided Nucleotide assembler) are methods to assemble short read sequencing data on a protein level to proteins or DNA contigs" ;
    schema1:downloadUrl "https://github.com/soedinglab/plass/archive/5-cf8933.tar.gz" ;
    schema1:identifier biotools:plass ;
    schema1:license "GPLv3" ;
    schema1:maintainer "martin-steinegger",
        "milot-mirdita" ;
    schema1:name "plass" ;
    schema1:softwareVersion "5.cf8933" ;
    schema1:url "https://github.com/soedinglab/plass" ;
    spdx:builtFrom biotools:plass .

