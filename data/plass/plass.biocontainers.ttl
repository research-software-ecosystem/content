@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:plass a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/s41592-019-0437-4",
        "doi:10.1101/386110" ;
    schema1:description "Plass (Protein-Level ASSembler) is a software to assemble short read sequencing data on a protein level" ;
    schema1:keywords "Amino Acid Sequence",
        "Codon",
        "Genomics",
        "Metagenome",
        "Metagenomics",
        "Open Reading Frames",
        "Proteins",
        "Proteomics",
        "Transcriptomics" ;
    schema1:license "GPL-3.0" ;
    schema1:name "plass" ;
    schema1:url "https://github.com/soedinglab/plass" .

