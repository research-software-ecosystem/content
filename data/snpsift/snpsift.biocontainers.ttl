@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:snpsift a schema1:SoftwareApplication ;
    schema1:citation "doi:10.3389/fgene.2012.00035" ;
    schema1:description "Toolbox that allows you to filter and manipulate annotated files" ;
    schema1:identifier biotools:SnpSift ;
    schema1:keywords "Data architecture, analysis and design",
        "Data management" ;
    schema1:license "LGPL-3.0" ;
    schema1:name "snpsift" ;
    schema1:url "http://snpeff.sourceforge.net/SnpSift.html" .

