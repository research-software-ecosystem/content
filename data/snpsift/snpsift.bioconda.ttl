@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:snpsift a schema1:SoftwareApplication ;
    schema1:citation "doi:10.3389/fgene.2012.00035" ;
    schema1:description "Toolbox that allows you to filter and manipulate annotated files" ;
    schema1:downloadUrl "https://snpeff-public.s3.amazonaws.com/versions/snpEff_v5_4c_core.zip" ;
    schema1:identifier biotools:SnpSift ;
    schema1:license "LGPLv3" ;
    schema1:name "snpsift" ;
    schema1:softwareVersion "5.4.0c" ;
    schema1:url "http://snpeff.sourceforge.net/SnpSift.html" ;
    spdx:builtFrom biotools:SnpSift .

