@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:negative_training_sampler a schema1:SoftwareApplication ;
    schema1:description "Generates negative samples with the same gc distribution as the positive samples per chromosome." ;
    schema1:license "MIT" ;
    schema1:name "negative_training_sampler" ;
    schema1:url "https://github.com/kircherlab/negative_training_sampler" .

