@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:metabolab a schema1:SoftwareApplication ;
    schema1:description "A container for a non-GUI version of MetaboLab, software for processing and analysing NMR data." ;
    schema1:keywords "Metabolomics" ;
    schema1:license "GPL" ;
    schema1:name "metabolab" ;
    schema1:url "https://github.com/phnmnl/container-metabolab" .

