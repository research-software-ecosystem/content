@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bax2bam a schema1:SoftwareApplication ;
    schema1:description "bax2bam converts the legacy PacBio basecall format (bax.h5) into the BAM basecall format" ;
    schema1:license "BSD-3-Clause-Clear" ;
    schema1:name "bax2bam" ;
    schema1:url "https://github.com/PacificBiosciences/bax2bam" .

