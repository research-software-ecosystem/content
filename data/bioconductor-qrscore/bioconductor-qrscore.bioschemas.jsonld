  "@graph": [
    {
      "@id": "https://doi.org/10.1101/2025.03.06.641952",
      "@type": "sc:CreativeWork"
    },
    {
      "@id": "https://bio.tools/bioconductor-qrscore",
      "@type": "sc:SoftwareApplication",
      "dcterms:conformsTo": "https://bioschemas.org/profiles/ComputationalTool/0.6-DRAFT",
      "sc:additionalType": [
        "Command-line tool",
        "Library"
      ],
      "sc:author": [
        "Dan Erdmann-Pham",
        "Jonathan Fischer",
        "Alan Aw",
        "Fanding Zhou"
      ],
      "sc:citation": {
        "@id": "https://doi.org/10.1101/2025.03.06.641952"
      },
      "sc:contributor": "Xurui Chen",
      "sc:description": "In genomics, differential analysis enables the discovery of groups of genes implicating important biological processes such as cell differentiation and aging. Non-parametric tests of differential gene expression usually detect shifts in centrality (such as mean or median), and therefore suffer from diminished power against alternative hypotheses characterized by shifts in spread (such as variance). This package provides a flexible family of non-parametric two-sample tests and K-sample tests, which is based on theoretical work around non-parametric tests, spacing statistics and local asymptotic normality (Erdmann-Pham et al., 2022+ [arXiv:2008.06664v2]; Erdmann-Pham, 2023+ [arXiv:2209.14235v2]).",
      "sc:license": "GPL-3.0-or-later",
      "sc:name": "QRscore",
      "sc:operatingSystem": [
        "Windows",
        "Linux",
        "Mac"
      ],
      "sc:softwareHelp": {
        "@id": "https://bioconductor.org/packages/QRscore"
      },
      "sc:softwareVersion": "1.2.0",
      "sc:url": "https://bioconductor.org/packages/QRscore"
    }
  ]
