  "@graph": [
    {
      "@id": "https://bio.tools/bioconductor-treeclimbr",
      "@type": "sc:SoftwareApplication",
      "dcterms:conformsTo": "https://bioschemas.org/profiles/ComputationalTool/0.6-DRAFT",
      "sc:additionalType": [
        "Command-line tool",
        "Library"
      ],
      "sc:author": [
        "Charlotte Soneson",
        "Ruizhu Huang"
      ],
      "sc:citation": {
        "@id": "https://doi.org/10.1186/s13059-021-02368-1"
      },
      "sc:description": "The arrangement of hypotheses in a hierarchical structure appears in many research fields and often indicates different resolutions at which data can be viewed. This raises the question of which resolution level the signal should best be interpreted on. treeclimbR provides a flexible method to select optimal resolution levels (potentially different levels in different parts of the tree), rather than cutting the tree at an arbitrary level. treeclimbR uses a tuning parameter to generate candidate resolutions and from these selects the optimal one.",
      "sc:license": "Artistic-2.0",
      "sc:name": "treeclimbR",
      "sc:operatingSystem": [
        "Windows",
        "Mac",
        "Linux"
      ],
      "sc:softwareHelp": {
        "@id": "https://bioconductor.org/packages/treeclimbR"
      },
      "sc:softwareVersion": "1.6.0",
      "sc:url": "https://bioconductor.org/packages/treeclimbR"
    },
    {
      "@id": "https://doi.org/10.1186/s13059-021-02368-1",
      "@type": "sc:CreativeWork"
    }
  ]
