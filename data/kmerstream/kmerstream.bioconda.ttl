@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:kmerstream a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btu713" ;
    schema1:description "Streaming algorithm for computing kmer statistics for massive genomics datasets" ;
    schema1:downloadUrl "https://github.com/pmelsted/KmerStream/archive/v1.1.tar.gz" ;
    schema1:identifier biotools:kmerstream ;
    schema1:license "free software license" ;
    schema1:name "kmerstream" ;
    schema1:softwareVersion "1.1" ;
    schema1:url "https://github.com/pmelsted/KmerStream" ;
    spdx:builtFrom biotools:kmerstream .

