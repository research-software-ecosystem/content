@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:kmerstream a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btu713" ;
    schema1:description "Streaming algorithm for computing kmer statistics for massive genomics datasets" ;
    schema1:identifier biotools:kmerstream ;
    schema1:keywords "Genome Size",
        "Genome, Human",
        "Genomics",
        "High-Throughput Nucleotide Sequencing",
        "Humans",
        "Sequence Analysis, DNA",
        "Sequencing",
        "Statistics and probability" ;
    schema1:license "free software license" ;
    schema1:name "kmerstream" ;
    schema1:url "https://github.com/pmelsted/KmerStream" .

