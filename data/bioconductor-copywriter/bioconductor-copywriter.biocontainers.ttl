@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-copywriter a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s13059-015-0617-1" ;
    schema1:description "Copy number information from targeted sequencing using off-target reads" ;
    schema1:identifier biotools:copywriter ;
    schema1:keywords "DNA Copy Number Variations",
        "Exome",
        "Exons",
        "Genome, Human",
        "High-Throughput Nucleotide Sequencing",
        "Humans",
        "Sequence Analysis, DNA",
        "Sequence analysis" ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-copywriter" ;
    schema1:url "http://bioconductor.org/packages/3.6/bioc/html/CopywriteR.html" .

