@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:proteowizard a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nbt.2377" ;
    schema1:description "The proteowizard library and tools are a set of modular and extensible open-source, cross-platform tools and software libraries that facilitate proteomics data analysis." ;
    schema1:identifier biotools:proteowizard ;
    schema1:keywords "Humans",
        "Mass Spectrometry",
        "Mass spectrometry",
        "Proteome",
        "Proteomics",
        "Proteomics experiment" ;
    schema1:license "Apache-2.0" ;
    schema1:name "proteowizard" ;
    schema1:url "http://proteowizard.sourceforge.net/" .

