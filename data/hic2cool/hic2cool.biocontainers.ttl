@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:hic2cool a schema1:SoftwareApplication ;
    schema1:description "A converter between .hic files (from juicer) and .cool files (for cooler)." ;
    schema1:license "MIT" ;
    schema1:name "hic2cool" ;
    schema1:url "https://github.com/4dn-dcic/hic2cool" .

