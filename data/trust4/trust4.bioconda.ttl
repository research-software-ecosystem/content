@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:trust4 a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/s41592-021-01142-2" ;
    schema1:description "TCR and BCR assembly from bulk or single-cell RNA-seq data." ;
    schema1:downloadUrl "https://github.com/liulab-dfci/TRUST4/archive/v1.1.9.tar.gz" ;
    schema1:identifier biotools:trust4 ;
    schema1:license "MIT" ;
    schema1:name "trust4" ;
    schema1:softwareHelp "https://github.com/liulab-dfci/TRUST4/blob/v1.1.9/README.md" ;
    schema1:softwareVersion "1.1.9" ;
    schema1:url "https://github.com/liulab-dfci/TRUST4" ;
    spdx:builtFrom biotools:trust4 .

