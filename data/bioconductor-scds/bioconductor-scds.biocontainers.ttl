@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-scds a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18129/b9.bioc.scds" ;
    schema1:description "In-silico annotation of doublets for single cell rna sequencing data" ;
    schema1:keywords "RNA-Seq",
        "Transcriptomics" ;
    schema1:license "MIT" ;
    schema1:name "bioconductor-scds" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/scds.html" .

