@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-systempiper a schema1:SoftwareApplication ;
    schema1:description "systemPipeR: Workflow Environment for Data Analysis and Report Generation" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/systemPipeR_2.16.3.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/systemPipeR/systemPipeR_2.16.3.tar.gz', 'https://bioarchive.galaxyproject.org/systemPipeR_2.16.3.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-systempiper/bioconductor-systempiper_2.16.3_src_all.tar.gz']" ;
    schema1:identifier biotools:systempiper ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-systempiper" ;
    schema1:softwareVersion "2.16.3" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/systemPipeR.html" ;
    spdx:builtFrom biotools:systempiper .

