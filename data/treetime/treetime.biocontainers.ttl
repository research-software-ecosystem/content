@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:treetime a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/ve/vex042" ;
    schema1:description "Maximum-likelihood dating and ancestral inference for phylogenetic trees" ;
    schema1:keywords "Genetics",
        "Phylogenetics",
        "Sequence Alignment" ;
    schema1:license "MIT" ;
    schema1:name "treetime" ;
    schema1:url "https://github.com/neherlab/treetime" .

