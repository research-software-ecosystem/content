@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-seq2pathway a schema1:SoftwareApplication ;
    schema1:description "a novel tool for functional gene-set (or termed as pathway) analysis of next-generation sequencing data" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/seq2pathway_1.38.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/seq2pathway/seq2pathway_1.38.0.tar.gz', 'https://bioarchive.galaxyproject.org/seq2pathway_1.38.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-seq2pathway/bioconductor-seq2pathway_1.38.0_src_all.tar.gz']" ;
    schema1:identifier biotools:seq2pathway ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-seq2pathway" ;
    schema1:softwareVersion "1.38.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/seq2pathway.html" ;
    spdx:builtFrom biotools:seq2pathway .

