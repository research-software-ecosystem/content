@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-seq2pathway a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1371/journal.pcbi.1002350" ;
    schema1:description "a novel tool for functional gene-set (or termed as pathway) analysis of next-generation sequencing data" ;
    schema1:identifier biotools:seq2pathway ;
    schema1:keywords "Carcinoma, Squamous Cell",
        "ChIP-seq",
        "Cohort Studies",
        "GWAS study",
        "Gene Expression Profiling",
        "Head and Neck Neoplasms",
        "Humans",
        "RNA-Seq",
        "RNA-seq",
        "ROC Curve" ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-seq2pathway" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/seq2pathway.html" .

