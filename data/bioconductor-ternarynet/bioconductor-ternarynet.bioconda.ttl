@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-ternarynet a schema1:SoftwareApplication ;
    schema1:description "Ternary Network Estimation" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/ternarynet_1.54.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/ternarynet/ternarynet_1.54.0.tar.gz', 'https://bioarchive.galaxyproject.org/ternarynet_1.54.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-ternarynet/bioconductor-ternarynet_1.54.0_src_all.tar.gz']" ;
    schema1:identifier biotools:ternarynet ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-ternarynet" ;
    schema1:softwareVersion "1.54.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/ternarynet.html" ;
    spdx:builtFrom biotools:ternarynet .

