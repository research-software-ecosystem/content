@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bismark a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btr167" ;
    schema1:description "Bismark is a tool to map bisulfite treated sequencing reads and perform methylation calling in a quick and easy-to-use fashion." ;
    schema1:identifier biotools:bismark ;
    schema1:keywords "Cytosine",
        "DNA",
        "DNA Methylation",
        "Epigenetics",
        "Epigenomics",
        "Genomics",
        "Sequence Analysis, DNA",
        "Sulfites" ;
    schema1:license "GPL-3.0" ;
    schema1:name "bismark" ;
    schema1:url "https://github.com/FelixKrueger/Bismark" .

