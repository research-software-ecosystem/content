@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:intarna a schema1:SoftwareApplication ;
    schema1:author "BackofenLab",
        "martin-raden" ;
    schema1:citation "doi:10.1093/bioinformatics/btn544",
        "doi:10.1093/nar/gkx279",
        "doi:10.1093/nar/gky329" ;
    schema1:description "Efficient RNA-RNA interaction prediction incorporating seeding and accessibility of interacting sites." ;
    schema1:downloadUrl "https://github.com/BackofenLab/IntaRNA/releases/download/v3.4.1/intaRNA-3.4.1.tar.gz" ;
    schema1:identifier biotools:intarna ;
    schema1:license "MIT" ;
    schema1:maintainer "BackofenLab",
        "martin-raden" ;
    schema1:name "intarna" ;
    schema1:softwareHelp "https://backofenlab.github.io/IntaRNA" ;
    schema1:softwareVersion "3.4.1" ;
    schema1:url "https://github.com/BackofenLab/IntaRNA" ;
    spdx:builtFrom biotools:intarna .

