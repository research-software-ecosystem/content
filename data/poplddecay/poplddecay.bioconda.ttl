@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:poplddecay a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/bty875" ;
    schema1:description "PopLDdecay: a fast and effective tool for linkage disequilibrium decay analysis based on variant call format (VCF) files." ;
    schema1:downloadUrl "https://github.com/BGI-shenzhen/PopLDdecay/archive/refs/tags/v3.43.tar.gz" ;
    schema1:identifier biotools:PopLDdecay ;
    schema1:license "MIT" ;
    schema1:name "poplddecay" ;
    schema1:softwareHelp "https://github.com/BGI-shenzhen/PopLDdecay/blob/v3.43/README.md" ;
    schema1:softwareVersion "3.43" ;
    schema1:url "https://github.com/BGI-shenzhen/PopLDdecay" ;
    spdx:builtFrom biotools:PopLDdecay .

