@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:delly a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/bts378" ;
    schema1:description "Structural variant discovery by integrated paired-end and split-read analysis" ;
    schema1:downloadUrl "https://github.com/dellytools/delly/archive/v2.0.0.tar.gz" ;
    schema1:identifier biotools:delly2 ;
    schema1:license "BSD-3-Clause" ;
    schema1:name "delly" ;
    schema1:softwareHelp "https://github.com/dellytools/delly/blob/v2.0.0/README.md" ;
    schema1:softwareVersion "2.0.0" ;
    schema1:url "https://github.com/dellytools/delly" ;
    spdx:builtFrom biotools:delly2 .

