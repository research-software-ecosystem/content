@prefix debianmed: <https://salsa.debian.org/med-team/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

debianmed:delly a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/bts378" ;
    schema1:description "Structural variant discovery by read analysis" ;
    schema1:identifier "bio.tools:delly2",
        "conda:bioconda:delly",
        "omictools:OMICS_00313",
        "scicrunch:SCR_004603" ;
    schema1:license "unknown" ;
    schema1:name "delly" ;
    schema1:softwareVersion "1.7.2" ;
    schema1:url "https://github.com/dellytools/delly" ;
    spdx:builtFrom "delly2" .

