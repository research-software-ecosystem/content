@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:autodock a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1002/jcc.21256",
        "doi:10.26434/CHEMRXIV.9702389.V1" ;
    schema1:description "Analysis of ligand binding to protein structure" ;
    schema1:identifier biotools:autodock ;
    schema1:keywords "Ligands",
        "Models, Molecular",
        "Molecular modelling",
        "Protein Binding",
        "Protein interactions",
        "Protein structural motifs and surfaces",
        "Proteins",
        "Small molecules" ;
    schema1:license "GPL-2+" ;
    schema1:name "autodock" ;
    schema1:url "http://autodock.scripps.edu/" .

