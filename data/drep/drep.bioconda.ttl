@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:drep a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/ismej.2017.126" ;
    schema1:description "De-replication of microbial genomes assembled from multiple samples." ;
    schema1:downloadUrl "https://pypi.io/packages/source/d/drep/drep-3.6.2.tar.gz" ;
    schema1:identifier biotools:drep ;
    schema1:license "MIT" ;
    schema1:name "drep" ;
    schema1:softwareHelp "https://drep.readthedocs.io/en/latest" ;
    schema1:softwareVersion "3.6.2" ;
    schema1:url "https://github.com/MrOlm/drep" ;
    spdx:builtFrom biotools:drep .

