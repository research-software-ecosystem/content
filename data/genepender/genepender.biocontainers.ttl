@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:genepender a schema1:SoftwareApplication ;
    schema1:description "Annotates overlapping BED-defined regions to variants in a VCF file. Used primarily for providing a gene/exon context to variants (see:bedtarget)." ;
    schema1:license "GPL-3.0" ;
    schema1:name "genepender" ;
    schema1:url "https://github.com/BioTools-Tek/genepender" .

