@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-biomformat a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "An interface package for the BIOM file format" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/biomformat_1.38.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/biomformat/biomformat_1.38.0.tar.gz', 'https://bioarchive.galaxyproject.org/biomformat_1.38.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-biomformat/bioconductor-biomformat_1.38.0_src_all.tar.gz']" ;
    schema1:identifier biotools:biomformat ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-biomformat" ;
    schema1:softwareVersion "1.38.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/biomformat.html" ;
    spdx:builtFrom biotools:biomformat .

