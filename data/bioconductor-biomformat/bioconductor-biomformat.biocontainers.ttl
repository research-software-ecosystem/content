@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-biomformat a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Gnu r interface package for the biom file format" ;
    schema1:identifier biotools:biomformat ;
    schema1:keywords "Computational Biology",
        "Gene Expression Profiling",
        "Genomics",
        "High-Throughput Screening Assays",
        "Laboratory information management",
        "Metagenome",
        "Metagenomics",
        "Programming Languages",
        "Sequence analysis",
        "User-Computer Interface" ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-biomformat" ;
    schema1:url "https://bioconductor.org/packages/biomformat/" .

