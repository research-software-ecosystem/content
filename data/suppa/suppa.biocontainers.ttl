@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:suppa a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1261/rna.051557.115" ;
    schema1:description "A tool to study splicing across multiple conditions at high speed and accuracy." ;
    schema1:identifier biotools:suppa ;
    schema1:keywords "Alternative Splicing",
        "Animals",
        "Cluster Analysis",
        "Clustering",
        "Computational Biology",
        "Computer Simulation",
        "Gene Expression",
        "Gene Expression Profiling",
        "Humans",
        "RNA",
        "RNA splicing",
        "Sequence Analysis, RNA",
        "Transcriptomics" ;
    schema1:license "MIT" ;
    schema1:name "suppa" ;
    schema1:url "https://github.com/comprna/SUPPA" .

