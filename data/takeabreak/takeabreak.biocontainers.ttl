@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:takeabreak a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1007/978-3-319-07953-0_10" ;
    schema1:description "tool that can detect inversion breakpoints directly from raw NGS reads, without the need of any reference genome and without de novo assembling the genomes" ;
    schema1:identifier biotools:takeabreak ;
    schema1:keywords "Genetic variation" ;
    schema1:license "GNU" ;
    schema1:name "takeabreak" ;
    schema1:url "https://colibread.inria.fr/software/takeabreak/" .

