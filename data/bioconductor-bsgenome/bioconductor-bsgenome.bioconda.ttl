@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-bsgenome a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Software infrastructure for efficient representation of full genomes and their SNPs" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/BSgenome_1.78.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/BSgenome/BSgenome_1.78.0.tar.gz', 'https://bioarchive.galaxyproject.org/BSgenome_1.78.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-bsgenome/bioconductor-bsgenome_1.78.0_src_all.tar.gz']" ;
    schema1:identifier biotools:bsgenome ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-bsgenome" ;
    schema1:softwareVersion "1.78.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/BSgenome.html" ;
    spdx:builtFrom biotools:bsgenome .

