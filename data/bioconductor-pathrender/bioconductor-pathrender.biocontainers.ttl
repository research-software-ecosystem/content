@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-pathrender a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Render molecular pathways" ;
    schema1:identifier biotools:pathrender ;
    schema1:keywords "Computational Biology",
        "Gene Expression Profiling",
        "Genomics",
        "High-Throughput Screening Assays",
        "Molecular interactions, pathways and networks",
        "Programming Languages",
        "Systems biology",
        "User-Computer Interface" ;
    schema1:license "LGPL" ;
    schema1:name "bioconductor-pathrender" ;
    schema1:url "http://bioconductor.org/packages/3.6/bioc/html/pathRender.html" .

