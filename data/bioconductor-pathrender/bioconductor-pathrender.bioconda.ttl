@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-pathrender a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Render molecular pathways" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/pathRender_1.74.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/pathRender/pathRender_1.74.0.tar.gz', 'https://bioarchive.galaxyproject.org/pathRender_1.74.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-pathrender/bioconductor-pathrender_1.74.0_src_all.tar.gz']" ;
    schema1:identifier biotools:pathrender ;
    schema1:license "LGPL" ;
    schema1:name "bioconductor-pathrender" ;
    schema1:softwareVersion "1.74.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/pathRender.html" ;
    spdx:builtFrom biotools:pathrender .

