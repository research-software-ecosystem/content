@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-kegglincs a schema1:SoftwareApplication ;
    schema1:citation "doi:10.7490/f1000research.1113436.1" ;
    schema1:description "Visualize all edges within a KEGG pathway and overlay LINCS data" ;
    schema1:identifier biotools:kegglincs ;
    schema1:keywords "Mapping",
