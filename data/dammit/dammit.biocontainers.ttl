@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:dammit a schema1:SoftwareApplication ;
    schema1:description "simple de novo transcriptome annotator" ;
    schema1:identifier biotools:dammit ;
    schema1:keywords "Genotype and phenotype",
        "Sequence assembly",
        "Transcriptome",
        "Transcriptomics" ;
    schema1:license "BSD" ;
    schema1:name "dammit" ;
    schema1:url "http://dib-lab.github.io/dammit/" .

