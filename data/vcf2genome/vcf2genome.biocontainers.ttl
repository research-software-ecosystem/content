@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:vcf2genome a schema1:SoftwareApplication ;
    schema1:description "A tool to create a draft genome file out of a gatk vcf file and enabling users to filter the vcf in a single step." ;
    schema1:license "GNU General Public License v3.0" ;
    schema1:name "vcf2genome" ;
    schema1:url "https://github.com/apeltzer/vcf2genome" .

