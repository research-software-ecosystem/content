@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-scdd a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18129/b9.bioc.scdd" ;
    schema1:description "Mixture modeling of single-cell RNA-seq data to identify genes with differential distributions" ;
    schema1:keywords "Clustering",
        "RNA-Seq" ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-scdd" ;
    schema1:url "https://bioconductor.org/packages/3.8/bioc/html/scDD.html" .

