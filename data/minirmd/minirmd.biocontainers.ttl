@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:minirmd a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btaa915" ;
    schema1:description "minirmd is a tool to remove duplicate reads. The program is written in C++11 (tested with g++ >= 5.4.0) and works on Linux." ;
    schema1:identifier biotools:minirmd ;
    schema1:keywords "Topic" ;
    schema1:license "GPL-3.0" ;
    schema1:name "minirmd" ;
    schema1:url "https://github.com/yuansliu/minirmd" .

