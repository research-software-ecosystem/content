@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-crimage a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1126/scitranslmed.3004330" ;
    schema1:description "CRImage a package to classify cells and calculate tumour cellularity" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/CRImage_1.54.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/CRImage/CRImage_1.54.0.tar.gz', 'https://bioarchive.galaxyproject.org/CRImage_1.54.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-crimage/bioconductor-crimage_1.54.0_src_all.tar.gz']" ;
    schema1:identifier biotools:crimage ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-crimage" ;
    schema1:softwareVersion "1.54.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/CRImage.html" ;
    spdx:builtFrom biotools:crimage .

