@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-multidataset a schema1:SoftwareApplication ;
    schema1:description "Implementation of MultiDataSet and ResultSet" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/MultiDataSet_1.34.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/MultiDataSet/MultiDataSet_1.34.0.tar.gz', 'https://bioarchive.galaxyproject.org/MultiDataSet_1.34.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-multidataset/bioconductor-multidataset_1.34.0_src_all.tar.gz']" ;
    schema1:identifier biotools:multidataset ;
    schema1:license "file LICENSE" ;
    schema1:name "bioconductor-multidataset" ;
    schema1:softwareVersion "1.34.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/MultiDataSet.html" ;
    spdx:builtFrom biotools:multidataset .

