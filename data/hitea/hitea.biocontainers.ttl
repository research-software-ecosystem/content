@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:hitea a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btaa923" ;
    schema1:description "Computational tool to identify trasposable element insertions using hi-c data" ;
    schema1:keywords "Genomics",
        "Sequence Alignment" ;
    schema1:license "MIT" ;
    schema1:name "hitea" ;
    schema1:url "https://github.com/parklab/HiTea" .

