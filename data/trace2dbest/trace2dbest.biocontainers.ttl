@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:trace2dbest a schema1:SoftwareApplication ;
    schema1:description "Bulk submission of chromatogram data to dbest" ;
    schema1:keywords "Genomics",
        "Transcriptome" ;
    schema1:license "GPL-2.0" ;
    schema1:name "trace2dbest" ;
    schema1:url "http://www.nematodes.org/bioinformatics/trace2dbEST/" .

