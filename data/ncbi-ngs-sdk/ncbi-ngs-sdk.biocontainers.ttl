@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:ncbi-ngs-sdk a schema1:SoftwareApplication ;
    schema1:description "NGS is a new, domain-specific API for accessing reads, alignments and pileups produced from Next Generation Sequencing." ;
    schema1:license "Public Domain" ;
    schema1:name "ncbi-ngs-sdk" ;
    schema1:url "https://github.com/ncbi/ngs" .

