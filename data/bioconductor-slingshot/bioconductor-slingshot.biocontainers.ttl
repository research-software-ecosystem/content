@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-slingshot a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18129/b9.bioc.slingshot" ;
    schema1:description "Tools for ordering single-cell sequencing" ;
    schema1:keywords "Clustering",
        "Transcriptomics" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-slingshot" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/slingshot.html" .

