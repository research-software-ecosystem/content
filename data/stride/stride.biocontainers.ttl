@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:stride a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/gkh429" ;
    schema1:description "The stride assembler integrates string and de bruijn graph by decomposing reads within error-prone regions, while extending paire-end read into long reads for assembly through repetitive regions." ;
    schema1:identifier biotools:stride ;
    schema1:keywords "Databases, Protein",
        "Hydrogen Bonding",
        "Internet",
        "Mapping",
        "Molecular Structure",
        "Protein Structure, Secondary",
        "Protein secondary structure",
        "Protein structure analysis",
        "Proteins",
        "Structural biology" ;
    schema1:license "GPL-3.0" ;
    schema1:name "stride" ;
    schema1:url "https://github.com/ythuang0522/StriDe" .

