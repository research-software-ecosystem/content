@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-degseq a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btp612" ;
    schema1:description "Identify Differentially Expressed Genes from RNA-seq data" ;
    schema1:identifier biotools:degseq ;
    schema1:keywords "Base Sequence",
        "Gene Expression Profiling",
        "Gene expression",
        "Molecular Sequence Data",
        "Oligonucleotide Array Sequence Analysis",
        "Programming Languages",
        "RNA",
        "RNA-Seq",
        "Sequence Analysis, RNA" ;
    schema1:license "LGPL (>=2)" ;
    schema1:name "bioconductor-degseq" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/DEGseq.html" .

