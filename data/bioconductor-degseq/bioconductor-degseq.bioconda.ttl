@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-degseq a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btp612" ;
    schema1:description "Identify Differentially Expressed Genes from RNA-seq data" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/DEGseq_1.64.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/DEGseq/DEGseq_1.64.0.tar.gz', 'https://bioarchive.galaxyproject.org/DEGseq_1.64.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-degseq/bioconductor-degseq_1.64.0_src_all.tar.gz']" ;
    schema1:identifier biotools:degseq ;
    schema1:license "LGPL (>=2)" ;
    schema1:name "bioconductor-degseq" ;
    schema1:softwareVersion "1.64.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/DEGseq.html" ;
    spdx:builtFrom biotools:degseq .

