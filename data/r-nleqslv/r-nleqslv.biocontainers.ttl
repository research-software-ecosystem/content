@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-nleqslv a schema1:SoftwareApplication ;
    schema1:description "Solve a system of nonlinear equations using a Broyden or a Newton method with a choice of global strategies such as line search and trust region. There are options for using a numerical or user supplied Jacobian, for specifying a banded numerical Jacobian and for allowing a singular or ill-conditioned Jacobian." ;
    schema1:license "GPL-3.0" ;
    schema1:name "r-nleqslv" ;
    schema1:url "https://CRAN.R-project.org/package=nleqslv" .

