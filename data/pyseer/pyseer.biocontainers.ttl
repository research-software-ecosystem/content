@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:pyseer a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/bty539",
        "doi:10.1101/852426v1" ;
    schema1:description "Sequence element enrichment analysis (seer), python implementation" ;
    schema1:identifier biotools:pyseer ;
    schema1:keywords "Bacteria",
        "Computational Biology",
        "GWAS study",
        "Genetic Association Studies",
        "Genotype and phenotype",
        "Literature and language",
        "Models, Statistical" ;
    schema1:license "Apache-2.0" ;
    schema1:name "pyseer" ;
    schema1:url "https://github.com/mgalardini/pyseer" .

