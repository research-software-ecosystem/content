@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:hifiadapterfilt a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s12864-022-08375-1" ;
    schema1:description "Convert .bam to .fastq and remove reads with remnant PacBio HiFi adapter sequences" ;
    schema1:downloadUrl "https://github.com/sheinasim/HiFiAdapterFilt/archive/refs/tags/v3.0.0.tar.gz" ;
    schema1:identifier biotools:hifiadapterfilt ;
    schema1:license "GPL-3.0-or-later" ;
    schema1:name "hifiadapterfilt" ;
    schema1:softwareVersion "3.0.0" ;
    schema1:url "https://bio.tools/hifiadapterfilt" ;
    spdx:builtFrom biotools:hifiadapterfilt .

