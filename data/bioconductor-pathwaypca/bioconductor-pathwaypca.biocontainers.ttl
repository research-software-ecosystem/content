        "Metabolomics",
        "Proteomics",
        "Transcriptomics" ;
    schema1:license "GPL-3" ;
    schema1:name "bioconductor-pathwaypca" ;
    schema1:url "https://bioconductor.org/packages/3.9/bioc/html/pathwayPCA.html" .

