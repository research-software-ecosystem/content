@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:scala a schema1:SoftwareApplication ;
    schema1:description "Scala combines object-oriented and functional programming in one concise, high-level language. scala's static types help avoid bugs in complex applications, and its jvm and javascript runtimes let you build high-performance systems with easy access to huge ecosystems of libraries." ;
    schema1:license "BSD" ;
    schema1:name "scala" ;
    schema1:url "https://github.com/scala/scala" .

