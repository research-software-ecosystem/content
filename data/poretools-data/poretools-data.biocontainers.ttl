@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:poretools-data a schema1:SoftwareApplication ;
    schema1:description "Toolkit for nanopore nucleotide sequencing data -- sample datasets" ;
    schema1:license "GPL-1+" ;
    schema1:name "poretools-data" ;
    schema1:url "https://github.com/arq5x/poretools" .

