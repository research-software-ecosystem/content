@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:quantwiz-iq a schema1:SoftwareApplication ;
    schema1:description "QuantWiz-IQ is a tool for reporter based MS/MS quantitation using iTRAQ or TMT tags from shotgun proteomics experiments." ;
    schema1:keywords "Proteomics" ;
    schema1:license "GPL" ;
    schema1:name "quantwiz-iq" ;
    schema1:url "https://sourceforge.net/projects/quantwiz/" .

