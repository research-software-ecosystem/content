@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:clever-toolkit a schema1:SoftwareApplication ;
    schema1:description "The clever toolkit (ctk) is a suite of tools to analyze next-generation sequencing data and, in particular, to discover and genotype insertions and deletions from paired-end reads." ;
    schema1:license "GPL-3.0" ;
    schema1:name "clever-toolkit" ;
    schema1:url "https://bitbucket.org/tobiasmarschall/clever-toolkit/" .

