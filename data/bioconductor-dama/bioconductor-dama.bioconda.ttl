bioconda:bioconductor-dama a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1016/j.csda.2004.08.014" ;
    schema1:description "Efficient design and analysis of factorial two-colour microarray data" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/daMA_1.82.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/daMA/daMA_1.82.0.tar.gz', 'https://bioarchive.galaxyproject.org/daMA_1.82.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-dama/bioconductor-dama_1.82.0_src_all.tar.gz']" ;
    schema1:identifier biotools:dama ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-dama" ;
    schema1:softwareVersion "1.82.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/daMA.html" ;
    spdx:builtFrom biotools:dama .

