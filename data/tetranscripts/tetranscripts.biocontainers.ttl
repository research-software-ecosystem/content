@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:tetranscripts a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btv422" ;
    schema1:description "A package for including transposable elements in differential enrichment analysis of sequencing datasets." ;
    schema1:keywords "Animals",
        "DNA Transposable Elements",
        "Databases, Genetic",
        "Drosophila melanogaster",
        "Gene Expression Profiling",
        "Mice",
        "RNA, Messenger",
        "RNA-Seq",
        "Sequence Analysis, RNA" ;
    schema1:license "GPL-3.0" ;
    schema1:name "tetranscripts" ;
    schema1:url "https://github.com/mhammell-laboratory/TEtranscripts" .

