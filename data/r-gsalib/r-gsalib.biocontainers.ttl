@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-gsalib a schema1:SoftwareApplication ;
    schema1:description "This package contains utility functions used by the Genome Analysis Toolkit (GATK) to load tables and plot data. The GATK is a toolkit for variant discovery in high-throughput sequencing data." ;
    schema1:license "MIT" ;
    schema1:name "r-gsalib" ;
    schema1:url "None" .

