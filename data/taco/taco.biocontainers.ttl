@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:taco a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.4078" ;
    schema1:description "A tool for multi-sample transcriptome assembly from RNA-Seq" ;
    schema1:keywords "RNA-Seq",
        "Transcriptome" ;
    schema1:license "MIT" ;
    schema1:name "taco" ;
    schema1:url "https://github.com/tacorna/taco" .

