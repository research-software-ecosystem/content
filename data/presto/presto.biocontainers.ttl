@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:presto a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btu138" ;
    schema1:description "A bioinformatics toolkit for processing high-throughput lymphocyte receptor sequencing data." ;
    schema1:identifier biotools:presto ;
    schema1:keywords "DNA",
        "High-Throughput Nucleotide Sequencing",
        "Immunology",
        "Lymphocytes",
        "Receptors, Immunologic",
        "Sequence Analysis, DNA",
        "Sequence Analysis, RNA",
        "Sequencing" ;
    schema1:license "AGPL-3.0" ;
    schema1:name "presto" ;
    schema1:url "https://bitbucket.org/kleinstein/presto/src/default/" .

