@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-prolocgui a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/ncomms9992" ;
    schema1:description "Interactive visualisation of spatial proteomics data" ;
    schema1:identifier biotools:prolocgui ;
    schema1:keywords "Animals",
        "Cell Fractionation",
        "Immunohistochemistry",
        "Intracellular Space",
        "Machine Learning",
        "Mass Spectrometry",
        "Mice",
        "Mouse Embryonic Stem Cells",
        "Multivariate Analysis",
        "Pluripotent Stem Cells",
        "Proteome",
        "Proteomics",
        "Subcellular Fractions" ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-prolocgui" ;
    schema1:url "http://bioconductor.org/packages/3.6/bioc/html/pRolocGUI.html" .

