@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-prolocgui a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/ncomms9992" ;
    schema1:description "Interactive visualisation of spatial proteomics data" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/pRolocGUI_2.20.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/pRolocGUI/pRolocGUI_2.20.0.tar.gz', 'https://bioarchive.galaxyproject.org/pRolocGUI_2.20.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-prolocgui/bioconductor-prolocgui_2.20.0_src_all.tar.gz']" ;
    schema1:identifier biotools:prolocgui ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-prolocgui" ;
    schema1:softwareVersion "2.20.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/pRolocGUI.html" ;
    spdx:builtFrom biotools:prolocgui .

