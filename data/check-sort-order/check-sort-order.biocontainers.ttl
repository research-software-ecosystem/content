@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:check-sort-order a schema1:SoftwareApplication ;
    schema1:description "Check sort-order of genomic files according to a genomefile" ;
    schema1:license "MIT" ;
    schema1:name "check-sort-order" ;
    schema1:url "https://github.com/gogetdata/ggd-utils" .

