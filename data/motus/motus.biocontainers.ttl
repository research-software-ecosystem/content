@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:motus a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.2693",
        "doi:10.1038/s41467-019-08844-4" ;
    schema1:description "Metagenomic operational taxonomic units (motus) allow for the taxonomic profiling of known (sequenced) and unknown microorganisms at species-level resolution from shotgun sequencing data. the method clusters single-copy phylogenetic marker gene sequences from metagenomes and reference genomes into motus to quantify their abundances in shotgun metagenomic samples." ;
    schema1:identifier biotools:motus ;
    schema1:keywords "Cluster Analysis",
        "Computational Biology",
        "Gene Expression Profiling",
        "Genes, Essential",
        "Genetic Markers",
        "Genome",
        "Host Microbial Interactions",
        "Humans",
        "Metagenomics",
        "Microbiota",
        "Molecular Sequence Annotation",
        "Phylogeny",
        "Sequence Alignment",
        "Sequence Analysis, DNA" ;
    schema1:license "GPL-3.0" ;
    schema1:name "motus" ;
    schema1:url "http://www.bork.embl.de/software/mOTU/" .

