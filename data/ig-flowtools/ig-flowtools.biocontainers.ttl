@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:ig-flowtools a schema1:SoftwareApplication ;
    schema1:description "Set of tools for flow cytometry analysis" ;
    schema1:license "BSD" ;
    schema1:name "ig-flowtools" ;
    schema1:url "https://github.com/ImmPortDB/ig-flowtools" .

