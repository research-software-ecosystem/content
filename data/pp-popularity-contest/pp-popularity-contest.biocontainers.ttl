@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:pp-popularity-contest a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/gkg508",
        "doi:10.1093/nar/gkg572",
        "doi:10.1093/nar/gkh377" ;
    schema1:description "Predictprotein popularity contest" ;
    schema1:identifier biotools:predictprotein ;
    schema1:keywords "Databases, Protein",
        "Internet",
        "Protein Structure",
        "Protein Structure, Secondary",
        "Protein Structure, Tertiary",
        "Protein folds and structural domains",
        "Protein structural motifs and surfaces",
        "Proteins",
        "Sequence Alignment",
        "Sequence Analysis, Protein",
        "Sequence sites, features and motifs",
        "Structure prediction",
        "Time Factors",
        "User-Computer Interface" ;
    schema1:license "custom, see /usr/share/doc/pp-popularity-contest/copyright" ;
    schema1:name "pp-popularity-contest" ;
    schema1:url "http://predictprotein.org/" .

