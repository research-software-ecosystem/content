@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-enrichr a schema1:SoftwareApplication ;
    schema1:description "Provides an R interface to all 'Enrichr' databases, a web-based tool for analysing gene sets and returns any enrichment of common annotated biological functions. <http://amp.pharm.mssm.edu/Enrichr/>." ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "r-enrichr" ;
    schema1:url "https://CRAN.R-project.org/package=enrichR" .

