@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-piano a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/nar/gkt111" ;
    schema1:description "Platform for integrative analysis of omics data" ;
    schema1:identifier biotools:piano ;
    schema1:keywords "Data Interpretation, Statistical",
        "Gene Expression Profiling",
        "Gene and protein families",
        "Genes",
        "Genetics",
        "Genomics",
        "Principal Component Analysis",
        "Saccharomyces cerevisiae" ;
    schema1:license "GPL (>=2)" ;
    schema1:name "bioconductor-piano" ;
    schema1:url "None" .

