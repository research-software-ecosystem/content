@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-piano a schema1:SoftwareApplication ;
    schema1:description "Platform for integrative analysis of omics data" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/piano_2.22.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/piano/piano_2.22.0.tar.gz', 'https://bioarchive.galaxyproject.org/piano_2.22.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-piano/bioconductor-piano_2.22.0_src_all.tar.gz']" ;
    schema1:identifier biotools:piano ;
    schema1:license "GPL (>=2)" ;
    schema1:name "bioconductor-piano" ;
    schema1:softwareVersion "2.22.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/piano.html" ;
    spdx:builtFrom biotools:piano .

