@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-geneaccord a schema1:SoftwareApplication ;
    schema1:citation "doi:10.18129/b9.bioc.geneaccord" ;
    schema1:description "Detection of clonally exclusive gene or pathway pairs in a cohort of cancer patients" ;
    schema1:keywords "Genetics",
        "Genomics" ;
    schema1:license "GNU GENERAL PUBLIC LICENSE" ;
    schema1:name "bioconductor-geneaccord" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/GeneAccord.html" .

