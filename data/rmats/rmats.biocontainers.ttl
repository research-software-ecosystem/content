@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:rmats a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1007/978-1-62703-514-9_10",
        "doi:10.1073/pnas.1419161111",
        "doi:10.1093/nar/gkr1291" ;
    schema1:description "Mats is a computational tool to detect differential alternative splicing events from rna-seq data." ;
    schema1:keywords "Alternative Splicing",
        "Bayes Theorem",
        "Brain",
        "Cell Line, Tumor",
        "Gene Expression",
        "High-Throughput Nucleotide Sequencing",
        "Humans",
        "Multivariate Analysis",
        "RNA-Binding Proteins",
        "RNA-Seq",
        "Reverse Transcriptase Polymerase Chain Reaction",
        "Sequence Analysis, RNA" ;
    schema1:license "MIT" ;
    schema1:name "rmats" ;
    schema1:url "http://rnaseq-mats.sourceforge.net" .

