@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:interproscan a schema1:SoftwareApplication ;
    schema1:description "InterPro integrates together predictive information about proteins function from a number of partner resources" ;
    schema1:downloadUrl "https://github.com/ebi-pf-team/interproscan/archive/5.59-91.0.tar.gz" ;
    schema1:identifier biotools:interproscan_ebi ;
    schema1:license "GPLv3" ;
    schema1:name "interproscan" ;
    schema1:softwareVersion "5.59_91.0" ;
    schema1:url "https://github.com/ebi-pf-team/interproscan" ;
    spdx:builtFrom biotools:interproscan_ebi .

