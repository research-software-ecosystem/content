@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:gadem a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1089/cmb.2008.16TT" ;
    schema1:description "A Genetic Algorithm Guided Formation of Spaced Dyads Coupled with an EM Algorithm for Motif Discovery." ;
    schema1:downloadUrl "https://www.niehs.nih.gov/research/resources/assets/docs/gadem_v1.3.1.tar.gz" ;
    schema1:identifier biotools:gadem ;
    schema1:license "GPL-3.0-or-later" ;
    schema1:name "gadem" ;
    schema1:softwareHelp "https://www.niehs.nih.gov/research/resources/software/biostatistics/gadem/index.cfm" ;
    schema1:softwareVersion "1.3.1" ;
    schema1:url "https://www.niehs.nih.gov/research/resources/software/biostatistics/gadem/index.cfm" ;
    spdx:builtFrom biotools:gadem .

