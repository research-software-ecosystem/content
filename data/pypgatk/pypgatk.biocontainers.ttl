@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:pypgatk a schema1:SoftwareApplication ;
    schema1:description "The Pypgatk framework and library provides a set of tools to perform ProteoGenomics Analysis." ;
    schema1:keywords "Genomics",
        "Peptides",
        "Protein Sequences",
        "Proteomics" ;
    schema1:license "Apache 2" ;
    schema1:name "pypgatk" ;
    schema1:url "http://github.com/bigbio/py-pgatk" .

