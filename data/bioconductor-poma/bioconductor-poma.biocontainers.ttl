@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-poma a schema1:SoftwareApplication ;
    schema1:description "POMA introduces a structured, reproducible and easy-to-use workflow for the visualization, pre-processing, exploratory and statistical analysis of mass spectrometry data. The main aim of POMA is to enable a flexible data cleaning and statistical analysis processes in one comprehensible and user-friendly R package. This package also has a Shiny app version that implements all POMA functions." ;
    schema1:keywords "Mass spectrometry",
        "Metabolomics",
        "Proteomics" ;
    schema1:license "GPL-3.0" ;
    schema1:name "bioconductor-poma" ;
    schema1:url "https://github.com/pcastellanoescuder/POMAShiny" .

