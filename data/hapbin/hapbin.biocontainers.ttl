@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:hapbin a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nature01140",
        "doi:10.1371/journal.pbio.0040072" ;
    schema1:description "Hapbin is a collection of tools for efficiently calculating extended haplotype homozygosity (ehh), the integrated haplotype score (ihs) and the cross population extended haplotype homozogysity (xp-ehh) statistic" ;
    schema1:keywords "Alleles",
        "Chromosomes, Human",
        "Genome, Human",
        "Humans",
        "Physical Chromosome Mapping",
        "Polymorphism, Single Nucleotide",
        "Selection, Genetic" ;
    schema1:license "GPL-3.0" ;
    schema1:name "hapbin" ;
    schema1:url "https://github.com/evotools/hapbin" .

