@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:phylowgs a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s13059-015-0602-8" ;
    schema1:description "Application for inferring subclonal composition and evolution from whole-genome sequencing data" ;
    schema1:keywords "Clone Cells",
        "Cluster Analysis",
        "Computer Simulation",
        "DNA Copy Number Variations",
        "Gene Frequency",
        "Genetic Heterogeneity",
        "Genome, Human",
        "High-Throughput Nucleotide Sequencing",
        "Humans",
        "Mutation",
        "Neoplasms",
        "Phylogeny",
        "Reference Standards" ;
    schema1:license "GPL-3.0" ;
    schema1:name "phylowgs" ;
    schema1:url "https://github.com/morrislab/phylowgs" .

