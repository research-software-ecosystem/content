@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-biobase a schema1:SoftwareApplication ;
    schema1:description "Biobase: Base functions for Bioconductor" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/Biobase_2.70.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/Biobase/Biobase_2.70.0.tar.gz', 'https://bioarchive.galaxyproject.org/Biobase_2.70.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-biobase/bioconductor-biobase_2.70.0_src_all.tar.gz']" ;
    schema1:identifier biotools:biobase ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-biobase" ;
    schema1:softwareVersion "2.70.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/Biobase.html" ;
    spdx:builtFrom biotools:biobase .

