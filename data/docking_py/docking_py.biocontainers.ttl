@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:docking_py a schema1:SoftwareApplication ;
    schema1:description "Docking_py is a python library allowing a simplified use of the smina, vina, qvina2 and qvinaw docking software. docking_py can be easily automatize and scripted." ;
    schema1:license "GNU General Public License v2.0" ;
    schema1:name "docking_py" ;
    schema1:url "https://github.com/samuelmurail/docking_py" .

