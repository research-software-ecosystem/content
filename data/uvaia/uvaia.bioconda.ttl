@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:uvaia a schema1:SoftwareApplication ;
    schema1:description "Reference-based alignment and sequence database search" ;
    schema1:identifier biotools:uvaia ;
    schema1:license "GPLv3" ;
    schema1:name "uvaia" ;
    schema1:softwareVersion "2.0.1" ;
    schema1:url "https://github.com/quadram-institute-bioscience/uvaia" ;
    spdx:builtFrom biotools:uvaia .

