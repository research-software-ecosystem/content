@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:ldhelmet a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1371/journal.pgen.1003090" ;
    schema1:description "Software program for statistical inference of fine-scale crossover recombination rates from population genetic data." ;
    schema1:downloadUrl "https://downloads.sourceforge.net/project/ldhelmet/LDhelmet_v1.10.tgz" ;
    schema1:identifier biotools:LDhelmet ;
    schema1:license "GPL3" ;
    schema1:name "ldhelmet" ;
    schema1:softwareVersion "1.1" ;
    schema1:url "http://sourceforge.net/projects/ldhelmet/" ;
    spdx:builtFrom biotools:LDhelmet .

