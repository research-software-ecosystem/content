biocontainers:ldhelmet a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1371/journal.pgen.1003090" ;
    schema1:description "Software program for statistical inference of fine-scale crossover recombination rates from population genetic data." ;
    schema1:identifier biotools:LDhelmet ;
    schema1:keywords "Africa",
        "Animals",
        "Base Composition",
        "Chromosome Mapping",
        "Chromosomes",
        "Crossing Over, Genetic",
        "DNA replication and recombination",
        "Drosophila melanogaster",
        "Evolution, Molecular",
        "Genetic Variation",
        "Genetics",
        "Genome, Insect",
        "Genomics",
        "Metagenomics",
        "North America",
        "Polymorphism, Single Nucleotide",
        "Recombination, Genetic" ;
    schema1:license "GPL-3.0" ;
    schema1:name "ldhelmet" ;
    schema1:url "http://sourceforge.net/projects/ldhelmet/" .

