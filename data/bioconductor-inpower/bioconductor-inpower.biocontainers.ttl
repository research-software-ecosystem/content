@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-inpower a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "An R package for computing the number of susceptibility SNPs" ;
    schema1:identifier biotools:inpower ;
    schema1:keywords "Computational Biology",
        "DNA polymorphism",
        "Gene Expression Profiling",
        "Genomics",
        "High-Throughput Screening Assays",
        "Nucleic acid sites, features and motifs",
        "Programming Languages",
        "User-Computer Interface" ;
    schema1:license "GPL-2" ;
    schema1:name "bioconductor-inpower" ;
    schema1:url "https://bioconductor.org/packages/3.11/bioc/html/INPower.html" .

