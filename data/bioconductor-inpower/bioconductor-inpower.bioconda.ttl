@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-inpower a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "An R package for computing the number of susceptibility SNPs" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/INPower_1.42.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/INPower/INPower_1.42.0.tar.gz', 'https://bioarchive.galaxyproject.org/INPower_1.42.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-inpower/bioconductor-inpower_1.42.0_src_all.tar.gz']" ;
    schema1:identifier biotools:inpower ;
    schema1:license "GPL-2 + file LICENSE" ;
    schema1:name "bioconductor-inpower" ;
    schema1:softwareVersion "1.42.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/INPower.html" ;
    spdx:builtFrom biotools:inpower .

