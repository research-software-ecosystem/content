@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:rvtests a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btw079" ;
    schema1:description "Rare variant test software for next generation sequencing data" ;
    schema1:identifier biotools:rvtests ;
    schema1:keywords "Animals",
        "Clustering",
        "Genetic Variation",
        "Genetic variation",
        "Genetics",
        "Genotype",
        "High-Throughput Nucleotide Sequencing",
        "Human genetics",
        "Humans",
        "Programming Languages",
        "Sequencing" ;
    schema1:license "GPL" ;
    schema1:name "rvtests" ;
    schema1:url "https://github.com/zhanxw/rvtests" .

