@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:rvtests a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btw079" ;
    schema1:description "Rare variant test software for next generation sequencing data" ;
    schema1:downloadUrl "https://github.com/zhanxw/rvtests/archive/v2.1.0.tar.gz" ;
    schema1:identifier biotools:rvtests ;
    schema1:license "GPL" ;
    schema1:name "rvtests" ;
    schema1:softwareVersion "2.1.0" ;
    schema1:url "https://github.com/zhanxw/rvtests" ;
    spdx:builtFrom biotools:rvtests .

