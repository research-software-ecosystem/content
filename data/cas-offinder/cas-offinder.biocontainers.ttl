@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:cas-offinder a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btu048" ;
    schema1:description "Cas-offinder is opencl based, ultrafast and versatile program that searches for potential off-target sites of crispr/cas-derived rna-guided endonucleases (rgen)." ;
    schema1:keywords "Animals",
        "Bacterial Proteins",
        "Base Sequence",
        "CRISPR-Associated Protein 9",
        "DNA",
        "Endonucleases",
        "Genome, Human",
        "Genome, Plant",
        "Humans",
        "Mice",
        "RNA, Guide",
        "Sequence Analysis, DNA",
        "Time Factors" ;
    schema1:license "BSD licence" ;
    schema1:name "cas-offinder" ;
    schema1:url "https://github.com/snugel/cas-offinder" .

