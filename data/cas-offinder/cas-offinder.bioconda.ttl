@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:cas-offinder a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btu048" ;
    schema1:description "Cas-OFFinder is OpenCL based, ultrafast and versatile program that searches for potential off-target sites of CRISPR/Cas-derived RNA-guided endonucleases (RGEN)." ;
    schema1:downloadUrl "https://github.com/snugel/cas-offinder/archive/refs/tags/2.4.1.tar.gz" ;
    schema1:identifier biotools:cas-offinder ;
    schema1:license "BSD-3-Clause" ;
    schema1:name "cas-offinder" ;
    schema1:softwareHelp "https://github.com/snugel/cas-offinder/blob/2.4.1/README.md" ;
    schema1:softwareVersion "2.4.1" ;
    schema1:url "https://github.com/snugel/cas-offinder" ;
    spdx:builtFrom biotools:cas-offinder .

