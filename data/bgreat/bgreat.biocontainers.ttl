@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bgreat a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/s12859-016-1103-9",
        "doi:abs/1711.03336" ;
    schema1:description "BGREAT2 is a read mapping tool for NGS sequencing data that align reads on a de Bruijn graph. Preliminary version described at https://bmcbioinformatics.biomedcentral.com/articles/10.1186/s12859-016-1103-9 and used in Bcool a short read corrector (https://arxiv.org/abs/1711.03336)" ;
    schema1:keywords "Contig Mapping",
        "Escherichia coli",
        "Genome, Human",
        "Genomics",
        "High-Throughput Nucleotide Sequencing",
        "Humans",
        "Sequence Analysis, DNA" ;
    schema1:license "AGPL-3.0" ;
    schema1:name "bgreat" ;
    schema1:url "https://github.com/Malfoy/BGREAT2" .

