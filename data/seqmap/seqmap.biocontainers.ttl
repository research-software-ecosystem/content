@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:seqmap a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btn429",
        "doi:https://doi.org/10.1093/bioinformatics/btn429" ;
    schema1:description "SeqMap is a tool for mapping large amount of oligonucleotide to the genome." ;
    schema1:identifier biotools:seqmap ;
    schema1:keywords "Base Sequence",
        "Chromosome Mapping",
        "Gene Deletion",
        "Genome",
        "Genomics",
        "Mapping",
        "Mutagenesis, Insertional",
        "Oligonucleotides" ;
    schema1:license "Custom OSS" ;
    schema1:name "seqmap" ;
    schema1:url "http://www-personal.umich.edu/~jianghui/seqmap/" .

