@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-cleaver a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Cleavage of Polypeptide Sequences" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/cleaver_1.48.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/cleaver/cleaver_1.48.0.tar.gz', 'https://bioarchive.galaxyproject.org/cleaver_1.48.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-cleaver/bioconductor-cleaver_1.48.0_src_all.tar.gz']" ;
    schema1:identifier biotools:cleaver ;
    schema1:license "GPL (>= 3)" ;
    schema1:name "bioconductor-cleaver" ;
    schema1:softwareVersion "1.48.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/cleaver.html" ;
    spdx:builtFrom biotools:cleaver .

