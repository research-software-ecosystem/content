@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-cleaver a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Cleavage of Polypeptide Sequences" ;
    schema1:identifier biotools:cleaver ;
    schema1:keywords "Computational Biology",
        "Gene Expression Profiling",
        "Genomics",
        "High-Throughput Screening Assays",
        "Peptides",
        "Programming Languages",
        "Protein sites, features and motifs",
        "Proteomics",
        "User-Computer Interface" ;
    schema1:license "GPL (>= 3)" ;
    schema1:name "bioconductor-cleaver" ;
    schema1:url "https://bioconductor.org/packages/release/bioc/html/cleaver.html" .

