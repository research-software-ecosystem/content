@prefix edam: <http://edamontology.org/> .
@prefix galaxytool: <https://github.com/galaxyproject/tools-iuc/tree/master/tools/> .
@prefix schema1: <http://schema.org/> .

galaxytool:irma a schema1:SoftwareApplication ;
    schema1:description "Iterative Refinement Meta-Assembler (IRMA) is a tool to construct assembly of highly variable RNA viruses." ;
    schema1:featureList edam:operation_0523 ;
    schema1:identifier "bioconda:irma",
        "biotools:irma-virus" ;
    schema1:keywords "Sequence Analysis" ;
    schema1:name "irma" ;
    schema1:softwareVersion "1.2.0" ;
    schema1:url "https://wonder.cdc.gov/amd/flu/irma/irma.html" .

