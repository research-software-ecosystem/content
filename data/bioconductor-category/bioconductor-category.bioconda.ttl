@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-category a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Category Analysis" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/Category_2.76.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/Category/Category_2.76.0.tar.gz', 'https://bioarchive.galaxyproject.org/Category_2.76.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-category/bioconductor-category_2.76.0_src_all.tar.gz']" ;
    schema1:identifier biotools:category ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-category" ;
    schema1:softwareVersion "2.76.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/Category.html" ;
    spdx:builtFrom biotools:category .

