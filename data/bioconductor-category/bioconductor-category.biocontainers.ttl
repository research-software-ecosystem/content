@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-category a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "A collection of tools for performing categoric analysis." ;
    schema1:identifier biotools:category ;
    schema1:keywords "Bioinformatics",
        "Computational Biology",
        "Gene Expression Profiling",
        "Gene expression",
        "Genomics",
        "High-Throughput Screening Assays",
        "Programming Languages",
        "User-Computer Interface" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-category" ;
    schema1:url "http://bioconductor.org/packages/release/bioc/html/Category.html" .

