@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:cell-types-analysis a schema1:SoftwareApplication ;
    schema1:description "A suite of scripts for analysis of scrna-seq cell type classification tools outputs." ;
    schema1:keywords "Gene Expression",
        "RNA-Seq" ;
    schema1:license "Apache-2.0" ;
    schema1:name "cell-types-analysis" ;
    schema1:url "https://github.com/ebi-gene-expression-group/cell-types-analysis" .

