@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:siann a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1101/001727" ;
    schema1:description "Siann was created to allow creation of local small sets of bacterial/viral genomes to perform strain level differentiation from fastq data" ;
    schema1:keywords "Genome" ;
    schema1:license "GPL" ;
    schema1:name "siann" ;
    schema1:url "https://github.com/signaturescience/siann/wiki" .

