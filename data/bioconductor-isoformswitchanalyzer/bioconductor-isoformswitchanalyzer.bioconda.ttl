bioconda:bioconductor-isoformswitchanalyzer a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1158/1541-7786.MCR-16-0459" ;
    schema1:description "Identify, Annotate and Visualize Isoform Switches with Functional Consequences from both short- and long-read RNA-seq data" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.22/bioc/src/contrib/IsoformSwitchAnalyzeR_2.10.0.tar.gz', 'https://bioconductor.org/packages/3.22/bioc/src/contrib/Archive/IsoformSwitchAnalyzeR/IsoformSwitchAnalyzeR_2.10.0.tar.gz', 'https://bioarchive.galaxyproject.org/IsoformSwitchAnalyzeR_2.10.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-isoformswitchanalyzer/bioconductor-isoformswitchanalyzer_2.10.0_src_all.tar.gz']" ;
    schema1:identifier biotools:IsoformSwitchAnalyzeR ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-isoformswitchanalyzer" ;
    schema1:softwareVersion "2.10.0" ;
    schema1:url "https://bioconductor.org/packages/3.22/bioc/html/IsoformSwitchAnalyzeR.html" ;
    spdx:builtFrom biotools:IsoformSwitchAnalyzeR .

