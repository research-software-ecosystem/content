@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-isoformswitchanalyzer a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1158/1541-7786.MCR-16-0459" ;
    schema1:description "Identify, Annotate and Visualize Alternative Splicing and Isoform Switches with Functional Consequences from both short- and long-read RNA-seq data." ;
    schema1:identifier biotools:IsoformSwitchAnalyzeR ;
    schema1:keywords "Base Sequence",
        "Computational biology",
        "Gene Expression Profiling",
        "Gene transcripts",
        "Genomics",
        "Humans",
        "Neoplasms",
        "Protein Isoforms",
        "RNA-Seq",
        "Transcriptome",
        "Transcriptomics" ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "bioconductor-isoformswitchanalyzer" ;
    schema1:url "http://bioconductor.org/packages/3.6/bioc/html/IsoformSwitchAnalyzeR.html" .

