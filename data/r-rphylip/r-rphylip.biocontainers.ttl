@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:r-rphylip a schema1:SoftwareApplication ;
    schema1:description "Rphylip provides an R interface for the PHYLIP package. All users of Rphylip will thus first have to install the PHYLIP phylogeny methods program package (Felsenstein 2013)." ;
    schema1:keywords "Genetics",
        "Phylogenetics" ;
    schema1:license "GPL (>= 2)" ;
    schema1:name "r-rphylip" ;
    schema1:url "https://cran.r-project.org/package=Rphylip" .

