@prefix biocontainers: <https://biocontainers.pro/tools/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

biocontainers:bioconductor-rsamtools a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Binary alignment (BAM), FASTA, variant call (BCF), and tabix file import" ;
    schema1:identifier biotools:rsamtools ;
    schema1:keywords "Computational Biology",
        "Gene Expression Profiling",
        "Genomics",
        "High-Throughput Screening Assays",
        "Programming Languages",
        "RNA-seq",
        "Sequence Alignment",
        "User-Computer Interface" ;
    schema1:license "Artistic-2.0" ;
    schema1:name "bioconductor-rsamtools" ;
    schema1:url "https://bioconductor.org/packages/release/bioc/html/Rsamtools.html" .

