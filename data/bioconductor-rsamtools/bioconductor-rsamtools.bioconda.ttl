@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .
@prefix spdx: <http://spdx.org/rdf/terms/> .

bioconda:bioconductor-rsamtools a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1038/nmeth.3252" ;
    schema1:description "Binary alignment (BAM), FASTA, variant call (BCF), and tabix file import" ;
    schema1:downloadUrl "['https://bioconductor.org/packages/3.20/bioc/src/contrib/Rsamtools_2.22.0.tar.gz', 'https://bioconductor.org/packages/3.20/bioc/src/contrib/Archive/Rsamtools/Rsamtools_2.22.0.tar.gz', 'https://bioarchive.galaxyproject.org/Rsamtools_2.22.0.tar.gz', 'https://depot.galaxyproject.org/software/bioconductor-rsamtools/bioconductor-rsamtools_2.22.0_src_all.tar.gz']" ;
    schema1:identifier biotools:rsamtools ;
    schema1:license "Artistic-2.0 | file LICENSE" ;
    schema1:name "bioconductor-rsamtools" ;
    schema1:softwareVersion "2.22.0" ;
    schema1:url "https://bioconductor.org/packages/3.20/bioc/html/Rsamtools.html" ;
    spdx:builtFrom biotools:rsamtools .

